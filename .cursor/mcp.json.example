{
  "mcpServers": {
    "repomix": {
      "command": "npx",
      "args": ["-y", "repomix", "--mcp"]
    },
    "CodeGraphContext": {
      "command": "/Users/enzo/.local/bin/cgc",
      "args": ["mcp", "start"],
      "_note": "En Linux era /home/enzo/.local/bin/cgc — ajustar al path real del MacBook. Instalar con: pip install codegraphcontext && cgc index /ruta/al/repo"
    },
    "firecrawl": {
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": {
        "FIRECRAWL_API_KEY": "fc-3264903361c64866ad119963f7c5df2a"
      }
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@context7/mcp@latest"]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "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I"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    }
  }
}
