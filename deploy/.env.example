# ═══════════════════════════════════════════════════════════════════
# SDA Framework — Deployment Configuration
# ═══════════════════════════════════════════════════════════════════
#
# Copy this file to .env and adjust for your environment:
#   cp deploy/.env.example deploy/.env
#
# For production, variables marked REQUIRED must be set.
# For development, defaults work out of the box.

# ── Core ─────────────────────────────────────────────────────────

# Domain for Traefik routing, CORS, SMTP, WebSocket origins.
# REQUIRED for production. Dev default: localhost
SDA_DOMAIN=localhost

# Let's Encrypt ACME email for TLS certificates.
# REQUIRED for production.
SDA_ACME_EMAIL=admin@example.com

# Active tenant slug. Used for NATS subjects, DB names, etc.
# REQUIRED for production.
SDA_TENANT_SLUG=dev

# GPU device IDs for SGLang model servers.
# "0" = first GPU, "0,1" = two GPUs, "" = no GPU.
SDA_GPU_DEVICES=0

# Environment: "development" or "production".
SDA_ENV=development

# ── Database ─────────────────────────────────────────────────────

# PostgreSQL password. REQUIRED for production (use strong password).
POSTGRES_PASSWORD=sda_dev

# ── NATS Service Passwords ───────────────────────────────────────
# Each service authenticates to NATS with its own password.
# REQUIRED for production (must match deploy/nats/nats-server.conf).
# Post ADR 025 only three users remain — the monolith + erp + the
# Python extractor.

APP_NATS_PASS=app_dev
ERP_NATS_PASS=erp_dev
EXTRACTOR_NATS_PASS=extractor_dev

# ── LLM / SGLang ────────────────────────────────────────────────

# SGLang LLM server URL (for agent + search services).
SGLANG_LLM_URL=http://host.docker.internal:8102
SGLANG_LLM_MODEL=

# ── Email (SMTP) ────────────────────────────────────────────────

# SMTP server for notification service. REQUIRED for production.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_FROM=noreply@example.com

# ── RAG Server ──────────────────────────────────────────────────

RAG_SERVER_URL=http://host.docker.internal:8081

# ── Alerting (production only) ──────────────────────────────────

# Email for critical severity alerts (Alertmanager → notification → SMTP).
# If not set, critical alerts are persisted in DB but no email is sent.
# ALERT_CRITICAL_EMAIL=ops@example.com

# ── Grafana ─────────────────────────────────────────────────────

GRAFANA_ADMIN_PASSWORD=sda-grafana-dev

# ── Host networking (auto-detected, override for WSL2) ──────────

# Override if auto-detection fails. Usually not needed.
# SDA_HOST_IP=host-gateway

# ── Service Versions (optional, default: latest) ────────────────

# APP_VERSION=latest
# ERP_VERSION=latest
# EXTRACTOR_VERSION=latest
