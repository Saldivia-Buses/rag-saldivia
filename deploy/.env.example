# ═══════════════════════════════════════════════════════════════════
# SDA Framework — Deployment Configuration
# ═══════════════════════════════════════════════════════════════════
#
# Copy this file to .env and adjust for your environment:
#   cp deploy/.env.example deploy/.env
#
# For production, ALL 5 core variables MUST be set.
# For development, defaults work out of the box.

# ── Core (the only 5 you MUST configure for production) ──────────

# Domain for Traefik routing, CORS, SMTP, WebSocket origins.
# Dev: localhost (no HTTPS). Prod: your actual domain.
SDA_DOMAIN=localhost

# Let's Encrypt ACME email for TLS certificates.
# Only used in production (Traefik HTTPS).
SDA_ACME_EMAIL=admin@example.com

# Active tenant slug. Used for NATS subjects, DB names, etc.
SDA_TENANT_SLUG=dev

# GPU device IDs for SGLang model servers.
# "0" = first GPU, "0,1" = two GPUs, "" = no GPU (CPU only).
SDA_GPU_DEVICES=0

# Environment: "development" or "production".
# Controls: HTTPS redirect, ACME, secret requirements, preflight checks.
SDA_ENV=development

# ── Database ─────────────────────────────────────────────────────

POSTGRES_PASSWORD=sda_dev

# ── Alerting (production only) ───────────────────────────────────

# Webhook URL for alerts (Slack, Discord, Telegram).
# SDA_ALERT_WEBHOOK=https://hooks.slack.com/services/xxx/yyy/zzz

# Email for critical alerts.
# SDA_ALERT_EMAIL=admin@example.com

# ── Host networking (auto-detected, override for WSL2) ───────────

# Override if auto-detection fails. Usually not needed.
# SDA_HOST_IP=host-gateway
