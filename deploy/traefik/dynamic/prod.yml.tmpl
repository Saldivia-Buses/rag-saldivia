# Traefik dynamic config for production.
# Extracts tenant slug from subdomain and injects as headers.
# Traffic arrives via Cloudflare Tunnel → Traefik → services.
#
# Subdomain routing: {slug}.$SDA_DOMAIN → X-Tenant-Slug: {slug}
# Services run as Docker containers on the same network.
#
# Post ADR 025: the `app` monolith owns every /v1/* path except
# /v1/erp (erp is still a standalone). Per-prefix routers kept so the
# middleware attachment mirrors the old per-service decisions (auth
# bypasses tenant-from-subdomain; everything else goes through it).
# Once the `app` binary lands under s6-overlay inside the all-in-one
# container this file goes away — the frontdoor / chi router takes
# over that role.

http:
  routers:
    # Auth — login, token refresh (no tenant context needed)
    auth:
      rule: "PathPrefix(`/v1/auth`) || PathPrefix(`/v1/modules`)"
      service: app
      entryPoints: [web]
      middlewares: [rate-limit, cors]

    # WebSocket — real-time channel
    ws:
      rule: "PathPrefix(`/ws`)"
      service: app
      entryPoints: [web]
      middlewares: [strip-spoofed-headers, tenant-from-subdomain, rate-limit, cors]

    # Chat — sessions + messages
    chat:
      rule: "PathPrefix(`/v1/chat`)"
      service: app
      entryPoints: [web]
      middlewares: [strip-spoofed-headers, tenant-from-subdomain, rate-limit, cors]

    # Agent — LLM runtime + tool execution
    agent:
      rule: "PathPrefix(`/v1/agent`)"
      service: app
      entryPoints: [web]
      middlewares: [strip-spoofed-headers, tenant-from-subdomain, rate-limit, cors]

    # Search — tree-based document retrieval
    search:
      rule: "PathPrefix(`/v1/search`)"
      service: app
      entryPoints: [web]
      middlewares: [strip-spoofed-headers, tenant-from-subdomain, rate-limit, cors]

    # Traces — execution traces + cost tracking
    traces:
      rule: "PathPrefix(`/v1/traces`)"
      service: app
      entryPoints: [web]
      middlewares: [strip-spoofed-headers, tenant-from-subdomain, rate-limit, cors]

    # Feedback — quality metrics + alerts
    feedback:
      rule: "PathPrefix(`/v1/feedback`) || PathPrefix(`/v1/platform/feedback`)"
      service: app
      entryPoints: [web]
      middlewares: [strip-spoofed-headers, tenant-from-subdomain, rate-limit, cors]

    # Notifications
    notifications:
      rule: "PathPrefix(`/v1/notifications`)"
      service: app
      entryPoints: [web]
      middlewares: [strip-spoofed-headers, tenant-from-subdomain, rate-limit, cors]

    # Platform — admin-only (platform.$SDA_DOMAIN)
    platform:
      rule: "Host(`platform.$SDA_DOMAIN`) && PathPrefix(`/v1/platform`)"
      service: app
      entryPoints: [web]
      middlewares: [rate-limit, cors]

    # Feature flags evaluate — any authenticated user
    flags:
      rule: "PathPrefix(`/v1/flags`)"
      service: app
      entryPoints: [web]
      middlewares: [strip-spoofed-headers, tenant-from-subdomain, rate-limit, cors]

    # Ingest — document upload
    ingest:
      rule: "PathPrefix(`/v1/ingest`)"
      service: app
      entryPoints: [web]
      middlewares: [strip-spoofed-headers, tenant-from-subdomain, rate-limit, cors]

    # ERP — legacy Histrix replacement modules (still standalone)
    erp:
      rule: "PathPrefix(`/v1/erp`)"
      service: erp
      entryPoints: [web]
      middlewares: [strip-spoofed-headers, tenant-from-subdomain, rate-limit, cors]

  services:
    app:
      loadBalancer:
        servers:
          - url: "http://app:8020"
    erp:
      loadBalancer:
        servers:
          - url: "http://erp:8013"

  middlewares:
    # Strip client-spoofed tenant headers before processing
    strip-spoofed-headers:
      headers:
        customRequestHeaders:
          X-Tenant-Slug: ""
          X-Tenant-ID: ""

    # Extract tenant slug from subdomain via regex.
    # saldivia.$SDA_DOMAIN → X-Tenant-Slug: saldivia
    # Only allows valid slugs: lowercase alphanumeric + hyphens, max 63 chars
    tenant-from-subdomain:
      plugin:
        rewriteHeaders:
          rewrites:
            - header: "Host"
              regex: "^([a-z0-9][a-z0-9-]{0,62})\\.$SDA_DOMAIN_ESCAPED$"
              replacement: "$1"
              targetHeader: "X-Tenant-Slug"

    # Rate limiting per client IP
    rate-limit:
      rateLimit:
        average: 100
        burst: 200
        period: 1s

    # CORS for frontend domains
    cors:
      headers:
        accessControlAllowMethods:
          - GET
          - POST
          - PUT
          - PATCH
          - DELETE
          - OPTIONS
        accessControlAllowHeaders:
          - Authorization
          - Content-Type
          - X-Tenant-Slug
        accessControlAllowOriginListRegex:
          - "$SDA_CORS_REGEX"
        accessControlMaxAge: 3600
        accessControlAllowCredentials: true
