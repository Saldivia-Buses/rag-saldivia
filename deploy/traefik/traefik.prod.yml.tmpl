# Traefik static configuration for production.
# Dynamic routing is in deploy/traefik/dynamic/prod.yml

entryPoints:
  web:
    address: ":80"
    http:
      redirections:
        entryPoint:
          to: websecure
          scheme: https
  websecure:
    address: ":443"

certificatesResolvers:
  cloudflare:
    acme:
      email: $SDA_ACME_EMAIL
      storage: /etc/traefik/acme/acme.json
      dnsChallenge:
        provider: cloudflare

providers:
  # Docker labels are the sole source of routing in production.
  # File provider removed (C5/C6 fix): Docker labels on each service define
  # routers with correct entryPoints (websecure) and TLS config.
  # The dynamic/prod.yml.tmpl is kept for reference but not loaded.
  docker:
    exposedByDefault: false

api:
  dashboard: false

log:
  level: WARN

accessLog:
  filePath: /var/log/traefik/access.log
  bufferingSize: 100
