{
  "uid": "sda-service-map",
  "title": "SDA Service Map",
  "tags": ["sda", "plan14"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-5m", "to": "now" },
  "editable": true,
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "title": "Service Status",
      "type": "table",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count by (service_name) (rate(http_server_request_duration_seconds_count[5m]) > 0)",
          "legendFormat": "{{ service_name }}",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "service_name": "Service",
              "Value": "Status (1=UP)"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    },
    {
      "id": 2,
      "title": "Request Rate (per service)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (service_name) (rate(http_server_request_duration_seconds_count[5m]))",
          "legendFormat": "{{ service_name }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate (5xx per service)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (service_name) (rate(http_server_request_duration_seconds_count{http_status_code=~\"5..\"}[5m]))",
          "legendFormat": "{{ service_name }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 30 } }
      }
    },
    {
      "id": 4,
      "title": "Container Restarts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "increase(container_restart_count[1h])",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      }
    }
  ]
}
