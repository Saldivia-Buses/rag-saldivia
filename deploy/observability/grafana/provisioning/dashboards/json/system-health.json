{
  "uid": "sda-system-health",
  "title": "SDA System Health",
  "tags": ["sda"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "editable": true,
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "custom",
        "label": "Service",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "options": [
          { "text": "All", "value": "$__all", "selected": true },
          { "text": "sda-auth", "value": "sda-auth", "selected": false },
          { "text": "sda-ws", "value": "sda-ws", "selected": false },
          { "text": "sda-chat", "value": "sda-chat", "selected": false },
          { "text": "sda-agent", "value": "sda-agent", "selected": false },
          { "text": "sda-search", "value": "sda-search", "selected": false },
          { "text": "sda-astro", "value": "sda-astro", "selected": false },
          { "text": "sda-notification", "value": "sda-notification", "selected": false },
          { "text": "sda-platform", "value": "sda-platform", "selected": false },
          { "text": "sda-ingest", "value": "sda-ingest", "selected": false },
          { "text": "sda-feedback", "value": "sda-feedback", "selected": false },
          { "text": "sda-traces", "value": "sda-traces", "selected": false }
        ],
        "includeAll": true,
        "multi": true,
        "query": "sda-auth,sda-ws,sda-chat,sda-agent,sda-search,sda-astro,sda-notification,sda-platform,sda-ingest,sda-feedback,sda-traces"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Service Status",
      "description": "UP if the service has handled requests in the last 5 minutes",
      "type": "stat",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service_name) (rate(http_server_request_duration_seconds_count{service_name=~\"$service\"}[5m])) > 0",
          "legendFormat": "{{service_name}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null",
                "result": { "text": "DOWN", "color": "red" }
              }
            },
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 0.0001, "color": "green" }
            ]
          },
          "noValue": "DOWN"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "name",
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 2,
      "title": "Request Rate",
      "description": "Requests per second per service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service_name) (rate(http_server_request_duration_seconds_count{service_name=~\"$service\"}[1m]))",
          "legendFormat": "{{service_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 3,
      "title": "Latency P50 / P95 / P99",
      "description": "Response time percentiles across all services",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "refId": "P50",
          "expr": "histogram_quantile(0.50, sum by (le, service_name) (rate(http_server_request_duration_seconds_bucket{service_name=~\"$service\"}[5m])))",
          "legendFormat": "p50 {{service_name}}"
        },
        {
          "refId": "P95",
          "expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(http_server_request_duration_seconds_bucket{service_name=~\"$service\"}[5m])))",
          "legendFormat": "p95 {{service_name}}"
        },
        {
          "refId": "P99",
          "expr": "histogram_quantile(0.99, sum by (le, service_name) (rate(http_server_request_duration_seconds_bucket{service_name=~\"$service\"}[5m])))",
          "legendFormat": "p99 {{service_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 5,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 4,
      "title": "Error Rate (5xx)",
      "description": "Rate of server errors per service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service_name) (rate(http_server_request_duration_seconds_count{http_status_code=~\"5..\", service_name=~\"$service\"}[1m]))",
          "legendFormat": "{{service_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "color": { "mode": "palette-classic" },
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.1, "color": "yellow" },
              { "value": 1, "color": "red" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 5,
      "title": "Active Requests",
      "description": "Current in-flight requests per service",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service_name) (http_server_active_requests{service_name=~\"$service\"})",
          "legendFormat": "{{service_name}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 50, "color": "yellow" },
              { "value": 100, "color": "red" }
            ]
          },
          "min": 0,
          "max": 150
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      }
    }
  ]
}