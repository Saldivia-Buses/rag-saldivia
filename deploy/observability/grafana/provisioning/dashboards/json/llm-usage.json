{
  "uid": "sda-llm-usage",
  "title": "SDA LLM Usage",
  "tags": ["sda", "plan14", "llm"],
  "timezone": "browser",
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "editable": true,
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "title": "Total Tokens (Input + Output)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(sda_llm_tokens_total)",
          "legendFormat": "Total Tokens",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 2,
      "title": "Tokens by Direction",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (direction) (sda_llm_tokens_total)",
          "legendFormat": "{{ direction }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Queries per Hour",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(sda_queries_total[1h])) * 3600",
          "legendFormat": "Queries/hr",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Token Consumption Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (model) (rate(sda_llm_tokens_total[5m])) * 300",
          "legendFormat": "{{ model }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } }
      }
    },
    {
      "id": 5,
      "title": "LLM Latency P50 / P95 / P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(sda_llm_request_duration_seconds_bucket[5m])))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(sda_llm_request_duration_seconds_bucket[5m])))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(sda_llm_request_duration_seconds_bucket[5m])))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 6,
      "title": "Tokens by Tenant",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (tenant_slug) (sda_llm_tokens_total)",
          "legendFormat": "{{ tenant_slug }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ]
}
