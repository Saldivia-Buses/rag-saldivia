# Cloudflare Tunnel configuration for SDA Framework.
# Routes *.$SDA_DOMAIN traffic to the local Traefik gateway.
#
# Setup:
#   1. cloudflared tunnel create sda
#   2. cloudflared tunnel route dns sda "*.$SDA_DOMAIN"
#   3. Copy credentials JSON to deploy/secrets/cloudflared-credentials.json
#   4. cloudflared tunnel --config deploy/cloudflare/config.yml run sda
#
# The tunnel exposes Traefik (:80) to the internet without opening ports.
# Traefik handles tenant routing via subdomain extraction.

tunnel: sda
credentials-file: /etc/cloudflared/credentials.json

ingress:
  # Platform admin subdomain (specific rules BEFORE wildcards)
  - hostname: platform.$SDA_DOMAIN
    service: http://traefik:80
    originRequest:
      noTLSVerify: true
      connectTimeout: 10s

  # WebSocket traffic — needs special handling
  - hostname: "*.$SDA_DOMAIN"
    path: /ws
    service: http://traefik:80
    originRequest:
      noTLSVerify: true
      connectTimeout: 10s
      httpHostHeader: ""

  # All other traffic → Traefik
  - hostname: "*.$SDA_DOMAIN"
    service: http://traefik:80
    originRequest:
      noTLSVerify: true
      connectTimeout: 10s

  # Catch-all (required by cloudflared)
  - service: http_status:404
