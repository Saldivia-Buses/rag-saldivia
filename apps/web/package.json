{
  "name": "@rag-saldivia/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "tsc --noEmit",
    "lint:next": "next lint",
    "test": "bun test src/lib",
    "test:coverage": "bun test src/lib --coverage",
    "type-check": "tsc --noEmit",
    "test:components": "bun test --preload ./src/lib/component-test-setup.ts src/components",
    "test:visual": "playwright test tests/visual",
    "visual:update": "playwright test tests/visual --update-snapshots",
    "visual:show": "playwright show-report",
    "test:a11y": "playwright test tests/a11y --config playwright.a11y.config.ts",
    "test:ui": "bun run test:components && bun run test:visual",
    "test:components:watch": "bun test --preload ./src/lib/component-test-setup.ts src/components --watch",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
