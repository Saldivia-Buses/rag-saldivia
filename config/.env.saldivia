# RAG Saldivia — Shared config overrides
# Only values that differ from NVIDIA RAG Blueprint v2.5.0 defaults.
# Secrets go in .env.local (not tracked).

# --- Hybrid Search ---
APP_VECTORSTORE_SEARCHTYPE=hybrid
APP_VECTORSTORE_RANKER_TYPE=rrf
APP_VECTORSTORE_INDEXTYPE=HNSW
APP_VECTORSTORE_ENABLEGPUSEARCH=False
APP_VECTORSTORE_ENABLEGPUINDEX=False

# --- Retriever Tuning ---
VECTOR_DB_TOPK=100
APP_RETRIEVER_TOPK=25

# --- NV-Ingest ---
APP_NVINGEST_EXTRACTIMAGES=True
APP_NVINGEST_EXTRACTTABLES=True
APP_NVINGEST_EXTRACTCHARTS=True
ENABLE_NV_INGEST_PARALLEL_BATCH_MODE=False

# --- VLM Captioning ---
APP_VLM_MAX_TOKENS=1024
APP_VLM_TEMPERATURE=0.3
APP_NVINGEST_CAPTIONMODELNAME=qwen3-vl-8b
APP_NVINGEST_CAPTIONENDPOINTURL=http://qwen3-vl-8b:8000/v1/chat/completions
VLM_CAPTION_ENDPOINT=http://qwen3-vl-8b:8000/v1/chat/completions
VLM_CAPTION_MODEL_NAME=qwen3-vl-8b
APP_VLM_MODELNAME=qwen3-vl-8b
APP_VLM_SERVERURL=http://qwen3-vl-8b:8000/v1

# --- Features ---
ENABLE_VLM_INFERENCE=false
ENABLE_SOURCE_METADATA=true
FILTER_THINK_TOKENS=true
ENABLE_QUERY_DECOMPOSITION=false
ENABLE_QUERYREWRITER=False
ENABLE_CITATIONS=False
CONVERSATION_HISTORY=0

# --- Paths ---
PROMPT_CONFIG_FILE=/opt/rag-saldivia/prompt.yaml

# --- SDA Frontend ---
SDA_ORIGIN=https://sda.tecpia.local
