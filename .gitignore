# ============================================================
# SDA Framework .gitignore
# ============================================================

# --- Secrets ---
.env.local
.env.merged
.env.blueprint
.env.build
*.key
*.pem
deploy/secrets/dynamic/
# All secrets EXCEPT README and .gitkeep — never commit real secret material
deploy/secrets/*
!deploy/secrets/README.md
!deploy/secrets/.gitkeep
!deploy/secrets/dynamic
config/*.env.*
deploy/.env

# --- Claude Code harness state (per-machine, not repo-shared) ---
.claude/projects/

# --- Stray root-level Go build artifacts ---
/cmd

# --- Generated configs (from .tmpl templates via gen-config.sh) ---
deploy/traefik/traefik.prod.yml
deploy/traefik/dynamic/prod.yml
deploy/cloudflare/config.yml

# --- Go ---
# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
/bin/
**/bin/
# Build cache
vendor/
# Test output
*.test
*.out
cover.html
coverage.out
**/coverage.out

# --- Node/Frontend ---
node_modules/
.next/
out/
*.tsbuildinfo
.turbo/
**/.turbo/
bun.lock

# --- Docker ---
docker-compose.override.yml

# --- Data (never commit) ---
data/
dump.rdb
*.db
*.db-shm
*.db-wal

# --- Logs ---
logs/
**/logs/
*.log

# --- Test artifacts ---
test-results/
**/test-results/
playwright-report/
**/playwright-report/
.playwright-mcp/

# --- MCP config (contains API keys) ---
.mcp.json

# --- IDE ---
.vscode/
.idea/
.cursor/
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db

# --- Runtime ---
*.pid
*.server-info
*.server-stopped

# --- Blueprint (cloned by setup, not tracked) ---
blueprint/

# --- Internal artifacts ---
.superpowers/
docs/superpowers/
_archive/

# --- Screenshots ---
*.png
!apps/web/public/**/*.png
!apps/login/public/**/*.png
apps/web/.firecrawl/
config/.env.saldivia
config/.env.*
firecrawl/
.firecrawl/
.claude/settings.local.json
