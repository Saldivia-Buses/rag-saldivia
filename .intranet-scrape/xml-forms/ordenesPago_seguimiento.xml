<?xml version="1.0" encoding="UTF-8"?>
<histrix modifica="true"  tabindex="1000" tipo="abm-mini" borra="true" subtipo="vertical" imprime="false">
	<title>Entregas</title>
	<obs/>
	<form>
		<table id="REG_MOVIMIENTO_OBS" _label="OBSERVACIONES">
			<field id="fec_observacion">
				<label>Fecha</label>
				<help>Fecha de la observación</help>
				<tipo>date</tipo>
				<valor>today</valor>
			</field>
			<field id="hora_observacion">
				<label>Hora</label>
				<help>Hora de la observación</help>
				<tipo>hora</tipo>
				<valor eval="true">date("H:i:s")</valor>
			</field>
			<field id="gencontacto_id">
				<helper type="combo" id="TIPO_MED_CONTACTO" empty="true">
					<field id="id_tipo"/>
					<field id="descripcion"/>
				</helper>
				<label>Tipo Contacto</label>
			</field>
			<field id="observacion" cellMaxLength="50">
				<label>Observación</label>
				<help>Observación</help>
				<size>200</size>
			</field>
			<field id="regmovim_id" noshow="true"/>
			<field id="tabla_origen" noshow="true"/>
			<field id="siscod" noshow="true"/>
			<field id="movfec" noshow="true"/>
			<field id="ctacod" noshow="true"/>
			<field id="concod" noshow="true"/>
			<field id="movnpv" noshow="true"/>
			<field id="movnro" noshow="true"/>

			<field id="login" noshow="true">
                <valor eval="true">$_SESSION['usuario']</valor>
				<label Formstyle="display:none;">Usuario</label>
				<tipo>varchar</tipo>
			</field>
		</table>
	</form>
</histrix>

