<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" class="consultaancha" tableHeight="40em">
  <title>Movimientos Mensuales</title>
  <obs/>
  <consulta>
    <table id="CTB_MOVIMIENTOS" label="movimientos">

      <field id="nro_minuta" noshow="true">
        <label>Nro minuta</label>
        <help>Numero de la minuta</help>
      </field>
      
      <field id="id_detalle" tabla="CTB_DETALLES" noshow="true" />

      <field id="concepto_id" noshow="true" />

      <field id="cuenta_id" tabla="CTB_DETALLES" noshow="true">
        <label>Cuenta</label>
      </field>
      <field id="regmovim_id" noshow="true" />
      <field id="id_movimiento" noshow="true">
        <label>Codigo</label>
        <help>Código de movimiento</help>
      </field>
	      
      <field id="estcod" tabla="REG_CUENTA" noshow="true" >
	<expression having="false">ifnull(estcod, 0)</expression>
	<condicion operador="=">0</condicion>
      </field>
      
      <field id="nro_minuta" >
        <label>Minuta</label>
	</field>
      <field id="fecha_movimiento" >
        <label>Fecha Reg.</label>
        <help>Fecha movimiento</help>
<!--        <condicion operador="&gt;=">'[__fecha_minima__]' and CTB_MOVIMIENTOS.fecha_movimiento &lt;= '[__fecha_maxima__]'</condicion> -->
      </field>
      <field id="ctanom" tabla="REG_CUENTA">
        <label>Cuenta</label>
	<expression>nombre_cuenta</expression>
      </field>
      <field id="fecha_mov" >
        <label>Fecha Comp.</label>
        <help>Fecha movimiento</help>
	<expression>REG_MOVIMIENTOS.fecha_movimiento</expression>
	<tipo>date</tipo>
      </field>

      <field id="concepto">
        <label>Conc</label>
	<expression>REG_CONCEPTOS.abreviacion_concepto</expression>
      </field>

      <field id="nro_movimiento" tabla="REG_MOVMIENTO">
        <label>Comprobante</label>
	<expression>concat(lpad(puesto_movimiento, 4, '0'), '-',lpad(nro_movimiento, 8, '0'))</expression>
      </field>

      <field id="referencia" >
        <label>Referencia</label>
      </field>

      
      <field id="mes" noshow="true" _break="true">
        <expresion having="false">MONTH(CTB_MOVIMIENTOS.fecha_movimiento)</expresion>
      </field>

      <field id="anio" noshow="true">
        <expresion having="false">YEAR(CTB_MOVIMIENTOS.fecha_movimiento)</expresion>
      </field>

      <!--
      <field id="debe" suma="true" noZero="true" acumula="true">
        <expresion>sum(case when doh = 0 then importe else 0 end)</expresion>
        <label>Debe</label>
        <tipo>cumtom_numeric</tipo>
      </field>
      
      <field id="haber" suma="true" noZero="true" acumula="true">
        <expresion>sum(case when doh = 1 then importe else 0 end)</expresion>
        <label>Haber</label>
        <tipo>custom_numeric</tipo>
      </field>
	-->
      <field id="diferencia" suma="true">
        <expresion>sum(round(importe, 2) * (case when doh = 0 then 1 else -1 end))</expresion>
        <label>Importe</label>
        <tipo>custom_numeric</tipo>
      </field>
      <field id="importancia">
    	    <expresion>sum(round(importe, 2) * (case when doh = 0 then 1 else -1 end))</expresion>
	    <tipo>grafico</tipo>
      </field>
      


    
      <field id="ejercicio_id" noshow="true" />

      <field id="fecha_minima" noshow="true" local="true" />
      <field id="fecha_maxima" noshow="true" local="true" />
      <field id="regcuenta_id" tabla="REG_MOVIMIENTOS" noshow="true">
      </field>

      <group>
        <field id="id_movimiento"/>
      </group>
      <order>
        <field id="fecha_movimiento"/>
      </order>
    </table>
    <join tipo="left">
      <table id="REG_MOVIMIENTOS">
        <field id="id_regmovim">
          <condicion operador="=">CTB_MOVIMIENTOS.regmovim_id</condicion>
        </field>
      </table>
    </join>
    <join tipo="left">
      <table id="REG_CUENTA">
        <field id="id_regcuenta">
          <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
        </field>
      </table>
    </join>
    <join tipo="left">
      <table id="REG_CONCEPTOS">
        <field id="id_concepto">
          <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
        </field>
      </table>
    </join>
<!--    <join tipo="inner">
      <table id="CTB_CONCEPTOS">
        <field id="id_concepto">
          <condicion operador="=">CTB_MOVIMIENTOS.concepto_id</condicion>
        </field>
      </table>
    </join>
-->
    <join tipo="left">
      <table id="CTB_DETALLES">
        <field id="movimiento_id">
          <condicion operador="=">id_movimiento</condicion>
        </field>
      </table>
    </join>
  </consulta>
</histrix>
