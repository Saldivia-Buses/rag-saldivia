    </table>
<!--
    <join>
      <table id="CTB_CONCEPTOS">
        <field id="id_concepto">
          <condicion operador="=">concepto_id</condicion>
        </field>
      </table>
    </join>
-->
    <join tipo="left">
      <table id="CTB_DETALLES">
        <field id="cuenta_id">
          <condicion operador="=">ctbcod</condicion>
        </field>
      </table>
    </join>
    <join tipo="left">
      <table id="CTB_MOVIMIENTOS">
        <field id="id_movimiento">
          <condicion operador="=">CTB_DETALLES.movimiento_id</condicion>
        </field>
      </table>
    </join>

    <join tipo="left">
      <table id="REG_MOVIMIENTOS">
        <field id="id_regmovim">
          <condicion operador="=">CTB_MOVIMIENTOS.regmovim_id</condicion>
        </field>
      </table>
    </join>
    <join tipo="left">
      <table id="REG_CUENTA">
        <field id="id_regcuenta">
          <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
        </field>
      </table>
    </join>
    <join>
      <table id="CTB_CUENTA_GRUPO">
        <field id="ctbcuenta_id">
          <condicion operador="=">CTB_DETALLES.cuenta_id</condicion>
        </field>
      </table>
    </join>
    <join>
      <table id="CTB_GRUPO_REPORTE">
        <field id="id_ctbgrupo">
          <condicion operador="=">ctbgrupo_id</condicion>
        </field>
      </table>
    </join>
  </consulta>
</histrix>
