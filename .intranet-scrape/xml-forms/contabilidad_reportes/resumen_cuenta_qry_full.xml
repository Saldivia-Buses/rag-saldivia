     <field id="ene"  suma="true" noZero="true" style="text-align:right;">
	<attribute id="linkdes">nombre_cuenta</attribute>
	<helper xml="movimientos_mensuales_agrup.xml" type="link" width="80%">
	    <parameter source="1" target="mes" />
	    <parameter source="anio" target="anio" />
	    <parameter source="cuenta_id" target="cuenta_id" />
	    <parameter source="ctbcentro_id" target="ctbcentro_id" operator="in"/>
	    <parameter source="prov_id" target="prov_id" /> 
	</helper>
        <expresion>sum( (case when month(CTB_MOVIMIENTOS.fecha_movimiento) = 1  then round(importe, 2) * (case when doh = 1 then -1 else 1 end) else 0 end))</expresion>
        <label>Ene</label>
        <tipo>custom_numeric</tipo>
     </field>
