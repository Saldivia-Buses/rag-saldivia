<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" _conBusqueda="true" _imprimetanda="true" pageBreak="true" _imprime="false" _preloadData="false">
  <title>Movimientos</title>
  <obs/>
  <consulta _detalle="movimientos_cuenta_expand.xml" _inline="true">

    <table id="CTBCUENT" label="Libro Mayor">

      <filters>

        <field id="anio" deshabilitado="false">
          <valor eval="true">date('Y')</valor>
          <operador>=</operador>
          <label modpos="nobr">Año</label>
        </field>

      <field id="ctbgrupo_id">
	    <label>Grupo</label>
	    <operador>=</operador>
	</field>
          <field id="ctbcentro_id"  modpos="nobr" deshabilitado="false" noshow="true">
	    <label>Centro de costos</label>
	  </field>
      <field id="cuenta_contable" deshabilitado="false" colspan="4">
        <label>Codigo cuenta</label>
	    <operador>=</operador>
	    <detalle>cuenta_id</detalle>
      </field>
      <field id="id_regcuenta" copia="prov_id" colspan="4">
        <label>Proveedor</label>
	    <operador>=</operador>
      </field>

      <field id="nombre_cuenta2"  deshabilitado="true" modpos="nobr">
      </field>

      <field id="prov_id"  deshabilitado="true">
      </field>

<!--
      <field id="estcod" local="true">
	    <label>Prov. NO Influye Costo</label>
	    <operador>=</operador>
      </field>
-->
      </filters>

      <fieldGroup>
      <field id="ctbgrupo_id" tabla="CTB_CUENTA_GRUPO" noshow="true" multiple="true">
	    <helper id="CTB_GRUPO_REPORTE" type="combo">
		<field id="id_ctbgrupo" />
		<field id="nombre_grupo_reporte" />
	    </helper>
      </field>

      <field id="estcod" tabla="REG_CUENTA" noshow="true" >
	    <expression having="false">ifnull(estcod, 0)</expression>
	<condicion operador="=">0</condicion>
	<tipo>check</tipo>
      </field>
      <field id="id_regcuenta" tabla="REG_CUENTA" noshow="true" multiple="true">
        <label>Proveedor</label>
        <helper type="combo" xml="regcuenta_simple_qry.xml" dir="/ayudas" empty="true" >
	    <field id="nombre_cuenta2" noshow="true">
		<expression>nombre_cuenta</expression>
		<detalle>nombre_cuenta2</detalle>
	    </field>
	    <field id="subsistema_id">
		<condicion operador="=">'01'</condicion>
	    </field>
	</helper>
      </field>

      <field id="id_movimiento" noshow="true" tabla="CTB_MOVIMIENTOS"/>

      <field id="concepto_id" noshow="true"  tabla="CTB_MOVIMIENTOS">
        <helper type="combo" xml="ctbconcepto_qry.xml" dir="/ayudas" />
        <label>Concepto</label>
        <detalle>concepto_id</detalle>
      </field>

      <field id="fecha_movimiento" noshow="true"  tabla="CTB_MOVIMIENTOS"/>

      <field id="cuenta_contable" tabla="CTB_DETALLES"  multiple="true" noshow="true">
	    <expression having="false">CTB_DETALLES.cuenta_id</expression>
        <label>Cuenta</label>
<!--        <helper type="external" xml="cuentas_habilitadas_qry.xml" dir="/ayudas" empty="true" /> -->

        <helper type="combo" id="CTBCUENT"  dir="/ayudas" empty="true" >
		<field id="ctbcod">
		    <detalle>cuenta_id</detalle>
		</field>
		
		<field id="nombres">
		    <expression having="false">concat(ctbcod, ' ', ctbnom)</expression>
		</field>
		
		<field id="ctbhab" noshow="true">
			<condicion operador="=">1</condicion>
		</field>
			<!--
		<field id="ejercicio_id" noshow="true">
			<condicion operador="=">(select id_ejercicio from CTB_EJERCICIOS where activo = 1 limit 1)</condicion>
		</field>
			
		<field id="tipo_id" noshow="true" />
-->
		<order>
			<field id="nombres" />
		</order>

	</helper>

        <detalle>cuenta_id</detalle>
      </field>
      <field id="nombre_cuenta2" local="true" noshow="true" style="color:red;font-weight:bold; ">
	<size>60</size>
      </field>

      <field id="cuenta_id">
	<expression>cuenta_id</expression>
        <detalle>cuenta_id</detalle>

        <helper type="link" xml="movimientos_cuenta_expand.xml" width="95%">
	    <parameter source="cuenta_id" target="cuenta_id"  />
	    <parameter source="anio" target="anio" />
	    <parameter source="ctbcentro_id" target="ctbcentro_id" operator="in"/>
<!--	    <parameter source="regcuenta_id" target="id_regcuenta" operator="in"/> -->
	</helper>
      </field>

      <field id="nombre_cuenta" >
        <label>Nombre Cuenta</label>
	<expression>ctbnom</expression>
      </field>
      <field id="xcentro_id" noZero="true">
        <label>C.Costos</label>
	<expression>count(distinct ifnull(ctbcentro_id, 0)) - 1</expression>

        <helper type="link" xml="movimientos_cuenta_expand_por_centro.xml" width="95%">
	    <parameter source="cuenta_id" 	target="cuenta_id" />
	    <parameter source="anio" 		target="anio" />
	    <parameter source="ctbcentro_id" 	target="ctbcentro_id" operator="in"/>
	</helper>
        <detalle>cuenta_id</detalle>
      </field>

