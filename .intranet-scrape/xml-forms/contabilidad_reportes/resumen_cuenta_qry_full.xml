          <field id="ctbcentro_id" modpos="nobr" _required="true" noshow="true">
	    <expression having="false">ctbcentro_id</expression>
	    <label>Centro de costos</label>
            <helper id="CTB_CENTROS"  type="combo" empty="true" multiple="true">
<!--	    <option value="0">Sin Asignar</option> -->
              <field id="id_ctbcentro" />
              <field id="centro">
                <expression>concat(referencia_centro,' ', nombre_centro)</expression>
              </field> 
            </helper>
          </field>

    </fieldGroup>
    <fieldGroup style="text-align:right;">
      <field id="prov_id"  deshabilitado="true" local="true" noshow="true">
