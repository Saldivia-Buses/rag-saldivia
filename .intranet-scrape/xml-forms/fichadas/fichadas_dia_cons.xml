				<jseval campodestino="fechaChar">\'fecha\'.substring(0,6) + \'fecha\'.substring(8,10)</jseval>

			</campo>	
			<campo id="hora">
				<label>Hora</label>
				<tipo>varchar</tipo>
				<jseval campodestino="fechaChar">\'fecha\'.substring(0,6) + \'fecha\'.substring(8,10)</jseval>
				<help>Hora</help>
				<jsfunction event="onchange">if ($('crc').value == ''){$('crc').value= this.value};</jsfunction>
			</campo>			
			<campo id="borrado" >
				<label>Borrado</label>
				<opciones>
					<opcion valor="0">NO</opcion>
					<opcion valor="1">SI</opcion>
					
				</opciones>
				<tipo>radio</tipo>

			</campo>

