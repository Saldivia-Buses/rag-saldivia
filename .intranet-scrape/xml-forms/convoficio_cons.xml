					</field>
<!--					<field id="Id_area">
						<condicion operador="=">1</condicion>
					</field> -->
				</tabla_ex>
<!--				<actualiza>
					<field destino="IdCateg" id="IdConvenio"/>
				</actualiza> -->
			
			</field>
			<field id="actividad" tabla="CATPERSONAL">
				<label>Desc.Categ-</label>
				<tipo>varchar</tipo>
			</field>
		<!--	<field id="IdConvenio" oculto="true">
				<label>Convenio</label>
				<tabla_ex id="CONVENIOS">
					<field id="IdConvenio"/>
					<field id="descripcion"/>
