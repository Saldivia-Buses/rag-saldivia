		<join>
			<table id="CATPERSONAL">
				<field id="IdSindicato">
					<condicion operador="=">RH_CONVOFICIO.IdSindicato</condicion>
				</field>				
				<field id="IdCateg">
					<condicion operador="=">RH_CONVOFICIO.IdCateg</condicion>
				</field>
			</table>
