						<condicion operador="=">1</condicion>
					</field>
				</tabla_ex>
				<valor>1</valor>
			</field> -->
			<field id="idOficio" >
				<label style="color:red;font-weight:bold;">Oficio</label>
				<tabla_ex id="RH_OFICIOS">
					<field id="idOficio"/>
					<field id="descripcion"/>
				</tabla_ex>
	
				
			</field>
			<field id="tareas">
				<label style="font-size:15px;">Tareas</label>
				<help>Tareas</help>
				<size>250</size>
				<tipo>varchar</tipo>
			</field>
			<filters>
				<field id="IdSindicato">
					<label>Sindicato</label>
					<tabla_ex id="SINDICATO">
						<field id="IdSindicato"/>
						<field id="Nombre"/>
					</tabla_ex>
					<help>Sindicato</help>
					<operador>=</operador>
					<valor>2</valor>
					<actualiza>
						<field destino="IdSindicato" id="IdCateg"/>
					
					</actualiza>					
				</field>
				<field id="IdCateg">
