<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="consulta" _paginar="100">
<title>HISTORICO</title>
<obs></obs>
<form >
	<table id="HTXLOG" label="Historico">
    <filters>
        <field id="fecha">
            <label modpos="nobr">Fecha Desde</label>
            <help>Fecha Desde</help>
            <operador>&gt;=</operador>
            <valor eval="true">date("d/m/Y", mktime(0, 0, 0, date("m"), date("d")-10, date("Y")))</valor>
        </field>
        <field id="obs">
            <label modpos="nobr">Buscar</label>
            <help>Buscar</help>
            <operador>like</operador>
        </field>                               
    </filters>

	<field id="xmlprog" oculto="true">
		<condicion operador="=">'stkinsumFicha.xml' or xmlprog = 'stkpieza_crud.xml' or xmlprog = 'articulo_foto_abm.xml'</condicion>
	</field>

	<field id="maxfec" local="true" noshow="true" print="false">
		<label>1</label>
		<expression>case when fecha = DATE(NOW()) then 'font-size:14px;color:red;font-weight:bold;' 
		when fecha = DATE(NOW()) -1  then 'font-size:14px;color:blue;font-weight:bold;' 
		end</expression>
		<tipo>varchar</tipo>
    </field>

	<field id="fecha" noshow="true" />

	<field id="fecha2" _noshow="true" style="text-align:left;"  tipoOrden="DESC">
            <expression>fecha</expression>
	     <size>30</size>
		 <label getStyle="maxfec">Fecha</label>
		 <tipo>date</tipo>
	</field>
	<field id="idLog" noshow="true"  tipoOrden="DESC">
	</field>
	
	<field id="hora2" _noshow="true" style="text-align:right;text-indent:15px;" >
	    <expression>TIME_FORMAT(hora, '%h:%i')</expression>
	    <label>hora</label>
	    <size>15</size>
	</field>
	
<!-- 	<field id="color" deshabilitado="true" clasefila="true" noshow="true">
		<expression>case when fecha = DATE(NOW()) then 'resaltado' 
                        when fecha = DATE(NOW()) - 1 then 'resaltadoVioleta' else '' end </expression>
	</field>
 -->			
	<field id="usuario" style="text-align:center;text-indent:10px;">
	<label>Usuario</label>
		<expression>concat(HTXUSERS.Nombre,' ',HTXUSERS.apellido)</expression>
	</field>
						
	<field id="tipo" _noshow="true">
		<label>Acción</label>
		<options>
			<option valor="INSERT"> Creó</option>
			<option valor="UPDATE"> Modificó </option>
			<option valor="DELETE"> Borró</option>
		</options>
	</field>

    <field id="obs" noshow="true">
        <label>Observaciones</label>
        <help>Buscar Palabra en Cambios</help>
        <size>50</size>
    </field>

    <field id="acc">
        <label>Cambios</label>
        <expression>case when tipo="UPDATE" or tipo="DELETE" then CONCAT('&lt;b&gt; ', obs, '&lt;br/&gt;&lt;b&gt; ', campo, '&lt;/b&gt;: ' , valorNuevoTxt ) else 
                        CONCAT('&lt;b&gt;', REPLACE(REPLACE( obs , ', ', '&lt;br/&gt;&lt;b&gt; '), ': ', '&lt;/b&gt;:' )) end</expression> 
        <tipo>varchar</tipo>
        <size>180</size>
    </field>

	<order>
		<field id="idLog" tipoOrden="DESC"/>
	</order>			
</table>

	<join tipo="left">
		<table id="HTXUSERS">
			<field id="login">
				<condicion operador="=">HTXLOG.usuario</condicion>
			</field>
		</table>
	</join>

</form>	   
</histrix> 
