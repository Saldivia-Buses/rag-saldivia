<group>
    <field id="artcod" tabla="FACDETAL"/>
  </group>

  <order>

    <field id="total" orderType="DESC"/>
  </order>

</table>

<join tipo="left">
<table id="STKINSUM">
<field id="siscod" oculto="true">
  <condicion operador="=">'01'</condicion>
</field>
<field id="artcod" oculto="true">
  <condicion operador="=">FACDETAL.artcod</condicion>
</field>
</table>
</join>

<join tipo="left">
<table id="REG_MOVIMIENTOS">
<field id="id_regmovim" oculto="true">
  <condicion operador="=">FACDETAL.regmovim_id</condicion>
</field>
</table>
</join>

    <join tipo="left">
      <table id="CTBCUENT">
        <field id="ctbcod">
          <condicion operador="=">STKINSUM.artctb</condicion>
        </field>
      </table>
    </join>

    <join tipo="left">
        <table id="STK_COSTO_REPOSICION">
            <field id="stkarticulo_id">
                <condicion operador="=">STKINSUM.artcod</condicion>
            </field>
        </table>
    </join>
