<!--      <tipo>custom_numeric</tipo> -->
    </field>

      <!-- COSTO -->
      <field id="costo_inicial">
        <label>Costo Inicial</label>
        <expression having="false"> 
          @cini:=(SELECT 
		ROUND((((((STKINSPR.artcos * valcps / valuso) - ((STKINSPR.artcos * valcps / valuso) * (artpor__1 / 100))) -
		(((STKINSPR.artcos * valcps / valuso) - ((STKINSPR.artcos * valcps / valuso) * (artpor__1 / 100))) * (artpor__2 / 100)))
		* (1 - (REG_MOVIMIENTOS.descuento_1 / 100)) ) * (1 - (REG_MOVIMIENTOS.descuento_2 / 100))), 2)
		FROM STKINSPR use index (fecha)
	        WHERE STKINSPR.artcod = STKINSUM.artcod
    		and STKINSPR.fecult &lt;= STR_TO_DATE('[__fecha_desde__]', '%d/%m/%Y')
		ORDER BY STKINSPR.fecult DESC LIMIT 1)
        </expression>
        <tipo>numeric</tipo>
      </field>
      <field id="fecha_ci">
        <label>Fecha CI</label>
        <expression having="false"> 
          @fcini:=(SELECT fecult FROM STKINSPR use index (fecha)
          WHERE STKINSPR.artcod = STKINSUM.artcod
          and STKINSPR.fecult &lt;= STR_TO_DATE('[__fecha_desde__]', '%d/%m/%Y')
          ORDER BY STKINSPR.fecult DESC LIMIT 1)
        </expression>
        <tipo>date</tipo>
        <detalle>fecha_ci</detalle>
      </field>
      <field id="ctacod_ci" noshow="true">
        <label>Prov CI</label>
        <expression having="false"> 
          @ctaini:=(SELECT ctacod FROM STKINSPR use index (fecha)
          WHERE STKINSPR.artcod = STKINSUM.artcod
          and STKINSPR.fecult &lt;= STR_TO_DATE('[__fecha_desde__]', '%d/%m/%Y')
          ORDER BY STKINSPR.fecult DESC LIMIT 1)
        </expression>
        <tipo>date</tipo>
      </field>
<!--      <field id="prov" >
  <label>Proveedor</label>
  <expression having="false">(select CCTCUENT.ctafan from STKINSPR as INSPR join CCTCUENT on CCTCUENT.ctacod = INSPR.ctacod and CCTCUENT.siscod = '01' where INSPR.artcod = STKINSUM.artcod and INSPR.siscod = STKINSUM.siscod order by fecult DESC limit 1)</expression>
        <tipo>varchar</tipo>
      </field> -->
      <field id="costo_final">
        <label>Costo Final</label>
        <expression having="false"> 
          @cfin:=(SELECT 
		ROUND((((((STKINSPR.artcos * valcps / valuso) - ((STKINSPR.artcos * valcps / valuso) * (artpor__1 / 100))) -
		(((STKINSPR.artcos * valcps / valuso) - ((STKINSPR.artcos * valcps / valuso) * (artpor__1 / 100))) * (artpor__2 / 100)))
		* (1 - (REG_MOVIMIENTOS.descuento_1 / 100)) ) * (1 - (REG_MOVIMIENTOS.descuento_2 / 100))), 2)
		FROM STKINSPR use index (fecha)
		WHERE STKINSPR.artcod = STKINSUM.artcod
		and STKINSPR.fecult &lt;= STR_TO_DATE('[__fecha_hasta__]', '%d/%m/%Y')
		ORDER BY STKINSPR.fecult DESC LIMIT 1)
        </expression>
        <tipo>numeric</tipo>
      </field>
      <field id="fecha_cf">
        <label>Fecha CF</label>
        <expression having="false"> 
          @fcfin:=(SELECT fecult FROM STKINSPR use index (fecha)
          WHERE STKINSPR.artcod = STKINSUM.artcod
          and STKINSPR.fecult &lt;= STR_TO_DATE('[__fecha_hasta__]', '%d/%m/%Y')
          ORDER BY STKINSPR.fecult DESC LIMIT 1)
        </expression>
        <tipo>date</tipo>
        <detalle>fecha_cf</detalle>
      </field>
      <field id="ctacod_cf" noshow="true">
        <label>Prov CF</label>
        <expression having="false"> 
          @ctafin:=(SELECT ctacod FROM STKINSPR use index (fecha)
          WHERE STKINSPR.artcod = STKINSUM.artcod
          and STKINSPR.fecult &lt;= STR_TO_DATE('[__fecha_desde__]', '%d/%m/%Y')
          ORDER BY STKINSPR.fecult DESC LIMIT 1)
        </expression>
        <tipo>date</tipo>
      </field>
      <!-- FIN COSTO -->

			<field id="porc_aumento">  
			    <label>% Aum.</label>
			    <expression having="false"> 
			    CAST((((@cfin) / (@cini)) - 1) * 100 AS DECIMAL)
			    </expression>


			    <tipo>decimal</tipo>
		        </field>
      <field id="aumento_mensual">
          <label>% Aum. Mens.</label>
          <expression having="false"> 
          (CAST((((@cfin) / (@cini)) - 1) * 100 AS DECIMAL)) / 
          (DATEDIFF(@fcfin, @fcini) / 30)

          </expression>
          <tipo>decimal</tipo>
        </field>


