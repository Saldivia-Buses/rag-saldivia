<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="abm-mini" subtipo="vertical">
    <title>Composición</title>
    <obs></obs>
    <form>
        <table id="STKPIEZA" label="Composicion">
            <field id="id_pieza" esClave="true" noshow="true" />

            <field id="idPadre" oculto="true">
                <label>Id Producto al que pertenece</label>
            </field>

            <field id="act" local="true" noshow="true">
                <if exp="true">
                    <true>Articulo::updateArbol('idPadre')</true>
                    <false>''</false>
                </if>
            </field>

          <field id="tienehijos" noshow="true">
            <expression>@tienehijos := ifnull((select 1 from STKPIEZA where STKPIEZA.idPadre = STKINSUM.artcod limit 1), 0)</expression>
          </field>
        
          <field id="bom" noshow="true" local="true">
            <if exp="tienehijos">
                <true>'stkpieza_qry.xml'</true>
                <false>''</false>
            </if>
    <!--     <expression>ifnull((select 'stkpieza_qry.xml' from STKPIEZA where STKPIEZA.idPadre = STKINSUM.artcod limit 1),'')</expression> -->
          </field>

            <field id="articulo_hijo" linkint="" linkdir="articulos" linkdes="Composición" required="true">
                <attribute id="linkint">bom</attribute>
               <paring destino="idPadre">articulo_hijo</paring>
                <helper type="external" xml="stkarticulo_autocomplete_qry.xml" dir="/help_local">
                    <field id="artdes">
                        <detalle>nom</detalle>
                    </field>
                    <field id="valcps">
                        <detalle>valCps</detalle>
                    </field>
                    <field id="valuso">
                        <detalle>valUso</detalle>
                    </field>
                    <field id="unicps">
                        <detalle>unicps</detalle>
                    </field>
                    <field id="artuni">
                        <detalle>artuni</detalle>
                    </field>
                </helper>
                <label>Código</label>
            </field>

            <field id="nom">
                <expression>artdes</expression>
                <label colspan="4">Producto</label>
                <size>70</size>
            </field>

            <field id="valCps" noshow="true">
                <expression>valcps</expression>
            </field>
            
            <field id="valUso" noshow="true" >
                <expression>valuso</expression>
            </field>
            
            <field id="cantidad"  preventLoop="true" suma="true">
                <label>Cantidad</label>
                <jseval campodestino="conversion" actxml="false">(valCps == 1)?(cantidad * valUso ):(cantidad / valCps)</jseval>
<!--        <tipo>float</tipo>                 -->
                <tipo>custom_numeric</tipo>
            </field>

            <field id="unicps" tabla="STKINSUM" deshabilitado="true">
                <label modpos="nobr">Unidad</label>
                <help>Unidad de Compra </help>
                <tabla_ex id="FSMUNIDS">
                    <field id="unicod"></field>
                    <field id="uninom"></field>
                </tabla_ex>
            </field>

            <field id="conversion" local="true"  preventLoop="true">
                <label>Uso</label>
                <if exp="valCps == valUso">
                    <true>valUso</true>
                    <false>(valCps == 1)?(cantidad * valUso):(cantidad / valCps)</false>                            
                </if>
                <jseval campodestino="cantidad" actxml="false">(valCps == 1)?(conversion / valUso):(conversion * valCps)</jseval>
                <tipo>custom_numeric</tipo>
            </field>

            <field id="artuni" tabla="STKINSUM" deshabilitado="true">
                <label modpos="nobr">Unid.</label>
                <help>Unidad de Compra </help>
                <tabla_ex id="FSMUNIDS">
                    <field id="unicod"></field>
                    <field id="uninom"></field>
                </tabla_ex>
            </field>
<!--            <field id="unitario"  >
        <expression> round(case WHEN (select sum(round( (SP.costo_automatico * SP.cantidad) * (1 + SP.recargo / 100) , 2)) from STKPIEZA as SP where SP.idPadre  = STKINSUM.artcod limit 1) != 0 then 
                              (select sum(round( (SP.costo_automatico * SP.cantidad) * (1 + SP.recargo / 100) , 2)) from STKPIEZA AS SP where SP.idPadre  = STKINSUM.artcod limit 1)
                              else costo_automatico end, 2) </expression>
                <label>Precio Unitario</label>
                <tipo>decimal</tipo>
            </field>-->
            <field id="unitario"  >
                <expression>round(costo_automatico, 2)</expression>
                <label>Precio Unitario</label>
                <tipo>decimal</tipo>
            </field>

            <field id="recargo" noZero="true" >
                <label>% Recargo</label>
                <tipo>decimal</tipo>
            </field>
                                                 <!--
            <field id="costo_autom2" suma="true" noshow="true">
                <tipo>decimal</tipo>
            <expression>cantidad * (round(case when valcps &gt; valuso then costo_calculado + ( costo_calculado / 100 * STKPIEZA.recargo) 
                          when (  costo_calculado * STKINSUM.valcps / STKINSUM.valuso) > 0  
                          then (  costo_calculado * STKINSUM.valcps / STKINSUM.valuso) + 
                               ( (costo_calculado * STKINSUM.valcps / STKINSUM.valuso) / 100 * STKPIEZA.recargo)
                      else STKINSUM.artcos end, 2))</expression>
            </field>
                                                     -->
        <!--
            <field id="costo_automatico2" suma="true" noshow="true">
                <tipo>decimal</tipo>
        <expression> round(case WHEN (select sum(round( (SP.costo_automatico * SP.cantidad) * (1 + SP.recargo / 100) , 2)) from STKPIEZA as SP where SP.idPadre  = STKINSUM.artcod limit 1) != 0 then 
                              (select sum(round( (SP.costo_automatico * SP.cantidad) * (1 + SP.recargo / 100) , 2)) from STKPIEZA AS SP where SP.idPadre  = STKINSUM.artcod limit 1)
                              else costo_automatico end, 2) </expression>
            </field>-->
            <field id="costo_automatico2" suma="true" >
                    <expression>
                        round(cantidad * ( costo_automatico + ( costo_automatico / 100 * STKPIEZA.recargo)), 2)
                    </expression>
                <label>Costo</label>
                <tipo>decimal</tipo>
            </field>

            <field id="costo_rec" suma="true" local="true" noshow="true">
                <if exp="true">
                    <true>costo_automatico2 * (1 + recargo / 100)</true>
                    <false>0</false>
                </if>
                <tipo>numeric</tipo>
            </field>
            
            <field id="costo_automatico3" suma="true" local="true" deshabilitado="true" noshow="true">
                <if exp="costo_rec != 0">
                    <true>costo_rec * cantidad</true>
                    <false>0</false>
                </if>
                <label>Costo</label>
                <tipo>numeric</tipo>
            </field>

        </table>
        <join>
            <table id="STKINSUM" label="Articulos">
                <field id="artcod">
                    <condicion operador="=">articulo_hijo</condicion>
                </field>
                <field id="siscod">
                    <condicion operador="=">'01'</condicion>
                </field>
            </table>
        </join>
    </form>
</histrix>  
