	    <field id="stock">
    		<label>Stock</label>
    		<expression>select sum(cantidad_stock) from STK_STOCKACTUAL join STK_DEPOSITOS on  id_stkdeposito = stkdeposito_id and suma_total = 1 where STK_STOCKACTUAL.stkarticulo_id = STKINSUM.artcod</expression>
    		<helper xml="stock_deposito_actual.xml" dir="/stock/qry/" type="link" title="Stock Actual">
  		    <parameter source="artcod" target="stkarticulo_id"/>
    		</helper>
    		<tipo>decimal</tipo>
	    </field>
      
      <field id="demprov">
        <label>Demora Pr.</label>
      	<help>Demora del proveedor en suministrar el artículo</help>
      	<tipo>integer</tipo>
      </field>
                                              
      <field id="artctb" print="false">
    	  <label colspan="4">Cta.Ctb.</label>
        <expression>CTBCUENT.ctbcod</expression>
        <help>Código Cuenta Contable</help>
      </field>    
      
      <field id="t_plano" disabled="true"    >
        <label modpos="nobr">Plano</label>
        <help>t-plano</help>
        <options>
          <option valor="0">No</option>
          <option valor="1">Si</option>
        </options>
        <tipo>check</tipo>
      </field>

      <field id="trazable" disabled="true">
        <label>Traz.</label>
        <help>Indica si el insumo es o No Trazable</help>
        <options>
          <option valor="0">No</option>
          <option valor="1">Si</option>
        </options>
        <tipo>check</tipo>
      </field>

      <field id="repuesto" disabled="true">
        <label>Rep.</label>
        <help>Repuesto Si o No </help>
        <options>
          <option valor="1">Si</option>
          <option valor="0">No</option>
        </options>
        <tipo>check</tipo>
      </field>

      <field id="fabricacion_propia" disabled="true">
        <label>Fab.Prop</label>
        <help>Indica si el insumo se fabrica internamente</help>
        <options>
          <option valor=""></option>
          <option valor="0">No</option>
          <option valor="1">Si</option>
        </options>
        <tipo>check</tipo>
      </field>

      <field id="tipocalculo_costo" disabled="true">
          <label modpos="nobr">Costo</label>
          <options> 
            <option valor=""></option>
            <option valor="0">Auto</option>
            <option valor="1">Man</option>
          </options>
      </field>

      <field id="fotopath" local="true" noshow="true">
        <if exp="true">
          <true>'artcod/'</true>
          <false>''</false>
        </if>
        <tipo>varchar</tipo>
      </field>

      <field id="foto" path="fotopath" _open="true" print="false" download="false" _viewer="true" watermark="artcod">
          <expression>select ARTICULO_FOTO.foto from ARTICULO_FOTO where ARTICULO_FOTO.idArticulo = STKINSUM.artcod and ARTICULO_FOTO.foto != '' order by revision desc limit 1</expression> 
	        <label>Imagen</label>
          <tipo Type="Image">file</tipo>
          <size>40</size> 
      </field>

      <field id="creado">
      	<expression having="false">creado</expression>
      	<label>Fecha Creación</label>
      	<tipo>date</tipo>
      </field>

      <field id="usuario_id">
          <label modpos="nobr">Creó</label>
          <helper type="combo" id="HTXUSERS" empty="true">
              <field id="id_usuario"/>
              <field id="nombre">
                <expression>CONCAT(apellido, ' ', Nombre)</expression>
              </field>
              <field id="baja">
                <condicion operador="=">0</condicion>
              </field>
              <order>
                <field id="nombre"/>
              </order>
          </helper>
      </field>  

    <field id="xml_consulta" local="true" noshow="true">
      <valor>'stkinsumFicha.xml'</valor>
    </field>

    <field id="nombre_id_registro" local="true" noshow="true">
      <valor>'Codigo Articulo'</valor>
    </field>

    <field id="id_registro" local="true" noshow="true">
      <expression><![CDATA[concat('\'',STKINSUM.artcod,'\'')]]></expression>
    </field>

    <field id="tipo_registro" local="true" noshow="true">
      <valor>'varchar'</valor>
    </field>

    <field id="log" local="true" linkint="registros_log_qry.xml" linkdir="/calidad/qry/" linkdes="Historial" print="false" >
      <label>Hist</label>
      <paring destino="xml_consulta">xml_consulta</paring>   
      <paring destino="id_registro">id_registro</paring>   
      <paring destino="nombre_id_registro">nombre_id_registro</paring>   
      <paring destino="tipo_registro">tipo_registro</paring>   
      <expression>'Hist.'</expression>  
    </field>

    <field id="siscod" oculto="true"/>   

    <group>
      <field id="artcod" tabla="STKINSUM"></field>
    </group>

	  <order>
      <field id="fecult" ></field>
    </order>   

    </table>

    <join tipo="left">
      <table id="STKPIEZA">
        <field id="idPadre">
          <condicion operador="=">STKINSUM.artcod</condicion>
        </field>
      </table>
    </join>    

    <join tipo="left">
      <table id="CTBCUENT">
          <field id="ctbcod" >
            <condicion operador="=">STKINSUM.artctb</condicion>
          </field>
          <field id="ctbhab">
            <condicion operador="=">1</condicion>
          </field>
      </table>
    </join>    

    <join tipo="left">
      <table id="STKINSPR">
        <field id="siscod">
          <condicion operador="=">STKINSUM.siscod</condicion>
        </field>
        <field id="artcod">
          <condicion operador="=">STKINSUM.artcod</condicion>
        </field>
      </table>
    </join>    

    <join tipo="left">
      <table id="STK_COSTO_REPOSICION">
        <field id="stkarticulo_id">
          <condicion operador="=">STKINSUM.artcod</condicion>
        </field>
      </table>
    </join>

  </form>
</histrix>
