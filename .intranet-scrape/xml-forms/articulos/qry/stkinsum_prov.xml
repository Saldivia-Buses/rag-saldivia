<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" borra="no" inserta="no" _paginar="250" path="fotos/articulos" preloadData="false" >
  <title>Insumos</title>
  <obs></obs>
  <form  detalle="inlinedetail" inline="true" >
    <table id="STKINSUM" styleTbody="height:500px;overflow-x:hidden;">
      <title>Insumos</title>

      <filters> 
        <field id="artcod" deshabilitado="false" oculto="true" >
          <label>Cod. 1</label>
          <operador oplogico="or">like</operador>
        </field>

        <field id="fabricacion_propia" deshabilitado="false">
          <operador>=</operador>
          <label modpos="nobr">Fab.Propia</label>
        </field>

        <field id="tipocalculo_costo">
          <label modpos="nobr" >Costo</label>
          <operador>=</operador>
        </field>

        <field id="baja" deshabilitado="false">
          <operador>=</operador>
          <label modpos="nobr">Estado</label>
        </field>  

        <field id="creado" deshabilitado="false">
          <operador>&gt;=</operador>
          <label modpos="nobr">Desde Creación</label>
        </field>

        <field id="creado" deshabilitado="false">
          <operador>&lt;=</operador>
          <label modpos="nobr">Hasta Creación</label>
        </field>

        <field id="usuario_id" deshabilitado="false">
          <operador>=</operador>
          <label modpos="nobr">Creó</label>
        </field>

        <field id="artdes" deshabilitado="false" colspan="4">
          <label _modpos="nobr">Artículo 1</label>
          <help>Descripción de Artículo</help>
	         <operador  oplogico="or">like</operador>
        </field>

        <field id="artcod" deshabilitado="false" grupo="Busqueda-Doble" >
          <ayuda_ex id="STKINSUM">
            <clave>artcod</clave>
            <descripcion>artdes</descripcion>
          </ayuda_ex>
          <operador oplogico="or">like</operador>
          <label modpos="nobr">Cod. 2</label>
        </field>    

        <field id="articulo_hijo" tabla="STKPIEZA" grupo="pieza">
        	<label>Pieza</label>
        	<operador>=</operador>
      	</field>

        <field id="artrub" deshabilitado="false">
          <operador>=</operador>
          <label modpos="nobr">Rubro</label>
        </field>

      </filters>

      <field id="artrub" noshow="true">
         <label>Rubro</label>
         <helper type="combo" xml="stkrubro_qry.xml" dir="/ayudas" empty="true"/>
      </field>

<!--
      <field id="updacost" noshow="true">
        <expression sql="true">update STKPIEZA SP set SP.recalc = SP.recalc + 1 where SP.idPadre = '[__artcod__]'</expression>
      </field>
    -->

      <field id="caracteristicas" >
        <label>%Seguridad</label>
          <helper xml="stkarticulo_atributos_fichaing.xml" dir="/stock/ing" type="link"  title="características" width="60%">
              <parameter source="artcod" target="id_stkarticulo" />
          </helper>
          <expression>(select ifnull((sum(porcentaje_opcion) + 10), 'cargar') from STK_ATRIBUTO_OPCIONES inner join STK_ATRIBUTOS on stkatributo_id = id_stkatributo inner join STK_ATRIBUTOS_GRUPOS on id_stkgrupoatrib = stkgrupoatrib_id  inner join STK_ATRIBUTO_VALORES on STK_ATRIBUTO_VALORES.stkatributo_id = STK_ATRIBUTO_OPCIONES.stkatributo_id and valor_atributo = id_atribopciones  where  STK_ATRIBUTO_VALORES.stkarticulo_id = STKINSUM.artcod and id_stkgrupoatrib = 1)</expression>
          
      </field>
<!--
      <field id="grilla" local="true" colspan="7">
        <label>Caract</label>	
	<valor>Caract.</valor>
        <helper dir="/stock/ing/" type="link" xml="producto_atributos_valores_grid.xml"  title="caracteristicas">
          <parameter source="1" target="id_stkgrupoatrib" />
          <parameter source="artcod" target="stkarticulo_id" />
        </helper>
      </field>    
-->
      <field id="tienehijos" noshow="true">
        <label>hijos</label>
        <expression>@tienehijos := ifnull((select 1 from STKPIEZA where STKPIEZA.idPadre = STKINSUM.artcod and bom_variacion_id = 0 limit 1), 0)</expression>
      </field>
	
      <field id="bom" noshow="true" local="true">
        <if exp="tienehijos == 1">
    	    <true>'stkpieza_qry.xml'</true>
    	    <false>''</false>
        </if>
      </field>

      <field id="fecha" local="true" noshow="true">
        <label>Fecha</label>
        <valor>today</valor>
        <tipo>date</tipo>
        <detalle>fecha</detalle>
      </field>
      
      <field id="inlinedetail" noshow="true">
        <expression>CASE WHEN tipocalculo_costo = 1 THEN 'cctcuent_x_insumo.xml' ELSE ifnull((select 'articulos/stkpieza_qry.xml' from STKPIEZA where STKPIEZA.idPadre = STKINSUM.artcod and bom_variacion_id = 0 limit 1),'cctcuent_x_insumo.xml') END</expression> 
      </field>

      <field id="artcod1" PDFcolor="000000" local="true" print="false" noshow="true" >
        <helper type="external" xml="HLPstkinsum.xml" dir="/help_local"  >
          <field id="artcod" >
            <label>Cod</label>
          </field>
          <field id="artdes" >
            <label>Nombre</label>
            <detalle>artdes1</detalle>
          </field>
        </helper>
      </field>

      <field id="artcod2" PDFcolor="000000" local="true" print="false" noshow="true">
        <helper type="external" xml="HLPstkinsum.xml" dir="/help_local"  >
          <field id="artcod" >
            <label>Cod</label>
          </field>
          <field id="artdes" >
            <label>Nombre</label>
            <detalle>artdes2</detalle>
          </field>
        </helper>
      </field>
    <field id="det" local="true" style="font-weight:bold;color:green;font-size:1.2em;">
	<expression>'ⓘ'</expression>
	<helper type="link" xml="planilla_datos_pieza.xml">
	    <parameter  source="artcod" target="id_stkarticulo" />
	</helper>
	
    </field>

      <field id="artdes2" local="true" print="false" noshow="true">
    		<expression>artdes</expression>  Si no pongo esto, no filtra bien los artículos con descripción que tenga comillas. Ej: art 104109 "TORN 5/16" X 1 1/2" ALLEN C/FRES" 
    		<size>50</size>
      </field>

      <field id="articulo_hijo" tabla="STKPIEZA" noshow="true">
        <label>padre</label>
    	</field>

      <field id="artcod" esclave="false" PDFcolor="000000" linkint="" linkdir="articulos" linkdes="Composición" oplogico="or">
        <attribute id="linkint">bom</attribute>
           <paring destino="idPadre">artcod</paring>
           <paring destino="fecha">fecha</paring>
           <attribute id="linkdes">artdes</attribute>
           <detalle>idPadre</detalle>
        <helper type="external" xml="HLPstkinsum.xml" dir="/help_local"  >
          <field id="artcod" >
            <label>Cod</label>
          </field>
          <field id="artdes" >
            <label>Nombre</label>
            <detalle>artdes</detalle>
          </field>
        </helper>
        <label>Cod.</label>
        <detalle>artcod</detalle>
      </field>

      <field id="artdes" oplogico="or">
        <label>Artículo</label>
        <help>Descripción de Artículo</help>
	       <size>60</size>
      </field>

      <field id="valcps">
        <label>Val.Compra</label>
        <help>Valor de Compra </help>
      </field>
      
      <field id="unicps">
        <label modpos="nobr">Unidad</label>
        <help>Unidad de Compra </help>
        <tabla_ex id="FSMUNIDS">
          <field id="unicod"></field>
          <field id="uniabv"></field>
        </tabla_ex>
      </field>
      
      <field id="valuso">
        <label>Val.Uso</label>
        <help>Valor de Uso </help>
      </field>
      
      <field id="artuni">
        <label modpos="nobr">U.Uso</label>
        <help>Unidad de Uso </help>
        <tabla_ex id="FSMUNIDS">
          <field id="unicod"></field>
          <field id="uniabv"></field>
        </tabla_ex>
      </field>
      
      <field id="baja" noshow="true">
        <options>
          <option valor="0">Activo</option>
          <option valor="1">Baja</option>
        </options>
      </field>

      <field id="regcuenta_id" tabla="STK_COSTO_REPOSICION" >
          <label >Prov Reposición</label>
          <helper type="combo" id="REG_CUENTA" empty="true">
              <field id="id_regcuenta"/>
              <field id="nombre_cuenta">
                <detalle>nombre_cuenta</detalle>
              </field>
              <field id="subsistema_id">
                 <condicion operador="=">'01'</condicion>
              </field>
              <field id="baja">
                 <condicion operador="=">0</condicion>
              </field>                    
              <order>
                  <field id="nombre_cuenta"/>
              </order>
          </helper>
      </field>
      
      <field id="costo" noZero="true">
        <label style="font-weight:bold;">Últ.Compra</label>
        <expression>round(case WHEN (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod and bom_variacion_id = 0 limit 1) != 0 then (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod and bom_variacion_id = 0 limit 1)
    			      when valcps &gt; valuso then costo_calculado * valcps
    			      when valcps &lt; valuso then costo_calculado 
    			      when ( costo_calculado * STKINSUM.valcps / STKINSUM.valuso) > 0  then (costo_calculado * STKINSUM.valcps / STKINSUM.valuso) else STKINSUM.artcos end, 2)</expression>
        <tipo>decimal</tipo>
      </field>

