                <tipo>numeric</tipo>
            </field>

            <field id="repodesc" style="color:green">
                <label>Repo.Desc</label>
                <expression>ifnull(getCostConDtoFunc(STKINSUM.artcod, ifnull(STK_COSTO_REPOSICION.moneda_id, 1), STR_TO_DATE('[__fecha__]', '%d/%m/%Y')  ), 0) * (case when (select count(*) from STKPIEZA where IdPadre = STKINSUM.artcod) then 1 else (valcps / valuso) end)</expression>
                <tipo>numeric</tipo>
