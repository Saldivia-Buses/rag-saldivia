      <field id="fecult" tabla="STKINSUM" tipoOrden="DESC">
        <expression>ultima_compra</expression>
        <label>Fecha últ compra</label>
        <tipo>date</tipo>
      </field>

      <field id="costo_reposicion" local="true">
        <expression>@costo_reposicion :=ifnull(getCostConDtoFunc(STKINSUM.artcod, ifnull(STK_COSTO_REPOSICION.moneda_id, 1), STR_TO_DATE('[__fecha__]', '%d/%m/%Y'),0  ), 0) * (case when (select count(*) from STKPIEZA where STKPIEZA.idPadre = STKINSPR.artcod and bom_variacion_id = 0) then 1 else (valcps / valuso) end)</expression>
        <label>Costo repo</label>
        <tipo>numeric</tipo>
      </field>
                   
