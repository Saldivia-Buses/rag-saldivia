      <field id="stklocacion_fija_id" editable="true">
          <label>Locacion Fija</label>
          <helper _empty="true" id="STK_LOCACION" type="combo" empty="true">
            <field id="id_stklocacion"/>
            <field id="codigo_locacion">
              <detalle>codigo_locacion</detalle>
            </field>
            <field id="stkdeposito_id">
              <detalle>stkdeposito_id</detalle>
            </field>
	    <order>
                <field id="codigo_locacion" />

	    </order>
          </helper>
      </field>

      <field id="tipoconteo_id" editable="true">
          <label>Tipo conteo</label>
          <helper empty="true" id="STK_TIPO_CONTEO" type="combo" >
            <field id="id_tipoconteo"/>
            <field id="tipo_conteo" />
          </helper>
      </field>

      <field id="artmin" editable="true">
        <label>Stock Seguridad</label>
        <help>Stock critico en deposito.</help>
        <jseval campodestino="lote_optimo" actxml="false">Math.pow(((2 * dem_diaria * 365 * valor_oc) / costo / costo_fin), 0.5).toFixed(2)</jseval>
        <jseval campodestino="artrep" actxml="false">((demprov * dem_diaria) + artmin).toFixed(2)</jseval>
      </field>

      <field id="dem_diaria" editable="true">
        <label modpos="nobr">Demanda Diaria</label>
        <help>demanda diaria</help>
        <jseval campodestino="lote_optimo" actxml="false">Math.pow(((2 * dem_diaria * 365 * valor_oc) / costo / costo_fin), 0.5).toFixed(2)</jseval>
        <jseval campodestino="artrep" actxml="false">((demprov * dem_diaria) + artmin).toFixed(2)</jseval>
      </field>

      <field id="artrep" _deshabilitado="true"  editable="true">
        <label modpos="nobr">Punto Pedido</label>
        <help>Stock de Reposicion.</help>
        <tipo>decimal</tipo>
      </field>

      <field id="demprov"   editable="true">
        <label>Lead Time</label>
        <help>Demora del proveedor en suministrar el artículo</help>
        <tipo>integer</tipo>
        <jseval campodestino="lote_optimo" actxml="false">Math.pow(((2 * dem_diaria * 365 * valor_oc) / costo / costo_fin), 0.5).toFixed(2)</jseval>
        <jseval campodestino="artrep" actxml="false">((demprov * dem_diaria) + artmin).toFixed(2)</jseval>
      </field>

      <field id="per_revision"  editable="true">
        <label modpos="nobr">Periodo Revision</label>
        <help>Periodo de revision</help>
        <tipo>integer</tipo>
        <jseval campodestino="lote_optimo" actxml="false">Math.pow(((2 * dem_diaria * 365 * valor_oc) / costo / costo_fin), 0.5).toFixed(2)</jseval>
        <jseval campodestino="artrep" actxml="false">((demprov * dem_diaria) + artmin).toFixed(2)</jseval>        
      </field>

      <field id="lote_optimo" _deshabilitado="true" editable="true">
        <label modpos="nobr">Lote Optimo Pedido</label>
        <help>Lote Optimo Pedido</help>
        <tipo>decimal</tipo>
      </field>

      <field id="herrinventario_id"  editable="true">
        <label _xml="/ayudas_local/HLPherramientas_inv.xml" modpos="nobr">H.Inventario</label>
        <helper type="combo" xml="HLPherramientas_inv.xml" dir="/ayudas_local" empty="true"/>
      </field>
      <field id="trazable"  editable="true">
        <label>Trazabilidad</label>
        <help>Indica si el insumo es o No Trazable</help>
        <options>
          <option valor="0">No Trazable</option>
          <option valor="1">Trazable</option>
        </options>
      </field>

      <field id="valor_oc" deshabilitado="true" _noshow="true" local="true" colstyle="display:none;">
          <label>Valor OC</label>
          <parametro id="cpsparam.xml" retorna="pardec">
              <field id="parcla" noshow="true">
                  <condicion operador="=">'valoc'</condicion>
              </field>
          </parametro>
      </field>

      <field id="costo_fin" deshabilitado="true" _noshow="true" local="true" _colstyle="display:none;">
          <label>Costo Fin.</label>
          <parametro id="cpsparam.xml" retorna="pardec">
              <field id="parcla" noshow="true">
                  <condicion operador="=">'costfi'</condicion>
              </field>
          </parametro>
      </field>


      <field id="costo" >
        <label >Costo</label>
        <!-- NO TOCAR, TE MATO -->

        <expression having="false" >(
        ifnull((select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1), 
        (select ROUND(INSPR.artcos * valcps / valuso, 2) from STKINSPR as INSPR where  INSPR.siscod = STKINSPR.siscod and INSPR.fecult= max(STKINSPR.fecult) and INSPR.artcod = STKINSPR.artcod limit 1)))</expression>
          
        <expresion_1 having="false" >(
        case when (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1) != 0 then 
                  (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1)
          else  (select ROUND(INSPR.artcos * valcps / valuso, 2) from STKINSPR as INSPR where INSPR.fecult= max(STKINSPR.fecult) and INSPR.artcod = STKINSPR.artcod and INSPR.siscod = STKINSPR.siscod limit 1) end)</expresion_1>

        <tipo>numeric</tipo>
      </field>     


      <group>
        <field id="artcod" tabla="STKINSUM"/>
      </group>

    </table>
        <join tipo="left">
    
      <table id="STKINSPR">
        <field id="siscod" >
          <condicion operador="=">'01'</condicion>
        </field>
        <field id="artcod" >
          <condicion operador="=">STKINSUM.artcod</condicion>
        </field>

    
      </table>
    </join>    
  </form>
</histrix>