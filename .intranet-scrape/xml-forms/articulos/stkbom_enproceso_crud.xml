                <tipo>numeric</tipo>
            </field>

            <field id="posicionfab_alarma_id" noZero="true" tabla="STKINSUM" deshabilitado="true">
              <label modpos="nobr">Inicio Fabri.</label>
              <helper xml="posicionesfab_qry.xml" type="combo" dir="/produccion" empty="true">
                <field id="linea_id" tabla="MOMENTO" oculto="true">
                  <condicion operador="=">1</condicion>
                </field>
              </helper>
            </field>

            <field id="posicionfab_entrega_id" noZero="true" tabla="STKINSUM" deshabilitado="true">
              <label modpos="nobr">Momento Entrega</label>
              <helper xml="posicionesfab_qry.xml" type="combo" dir="/produccion" empty="true">
                <field id="linea_id" tabla="MOMENTO" oculto="true">
                  <condicion operador="=">1</condicion>
                </field>
              </helper>
            </field>

            <field id="posicionfab_id" noZero="true" tabla="STKINSUM" deshabilitado="true">
              <label modpos="nobr">Destino Estac.</label>
              <helper xml="posicionesfab_qry.xml" type="combo" dir="/produccion" empty="true">
                <field id="linea_id" tabla="MOMENTO" oculto="true">
                  <condicion operador="=">1</condicion>
                </field>
              </helper>
            </field>
