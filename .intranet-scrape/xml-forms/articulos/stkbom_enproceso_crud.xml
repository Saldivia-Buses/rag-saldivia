            </field>
                                                     -->
	    <!--
            <field id="costo_automatico2" suma="true" noshow="true">
                <tipo>decimal</tipo>
        <expression> round(case WHEN (select sum(round( (SP.costo_automatico * SP.cantidad) * (1 + SP.recargo / 100) , 2)) from STKPIEZA as SP where SP.idPadre  = STKINSUM.artcod limit 1) != 0 then 
    				   	      (select sum(round( (SP.costo_automatico * SP.cantidad) * (1 + SP.recargo / 100) , 2)) from STKPIEZA AS SP where SP.idPadre  = STKINSUM.artcod limit 1)
                              else costo_automatico end, 2) </expression>


            </field>-->

        <field id="costo_automatico2" suma="true" >
                <expression>
                    round(cantidad * ( costo_automatico + ( costo_automatico / 100 * STK_BOM_ENPROCESO.recargo)), 2)
                </expression>
            <label>Costo</label>
            <tipo>decimal</tipo>
        </field>
<!--
            <field id="costo_rec" suma="true" local="true" noshow="true">
		<if exp="true">
		    <true>costo_automatico2 * (1 + recargo / 100)</true>
		    <false>0</false>
		</if>
                <tipo>numeric</tipo>
            </field>
            
            <field id="costo_automatico3" suma="true" local="true" deshabilitado="true" noshow="true">
