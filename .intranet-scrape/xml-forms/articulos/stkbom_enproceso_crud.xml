        </table>

        <join>
            <table id="STKINSUM" label="Articulos">
                <field id="artcod">
                    <condicion operador="=">stkarticulohijo_id</condicion>
                </field>
                <field id="siscod">
                    <condicion operador="=">'01'</condicion>
                </field>
                    
            </table>
            
        </join>
    </form>
</histrix>	
