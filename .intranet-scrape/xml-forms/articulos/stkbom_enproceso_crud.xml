                              else costo_automatico end, 2) </expression>

                <label>Precio Unitario</label>
                <tipo>decimal</tipo>
            </field>-->

<field id="unitario"  >
                <expression>round(costo_automatico, 2)</expression>
                <label>Precio Unitario</label>
                <tipo>decimal</tipo>
            </field>

            <field id="recargo" noZero="true" >
                <label>% Recargo</label>
                <tipo>decimal</tipo>
            </field>
                                                 <!--
            <field id="costo_autom2" suma="true" noshow="true">
                <tipo>decimal</tipo>

    	    <expression>cantidad * (round(case when valcps &gt; valuso then costo_calculado + ( costo_calculado / 100 * STKPIEZA.recargo) 
