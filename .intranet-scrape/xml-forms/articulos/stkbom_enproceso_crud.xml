<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="abm-mini" subtipo="vertical" log="true" logReference="log_reference">
    <title>Composición en proceso</title>
    <obs></obs>
    <form>
        <table id="STK_BOM_ENPROCESO" label="Compos.En Proceso">
            <field id="stkarticulohijo_id" esClave="true" noshow="true" />

            <field id="stkarticulopadre_id" oculto="true">
                <label>Padre</label>
            </field>
   
      <field id="tienehijos" noshow="true">
        <expression>@tienehijos := ifnull((select 1 from STK_BOM_ENPROCESO where STK_BOM_ENPROCESO.stkarticulopadre_id = STKINSUM.artcod limit 1), 0)</expression>
      </field>
	
      <field id="bom" noshow="true" local="true">
        <if exp="tienehijos">
    	    <true>'stkpieza_qry.xml'</true>
    	    <false>''</false>
        </if>
<!--     <expression>ifnull((select 'stkpieza_qry.xml' from STKPIEZA where STKPIEZA.idPadre = STKINSUM.artcod limit 1),'')</expression> -->
      </field>

            <field id="stkarticulohijo_id" linkint="" linkdir="articulos" linkdes="Composición">
		<attribute id="linkint">bom</attribute>
               <paring destino="idPadre">articulo_hijo</paring>
				<helper type="external" xml="stkarticulo_autocomplete_qry.xml" dir="/help_local">
					<field id="artdes">
						<detalle>nom</detalle>
					</field>
					<field id="valcps">
						<detalle>valCps</detalle>
					</field>
					<field id="valuso">
						<detalle>valUso</detalle>
					</field>
					<field id="unicps">
						<detalle>unicps</detalle>
					</field>
					<field id="artuni">
						<detalle>artuni</detalle>
					</field>
				</helper>
                <label>Artículo</label>
		<size>20</size>
                <help>Artículo</help>
            </field>

            <field id="nom">
        		<expression>artdes</expression>
                <label colspan="4">Producto</label>
				<size>70</size>
            </field>

            <field id="valCps" noshow="true">
        	<expression>valcps</expression>
            </field>
            
            <field id="valUso" noshow="true" >
        	<expression>valuso</expression>
            </field>
            
            <field id="cantidad"  preventLoop="true" suma="true">
                <label>Cantidad</label>
                <jseval campodestino="conversion" actxml="false">(valCps == 1)?(cantidad * valUso ):(cantidad / valCps)</jseval>
<!--		<tipo>float</tipo>                 -->
                <tipo>custom_numeric</tipo>

            </field>
    	    <field id="unicps" tabla="STKINSUM" deshabilitado="true">
		<expression>unicps</expression>
		<label modpos="nobr">Unidad</label>
		<help>Unidad de Compra </help>
		<tabla_ex id="FSMUNIDS">
			<field id="unicod"></field>
			<field id="uninom"></field>
		</tabla_ex>
	    </field>
            <field id="conversion" local="true"  preventLoop="true">
                <label>Uso</label>
                <if exp="valCps == valUso">
            	    <true>valUso</true>
            	    <false>(valCps == 1)?(cantidad * valUso):(cantidad / valCps)</false>	                	    
                </if>
                
                <jseval campodestino="cantidad" actxml="false">(valCps == 1)?(conversion / valUso):(conversion * valCps)</jseval>
                
                <tipo>custom_numeric</tipo>
            </field>

    	    <field id="artuni" tabla="STKINSUM" deshabilitado="true">
		<expression>artuni</expression>
		<label modpos="nobr">Unid.</label>
		<help>Unidad de Compra </help>
		<tabla_ex id="FSMUNIDS">
			<field id="unicod"></field>
			<field id="uninom"></field>
		</tabla_ex>
	    </field>

