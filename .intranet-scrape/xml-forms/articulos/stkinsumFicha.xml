        <label >Cuenta Contable Compra</label>
        <help>Código Cuenta Contable</help>
        <helper type="external" id="CTBCUENT" vacio="true">
          <field id="ctbcuentacps_id" noshow="true">
            <expression>ctbcod</expression>
            <detalle>ctbcuentacps_id</detalle>
          </field>
