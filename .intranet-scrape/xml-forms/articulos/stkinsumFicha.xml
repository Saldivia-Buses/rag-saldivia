          </order>
        </helper>
        <expression>CONCAT(ctbnom, ' (', ctbcod, ')')</expression>
        <size>40</size>
      </field>
-->
      <field id="artctb2" _required="true" _noshow="true" >
        <label _modpos="nobr" >Cuenta Compra</label>
        <helper type="combo" id="CTBCUENT" empty="true">
          <field id="artctb2" noshow="true">
            <expression>ctbcod</expression>
            
          </field>
          <field id="ctbnom">
            <expression>CONCAT(ctbnom, ' (', ctbcod, ')')</expression>
          </field>       
          <field id="ctbhab" noshow="true">
            <condicion operador="=">1</condicion>
          </field>
          <order>
            <field id="ctbnom" tabla="CTBCUENT"/>
          </order>
        </helper>        
      </field>

      <field id="artctb" _required="true" _noshow="true" modpos="nobr">
        <label >Cuenta Contable Venta</label>
          <helper type="combo" id="CTBCUENT" empty="true">
          
          <field id="artctb" noshow="true">
            <expression>ctbcod</expression>
            <detalle>artctb</detalle>
          
          </field>
          <field id="ctbnom2">
            <expression>CONCAT(ctbnom, ' (', ctbcod, ')')</expression>
          </field>       
          <field id="ctbhab" noshow="true">
            <condicion operador="=">1</condicion>
          </field>
          <order>
            <field id="ctbnom" tabla="CTBCUENT"/>
          </order>
        </helper>
      </field>
      <field id="tipocalculo_costo">
        <label modpos="nobr" >Tipo de Cálculo Costo</label>
        <options> 
          <option valor="0">Automático</option>
          <option valor="1">Manual</option>
        </options>
      </field>
<!--
    desactualizado / utilizar standarpacks subsistema proveedor
      <field id="stkformaemb_id">
	<helper type="combo" xml="stkformasemb_qry.xml" dir="/ayudas_local" />
	<label xml="/articulos/stk_formas_emb_abm.xml" modpos="nobr" >Forma de Emabalaje</label>
      </field>
-->
      <field id="sep2" colspan="8" style="background-color:#444;color:white;" deshabilitado="true" local="true">
  	    <label>Planos</label>
  	    <valor>'Fabricación'</valor>
      </field>

      <field id="plaubi">
        <label>Ubic.Plano</label>
        <help></help>
	       <size>30</size>
      </field>

      <field id="fabricacion_propia">
        <label modpos="nobr" >Fabricación Propia</label>
        <options> 
          <option valor="0">No</option>
          <option valor="1">Si</option>
        </options>
      </field>

      <field id="ext_plano">
        <label modpos="nobr">Extensión plano</label>
        <tipo>check</tipo>
      </field>
      
      <field id="norcod">
        <label>Cod.Norma</label>
        <help>Código de Norma</help>
        <tabla_ex id="INSNORMA">
          <field id="norcod"/>
          <field id="norabv"/>
        </tabla_ex>
      </field>

      <field id="t_pieza">
        <label modpos="nobr">t_pieza</label>
        <help>t-pieza</help>
        <options>
          <option valor="0">No</option>
          <option valor="1">Si</option>
        </options>
      </field>

      <field id="t_plano">
        <label modpos="nobr">t_plano</label>
        <help>t-plano</help>
        <options>
          <option valor="0">No</option>
          <option valor="1">Si</option>
        </options>
      </field>

      <field id="t_dispo">
        <label modpos="nobr">t_dispo</label>
        <help>t-dispo</help>
        <options>
          <option valor="0">No</option>
          <option valor="1">Si</option>
        </options>
      </field>

      <field id="sep1" colspan="8" style="background-color:#444;color:white;" deshabilitado="true" local="true">
  	    <label>Stock</label>
  	    <valor>'Stock'</valor>
      </field>

      <field id="stklocacion_fija_id">
        <label>Locación Fija</label>
        <helper _empty="true" id="STK_LOCACION" type="combo" empty="true">
          <field id="id_stklocacion"/>
          <field id="codigo_locacion">
            <detalle>codigo_locacion</detalle>
          </field>
          <field id="stkdeposito_id">
            <detalle>stkdeposito_id</detalle>
          </field>
          <order>
            <field id="codigo_locacion" />
          </order>
        </helper>
      </field>

      <field id="trazable">
        <label>Trazabilidad</label>
        <help>Indica si el insumo es o No Trazable</help>
        <options>
          <option valor="0">No Trazable</option>
          <option valor="1">Trazable</option>
        </options>
      </field>

      <field id="recLote">
        <label modpos="nobr">Recepción por Lote</label>
        <options>
          <option valor="0">No</option>
          <option valor="1">Si</option>
        </options>
      </field>

      <field id="stock">
        <label modpos="nobr">Control Stock</label>
        <options>
          <option valor="0">No</option>
          <option valor="1">Si</option>
        </options>
      </field>

      <field id="fifo">
        <label modpos="nobr">FIFO</label>
        <options>
          <option valor="0">No</option>
          <option valor="1">Si</option>
        </options>
      </field>

      <field id="dias_fifo" sincelda="true">
        <label modpos="nobr">Dias FIFO</label>
        <size>4</size>
      </field>


      <field id="peso_articulo">
        <label>Peso (Kg)</label>
      </field>

      <field id="artmax">
        <label modpos="nobr">Stock Máximo</label>
        <help>Stock Máximo</help>
        <jseval campodestino="lote_optimo">((lote_minimo &lt;= ((parseInt(((artmax - Math.ceil(demprov * dem_diaria)) / pack_embalaje), 10) + ((((artmax - Math.ceil(demprov * dem_diaria)) % pack_embalaje) != 0) ? 1 : 0)) * pack_embalaje)) ? ((parseInt(((artmax - Math.ceil(demprov * dem_diaria)) / pack_embalaje), 10) + ((((artmax - Math.ceil(demprov * dem_diaria)) % pack_embalaje) != 0) ? 1 : 0)) * pack_embalaje) : (parseInt((lote_minimo / pack_embalaje), 10) + (((lote_minimo % pack_embalaje) != 0) ? 1 : 0)) * pack_embalaje)</jseval>
        <size>10</size>
      </field>

      <field id="artmin" deshabilitado="false">
        <label modpos="nobr">Stock Mínimo</label>
        <help>Stock Mínimo</help>
        <expression>ceil(demprov * dem_diaria)</expression>
        <size>10</size>
        <jseval campodestino="artmax">Math.ceil(artrep + artmin)</jseval>
        <jseval campodestino="artrep">Math.ceil(stock_seguridad + artmin)</jseval>
        <jseval campodestino="lote_optimo">((lote_minimo &lt;= ((parseInt(((artmax - Math.ceil(demprov * dem_diaria)) / pack_embalaje), 10) + ((((artmax - Math.ceil(demprov * dem_diaria)) % pack_embalaje) != 0) ? 1 : 0)) * pack_embalaje)) ? ((parseInt(((artmax - Math.ceil(demprov * dem_diaria)) / pack_embalaje), 10) + ((((artmax - Math.ceil(demprov * dem_diaria)) % pack_embalaje) != 0) ? 1 : 0)) * pack_embalaje) : (parseInt((lote_minimo / pack_embalaje), 10) + (((lote_minimo % pack_embalaje) != 0) ? 1 : 0)) * pack_embalaje)</jseval>
      </field>

      <field id="stock_seguridad" colspan="1" deshabilitado="false">
        <label>Stock Seguridad</label>
        <help>Stock crítico en depósito</help>
        <expression>round((select sum(porcentaje_opcion) + 10 from STK_ATRIBUTO_OPCIONES inner join STK_ATRIBUTOS on stkatributo_id = id_stkatributo 
            inner join STK_ATRIBUTOS_GRUPOS on id_stkgrupoatrib = stkgrupoatrib_id  inner join STK_ATRIBUTO_VALORES on 
            STK_ATRIBUTO_VALORES.stkatributo_id = STK_ATRIBUTO_OPCIONES.stkatributo_id and valor_atributo = id_atribopciones  
            where  STK_ATRIBUTO_VALORES.stkarticulo_id = artcod and id_stkgrupoatrib = 1) /100 * demprov * dem_diaria, 0)</expression>
        <jseval campodestino="artrep">Math.ceil(stock_seguridad + artmin)</jseval>
        <size>10</size>
      </field>

      <field id="dem_diaria">
        <label modpos="nobr">Demanda Diaria</label>
        <help>Cantidad demanda diaria</help>
        <jseval campodestino="artmin">Math.ceil(demprov * dem_diaria)</jseval>
        <size>10</size>
      </field>

      <field id="cantxuni">
        <label modpos="nobr">Cant.x Un.</label>
        <help>Cantidad por unidad (en unidad de uso)</help>
      </field>

      <field id="artrep" _deshabilitado="true">
        <label modpos="nobr">Punto Pedido</label>
        <help>Stock de Reposición.</help>
        <jseval campodestino="artmax">Math.ceil(artrep + artmin)</jseval>
        <tipo>decimal</tipo>
      </field>

      <field id="demprov">
        <label>Lead Time</label>
        <help>Demora del proveedor en suministrar el artículo</help>
        <tipo>integer</tipo>
        <jseval campodestino="artmin">Math.ceil(demprov * dem_diaria)</jseval>
      </field>

      <field id="per_revision">
        <label modpos="nobr">Período Revisión</label>
        <help>Período de revisión</help>
        <tipo>integer</tipo>
      </field>

      <field id="herrinventario_id">
        <label _xml="/ayudas_local/HLPherramientas_inv.xml" modpos="nobr">H.Inventario</label>
        <helper type="combo" xml="HLPherramientas_inv.xml" dir="/ayudas_local" empty="true"/>
      </field>     
 
      <field id="lote_optimo" deshabilitado="false">
        <label modpos="nobr">Lote Óptimo Pedido</label>
        <help>Lote Óptimo Pedido</help>
        <!-- <if exp="lote_optimo > lote_minimo">
          <true>lote_optimo</true>
          <false>lote_minimo</false>
        </if> -->
      </field>
      
      <field id="dias_acopio">
        <label>Días de Acopio</label>
      </field>
      
      <field id="pedido_automatico" modpos="nobr">
        <label>Pedido Automático</label>
        <help>El sistema realizará el pedido automáticamente en base al punto de pedido</help>
        <tipo>check</tipo>
      </field>

      <field id="pack_embalaje">
        <label modpos="nobr">Standard Pack</label>
        <jseval campodestino="lote_optimo">((lote_minimo &lt;= ((parseInt(((artmax - Math.ceil(demprov * dem_diaria)) / pack_embalaje), 10) + ((((artmax - Math.ceil(demprov * dem_diaria)) % pack_embalaje) != 0) ? 1 : 0)) * pack_embalaje)) ? ((parseInt(((artmax - Math.ceil(demprov * dem_diaria)) / pack_embalaje), 10) + ((((artmax - Math.ceil(demprov * dem_diaria)) % pack_embalaje) != 0) ? 1 : 0)) * pack_embalaje) : (parseInt((lote_minimo / pack_embalaje), 10) + (((lote_minimo % pack_embalaje) != 0) ? 1 : 0)) * pack_embalaje)</jseval>
      </field> 

      <field id="lote_minimo">
        <label modpos="nobr">Lote Mínimo</label>
        <jseval campodestino="lote_optimo">((lote_minimo &lt;= ((parseInt(((artmax - Math.ceil(demprov * dem_diaria)) / pack_embalaje), 10) + ((((artmax - Math.ceil(demprov * dem_diaria)) % pack_embalaje) != 0) ? 1 : 0)) * pack_embalaje)) ? ((parseInt(((artmax - Math.ceil(demprov * dem_diaria)) / pack_embalaje), 10) + ((((artmax - Math.ceil(demprov * dem_diaria)) % pack_embalaje) != 0) ? 1 : 0)) * pack_embalaje) : (parseInt((lote_minimo / pack_embalaje), 10) + (((lote_minimo % pack_embalaje) != 0) ? 1 : 0)) * pack_embalaje)</jseval>
        <tipo>varchar</tipo>
      </field> 

      <field id="valor_oc" deshabilitado="true" noshow="true" _local="true" _colstyle="display:none;">
        <label>Valor OC</label><!--
        <parametro id="cpsparam.xml" retorna="pardec">
            <field id="parcla" oculto="true">
                <condicion operador="=">'valoc'</condicion>
            </field>
        </parametro>-->
        <expression>SELECT pardec FROM CPSPARAM WHERE parcla = 'valoc'</expression>
      </field>

      <field id="costo_fin" deshabilitado="true" noshow="true" _local="true" _colstyle="display:none;">
        <label>Costo Fin.</label><!--
        <parametro id="cpsparam.xml" retorna="pardec">
            <field id="parcla" oculto="true">
                <condicion operador="=">'costfi'</condicion>
            </field>
        </parametro>-->
        <expression>SELECT pardec FROM CPSPARAM WHERE parcla = 'costfi'</expression>
      </field>



      <field id="sep3" colspan="8" style="background-color:#444;color:white;" deshabilitado="true" local="true">
  	    <label>Fabricación</label>
  	    <valor>'Fabricación'</valor>
      </field>



      <field id="posicionfab_alarma_id" noZero="true">
        <label _modpos="nobr">Inicio Fabri.</label>
        <helper xml="posicionesfab_qry.xml" type="combo" dir="/produccion" empty="true">
          <field id="linea_id" tabla="MOMENTO" oculto="true">
            <condicion operador="=">1</condicion>
          </field>
        </helper>
      </field>

      <field id="posicionfab_entrega_id" noZero="true">
        <label modpos="nobr">Momento Entrega</label>
        <helper xml="posicionesfab_qry.xml" type="combo" dir="/produccion" empty="true">
          <field id="linea_id" tabla="MOMENTO" oculto="true">
            <condicion operador="=">1</condicion>
          </field>
        </helper>
      </field>

      <field id="posicionfab_id" noZero="true">
        <label modpos="nobr">Destino Estac.</label>
        <helper xml="posicionesfab_qry.xml" type="combo" dir="/produccion" empty="true">
          <field id="linea_id" tabla="MOMENTO" oculto="true">
            <condicion operador="=">1</condicion>
          </field>
        </helper>
      </field>
