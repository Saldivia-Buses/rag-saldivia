<?xml version="1.0" encoding="UTF-8"?>
<histrix borra="no" tipo="ficha" tooltip="true" logReference="artdes" conBusqueda="true">
  <title>Insumos</title>
  <obs/>
  <form >
    <table id="STKINSUM" label="Insumos">
    
      <field id="siscod" oculto="true" esClave="true">
        <label>Código Sistema</label>
        <valor>'01'</valor>
      </field>

      <field id="artrub">
        <label>Rubro</label>
        <help>Rubro del Artículo</help>
        <helper type="combo" id="STKRUBRO">
          <field id="artrub"/>
          <field id="rubnom">
            <expression>CONCAT(artrub, '-', rubnom)</expression>
          </field>
        </helper>
        <actualiza>
          <field destino="artrub" id="artcodpro"/>
          <field destino="artrub" id="artsub"/>
        </actualiza>
      </field>

      <field id="artsub">
        <label modpos="nobr">SubRubro</label>
        <helper type="combo" id="STKSUBRU">
          <field id="artsub"/>
          <field id="subnom">
            <expression>CONCAT(artsub, '-', subnom)</expression>
          </field>
          <field id="artrub" oculto="true">
            <condicion operador="=">1</condicion>
          </field>
        </helper>
        <actualiza>
          <field destino="artsub" id="artcodpro"/>
        </actualiza>
        <help>Grupo del Artículo</help>
      </field>

      <field id="baja">
        <label modpos="nobr" style="color:red;">Condición</label>
        <help>Baja</help>
        <options>
          <option valor="0">Activo</option>
          <option valor="1">Baja</option>
        </options>
        <valor>0</valor>
        <tipo>integer</tipo>
      </field>

      <field deshabilitado="true" id="artcodpro" local="true" _noshow="true" >
        <label style="color:red">Código Sugerido</label>
        <tabla_ex id="STKSUBRU">
          <field id="subnro">
            <expression>SELECT max(STKINSUM.artcod) + 1   FROM STKINSUM where substring(STKINSUM.artcod, 1, 1) = STKSUBRU.artrub and substring(STKINSUM.artcod, 2, 2) = LPAD(STKSUBRU.artsub, 2, '0')</expression>
          </field>
          <field id="subnro2">
            <expression>SELECT max(STKINSUM.artcod) + 1  FROM STKINSUM where substring(STKINSUM.artcod, 1, 1) = STKSUBRU.artrub and substring(STKINSUM.artcod, 2, 2) = LPAD(STKSUBRU.artsub, 2, '0')</expression>
          </field>
          <field id="artsub" oculto="true">
            <condicion operador="=">1</condicion>
          </field>
          <field id="artrub" oculto="true">
            <condicion operador="=">1</condicion>
          </field>
        </tabla_ex>
      </field>

      <field  esClave="true" id="artcod">
        <label>Código Artículo</label>
        <help>Código de Artículo</help>
      </field>

      <field id="artdes" maxlength="150">
        <label colspan="10" modpos="nobr">Descripción</label>
        <help>Descripción de Artículo</help>
      	<tipo>varchar</tipo>
      	<size>80</size>
      </field>

      <field id="valcps">
        <label>Val.Compra</label>
        <help>Valor de Compra</help>
      </field>

      <field id="unicps">
        <label modpos="nobr">U. Compra</label>
        <help>Unidad de Compra</help>
        <tabla_ex id="FSMUNIDS">
          <field id="unicod"/>
          <field id="uninom"/>
        </tabla_ex>
      </field>

      <field id="valuso">
        <label modpos="nobr">Val.Uso</label>
        <help>Valor de Uso</help>
      </field>

      <field id="artuni">
        <label modpos="nobr">U.Uso</label>
        <tabla_ex id="FSMUNIDS">
          <field id="unicod"/>
          <field id="uninom"/>
        </tabla_ex>
        <help>Código Unidad de Medida de Uso</help>
      </field>
      
      <field id="usuario_id" valauto="true" noshow="true">
        <label>Creado por</label>
        <valor eval="true">$_SESSION['idUser']</valor>
      </field>

      <field id="creac" deshabilitado="true" >
        <expression>DATE(STKINSUM.creado)</expression>
        <label _modpos="nobr">Fecha de Creación</label>
        <help>Fecha de Creación del artículo</help>
        <tipo>date</tipo>
      </field>

      <field id="fecvenc">
        <label modpos="nobr">Fecha de Vencimiento</label>
        <help>Fecha de Vencimiento del artículo</help>
        <tipo>date</tipo>
      </field>

      <field id="artiva">
        <label>Situación IVA</label>
        <help>Situación I.V.A.</help>
        <options>
          <option valor="0">No Gravado</option>
          <option valor="1">Alicuota Total</option>
          <option valor="2">Alicuota Parcial</option>
        </options>
      </field>
