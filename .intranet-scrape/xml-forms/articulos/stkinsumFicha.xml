      <field id="norma" local="true" obj="normainsumos.xml">
        <paring destino="artcod">artcod</paring>
      </field> 

      <field id="ultimocosto" local="true" obj="ultimocosto_cons.xml">
        <paring destino="artcod">artcod</paring>
      </field>
      
      <field id="Proveedor" local="true" obj="articulo_proveedor.xml">
        <paring destino="stkarticulo_id">artcod</paring>
      </field>

      <field id="Composicion" local="true" obj="stkpieza_crud.xml">
        <paring destino="idPadre">artcod</paring>
      </field>

      <field id="Composicionproceso" local="true" obj="stkbom_enproceso_crud.xml">
        <paring destino="stkarticulopadre_id">artcod</paring>
      </field>

      <field id="datostecnicos" local="true" obj="stkinsum_datos_tecnicos.xml">
        <paring destino="idArticulo">artcod</paring>
      </field>      

      <field id="locaciones" local="true" >
        <helper xml="stkarticulo_locacion_grid.xml" type="object">
          <parameter source="artcod" target="stkarticulo_id" />
        </helper>
      </field>    
      <field id="uso" local="true" >
        <helper xml="stkarticulo_uso_grid.xml" type="object" label="Locaciones de uso">
          <parameter source="artcod" target="stkarticulo_id" />
        </helper>
      </field>    

      <field id="packs" local="true" >
        <helper xml="stk_articulo_pack_crud.xml" type="object" dir="/stock/man/">
          <parameter source="artcod" target="stkarticulo_id" />
        </helper>
      </field>    

      <field id="cantidad_modelo" local="true" >
        <helper xml="mrp_cantidad_articulo_modelo_grid.xml" type="object">
          <parameter source="artcod" target="stkarticulo_id" />
        </helper>
      </field>    
    </table>
