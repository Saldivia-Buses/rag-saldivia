			<filters>
				<field id="artcod" deshabilitado="false">
					<ayuda_ex id="STKINSUM">
						<clave>artcod</clave>
						<descripcion>artdes</descripcion>
					</ayuda_ex>
					
					<label>Cod.</label>
					<operador>=</operador>					
				</field>			
				<field id="artdes" deshabilitado="false">
					<label>Articulo</label>
					<help>Descripcion de Articulo. (ENTER = Retorna a ingreso de codigo).
						</help>
					<operador>like</operador>
				</field>				
			</filters>			
		</table>
	</form>
</histrix>