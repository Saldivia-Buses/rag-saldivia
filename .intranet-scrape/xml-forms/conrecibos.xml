<?xml version="1.0" encoding="utf-8" ?>
   <histrix tipo="consulta">
       <title>Cuenta Corriente</title>
        <obs></obs>
               <form  >
                  <table id="CCTMOVIM" label="Movimientos">

                    <filters>
                      <field id="movfec"  >
                          <operador>&gt;=</operador>
                          <label>Desde Fecha</label>
                          <valor>today</valor>

                      </field>  
                      <field id="movfec" >
                          <operador>&lt;=</operador>
                          <label>Hasta Fecha</label>
                          <valor>today</valor>

                      </field>
                    </filters>

                  <field id="siscod" oculto="true">
                      <label>Cod.</label>
                      <help> </help>
                  </field>
                  <field id="ctacod">
                      <label>Cuenta</label>
                      <help>Código de Cuenta </help>
                  </field>
                  <field id="ctanom" tabla="CCTCUENT">
                      <label>Nombre</label>
                  </field>
                  
                  <field id="movnpv">
                      <label>P.V.</label>
                      <help> Punto Venta</help>
				      <format>%04d</format>
                  </field>
                  <field id="movnro">
                      <label>Número</label>
                      <help> Número Comprobante</help>
				      <format>%12d</format>
                  </field>
                  <field id="condes" tabla="CCTCONCE">
                      <label>Cod.Concepto</label>
                      <help> </help>
				      <tipo>string</tipo>
                  </field>
                  
				  <field id="concod" oculto="true">
					  <label>conc</label>
					  <condicion operador="=">4</condicion>
					</field>
		

                  <field id="movfec">
                      <label>Fecha </label>
                      <help> </help>
					  <detalle>movfec</detalle>
					  <detalle>cajfec</detalle>					  
                  </field>

    <!--          <field id="movvto">
                      <label>Venc. </label>
                      <help> </help>
                  </field>
-->
                  <field id="movimp" >
                      <label>Importe</label>
                      <help> </help>
                  </field>

                  <field id="movsal" suma="true">
                      <label>Saldo</label>
                      <help> </help>
                  </field>

                  </table>
		  <join tipo="left">
		    <table id="CCTCONCE">
			<field id="siscod" oculto="true">
			    <label>cctcuent.siscod</label>
			    <condicion operador="=">CCTMOVIM.siscod</condicion>
			</field>

			<field id="concod" oculto="true">
			    <condicion operador="=">CCTMOVIM.concod</condicion>
			</field>

			<field id="condes" oculto="true">
			</field>
		    </table>
		  </join>
		  <join tipo="left">
		    <table id="CCTCUENT">
			<field id="siscod" >
			    <label>cctcuent.siscod</label>
			    <condicion operador="=">CCTMOVIM.siscod</condicion>
			</field>

			<field id="ctacod" >
			    <condicion operador="=">CCTMOVIM.ctacod</condicion>
			</field>

		    </table>
		  </join>		  
               </form>
        </histrix>