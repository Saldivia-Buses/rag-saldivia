<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="ing"  borra="no" inserta="false" modifica="false" llenoreferente="true" imprime="false">
	<title>COMPROBANTES A IMPUTAR</title>
	<obs/>
	<form>
		<table id="CCTMOVIM" label="COMPROBANTES A IMPUTAR" idCampoCond="imputar">

			<campo id="siscod" oculto="true" _esClave="true">
				<label>Cod.</label>
				<help></help>
				<valor>'02'</valor>
				<condicion operador="=">'02'</condicion>
			</campo>

			<campo id="ctacod" oculto="true" _esClave="true">
				<label>Cuenta</label>
				<help>Codigo de Cuenta</help>
			</campo>
			<campo id="movfec" deshabilitado="true">
				<label modpos="nobr">Fecha</label>
				<help></help>
				<!--  <format>d  m  y</format> -->
				<detalle>movfec</detalle>				
			</campo>
			<campo id="concod"  tabla="CCTMOVIM" oculto="true" _esClave="true">
				<label>concod</label>
				<help>Tipo</help>
				<detalle>concod</detalle>
			</campo>

			<campo id="condes"  tabla="CCTCONCE" deshabilitado="true">
				<label>Tipo</label>
				<help>Tipo de Comprobante</help>
				<tipo>varchar</tipo>
			</campo>
			<campo id="movnpv" deshabilitado="true" _esClave="true">
				<label modpos="nobr">Numero</label>
				<help>Comprobante</help>
				<format>%04d</format>
				<detalle>movnpv</detalle>				
			</campo>
			<campo id="movnro" deshabilitado="true" __esClave="true">
				<label modpos="nobr"/>
				<help>Numero Comprobante</help>
				<format>%012d</format>
				<detalle>movnro</detalle>				
			</campo>
			<campo id="movimp" deshabilitado="true">
				<label PDFsize="12" posx="130" posy="+1">Total Pago</label>
				<help></help>
				<format>%01.2f</format>
				<detalle>movimp</detalle>
				
			</campo>
			<campo id="movsal" deshabilitado="true">
				<label>saldo</label>
				<help></help>
				<condicion operador="!=">0</condicion>
				<detalle>movsal</detalle>				
				<detalle>salant</detalle>				
				
			</campo>
			
			<campo id="imputar" local="true" refresh="true" >
				<label>imputar</label>
				<help>Seleccion</help>
				<tipo>check</tipo>  
				<valor>0</valor>
			</campo>			
			<campo id="movcta" deshabilitado="true" noshow="true">
				<label modpos="nobr">movcta</label>
				<detalle>movcta</detalle>				
			</campo>	
			<campo id="movlet"  noshow="true">
				<detalle>movlet</detalle>				

			</campo>			
			<campo id="movipv"  noshow="true">
				<detalle>movipv</detalle>				
			</campo>			
			<campo id="movinc"  noshow="true">
				<detalle>movinc</detalle>				
			</campo>			
			<campo id="zoncod"  noshow="true">
				<detalle>zoncod</detalle>				
			</campo>	
					
			<campo id="ctanom"  noshow="true">
				<detalle>ctanom</detalle>				
			</campo>			
			<campo id="movicc"  noshow="true">
				<detalle>movicc</detalle>				
			</campo>			
			<campo id="movnet"  noshow="true">
				<detalle>movnet</detalle>				
			</campo>			
<!--			<campo id="movpro"  noshow="true">
				<detalle>movpro</detalle>				
			</campo>			
-->
			<campo id="movref__1"  noshow="true">
				<detalle>movref__1</detalle>				
			</campo>			
			<campo id="movref__2"  noshow="true">
				<detalle>movref__2</detalle>				
			</campo>			
			<campo id="movref__3"  noshow="true">
				<detalle>movref__3</detalle>				
			</campo>			
			<campo id="movvto"  noshow="true">
				<detalle>movvto</detalle>				
			</campo>			
			<campo id="opecla"  noshow="true">
				<detalle>opecla</detalle>				
			</campo>			
			<campo id="regmin"  noshow="true">
				<detalle>regmin</detalle>				
			</campo>			
			
			
			
		</table>
		<join tipo="left">
			<table id="CCTCONCE">
				<campo id="siscod" oculto="true">
					<label>cctcuent.siscod</label>
					<condicion operador="=">CCTMOVIM.siscod</condicion>
				</campo>
				<campo id="concod" oculto="true">
					<condicion operador="=">CCTMOVIM.concod</condicion>
				</campo>
				<campo id="condes" oculto="true"></campo>
			</table>
		</join>
		<join tipo="left">
			<table id="CCTCUENT">
				<campo id="siscod" oculto="true">
					<label>cctcuent.siscod</label>
					<condicion operador="=">CCTMOVIM.siscod</condicion>
				</campo>
				<campo id="ctacod" oculto="true">
					<condicion operador="=">CCTMOVIM.ctacod</condicion>
				</campo>
			</table>
		</join>
	</form>
</histrix>
