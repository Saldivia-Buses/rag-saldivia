				<join tipo="left">
					<table id="PEDCOTIZ">
						<field id="nrocha">
							<condicion operador="=">TURNOSPRODUCCION.nrofab</condicion>
						</field>
					</table>
				</join>				   
				<join tipo="left">
					<table id="CCTCUENT">
						<field id="ctacod">
							<condicion operador="=">PEDCOTIZ.ctacod</condicion>
						</field>
						<field id="siscod" oculto="true">
							<condicion operador="=">'02'</condicion>
						</field>
						
					</table>
				</join>				   
				<join tipo="left">
					<table id="CHASIS">
						<field id="nrocha">
							<condicion operador="=">TURNOSPRODUCCION.nrofab</condicion>
						</field>
					</table>
				</join>
				<join tipo="left">
					<table id="CONCESIONARIO">
						<field id="idconces">
							<condicion operador="=">CHASIS.conces</condicion>
						</field>
					</table>
				</join>		
				<join tipo="left">
					<table id="MODCHASIS">
						<field id="modcha">
							<condicion operador="=">CHASIS.modcod</condicion>
						</field>
						<field id="marcod">
							<condicion operador="=">CHASIS.marcod</condicion>
						</field>
					</table>
				</join>
					<join tipo="left">
