<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" path="fotos/" preloadData="false" paginar="100">
    <title>Ingreso de unidades por seccion</title>
    <obs/>
    <form>
        <table id="MRP_PEDIDO_PRODUCCION">

            <filters>
                <field id="seccion_id">
                    <label>Seccion</label>
                    <operador>=</operador>
                </field>

                <field id="iniciado" deshabilitado="false">
                    <label modpos="nobr">Iniciado</label>
                    <operador>=</operador>
                    <valor>1</valor>
                </field>

                <field id="terminado2" deshabilitado="false">
                    <label modpos="nobr">Terminado</label>
                    <operador>=</operador>
                    <valor>0</valor>
                </field>
			   <field id="nrofab_id">
           		<label modpos="nobr">Unidad</label> 
                 <operador>=</operador>

              	</field>
            </filters>

            <field id="id_mrp_pedido_prod" esClave="true" noshow="true"/>

            <field id="ficha_id" noshow="true">
                <expression>PEDCOTIZ.id</expression>
            </field>

            <field id="nrofab_id">
                <label>Nro.Fab</label>
                <helper type="link" xml="ficha_producto1_qry.xml" dir="/producto" title="Ficha Técnica">
                    <parameter source="ficha_id" target="id" />
                    <parameter source="ficha_id" target="producto_id" />
                    <parameter source="nrofab_id" target="nrofab" />
                </helper>
            </field>

            <field id="stkarticulo_id" _noshow="true">
                <label>Articulo</label>
            </field>

            <field id="artcod" noshow="true" tabla="STKINSUM" />

            <field id="artdes">
                <expression>artdes</expression>
                <label>Descripcion</label>
            </field>

            <field id="cantidad_pieza_unidad">
                <label>Cant.Unidad</label>
                <tipo>decimal</tipo>
            </field>

            <field id="homologacion" noshow="true">
                <label>Homol</label>
                <expression>@homologacion:=(PEDCOTIZ.homologacion_id)</expression>
            </field>

            <field id="fotopath" local="true" noshow="true">
                <valor>articulos</valor>
            </field>

<!--             <field id="foto" path="fotopath" print="false" download="false">
              <expression><![CDATA[CASE WHEN (MRP_PEDIDO_PRODUCCION.stkarticulo_id = '558007' OR MRP_PEDIDO_PRODUCCION.stkarticulo_id = '558008')
