                                                    ORDER BY revision DESC LIMIT 1) END]]></expression> 
                <label>Imagen</label>
                <tipo>file</tipo>
              <size>60</size>
            </field>
 -->
            <field id="seccion_id" tabla="MRP_PEDIDO_PRODUCCION" noshow="true">
                <label>Salida de</label>
                <helper type="combo" id="MOMENTO" empty="true">
                    <field id="idMomento" />
                    <field id="descripcion" />
                    <field id="pedidoproduccion" local="true">
                        <expression>select count(*) from MRP_PEDIDO_PRODUCCION MP where MP.seccion_id = seccion_id</expression>
                        <condicion operador="!=">0</condicion>
                    </field>
                    <field id="linea_id">
                        <condicion operador="=">1</condicion>
                    </field>
                    <order>
                        <field id="orden" tipoOrden="ASC"/>
                    </order>
                </helper>
            </field>

            <field id="usuario_id" local="true" noshow="true">
                <valor eval="true">$_SESSION['idUser']</valor>
            </field>

             <field id="homologacion_id" tabla="PEDCOTIZ" noshow="true">
                <label>Homol</label>
<!--                 <helper type="combo" xml="combo_homologacion_modelo.xml" dir="/fabricacion" empty="true">
                </helper>
 -->            </field>

             <field id="creacion">
                <label>Creó</label>
                <expression>case when creacion_hora = '0000-00-00 00:00:00' then '' else creacion_hora end</expression>
                <tipo>date</tipo>
            </field>

             <field id="creacion_hora">
                <label>Creó Hs</label>
                <expression>case when creacion_hora = '0000-00-00 00:00:00' then '' else TIME(creacion_hora)  end</expression>
            </field>

             <field id="inicio">
                <label>Inicio</label>
                <expression>case when inicio_hora = '0000-00-00 00:00:00' then '' else inicio_hora end</expression>
                <tipo>date</tipo>
            </field>

             <field id="inicio_hora">
                <label>Inicio Hs</label>
                <expression>case when inicio_hora = '0000-00-00 00:00:00' then '' else TIME(inicio_hora)  end</expression>
            </field>

             <field id="terminado">
                <label>Term.</label>
                <expression>case when terminado_hora = '0000-00-00 00:00:00' then '' else terminado_hora end</expression>
                <tipo>date</tipo>
            </field>

             <field id="terminado_hora">
                <label>Term. Hs</label>
                <expression>case when terminado_hora = '0000-00-00 00:00:00' then '' else TIME(terminado_hora)  end</expression>
            </field>

            <field id="iniciado" noshow="true">
                <label>Iniciado</label>
                <expression>case when inicio_hora = '0000-00-00 00:00:00' then 0 else 1 end</expression>
                <options>
                    <option valor=""></option>
                    <option valor="0">No</option>
                    <option valor="1">Si</option>
                </options>
            </field>

            <field id="terminado2" noshow="true">
                <label>Inicio</label>
                <expression>case when terminado_hora = '0000-00-00 00:00:00' then 0 else 1 end</expression>
                <options>
                    <option valor=""></option>
                    <option valor="0">No</option>
                    <option valor="1">Si</option>
                </options>
            </field>

            <field id="modelo_lcm_id" tabla="HOMOLOGMOD" noshow="true"/>
            <field id="nrocar" tabla="HOMOLOGMOD" noshow="true"/>

            <order>
                <field id="creacion_hora" tipoOrden="DESC" />
            </order>

        </table>

        <join>
            <table id="POSICIONESFAB">
                <field id="id_posicionfab">
                    <condicion operador="=">MRP_PEDIDO_PRODUCCION.posicionfab_id</condicion>
                </field>
            </table>
        </join>

        <join>
            <table id="PEDCOTIZ">
                <field id="nrocha">
                    <condicion operador="=">MRP_PEDIDO_PRODUCCION.nrofab_id</condicion>
                </field>
            </table>
        </join>

        <join>
            <table id="MOMENTO">
                <field id="idMomento">
                    <condicion operador="=">MRP_PEDIDO_PRODUCCION.seccion_id</condicion>
                </field>
            </table>
        </join>

        <join>
            <table id="HOMOLOGMOD">
                <field id="id_homologacion">
                    <condicion operador="=">PEDCOTIZ.homologacion_id</condicion>
                </field>
            </table>
        </join>

        <join tipo="left">
            <table id="STKINSUM">
                <field id="artcod">
                    <condicion operador="=">MRP_PEDIDO_PRODUCCION.stkarticulo_id</condicion>
                </field>
                <field id="siscod">
                    <condicion operador="=">'01'</condicion>
                </field>
            </table>
        </join> 

    </form>
</histrix>