<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="liveGrid" deleteRow="false">
    <title>DETALLE ORDEN PRODUCCION</title>
    <obs></obs>
    <form >
        <table id="MRP_CONTROL_DETALLE" label="CONTROLES CALIDAD" >

            <field id="id_mrpcontroldetalle"   noshow="true" esClave="true"/>

            <field id="mrpordendetalle_id"   noshow="true" />
            <field id="mrpcontrol_id" noshow="true">
            </field>
            <field id="nombre_control" >
        	<expresion>nombre_control</expresion>

        	<label>Control</label>
            </field>
            <field id="peso_control" noshow="true">
        	<expresion>peso_control</expresion>
        	<label>Valor</label>
            </field>




            <field id="control_estado" editable="true">
        	<label>S</label>
        	<tipo>check</tipo>
            </field>
            <field id="control_observacion" editable="true">
        	<label>observacion</label>
        	<size>10</size>
            </field>

        </table>
        <join tipo="left">
    	    <table id="MRP_CONTROLES">
    		<field id="id_mrpcontrol">
    		    <condicion  operador="=">mrpcontrol_id</condicion>
    		</field>
    	    </table>
    	    
        </join>
    </form>
</histrix>
