            <field id="ninterno" deshabilitado="true">
                <label  size="23" posx="160" posy="0" PDFsize="10"  colspan="2">Nro Interno</label>
                <help></help>
            </field>

            <field id="usuarionow" local="true" noshow="true">
                <valor eval="true">$_SESSION['idUser']</valor>
            </field>            
            <!--<order>
                                <field id="fechaing" tabla="TURNOSPRODUCCION"/>
                        </order> -->
            <order>
                <field id="fechaing"/>
                <field id="ingresoLinea"/>
            </order>
        </table>
        
        <join tipo="left">
      <table id="CHASIS">
    <field id="nrocha">
        <condicion operador="=">PEDCOTIZ.nrocha</condicion>
    </field>
      </table>
      </join>
        <join >
          <table id="HOMOLOGMOD">
            <field id="id_homologacion">
              <condicion operador="=">homologacion_id</condicion>
            </field>
          </table>
        </join>  

        <join tipo="left">
            <table id="TURNOSPRODUCCION">
                <field id="nrofab">
                  <condicion operador="=">PEDCOTIZ.nrocha</condicion>
                </field>
            </table>
        </join>

        <join tipo="left">
            <table id="REG_CUENTA">
                <field id="nro_cuenta">
                  <condicion operador="=">PEDCOTIZ.ctacod</condicion>
                </field>
                <field id="subsistema_id">
                  <condicion operador="=">'02'</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
          <table id="HTXUSERS">
            <field id="id_usuario">
              <condicion operador="=">[__usuarionow__]</condicion>
            </field>
          </table>
        </join>  
    </form>
</histrix>
