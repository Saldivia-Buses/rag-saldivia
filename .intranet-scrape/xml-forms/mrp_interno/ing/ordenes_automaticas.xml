            <field id="cantasi" deshabilitado="true" >
                <label  >Asi.</label>
                <help></help>
            </field>
            <field id="marasi" deshabilitado="true">
                <label size="23" posx="60" posy="0" modpos="nobr" xml="marcaasi.xml" PDFsize="10" colstyle="display:none;" colspan="2">Marca</label>
                <help></help>
                <tabla_ex xml="marcaasi.xml">
                    <field id="siscod" oculto="true">
                        <condicion operador="=">03</condicion>
                    </field>
                </tabla_ex>
            </field>
            <field id="tipasi" deshabilitado="true">
                <tabla_ex xml="tipoasiento.xml" dir="/produccion">
                    <field id="siscod" oculto="true">
                        <condicion operador="=">03</condicion>
                    </field>
                </tabla_ex>
                <label size="23" posx="6" posy="+1" PDFsize="10" colstyle="display:none;">Tipo As.</label>
                <help></help>
            </field>

            <field id="bagno" deshabilitado="true">
                <label size="23" posx="6" posy="+1" PDFsize="10" >Baño</label>
                <help></help>
                <options>
                    <option valor="0"></option>
                    <option valor="1">No</option>
                    <option valor="2">Si</option>
                    <option valor="3">S/D</option>
                </options>
            </field>
            <field id="miniba" deshabilitado="true">
                <label size="23" posx="60" posy="0" modpos="nobr" PDFsize="10" colstyle="display:none;">Minibar</label>
                <help></help>
                <!--
                                <tipo>check</tipo> -->
                <options>
                    <option valor="0"></option>
                    <option valor="1">No</option>
                    <option valor="2">Si</option>
                    <option valor="3">S/D</option>
                </options>

            </field>

            <field id="barcom" deshabilitado="true">
                <label size="23" posx="110" posy="0"  PDFsize="10" colstyle="display:none;">Bar Completo</label>
                <help></help>
                <tipo>check</tipo>
            </field>
