                                        </field>
                                </tabla_ex>
                        </field>
-->
            <field id="nrocar" deshabilitado="true">
                <tabla_ex xml="carroceria.xml">
                    <field id="siscod" oculto="true">
                        <condicion operador="=">03</condicion>
                    </field>
                </tabla_ex>

                <label size="23" posx="110" posy="0" PDFsize="10">Carroceria</label>
                <help></help>
            </field>

      <field id="modcod" tabla="CHASIS">
        <label>Mod. Chasis</label>
        <expression> SELECT MODCHASIS.moddes FROM MODCHASIS where CHASIS.marcod=MODCHASIS.marcod AND modcod=MODCHASIS.modcha </expression>
      <help></help>
      </field>
    
          
                  
    <field id="marca" tabla="CHASIS" local="true">
        <label>Marca. Chasis</label>
        <expression> select MARCHASIS.mardes from MARCHASIS where CHASIS.marcod=MARCHASIS.marcod</expression>
      <help></help>
      </field> 
    
       
