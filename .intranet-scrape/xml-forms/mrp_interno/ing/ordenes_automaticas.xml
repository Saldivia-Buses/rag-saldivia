<?xml version="1.0" encoding="UTF-8"?>
<histrix  tipo="grid" log="false" paginar="100" path="fotos/coches" _width="50"  process="true"
          borra="false" inserta="false"
          >
    <title>ENTRADA Y SALIDA</title>
    <obs/>
    <form  >
        <table id="PEDCOTIZ" label="Ficha de Ventas">

	    <movimientos>
		<relacion id="orden_automatica_ins.xml" />
	    </movimientos>

	    <filters>
                <field id="nrocha" tabla="PEDCOTIZ" >
    	            <label >N.Fab.</label>
		    <operador>=</operador>
		</field>
	    </filters>

            <field id="id" noshow="true" deshabilitado="true">
            </field>
            <field id="nrocha" tabla="PEDCOTIZ" esClave="true" tipoOrden="DESC" deshabilitado="true">
                <!--      <expression>LPAD(PEDCOTIZ.nrocha,3,'0')</expression> -->
                <label size="25" _modpos="nobr" posx="110" posy="0" PDFsize="11">N.Fab.</label>
                <help>Numero de Fabricacion</help>

            </field>
            <field id="artcod_id" tabla="HOMOLOGMOD" >
		    <label>Articulo</label>
            </field>
            <field _esClave="true" id="fechaing" _PDFanchofijo="true" tipoOrden="DESC" noshow="true">
                <expression>case when PEDCOTIZ.ingresoLinea != '0000-00-00' then PEDCOTIZ.ingresoLinea else fechaing end</expression>
                <label >Entra</label>
                <tipo>date</tipo>
                <help>Fecha de Ingreso a Linea</help>
                <!--  <format>d/m</format> -->

            </field>
            <field id="ingresoLinea" tipoOrden="DESC">
                <label>Fecha de Inicio</label>
                <help>Fecha de ingreso a la línea de producción</help>
                <tipo>date</tipo>
            </field>
            <!-- <field id="sale2" esClave="true" noshow="true">
                <attribute id="style">colorFecTer</attribute>

                <label modpos="nobr" >Sale</label>
                <expression>DATE_ADD((case when ingresoLinea != '0000-00-00' then ingresoLinea else fechaing end), INTERVAL 45 DAY)</expression>-->


          <field id="fecha_chaperia" tipoOrden="DESC">
                <label>Fecha Chaperia</label>
                <tipo>date</tipo>
            </field>

          

            <field id="terminacion" tipoOrden="DESC">
                <label>Fecha de Terminación</label>
                <tipo>date</tipo>
            </field>
          
          
            

            <field id="terminacionFinal">
                <label>Aviso Entrega</label>
                <tipo>date</tipo>
            </field>

            <field id="mailto"  deshabilitado="true" noshow="true">
              <expression>select mail from CCTCONTA where siscod = '02' and CCTCONTA.ctacod = PEDCOTIZ.ctacod order by principal DESC limit 1</expression>
            </field>

            <field id="mailsubj" noshow="true" >
              <expression>CONCAT('Entrega Unidad ', PEDCOTIZ.nrocha)</expression>
            </field>

            <field id="mailbody" noshow="true">
              <expression><![CDATA[CONCAT(

                'Att Sres.n</br>El día ', DATE_FORMAT(PEDCOTIZ.terminacionFinal, '%d/%m/%Y'), ', por la tarde, tendremos terminada la unidad ', PEDCOTIZ.nrocha, ' de ', REG_CUENTA.nombre_cuenta,
                ', chasis nro. ', RIGHT(CHASIS.chasis, 6), ' concesionario ', (select CONCESIONARIO.nombre from CONCESIONARIO WHERE CHASIS.conces = CONCESIONARIO.idconces), '.</br>La misma es retirada por el concesionario.n</br>Nuestro horario de entrega es de Lunes a Viernes 7 a 16hs.nn</br></br></br>Saludosnn</br></br>', HTXUSERS.apellido, ', ', HTXUSERS.Nombre, '</br>n0341-4921135n</br>Chile 2541 - Villa Gdor. Galvez - Santa Fe - Argentinan</br><a href="www.saldiviabuses.com.ar" >www.saldiviabuses.com.ar</a>'

                )]]>
              </expression>
            </field>

              <field id="filtmail" noshow="true">
                <expression>CONCAT('+"Entrega Unidad" +', PEDCOTIZ.nrocha)</expression>
              </field>

            <field id="email"  colstyle="width:auto;" deshabilitado="false" local="true" Formstyle="display:none;">
                <helper type="link" xml="mails_send.xml" dir="/histrix/mensajeria/" title="Entrega Unidad" width="700" height="600">
                    <parameter source="mailto"  target="para" />
                    <parameter source="mailsubj" target="subject" />
                    <parameter source="mailbody" target="mensaje" />
                </helper>
                <expression sql="true"><![CDATA[
                SELECT CONCAT(
                (SELECT COUNT(*) FROM HTXMAIL WHERE MATCH(subject, body) AGAINST ('[__filtmail__]' IN BOOLEAN MODE) )
                , ' <img src="../img/mail_generic.png"/>') 
                ]]></expression>
            </field>
            <!-- <field id="fechaing" tabla="TURNOSPRODUCCION" tipoOrden="DESC">
                                <label>FEcha Ingreso</label>
                                <tipo>date</tipo>
                        </field>-->
          <field id="nomconces" local="true">
          
            <label>Concesionario</label>
            <expression>select CONCESIONARIO.nombre from CONCESIONARIO WHERE CHASIS.conces = CONCESIONARIO.idconces </expression>
            
          </field>
          
          
          
            <field id="nro2" noshow="true">
                <expression>LPAD(PEDCOTIZ.nrocha,3,'0')</expression>
            </field>

            <field id="ctacod" deshabilitado="true">
                <label size="23" posx="6" posy="+1" PDFsize="12" colspan="6">Cliente</label>
                <help>Codigo de Cuenta</help>
                <tabla_ex condes="true" id="CCTCUENT">
                    <field id="ctacod"/>
                    <field id="ctafan2">
                        <expression>CCTCUENT.ctafan</expression>
                    </field>
                    <field id="siscod" oculto="true">
                        <condicion operador="=">'02'</condicion>
                    </field>
                    <field id="baja" oculto="true">
                        <condicion operador="=">0</condicion>
                    </field>
                    <order>
                        <field id="ctafan" />
                    </order>
                </tabla_ex>

            </field>
            <!--
                        <field id="idconta" deshabilitado="true">
                                <label size="23" posx="6" posy="+1" PDFsize="12" colspan="4" colstyle="display:none;">Contacto</label>
                                <help>Codigo de Cuenta</help>
                                <tabla_ex condes="true" id="CCTCONTA" vacio="true">
                                        <field id="idconta"/>
