		<!--/////////////////////////////////////////////////////////////////-->

		<field id="unicps" tabla="STKINSUM" deshabilitado="true">
			<label modpos="nobr">Unidad</label>
			<help>Unidad de Compra</help>
			<helper type="combo" id="FSMUNIDS">
				<field id="unicod"></field>
				<field id="uninom"></field>
			</helper>
			<detalle>unicps</detalle>
		</field>
		<field id="conversion" local="true"  >
			<label>Conv</label>
			<if exp="valcps == valuso">
				<true>valuso * cantidad</true>
				<false>(valcps == 1)?(cantidad * valuso):(cantidad / valcps)</false>
			</if>
			<tipo>decimal</tipo>
			<detalle>cant</detalle>

		</field>

		<field id="artuni" _noshow="true" tabla="STKINSUM" deshabilitado="true">
			<detalle>artuni</detalle>
			<label modpos="nobr">Unid.</label>
			<help>Unidad de Compra</help>
			<helper type="combo" id="FSMUNIDS">
				<field id="unicod"></field>
				<field id="uninom"></field>
			</helper>
		</field>

		<field id="selec" local="true" refresh="true">
			<label Formstyle="display:none;">Selec.</label>
			<help>Seleccion</help>
			<tipo>check</tipo>
			<valor>1</valor>
		</field>
		<field id="artcos" noshow="true" tabla="STKINSUM">
			<detalle>artcos</detalle>
		</field>
		<field id="artrub" noshow="true" tabla="STKINSUM">
			<detalle>artrub</detalle>
		</field>
		<field id="unidef" noshow="true" tabla="STKINSUM">
			<detalle>unidef</detalle>
		</field>

		<field id="valcps" noshow="true" tabla="STKINSUM">
			<detalle>valcps</detalle> 
		</field>
		<field id="valuso" noshow="true" tabla="STKINSUM">
			<detalle>valuso</detalle> 

		</field> 
	</table>
	<join tipo="left">
		<table id="STKINSUM">
			<field id="siscod" >
				<condicion operador="=">'01'</condicion>
			</field>
			<field id="artcod">
				<condicion operador="=">STKPIEZA.articulo_hijo</condicion>
			</field>

		</table>
    	</join>
</form>
</histrix>