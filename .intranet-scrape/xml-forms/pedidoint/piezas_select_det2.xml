<?xml version="1.0" encoding="ISO-8859-1" ?>
<histrix tipo="ing" imprime="false" llenoreferente="true"  style="height:100%" modifica="false" inserta="false">
	<title>FORMACION DE PRODUCTO</title>
	<obs></obs>
	<form >
		<table id="STKPIEZA" label="Piezas" idCampoCond="selec">

			<field id="_ORDEN" oculto="true" local="true">
				<detalle>_ORDEN</detalle>
			</field>
			<field id="fecreq" noshow="true" local="true">
				<detalle>fecreq</detalle>
			</field>
			<field id="codprv" noshow="true" local="true">
				<label>ctacod</label>
				<detalle>codprv</detalle>
			</field>

			<field id="ctanom" tabla="CCTCUENT" noshow="true" >
				<expression>
					select CCTCUENT.ctanom FROM CCTCUENT where siscod = '01' and ctacod = ([__codprv__] + 0 ) LIMIT 1
				</expression>
				<detalle>ctanom</detalle>
			</field>

			<field id="id_pieza" oculto="true"></field>

			<field id="idPadre" oculto="true" esClave="false">
				<label>padre</label>
				<help>Nombre del Articulo al que pertenece</help>
			</field>
			<field id="articulo_hijo" arbol="hijo" deshabilitado="true">
				<label>Cod.de Pieza</label>
				<help>Codigo del Articulo</help>
				<detalle>artcod</detalle>
				<detalle>idPadre</detalle>
			</field>
			<field id="artdes" deshabilitado="true">
				<expression>artdes</expression>
				<label>Articulo</label>
				<tipo>varchar</tipo>
				<detalle>artdes</detalle>
			</field>
			<field id="cantidad" deshabilitado="true" suma="true">
				<label>Cantidad</label>
				
				<detalle>movcant</detalle>
<!--				<detalle>cant</detalle> -->
                                    
                                    <detalle>conversion</detalle>
				<detalle>movtemp</detalle>

			</field>

			<!--/////////////////////////////////////////////////////////////////-->

			<!--

            <field id="valCps" _noshow="true">
			<expression>valcps</expression>
		</field>

		<field id="valUso" _noshow="true" >
