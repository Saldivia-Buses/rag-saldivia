<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="insert">
    <title>MOVIMIENTOS DE orden compras</title>
    <obs></obs>
    <form >
        <table id="PEDIDOINT" label="MOVIMIENTOS" idCampoCond="pedir">
            <field id="artcod"      id_temp="id_stkarticulo"></field>


            <field id="usuario" 	>
                <valor eval="true">$_SESSION['usuario']</valor>
            </field>
            <field id="tipocomp" 	>
                <valor>1</valor>
            </field>
            <field id="fechaemi" 	>
                <valor>curdate()</valor>
