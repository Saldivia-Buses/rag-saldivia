<?xml version="1.0" encoding="utf-8" ?>
<histrix tipo="chart">
	<titulo>LLamadas Mensuales</titulo>
	<obs></obs>
	<consulta>
		<tabla id="GEN_CALENDAR" >
			<titulo>Cantidad Llamadas</titulo>
		   <grafico id="llamadas" >
			   <ancho>400</ancho>
			   <tipo>P</tipo>
			   
			   <etiquetas>mes</etiquetas> 
			   <serie>entrantes</serie>
                           <serie>salientes</serie>
			   
			   <titulo>Total llamadas</titulo>
			   <subtitulo></subtitulo>
		   </grafico>
		    <filtros>
			    <campo id="fecha">
				    <label>Desde</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-1 month')) , 1, date("Y") - 1 ))</valor>
				    <operador>&gt;=</operador>
			    </campo>
			    <campo id="fecha">
                                    <label>Hasta</label>
				     <valor>today</valor>
				    <operador>&lt;=</operador>
			    </campo>
		    </filtros>
		
			<campo id="mes">
				<expresion>month(fecha)</expresion>
				<label>Mes</label>	
				<opciones>
					<opcion valor="1">Ene</opcion>
					<opcion valor="2">Feb</opcion>
					<opcion valor="3">Mar</opcion>
					<opcion valor="4">Abr</opcion>
					<opcion valor="5">May</opcion>
					<opcion valor="6">Jun</opcion>
					<opcion valor="7">Jul</opcion>
					<opcion valor="8">Ago</opcion>
					<opcion valor="9">Sep</opcion>
					<opcion valor="10">Oct</opcion>
					<opcion valor="11">Nov</opcion>
					<opcion valor="12">Dic</opcion>
					
				</opciones> 
			</campo>
                    <campo id="fecha" oculto="true">
<!--                            <condicion operador="&gt;="> DATE_FORMAT(date_sub(date(now()) , interval 1 year) ,'%Y-%m-01') and GEN_CALENDAR.fecha &lt;= now()</condicion>
-->
<!--                        <condicion operador="&gt;="> date_sub(date(now()) , interval 1 year) and GEN_CALENDAR.fecha &lt;= now()</condicion> -->
                    </campo>
                    <campo id="year" oculto="true">
                        <expresion>year(fecha)</expresion>

                    </campo>
			<campo id="entrantes">
				<expresion><![CDATA[(select avg(case when LOCATE('<', numero) != 0 then SUBSTRING(trim(numero), 7) end) from TEL_LOG
                                where
                                month(TEL_LOG.fecha) = month(GEN_CALENDAR.fecha) and
                                year(TEL_LOG.fecha) = year(GEN_CALENDAR.fecha))]]>
                                </expresion>
				<label>Entrantes</label>
                                <tipo>integer</tipo>
			</campo>
			<campo id="salientes">
				<expresion><![CDATA[(select avg(case when LOCATE('<', numero) = 0 then SUBSTRING(trim(numero), 7) end) from TEL_LOG 
                                where  month(TEL_LOG.fecha) = month(GEN_CALENDAR.fecha) and
                                year(TEL_LOG.fecha) = year(GEN_CALENDAR.fecha))]]>
                                </expresion>
				<label>Salientes</label>
				<tipo>integer</tipo>
			</campo>
			<group>
                                <campo id="year"></campo>
				<campo id="mes"></campo>

			</group>

		</tabla>
			
	</consulta>	   
</histrix> 
