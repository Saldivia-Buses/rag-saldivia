<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" _autoupdate="180" path="../files/archives/nfsAsterisk" _limit="10" paginar="40">
    <title>CONSULTA DE LLAMADAS</title>
    <form detalle="hasdetseg" inline="true" hasDetail="hasdet">
        <table id="ASTERIX_CDR">
            <title>Llamadas</title>
            <filters>
                <field id="fecha" deshabilitado="false">
                    <label>Desde Fecha</label>
                    <operador>&gt;=</operador>
                    <valor>today</valor>
          
                </field>
                <field id="fecha" deshabilitado="false">
                    <label modpos="nobr">Hasta Fecha</label>
                    <operador>&lt;=</operador>
                    <valor>today</valor>
          
                </field>
                <field id="telefonos" deshabilitado="false">
                    <label>Teléfono</label>
                    <operador>like</operador>
                </field>
        
            </filters>
            
            <field id="uniqueid" oculto="true" >
        	<label>id</label>
            </field>
            
            <field id="calldate" noshow="true" tipoOrden="DESC">
            </field>
            
            <field id="fecha">
        	<expression>date(calldate)</expression>
                <label>Fecha</label>
                <tipo>date</tipo>
                <detalle>fecha</detalle>
            </field>
            <field id="hora" style="padding:0px 5px;">
        	<expression>date_format( calldate, '%H:%i:%s' )</expression>
                <label>Hora</label>
                <tipo>time</tipo>
            </field>
            
            <field id="tipo" noshow="true" local="true">
                <options>
                    <option valor="">Todos</option>
                    <option valor="entrantes">Entrantes</option>
                    <option valor="salientes">Salientes</option>
                </options>
            </field>
            
<!--            <field id="src" >
                <label>Origen</label>
            </field>             -->
            <field id="newsrc" >
        	<expression>@newsrc:=(case when src != '' then src else (substring(channel,5,3)) end)</expression>
                <label>Origen</label>
            </field>

            <field id="telefonos" noshow="true">
        	<expression having="false">CONCAT(src,dst)</expression>
            </field>

            <field id="InternoSrc" noshow="true">
                <expression>@internosrc := (case when length(@newsrc) = 3 then (select CONCAT(Nombre, ' ', apellido) from HTXUSERS where HTXUSERS.interno = @newsrc limit 1) end)</expression>
            </field>
            <field id="empresaSrc" noshow="true">
                <expression>@empresasrc :=  ifnull((SELECT CCTCUENT.ctafan  FROM CCTCONTA
          left join CCTCUENT on CCTCUENT.siscod = CCTCONTA.siscod and CCTCUENT.ctacod = CCTCONTA.ctacod
          WHERE   length(@newsrc) != 3 and (
          (replace(CONCAT(Telefono,'.',movil), ' ','') like CONCAT('%' ,trim(@newsrc) ,'%') and trim( @newsrc) != '' )  or  
          (replace(CONCAT(Telefono,'.',movil), ' ','') like CONCAT('%' ,right(trim(@newsrc), 6 ) ,'%') and trim( @newsrc) != '' ) or
          (replace(CONCAT(Telefono,'.',movil), '-','') like CONCAT('%' ,trim(@newsrc) ,'%') and trim( @newsrc) != '' )  or  
          (replace(CONCAT(Telefono,'.',movil), '-','') like CONCAT('%' ,right(trim(@newsrc), 6 ) ,'%') and trim( @newsrc) != '' ))
          group by CCTCONTA.siscod, CCTCONTA.ctacod limit 1),'')
          
                </expression>
		
            </field>
            <field id="cuentaSrc" noshow="true">
        
	    <expression><![CDATA[@fan1 := (SELECT group_concat( ctafan separator '<br>')  FROM CCTCUENT  where
                        (replace(ctatel, ' ','') like CONCAT('%' ,trim(@newsrc) ,'%') and trim( @newsrc) != '' )
                         and baja = 0 and length(@newsrc) > 3 )]]></expression>
          </field> 

            <field id="srcNom" local="true">
                <label>Nombre Origen</label>
                <if exp="true">
            	    <true>'InternoSrc empresaSrc cuentaSrc'</true>
            	    <false>''</false>
                </if>
            </field>

            <field id="dst" >
                <label>Destino</label>
<!--		<condicion operador="!=">998 and dst != 999</condicion> -->
            </field>
                                         
    	<field id="hasdetseg" noshow="true">
    	    <expression>case when dst = 998 then 'seguimiento_tel.xml' else '' end</expression>
    	</field>                           
     	<field id="hasdet" noshow="true">
    	    <expression>case when dst = 998 then 1 else '' end</expression>
    	</field>                           

    	<field id="seg" noshow="true">
    	
    	    <expression>case when dst = 998 then left(dstchannel, 15) end</expression>
    	    <detalle>channel</detalle>
    	</field>                           

    	<field id="horaCorte">
    	              
    	    <expression>case when dst = 998 then (select AST.calldate from ASTERIX_CDR AST where left(ASTERIX_CDR.dstchannel, 15) = left(AST.channel, 15) and 
    	    date(AST.calldate) = date(ASTERIX_CDR.calldate) and
    	    AST.calldate &gt;= ASTERIX_CDR.calldate order by calldate ASC
    	    limit 1 ) end</expression>
    	    <detalle>maxtime</detalle>
    	</field>                           
                                         

            <field id="InternoDst" noshow="true">
                <expression>@internodst := (case when length(dst) = 3 then (select CONCAT(Nombre, ' ', apellido) from HTXUSERS where HTXUSERS.interno = dst limit 1) end)</expression>
            </field>
            <field id="empresaDst" noshow="true">
                <expression>@empresadst :=  ifnull((SELECT CCTCUENT.ctafan  FROM CCTCONTA
          left join CCTCUENT on CCTCUENT.siscod = CCTCONTA.siscod and CCTCUENT.ctacod = CCTCONTA.ctacod
          WHERE   length(dst) != 3 and (
          (replace(CONCAT(Telefono,'.',movil), ' ','') like CONCAT('%' ,trim(dst) ,'%') and trim(dst) != '' )  or  
          (replace(CONCAT(Telefono,'.',movil), ' ','') like CONCAT('%' ,right(trim(dst), 6 ) ,'%') and trim(dst) != '' ) or
          (replace(CONCAT(Telefono,'.',movil), '-','') like CONCAT('%' ,trim(dst) ,'%') and trim( dst) != '' )  or  
          (replace(CONCAT(Telefono,'.',movil), '-','') like CONCAT('%' ,right(trim(dst), 6 ) ,'%') and trim(dst) != '' ))
          group by CCTCONTA.siscod, CCTCONTA.ctacod limit 1),'')
          
                </expression>
		
            </field>
            <field id="cuentaDst" noshow="true">
        
	    <expression><![CDATA[@fan1 := (SELECT group_concat( ctafan separator '<br>')  FROM CCTCUENT  where
                        (replace(ctatel, ' ','') like CONCAT('%' ,trim(dst) ,'%') and trim(dst) != '' )
                         and baja = 0 and length(dst) > 3 )]]></expression>
          </field> 

            <field id="DstNom" local="true">
                <label>Nombre Destino</label>
                <if exp="true">
            	    <true>'InternoDst empresaDst cuentaDst'</true>
            	    <false>''</false>
                </if>
            </field>

            <field id="disposition" _noshow="true">
        	<label>Estado</label>
            </field>

            
            <field id="duration" suma="true">
        	<expression>sec_to_time(duration)</expression>
                <label>Tiempo </label>
                <tipo>time</tipo>
            </field>
      
