          <field id="usuario" local="true" noshow="true">
            <valor eval="true">$_SESSION['usuario']</valor>
          </field> 

          <field id="interno" _local="true" noshow="true">
            <expression having="false">cast((select interno from HTXUSERS where '[__usuario__]' = login) as char)</expression>
            <label>Interno</label>
            <condicion operador="in">(src, dst)</condicion>
            <tipo>varchar</tipo>
          </field>

          <field id="src">
                <label colstyle="color:blue">Origen</label>
                
                  
                <!--
                <condicion operador="=">124 OR dst=124</condicion>
              
              <condicion operador="=">'[__interno__]' or `dst` = '[__interno__]'</condicion> 
-->
              
            </field>            
