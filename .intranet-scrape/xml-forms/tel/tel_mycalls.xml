            <title>Llamadas</title>
      
            <field id="uniqueid" oculto="true" >
          <label>id</label>
            </field>
            <field id="calldate" noshow="true" tipoOrden="DESC">
            </field>
            
            <field id="fecha">
          <expression>date(calldate)</expression>
                <label>Fecha</label>
                <tipo>date</tipo>
                <detalle>fecha</detalle>
                
            </field>
            <field id="hora" style="padding:0px 5px;">
          <expression>date_format( calldate, '%H:%i:%s' )</expression>
                <label>hora</label>
                <tipo>time</tipo>
            </field>
            
            <field id="tipo" noshow="true" local="true">
                <options>
                    <option valor="">Todos</option>
                    <option valor="entrantes">Entrantes</option>
                    <option valor="salientes">Salientes</option>
                </options>
            </field>
            
