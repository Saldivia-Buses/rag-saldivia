                   ifnull(@pers, '')  )) = '' then '<img src=\"../img/list-add.png\">' else  concat(@fan1, @fan2, @emp , @pers) end]]>
                </expression>         -->
                <paring destino="Telefono">dst</paring>

            </field>

            <field id="disposition" _noshow="true">
          <label>Estado</label>
            </field>

            
            <field id="duration" suma="true">
          <expression>sec_to_time(duration)</expression>
                <label>Tiempo </label>
                <tipo>time</tipo>
            </field>
      
