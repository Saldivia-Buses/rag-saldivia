							<condicion operador="!=">0</condicion>
						</campo>
						<campo id="salantCAB" local="true" noshow="true">
							<label>salant</label>
							<help></help>
						</campo>
						<campo id="newsaldoCAB" local="true" deshabilitado="true">
							<label>Saldo</label>
							<if exp="true" operador="=">
								<verdadero>salantCAB + movsal + 0</verdadero>
