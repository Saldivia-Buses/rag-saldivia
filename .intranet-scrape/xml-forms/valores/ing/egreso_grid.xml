<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="ing" inserta="false" modifica="false" borra="false" imprime="false" transaccional="true" showCantidad="false" tooltip="false" exportasuma="true" updateTotals="true" deleteRow="false">
    <title>Egreso de Valores</title>
    <obs></obs>
    <consulta>
        <table id="CAR_VALORES" label="Egreso de cheques">

            <movimientos cabecera="egreso_fichaing.xml">
                <relacion id="egreso_upd.xml"/>
                <relacion id="egreso_ins.xml"/>
            </movimientos>

            <filters>
				
                <field id="moneda_id" deshabilitado="false">
					<label>Moneda</label>
                    <operador>=</operador>
                </field>
                
            </filters>
            
            <field id="id_carvalor" deshabilitado="true" autoinc="true" >
                <label>Nro interno</label>
            </field>

           <field id="moneda_id" noshow="true">
				<label>Moneda</label>
                <helper type="combo" xml="monedas_qry.xml" dir="/ayudas" empty="true" />
            </field>
			
            <field id="nombre_banco" tabla="CAR_BANCOS" deshabilitado="true">
                <label>Banco</label>
            </field>

            <field id="nombre_plaza" tabla="CAR_PLAZAS" deshabilitado="true">
                <label>Plaza</label>
            </field>

            <field id="nro_valor" deshabilitado="true">
                <label>Nº</label>
            </field>

            <field id="fecha_valor" deshabilitado="true">
                <label>Fecha</label>
                <tipo>date</tipo>
            </field>

            <field id="acreditacion_valor" deshabilitado="true">
                <label>Acreditacion</label>
                <tipo>date</tipo>
            </field>

            <field id="cuenta_valor" deshabilitado="true">
                <label>Nº Cuenta</label>
                <help>Cuenta del cheque</help>
            </field>

            <field id="cuit_valor"  deshabilitado="true">
                <label>CUIT</label>
            </field>

            <field id="titular_valor" deshabilitado="true">
                <label>Titular</label>
            </field>

            <field id="importe_valor" deshabilitado="true">
                <label>importe</label>
                <tipo>numeric</tipo>
            </field>
            
			<!--
			<field id="referencia_movimiento" local="true" _noshow="true" editable="true">
				<valor>'EGRESO MANUAL DE CARTERA'</valor>
			</field>
			-->
			<field id="tipo_movimiento" local="true" noshow="true">
				<valor>1</valor>
			</field>

			<field id="egreso_valor" noshow="true">
				<condicion operador="=">'0000-00-00'</condicion>
			</field>
					
			<field id="imputar" local="true" refresh="true">
				<label>Imputar</label>
				<tipo>check</tipo>
			</field>
									
			<field id="total_imputado" local="true" suma="true" editable="true" deshabilitado="true">
			  <label>Total Imputado</label>
			  <if exp="imputar != ''">
				<true>importe_valor + 0</true>
				<false>0</false>
			  </if>
			  <tipo>numeric</tipo>
			</field>

        </table>

        <join>
            <table id="GEN_MONEDAS">
                <field id="id_moneda">
                    <condicion operador="=">CAR_VALORES.moneda_id</condicion>
                </field>
            </table>
        </join>

        <join>
            <table id="CAR_BANCOS">
                <field id="id_carbanco">
                    <condicion operador="=">CAR_VALORES.carbanco_id</condicion>
                </field>
            </table>
        </join>

        <join tipo="left">
            <table id="CAR_PLAZAS">
                <field id="id_carplaza">
                    <condicion operador="=">CAR_VALORES.carplaza_id</condicion>
                </field>
            </table>
        </join>

    </consulta>
</histrix>  
