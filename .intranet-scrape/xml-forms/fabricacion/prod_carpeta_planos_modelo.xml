<?xml version="1.0" encoding="utf-8" ?>
<histrix tipo="consulta">
	<title>CARROCERIAS</title>
	<obs></obs>
	<form >
		<table id="CARROCERIA" >
		    <title>Carrocerias</title>
			<field id="nrocar">
				<label>Código</label>
				<help>Código de Carrocería</help>
				<condicion operador="!=">0</condicion>
			</field>
			<field id="modcar">
				<label>Modelo</label>
				<help>Modelo de Carrocería</help>
			</field>
			<field id="descar">
				<label>Descripción</label>
				<help>Descripción</help>
			</field>
			<field id="desabv">
				<label>Abrev.</label>
				<help>Abreviatura</help>
			</field>
			<field id="vigente">
				<label>Vigente</label>
				<options>
					<option valor="0">No</option>
					<option valor="1">Si</option>
				</options>
			</field>

	 		<field id="carpeta_planos" local="true" linkint="prod_carpeta_planos_crud.xml" linkdir="fabricacion" linkdes="Carpeta Planos" linkWidth="90%">
        		<label modpos="nobr">PL STD</label>
             	<paring destino="nrocar_id">nrocar</paring>
          		<expression>select CONCAT(count(*), ' PL') FROM PRD_CARPETA_PLANOS where PRD_CARPETA_PLANOS.nrocar_id = nrocar</expression>
        	</field>

    			<order>
				<field id="modcar" tipoOrden="ASC"></field>
			</order>
        </table>
	</form>	   
</histrix> 