<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="abm-mini" subtipo="vertical"  path="fotos/homologaciones/">
  <title>HOMOLOGACION POR MODELO</title>
  <obs/>
  <consulta>
    <table id="HOMOLOGMOD">
      <title>Homologaciones por modelo</title>
      <field id="id_homologacion" _noshow="true" autoinc="true">

      </field>
      
      <field id="Descripcion">
        <label>Descripcion</label>
        <expresion>CONCAT(CARROCERIA.modcar,' ',MARCHASIS.mardes, ' ',MODCHASIS.moddes, ' ',HOMOLOGMOD.asientos + acompañante,' Asientos ',(CASE WHEN banbar = 1 THEN 'BB' ELSE ' ' END) ,'- Largo:', largo)</expresion>
      </field>
      
      <field id="nrocar">
        <label>Carroceria</label>
        <tabla_ex id="CARROCERIA">
          <field id="nrocar">
            <label>Codigo</label>
          </field>
          <field id="modcar">
            <label>Modelo</label>
          </field>          
        </tabla_ex>
      </field>
      <field id="modcod">
        <expresion having="false">HOMOLOGMOD.modcha</expresion>
      </field>
    
      <field id="marcod">
        <label modpos="nobr" >Marca</label>
        <help>Marca del Chasis</help>
      </field>
      <field id="modcha" >
        <label modpos="nobr" colstyle="display:none;">Modelo</label>
        <help>Modelo del Chasis</help>
      </field>    
      <field id="moddes" tabla="MODCHASIS" >
        <expresion>MODCHASIS.moddes</expresion>
        <label Formstyle="display:none;" modpos="nobr">ModeloChasis</label>
        <tipo>varchar</tipo>
      </field>
      <field id="asientos">
        <label modpos="nobr">Asientos</label>
        <label>Cantidad de Asientos</label>
      </field>
      <field id="cantasi">
        <expresion>asientos + acompañante</expresion>
        <detalle>cantasi</detalle>
      </field>
      <field id="tipserv" >
    	<detalle>tipserv</detalle>
      </field>
      
      
