<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="crud" class="consultaancha" path="fotos/articulos" _preloadData="false" paginar="25">
	<title>Carpeta Planos</title>
	<obs/>
	<form >
		<table id="PRD_CARPETA_PLANOS">
			<title>Carpeta Planos</title>
        <filters _auto="true">

			<field id="linea_id">
				<label modpos="nobr">Línea</label>
				<operador>=</operador>
				<valor>1</valor>
			</field>

			<field id="seccion_id">
				<label modpos="nobr">Sección</label>
				<operador>=</operador>
			</field>

        	<field id="stkarticulo_id">
          		<label modpos="nobr">Art.</label>
	   	 		<operador>=</operador>
	   	 	</field>

			<field id="nrocar_id">
				<label>Modelo</label>
				<operador>=</operador>
			</field>

			<field id="modelo_lcm_id">
				<label modpos="nobr">Modelo LCM</label>
				<operador>=</operador>
			</field>			

			<field id="homologacion_id">
				<label modpos="nobr">Homologación</label>
				<operador>=</operador>
			</field>

		</filters>
					
			<field id="id_carpetaplanos" esClave="true" noshow="true" />
			
            <field id="nrocar_id" noZero="true">
                <label>Modelo</label>
                <tabla_ex id="CARROCERIA" vacio="true">
                    <field id="nrocar">
                        <label>Codigo</label>
                    </field>
                    <field id="desabv">
                        <label>Abrev.</label>
                    </field>
                <field id="vigente">
                    <condicion operador="=">1</condicion>
                </field>
                <order>
                    <field id="desabv" />
                </order>
                </tabla_ex>                
            </field>

            <field id="modelo_lcm_id" noZero="true">
                <label>Modelo LCM</label>
	            <helper type="combo" xml="prod_modelo_lcm_qry.xml" empty="true">
	            	<field id="nrocar_id" oculto="true" />
	            	<field id="modelo_lcm_activo">
	            		<condicion operador="=">0</condicion>
	            	</field>
	            </helper>	
            </field>

            <field id="homologacion_id" noZero="true">
                <label>Homologación</label>
            	<helper type="combo" xml="combo_homologacion_modelo.xml" dir="/fabricacion" empty="true">
            		<field id="baja" noshow="true">
        				<condicion operador="=">0</condicion>
      				</field>
  				</helper>
            </field>

			<field id="usuario" noshow="true" deshabilitado="true" valauto="true">
            <label>Usuario</label>
            <valor eval="true">$_SESSION['usuario']</valor>
            </field>

		<field id="linea_id" colstyle="display:none;" deshabilitado="true">
			<label>Línea</label>
			<helper id="PROD_LINEAS" type="combo" empty="true">
                <field id="id_linea" />
                <field id="nombre_linea" />
                <field id="vigente_linea" oculto="true">
                	<condicion operador="=">1</condicion>
                </field>
		    </helper>
		    <valor>1</valor>
<!-- 			<actualiza>
				<field id="seccion_id" destino="linea_id" /> 
			</actualiza> -->
		</field>

		<field id="linea_id2" Formstyle="display:none;" colstyle="display:none;">
			<label modpos="nobr">Línea</label>
			<helper id="PROD_LINEAS" type="combo" empty="true">
                <field id="id_linea" />
                <field id="nombre_linea" />
                <field id="vigente_linea" oculto="true">
                	<condicion operador="=">1</condicion>
                </field>
		    </helper>
		    <expression>linea_id</expression>
		</field>

		<field id="seccion_id" colstyle="display:none;">
			<label>Sección</label>
			<helper id="MOMENTO" type="combo" empty="true">
                <field id="idMomento" />
                <field id="descripcion" />
                <field id="linea_id" oculto="true">
                	<condicion operador="=">1</condicion>
                </field>
		    </helper>
		</field>

		<field id="seccion_id2" Formstyle="display:none;">
			<label>Sección</label>
			<helper id="MOMENTO" type="combo" empty="true">
                <field id="idMomento" />
                <field id="descripcion" />
                <field id="linea_id" oculto="true">
                	<condicion operador="=">1</condicion>
                </field>
		    </helper>
		    <expression>PRD_CARPETA_PLANOS.seccion_id</expression>
		</field>

		<field id="tienehijos" noshow="true">
			<expression>@tienehijos := ifnull((select 1 from STKPIEZA where STKPIEZA.idPadre = STKINSUM.artcod limit 1), 0)</expression>
		</field>

		<field id="bom" noshow="true" local="true">
			<if exp="tienehijos">
			    <true>'articulos/stkpieza_qry.xml'</true>
			    <false>''</false>
			</if>
		</field>

		<field id="fecha" local="true" noshow="true">
			<label>Fecha</label>
			<valor>today</valor>
			<tipo>date</tipo>
			<detalle>fecha</detalle>
		</field>

		<field id="stkarticulo_id" _required="true">
			<label>Art.</label>
			<help>Código de Artículo</help>
			<ayuda_ex id="STKINSUM" xml="HLPstkinsum.xml" dir="/ayudas_local" >
				<field id="artcod">
					<label>Cod.</label>
				</field>
				<field id="artdes">
					<label>Insumo</label>
					<detalle>artdes</detalle>
				</field>
			</ayuda_ex>
			<size>12</size>
			<attribute id="linkint">bom</attribute>
           	<paring destino="idPadre">stkarticulo_id</paring>
           	<paring destino="fecha">fecha</paring>
           	<attribute id="linkdes">artdes</attribute>
           	<detalle>idPadre</detalle>		
		</field>

		<field id="artdes">
			<expression>artdes</expression>
			<label _modpos="nobr">Descripción</label>
			<size>100</size>
		</field>

		<field id="cantidad_pieza_unidad">
			<label>Cant.Unidad</label>
			<help>Cant x Unidad</help>
			<tipo>decimal</tipo>
		</field>

		<field id="estandar_plano">
			<label>Estándar</label>
			<options>
				<option valor="0">No</option>
				<option valor="1">Si</option>
			</options>
			<valor>1</valor>
		</field>

		<field id="posicionfab_alarma_id" noZero="true">
			<label>Inicio Fabri.</label>
			<helper xml="posicionesfab_qry.xml" type="combo" dir="/produccion" empty="true">
				<field id="linea_id" tabla="MOMENTO" oculto="true">
					<condicion operador="=">1</condicion>
				</field>
				<field id="pertenece_linea" oculto="true">
					<condicion operador="=">1</condicion>
				</field>	
			</helper>
		</field>

		<field id="posicionfab_entrega_id" noZero="true">
			<label>Momento Entrega</label>
			<helper xml="posicionesfab_qry.xml" type="combo" dir="/produccion" empty="true">
				<field id="linea_id" tabla="MOMENTO" oculto="true">
					<condicion operador="=">1</condicion>
				</field>
			</helper>
		</field>

		<field id="posicionfab_id" noZero="true">
			<label>Destino Estac.</label>
			<helper xml="posicionesfab_qry.xml" type="combo" dir="/produccion" empty="true">
				<field id="linea_id" tabla="MOMENTO" oculto="true">
					<condicion operador="=">1</condicion>
				</field>
			</helper>
<!--             <helper type="combo" id="POSICIONESFAB" empty="true">
                <field id="id_posicionfab" />
                <field id="nombre" />
                <order>
                    <field id="nombre" />
                </order>
            </helper>
 -->		</field>

      	<field id="herrinventario_id" tabla="STKINSUM" noZero="true" Formstyle="display:none;">
        	<label>Abast.</label>
        	<helper type="combo" xml="HLPherramientas_inv.xml" dir="/ayudas_local" empty="true"/>
      	</field>

		<field id="prdatributo_id" noZero="true" cellMaxLength="20">
			<label>Atributo</label>
        	<helper type="combo" xml="atributos_homologacion_qry.xml" dir="/producto" empty="true">
<!--                 <parameter source="homologacion_id" target="homologacion_id"/>-->
                    <!--<field id="homologacion_id" oculto="true" />-->
            </helper>
		</field>

		<field id="userid" cellMaxLength="20">
		    <label>Cargó</label>
		    <expression>concat(HTXUSERS.Nombre,' ', HTXUSERS.apellido,' ', stamp, ' En ', (
		    	case when nrocar_id != 0 then 'Modelo'
		    	     when modelo_lcm_id !=0 then 'Modelo/Chasis'
		    	     when homologacion_id !=0 then 'Homologacion' end))</expression>
		</field>

		<field id="fotopath" local="true" noshow="true">
			<if exp="true">
				<true>'stkarticulo_id/'</true>
				<false>''</false>
			</if>
			<tipo>varchar</tipo>
		</field>
 
 		<field id="foto" path="fotopath" open="true" print="false" _download="true" Formstyle="display:none;">
          		<expression>select ARTICULO_FOTO.foto from ARTICULO_FOTO where ARTICULO_FOTO.idArticulo = STKINSUM.artcod and ARTICULO_FOTO.foto != '' order by revision desc limit 1</expression> 
				<label>Imagen</label>
                <tipo >file</tipo>
                <size>20</size>
		</field>

</table>
	<join tipo="left">
		<table id="STKINSUM">
			<field id="artcod">
				<condicion operador="=">PRD_CARPETA_PLANOS.stkarticulo_id</condicion>
			</field>
			<field id="siscod">
				<condicion operador="=">'01'</condicion>
			</field>
		</table>
	</join> 

		<join tipo="left">
		    <table id="HTXUSERS">
			<field id="login">
			    <condicion operador="=">usuario</condicion>
			</field>
		    </table>
		</join>

	</form>
</histrix>
