<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="consulta"  >
	<title>CERTIFICADOS FABRICACION</title>
	<obs></obs>
	<form >
		<table id="CERTFABRICACION" >
		    <title>Carrocerias</title>
			<filters>
			    <field id="fechaCert">
				    <label>Desde</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-1 month')) , 1, date("Y") ))</valor>
				    <operador>&gt;=</operador>
			    </field>
			    <field id="fechaCert">
                    <label>Hasta</label>
				    <valor>today</valor>
				    <operador>&lt;=</operador>
			    </field>
		    </filters> 



			<field id="fechaCert" noshow="true">
				<label>Fecha</label>
			</field>

			<field id="modcar" tabla="CARROCERIA">
				<label modpos="nobr" deshabilitado="true">Carrocería</label>
				<tipo>varchar</tipo>
			</field>			

			<field id="marcod" tabla="CHASIS" deshabilitado="true" _noshow="true" requiered="true">
				<expression>CHASIS.marcod</expression>
				<label modpos="nobr" >Chasis</label>
				<help/>
				<tabla_ex id="MARCHASIS">
					<field id="marcod">
					</field>
					<field id="mardes">
					</field>

					<field id="siscod" oculto="true">
						<condicion operador="=">03</condicion>
					</field>
				</tabla_ex>
				<tipo>integer</tipo>
			</field>	

			<field deshabilitado="true" id="moddes" tabla="MODCHASIS" required="true">
				<expression>MODCHASIS.moddes</expression>				
				<label modpos="nobr" >Mod</label>
				<help/>
				<tipo>varchar</tipo>
			</field>	
		<field id="id_homologacion" tabla="HOMOLOGMOD" noshow="true">
      	</field>

		<field id="lcm" linkdir="/fabricacion/">
			<attribute id="linkint">hasLCM</attribute>
			<label modpos="nobr" style="width:auto;">L.C.M. Nro</label>
			<help>Número de Licencia de Configuración de Modelo</help>
			<paring destino="lcm" >lcm</paring>
			<condicion operador="!=">0</condicion>
		</field>
					
		<field id="hasLCM" noshow="true">
        	    <expression>select (case when count(*) >= 1 then 'imp_lcm.xml'  else '' end) from LCMFOTOS where LCMFOTOS.lcm = HOMOLOGMOD.lcm</expression>
		</field>

		  <field id="cant" suma="true" tipoOrden="DESC">
				<expression>COUNT(*)</expression>
				<label style="text-align:center;">Cantidad de usos</label>
		  </field>

			<group>
				<field id="lcm" tabla="CERTFABRICACION"/>
			</group>
   			<order>
				<field id="cant"/>
			</order>
		</table>
		<join tipo="left">
               <table id="PEDCOTIZ">
				<field id="nrocha">
					       <condicion operador="=">CERTFABRICACION.nrofab</condicion>
					</field>
				</table> 		
		</join>
		<join tipo="left">
			<table id="CHASIS">
				<field id="nrocha">
					<condicion operador="=">CERTFABRICACION.nrofab</condicion>
				</field>
			</table> 
		</join>		
		<join tipo="left">
			<table id="HOMOLOGMOD">
				<field id="id_homologacion">
					<condicion operador="=">PEDCOTIZ.homologacion_id</condicion>
				</field>
			</table> 					
		</join>			
		<join tipo="left">
               <table id="CARROCERIA">
					<field id="nrocar">
					       <condicion operador="=">HOMOLOGMOD.nrocar</condicion>
					</field>
				</table> 		
		</join>		
		<join tipo="left">
			<table id="MARCHASIS">
				<field id="marcod">
					<condicion operador="=">HOMOLOGMOD.marcod</condicion>
				</field>
			</table> 
		</join>		
		<join tipo="left">
			<table id="MODCHASIS">
				<field id="modcha">
					<condicion operador="=">HOMOLOGMOD.modcha</condicion>
				</field>
				<field id="marcod">
					<condicion operador="=">HOMOLOGMOD.marcod</condicion>
				</field>
			</table> 
		</join>

	</form>	   
</histrix> 
