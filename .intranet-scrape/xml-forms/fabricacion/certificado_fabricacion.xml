					<tipo>varchar</tipo>
				</field>
				<field id="yearModelo" >
		                     <label size="12" posx="160" posy="0" PDFsize="11" PDFnoborder="true">AÑO:</label>
					 <expression>DATE_FORMAT(fechaCert, '%Y')</expression>
				</field> 					    

				<field id="tipserv" tabla="HOMOLOGMOD">
					<label size="70" posx="18" posy="+2" PDFsize="11" PDFnoborder="true" >CARROCERÍA PARA SERVICIO *: </label>
					
					<help>Tipo de Servicio</help>
					<tabla_ex id="TIPOSERVICIO">
							<field id="tipserv">
							</field>
							<field id="servdes">
							</field>					
					</tabla_ex>
				</field>					
				<field id="asientos" tabla="HOMOLOGMOD">
					<expression>concat('Conductor + ',
					(case when CARROCERIA.doble_piso = 1 then (CONCAT(asientos, '+', asientos_plantabaja)) else (asientos) end),
					' pasajeros',
					(case when acompañante = 1 then ' + acompañante' else '' end),
					(case when auxiliar = 1 then ' + auxiliar' else '' end))</expression>
					<label size="88" posx="18" posy="+2" PDFsize="11" PDFnoborder="true" >CANTIDAD DE ASIENTOS PARA PASAJEROS: </label>
				</field>					  
					  
				<field id="tara" tabla="HOMOLOGMOD">
					<expression>concat(HOMOLOGMOD.tara, ' Kgs')</expression>
					
					<label size="70" posx="18" posy="+2" PDFsize="11" PDFnoborder="true" >PESO DEL VEHÍCULO VACIO:</label>
				</field>
				<field id="bruto" tabla="HOMOLOGMOD">
					<expression>concat(HOMOLOGMOD.bruto, ' Kgs')</expression>
					
					<label size="150" posx="18" posy="+2" PDFsize="10" PDFnoborder="true" >PESO DEL VEHÍCULO EN FUNCION DEL CÁLCULO DE DISTRIBUCION DE CARGAS:</label>
				</field>					  


