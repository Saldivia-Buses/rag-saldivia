				<field id="ident" local="true">
					<label size="67" posx="65" posy="+10" PDFsize="12" >IDENTIFICACION DE VEHICULO</label>
				</field>					  


                <field id="mardes">
					<label size="40" posx="18" posy="+5" PDFsize="12" PDFnoborder="true">CHASIS MARCA:</label>
				<expression>CHASIS.marcod</expression>
				<label modpos="nobr" Formstyle="display:none;">Ch.</label>
				<help/>
				<tabla_ex id="MARCHASIS">
					<field id="marcod">
					</field>
					<field id="mardes">
					</field>

					<field id="siscod" oculto="true">
						<condicion operador="=">03</condicion>
					</field>
				</tabla_ex>
				<tipo>integer</tipo>					
				</field>
				<field id="chasis" tabla="CHASIS">
					<label size="10" posx="120" posy="0" PDFsize="12" PDFnoborder="true">Nº:</label>
				</field>					  
				<field id="nombre" tabla="MARCAMOTOR">
					<label size="40" posx="18" posy="+2" PDFsize="11" PDFnoborder="true" >MOTOR MARCA:</label>
				</field>
				<field id="nromotor" tabla="CHASIS">
