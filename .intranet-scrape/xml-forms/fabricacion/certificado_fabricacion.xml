				</field>

                <field id="moddes">
					<label size="40" posx="18" posy="+2" PDFsize="11" PDFnoborder="true">CHASIS MODELO:</label>
					<expression>MODCHASIS.moddes</expression>
				</field>

				<field id="marcha" local="true">
					<label size="70" posx="18" posy="+10" PDFsize="11" PDFnoborder="true" >CARROCERÍA MARCA: </label>
