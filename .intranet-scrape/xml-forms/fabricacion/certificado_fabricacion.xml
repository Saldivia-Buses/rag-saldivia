                  </table>
					<join tipo="left">
						<table id="PEDCOTIZ">
							<field id="nrocha">
								<condicion operador="=">CERTFABRICACION.nrofab</condicion>
							</field>
						</table>
					</join>				   
					<join tipo="left">
						<table id="CCTCUENT">
							<field id="ctacod">
								<condicion operador="=">PEDCOTIZ.ctacod</condicion>
							</field>
							<field id="siscod">
								<condicion operador="=">'02'</condicion>
							</field>
						</table>
					</join>				   
				   
			       	<join tipo="left">
						<table id="CHASIS">
							<field id="nrocha">
								<condicion operador="=">CERTFABRICACION.nrofab</condicion>
							</field>
						</table>
					</join>
		
				<join tipo="left">
					<table id="MODCHASIS">
						<field id="modcha">
							<condicion operador="=">CHASIS.modcod</condicion>
						</field>
						<field id="marcod">
							<condicion operador="=">CHASIS.marcod</condicion>
						</field>
					</table>
				</join>
					<join tipo="left">
						<table id="HOMOLOGMOD">
						    	<field id="id_homologacion">
							    <condicion operador="=">PEDCOTIZ.homologacion_id</condicion>
					        	</field>
							
						</table>
					</join>						   
    <join tipo="left">
       <table id="CARROCERIA">
          <field id="nrocar">
                 <condicion operador="=">HOMOLOGMOD.nrocar</condicion>
          </field>
        </table>
    </join>

					<join tipo="left">
						<table id="MARCAMOTOR">
							<field id="idMarca">
								<condicion operador="=">CHASIS.idMarcaMotor</condicion>
							</field>
						</table>
					</join>				   
				</form>
