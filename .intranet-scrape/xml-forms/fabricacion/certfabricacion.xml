<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="crud" paginar="100" path="/fotos/coches/" borra="false" preloadData="false">
    <title>CERTIFICADOS FABRICACION</title>
    <obs></obs>
    <form>
        <table id="CERTFABRICACION">

            <filters>
                <field id="nrofab">
                    <label>Nro Fab</label>
                    <operador>=</operador>
                </field>
            <field id="plano" >
                <label>Plano Nro</label>
                <help>Plano</help>
                <tipo>varchar</tipo>
                    <operador>like</operador>
            </field>
            </filters>
