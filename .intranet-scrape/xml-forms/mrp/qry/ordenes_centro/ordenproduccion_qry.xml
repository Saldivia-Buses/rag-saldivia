<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" inserta="no" >
    <title>ORDENES DE PRODUCCION</title>
    <obs></obs>
    <form  _detalle="mrp_ordendetalle_impresion.xml"  inline="true">
	        
	<table id="MRP_ORDEN_PRODUCCION" label="Consulta de Ordenes de Producción">

            <field id="fecha_orden">
                <label>Fecha</label>
                <help>Fecha de Orden de Fabricación</help>
            </field>

            <field id="id_mrporden">
                <!--
            	<helper xml="ordenproduccion_imp.xml" dir="/mrp/qry/" type="link" modal="true">
            	    <parameter source="id_mrporden"  target="id_mrporden" />
            	</helper>
            -->
                <label>Nro</label>
                <help>Numero de Orden de Fabricación</help>
                <detalle>mrporden_id</detalle>
            </field>


            <field id="mrpestado_id" noshow="true" />

            <field id="producto" noshow="true">
        		<label>Producto</label>
        		<expresion>CONCAT(stkarticulo_id, ' - ',nombre_articulo )</expresion>
            </field>                 

	    <field id="centro_productivo_id" noshow="true"/>

            <field id="mrpestado_id" >
                <label>Estado </label>
                <help>Estado Actual</help>
                <options>
                        <option valor="0">Pendiente</option>
                        <option valor="1">Cumplida</option>
                        <option valor="2">Anulada</option>
                        <option valor="3">Con Perdidas</option>
                        <option valor="4">Sin Perdidas</option>
                </options>
                <valor>0</valor>
            </field>

            <field id="detalle">
                <helper xml="mrp_ordendetalle_impresion.xml" dir="/mrp/qry/ordenes_centro/" type="link" icon="ui-icon-zoomin" text="false" width="80%">
                    <parameter source="id_mrporden" target="mrporden_id" />
                </helper>
                <expresion>'detalle'</expresion>
            </field>

            <field id="cerrar">
                <helper xml="mrp_cerrarorden_ficha.xml" dir="/mrp/ing/orden_centro_prod" type="link" width="60%">
                    <parameter source="id_mrporden" target="id_mrporden" />
                    <parameter source="centro_productivo_id" target="centro_productivo_id" />
                </helper>
                <expresion>case when mrpestado_id = 0 then 'Cerrar' end</expresion>
            </field>


            <group>
                <field id="id_mrporden"></field>
            </group>
            
            <order>
                <field id="fecha_orden"></field>
            </order>

        </table>

        <join tipo="left">
    	    <table id="MRP_ORDEN_DETALLE">
                <field id="mrporden_id">
            	    <condicion operador="=">MRP_ORDEN_PRODUCCION.id_mrporden</condicion>
                </field>
    	    </table>
        </join>
        
        <join tipo="inner">
    	    <table id="STK_ARTICULOS">
    		<field id="id_stkarticulo">
    		    <condicion  operador="=">MRP_ORDEN_DETALLE.stkarticulo_id</condicion>
    		</field>
    	    </table>
        </join>
        
    </form>
</histrix>
