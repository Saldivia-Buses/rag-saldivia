                    <expresion>sum((select sum(MDR.cantidad) from MRP_DETALLE_REGISTRO MDR where MDR.mrpordendetalle_id = id_mrpordendetalle and mrpconcepto_id = 1 and MRP_DETALLE_REGISTRO.fecha_ingreso = MDR.fecha_ingreso and mrpseccion_id = 2))</expresion>
