<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="fichaing" limit="1" inserta="false" modifica="false" borra="false" procesa="false" imprime="true" export="true" PDForientation="L">
    <title>ORDENES DE PRODUCCION</title>
    <obs></obs>
    <form>
        <table id="MRP_ORDEN_PRODUCCION" label="Consulta de Ordenes de Producción">

            <field id="fecha_desde_ingreso" local="true" PDFnoborder="true">
                <label posX="5" posY="+2">DESDE:</label>
                <tipo>date</tipo>
                <valor eval="true">date('01/m/Y')</valor>
                <actualiza>
                    <field id="detalle" destino="fecha_desde_ingreso" />
                </actualiza>
            </field>

            <field id="fecha_hasta_ingreso" local="true" PDFnoborder="true">
                <label posX="75" posY="0" modpos="nobr">HASTA:</label>
                <tipo>date</tipo>
                <valor>today</valor>
                <actualiza>
                    <field id="detalle" destino="fecha_hasta_ingreso" />
                </actualiza>
            </field>

            <field id="stkrubro_id" local="true" PDFnoborder="true">
                <label posX="145" posY="0" modpos="nobr">RUBRO:</label>
                <helper type="combo" xml="stkrubro_qry.xml" dir="/ayudas" empty="true" />
                <actualiza>
                    <field id="detalle" destino="rubro" />
                </actualiza>
            </field>

            <field id="detalle" local="true" colspan="8">
                <label posX="5" posY="+3" />
                <helper type="object" xml="ordenproduccion_agrupada_mensual.xml" />
            </field>

            <field id="separador" local="true" deshabilitado="true" colspan="8" style="height:2px;" print="false" export="false" />

            <field id="total_roturas_horno" local="true" noshow="true" print="false" export="false">
                <label>Total Roturas Horno</label>
                <tipo>numeric</tipo>
            </field>

            <field id="total_horno" local="true" noshow="true" print="false" export="false">
                <label>Total Horno</label>
                <tipo>numeric</tipo>
                <jseval fielddestino="porcentaje_total_horno">(((total_roturas_horno / total_horno) * 100).toFixed(2) + ' %')</jseval>
            </field>

            <field id="total_roturas_laminado" local="true" noshow="true" print="false" export="false">
                <label>Total Roturas Laminado</label>
                <tipo>numeric</tipo>
            </field>

            <field id="total_laminado" local="true" noshow="true" print="false" export="false">
                <label>Total Laminado</label>
                <tipo>numeric</tipo>
                <jseval fielddestino="porcentaje_total_laminado">(((total_roturas_laminado / total_laminado) * 100).toFixed(2) + ' %')</jseval>
            </field>

            <field id="total_roturas_autoclave" local="true" noshow="true" print="false" export="false">
                <label>Total Roturas Autoclave</label>
                <tipo>numeric</tipo>
            </field>

            <field id="total_autoclave" local="true" noshow="true" print="false" export="false">
                <label>Total Autoclave</label>
                <tipo>numeric</tipo>
                <jseval fielddestino="porcentaje_total_autoclave">(((total_roturas_autoclave / total_autoclave) * 100).toFixed(2) + ' %')</jseval>
            </field>

            <field id="separador2" local="true" deshabilitado="true" style="font-weight: bold; font-size:13px;" print="false" export="false">
                <label>.</label>
            </field>

            <field id="porcentaje_total_horno" local="true" deshabilitado="true" style="font-weight: bold; font-size:13px;" PDFnoborder="true" pdfnolabel="true" PDFbold="true" PDFbackgroundColor="#E6FFD6" PDFcolor="#000">
                <label posX="139" posY="+1" size="15" modpos="nobr">HORNO:</label>
                <tipo>varchar</tipo>
            </field>

            <field id="porcentaje_total_laminado" local="true" deshabilitado="true" style="font-weight: bold; font-size:13px;" PDFnoborder="true" pdfnolabel="true" PDFbold="true" PDFbackgroundColor="#E6FFD6" PDFcolor="#000">
                <label posX="202" posY="0" size="15" modpos="nobr">LAMINADO:</label>
                <tipo>varchar</tipo>
            </field>

            <field id="porcentaje_total_autoclave" local="true" deshabilitado="true" style="font-weight: bold; font-size:13px;" PDFnoborder="true" pdfnolabel="true" PDFbold="true" PDFbackgroundColor="#E6FFD6" PDFcolor="#000">
                <label posX="235" posY="0" size="15" modpos="nobr">AUTOCLAVE:</label>
                <tipo>varchar</tipo>
            </field>

        </table>
    </form>
</histrix>
