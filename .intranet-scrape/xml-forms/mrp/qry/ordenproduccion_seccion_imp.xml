<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="ficha" sololectura="true" autoprint="true" preFetch="true" >
    <title>ORDEN DE PRODUCCION</title>
    <obs></obs>
    <form>        
        <table id="MRP_ORDEN_PRODUCCION" label="ORDEN DE PRODUCCION">                     

           <field id="id_mrporden" deshabilitado="true" PDFnoborder="true" noshow="true" print="false">
            </field>
            <field id="mrporden_relacionada_id" noshow="true" print="false">
            </field>
 
            <field id="mrpestado_id" PDFnoborder="true">
                <label posx="5" posy="+2" size="20" PDFsize="10">Estado:</label>
                <options>
                    <option valor="0">En Proceso</option>
                    <option valor="1">Cumplida</option>
                    <option valor="2">Anulada</option>
                </options>
            </field>
            <field id="fecha_orden" deshabilitado="true" PDFnoborder="true">
                <label posx="110" posy="0" size="20" PDFsize="10">Fecha:</label>
            </field>

            <field id="nombre_ordenconcepto" tabla="MRP_ORDEN_CONCEPTO">
                <setvar>titulo_div</setvar>
                <label posx="5" posy="+2" size="20">Concepto</label>
            </field>


            <field id="numero_orden" deshabilitado="true" PDFnoborder="true">
                <label posx="110" posy="0" size="30" PDFsize="10">Orden Nro:</label>
            </field>


            <field id="relacionada" deshabilitado="true" PDFnoborder="true">
                <label posx="110" posy="+2" size="30" PDFsize="10">Orden Original:</label>
                <expression>select NP.numero_orden from MRP_ORDEN_PRODUCCION NP where NP.id_mrporden = MRP_ORDEN_PRODUCCION.mrporden_relacionada_id limit 1</expression>
            </field>


            <!--
            <field id="rhpersonal_id" PDFnoborder="true">
                <helper type="combo" xml="rhpersonal_qry.xml" dir="/ayudas" empty="true" />
                <label posx="5" posy="+2" size="20" PDFsize="10">Empleado:</label>  
            </field>
          -->

            <field id="movimientos" local="true" obj="mrp_ordendetalle_seccion_impresion.xml" pdfwidth="200">
                <label colspan="4" posx="5" posy="+3" PDFsize="10"></label>
                <paring destino="mrporden_id">id_mrporden</paring>
            </field>

            <field id="muestra_obs" print="false" noshow="true">
                <expression>case when orden_comentarios = '' or orden_comentarios IS NULL then 'false' else 'true' end</expression>
            </field>

            <field id="orden_comentarios" deshabilitado="true" pdfancho="170" PDFnoborder="true">
                <label colspan="4" posx="5" posy="+3">Comentarios</label>
                <tipo>varchar</tipo>
                <attribute id="print">muestra_obs</attribute>
            </field>

            <field id="secciones" local="true"  pdfwidth="200">
                <helper xml="ordendetalle_agrupada_det_imp.xml" type="object">
                    <parameter source="id_mrporden" target="mrporden_id" />
                </helper>
                <label colspan="4" posx="5" posy="+3" PDFsize="8"></label>

            </field>            
<!--
            <field id="firma_empleado" local="true" PDFnoborder="true">
            	<label PDFsize="10" size="20" posx="5" posy="+15">Empleado:</label>
            	<valor>.........................................................</valor>
            </field>

            <field id="firma_encargado" local="true" PDFnoborder="true">
            	<label PDFsize="10" size="30" posx="105" posy="0">Enc. Produccion:</label>
                <valor>.........................................................</valor>
            </field>
-->
            <!--                        
    	    <field id="titcontrol" local="true" PDFbold="true" PDFnoborder="true" PDFnolabel="true">
    		    <label PDFsize="12" posx="75" posy="+5" />
                <valor>CONTROL DE CALIDAD</valor>
    	    </field>
                            
            <field id="control_calidad" local="true" obj="mrp_ordendetalle_art_impresion.xml" pdfwidth="200">
                <label colspan="4" posx="5" posy="+3" PDFsize="8" PDFlineas="false"></label>
                <paring destino="mrporden_id">id_mrporden</paring>
            </field>
            
            <field id="indice" PDFnoborder="true">
            	<label posx="5" posy="+2" size="30" PDFsize="10">Indice de Calidad</label>
            	<expression>select sum(peso_control) * (case when mrpestado_id = 1 then 0 else 1 end) from MRP_ORDEN_DETALLE
                    left join MRP_CONTROL_DETALLE on MRP_CONTROL_DETALLE.mrpordendetalle_id = MRP_ORDEN_DETALLE.id_mrpordendetalle
                    left join MRP_CONTROLES on MRP_CONTROLES.id_mrpcontrol = MRP_CONTROL_DETALLE.mrpcontrol_id 
                    where   MRP_ORDEN_DETALLE.mrporden_id = MRP_ORDEN_PRODUCCION.id_mrporden 
                </expression>
            </field>      
            -->
<!--
    	    <field id="trazabilidad" local="true" PDFbold="true" PDFnoborder="true" PDFnolabel="true">
    		  <label PDFsize="12" posx="80" posy="+5" />
              <valor>TRAZABILIDAD</valor>
    	    </field>
                
            <field id="trzobj" local="true" obj="mrp_ordendetalle_trz_impresion.xml" pdfwidth="200">
                <label colspan="4" posx="5" posy="+3" PDFsize="8"></label>
                <paring destino="mrporden_id">id_mrporden</paring>
            </field>
-->


        </table>
        <join tipo="left">
            <table id="MRP_ORDEN_CONCEPTO">
                <field id="id_mrporden_concepto">
                    <condicion operador="=">mrporden_concepto_id</condicion>
                </field>
            </table>
        </join>        

    </form>
</histrix>