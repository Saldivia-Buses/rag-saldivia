<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="abm-mini" PDForientacion="L" subtipo="vertical">
    <title>Forecast Articulos</title>
    <obs></obs>
    <form >
        <table id="MRP_FORECAST" label="Forecast">
                <field id="stkarticulo_id" esClave="true">
                    <label>Código</label>
                    <help>Codigo de Articulo</help>
                    <helper type="external" xml="stkarticulo_qry.xml" dir="/ayudas">
                        <field id="nombre_articulo">
	                    <detalle>nombre_articulo</detalle>
    	                </field>
        	        <field id="produccion_diaria">
            	            <detalle>minimo_ordendetalle</detalle>
            	        </field>
            	    </helper>
                </field>

                <field id="nombre" deshabilitado="true">
                    <expresion>nombre_articulo</expresion>
                    <label modpos="nobr">Articulo</label>
                    <help>Codigo de Articulo</help>
                    <helper type="link" xml="mrp_forecast_ins.xml" >
                        <parameter source="stkarticulo_id" target="stkarticulo_id" />
                        <parameter source="year_forecast"  target="year_forecast" />
                        <parameter source="tipo_forecast"  target="tipo_forecast" />
                    </helper>                                        
                </field>

                <field id="mes_forecast" colstyle="display:none;">
                    <label>Mes</label>
                <options>
                    <option valor="1">Enero</option>
                    <option valor="2">Febrero</option>
                    <option valor="3">Marzo</option>
                    <option valor="4">Abril</option>                                        
                    <option valor="5">Mayo</option>
                    <option valor="6">Junio</option>
                    <option valor="7">Julio</option>
                    <option valor="8">Agosto</option>                                        
                    <option valor="9">Septiembre</option>
                    <option valor="10">Octubre</option>
                    <option valor="11">Noviembre</option>
                    <option valor="12">Diciembre</option>                                    
                </options>                            
            </field>
            <field id="cantidad_forecast" >
                <label modpos="nobr">Cantidad</label>
            </field>

                <field id="year_forecast" required="true" _noshow="true" valauto="true" colstyle="display:none;">
                    <label>año</label>     
                </field>

                <field id="tipo_forecast" _noshow="true" colstyle="display:none;">
                    <label>Tipo</label>     
                    <options>
                        <option valor="1">Venta</option>
                        <option valor="2">Producción</option>
                        <option valor="3">Compras</option>

                    </options>
                </field>
            <group>
                <field id="stkarticulo_id"></field>
            </group>
        </table>
        <join tipo="left">
            <table id="STK_ARTICULOS">
                <field id="id_stkarticulo">
                    <condicion operador="=">stkarticulo_id</condicion>
                </field>
            </table>
        </join>
    </form>
</histrix>