            <field id="premio" suma="true">
                <label >Premio</label>
                <expresion><![CDATA[round((case 
            				  when @producido_total < minimo_ordendetalle then -0.5 * ( 1 +  @excedente )
                                           when @producido_total <= objetivo_ordendetalle then 0
                                           else round( 0.5 * ( 1 + @excedente ) , 3) end) ,3)]]></expresion>
                <tipo>decimal</tipo>
            </field>
       -->
        </table>
        <join tipo="left">
    	    <table id="MRP_ORDEN_DETALLE">
    	      <field id="mrporden_id">
    	      <condicion operador="=">MRP_ORDEN_PRODUCCION.id_mrporden</condicion>
    	      </field>
    	    </table>
        </join>
    </form>
</histrix>
