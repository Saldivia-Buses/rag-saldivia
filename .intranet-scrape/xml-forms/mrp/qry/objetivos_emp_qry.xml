            <field id="cant">
        	<label>Ordenes</label>
        	<expresion>@dias := round((select count(*) FROM MRP_ORDEN_PRODUCCION as MRP where MRP.rhpersonal_id = MRP_ORDEN_PRODUCCION.rhpersonal_id and MRP.mrpestado_id = 1 ) ,0  )</expresion>
            </field>
   -->
   
