<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="chart" limit="10" preloadData="true">
    <title>Roturas por Producto</title>
    <obs></obs>
    <form>
	        
	<table id="MRP_DETALLE_REGISTRO" label="Roturas por Producto">
            
            <grafico id="Producto">
                       <ancho>400</ancho>
                       <tipo>C</tipo>
                       <etiquetas>cod_producto</etiquetas>
                       <serie>roturas</serie> 
                       <title>Roturas por Producto</title>
                       <subtitulo>TOP 10</subtitulo>
            </grafico>

            <filters>
                <field id="fecha_ingreso">
                    <label>Desde Fecha</label>
                    <help>Fecha de Orden de Carga</help>
                    <operador>&gt;=</operador>
		           
                </field>

                <field id="fecha_ingreso">
                    <label modpos="nobr">Hasta Fecha</label>
                    <help>Fecha de Orden de Carga</help>
                    <operador>&lt;=</operador>
		              <valor>today</valor>
                </field>
            </filters>

            <field id="mrpconcepto_id" noshow="true">
                <condicion operador="!=">1</condicion>
            </field>

            <field id="fecha_ingreso" tabla="MRP_DETALLE_REGISTRO" noshow="true" />

            <field id="id">
                <label>Codigo</label>
                <expresion having="false">concat(left(id_stkarticulo, 1),'/', substr(id_stkarticulo, 2,4),'-' , substr(id_stkarticulo, 6,4) )</expresion>
            </field>                 

            <field id="cod_producto">
                <label>Codigo</label>
                <expresion having="false">concat(left(id_stkarticulo, 1),'/', substr(id_stkarticulo, 2,4),'-' , substr(id_stkarticulo, 6,4),' ',nombre_articulo)</expresion>
            </field>

    	    <field id="producto" export="false">
        		<label>Producto</label>
        		<expresion>nombre_articulo</expresion>
    	    </field>

            <field id="roturas"  suma="true">
                <label>Rot/Rech</label>
                <expression having="false">sum(MRP_DETALLE_REGISTRO.cantidad)</expression>
                <tipo>integer</tipo>
            </field>

			<group>
                <field id="id" />
			</group>
            <order>
                <field id="roturas" orderType="DESC" />
                <field id="ubicacion"  />
            </order>
        </table>


        <join tipo="left">
            <table id="MRP_ORDEN_DETALLE">
                <field id="id_mrpordendetalle">
                    <condicion operador="=">mrpordendetalle_id</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="MRP_ORDEN_PRODUCCION">
                <field id="id_mrporden">
                    <condicion operador="=">mrporden_id</condicion>
                </field>
            </table>
        </join>        
        <join tipo="left">
            <table id="REG_CUENTA">
                <field id="id_regcuenta">
                    <condicion operador="=">regcuenta_id</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="MRP_PRODUCT_PATH">
                <field id="id_productpath">
                    <condicion operador="=">MRP_DETALLE_REGISTRO.productpath_id</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="MRP_SECCION">
                <field id="id_mrpseccion">
                    <condicion operador="=">MRP_PRODUCT_PATH.mrpseccion_id</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="MRP_CONCEPTOS">
                <field id="id_mrpconcepto">
                    <condicion operador="=">mrpconcepto_id</condicion>
                </field>
            </table>
        </join>
        <join tipo="inner">
    	    <table id="STK_ARTICULOS">
        		<field id="id_stkarticulo">
        		    <condicion  operador="=">MRP_ORDEN_DETALLE.stkarticulo_id</condicion>
        		</field>
    	    </table>
        </join>
    </form>
</histrix>
