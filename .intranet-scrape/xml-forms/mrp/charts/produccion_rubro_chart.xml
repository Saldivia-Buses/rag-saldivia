<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="chart">
    <title>Consulta de Producción</title>
    <obs/>
    <form>
        <table id="STK_ARTICULOS" label="Consulta de Producción">
            <grafico id="xrubro">
                <ancho>400</ancho>
                <tipo>P</tipo>
                <etiquetas>nombre_rubro</etiquetas>
                <datos>cantidad</datos>
                <title>Producción por rubro</title>
            </grafico>
            <filters>
                <field id="fecha_movimiento">
                    <label>Desde</label>
                    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date(&quot;m&quot; ) , 1, date(&quot;Y&quot;)  ))</valor>
                    <operador>&gt;=</operador>
                </field>
                <field id="fecha_movimiento">
                    <label>Hasta</label>
                    <valor>today</valor>
                    <operador>&lt;=</operador>
                </field>
            </filters>
            <field id="nombre_rubro" tabla="STK_RUBROS">
                <label>Articulo</label>
                <detalle>nombre_articulo</detalle>
            </field>
            <field id="fecha_movimiento" noshow="true" tabla="STK_MOVIMIENTOS">
                <label>año</label>
                <tipo>date</tipo>
            </field>
            <field id="cantidad">
                <label>Cantidad</label>
                <expresion>round(sum(STK_MOVIMIENTOS.cantidad ),0)</expresion>
                <tipo>numeric</tipo>
            </field>
            <field id="stkrubro_id" tabla="STK_ARTICULOS"/>
            <group>
                <field id="stkrubro_id"/>
            </group>
            <order>
                <field id="total"/>
            </order>
        </table>
        <join tipo="left">
            <table id="STK_RUBROS">
                <field id="id_stkrubro">
                    <condicion operador="=">STK_ARTICULOS.stkrubro_id</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="STK_MOVIMIENTOS">
                <field id="stkarticulo_id">
                    <condicion operador="=">id_stkarticulo</condicion>
                </field>
            </table>
        </join>
        <join>
            <table id="STK_CONCEPTOS">
                <field id="id_stkconcepto">
                    <condicion operador="=">stkconcepto_id</condicion>
                </field>
                <field id="tipo_concepto">
                    <condicion operador="=">0</condicion>
                </field>
                <field id="produccion_concepto">
                    <condicion operador="=">1</condicion>
                </field>
            </table>
        </join>
    </form>
</histrix>