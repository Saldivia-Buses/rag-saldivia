<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="chart">
    <title>Consulta de Producción</title>
    <obs/>
    <form>
        <table id="MRP_DETALLE_REGISTRO" label="Consulta de Producción">
            <grafico id="roturas">
                <ancho>400</ancho>
                <tipo>SC</tipo>
                <etiquetas>fecha_registro</etiquetas>
                <serie>cantidad</serie>
                <serie>rechazos</serie>
                <title>Roturas</title>
            </grafico>
            <filters>
                <field id="fecha_registro" deshabilitado="false">
                    <label>Desde</label>
                    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date(&quot;m&quot; ) , 1, date(&quot;Y&quot;)  ))</valor>
                    <operador>&gt;=</operador>
                </field>
                <field id="fecha_registro" deshabilitado="false">
                    <label>Hasta</label>
                    <valor>today</valor>
                    <operador>&lt;=</operador>
                </field>
            </filters>
            <field id="fecha_registro" noshow="true" >
                <expresion>date(fecha_carga)</expresion>
                <label>año</label>
                <tipo>date</tipo>
            </field>
            <field id="rechazos">
                <label>Rechazos</label>
                <expresion>round(sum((case when mrpconcepto_id = 2 then cantidad else 0 end) ),0)</expresion>
                <tipo>numeric</tipo>
            </field>            
            <field id="cantidad">
                <label>roturas</label>
                <expresion>round(sum((case when mrpconcepto_id = 3 then cantidad else 0 end) ),0)</expresion>
                <tipo>numeric</tipo>
            </field>


            <field id="mrpconcepto_id">
                <condicion operador="in">2,3</condicion>
            </field>
            <group>
                <field id="fecha_registro"/>
            </group>
        </table>
    </form>
</histrix>