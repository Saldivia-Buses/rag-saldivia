<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="fichaing" inserta="false" modifica="false" imprime="false" preFetch="true" transaccional="true">
    <title>Cerrar Orden de Producción</title>

<customScript>
    if(jQuery('input[name=mrpestado_id]').val() == 1){
        $('button[name=Procesar]').prop('disabled', true);
    };
</customScript>

    <form >
        <table id="MRP_ORDEN_PRODUCCION" label="Cerrar Orden de Producción" >
            
            <movimientos >
                <relacion id="mrp_cerrarordenproduccion_update2.xml"></relacion>
            </movimientos>

            <field id="user_id" local="true" deshabilitado="true" noshow="true">
                <valor eval="true">$_SESSION['idUser']</valor>
            </field>

            <field id="centro_productivo_id" noshow="true" />

            <field id="id_mrporden" deshabilitado="true" style="text-align:left;width:90px;" >
               <label>Número</label>
            </field>

            <field id="fecha_orden" deshabilitado="true" style="text-align:left;margin-left:20px;">
                <label _modpos="nobr">Fecha</label>
                <help>Fecha de Orden de Producción</help>
                <tipo>date</tipo>
            </field>
<!--
            <field id="rhpersonal_id"  deshabilitado="true" style="text-align:left;">
                <helper type="combo" xml="rhpersonal_qry.xml" dir="/ayudas" empty="true"/>
                <label _modpos="nobr">Empleado</label>
                <help>Empleado responsable de la Orden de Producción</help>
            </field>
-->
            <field id="fecha_cierre" local="true" style="text-align:left;margin-left:20px;">
                <label modpos="nobr">Fecha Cierre</label>
                <help >Fecha de Cierre</help>
                <valor>today</valor>
                <tipo>date</tipo>
                <attribute id="deshabilitado">deshabilitado</attribute>
            </field>   

            <field id="stkdeposito_id" local="true" deshabilitado="true" style="text-align:left;">
                <label>Depósito Origen</label>
                <help>Lugar de Entrega/Descarga</help>
                <helper type="combo"  xml="stkdepositos_crud.xml" dir="/stock/man/" />
                <expresion>select deposito_materiaprima_id from MRP_CENTRO_PRODUCTIVO where id_centro_productivo = centro_productivo_id limit 1</expresion>
            </field>

            <field id="stkdeposito_destino_id" local="true" deshabilitado="false" modpos="nobr">
                <label >Destino</label>
                <expresion>select deposito_destino_id from MRP_CENTRO_PRODUCTIVO where id_centro_productivo = centro_productivo_id limit 1</expresion>
                <helper type="combo"  xml="stkdepositos_crud.xml" dir="/stock/man/" />
            </field>
            

            <field id="mrpestado_id" noshow="true" deshabilitado="true">
                <label modpos="nobr">Estado</label>
            </field>


            <field id="cumplir_orden" local="true" noshow="true" deshabilitado="true">
                <label modpos="nobr">Estado</label>
                <valor>1</valor>
            </field>


            <field id="stkconcepto_id"  local="true" _noshow="true">
                <expresion>select id_stkconcepto FROM STK_CONCEPTOS where tipo_concepto = 0 and produccion_concepto = 1 limit 1</expresion>
            </field>

            <field id="stkconcepto_consumido_id"  local="true" _noshow="true">
                <expresion>select id_stkconcepto FROM STK_CONCEPTOS where tipo_concepto = 1 and produccion_concepto = 1 limit 1</expresion>
            </field>

            <field id="datos"  local="true" colspan="7">
                <label>datos</label>
                <helper type="object" xml="mrp_cerrarorden_grid.xml">
                  <parameter source="id_mrporden" target="mrporden_id" />
                </helper>
            </field>


            <field id="orden_comentarios" style="text-align:left;margin-left:20px;">
                <label >Comentarios</label>
                <help>Comentarios</help>
                <size>100</size>
                <attribute id="deshabilitado">deshabilitado</attribute>
            </field>

            <field id="deshabilitado" local="true" noshow="true">
                <expression> if(mrpestado_id = 1,'true','false') </expression>
            </field>
        
            <field id="login_id" local="true" deshabilitado="true" noshow="true">
                <valor eval="true">$_SESSION['usuario']</valor>
            </field>



        </table>
    </form>
</histrix>
