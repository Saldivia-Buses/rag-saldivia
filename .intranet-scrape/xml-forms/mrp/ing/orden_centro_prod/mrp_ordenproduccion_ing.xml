<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="ing" subtipo="vertical" llenoTemporal="false" 
    _impresion="ordenproduccion_imp.xml"  dirimpresion="/mrp/qry"   imprime="false"    transaccional="true"    >

    <title>ORDEN DE PRODUCCION</title>
    <form >
        <table id="MRP_ORDEN_DETALLE" label="Orden de Producción">
            <movimientos cabecera="mrp_ordenproduccion_cab.xml">
                <relacion id="mrp_ordenproduccion_insert.xml"></relacion>

                <relacion id="mrp_ordendetalle_insert.xml"></relacion>
<!-- VIA TRIGGER  <relacion id="mrp_controldetalle_insert.xml"></relacion> -->

            </movimientos>
                                                                                                                            
            <field id="_ORDEN" oculto="true" local="true">
                <label>Orden</label>
            </field>
            
            <field id="centro_productivo_id" oculto="true">
            </field>
            <field id="stkarticulo_id"  esClave="true" linkint="stk_hist_costos_qry.xml" linkdes="Precios" linkdir="/compras/qry">
                <paring destino="stkarticulo_id" colspan="2">stkarticulo_id</paring>
                <label  style="text-align:center;"> Artículo</label>
                <help>Codigo de Articulo</help>

                <helper id="MRP_PRODUCTOS_CENTRO" type="combo" empty="true">
                    <field id="stkarticulo_id" />
                    <field id="nombre_articulo">
                        <expresion>(select nombre_articulo from STK_ARTICULOS where id_stkarticulo = stkarticulo_id)</expresion>
                        <detalle>nombre_articulo</detalle>
                    </field>
                    <field id="centro_productivo_id" >
                        <condicion operador="=" valorde="centro_productivo_id"></condicion>
                    </field>
                </helper>

                <actualiza>
            	    <field id="bomart" destino="stkarticulopadre_id"/>
                </actualiza>
            </field>
            
            <!-- <field id="codigo_plu"  deshabilitado="true">
                <label modpos="nobr">Codigo Ant</label>
            </field> -->
            <!--
            <field id="nombre_articulo"  tabla="STK_ARTICULOS" esClave="true" deshabilitado="true">
                <label  style="text-align:center;" modpos="nobr" colspan="5">Nombre</label>
                <tipo>varchar</tipo>
                <size>30</size>
            </field>
        -->

            <field id="objetivo_ordendetalle" >
                <label modpos="nobr">Cantidad</label>
                <tipo>integer</tipo>
            </field>

            <field id="bomart" showObjTabla="true" Formstyle="true">
            	<label _modpos="nobr" colspan="4">Composición</label>
            	<helper xml="mrp_bom_qry.xml" type="object" dir="/mrp/ing">
            	    <parameter source="stkarticulo_id" target="stkarticulopadre_id" />
            	    <parameter source="objetivo_ordendetalle" target="WCantidad1" /> 
            	</helper>
            </field>
<!--
            <field id="mrpobservaciones"  esClave="true" required="false">
                <label colspan="5">Observaciones</label>
                <size>80</size>
                <valor></valor>
            </field>
    -->        
            <order>
                <field id="ocpren"></field>
            </order>
        </table>
        <join tipo="left">
            <table id="STK_ARTICULOS">
                <field id="subsistema_id" >
                    <label>STK_ARTICULOS.subsistema_id</label>
                    <condicion operador="=">'01'</condicion>
                </field>
                <field id="stkarticulo_id" >
                    <condicion operador="=">CPS_DETALLE.stkarticulo_id</condicion>
                </field>
            </table>
        </join>
    </form>
</histrix>