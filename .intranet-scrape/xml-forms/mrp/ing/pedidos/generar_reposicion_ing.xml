		<helper id="MRP_ORDEN_CONCEPTO" type="combo">
			<field id="id_mrporden_concepto" />
			<field id="nombre_ordenconcepto" />
		</helper>
		<valor>2</valor>
	</field>

	<field id="numero_orden" >
			<label modpos="nobr">Nro</label>
			<expression sql="true">(select ifnull(max(numero_orden),0) + 1 from MRP_ORDEN_PRODUCCION where mrporden_concepto_id = 2)</expression>
	</field>


	<field id="mrporden_relacionada_id" local="true" deshabilitado="true" noshow="true">
		
	</field>
	<field id="detalle_reg_id" local="true" deshabilitado="true" noshow="true">
		
	</field>
                      
	<field id="id_regmovim" noshow="true" tabla="REG_MOVIMIENTOS">
		<!-- <detalle>regmovim_id</detalle>-->
	</field>
