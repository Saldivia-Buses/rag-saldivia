<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="fichaing" inserta="false" modifica="false" imprime="false" preFetch="true" _sololectura="true" processFirst="true"
	log="false" transaccional="true">
  <title>Cta Ctes</title>
  <obs/>
    <eventos>
        <event id="procesar">close</event>
    </eventos>

  <form  >
    <table id="REG_MOVIMIENTOS">
     
        <movimientos >
            <relacion id="mrp_orden_insert.xml"/>
            <relacion id="mrp_pedidos_update.xml"/>
    	</movimientos>

	<field id="id_regmovim" noshow="true" >
	</field>
	
	<field id="nro_cuenta" tabla="REG_CUENTA" noshow="true">
		<label>Cliente</label>
		<helper type="external" xml="regcuenta_solamente_nro_qry.xml" dir="/ayudas">
		    <field id="subsistema_id"></field>
		    <order>
		    <field id="nombre_cuenta"></field>
		    </order>
		</helper>
	</field>

	<field id="regcuenta_id" noshow="true">
		<operador>=</operador>
		<help>Cliente</help>
	</field>

	<field id="nombre_cuenta" tabla="REG_CUENTA ">
		<label>Nombre Cuenta</label>
		<size>60</size>
	</field>


	<field id="descripcion_concepto" tabla="REG_CONCEPTOS" >
		<label>Concepto</label>
	</field>

	<field id="nro_movimiento" noshow="true" />

	<field id="num_movimiento">
		<label>Numero</label>
		<expression>CONCAT(REG_MOVIMIENTOS.letra_movimiento,' ',LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,'0'),'-',LPAD(case when REG_MOVIMIENTOS.cajmovimiento_id &gt;
			 0 then REG_MOVIMIENTOS.cajmovimiento_id else REG_MOVIMIENTOS.nro_movimiento end ,8,'0'))
		</expression>
		<helper type="link" dir="/clientes/qry">
		    <parameter source="id_regmovim" target="id_regmovim" />  
		</helper>
	    <attribute id="linkint">imprime_concepto</attribute>
      </field>
      
      
      <field id="imprime_concepto" noshow="true">
        <expression>ifnull(ejecuta,'')</expression>
      </field>

	<field id="fecha_orden" noshow="true" local="true">
		<tipo>date</tipo>
		<valor>today</valor>
	</field>
	
	<field id="fecha_movimiento">
		<label>Fecha</label>

	</field>
                     
    <!--
	<field id="Pedido" local="true" _noshow="true">
		<label>Pedido</label>
		<expression>sum(ifnull(REG_DETALLES.cantidad_detalle,0) )</expression>
		<tipo>numeric</tipo>
	</field>
-->
	<field id="detalle" local="true" colspan="4">
		<helper xml="regpendientes_grid.xml" type="object">
			<parameter source="id_regmovim" target="regmovim_id" />
		</helper>
	</field>

	<group>
		<field id="id_regmovim" tabla="REG_MOVIMIENTOS"/>
	</group>
    </table>
    <join>
      <table id="REG_CUENTA">
        <field id="id_regcuenta">
          <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
        </field>
      </table>
    </join>
    <join>
      <table id="REG_CONCEPTOS">
        <field id="id_concepto">
          <condicion operador="=">REG_MOVIMIENTOS.concepto_id and REG_CONCEPTOS.informa_calculo = 1 </condicion>
        </field>
      </table>
    </join>

    <join tipo="left">
      <table id="REG_NUMERADORES">
        <field id="subsistema_id">
          <condicion operador="=">REG_MOVIMIENTOS.subsistema_id</condicion>
        </field>
        <field id="regconcepto_id">
          <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
        </field>
        <field id="puesto">
          <condicion operador="=">REG_MOVIMIENTOS.puesto_movimiento</condicion>
        </field>
        <field id="letra">
          <condicion operador="=">REG_MOVIMIENTOS.letra_movimiento</condicion>
        </field>
      </table>
    </join>
  </form>
</histrix>
