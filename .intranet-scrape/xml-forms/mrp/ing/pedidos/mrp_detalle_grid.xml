<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="grid" deleteRow="false" inserta="false">
  <title>Cta Ctes</title>
  <obs/>
  <form  >
    <table id="REG_DETALLES">
    	<!--
 <movimientos >
    <relacion id="mrp_imputacion_detalle_insert.xml"/>
 </movimientos>
-->
     
      <!-- CONSULTA -->
    	<fieldGroup>    

		    <field id="regmovim_id" noshow="true">
		    	<tipo>integer</tipo>
		    </field>
		    <field id="id_regdetalle" esClave="true" noshow="true">
		    </field>

			<field id="fecha_movimiento" tabla="REG_MOVIMIENTOS" >
				<label>Fecha</label>
				<tipo>date</tipo>
			</field>
			<field id="nombre_cuenta" tabla="REG_CUENTA ">
				<label>Nombre Cuenta</label>
			</field>
			<field id="nro_movimiento" tabla="REG_MOVIMIENTOS"  noshow="true" />

			<field id="num_movimiento">
				<label>Numero</label>
				<expression>CONCAT(REG_MOVIMIENTOS.letra_movimiento,' ',LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,'0'),'-',LPAD(case when REG_MOVIMIENTOS.cajmovimiento_id &gt;
					 0 then REG_MOVIMIENTOS.cajmovimiento_id else REG_MOVIMIENTOS.nro_movimiento end ,8,'0'))
				</expression>
				<helper type="link" dir="/clientes/qry">
				    <parameter source="id_regmovim" target="id_regmovim" />  
				</helper>
			    <attribute id="linkint">imprime_concepto</attribute>
	      	</field>
	     
		    <field id="imprime_concepto" noshow="true">
		        <expression>ifnull(ejecuta,'')</expression>
		    </field>

			<field id="codigo_detalle">
			    <label>Codigo</label>
			</field>
			<field id="nombre_articulo" tabla="STK_ARTICULOS">
			    <label>Articulos</label>
			</field>
			<field id="colorlabel" local="true"  noshow="true">
				<label>colorlabel</label>
				<if exp="actual==0">
					<true>'color:red;'</true>
					<false>'color:green;'</false>
				</if>
			</field>

			<field id="actual" >
				<label>Stock Actual</label>
				<attribute id="colstyle">colorlabel</attribute> 
				<expresion>ifnull((SELECT sum(cantidad_stock) FROM STK_STOCKACTUAL SA WHERE SA.stkarticulo_id= REG_DETALLES.codigo_detalle), 0)</expresion>
				<tipo>numeric</tipo>
			</field>     

			<field id="cantidad_detalle" suma="true">
				<label>cantidad</label>
				<tipo>integer</tipo>
				<jseval campodestino="cantidad_detalle" total="true">cantidad_detalle</jseval>
			</field>

			<field id="grabar" local="true">
				<valor>1</valor>
				<tipo>check</tipo>

			</field>
		</fieldGroup>
    </table>
    <join tipo="left">
      <table id="REG_MOVIMIENTOS">
        <field id="id_regmovim">
          <condicion operador="=">REG_DETALLES.regmovim_id</condicion>
        </field>
      </table>
    </join>  
        <join tipo="left">
      <table id="REG_NUMERADORES">
        <field id="subsistema_id">
          <condicion operador="=">REG_MOVIMIENTOS.subsistema_id</condicion>
        </field>
        <field id="regconcepto_id">
          <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
        </field>
        <field id="puesto">
          <condicion operador="=">REG_MOVIMIENTOS.puesto_movimiento</condicion>
        </field>
        <field id="letra">
          <condicion operador="=">REG_MOVIMIENTOS.letra_movimiento</condicion>
        </field>
      </table>
    </join>  
    <join>
      <table id="REG_CONCEPTOS">
        <field id="id_concepto">
          <condicion operador="=">REG_MOVIMIENTOS.concepto_id and REG_CONCEPTOS.informa_calculo = 1 </condicion>
        </field>
      </table>
    </join>
    <join>
      <table id="REG_CUENTA">
        <field id="id_regcuenta">
          <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
        </field>
      </table>
    </join>

    <join tipo="left">
      <table id="STK_ARTICULOS">
        <field id="id_stkarticulo">
          <condicion operador="=">REG_DETALLES.codigo_detalle</condicion>
        </field>
      </table>
    </join>    

  </form>
</histrix>
