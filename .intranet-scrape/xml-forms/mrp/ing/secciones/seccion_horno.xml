<?xml version="1.0" encoding="UTF-8"?>
<histrix borra="no" deleteRow="false" inserta="no" log="false" modifica="false" preFetch="true" tableHeight="auto" tipo="fichaing" imprime="false">
    <title>horno</title>

    <obs/>
    <events>
        <event id="procesar">
            if ($.mobile) {
                $( ":mobile-pagecontainer" ).pagecontainer(
                    'change',
                    $('[data-role="page"][id="Showordenes_x_seccion_movil_xml"]')
                );
            }
        </event>
    </events>

    <form>
        <table id="MRP_ORDEN_PRODUCCION" label="Horno">
            <movimientos>
                <relacion id="detalle_registro_insert.xml"/>
                <relacion id="ingreso_stock_insert.xml"/>
            </movimientos>
            <field id="mrpconcepto_id" local="true" noshow="true" valauto="true">
                <valor>1</valor>
            </field>
            <field id="graba_stock" local="true" noshow="true"/>
            <field id="stkconcepto_id" noshow="true">
                <label>Concepto</label>
                <expression sql="true">SELECT STK_CONCEPTOS.id_stkconcepto FROM STK_CONCEPTOS
                                            WHERE STK_CONCEPTOS.produccion_concepto = 1
                                              AND STK_CONCEPTOS.tipo_concepto = 0 LIMIT 1</expression>
            </field>

            <field id="fecha_orden" noshow="true">
                <label>Fecha</label>
            </field>
            <field id="fecha_ingreso" local="true" deshabilitado="false">
                <label>Fecha</label>
		<tipo>date</tipo>
		<valor>today</valor>

            </field>

            <field id="id_mrpordendetalle" noshow="true" tabla="MRP_ORDEN_DETALLE"/>
            <field id="mrpseccion_id" local="true" noshow="true">
                <valor>2</valor>
            </field>
            
            <field deshabilitado="true" id="stkarticulo_id" noshow="true" tabla="MRP_ORDEN_DETALLE">
                <label>Código</label>
                <size>12</size>
            </field>
            <field deshabilitado="true" id="nombre_articulo" local="true" tabla="STK_ARTICULOS">
                <label>Artículo</label>
            </field>
            <field deshabilitado="true" id="objetivo_ordendetalle" local="true">
                <label>Objetivo</label>
                <expresion>objetivo_ordendetalle</expresion>
                <tipo>numeric</tipo>
            </field>
            <field deshabilitado="false" id="carro_horno" tabla="MRP_DETALLE_REGISTRO">
                <label>Carro</label>
                <helper _empty="true" type="combo">
                    <!--
            <option value=""></option>-->
                    <option value="1">1</option>
                    <option value="2">2</option>
                    <option value="3">3</option>
                    <option value="4">4</option>
                    <option value="5">5</option>
                    <option value="6">6</option>
                    <option value="7">7</option>
                </helper>
                <!--        <tipo>radio</tipo>-->
            </field>
            <field id="id_detalle_reg" noshow="true" tabla="MRP_DETALLE_REGISTRO"/>

            <field deshabilitado="false" id="cantidad" tabla="MRP_DETALLE_REGISTRO" local="true">
                <label>Cantidad</label>
                <tipo>integer</tipo>
            </field>

            <field deshabilitado="false" id="ingreso" tabla="MRP_DETALLE_REGISTRO" local="true">
                <label>Entrada</label>
                <tipo>time</tipo>
                <valor eval="true">date('H:i')</valor>
            </field>
            <field deshabilitado="false" id="salida" tabla="MRP_DETALLE_REGISTRO" local="true">
                <label>Salida</label>
                <tipo>time</tipo>
                <valor eval="true">date('H:i')</valor>
            </field>

            <field id="precamara_in"  deshabilitado="false" tabla="MRP_DETALLE_REGISTRO">
                <label>T.Precamara 1</label>
                <tipo>integer</tipo>
            </field>
            <field deshabilitado="false" id="precamara_out" tabla="MRP_DETALLE_REGISTRO">
                <label>T.Precamara 2</label>
                <tipo>integer</tipo>
            </field>
            <field deshabilitado="false" id="camara_in" tabla="MRP_DETALLE_REGISTRO">
                <label>Camara 1</label>
                <tipo>integer</tipo>
            </field>
            <field deshabilitado="false" id="camara_out" tabla="MRP_DETALLE_REGISTRO">
                <label>Camara 2</label>
                <tipo>integer</tipo>
            </field>
            <field deshabilitado="false" id="observacion" tabla="MRP_DETALLE_REGISTRO">
                <label>Observacion</label>
            </field>
            <field id="productpath_id" local="true" noshow="true"/>                        
            <field id="proxima_seccion">
                <label>Proxima Sección</label>
                <helper xml="mrp_seccion_crud.xml" dir="/mrp/man/" type="combo"  empty="true"/>

                // SELECCIONO PROXIMA SECCION
                <expression>(select mrpseccion_id from MRP_PRODUCT_PATH as PP where PP.parent_productpath_id =  MRP_PRODUCT_PATH.id_productpath)</expression>
            </field>           
            <group>
                <field id="id_mrpordendetalle"/>
            </group>
            <order>
                <field id="fecha_orden"/>
            </order>
        </table>
        <join tipo="left">
            <table id="MRP_ORDEN_DETALLE">
                <field id="mrporden_id">
                    <condicion operador="=">MRP_ORDEN_PRODUCCION.id_mrporden</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="MRP_DETALLE_REGISTRO">
                <field id="mrpordendetalle_id">
                    <condicion operador="=">id_mrpordendetalle</condicion>
                </field>
                <field id="mrpseccion_id">
                    <condicion operador="=">[__mrpseccion_id__]</condicion>
                </field>
            </table>
        </join>
        <join tipo="inner">
            <table id="STK_ARTICULOS">
                <field id="id_stkarticulo">
                    <condicion operador="=">MRP_ORDEN_DETALLE.stkarticulo_id</condicion>
                </field>
            </table>
        </join>
        <join tipo="inner">
            <table id="MRP_PRODUCT_PATH">
                <field id="id_productpath">
                    <condicion operador="=">[__productpath_id__]</condicion>
                </field>
            </table>
        </join>
    </form>
</histrix>