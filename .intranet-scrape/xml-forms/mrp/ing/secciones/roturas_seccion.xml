<?xml version="1.0" encoding="UTF-8"?>
<histrix borra="no" deleteRow="false" imprime="false" inserta="no" log="false" modifica="false" preFetch="true" procesa="true" tableHeight="auto" tipo="fichaing">
    <title>Rechazo</title>
    <obs/>
    <form>
        <table id="MRP_ORDEN_PRODUCCION" label="Roturas">
            <movimientos>
                <relacion id="detalle_registro_insert.xml"/>
            </movimientos>

            <field id="mrpconcepto_id" local="true" noshow="true" valauto="true">
                <valor>3</valor>
            </field>

            <field id="fecha_orden" noshow="true">
                <label>Fecha</label>
            </field>
            <field id="fecha_ingreso" local="true" deshabilitado="false">
                <label>Fecha</label>
		<tipo>date</tipo>
		<valor>today</valor>

            </field>

            <field id="id_mrpordendetalle" noshow="true" tabla="MRP_ORDEN_DETALLE"/>
            <field id="mrpseccion_id" local="true" noshow="true"/>
            <field id="id_mrporden" noshow="true"/>
            <field deshabilitado="true" id="stkarticulo_id" noshow="true" tabla="MRP_ORDEN_DETALLE">
                <label>Código</label>
                <size>12</size>
            </field>
            <field deshabilitado="true" id="nombre_articulo" local="true" tabla="STK_ARTICULOS" style="font-weight:bold;color:#222;">
                <size>30</size>
            </field>
            <field id="id_detalle_reg" local="true" noshow="true"/>
            <field deshabilitado="false" editable="true" id="ingreso" local="true" noshow="true" valauto="true">
                <label>Inicio</label>
                <tipo>time</tipo>
                <valor eval="true">time()</valor>
            </field>
            <field deshabilitado="false" editable="true" id="cantidad" local="true">
                <label>Rotos</label>
                <tipo>integer</tipo>
            </field>
            <field id="mrpcontrol_id" local="true">
                <label>Motivo Rechazo</label>
                <helper id="MRP_CONTROLES" type="combo">
                    <field id="id_mrpcontrol"/>
                    <field id="nombre_control"/>
                    <field id="mrpseccion_id">
                        <condicion operador="=" valorde="mrpseccion_id"/>
                    </field>
                </helper>
            </field>
            <field id="observacion" local="true">
                <label>Observaciones</label>
                <size>80</size>
            </field>
            <!--
            <field id="foto" local="true">
                <label>Foto</label>
                <tipo>file</tipo>
            </field>            
        -->
            <group>
                <field id="id_mrpordendetalle"/>
            </group>
            <order>
                <field id="fecha_orden"/>
            </order>
        </table>
        <join tipo="left">
            <table id="MRP_ORDEN_DETALLE">
                <field id="mrporden_id">
                    <condicion operador="=">MRP_ORDEN_PRODUCCION.id_mrporden</condicion>
                </field>
            </table>
        </join>
        <join tipo="inner">
            <table id="STK_ARTICULOS">
                <field id="id_stkarticulo">
                    <condicion operador="=">MRP_ORDEN_DETALLE.stkarticulo_id</condicion>
                </field>
            </table>
        </join>
        <join tipo="inner">
            <table id="MRP_PRODUCT_PATH">
                <field id="mrpseccion_id">
                    <condicion operador="=">[__mrpseccion_id__]</condicion>
                </field>
                <field id="stkrubro_id">
                    <condicion operador="=">STK_ARTICULOS.stkrubro_id</condicion>
                </field>
            </table>
        </join>
    </form>
</histrix>