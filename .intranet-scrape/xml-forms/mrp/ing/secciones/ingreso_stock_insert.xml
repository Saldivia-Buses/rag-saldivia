<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="insert" >
    <title>ORDENES DE PRODUCCION</title>
    <obs></obs>
    <form  >
	        
	<table id="STK_MOVIMIENTOS" label="Registro de produccion" idCampoCond="graba_stock">

            
            <field id="stkarticulo_id"         id_temp="stkarticulo_id"/>
            <field id="stkdeposito_id"         id_temp="stkdeposito_id"/>
            <field id="fecha_movimiento"       >
                <valor>now()</valor>
                <tipo>integer</tipo>
            </field>
            <field id="alta_movimiento"           >
                <valor>now()</valor>
                <tipo>integer</tipo>
            </field>
            <field id="stkconcepto_id"         id_temp="stkconcepto_id"/>

            <field id="unidad_id"              id_temp="unidad_id"/>
            <field id="cantidad"               id_temp="cantidad"/>
            <field id="numero_movimiento"      id_temp="id_mrporden" />
            <field id="referencia"             id_cab="observacion"/>
            <field id="user_id" >
                <valor eval="true">$_SESSION['idUser']</valor>
            </field>


            <field id="ordendetalle_id" id_temp="id_mrpordendetalle" />

        </table>
    </form>
</histrix>
