<?xml version="1.0" encoding="UTF-8"?>
<histrix borra="no" deleteRow="false" imprime="false" inserta="no" log="false" modifica="false" preFetch="true" procesa="true" tableHeight="auto" tipo="fichaing" transaccional="true">
    <title>Corte</title>
    <obs/>
    <events>
        <event id="procesar">if ($.mobile) {
                $( &quot;:mobile-pagecontainer&quot; ).pagecontainer(
                    'change',
                    $('[data-role=&quot;page&quot;][id=&quot;Showordenes_x_seccion_movil_xml&quot;]')
                );
            }
        </event>
    </events>
    <form>
        <table id="MRP_ORDEN_PRODUCCION" label="Corte">
            <movimientos>
                <relacion id="detalle_registro_insert.xml"/>
                <relacion id="detalle_registro_filet_insert.xml"/>
                <relacion id="detalle_registro_serig_insert.xml"/>
                <relacion id="ingreso_stock_insert.xml"/>
                <relacion id="marco_orden_cumplida.xml"/>
            </movimientos>
            <field id="mrpconcepto_id" local="true" noshow="true" valauto="true">
                <valor>1</valor>
            </field>
            <field id="graba_stock" local="true" noshow="true">
                <label>graba Stock</label>
            </field>
            <field id="stkconcepto_id" noshow="true">
                <expression>select id_stkconcepto from STK_CONCEPTOS where produccion_concepto = 1 and tipo_concepto = 0 limit 1</expression>
            </field>
            <field id="fecha_orden" noshow="true">
                <label>Fecha</label>
            </field>
            <field deshabilitado="false" id="fecha_ingreso" local="true">
                <label>Fecha</label>
                <tipo>date</tipo>
                <valor>today</valor>
            </field>
            <field id="id_mrpordendetalle" noshow="true" tabla="MRP_ORDEN_DETALLE"/>
            <field id="mrpseccion_id" local="true" noshow="true"/>
            <field id="id_mrporden" noshow="true"/>
            <field deshabilitado="true" id="stkarticulo_id" noshow="true" tabla="MRP_ORDEN_DETALLE">
                <label>Código</label>
                <size>12</size>
            </field>
            <field deshabilitado="true" id="nombre_articulo" local="true" style="font-size:1.2em;" tabla="STK_ARTICULOS">
                <label>Artículo</label>
                <size>30</size>
            </field>
            <field deshabilitado="true" id="locacion">
                <expression>locacion</expression>
                <label>Medidas</label>
                <size>60</size>
            </field>
            <field deshabilitado="true" id="objetivo_ordendetalle" local="true" noshow="true" suma="true">
                <label>Objetivo</label>
                <tipo>integer</tipo>
            </field>
            <field deshabilitado="true" id="pendiente" local="true" noshow="true" style="color:red;">
                <label>Pend</label>
            </field>
            <field deshabilitado="true" id="falta" local="true" style="color:red;font-weight:bold;">
                <label/>
                <if exp="true">
                    <true>'Pendiente: pendiente de objetivo_ordendetalle'</true>
                    <false>''</false>
                </if>
                <size>30</size>
            </field>
            <field id="id_detalle_reg" local="true" noshow="true"/>
            <field deshabilitado="false" editable="true" id="cantidad" local="true" style="color:green;font-weight:bold;font-size:1.2em;">
                <label>Cantidad</label>
                <jseval>cantidad &lt;= objetivo_ordendetalle</jseval>
                <jseval campodestino="hojas_corte">cantidad * multiplo</jseval>
            </field>
            <field deshabilitado="false" id="multiplo" local="true" noshow="true">
                <label>Multiplo</label>
                <valor>1</valor>
                <jseval campodestino="hojas_corte">cantidad * multiplo</jseval>
            </field>
            <field deshabilitado="false" editable="true" id="hojas_corte" local="true" style="color:green;font-weight:bold;font-size:1.2em;">
                <label>Paños</label>
            </field>
            <field id="paquete_id" local="true" style="font-size:1.2em;">
                <label>Nro Paquete</label>
                <helper xml="stkmovimientos_trazables_qry.xml" _id="STK_MOVIMIENTO_TRAZ" type="combo" empty="true">
                    <field id="stkdeposito_id">
                        <condicion operador="=">2</condicion>
                    </field>
                    <field id="descripcion_paquete">
                        <expression>STK_MOVIMIENTOS.stkarticulo_id</expression>
                        <detalle>descripcion_paquete</detalle>
                    </field>
                </helper>                
            </field>
            <field id="descripcion_paquete" local="true" style="font-size:1.2em;">
                <label>Material</label>
                <helper _xml="stkarticulo_simple_qry.xml" dir="/ayudas" empty="true" id="STK_ARTICULOS" type="combo">
                    <field id="id_stkarticulo">
                        <condicion operador="like">'F%'</condicion>
                    </field>
                    <field id="nombre_articulo2">
                        <expression having="false">nombre_articulo</expression>
                    </field>
                    <!--
            <field id="stkrubro_id"><condicion operador="=">3</condicion></field>-->
                </helper>
            </field>
            <field id="alto_corte" _local="true" style="font-size:1.2em;" deshabilitado="false">
                <label>Alto</label>
		        <expression>(case when alto_ordendetalle != 0 then alto_ordendetalle else alto end)</expression>
            </field>
            <field id="ancho_corte" _local="true" style="font-size:1.2em;" deshabilitado="false">
                <label>Ancho</label>
		        <expression>(case when ancho_ordendetalle != 0 then ancho_ordendetalle else alto end)</expression>
            </field>
            <field deshabilitado="false" editable="true" id="ingreso" local="true" style="font-size:1.2em;" valauto="true">
                <label>Inicio</label>
                <tipo>time</tipo>
                <valor eval="true">date('H:i')</valor>
            </field>
            <field deshabilitado="false" editable="true" id="salida" local="true" style="font-size:1.2em;">
                <label>Finalización</label>
                <tipo>time</tipo>
                <valor eval="true">date('H:i')</valor>
            </field>
            <field id="observacion" local="true" style="font-size:1.2em;">
                <label>Observaciones</label>
                <size>40</size>
            </field>
            <field id="productpath_id" local="true" noshow="true"/>// PROXIMA SECCION
            
            <field id="next_productpath_id" noshow="true">
                <label>Proxima Sección</label>
                <expression>(select PP.id_productpath from MRP_PRODUCT_PATH as PP where PP.parent_productpath_id =  MRP_PRODUCT_PATH.id_productpath)</expression></field>
            <field id="next_2_productpath_id" noshow="true">
                <expression>select MPP.id_productpath from MRP_PRODUCT_PATH MPP where MPP.parent_productpath_id = (select MPP.id_productpath from MRP_PRODUCT_PATH MPP where MPP.parent_productpath_id = MRP_PRODUCT_PATH.id_productpath)</expression>
            </field>
            <group>
                <field id="id_mrpordendetalle"/>
            </group>
            <order>
                <field id="fecha_orden"/>
            </order>
        </table>
        <join tipo="left">
            <table id="MRP_ORDEN_DETALLE">
                <field id="mrporden_id">
                    <condicion operador="=">MRP_ORDEN_PRODUCCION.id_mrporden</condicion>
                </field>
            </table>
        </join>
        <!--
        <join tipo="left"><table id="MRP_DETALLE_REGISTRO"><field id="mrpordendetalle_id"><condicion operador="=">id_mrpordendetalle</condicion></field><field id="mrpseccion_id"><condicion operador="=">[__mrpseccion_id__]</condicion></field></table></join>-->
        <join tipo="inner">
            <table id="STK_ARTICULOS">
                <field id="id_stkarticulo">
                    <condicion operador="=">MRP_ORDEN_DETALLE.stkarticulo_id</condicion>
                </field>
            </table>
        </join>
        <join tipo="inner">
            <table id="MRP_PRODUCT_PATH">
                <field id="mrpseccion_id">
                    <condicion operador="=">[__mrpseccion_id__]</condicion>
                </field>
                <field id="stkrubro_id">
                    <condicion operador="=">STK_ARTICULOS.stkrubro_id</condicion>
                </field>
            </table>
        </join>
    </form>
</histrix>