<?xml version="1.0" encoding="UTF-8"?>
<histrix borra="no" deleteRow="false" imprime="false" inserta="no" log="false" modifica="false" preFetch="true" procesa="true" tableHeight="auto" tipo="fichaing">
    <title>Laminado</title>
    <obs/>
    <events>
        <event id="procesar">
            if ($.mobile) {
                $( ":mobile-pagecontainer" ).pagecontainer(
                    'change',
                    $('[data-role="page"][id="Showordenes_x_seccion_movil_xml"]')
                );
            }
        </event>
    </events>

    <form>
        <table id="MRP_ORDEN_PRODUCCION" label="Laminado">

            <movimientos>
                <relacion id="detalle_registro_insert.xml"/>
                <relacion id="ingreso_stock_insert.xml"/>
                <relacion id="marco_orden_cumplida.xml" />
            </movimientos>

            <field id="mrpconcepto_id" local="true" noshow="true" valauto="true">
                <valor>1</valor>
            </field>
            <field id="graba_stock" local="true" noshow="true"/>
            <field id="stkconcepto_id" noshow="true">
                <expression sql="true">select id_stkconcepto from STK_CONCEPTOS where produccion_concepto = 1 and tipo_concepto = 0 limit 1</expression>
            </field>
            <field id="fecha_orden" noshow="true">
                <label>Fecha</label>
            </field>
            <field id="fecha_ingreso" local="true" deshabilitado="false">
                <label>Fecha</label>
		<tipo>date</tipo>
		<valor>today</valor>

            </field>

            <field id="id_mrpordendetalle" noshow="true" tabla="MRP_ORDEN_DETALLE"/>
            <field id="mrpseccion_id" local="true" noshow="true"/>
            

            <field id="id_mrporden" noshow="true"/>
            <field deshabilitado="true" id="stkarticulo_id" noshow="true" tabla="MRP_ORDEN_DETALLE">
                <label>Código</label>
                <size>12</size>
            </field>
            <field deshabilitado="true" id="nombre_articulo" local="true" tabla="STK_ARTICULOS">
                <label>Artículo</label>
                <size>30</size>
            </field>
            <field deshabilitado="true" id="objetivo_ordendetalle" local="true" suma="true" noshow="true">
                <label>Objetivo</label>
            </field>
            <field id="pendiente" deshabilitado="true" style="color:red;" local="true" noshow="true">
                <label>Pend</label>
            </field>          
            <field id="falta" local="true" deshabilitado="true" style="color:red;font-weight:bold;">
                <label></label>
                <if exp="true">
                    <true>'Pendiente: pendiente de objetivo_ordendetalle'</true>
                    <false>''</false>
                </if>
                <size>30</size>
            </field>
            <field id="id_detalle_reg" local="true" noshow="true"/>
            <field deshabilitado="false" editable="true" id="cantidad" local="true">
                <label>Cantidad</label>
                <jseval>cantidad &lt;= objetivo_ordendetalle</jseval>
            </field>
            <field deshabilitado="false" editable="true" id="ingreso" local="true" valauto="true">
                <label>Inicio</label>
                <tipo>time</tipo>
                 <valor eval="true">date('H:i')</valor>
            </field>
            <field deshabilitado="false" editable="true" id="salida" local="true">
                <label>Finalización</label>
                <tipo>time</tipo>
                 <valor eval="true">date('H:i')</valor>
            </field>
            <field deshabilitado="false" editable="true" id="mesa_1" local="true" multiple="true">
                <label>Mesa 1</label>
                <helper type="combo" id="REG_CUENTA">
                    <field id="id_regcuenta">
                    </field>
                    <field id="nombre">
                        <expression>concat(apellido_cuenta, ', ',nombre_cuenta )</expression>
                    </field>
                    <field id="subsistema_id">
                        <condicion operador="=">'RH'</condicion>
                    </field>
                    <order>
                        <field id="nombre" />
                    </order>*
                </helper>
                <tipo>varchar</tipo>
            </field>
        
            <field deshabilitado="false" editable="true" id="mesa_2" local="true" multiple="true">
                <label>Mesa 2</label>
                <helper type="combo" id="REG_CUENTA">
                    <field id="id_regcuenta">
                    </field>
                    <field id="nombre">
                        <expression>concat(apellido_cuenta, ', ',nombre_cuenta )</expression>
                    </field>
                    <field id="subsistema_id">
                        <condicion operador="=">'RH'</condicion>
                    </field>
                    <order>
                        <field id="nombre" />
                    </order>*
                </helper>
                <tipo>varchar</tipo>
            </field>
        
            <field deshabilitado="false" editable="true" id="codigo_pvb" local="true">
                <label>Codigo PVB</label>
                <helper xml="stkmovimientos_trazables_qry.xml" _id="STK_MOVIMIENTO_TRAZ" type="combo">
                    <field id="stkdeposito_id">
                        <condicion operador="=">1</condicion>
                    </field>
                </helper>
            </field>
            
            <field id="observacion" local="true">
                <label>Observaciones</label>
                <size>40</size>
            </field>
            <field id="productpath_id" local="true" noshow="true"/>
            <field id="proxima_seccion">
                <label>Proxima Sección</label>
                <helper xml="mrp_seccion_crud.xml" dir="/mrp/man/" type="combo"  empty="true"/>

                // SELECCIONO PROXIMA SECCION
                <expression>(select mrpseccion_id from MRP_PRODUCT_PATH as PP where PP.parent_productpath_id =  MRP_PRODUCT_PATH.id_productpath)</expression>
            </field>          
            <group>
                <field id="id_mrpordendetalle"/>
            </group>
            <order>
                <field id="fecha_orden"/>
            </order>
        </table>
        <join tipo="left">
            <table id="MRP_ORDEN_DETALLE">
                <field id="mrporden_id">
                    <condicion operador="=">MRP_ORDEN_PRODUCCION.id_mrporden</condicion>
                </field>
            </table>
        </join>
        <join tipo="inner">
            <table id="STK_ARTICULOS">
                <field id="id_stkarticulo">
                    <condicion operador="=">MRP_ORDEN_DETALLE.stkarticulo_id</condicion>
                </field>
            </table>
        </join>
        <join tipo="inner">
            <table id="MRP_PRODUCT_PATH">
                <field id="id_productpath">
                    <condicion operador="=">[__productpath_id__]</condicion>
                </field>
            </table>
        </join>
    </form>
</histrix>