<?xml version="1.0" encoding="UTF-8"?>
<histrix inserta="no" preFetch="true"  tipo="ficha" imprime="false">
    <title>horno</title>
    <obs/>
    <form>
        <table id="MRP_DETALLE_REGISTRO" label="Horno">
            <movimientos>
                <relacion id="marco_cumplida.xml" />
            </movimientos>

             <field id="id_mrpordendetalle" noshow="true">
                <expression>mrpordendetalle_id</expression>
             </field>

            <field id="fecha_ingreso" >
                <label>Fecha</label>
		<tipo>date</tipo>
            </field>

            <field id="carro_horno" >
                <label>Carro</label>
                <helper _empty="true" type="combo">
                    <option value="1">1</option>
                    <option value="2">2</option>
                    <option value="3">3</option>
                    <option value="4">4</option>
                    <option value="5">5</option>
                    <option value="6">6</option>
                    <option value="7">7</option>
                </helper>
            </field>
            <field id="id_detalle_reg" noshow="true" />

            <field  id="cantidad"  >
                <label>Cantidad</label>
                <tipo>integer</tipo>
            </field>

            <field  id="ingreso"  >
                <label>Entrada</label>
                <tipo>time</tipo>
            </field>
            <field  id="salida"  >
                <label>Salida</label>
                <tipo>time</tipo>
            </field>

            <field id="precamara_in"   >
                <label>T.Precamara 1</label>
                <tipo>integer</tipo>
            </field>
            <field  id="precamara_out" >
                <label>T.Precamara 2</label>
                <tipo>integer</tipo>
            </field>
            <field  id="camara_in" >
                <label>Camara 1</label>
                <tipo>integer</tipo>
            </field>
            <field  id="camara_out" >
                <label>Camara 2</label>
                <tipo>integer</tipo>
            </field>
            <field  id="observacion" >
                <label>Observacion</label>
            </field>
        </table>
    </form>
</histrix>