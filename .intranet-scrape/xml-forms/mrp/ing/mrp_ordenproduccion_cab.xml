<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="cabecera" >
    <title>ORDEN DE COMPRA</title>
    <consulta>
        <table id="MRP_ORDEN_PRODUCCION" label="ORDEN DE COMPRA" >

    <fieldGroup style="padding:2px 2px 2px 2px;">

            <field id="fecha_orden" >
                <label modpos="nobr">Fecha</label>
                <help >Fecha de Orden de Producción</help>
                <valor>today</valor>
                <tipo>date</tipo>
            </field>

            <field id="id_mrporden">
                    <label modpos="nobr">Nro</label>
                    <expresion sql="true">select max(id_mrporden) + 1 from MRP_ORDEN_PRODUCCION</expresion>
                    <detalle>id_mrporden</detalle>
            </field>
            
            <field id="rhpersonal_id" >
        	    <helper type="combo" xml="rhpersonal_qry.xml" dir="/ayudas" empty="true"/>
                <label modpos="nobr">Empleado</label>
                <help >Empleado responsable de la Orden de Producción</help>
                <actualiza>
                    <field id="codemp"></field>
                </actualiza>
            </field>

            <field id="codemp" local="true" noshow="true"></field>

            <field id="mrporden_id" noshow="true">
            	<expresion sql="true">select max(id_mrporden) + 1 from MRP_ORDEN_PRODUCCION</expresion>
            	<detalle>id_mrporden</detalle>
            </field>

            <field id="orden_comentarios" >
                <label colspan="5">Comentarios</label>
                <help>Comentarios</help>
                <size>140</size>
            </field>



    </fieldGroup>

            <field id="login_id" local="true" deshabilitado="true" noshow="true">
                <valor eval="true">$_SESSION['idUser']</valor>
            </field>

            
            <!-- <field id="mrpestado_id" oculto="true">
                <label>Estado </label>
                <help>Estado Actual</help>
                <options>
                    <option valor="0">Pendiente</option>
                    <option valor="1">Cumplida</option>
                </options>
                <valor>1</valor>
            </field> -->

        </table>
    </consulta>
</histrix>
