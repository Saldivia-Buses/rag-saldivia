<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="consulta" _imprime="false" >
    <title>Cálculo de Compras</title>
    <obs></obs>
    <form >
        <table id="MRP_FORECAST" label="Cálculo de Compras">

            <fieldGroup noshow="true">

                <field id="fecha_calculo" local="true">
                    <label modpos="nobr">Fecha</label>
                    <operador>=</operador>
                    <tipo>date</tipo>
                </field>

                <field id="stkdeposito_id" deshabilitado="true" local="true" noshow="true">
	               <label >Deposito</label>
	               <helper type="combo"  id="STK_DEPOSITOS" _xml="stkdepositos_crud.xml" dir="/stock/man">
                        <field id="id_stkdeposito" />
                        <field id="DEPOSITO">
                            <expresion>nombre_deposito</expresion>
                        </field>
	                </helper>
                </field>
			
                <field id="year_forecast" noshow="true" incdec="true">
                    <label>año</label>
                </field>

                <field id="mes_forecast" noshow="true">
                    <label>mes</label>
                    <options>
                        <option valor="1">Enero</option>
                        <option valor="2">Febrero</option>
                        <option valor="3">Marzo</option>
                        <option valor="4">Abril</option>                                        
                        <option valor="5">Mayo</option>
                        <option valor="6">Junio</option>
                        <option valor="7">Julio</option>
                        <option valor="8">Agosto</option>                                        
                        <option valor="9">Septiembre</option>
                        <option valor="10">Octubre</option>
                        <option valor="11">Noviembre</option>
                        <option valor="12">Diciembre</option>                                    
                    </options>                            
                </field>
                
                <!-- <field id="mes_forecast2" noshow="true">
                    <expresion having="false">mes_forecast</expresion>
                    <condicion operador="&lt;=">([__mes_forecast__] + 3)</condicion>
                </field> -->

                <field id="tipo_forecast" oculto="true" >
		              <condicion operador="=">2</condicion>
                </field>
	   
            </fieldGroup>
	
	    <fieldGroup _noshow="true" style="text-align:right;">

            <!-- <field id="Produccion1">
                    <label>Pronostico 1</label>
                    <expresion>select MRP.cantidad_forecast from MRP_FORECAST as MRP where MRP.stkarticulo_id = MRP_FORECAST.stkarticulo_id and
		              MRP_FORECAST.mes_forecast = MRP.mes_forecast and MRP.year_forecast = MRP_FORECAST.year_forecast and MRP.tipo_forecast = 2
                      </expresion>
                    <tipo>integer</tipo>
                </field>  -->

                # SUMA EL PRONOSTICO DE COMPRAS
                # EL MES QUE QUE VIENE + 1 MES ADELANTE + OTRO MES ADELANTE
                
                <field id="Produccion1" noZero="true" suma="true">
                    <label>Pronostico P 1</label>
                    <expresion having="false">sum(cantidad_forecast)</expresion>
                    <help>Pronostico de Produccion del Mes Actual</help>
                    <!-- <expresion>select MRP.cantidad_forecast from MRP_FORECAST as MRP where MRP.stkarticulo_id = MRP_FORECAST.stkarticulo_id and
                    MRP.mes_forecast  = (case when MRP_FORECAST.mes_forecast = 12 then 1 else MRP_FORECAST.mes_forecast + 1 end ) and 
                    MRP.year_forecast = (case when MRP_FORECAST.mes_forecast = 12 then MRP_FORECAST.year_forecast + 1 else MRP_FORECAST.year_forecast  end ) 
		              and MRP.tipo_forecast = 2</expresion>-->
                    <tipo>integer</tipo>
                </field>

                <field id="Produccion2"  noZero="true" suma="true">
                    <label>Pronostico v 2</label>
                    <expresion>sum((select MRP.cantidad_forecast from MRP_FORECAST as MRP where MRP.stkarticulo_id = MRP_FORECAST.stkarticulo_id and
                    MRP.mes_forecast  = (case when MRP_FORECAST.mes_forecast >= 11 then ( 12 -  MRP_FORECAST.mes_forecast + 2 ) else MRP_FORECAST.mes_forecast + 2 end ) and 
                    MRP.year_forecast = (case when MRP_FORECAST.mes_forecast >= 11 then MRP_FORECAST.year_forecast + 1 else MRP_FORECAST.year_forecast  end ) 
		              and MRP.tipo_forecast = 1))</expresion>
                    <tipo>integer</tipo>
                    <help>Pronostico de Venta del Mes Próximo</help>
                </field>

                <field id="Produccion3" noZero="true" suma="true">
                    <label>Pronostico v 3</label>
		           <expresion>sum((select MRP.cantidad_forecast from MRP_FORECAST as MRP where MRP.stkarticulo_id = MRP_FORECAST.stkarticulo_id and
                    MRP.mes_forecast  = (case when MRP_FORECAST.mes_forecast >= 10 then ( 12 -  MRP_FORECAST.mes_forecast + 3 ) else MRP_FORECAST.mes_forecast + 3 end ) and 
                    MRP.year_forecast = (case when MRP_FORECAST.mes_forecast >= 10 then MRP_FORECAST.year_forecast + 1 else MRP_FORECAST.year_forecast  end ) 
		            and MRP.tipo_forecast = 1))</expresion>
                    <tipo>integer</tipo>
                    <help>Pronostico de Venta dentro de 3  Meses</help>
                </field>
                
            </fieldGroup>
	
	        <fieldGroup >
                
                # TOTAL DE LA PRODUCCION DEL PRODUCTO ELABORADO

                <field id="totpron" local="true" suma="true">
            	    <label>Total Pronostico</label>
            	    <if exp="true">
            		<true>(Produccion1 + 0 ) + (Produccion2 + 0 )  + ( Produccion3 + 0)</true>
            		<false>0</false>
            	    </if>
                </field>

                <field id="stkarticulohijo_id" noshow="true" esClave="true" linkint="mrp_mp_prod_qry.xml" linkdir="/mrp/ing/compras/" linkdes="Se utiliza en">
                    <label>Materia Prima</label>
                    <paring destino="stkarticulohijo_id" id="stkarticulohijo_id">stkarticulohijo_id</paring>
                    <helper type="external" id="STK_ARTICULOS" _xml="stkarticulo_qry.xml" dir="/ayudas">
            			<field id="id_stkarticulo"   >
            				<label>Codigo auto de Articulo</label>
            			</field>
            			<field id="nombre_articulo">
            				<label>Nombre</label>
            			</field>
                    </helper>
        		    <expresion having="false">STK_BOM.stkarticulohijo_id</expresion>
                </field>
                
                <!--<field id="nombre" >
                    <expresion>nombre_articulo</expresion>    
                    <label>Articulo</label>
                    <help>Codigo de Articulo</help>
                </field>-->

                <field id="stkarticulo_id" style="text-align:center;" >
                    <label>Código</label>
                    <helper type="external" xml="stkarticulo_qry.xml" dir="/ayudas"/>
                    <help>Codigo de Articulo</help>
                </field>
                
                <field id="nombre_prod" style="text-align:center;">
                    <expresion having="false">(select ART.nombre_articulo from STK_ARTICULOS as ART where ART.id_stkarticulo = MRP_FORECAST.stkarticulo_id)</expresion>
                    <label>Producto Elaborado</label>
                    <help>Codigo de Articulo</help>
                </field>

                <field id="cantidad" >
                    <expresion having="false">STK_BOM.cantidad</expresion>
                    <label>Multiplo</label>
                    <tipo>decimal</tipo>
                </field>

                <!--<field id="nombre_cuenta" tabla="REG_CUENTA">
                        <label>Proveedor</label>
                        <size>50</size>
                </field>-->         

        		<field id="cantidad_forecast" noZero="true" noshow="true">
                    <expresion>sum(cantidad_forecast)</expresion>
                    <label>Producido</label>
                    <tipo>decimal</tipo>
                    <!-- <condicion operador="!=">0</condicion>  -->
                </field>

                 <!--<field id="Cantidad"  noshow="true">
                    <label>Multiplo</label>
                    <expresion>STK_BOM.cantidad</expresion>
                </field> -->  

                <field id="Compras" suma="true">
                    <label>Compras</label>
		              <expresion>sum( STK_BOM.cantidad * (cantidad_forecast + (select MRP.cantidad_forecast from MRP_FORECAST as MRP where MRP.stkarticulo_id = MRP_FORECAST.stkarticulo_id and
                    MRP.mes_forecast  = (case when MRP_FORECAST.mes_forecast >= 11 then ( 12 -  MRP_FORECAST.mes_forecast + 2 ) else MRP_FORECAST.mes_forecast + 2 end ) and 
                    MRP.year_forecast = (case when MRP_FORECAST.mes_forecast >= 11 then MRP_FORECAST.year_forecast + 1 else MRP_FORECAST.year_forecast  end ) 
		              and MRP.tipo_forecast = 1) + (select MRP.cantidad_forecast from MRP_FORECAST as MRP where MRP.stkarticulo_id = MRP_FORECAST.stkarticulo_id and
                    MRP.mes_forecast  = (case when MRP_FORECAST.mes_forecast >= 10 then ( 12 -  MRP_FORECAST.mes_forecast + 3 ) else MRP_FORECAST.mes_forecast + 3 end ) and 
                    MRP.year_forecast = (case when MRP_FORECAST.mes_forecast >= 10 then MRP_FORECAST.year_forecast + 1 else MRP_FORECAST.year_forecast  end ) 
		              and MRP.tipo_forecast = 1)))</expresion>
                    <tipo>decimal</tipo>
                </field>
            
            <!-- <field id="totprod" local="true" suma="true" >
            	    <label>Total</label>
            	    <if exp="true">
                		<true>Cantidad * totpron</true>
                		<false>0</false>
            	    </if>
                    <tipo>decimal</tipo>
            </field>
                                                  -->
