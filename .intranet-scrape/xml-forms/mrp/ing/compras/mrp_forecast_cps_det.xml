            	    <label>Stock</label>

                    <expresion> ifnull(( SELECT sum((CASE WHEN STK_CONCEPTOS.tipo_concepto = 0 THEN STK_MOVIMIENTOS.cantidad ELSE -(STK_MOVIMIENTOS.cantidad) END)) as "Stock" from STK_MOVIMIENTOS  
