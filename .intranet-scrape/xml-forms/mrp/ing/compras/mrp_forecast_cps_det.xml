	    </fieldGroup>

        	    <field id="color" clasefila="true" local="true" noshow="true">
                    <if exp=" stock_actual &lt; 0">
        		      <true>'error'</true>
        		      <false>''</false>
                    </if>
        	    </field>

	    <group>
		      <field id="stkarticulo_id" />
	    </group>
    
        </table>

            <join tipo="left">
                <table id="STK_BOM">
                    <field id="stkarticulopadre_id">
                        <condicion operador="=">stkarticulo_id</condicion>
                    </field>
                </table>
            </join>
            <join tipo="left">
                <table id="STK_ARTICULOS">
                    <field id="id_stkarticulo">
                        <condicion operador="=">stkarticulohijo_id</condicion>
                    </field>
                </table>
            </join>
            
