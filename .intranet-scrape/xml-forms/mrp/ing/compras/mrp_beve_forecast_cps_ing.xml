<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="consulta" _imprime="false" preloadData="false" preFetch="false">
    <title>Forecast Articulos</title>
    <obs></obs>
    <form >
        <table id="MRP_FORECAST" label="Forecast">
            <filters>
                <field id="year_forecast">
                    <label>año</label>
                    <operador>=</operador>
                    <valor eval="true">date("Y")</valor>
                </field>
                <field id="mes_forecast">
                    <label modpos="nobr">mes</label>
                    <operador>=</operador>
                    <valor eval="true">date("m")</valor>
                </field>
                <field id="mrpperiodo_id" >
		        <label modpos="nobr">Periodo</label>
                </field>
		<field id="fecini_mrpperiodo"  _local="true" _noshow="true">
			<label modpos="nobr">PIni</label>
		</field>
		<field id="fecfin_mrpperiodo"  _local="true" _noshow="true">
			<label modpos="nobr">PFin</label>
		</field> 

                <field id="stkarticulo_id" esClave="true">
                    <label>Producto</label>
                    <helper type="external" xml="stkarticulo_qry.xml" dir="/ayudas"/>
                    <help>Codigo de Articulo</help>
                    <operador>=</operador>
                </field>
		<field id="stkarticulohijo_id" deshabilitado="false">
                    <label>Materia Prima</label>
		    <expresion>STK_BOM.stkarticulohijo_id</expresion>
                    <tipo>integer</tipo>
                    <operador>=</operador>

                </field>
            <field id="stkdeposito_id" >
        	<label>Deposito</label>
        	<valor>1</valor>
        	
	    </field>

            </filters>
         
	    <movimientos>
		<relacion id="mrp_forecast_cps_insert.xml" />

	    </movimientos>	
		<field id="fecini_mrpperiodo"  local="true" noshow="true">
			<label modpos="nobr">Ini</label>
		</field>
		<field id="fecfin_mrpperiodo"  local="true" noshow="true">
			<label modpos="nobr">Fin</label>
		</field>
                <field id="mrpperiodo_id" _local="true" tabla="MRP_FORECAST"  deshabilitado="true" noshow="true">
		       	<helper type="combo" xml="mrpperiodos_qry.xml" dir="/ayudas" empty="true"/>
		        <label modpos="nobr">Periodo</label>
                </field>	
		<field id="stkdeposito_id" deshabilitado="true" local="true" noshow="true">
			<label >Deposito</label>
			<helper type="combo"  id="STK_DEPOSITOS" _xml="stkdepositos_crud.xml" dir="/stock/man">
			    <field id="id_stkdeposito" />
			    <field id="DEPOSITO">
				<expresion>nombre_deposito</expresion>
			    </field>
			</helper>
		</field>

            <fieldGroup noshow="true">
                <field id="stkarticulo_id" esClave="true">
                    <label>Código</label>
                    <helper type="external" xml="stkarticulo_qry.xml" dir="/ayudas"/>
                    <help>Codigo de Articulo</help>
                </field>
                
    		<field id="nombre_prod" >
                    <expresion having="false">(select ART.nombre_articulo from STK_ARTICULOS as ART where ART.id_stkarticulo = MRP_FORECAST.stkarticulo_id)</expresion>
                    <label>Producto Elaborado</label>
                    <help>Codigo de Articulo</help>
                </field>
    
		
                <field id="year_forecast" noshow="true" incdec="true">
                    <label>año</label>
                </field>
                <field id="mes_forecast" noshow="true">
                    <label>mes</label>
                <options>
                    <option valor="1">Enero</option>
                    <option valor="2">Febrero</option>
                    <option valor="3">Marzo</option>
                    <option valor="4">Abril</option>                                        
                    <option valor="5">Mayo</option>
                    <option valor="6">Junio</option>
                    <option valor="7">Julio</option>
                    <option valor="8">Agosto</option>                                        
                    <option valor="9">Septiembre</option>
                    <option valor="10">Octubre</option>
                    <option valor="11">Noviembre</option>
                    <option valor="12">Diciembre</option>                                    
                </options>                            

                </field>
                <!--
                <field id="mes_forecast2" noshow="true">
                    <expresion having="false">mes_forecast</expresion>
                    <condicion operador="&lt;=">([__mes_forecast__] + 3)</condicion>
                </field>
                -->
                <field id="tipo_forecast" oculto="true" >
		    <condicion operador="=">2</condicion>
                </field>

	   
            </fieldGroup>
	
	    <fieldGroup _noshow="true">
                                      <!--
		<field id="Produccion1">
                    <label>Pronostico 1</label>
		    <expresion>select MRP.cantidad_forecast from MRP_FORECAST as MRP where MRP.stkarticulo_id = MRP_FORECAST.stkarticulo_id and
		    MRP_FORECAST.mes_forecast = MRP.mes_forecast and MRP.year_forecast = MRP_FORECAST.year_forecast
		    and MRP.tipo_forecast = 2</expresion>
                    <tipo>integer</tipo>
                </field>
                                          -->
                # SUMA EL PRONOSTICO DE COMPRAS
                # EL MES QUE QUE VIENE + 1 MES ADELANTE + OTRO MES ADELANTE
                
		<field id="Produccion1" noZero="true">
                    <label>Pronostico P 1</label>
                    <expresion>sum(cantidad_forecast)</expresion>
<!--
		    <expresion>select MRP.cantidad_forecast from MRP_FORECAST as MRP where MRP.stkarticulo_id = MRP_FORECAST.stkarticulo_id and
                    MRP.mes_forecast  = (case when MRP_FORECAST.mes_forecast = 12 then 1 else MRP_FORECAST.mes_forecast + 1 end ) and 
                    MRP.year_forecast = (case when MRP_FORECAST.mes_forecast = 12 then MRP_FORECAST.year_forecast + 1 else MRP_FORECAST.year_forecast  end ) 
		    and MRP.tipo_forecast = 2</expresion>
		    -->
                    <tipo>integer</tipo>
                </field>

		<field id="Produccion2"  noZero="true" noshow="true">
                    <label>Pronostico v 2</label>
		    <expresion>select MRP.cantidad_forecast from MRP_FORECAST as MRP where MRP.stkarticulo_id = MRP_FORECAST.stkarticulo_id and
                    MRP.mes_forecast  = (case when MRP_FORECAST.mes_forecast >= 11 then ( 12 -  MRP_FORECAST.mes_forecast + 2 ) else MRP_FORECAST.mes_forecast + 2 end ) and 
                    MRP.year_forecast = (case when MRP_FORECAST.mes_forecast >= 11 then MRP_FORECAST.year_forecast + 1 else MRP_FORECAST.year_forecast  end ) 
		    and MRP.tipo_forecast = 1</expresion>
                    <tipo>integer</tipo>
                </field>

		<field id="Produccion3" noZero="true" noshow="true">
                    <label>Pronostico v 3</label>
		    <expresion>select MRP.cantidad_forecast from MRP_FORECAST as MRP where MRP.stkarticulo_id = MRP_FORECAST.stkarticulo_id and
                    MRP.mes_forecast  = (case when MRP_FORECAST.mes_forecast >= 10 then ( 12 -  MRP_FORECAST.mes_forecast + 3 ) else MRP_FORECAST.mes_forecast + 3 end ) and 
                    MRP.year_forecast = (case when MRP_FORECAST.mes_forecast >= 10 then MRP_FORECAST.year_forecast + 1 else MRP_FORECAST.year_forecast  end ) 
		    and MRP.tipo_forecast = 1</expresion>
                    <tipo>integer</tipo>
                </field>

                
            </fieldGroup>
	
	    <fieldGroup >
                # TOTAL DE LA PRODUCCION DEL PRODUCTO ELABORADO

                <field id="totpron" local="true">
            	    <label>Total Pronostico</label>
            	    <if exp="true">
            		<true>(Produccion1 + 0 ) + (Produccion2 + 0 )  + ( Produccion3 + 0)</true>
            		<false>0</false>
            	    </if>
                </field>

		<field id="stkarticulohijo_id" esClave="true">
                    <label>Materia Prima</label>
                    <helper type="external" xml="stkarticulo_qry.xml" dir="/ayudas"/>
		    <expresion having="false">STK_BOM.stkarticulohijo_id</expresion>
		    <detalle>stkarticulohijo_id</detalle>
                </field>

                <field id="nombre" >
                    <expresion>nombre_articulo</expresion>    
                    <label>Articulo</label>
                    <help>Codigo de Articulo</help>
                </field>
                
		<field id="cantidad_forecast" noZero="true" noshow="true">
                    <expresion>sum(cantidad_forecast)</expresion>
                    <label>Producido</label>
                    <tipo>decimal</tipo>
                    <condicion operador="!=">0 and STK_BOM.stkarticulohijo_id  not in(select stkarticulopadre_id from STK_BOM)</condicion>
                </field>
		<field id="Cantidad">
                    <label>Multiplo</label>
		    <expresion>max(STK_BOM.cantidad)</expresion>
                    <tipo>decimal</tipo>
                </field>
                <!--
		<field id="Compras">
                    <label>Compras</label>
		    <expresion>sum(STK_BOM.cantidad) * sum(cantidad_forecast)</expresion>
                    <tipo>decimal</tipo>
                </field>
                -->
                       
                <field id="totprod" local="true">
            	    <label>Total</label>
            	    <if exp="true">
            		<true>Cantidad * totpron</true>
            		<false>0</false>
            	    </if>

            	    
                    <tipo>decimal</tipo>

                </field>
                           

                <field id="stock_minimo">
            	    <label>Stock Minimo</label>
            	    <expresion>STK_ARTICULOS.stock_minimo</expresion>
                    <tipo>decimal</tipo>

                </field>

                <field id="stock_actual">
            	    <label>Stock</label>

                    <expresion> ifnull(( SELECT sum((CASE WHEN STK_CONCEPTOS.tipo_concepto = 0 THEN STK_MOVIMIENTOS.cantidad ELSE -(STK_MOVIMIENTOS.cantidad) END)) as "Stock" from STK_MOVIMIENTOS  
                             inner JOIN STK_CONCEPTOS on STK_CONCEPTOS.id_stkconcepto = STK_MOVIMIENTOS.stkconcepto_id 
                             where  STK_MOVIMIENTOS.stkarticulo_id = STK_BOM.stkarticulohijo_id  and 
                            	    STK_MOVIMIENTOS.stkdeposito_id = [__stkdeposito_id__] and
                                    STK_MOVIMIENTOS.fecha_movimiento &lt; '[__year_forecast__]-[__mes_forecast__]-01'),0 )
                    </expresion>
                    <tipo>decimal</tipo>
                </field>
                
		<field id="total" local="true" noZero="true" style="font-weight:bold;color:red; font-size:13px;" >
		    <label>Comprar</label>
			# FORMULA:  cantidad a producir * multiplo + stock minimo - stock actual
		    <if exp="( (totpron + 0 ) * (Cantidad + 0 )) + ( stock_minimo + 0 ) - ( stock_actual + 0) &gt; 0">
			<true>( (totpron + 0 ) * (Cantidad + 0 ))  + ( stock_minimo + 0 ) - ( stock_actual + 0)</true>
			<false>0</false>
		    </if>
                    <tipo>numeric</tipo>
		</field>
                <field id="comprado" noZero="true">
            	    <label>Comprado</label>
            	    <helper type="link" xml="cps_movimientos_x_artic2.xml" dir="/compras/qry/">
            		<parameter source="stkarticulohijo_id" target="stkarticulo_id" />
            	    </helper>
            	    <expresion>select sum(cantidad_compra) from CPS_DETALLE where 
            	    CPS_DETALLE.stkarticulo_id = STK_BOM.stkarticulohijo_id and 
            	    month(fecha_requerido) &gt;=  mes_forecast and 
            	    year(fecha_requerido) &gt;= year_forecast</expresion>
            	    <tipo>numeric</tipo>
                </field>
                                           
                <field id="faltaPedir" local="true" noZero="true" 
                style="font-weight:bold;color:green; font-size:13px;" 
                >
            	    <label>Falta</label>
            	    
            	    <if exp="true">
            	    
            		<true>total + 0  - comprado + 0</true>
            		
            		<false>0</false>
            		
            	    </if>
            	    
            	    <tipo>decimal</tipo>
                </field>
		                               
	    </fieldGroup>
	    <field id="color" clasefila="true" local="true" noshow="true">
		<if exp="Cantidad == 0 || stock_actual &lt; 0">
		    <true>'error'</true>
		    <false>''</false>
		</if>
		
	    </field>
	    <group>
	    		<field id="stkarticulo_id" />

		<field id="stkarticulohijo_id" />
	    </group>


        </table>
        <join tipo="left">
            <table id="STK_BOM">
                <field id="stkarticulopadre_id">
                    <condicion operador="=">stkarticulo_id</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="STK_ARTICULOS">
                <field id="id_stkarticulo">
                    <condicion operador="=">stkarticulohijo_id</condicion>
                </field>
            </table>
        </join>
   <!--     <join tipo="left">
            <table id="GEN_UNIDADES">
                <field id="unidad_id">
                    <condicion operador="=">id_unidad</condicion>
                </field>
            </table>
        </join>    -->
    </form>
</histrix>
