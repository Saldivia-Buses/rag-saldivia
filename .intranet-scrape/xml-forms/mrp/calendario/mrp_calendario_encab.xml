    <title>ORDEN DE PRODUCCION</title>
    <obs></obs>
    <form >
        
        <table id="MRP_ORDEN_PRODUCCION" label="ORDEN DE PRODUCCION" >
            <field id="fecha_orden" deshabilitado="true">
                <label size="27" posx="5" posy="+3"  PDFsize="16">Fecha</label>
            </field>

            <field id="id_mrporden" deshabilitado="true">
                <label posx="80" posy="0"  PDFsize="16">Orden Nº</label>
            </field>

            <field id="mrpestado_id">
                <label posx="5" posy="+4" PDFsize="16" >Estado</label>
                <options>
                    <option valor="0">Pendiente</option>
                    <option valor="1">Cumplida</option>
                    <option valor="2">Anulada</option>
                </options>
            </field>
            <field id="rhpersonal_id" >
        	<helper type="combo" xml="rhpersonal_qry.xml" dir="/ayudas" empty="true"/>
                <label posx="80" posy="0" PDFsize="16" >Empleado</label>
                
                <help >Empleado responsable de la Orden de Producción</help>
            </field>
                
            <field id="movimientos" local="true" _obj="mrp_ordendetalle_impresion.xml" obj="mrp_calendario_ordendetalle.xml">
                <label colspan="4" posx="10" posy="+12" PDFsize="10">Detalles...</label>
                <paring destino="mrporden_id">id_mrporden</paring>
            </field>

            <field id="orden_comentarios" deshabilitado="true" pdfancho="20">
                <label  colspan="4" posx="6" posy="+5"   >Comentarios</label>
                <help>Observaciones</help>
                <tipo>varchar</tipo>
                <pdfancho>170</pdfancho>
            </field>
