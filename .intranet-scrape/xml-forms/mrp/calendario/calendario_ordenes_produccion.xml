<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="calendar" _imprime="false" inserta="false" modifica="false" borra="false" calendarAspectRatio="1.4" sidePanel="false" >
    <title>CALENDARIO ORDENES DE PRODUCCION</title>
    <obs></obs>
    <form  _detalle="mrp_calendario_ordendetalle.xml" _inline="true" detalle="mrp_calendario_encab.xml" dir="/compras/calendario">
	        
	<table id="MRP_ORDEN_PRODUCCION" label="Consulta de Ordenes de Producción">
            <filters>
                <field id="mrpestado_id" >
                    <label>Estado </label>
                    <help>Estado Actual</help>
                    <options>
                        <option valor=""></option>
                        <option valor="0">Pendiente</option>
                        <option valor="1">Cumplida</option>
                    </options>
                    <operador>=</operador>
                    <valor>0</valor>
                </field>
            <!--
            <field id="fecha_orden">
                <label>Desde Fecha</label>
                <help>Fecha de Orden de Fabricación</help>
                <operador>&gt;=</operador>
            </field>
            <field id="fecha_orden">
                <label modpos="nobr">Hasta Fecha</label>
                <help>Fecha de Orden de Fabricación</help>
                <operador>&lt;=</operador>
            </field>
	    <field id="producto"  deshabilitado="false" >
		<label>Producto</label>
		<operador>like</operador>
	    </field>                 
        -->
            <field id="rhpersonal_id" >
        	<helper empty="true" type="combo" xml="rhpersonal_qry.xml" dir="/ayudas" />
                <label modpos="nobr" posx="80" posy="0" PDFsize="16" >Empleado</label>
                
                <help >Empleado responsable de la Orden de Producción</help>
                <operador>=</operador>
            </field>

            </filters>

            <field id="fecha_orden" deshabilitado="true" _noshow="true" calendarStartDate="true">
                <label>Fecha</label>
                <help>Fecha de Orden de Fabricación</help>
                <detalle>fecha_orden</detalle>
            </field>

            <field id="fecha_cierre" deshabilitado="true" noshow="true">
                <condicion operador="=">'0000-00-00'</condicion>
            </field>

            <field id="id_mrporden" deshabilitado="true" calendarId="true" _calendarEditable="true" noshow="true">
                <detalle>id_mrporden</detalle>
            </field>

            <field id="numero_orden" deshabilitado="true" >
            	<!--
                <helper xml="ordenproduccion_imp.xml" type="link" modal="true">
            	    <parameter source="id_mrporden"  target="id_mrporden" />
            	</helper>
                -->
                <expression>concat((case when scv_ID = 0 and mrporden_concepto_id != 1 then 'R' 
                                     when scv_ID = 0 and mrporden_concepto_id = 1 then 'A' else '' end), numero_orden)</expression>                                
                <label>Nro</label>
                <help>Numero de Orden de Fabricación</help>
            </field>
        
            <field id="rhpersonal_id" deshabilitado="true">
        	<helper type="combo" xml="rhpersonal_qry.xml" dir="/ayudas" empty="true"/>
                <label posx="80" posy="0" PDFsize="16" >Empleado</label>
                <help >Empleado responsable de la Orden de Producción</help>
            </field>


	       <field id="descripcion" _noshow="true" calendarSubject="true">
		      
		      <expresion>CONCAT((case when scv_ID = 0 and mrporden_concepto_id != 1 then 'R' 
                                     when scv_ID = 0 and mrporden_concepto_id = 1 then 'A' else '' end) ,numero_orden, ' - ', ifnull(RH_PERSONAL.nombre_personal,''), ' ', ifnull(RH_PERSONAL.apellido_personal,''), '-', STK_ARTICULOS.nombre_articulo)</expresion>
              <size>80</size>
	       </field> 

           
            <field id="mrpestado_id" deshabilitado="true">
                    <label>Estado </label>
                    <help>Estado Actual</help>
                    <options>
                        <option valor=""></option>
                        <option valor="0">Pendiente</option>
                        <option valor="1">Cumplida</option>
                    </options>
                    <valor>0</valor>
            </field>

            <field id="estilo" noshow="true" local="true" />

            <field id="color" calendarColor="true" noshow="true">
                <expression>case when sum(ifnull(cantidad,0)) = 0 then '' 
                                 when sum(ifnull(cantidad,0)) &lt; objetivo_ordendetalle then 'orange' 
                                 when sum(ifnull(cantidad,0)) = objetivo_ordendetalle then '#009900' 
                                 end</expression>
            </field>
<!--
            <field id="color" noshow="true" calendarColor="true">
                <attribute id="style">estilo</attribute>
                <expression>(case 
                            when mrpestado_id = 0 then '#FF0000' 
                            when mrpestado_id = 1 then '#006600' 
                            else 'blue' 
                            end)
                </expression>
            </field>
    -->     
            <group>
                <field id="id_mrporden"></field>
            </group>
            
            <order>
                <field id="fecha_orden"></field>
            </order>
        </table>
        
        <join tipo="left">
    	    <table id="MRP_ORDEN_DETALLE">
                <field id="mrporden_id">
            	    <condicion operador="=">MRP_ORDEN_PRODUCCION.id_mrporden</condicion>
                </field>
    	    </table>
        </join>

        <join tipo="left">
            <table id="RH_PERSONAL">
                <field id="id_rhpersonal">
                    <condicion operador="=">MRP_ORDEN_PRODUCCION.rhpersonal_id</condicion>
                </field>
            </table>
        </join>

        <join tipo="inner">
    	    <table id="STK_ARTICULOS">
    		<field id="id_stkarticulo">
    		    <condicion  operador="=">MRP_ORDEN_DETALLE.stkarticulo_id</condicion>
    		</field>
    	    </table>
    	    
        </join>
        <join tipo="left">
            <table id="MRP_DETALLE_REGISTRO">
                <field id="mrpseccion_id">
                    <condicion operador="=">1</condicion>
                </field>

                <field id="mrpordendetalle_id">
                    <condicion operador="=">MRP_ORDEN_DETALLE.id_mrpordendetalle</condicion>
                </field>
            </table>
        </join>                
    </form>
</histrix>
