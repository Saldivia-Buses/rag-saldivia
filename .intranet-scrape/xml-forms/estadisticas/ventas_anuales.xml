		   <grafico id="Ventas" >
			   <ancho>500</ancho>
			   <tipo>BC</tipo>
			   
			   <etiquetas>mes</etiquetas> 
			   <serie>cinco</serie>
			   <serie>seis</serie> 
			   <serie>siete</serie> 
   			   <serie>ocho</serie>
   			   <serie>nueve</serie>   			   
			   
			   
			   <titulo>Ventas</titulo>
			   <subtitulo>comparacion</subtitulo>
		   </grafico>		
		   
	<!--		<campo id="siscod" noselect="true">
				<label>Cod.</label>
				<condicion operador='='>'02'</condicion>
			</campo> 			 
			<campo id="concod" oculto="true" noselect="true">
				<label>comp</label>
				<condicion operador="!=">4</condicion>
			</campo> 		
