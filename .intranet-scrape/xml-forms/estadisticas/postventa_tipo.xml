<?xml version="1.0" encoding="utf-8" ?>
<histrix tipo="chart">
	<title>Tipo</title>
	<obs></obs>
	<form >
		<table id="SERVICE_TURNOS" >
		   <title>Tipo de Servicio</title>
	 
		   <grafico id="Tareas" >
			   <ancho>400</ancho>
			   <tipo>P</tipo>
			   
			   <etiquetas>cargo</etiquetas>  
			   <datos>cantTipo</datos>
			   
			   <title>Cantidad de Tareas</title>
			   <subtitulo>x Tipo de Servicio</subtitulo>
		   </grafico>		
		    <filters>
			    <field id="fecha">
				    <label>Desde</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-12 month')) , 1, date("Y") -  1 ))</valor>
				    <operador>&gt;=</operador>
			    </field>
			    <field id="fecha">
                                    <label>Hasta</label>
				    <valor eval="true">date('d/m/Y', strtotime('-1 second', strtotime(date('Y-m-01'))))</valor>
				    <operador>&lt;=</operador>
			    </field>
		    </filters> 
			<field id="fecha"></field>
			<field id="cargo" tabla="SERVICE_TAREA_UNIDAD">
			    <options>
				<option valor="0">Sin Cargo</option>
				<option valor="1">Con Cargo</option>
				<option valor="2">Con Cargo 3ro</option>
				
				
			    </options>
			</field>
			<field id="cantTipo" tipoOrden="DESC">
			    <expression>count(SERVICE_TAREA_UNIDAD.cargo)</expression>
			</field>
			
			

			<group>
                                <field id="cargo" tabla="SERVICE_TAREA_UNIDAD"></field>
			</group>

			<order>
				<field id="cantTipo"/>
			</order>
		</table>
		<join tipo="INNER">
		    <table id="SERVICE_TAREA_UNIDAD">
			<field id="idTurno">
			    <condicion operador="=">SERVICE_TURNOS.idTurno</condicion>
			</field>
		    </table>
		</join>
	</form>	   
</histrix> 
