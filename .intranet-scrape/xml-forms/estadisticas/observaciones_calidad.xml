<?xml version="1.0" encoding="utf-8" ?>
<histrix tipo="chart">
	<title>Cantidad</title>
	<obs></obs>
	<form>
		<table id="CONTROLCALIDAD" >
		   <title>CANTIDAD DE OBSERVACIONES</title>
		   <grafico id="Internos">
			   <ancho>400</ancho>
			   <tipo>P</tipo>
			   <etiquetas>descripcion</etiquetas>
			   <datos>cantidad</datos>
               <title>Cantidad de Observaciones (retrabajos)</title>
				<subtitulo> x Sección</subtitulo>
		   </grafico>
		   <filters>
			    <field id="fecha">
				    <label>Desde</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-12 month')) , 1, date("Y") -  1 ))</valor>
				    <operador>&gt;=</operador>
			    </field>
			    <field id="fecha">
                    <label>Hasta</label>
<!--				    <valor>today</valor> -->
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-0 month')) , 1, date("Y") ) - 1)</valor>
				    <operador>&lt;=</operador>
			    </field>
			    <field id="nrofab">
                    <label>Coche</label>
				    <operador>=</operador>
			    </field>
		    </filters>
   			<field id="nrofab">
                <label>Coche</label>
				<ayuda_ex id="PEDCOTIZ">
					<field id="nrocha"/>
					<field id="nrocha"/>
				</ayuda_ex>
			</field>
			<field id="fecha"></field>
			
			<field id="idSeccion" noshow="true">
				<condicion operador="!=">0</condicion>
			</field>
			
			<field id="descripcion" tabla="MOMENTO">
				<label>Seccion</label>
			</field>
		
            <field id="observaciones">
				<label>Observacion</label>
<!--				<condicion operador="!=">' '</condicion> -->
            </field>

			<field id="orden" tabla="MOMENTO" noshow="true"/>

			<field id="cantidad" _local="true" tipoOrden="DESC">
				<expression><![CDATA[(SUM(cantObs))]]></expression>
				<label>Observaciones</label>
			</field>
                      
			<group>
                <field id="orden"></field>
			</group>

            <order>
                <field id="cantidad" tipoOrden="DESC"></field>
			</order>

		</table>
		<join tipo="left">
            <table id="MOMENTO">
                <field id="idMomento">
                    <condicion operador="=">CONTROLCALIDAD.idSeccion</condicion>
                </field>
            </table>
        </join>
	</form>
</histrix>
