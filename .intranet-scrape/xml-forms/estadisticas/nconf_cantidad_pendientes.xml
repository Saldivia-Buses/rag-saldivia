<?xml version="1.0" encoding="utf-8" ?>
<histrix tipo="chart">
	<title>Cantidad</title>
	<obs></obs>
	<form >
		<table id="GEN_CALENDAR" >
			<title>Cantidad</title>
	 
		   <grafico id="Cantidad" >
			   <ancho>400</ancho>
			   <tipo>L</tipo>
			   <etiquetas>mes</etiquetas> 
<!--			   <serie>cantidad</serie>
	   		   <serie>cantidad_creadas</serie>-->
			   <serie>cantidad_pendientes</serie><!--
			   <serie>cantidad_cerradas</serie>-->
			   <title>Cantidad de no conformidades Pendientes x Mes</title>
			   <subtitulo></subtitulo>
		   </grafico>		
		    <filters>
			    <field id="fecha">
				    <label>Desde</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-12 month')) , 1, date("Y") -  1 ))</valor>
				    <operador>&gt;=</operador>
			    </field>
			    <field id="fecha">
                                    <label>Hasta</label>
				    <valor eval="true">date('d/m/Y', strtotime('-1 second', strtotime(date('Y-m-01'))))</valor>
				    <operador>&lt;=</operador>
			    </field>
		    </filters> 

			<field id="mes">
				<expression>month(fecha)</expression>
				<label>Mes</label>
				<options>
					<option valor="1">Ene</option>
					<option valor="2">Feb</option>
					<option valor="3">Mar</option>
					<option valor="4">Abr</option>
					<option valor="5">May</option>
					<option valor="6">Jun</option>
					<option valor="7">Jul</option>
					<option valor="8">Ago</option>
					<option valor="9">Sep</option>
					<option valor="10">Oct</option>
					<option valor="11">Nov</option>
					<option valor="12">Dic</option>

				</options>
       				<tipo>varchar</tipo>
			</field>

            <field id="fecha" oculto="true">
				<tipo>date</tipo>
            </field>

            <field id="year" oculto="true">
                <expression>year(fecha)</expression>

            </field><!--
			<field id="cantidad">
                             <expression><![CDATA[(select count(*) from CAL_NOCONFORMIDADES where
                                month(CAL_NOCONFORMIDADES.fecha_nconf) = month(GEN_CALENDAR.fecha) and
                                year(CAL_NOCONFORMIDADES.fecha_nconf) = year(GEN_CALENDAR.fecha))]]></expression>


				<label>Cantidad</label>
                <tipo>numeric</tipo>
			</field>
			<field id="cantidad_creadas">
                             <expression><![CDATA[(select count(*) from CAL_NOCONFORMIDADES where
                                month(CAL_NOCONFORMIDADES.fecha_nconf) = month(GEN_CALENDAR.fecha) and
                                year(CAL_NOCONFORMIDADES.fecha_nconf) = year(GEN_CALENDAR.fecha))]]></expression>
				<label>Creadas</label>
                <tipo>numeric</tipo>
			</field>-->

			<field id="cantidad_pendientes">
                        <expression><![CDATA[(select count(*) from CAL_NOCONFORMIDADES where 
						fecha_nconf < GEN_CALENDAR.fecha and (fecha_cierrenconf > GEN_CALENDAR.fecha or fecha_cierrenconf = '0000-00-00'))]]></expression>
				<label>Pendientes</label>
                <tipo>numeric</tipo>
			</field>
<!--
			<field id="cantidad_cerradas">
                             <expression><![CDATA[(select count(*) from CAL_NOCONFORMIDADES where
                                month(CAL_NOCONFORMIDADES.fecha_cierrenconf) = month(GEN_CALENDAR.fecha) and
                                year(CAL_NOCONFORMIDADES.fecha_cierrenconf) = year(GEN_CALENDAR.fecha))]]></expression>


				<label>Cerradas</label>
                <tipo>numeric</tipo>
			</field>-->

			<group>
                <field id="year"></field>
				<field id="mes"></field>
			</group>
		</table>
		
	</form>	   
</histrix> 
