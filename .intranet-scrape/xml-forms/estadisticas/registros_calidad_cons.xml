<?xml version="1.0" encoding="utf-8" ?>
<histrix tipo="chart">
	<title>Registros de Calidad</title>
	<obs></obs>
	<form >
		<table id="HTXMENU" >
			<title>Registros de Calidad</title>
	 
		   <grafico id="registrosusados" >
			   <ancho>400</ancho>
			   <tipo>L</tipo>
			   <etiquetas>mes</etiquetas>
			   <serie>cantidad</serie>
			   <title>Usos de programas que poseen Registros de Calidad x Mes</title>
			   <subtitulo></subtitulo>
		   </grafico>		<!---->
		    <filters>
			    <field id="fecha">
				    <label>Desde</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-12 month')) , 1, date("Y") -  1 ))</valor>
				    <operador>&gt;=</operador>
			    </field>
			    <field id="fecha">
                    <label>Hasta</label>
				    <valor eval="true">date('d/m/Y', strtotime('-1 second', strtotime(date('Y-m-01'))))</valor>
				    <operador>&lt;=</operador>
			    </field>
		    </filters> 

			<field id="mes">
				<expression>month(GEN_CALENDAR.fecha)</expression>
				<label>Mes</label>
				<options>
					<option valor="1">Ene</option>
					<option valor="2">Feb</option>
					<option valor="3">Mar</option>
					<option valor="4">Abr</option>
					<option valor="5">May</option>
					<option valor="6">Jun</option>
					<option valor="7">Jul</option>
					<option valor="8">Ago</option>
					<option valor="9">Sep</option>
					<option valor="10">Oct</option>
					<option valor="11">Nov</option>
					<option valor="12">Dic</option>

				</options>
       				<tipo>varchar</tipo>
			</field>

            <field id="fecha" oculto="true" tabla="GEN_CALENDAR">
				<tipo>date</tipo>
            </field>

            <field id="year" oculto="true">
                <expression>year(GEN_CALENDAR.fecha)</expression>

            </field>
		
			<field id="cantidad">
                <expression><![CDATA[(CASE WHEN COUNT(HTXLOG.xmlprog) = 0 THEN 0 ELSE  COUNT(HTXLOG.xmlprog) END)]]></expression>
				<label>Cantidad</label>
                <tipo>numeric</tipo>
			</field>


			<group>
				<field id="year"/>
				<field id="mes" />
			</group>
		</table>

        <join tipo="left">
            <table id="HTXLOG">
                <field id="xmlprog">
                    <condicion operador="="><![CDATA[REPLACE(REPLACE(LEFT(HTXMENU.parametros, LOCATE('.xml', HTXMENU.parametros)),'&xml=',''),'.','.xml')]]> </condicion>
                </field>
            </table>
        </join> 
        <join tipo="left">
            <table id="GEN_CALENDAR">
                <field id="fecha">
                    <condicion operador="=">HTXLOG.fecha</condicion>
                </field>
            </table>
        </join> 
	</form>	   
</histrix> 
