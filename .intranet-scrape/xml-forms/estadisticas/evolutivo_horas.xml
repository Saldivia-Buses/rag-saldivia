	<titulo>HORAS</titulo>
	<obs></obs>
	<consulta>
		<tabla id="GEN_CALENDAR" >
			<titulo>Horas</titulo>
		   <grafico id="Horas" >
			   <ancho>400</ancho>
			   <tipo>L</tipo>

			   <etiquetas>mes</etiquetas>
