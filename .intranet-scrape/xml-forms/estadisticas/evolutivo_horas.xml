					<opcion valor="3">Mar</opcion>
					<opcion valor="4">Abr</opcion>
					<opcion valor="5">May</opcion>
					<opcion valor="6">Jun</opcion>
					<opcion valor="7">Jul</opcion>
					<opcion valor="8">Ago</opcion>
					<opcion valor="9">Sep</opcion>
					<opcion valor="10">Oct</opcion>
					<opcion valor="11">Nov</opcion>
					<opcion valor="12">Dic</opcion>
				</opciones>
       				<tipo>varchar</tipo>
			</campo>


