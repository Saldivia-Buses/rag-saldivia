<?xml version="1.0" encoding="utf-8" ?>
<histrix tipo="chart">
	<title>Resultados de encuestas</title>
	<obs></obs>
	<form >
		<table id="GEN_CALENDAR" >
			<title>Resultados de encuestas</title>

			<grafico id="Resultados encuestas" >
				<ancho>400</ancho>
				<tipo>P</tipo>
				<etiquetas>valor</etiquetas> 
				<datos>cantxvalor</datos>
				<title>Resultados obtenidos</title>
				<subtitulo>x Pregunta</subtitulo>
			</grafico>		

			<filters>
				<field id="fecha">
					<label>Desde</label>
					<valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-12 month')) , 1, date("Y") -  1 ))</valor>
					<operador>&gt;=</operador>
				</field>
				<field id="fecha">
					<label>Hasta</label>
					<valor eval="true">date('d/m/Y', strtotime('-1 second', strtotime(date('Y-m-01'))))</valor>
					<operador>&lt;=</operador>
				</field>
				<field id="idPregunta">
					<label>Pregunta</label>
					<operador>=</operador>
				</field>
  			</filters>

			<field id="mes" oculto="true">
				<expression>month(GEN_CALENDAR.fecha)</expression>
				<label>Mes</label>
				<options>
					<option valor="1">Ene</option>
					<option valor="2">Feb</option>
					<option valor="3">Mar</option>
					<option valor="4">Abr</option>
					<option valor="5">May</option>
					<option valor="6">Jun</option>
					<option valor="7">Jul</option>
					<option valor="8">Ago</option>
					<option valor="9">Sep</option>
					<option valor="10">Oct</option>
					<option valor="11">Nov</option>
					<option valor="12">Dic</option>
				</options>
				<tipo>varchar</tipo>
			</field>

			<field id="fecha" oculto="true">
				<condicion operador="&gt;="> DATE_FORMAT(date_sub(date(now()) , interval 1 year) ,'%Y-%m-01') and GEN_CALENDAR.fecha &lt;= now()</condicion>
				<tipo>date</tipo>
			</field>
			
			<field id="year" oculto="true">
				<expression>year(GEN_CALENDAR.fecha)</expression>
			</field>

			<field id="idPregunta" tabla="ENCUESTA_CLIENTE_ITEM">
				<helper type="combo" id="ENCUESTA_PREGUNTA" empty="true">
					<field id="idPregunta"/>
					<field id="pregunta"/>
				</helper>
				<label>Pregunta</label>

			</field>

			<field id="valor" tabla="ENCUESTA_CLIENTE_ITEM" tipoOrden="DESC">
				<options>
					<option valor="5">Excelente</option>
					<option valor="4">Muy Bueno</option>
					<option valor="3">Bueno</option>
					<option valor="2">Regular</option>
					<option valor="1">Malo</option>  
					<option valor="0">Ns/Nc</option>     
				</options>
				<condicion operador="IS NOT">NULL</condicion>
			</field>

			<field id="cantxvalor">
				<expression>COUNT(*)</expression>
			</field>

			<group>
				<field id="valor" tabla="ENCUESTA_CLIENTE_ITEM"/>
			</group>
			<order>
				<field id="valor" tabla="ENCUESTA_CLIENTE_ITEM"/>
			</order>
		
		</table>
	
		<join tipo="left">
			<table id="ENCUESTA_CLIENTE">
				<field id="fecha">
					<condicion operador="=">GEN_CALENDAR.fecha</condicion>
				</field>
			</table>
		</join>
		<join tipo="left">
			<table id="ENCUESTA_CLIENTE_ITEM">
				<field id="numero">
					<condicion operador="=">ENCUESTA_CLIENTE.numero</condicion>
				</field>
			</table>
		</join>
	</form>	   
</histrix> 
