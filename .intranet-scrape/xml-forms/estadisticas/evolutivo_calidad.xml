<?xml version="1.0" encoding="utf-8" ?>
<abm tipo="chart">
	<titulo>Cantidad</titulo>
	<obs></obs>
	<consulta>
		<tabla id="CONTROLCALIDAD" >
		    <title>OBSERVACIONES POR UNIDAD</title>
		   <grafico id="internos" >
			   <ancho>400</ancho>
			   <tipo>L</tipo>
                           <titulo>Cantidad de Observaciones</titulo>
			   <etiquetas>mes</etiquetas>
			   <serie>cantidad</serie>
			   <subtitulo></subtitulo>
		   </grafico>
		    <filtros>
			    <field id="fecha">
				    <label>Desde</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-12 month')) , 1, date("Y") -  1 ))</valor>
				    <operador>&gt;=</operador>
			    </field>
			    <field id="fecha">
                                    <label>Hasta</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-0 month')) , 1, date("Y") ) - 1)</valor>
				    
				    <operador>&lt;=</operador>
			    </field>
<!--                        <field id="idSeccion" >
                    	    <label>Seccion</label>
                    	    <operador>=</operador>
                        </field>                  -->
			    
		    </filtros>
       			<field id="nrofab">
                                    <label>Coche</label>
		       </field>
                    <field id="year" oculto="true">
                        <expresion>year(fecha)</expresion>
                    </field>

			<field id="fecha"></field>
			<field id="mes">
				<expresion>month(fecha)</expresion>
				<label>Mes</label>
				<opciones>
					<opcion valor="1">Ene</opcion>
					<opcion valor="2">Feb</opcion>
					<opcion valor="3">Mar</opcion>
					<opcion valor="4">Abr</opcion>
					<opcion valor="5">May</opcion>
					<opcion valor="6">Jun</opcion>
					<opcion valor="7">Jul</opcion>
					<opcion valor="8">Ago</opcion>
					<opcion valor="9">Sep</opcion>
					<opcion valor="10">Oct</opcion>
					<opcion valor="11">Nov</opcion>
					<opcion valor="12">Dic</opcion>

				</opciones>
       				<tipo>varchar</tipo>
			</field>

			
                        <field id="idSeccion" >
<!--                    	    <helper type="combo" xml="momento.xml" /> -->
                        </field>
<!--                         <field id="observaciones">
                              <label>Observacion</label>
				<condicion operador="!=">' '</condicion>
                        </field> -->
			<field id="cantidad" local="true" tipoOrden="DESC">

                                <expresion><![CDATA[(SELECT ROUND((SUM(CONTROLCALIDAD.cantObs)/ COUNT(*)),1) FROM PEDCOTIZ  where MONTH(terminacion) = MONTH(fecha) and YEAR(terminacion) = YEAR(fecha))]]></expresion>
			       <!--<expresion><![CDATA[(SUM(cantObs))]]></expresion>-->
				<label>Observaciones</label>

			</field>
			<group>
                                <field id="year"></field>
				<field id="mes"></field>

			</group>

                        <orden>
                                <field id="fecha"></field>
			</orden>

		</tabla>


	</consulta>
</abm>
