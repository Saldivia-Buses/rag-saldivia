<?xml version="1.0" encoding="ISO-8859-1" ?>
<histrix tipo="chart">
        <title>Cursos</title>
        <obs></obs>
        <form >

                <table id="GEN_CALENDAR" >

		   <grafico id="Cantidad" >
			   <ancho>400</ancho>
			   <tipo>C</tipo>
			   <etiquetas>mes</etiquetas> 
			   <serie>cantidad</serie>
			   <title>Cursos realizados</title>
			   <subtitulo></subtitulo>
		   </grafico>		

                    <title>Cursos</title>
		    <filters>
			    <field id="fecha">
				    <label>Desde</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-12 month')) , 1, date("Y") -  1 ))</valor>
				    <operador>&gt;=</operador>
			    </field>
			    <field id="fecha">
                                    <label>Hasta</label>
				    <valor eval="true">date('d/m/Y', strtotime('-1 second', strtotime(date('Y-m-01'))))</valor>
				    <operador>&lt;=</operador>
			    </field>
		    </filters> 

			<field id="mes">
				<expresion>month(fecha)</expresion>
				<label>Mes</label>
				<options>
					<option valor="1">Ene</option>
					<option valor="2">Feb</option>
					<option valor="3">Mar</option>
					<option valor="4">Abr</option>
					<option valor="5">May</option>
					<option valor="6">Jun</option>
					<option valor="7">Jul</option>
					<option valor="8">Ago</option>
					<option valor="9">Sep</option>
					<option valor="10">Oct</option>
					<option valor="11">Nov</option>
					<option valor="12">Dic</option>

				</options>
       				<tipo>varchar</tipo>
			</field>

            <field id="fecha" oculto="true">
				<tipo>date</tipo>
            </field>

            <field id="year" oculto="true">
                <expresion>year(fecha)</expresion>

            </field>
			<field id="cantidad">
                             <expresion><![CDATA[(select count(*) from RH_CURSOS where
                                month(RH_CURSOS.inicio) = month(GEN_CALENDAR.fecha) and
                                year(RH_CURSOS.inicio) = year(GEN_CALENDAR.fecha))]]></expresion>


				<label>Cantidad</label>
                                <tipo>numeric</tipo>
			</field>
			<group>
                                <field id="year"></field>
				<field id="mes"></field>

			</group>
                                        
		</table>                
        </form>           
</histrix>
