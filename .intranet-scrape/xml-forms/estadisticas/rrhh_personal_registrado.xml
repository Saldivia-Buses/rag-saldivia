<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="chart">
	<title>ESTADISTICAS DE ACCIDENTES</title>
	<obs></obs>
	<form>
		<table id="GEN_CALENDAR" label="ESTAD ACCIDENTES">

			<grafico id="Personal">
				<ancho>400</ancho>
				<tipo>L</tipo>
				<etiquetas>mes</etiquetas>
				<serie>personal</serie>
				<title>Personal Registrado x Mes</title>
			</grafico>

			<filters>
				<field id="fecha">
					<label>Desde</label>
					<valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-12 month')) , 1, date("Y") -  1 ))</valor>
					<operador>&gt;=</operador>
				</field>
				<field id="fecha">
					<label>Hasta</label>
					<valor eval="true">date('d/m/Y', strtotime('-1 second', strtotime(date('Y-m-01'))))</valor>
					<operador>&lt;=</operador>
				</field>
			</filters>

			<field id="mes">
				<expression>month(GEN_CALENDAR.fecha)</expression>
				<label>Mes</label>
				<options>
					<option valor="1">Ene</option>
					<option valor="2">Feb</option>
					<option valor="3">Mar</option>
					<option valor="4">Abr</option>
					<option valor="5">May</option>
					<option valor="6">Jun</option>
					<option valor="7">Jul</option>
					<option valor="8">Ago</option>
					<option valor="9">Sep</option>
					<option valor="10">Oct</option>
					<option valor="11">Nov</option>
					<option valor="12">Dic</option>
				</options>
				<tipo>varchar</tipo>
			</field>

			<field id="fecha" oculto="true">
				<tipo>date</tipo>
			</field>

			<field id="year" oculto="true">
				<expression>year(GEN_CALENDAR.fecha)</expression>
			</field>

			<field id="personal">
				<expression sql="true">SELECT SUM(cant_personal) FROM (SELECT 1 AS cant_personal FROM PERSONAL P
											JOIN GEN_CALENDAR GC ON GC.fecha &gt;= P.fecing
													    AND GC.fecha &lt;= (CASE WHEN P.fechaEgreso = '0000-00-00' THEN CURDATE() ELSE P.fechaEgreso END)
											WHERE MONTH(GC.fecha) = '[__mes__]'
											  AND YEAR(GC.fecha) = '[__year__]'
											GROUP BY P.idPersona
											HAVING COUNT(*) &gt;= 15) cant_personas_mensual</expression>
				<label>Personal</label>
				<tipo>integer</tipo>
			</field>

	 		<group>
				<field id="year"></field>
				<field id="mes"></field>
			</group>

		</table>

	</form>
</histrix>