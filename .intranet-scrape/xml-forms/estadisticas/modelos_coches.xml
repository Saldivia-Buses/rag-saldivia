<?xml version="1.0" encoding="utf-8" ?>       
<histrix tipo="chart">
	<title>Modelos</title>
	<obs></obs>
	<form >
		<table id="GEN_CALENDAR" >
			<title>Modelos Fabricados</title>
	 
		   <grafico id="Ventas" >
			   <ancho>400</ancho>
			   <tipo>P</tipo>
			   
			   <etiquetas>modelos</etiquetas> 
			   <datos>coches</datos>
			   <serie>coches</serie>
			   <title>Distribución de Modelos</title>
			   <subtitulo>x Fecha</subtitulo>
		   </grafico>		
		    <filters>
			    <field id="fecha">
				    <label>Desde</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-12 month')) , 1, date("Y") -  1 ))</valor>
				    <operador>&gt;=</operador>
			    </field>
			    <field id="fecha">
                                    <label modpos="nobr">Hasta</label>
				    <valor eval="true">date('d/m/Y', strtotime('-1 second', strtotime(date('Y-m-01'))))</valor>
				    <operador>&lt;=</operador>
			    </field>
		    </filters> 

			<field id="mes">
				<expression>month(fecha)</expression>
				<label>Mes</label>
				<options>
					<option valor="1">Ene</option>
					<option valor="2">Feb</option>
					<option valor="3">Mar</option>
					<option valor="4">Abr</option>
					<option valor="5">May</option>
					<option valor="6">Jun</option>
					<option valor="7">Jul</option>
					<option valor="8">Ago</option>
					<option valor="9">Sep</option>
					<option valor="10">Oct</option>
					<option valor="11">Nov</option>
					<option valor="12">Dic</option>

				</options>
       				<tipo>varchar</tipo>
			</field>
                    <field id="fecha" oculto="true">
<!--                        <condicion operador="&gt;="> DATE_FORMAT(date_sub(date(now()) , interval 1 year) ,'%Y-%m-01') and GEN_CALENDAR.fecha &lt;= now()</condicion> -->
			<tipo>date</tipo>
                    </field>
                    <field id="year" oculto="true">
                        <expression>year(fecha)</expression>

                    </field>

			<field id="modelos" >
			    <expression>modcar</expression>
				<label>Modelo</label>
			</field>

			<field id="coches" tipoOrden="DESC">
			    <expression>count(*)</expression>
				<label>Coches</label>
                                <tipo>numeric</tipo>
			</field>
			<group>
<!--                                <field id="year"></field>
				<field id="mes"></field> -->
				<field id="nrocar" tabla="PEDCOTIZ"></field>

			</group>

			<order>
				<field id="coches"/>
			</order>
		</table>
		<join tipo="left">
		    <table id="PEDCOTIZ">
			<field id="terminacion">
			    <condicion operador="=">fecha</condicion>
			</field>
		    </table>
		</join>
		
		<join tipo="inner">
		    <table id="CARROCERIA">
			<field id="nrocar">
			    <condicion operador="=">PEDCOTIZ.nrocar</condicion>
			</field>
		    </table>
		</join>
	</form>	   
</histrix> 
