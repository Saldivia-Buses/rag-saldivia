<?xml version="1.0" encoding="utf-8" ?>
<histrix tipo="chart">
	<title>Cantidad</title>
	<obs></obs>
	<form >
		<table id="SERVICE_TURNOS" >
		   <title>Tareas</title>
	 
		   <grafico id="Tareas" >
			   <ancho>400</ancho>
			   <tipo>P</tipo>
			   
			   <etiquetas>nomTarea</etiquetas>  
			   <datos>cantTarea</datos>
			   
			   <title>Cantidad de Tareas Con Cargo</title>
			   <subtitulo>x Tipo de Tarea</subtitulo>
		   </grafico>		
		    <filters>
			    <field id="fecha">
				    <label>Desde</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-12 month')) , 1, date("Y") -  1 ))</valor>
				    <operador>&gt;=</operador>
			    </field>
			    <field id="fecha">
                                    <label>Hasta</label>
				    <valor eval="true">date('d/m/Y', strtotime('-1 second', strtotime(date('Y-m-01'))))</valor>
				    <operador>&lt;=</operador>
			    </field>
		    </filters> 
			<field id="fecha"></field>
			<field id="idTarea" tabla="SERVICE_TAREA_UNIDAD">
			    <condicion operador="!=">0</condicion>

			</field>
			 <field id="cargo" tabla="SERVICE_TAREA_UNIDAD">			
			    <condicion operador="=">1</condicion>
			    
			 </field>
			<field id="cantTarea" tipoOrden="DESC">
			    <expression>count(SERVICE_TAREA_UNIDAD.idTarea)</expression>
			    <condicion operador="&gt;">2</condicion>
			</field>
			
			
			<field id="nomTarea" tabla="SERVICE_TAREAS"></field>

			<group>
                                <field id="idTarea" tabla="SERVICE_TAREA_UNIDAD"></field>
			</group>
			<order>
				<field id="cantTarea" />
			    
			</order>
		</table>
		<join tipo="INNER">
		    <table id="SERVICE_TAREA_UNIDAD">
			<field id="idTurno">
			    <condicion operador="=">SERVICE_TURNOS.idTurno</condicion>
			</field>
		    </table>
		</join>
		<join tipo="LEFT">
		    <table id="SERVICE_TAREAS">
			<field id="idTarea">
			    <condicion operador="=">SERVICE_TAREA_UNIDAD.idTarea</condicion>
			</field>
		    </table>
		</join>
		
	</form>	   
</histrix> 
