<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="chart">
	<title>Cantidad de horas de cursos</title>
	<obs></obs>
	<form >
		<table id="GEN_CALENDAR" label="Cursos por mes">
		   <grafico id="Cursos" >
			   <ancho>400</ancho>
			   <tipo>P</tipo>

			   <etiquetas>nombre</etiquetas>
			   <datos>horas</datos>
			   <title>Cantidad de Horas de Cursado</title>
			   <subtitulo>x Sección</subtitulo>
		   </grafico>		
		    <filters>
			    <field id="fecha">
				    <label>Desde</label>
				    <valor eval="true">date("01/01/Y")</valor>
				    <operador>&gt;=</operador>
			    </field>
			    <field id="fecha">
                    <label>Hasta</label>
				    <valor eval="true">date("31/12/Y")</valor>
				    <operador>&lt;=</operador>
			    </field>
		    </filters> 


			<field id="fecha" oculto="true">
				<tipo>date</tipo>
            </field>

<!--
			<field id="cursos">
				<label>Cantidad de Cursos</label>
				<expression ><![CDATA[ (SELECT COUNT(*) FROM RH_CURSOS WHERE month(inicio) = month(fecha) AND  year(inicio) = year(fecha)) ]]></expression>
			</field>-->

			<field id="horas" tipoOrden="DESC">
				<label>Carga Horaria</label>
                <expression >IFNULL(SUM(RH_CURSOS.edicion), 0) </expression>
			</field>

			<field id="id_seccion" tabla="SECCION" />

			<field id="nombre" tabla="SECCION" />

	 		<group>
				<field id="id_seccion"></field>
			</group>

			<order>
				<field id="horas"/>
			</order>

		</table>
		<join tipo="left">
			<table id="RH_CURSOS">
				<field id="fin">
					<condicion operador="=">GEN_CALENDAR.fecha</condicion>
				</field>
			</table>
		</join>
		<join tipo="left">
			<table id="RH_CURSO_SECCIONES">
				<field id="curso_id">
					<condicion operador="=">RH_CURSOS.id_curso</condicion>
				</field>
			</table>
		</join>
		<join tipo="inner">
			<table id="SECCION">
				<field id="id_seccion">
					<condicion operador="=">RH_CURSO_SECCIONES.rhseccion_id</condicion>
				</field>
			</table>
		</join>
	</form>
</histrix>
