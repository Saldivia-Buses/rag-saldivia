<?xml version="1.0" encoding="utf-8" ?>
<histrix tipo="chart">
	<titulo>VENTAS ANUALES</titulo>
	<obs></obs>
	<form>
		<table id="GEN_CALENDAR" >
			<titulo>Ventas Anuales</titulo>

	 
		   <grafico id="Ventas" >
			   <ancho>400</ancho>
			   <tipo>L</tipo>
			   
			   <etiquetas>mes</etiquetas> 
			   <serie>ventas</serie>
			   
			   <titulo>Evolución de Ventas</titulo>
			   <subtitulo></subtitulo>
		   </grafico>		
		    <filtros>
			    <field id="fecha">
				    <label>Desde</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-12 month')) , 1, date("Y") -  1 ))</valor>
				    <operador>&gt;=</operador>
			    </field>
			    <field id="fecha">
                                    <label>Hasta</label>
				    <valor eval="true">date('d/m/Y', strtotime('-1 second', strtotime(date('Y-m-01'))))</valor>
				    <operador>&lt;=</operador>
			    </field>
		    </filtros>
			<field id="mes">
				<expresion>month(fecha)</expresion>
				<label>Mes</label>
				<opciones>
					<opcion valor="1">Ene</opcion>
					<opcion valor="2">Feb</opcion>
					<opcion valor="3">Mar</opcion>
					<opcion valor="4">Abr</opcion>
					<opcion valor="5">May</opcion>
					<opcion valor="6">Jun</opcion>
					<opcion valor="7">Jul</opcion>
					<opcion valor="8">Ago</opcion>
					<opcion valor="9">Sep</opcion>
					<opcion valor="10">Oct</opcion>
					<opcion valor="11">Nov</opcion>
					<opcion valor="12">Dic</opcion>

				</opciones>
       				<tipo>varchar</tipo>
			</field>
                    <field id="fecha" oculto="true">
                <!--        <condicion operador="&gt;="> DATE_FORMAT(date_sub(date(now()) , interval 1 year) ,'%Y-%m-01') and GEN_CALENDAR.fecha &lt;= now()</condicion> -->

        <!--                 <condicion operador="&gt;="> date_sub(date(now()) , interval 1 year) and GEN_CALENDAR.fecha &lt;= now()</condicion> -->
                    </field>
                    <field id="year" oculto="true">
                        <expresion>year(fecha)</expresion>

                    </field>
			<field id="ventas">
				<expression>sum(impgra * (case when conimp = 1 then 1 else -1 end))</expression>
<!--
				<expresion>(select sum(impgra * (case when conimp = 1 then 1 else -1 end)) from IVACOMPRAS
				join IVAIMPORTES on ivacv_id = id_ivacompra and tipoiva = 1
                                left join CCTCONCE on CCTCONCE.concod = IVACOMPRAS.codcom and CCTCONCE.siscod = '01'
                                where month(IVACOMPRAS.feciva) = month(GEN_CALENDAR.fecha) and
                                year(IVACOMPRAS.feciva) = year(GEN_CALENDAR.fecha)) </expresion> -->
				<label>Ventas</label>
                                <tipo>numeric</tipo>
			</field>
			<group>
                                <field id="year"></field>
				<field id="mes"></field>

			</group>
		</table>
		<join tipo="left">
		    <table id="IVAVENTAS">
			<field id="feciva">
			    <condicion operador="=">fecha</condicion>
			</field>
		    </table>
		</join>
		<join >
		    <table id="CCTCONCE">
			<field id="concod">
			    <condicion operador="=">codcom</condicion>
			</field>
		    </table>
		</join>
		<join tipo="left">
		    <table id="IVAIMPORTES">
			<field id="ivacv_id">
			    <condicion operador="=">id_ivaventa</condicion>
			</field>
			<field id="tipoiva">
			    <condicion operador="=">2</condicion>
			</field>
		    </table>
		</join>		
	</form>	   
</histrix> 
