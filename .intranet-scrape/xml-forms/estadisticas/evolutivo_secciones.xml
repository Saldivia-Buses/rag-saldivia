<?xml version="1.0" encoding="utf-8" ?>
<histrix tipo="chart">
	<title>Cantidad</title>
	<obs></obs>
	<form >
		<table id="CONTROLCALIDAD" >
		    <title>OBSERVACIONES POR UNIDAD</title>
		   <grafico id="calidad" >
			    <options><![CDATA[ ['plotOptions' => ['line' => ['dataLabels' => ['enabled' => true]]]] ]]></options>
			   <ancho>400</ancho>
			   <tipo>L</tipo>
               <title>Cantidad de Observaciones (retrabajos) promedio x Mes</title>
			   <etiquetas>mes</etiquetas>
			   <serie>cantidad</serie>
			   <subtitulo></subtitulo>
		   </grafico>
		    <filters>
			    <field id="fecha">
				    <label>Desde</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-12 month')) , 1, date("Y") -  1 ))</valor>
				    <operador>&gt;=</operador>
			    </field>
			    <field id="fecha">
                                    <label>Hasta</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-0 month')) , 1, date("Y") ) - 1)</valor>
				    
				    <operador>&lt;=</operador>
			    </field>
<!--                        <field id="idSeccion" >
                    	    <label>Seccion</label>
                    	    <operador>=</operador>
                        </field>                  -->
			    
		    </filters>
       			<field id="nrofab">
                                    <label>Coche</label>
		       </field>
                    <field id="year" oculto="true">
                        <expression>year(fecha)</expression>
                    </field>

			<field id="fecha"></field>
			<field id="mes">
				<expression>month(fecha)</expression>
				<label>Mes</label>
				<options>
					<option valor="1">Ene</option>
					<option valor="2">Feb</option>
					<option valor="3">Mar</option>
					<option valor="4">Abr</option>
					<option valor="5">May</option>
					<option valor="6">Jun</option>
					<option valor="7">Jul</option>
					<option valor="8">Ago</option>
					<option valor="9">Sep</option>
					<option valor="10">Oct</option>
					<option valor="11">Nov</option>
					<option valor="12">Dic</option>
				</options>
       				<tipo>varchar</tipo>
			</field>

			
                        <!--<field id="idSeccion"/>-->
			<field id="cantidad" local="true" tipoOrden="DESC">
				 <expression><![CDATA[(SELECT ROUND((SUM(CONTROLCALIDAD.cantObs)/ COUNT(*)),1) FROM PEDCOTIZ  where MONTH(terminacion) = MONTH(fecha) and YEAR(terminacion) = YEAR(fecha))]]></expression>
			   <!--    <expression><![CDATA[(SUM(cantObs))]]></expression>-->
				<label>Observaciones</label>
				<tipo>numeric</tipo>

			</field>
			<group>
                                <field id="year"></field>
				<field id="mes"></field>

			</group>

                        <order>
                                <field id="fecha"></field>
			</order>

		</table>


	</form>
</histrix>
