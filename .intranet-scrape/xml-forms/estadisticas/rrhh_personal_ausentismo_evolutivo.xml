			<field id="porcentaje_faltas_gral" noZero="true">
				<label>Hs.Restantes Gral</label>
				<expression sql="true">select (('[__proyeccion_gral__]' + 0) - ('[__trabajadas_gral__]' + 0))</expression>
				<tipo>decimal</tipo>
			</field>

			<field id="porcentaje_ausentismo_gral" noZero="true">
				<label colstyle="font-size:14px;">% Gral</label>
				<expression sql="true">select ROUND(((('[__proyeccion_gral__]' + 0) - ('[__trabajadas_gral__]' + 0) - ('[__licencias_no_imputables_gral__]' + 0)) / ('[__proyeccion_gral__]' + 0)) * 100, 2)</expression>
