<?xml version="1.0" encoding="ISO-8859-1"?>
<histrix tipo="consulta">
	<title>Ausentismo Personal Evolutivo</title>
	<obs></obs>
	<form>
		<table id="PERSONAL" label="Ausentismo Personal Evolutivo">

			<grafico id="Por">
				<ancho>400</ancho>
				<tipo>L</tipo>
				<title>Ausentismo Personal Evolutivo</title>
				<etiquetas>mes</etiquetas>
				<serie>porcentaje_ausentismo</serie>
<!-- 				<serie>porcentaje_ausentismo_gral</serie>
 -->			</grafico>

			<filters>
				<field id="desdefecha">
					<operador>&gt;=</operador>
					<label>Desde Fecha</label>
					<valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m", strtotime('-1 month')), 1, date("Y") -  1))</valor>
				</field>
				<field id="hastafecha">
					<operador>&lt;=</operador>
					<label modpos="nobr">Hasta Fecha</label>
					<valor eval="true">date("d/m/Y", mktime(0, 0, 0, date("m"), date("d")-1, date("Y")))</valor>
				</field>
			</filters>

			<field id="IdPersona" noshow="true" />

			<field id="mes" noshow="true">
				<expression>MONTH(GEN_CALENDAR.fecha)</expression>
				<label>Mes</label>
				<options>
					<option valor="1">Ene</option>
					<option valor="2">Feb</option>
					<option valor="3">Mar</option>
					<option valor="4">Abr</option>
					<option valor="5">May</option>
					<option valor="6">Jun</option>
					<option valor="7">Jul</option>
					<option valor="8">Ago</option>
					<option valor="9">Sep</option>
					<option valor="10">Oct</option>
					<option valor="11">Nov</option>
					<option valor="12">Dic</option>
				</options>
				<tipo>varchar</tipo>
			</field>

			<field id="year" noshow="true">
				<expression>YEAR(GEN_CALENDAR.fecha)</expression>
			</field>

			<field id="id_seccion" noshow="true">
				<label>Seccion</label>
				<helper type="combo" id="SECCION" empty="true">
					<field id="id_seccion" />
					<field id="nombre" />
					<order>
						<field id="nombre" />
					</order>
				</helper>
			</field>

			<!--<field id="cant" suma="true">
				<label>Cant.Personal</label>
				<expression>count(*)</expression>
			</field>-->

			<field id="cant">
				<expression sql="true">SELECT SUM(cant_personal) FROM (SELECT 1 AS cant_personal FROM PERSONAL P
											JOIN GEN_CALENDAR GC ON GC.fecha &gt;= P.fecing
													    AND GC.fecha &lt;= (CASE WHEN P.fechaEgreso = '0000-00-00' THEN CURDATE() ELSE P.fechaEgreso END)
											WHERE MONTH(GC.fecha) = '[__mes__]'
											  AND YEAR(GC.fecha) = '[__year__]'
											GROUP BY P.idPersona
											HAVING COUNT(*) &gt;= 15) cant_personas_mensual</expression>
				<label>Personal</label>
				<tipo>integer</tipo>
			</field>

			<field id="fechaEgreso" noshow="true">
				<label>Baja</label>
				<condicion operador="=">'0000-00-00' OR (PERSONAL.fechaEgreso &gt;= STR_TO_DATE('[__desdefecha__]', '%d/%m/%Y'))</condicion>
			</field>

			<field id="fecing" noshow="true">
				<label>Alta</label>
				<condicion operador="&lt;=">STR_TO_DATE('[__hastafecha__]', '%d/%m/%Y')</condicion>
			</field>

			<field id="desdefecha" local="true" noshow="true">
				<label>Desde Fecha</label>
				<tipo>date</tipo>
			</field>

			<field id="hastafecha" local="true" noshow="true">
				<label>Hasta Fecha</label>
				<tipo>date</tipo>
			</field>

			<field id="trabajadas" _noshow="true" suma="true">
				<label>Horas</label>
				<expression sql="true"><![CDATA[SELECT 
                    (concat(CAST(FLOOR((sum(FF.minutos)/3600)) as char),':', 
                      LPAD(CAST(FLOOR((sum(FF.minutos)%3600)/60)AS CHAR),2,'0'),':', 
                      LPAD(CAST((sum(FF.minutos)%60) AS CHAR),2,'0')) + 0)
                    from 
                    (select F1.fecha,
				               
				@egr:= (SELECT H.egreso from HORARIOHIST as H  where H.desdeFecha <= F1.fecha and H.dia = DAYOFWEEK(F1.fecha) order by H.desdeFecha DESC limit 1) as "egr",
				@ing:= (SELECT H.ingreso from HORARIOHIST as H where H.desdeFecha <= F1.fecha and H.dia = DAYOFWEEK(F1.fecha) order by H.desdeFecha DESC limit 1) as "ing",

				@h1:= (select H1.hora from FICHADAS as H1 left join FERIADOS ON FERIADOS.idFeriado = H1.fecha where H1.tarjeta = (SELECT TJT.tarjeta from PERSONAL_TARJETA as TJT where TJT.idPersona = PERSONAL.idPersona  and TJT.fechaDesde <= F1.fecha order by fechaDesde DESC limit 1) and H1.fecha = F1.fecha and H1.borrado = 0 order by H1.hora  limit 0, 1) as "h1",
				@h2:= (select H1.hora from FICHADAS as H1 left join FERIADOS ON FERIADOS.idFeriado = H1.fecha where H1.tarjeta = (SELECT TJT.tarjeta from PERSONAL_TARJETA as TJT where TJT.idPersona = PERSONAL.idPersona  and TJT.fechaDesde <= F1.fecha order by fechaDesde DESC limit 1) and H1.fecha = F1.fecha and H1.borrado = 0 order by H1.hora  limit 1, 1) as "h2",
				@h3:= (select H1.hora from FICHADAS as H1 left join FERIADOS ON FERIADOS.idFeriado = H1.fecha where H1.tarjeta = (SELECT TJT.tarjeta from PERSONAL_TARJETA as TJT where TJT.idPersona = PERSONAL.idPersona  and TJT.fechaDesde <= F1.fecha order by fechaDesde DESC limit 1) and H1.fecha = F1.fecha and H1.borrado = 0 order by H1.hora  limit 2, 1) as "h3",
				@h4:= (select H1.hora from FICHADAS as H1 left join FERIADOS ON FERIADOS.idFeriado = H1.fecha where H1.tarjeta = (SELECT TJT.tarjeta from PERSONAL_TARJETA as TJT where TJT.idPersona = PERSONAL.idPersona  and TJT.fechaDesde <= F1.fecha order by fechaDesde DESC limit 1) and H1.fecha = F1.fecha and H1.borrado = 0 order by H1.hora  limit 3, 1) as "h4",

				ifnull( time_to_sec( timediff( case when @h2 > @egr then @egr else @h2 end , case when @h1 < @ing then @ing else @h1 end )), 0)
				+
				ifnull( time_to_sec( timediff( case when @h4 > @egr then @egr else @h4 end , case when @h4 < @ing then @ing else @h3 end )), 0)

				as "minutos"

                    from 
             GEN_CALENDAR as F1 
             left join PERSONAL on PERSONAL.fechaEgreso = '0000-00-00' 
			 left join SECCION S on PERSONAL.id_seccion = S.id_seccion             
             left join FERIADOS ON FERIADOS.idFeriado = F1.fecha
        where
                          MONTH(F1.fecha)  = '[__mes__]' and
                          YEAR(F1.fecha) = '[__year__]' and
                          S.seccion_productiva = 0 and
                      	  PERSONAL.marcaTarjeta = 1 and
        isnUll(FERIADOS.idFeriado)) as FF ]]>
                </expression>
            </field>
     
       <field id="licencias_no_imputables" local="true" noZero="true">
            <expression sql="true"><![CDATA[select SUM((SELECT (HORARIOHIST.egreso - HORARIOHIST.ingreso) 
							FROM HORARIOHIST 
							WHERE HORARIOHIST.dia = DAYOFWEEK(CALENDAR.fecha) 
							ORDER BY HORARIOHIST.desdeFecha DESC LIMIT 1)) 
					    from FRANCOS_PER F
                			join PERSONAL P on F.IdPersona = P.IdPersona and P.fechaEgreso = "0000-00-00"
							join SECCION S on P.id_seccion = S.id_seccion             
                            join CALENDAR ON CALENDAR.fecha >= F.fechainicio and CALENDAR.fecha <= (case 	when F.fechafin = '0000-00-00' then '[__hastafecha__]' else F.fechafin end)
                            join FRANCOS_CAT FC on FC.idfranco = F.idfranco and FC.tipo = F.tipo
                            where 
                            	  FC.descuenta_grupo = 1 and
                                  MONTH(CALENDAR.fecha) = '[__mes__]' and 
                                  YEAR(CALENDAR.fecha) = '[__year__]' and
                                  dayofweek(CALENDAR.fecha) NOT IN (1,7) and
		                          S.seccion_productiva = 0 and
		                      	  P.marcaTarjeta = 1 and
                                  CALENDAR.fecha NOT IN (select idFeriado from FERIADOS)]]></expression>
        <label>No.Imp</label>
        <tipo>decimal</tipo>
        </field> 

            <field id="proyeccion" suma="true">
                <label>Proyeccion</label>
                <expression sql="true"><![CDATA[

                    select
                    (concat(CAST(FLOOR((sum(FF.minutos)/3600)) as char),':', 
                      LPAD(CAST(FLOOR((sum(FF.minutos)%3600)/60)AS CHAR),2,'0'),':', 
                      LPAD(CAST((sum(FF.minutos)%60) AS CHAR),2,'0')) + 0)
                     from 
                    
				(select F1.fecha,
				               
				@egr2:= (SELECT H.egresoPremio  from HORARIOHIST as H  where H.desdeFecha <= F1.fecha and H.dia = DAYOFWEEK(F1.fecha) order by H.desdeFecha DESC limit 1) as "egr",
				@ing2:= (SELECT H.ingresoPremio from HORARIOHIST as H  where H.desdeFecha <= F1.fecha and H.dia = DAYOFWEEK(F1.fecha) order by H.desdeFecha DESC limit 1) as "ing",

				ifnull( time_to_sec( timediff( @egr2 , @ing2 )), 0)

				as "minutos"

				                   
				             from GEN_CALENDAR as F1 
					    join PERSONAL P on P.fechaEgreso = "0000-00-00"
					    join SECCION S on P.id_seccion = S.id_seccion
				    left join FERIADOS ON FERIADOS.idFeriado = F1.fecha
				        where
				                          F1.fecha  >= (select (case when fechaDesde < '[__desdefecha__]' then '[__desdefecha__]' else fechaDesde end) from SECCIONHISTORIA where fechaDesde <= '[__hastafecha__]' and SECCIONHISTORIA.IdPersona = P.IdPersona order by fechaDesde DESC limit 1) and
				                          F1.fecha  <= (select (case when fechaEgreso = '0000-00-00' then '[__hastafecha__]' else fechaEgreso end) from PERSONAL where PERSONAL.IdPersona = P.IdPersona) and
				                          S.seccion_productiva = 0 and
				                      	  P.marcaTarjeta = 1 and
				        isnUll(FERIADOS.idFeriado)) as FF ]]>
				</expression>
            </field>

			<field id="porcentaje_faltas" noZero="true">
				<label>Hs.Restantes</label>
				<expression sql="true">select (('[__proyeccion__]' + 0) - ('[__trabajadas__]' + 0))</expression>
				<tipo>decimal</tipo>
			</field>

<!-- 			<field id="objetivo_mensual_ausentismo">
			<label>%Obj.Men</label>
			<expression>select (option_value + 0) FROM HTXOPTIONS where option_description = 'Objetivo grafico Cantidad de Inasistencias x Mes' limit 1</expression>
			<tipo>decimal</tipo>
			</field>
 -->
			<field id="porcentaje_ausentismo" noZero="true">
				<label colstyle="font-size:14px;">% Prod</label>
				<expression sql="true">select ROUND(((('[__proyeccion__]' + 0) - ('[__trabajadas__]' + 0) - ('[__licencias_no_imputables__]' + 0)) / ('[__proyeccion__]' + 0)) * 100, 2)</expression>
				<tipo>decimal</tipo>  
			</field>
