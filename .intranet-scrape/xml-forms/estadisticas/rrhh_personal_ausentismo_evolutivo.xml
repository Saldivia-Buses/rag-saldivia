			<group>
				<field id="year" />
				<field id="mes" />
			</group>

		</table>

		<join tipo="left">
			<table id="SECCION">
				<field id="id_seccion">
					<condicion operador="=">PERSONAL.id_seccion</condicion>
				</field>
			</table>
		</join>

		<join>
			<table id="GEN_CALENDAR">
				<field id="fecha">
					<condicion operador="&gt;=">STR_TO_DATE('[__desdefecha__]', '%d/%m/%Y') AND GEN_CALENDAR.fecha &lt;= STR_TO_DATE('[__hastafecha__]', '%d/%m/%Y')</condicion>
				</field>
			</table>
		</join>

	</form>
</histrix>
