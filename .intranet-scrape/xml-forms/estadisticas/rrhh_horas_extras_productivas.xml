<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="chart">
	<title>ESTADISTICAS DE INASISTENCIAS</title>
	<obs></obs>
	<form >
		<table id="GEN_CALENDAR" label="ESTAD INASISTENCIAS">
		   <grafico id="Inasistencias" >
			   <ancho>400</ancho>
			   <tipo>L</tipo>
			   <etiquetas>mes</etiquetas>
			   <serie>cantidad_hs</serie>
			   <title>H.Extras productivas x mes</title>
		   </grafico>		
		    <filters>
			    <field id="fecha">
				    <label>Desde</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-12 month')) , 1, date("Y") -  1 ))</valor>
				    <operador>&gt;=</operador>
			    </field>
			    <field id="fecha">
                    <label>Hasta</label>
                    <!--<valor eval="true">date('d/m/Y', strtotime('-1 second', strtotime(date('Y-m-01'))))</valor> -->
                    <valor>today</valor>
                    <operador>&lt;=</operador>
			    </field>
		    </filters> 

			<field id="mes">
				<expression>month(GEN_CALENDAR.fecha)</expression>
				<label>Mes</label>
				<options>
					<option valor="1">Ene</option>
					<option valor="2">Feb</option>
					<option valor="3">Mar</option>
					<option valor="4">Abr</option>
					<option valor="5">May</option>
					<option valor="6">Jun</option>
					<option valor="7">Jul</option>
					<option valor="8">Ago</option>
					<option valor="9">Sep</option>
					<option valor="10">Oct</option>
					<option valor="11">Nov</option>
					<option valor="12">Dic</option>

				</options>
       				<tipo>varchar</tipo>
			</field>
                    <field id="fecha" oculto="true">
<!--                        <condicion operador="&gt;="> DATE_FORMAT(date_sub(date(now()) , interval 1 year) ,'%Y-%m-01') and GEN_CALENDAR.fecha &lt;= now()</condicion> -->
			<tipo>date</tipo>
                    </field>
                    <field id="year" oculto="true">
                        <expression>year(GEN_CALENDAR.fecha)</expression>

                    </field>
			<field id="cantidad_hs" tabla="RH_AUTH_EXTRAS_DETAIL">
				<label>Horas</label>
                <expression>sum(RH_AUTH_EXTRAS_DETAIL.cantidad_hs)</expression>                
				<tipo>numeric</tipo>
			</field>

<!--             <field id="fechaEgreso" tabla="PERSONAL">
        	    <condicion operador="=">'0000-00-00'</condicion>
        	</field> -->

        <field id="seccion_productiva" tabla="SECCION" oculto="true">
            <label>Productiva</label>
            <help>Productiva</help>
            <options>
                <option valor="0">Si</option>
                <option valor="1">No</option>           
            </options>
            <condicion operador="=">0</condicion>            
        </field>

	 		<group>
				<field id="year"></field>
				<field id="mes"></field>
			</group>

		</table>
        <join tipo="left">
            <table id="RH_AUTH_EXTRAS_DETAIL">
                <field id="desdeFecha">
                    <condicion operador="=">GEN_CALENDAR.fecha</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="PERSONAL">
    	        <field id="legajo">
                    <condicion operador="=">RH_AUTH_EXTRAS_DETAIL.legajo</condicion>
                </field>
            </table>
        </join>
        <join>
            <table id="SECCION">
            <field id="id_seccion">
                <condicion>RH_AUTH_EXTRAS_DETAIL.seccion_id</condicion>
            </field>
            </table>
        </join>        
	</form>
</histrix>
