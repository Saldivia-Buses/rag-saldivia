<?xml version="1.0" encoding="utf-8" ?>
<histrix tipo="chart">
	<title>Cantidad de coches con audio y video</title>
	<obs></obs>
	<form >
		<table id="GEN_CALENDAR" >
			<title>Cantidad de coches con audio y video</title>

			<grafico id="coches con av" >
				<ancho>400</ancho>
				<tipo>P</tipo>
				<serie>cantconav</serie>
				<serie>cantsinav</serie>
				<title>Cantidad de coches fabricados</title>
				<subtitulo>con A/V o sin A/V</subtitulo>
			</grafico>		

			<filters>
				<field id="fecha">
					<label>Desde</label>
					<valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-12 month')) , 1, date("Y") -  1 ))</valor>
					<operador>&gt;=</operador>
				</field>
				<field id="fecha">
					<label>Hasta</label>
					<valor eval="true">date('d/m/Y', strtotime('-1 second', strtotime(date('Y-m-01'))))</valor>
					<operador>&lt;=</operador>
				</field>
  			</filters>

			<field id="mes" oculto="true">
				<expression>month(GEN_CALENDAR.fecha)</expression>
				<label>Mes</label>
				<options>
					<option valor="1">Ene</option>
					<option valor="2">Feb</option>
					<option valor="3">Mar</option>
					<option valor="4">Abr</option> <!--SELECT COUNT(*) FROM (SELECT * FROM `ACCESORIOS_COCHE` where artdes like "%audio y video%" and nrofab IS NOT NULL and nrofab != 0 group by nrofab, ficha_id) a-->
					<option valor="5">May</option>
					<option valor="6">Jun</option>
					<option valor="7">Jul</option>
					<option valor="8">Ago</option>
					<option valor="9">Sep</option>
					<option valor="10">Oct</option>
					<option valor="11">Nov</option>
					<option valor="12">Dic</option>
				</options>
				<tipo>varchar</tipo>
			</field>

			<field id="fecha" oculto="true">
				<condicion operador="&gt;="> DATE_FORMAT(date_sub(date(now()) , interval 1 year) ,'%Y-%m-01') and GEN_CALENDAR.fecha &lt;= now()</condicion>
				<tipo>date</tipo>
			</field>
			
			<field id="year" oculto="true">
				<expression>year(GEN_CALENDAR.fecha)</expression>
			</field>

			<field id="cantconav" tipoOrden="DESC">
				<expression>SELECT COUNT(*) FROM (SELECT * FROM ACCESORIOS_COCHE ac WHERE ac.artdes LIKE "%audio y video%" and nrofab IS NOT NULL and nrofab != 0 group by nrofab, ficha_id) a where a.nrofab = PEDCOTIZ.nrocha and a.ficha_id = PEDCOTIZ.id </expression>
				<label>Con A/V</label>
				<tipo>numeric</tipo>
			</field>

			<field id="cantsinav" tipoOrden="DESC">
				<expression>SELECT COUNT(*) FROM (SELECT * FROM ACCESORIOS_COCHE ac WHERE ac.artdes NOT LIKE "%audio y video%" and nrofab IS NOT NULL and nrofab != 0 group by nrofab, ficha_id) a where a.nrofab = PEDCOTIZ.nrocha and a.ficha_id = PEDCOTIZ.id</expression>
				<label>Sin A/V</label>
				<tipo>numeric</tipo>
			</field>

	
		</table>
	
		<join tipo="left">
			<table id="PEDCOTIZ">
				<field id="pedfec">
					<condicion operador="=">GEN_CALENDAR.fecha</condicion>
				</field>
			</table>
		</join>
	</form>	   
</histrix> 
