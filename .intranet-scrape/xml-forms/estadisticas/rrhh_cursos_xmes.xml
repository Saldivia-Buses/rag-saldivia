<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="chart">
	<title>Cursos por mes</title>
	<obs></obs>
	<form >
		<table id="GEN_CALENDAR" label="Cursos por mes">
		   <grafico id="Cursos" >
			   <ancho>400</ancho>
			   <tipo>L</tipo>

			   <etiquetas>mes</etiquetas>
			   <serie>cursos</serie>
			   <serie>horas</serie>
			   <title>Cantidad de Cursos realizados y Carga horaria x Mes</title>
		   </grafico>		
		    <filters>
			    <field id="fecha">
				    <label>Desde</label>
				    <valor eval="true">date("01/01/Y")</valor>
				    <operador>&gt;=</operador>
			    </field>
			    <field id="fecha">
                    <label>Hasta</label>
				    <valor eval="true">date("31/12/Y")</valor>
				    <operador>&lt;=</operador>
			    </field>
		    </filters> 

			<field id="mes">
				<expression>month(GEN_CALENDAR.fecha)</expression>
				<label>Mes</label>
				<options>
					<option valor="1">Ene</option>
					<option valor="2">Feb</option>
					<option valor="3">Mar</option>
					<option valor="4">Abr</option>
					<option valor="5">May</option>
					<option valor="6">Jun</option>
					<option valor="7">Jul</option>
					<option valor="8">Ago</option>
					<option valor="9">Sep</option>
					<option valor="10">Oct</option>
					<option valor="11">Nov</option>
					<option valor="12">Dic</option>

				</options>
   				<tipo>varchar</tipo>
			</field>
                   
			<field id="fecha" oculto="true">
				<tipo>date</tipo>
            </field>
            <field id="year" oculto="true">
                <expression>year(GEN_CALENDAR.fecha)</expression>
            </field>

			<field id="cursos">
				<label>Cantidad de Cursos</label>
				<expression ><![CDATA[ (SELECT COUNT(*) FROM RH_CURSOS WHERE month(inicio) = month(fecha) AND  year(inicio) = year(fecha)) ]]></expression>
			</field>

			<field id="horas">
				<label>Carga Horaria</label>
                <expression ><![CDATA[ (SELECT IFNULL(SUM(edicion), 0) FROM RH_CURSOS WHERE month(inicio) = month(fecha) AND  year(inicio) = year(fecha)) ]]></expression>
			</field>

	 		<group>
				<field id="year"></field>
				<field id="mes"></field>
			</group>

		</table>

	</form>
</histrix>
