<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="chart">
	<title>ESTADISTICAS DE ACCIDENTES</title>
	<obs></obs>
	<form >
		<table id="GEN_CALENDAR" label="ESTAD ACCIDENTES">
		   <grafico id="Accidentes" >
			   <ancho>400</ancho>
			   <etiquetas>mes</etiquetas>
               <tipo>L</tipo>
			   <serie>accidentes_total</serie>
			   <serie>accidentes</serie>
			   <serie>accidentes_ini</serie>
			   <serie>enf_profesional</serie>
			   <title>Cantidad de Accidentes x Mes</title>
		   </grafico>		
		    <filters>
			    <field id="fecha">
				    <label>Desde</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-12 month')) , 1, date("Y") -  1 ))</valor>
				    <operador>&gt;=</operador>
			    </field>
			    <field id="fecha">
                                    <label>Hasta</label>
				    <valor eval="true">date('d/m/Y', strtotime('-1 second', strtotime(date('Y-m-01'))))</valor>
				    <operador>&lt;=</operador>
			    </field>
		    </filters> 

			<field id="mes">
				<expression>month(GEN_CALENDAR.fecha)</expression>
				<label>Mes</label>
				<options>
					<option valor="1">Ene</option>
					<option valor="2">Feb</option>
					<option valor="3">Mar</option>
					<option valor="4">Abr</option>
					<option valor="5">May</option>
					<option valor="6">Jun</option>
					<option valor="7">Jul</option>
					<option valor="8">Ago</option>
					<option valor="9">Sep</option>
					<option valor="10">Oct</option>
					<option valor="11">Nov</option>
					<option valor="12">Dic</option>

				</options>
       			<tipo>varchar</tipo>
			</field>

            <field id="fecha" oculto="true">
				<tipo>date</tipo>
            </field>

            <field id="year" oculto="true">
                <expression>year(GEN_CALENDAR.fecha)</expression>
            </field>

			<field id="accidentes_total">
				<expression>select count(*) from FRANCOS_PER where tipo= 1 and month(fechainicio) = month(fecha) and  year(fechainicio) = year(fecha)</expression>
				<label>Totales</label>
				<help></help>
				<tipo>integer</tipo>
			</field>

			<field id="accidentes">
				<expression>select count(*) from FRANCOS_PER where tipo= 1 and idfranco = 1 and month(fechainicio) = month(fecha) and  year(fechainicio) = year(fecha)</expression>
				<label>Accidentes</label>
				<help></help>
				<tipo>integer</tipo>
			</field>

			<field id="accidentes_ini">
				<expression>select count(*) from FRANCOS_PER where tipo= 1 and idfranco = 2 and month(fechainicio) = month(fecha) and  year(fechainicio) = year(fecha)</expression>
				<label>Accidentes in Itinere</label>
				<help></help>
				<tipo>integer</tipo>
			</field>

			<field id="enf_profesional">
				<expression>select count(*) from FRANCOS_PER where tipo= 1 and idfranco = 3 and month(fechainicio) = month(fecha) and  year(fechainicio) = year(fecha)</expression>
				<label>Enfermedad Profesional</label>
				<help></help>
				<tipo>integer</tipo>
			</field>

	 		<group>
				<field id="year"></field>
				<field id="mes"></field>			
			</group>

		</table>
	</form>
</histrix>
