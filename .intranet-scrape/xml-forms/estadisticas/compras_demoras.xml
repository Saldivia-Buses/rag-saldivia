<?xml version="1.0" encoding="utf-8" ?>
<histrix tipo="chart">
	<title>Cantidad</title>
	<obs></obs>
	<form >
		<table id="GEN_CALENDAR">
			<title>Cantidad</title>
	 
		   <grafico id="Demora">
			   <ancho>400</ancho>
			   <tipo>L</tipo>
			   
			   <etiquetas>mes</etiquetas> 
			   <serie>demora</serie>
			   
			   <title>Promedio Días de Retraso</title>
			   <subtitulo></subtitulo>
		   </grafico>		
		   
		    <filters>
			    <field id="fecha">
				    <label>Desde</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-12 month')) , 1, date("Y") -  1 ))</valor>
				    <operador>&gt;=</operador>
			    </field>
			    <field id="fecha">
                                    <label>Hasta</label>
				    <valor eval="true">date('d/m/Y', strtotime('-1 second', strtotime(date('Y-m-01'))))</valor>
				    <operador>&lt;=</operador>
			    </field>
		    </filters> 

			<field id="mes">
				<expression>month(fecha)</expression>
				<label>Mes</label>
				<options>
					<option valor="1">Ene</option>
					<option valor="2">Feb</option>
					<option valor="3">Mar</option>
					<option valor="4">Abr</option>
					<option valor="5">May</option>
					<option valor="6">Jun</option>
					<option valor="7">Jul</option>
					<option valor="8">Ago</option>
					<option valor="9">Sep</option>
					<option valor="10">Oct</option>
					<option valor="11">Nov</option>
					<option valor="12">Dic</option>

				</options>
       				<tipo>varchar</tipo>
			</field>
                    <field id="fecha" oculto="true">
<!--                        <condicion operador="&gt;="> DATE_FORMAT(date_sub(date(now()) , interval 1 year) ,'%Y-%m-01') and GEN_CALENDAR.fecha &lt;= now()</condicion> -->
			<tipo>date</tipo>
                    </field>
                    <field id="year" oculto="true">
                        <expression>year(fecha)</expression>

                    </field>

<!--			<field id="demora">
                             <expression><![CDATA[(select avg(DATEDIFF(OCPRECIB.fecrec, OCPRECIB.fecreq)) from OCPRECIB where year(OCPRECIB.ocpfec) = year(fecha) and month(OCPRECIB.ocpfec) = month(fecha))]]></expression>

				<label>Demoras</label>
                                <tipo>numeric</tipo>
			</field> -->
		<field id="demora">
                             <expression><![CDATA[avg(DATEDIFF(OCPRECIB.fecrec, OCPRECIB.fecreq))]]></expression>
				<label>Demoras</label>
                                <tipo>numeric</tipo>
			</field> 			
			
			<group>
                                <field id="year"></field>
				<field id="mes"></field>
			</group>
		</table>
		<join tipo="left">
		    <table id="OCPRECIB">
			<field id="ocpfec">
			    <condicion operador="=">GEN_CALENDAR.fecha</condicion>
			</field>
		    </table>
		</join>
		
	</form>	   
</histrix> 
