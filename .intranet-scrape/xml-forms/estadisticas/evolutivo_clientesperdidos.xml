<?xml version="1.0" encoding="utf-8" ?>
<histrix tipo="chart">
	<title>Clientes Perdidos</title>
	<obs></obs>
	<form >
		<table id="GEN_CALENDAR" >
			<title>Clientes perdidos</title>

			<grafico id="Resultados encuestas" >
				<ancho>400</ancho>
				<tipo>L</tipo>
				<etiquetas>year</etiquetas> 
				<serie>cantidadTotal</serie>
				<serie>cantidadPerdidos</serie>
				<title>Cantidad de Clientes que compraron por última vez x Mes</title>
			</grafico>		

			<filters>
				<field id="fecha">
					<label>Desde</label>
					<valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-12 month')) , 1, date("Y") -  10 ))</valor>
					<operador>&gt;=</operador>
				</field>
				<field id="fecha">
					<label>Hasta</label>
					<valor eval="true">date('d/m/Y', strtotime('-1 year', strtotime(date('Y-12-31'))))</valor>
					<operador>&lt;=</operador>
				</field>
  			</filters>

			<field id="mes" oculto="true">
				<expression>month(GEN_CALENDAR.fecha)</expression>
				<label>Mes</label>
				<options>
					<option valor="1">Ene</option>
					<option valor="2">Feb</option>
					<option valor="3">Mar</option>
					<option valor="4">Abr</option>
					<option valor="5">May</option>
					<option valor="6">Jun</option>
					<option valor="7">Jul</option>
					<option valor="8">Ago</option>
					<option valor="9">Sep</option>
					<option valor="10">Oct</option>
					<option valor="11">Nov</option>
					<option valor="12">Dic</option>
				</options>
				<tipo>varchar</tipo>
			</field>

			<field id="fecha" oculto="true">
				<tipo>date</tipo>
			</field>
			
			<field id="year" _oculto="true">
				<expression>year(GEN_CALENDAR.fecha)</expression>
			</field>

			
			<field id="cantidadTotal">
				<expression>count(DISTINCT PEDCOTIZ.ctacod)</expression>
				<label>Total</label>
			</field>

			<field id="cantidadPerdidos">
			    <label>Perdidos</label>

			-    <expression having="false" sql="true" >
			( select count(distinct(cta)) from (SELECT ctacod as cta , year(max(pedfec)) as ani FROM PEDCOTIZ  group by ctacod) as DIST where ani =  [__year__])
			</expression>
			    
			</field>
		      
			<field id="idconces" tabla="CONCESIONARIO">
			    <condicion operador="IS">NULL</condicion>
			</field>                                     
			
			<group>
				<field id="year" />
			</group>
			<order>
			</order>
		
		</table>
	
		<join tipo="left">
			<table id="PEDCOTIZ">
				<field id="pedfec">
					<condicion operador="=">GEN_CALENDAR.fecha</condicion>
				</field>
			</table>
		</join>
		<join tipo="left">
			<table id="CONCESIONARIO">
				<field id="ctacod">
					<condicion operador="=">PEDCOTIZ.ctacod</condicion>
				</field>
			</table>
		</join>
	</form>	   
</histrix> 
