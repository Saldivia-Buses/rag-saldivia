<?xml version="1.0" encoding="utf-8" ?>
<histrix tipo="chart">
	<title>Cambios</title>
	<obs></obs>
	<form >
		<table id="GEN_CALENDAR" >
			<title>Cambios</title>
	 
		   <grafico id="cambios" >
			   <ancho>400</ancho>
			   <tipo>L</tipo>
			   <etiquetas>mes</etiquetas> 
			   <serie>cantidad_cambios</serie>
<!--			   <serie>provisorios</serie>
			   <serie>definitivos</serie>-->
			   <title>Cambios realizados en Unidades x Mes</title>
			   <subtitulo></subtitulo>
		   </grafico>		
		    <filters>
			    <field id="fecha">
				    <label>Desde</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-12 month')) , 1, date("Y") -  1 ))</valor>
				    <operador>&gt;=</operador>
			    </field>
			    <field id="fecha">
                                    <label>Hasta</label>
				    <valor eval="true">date('d/m/Y', strtotime('-1 second', strtotime(date('Y-m-01'))))</valor>
				    <operador>&lt;=</operador>
			    </field>
		    </filters> 

			<field id="mes">
				<expression>month(fecha)</expression>
				<label>Mes</label>
				<options>
					<option valor="1">Ene</option>
					<option valor="2">Feb</option>
					<option valor="3">Mar</option>
					<option valor="4">Abr</option>
					<option valor="5">May</option>
					<option valor="6">Jun</option>
					<option valor="7">Jul</option>
					<option valor="8">Ago</option>
					<option valor="9">Sep</option>
					<option valor="10">Oct</option>
					<option valor="11">Nov</option>
					<option valor="12">Dic</option>

				</options>
       				<tipo>varchar</tipo>
			</field>

            <field id="fecha" oculto="true">
				<tipo>date</tipo>
            </field>

            <field id="year" oculto="true">
                <expression>year(fecha)</expression>

            </field>
			<field id="cantidad_cambios">
				<expression><![CDATA[(select count(*) from CONTROLCAMBIOS where
				month(CONTROLCAMBIOS.fecha) = month(GEN_CALENDAR.fecha) and
				year(CONTROLCAMBIOS.fecha) = year(GEN_CALENDAR.fecha))]]></expression>
				<label>Cantidad</label>
				<tipo>numeric</tipo>
			</field>
<!--
			<field id="provisorios">
				<expression><![CDATA[(select count(*) from CONTROLCAMBIOS where
				month(CONTROLCAMBIOS.fecha) = month(GEN_CALENDAR.fecha) and
				year(CONTROLCAMBIOS.fecha) = year(GEN_CALENDAR.fecha) and condicion = 0)]]></expression>
				<label>Provisorios</label>
				<tipo>numeric</tipo>
			</field>
			<field id="definitivos">
				<expression><![CDATA[(select count(*) from CONTROLCAMBIOS where
				month(CONTROLCAMBIOS.fecha) = month(GEN_CALENDAR.fecha) and
				year(CONTROLCAMBIOS.fecha) = year(GEN_CALENDAR.fecha) and condicion = 1)]]></expression>
				<label>Definitivos</label>
				<tipo>numeric</tipo>
			</field>-->
			<group>
                <field id="year"></field>
				<field id="mes"></field>

			</group>
		</table>
		
	</form>	   
</histrix> 
