<?xml version="1.0" encoding="utf-8" ?>
<histrix tipo="chart">
	<title>VENTAS ANUALES</title>
	<obs></obs>
	<form>
		<table id="GEN_CALENDAR" >
			<title>Ventas Anuales</title>	 
		    <filters>
			    <field id="fecha">
				    <label>Desde</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-12 month')) , 1, date("Y") -  1 ))</valor>
				    <operador>&gt;=</operador>
			    </field>
			    <field id="fecha">
                                    <label>Hasta</label>
				    <valor eval="true">date('d/m/Y', strtotime('-1 second', strtotime(date('Y-m-01'))))</valor>
				    <operador>&lt;=</operador>
			    </field>
		    </filters>
		   <grafico id="Relacion" >
			   <ancho>700</ancho>
			   <tipo>L</tipo>
			   <etiquetas>mes</etiquetas>
			   <serie>ventas</serie>
                <serie>opagos</serie>
			   <title>Iva Ventas vs Ordenes de Pago - Mensual</title>
			   <subtitulo></subtitulo>
		   </grafico>
		   
			<field id="mes">
				<expression>month(fecha)</expression>
				<label>Mes</label>	
				<options>
					<option valor="1">Ene</option>
					<option valor="2">Feb</option>
					<option valor="3">Mar</option>
					<option valor="4">Abr</option>
					<option valor="5">May</option>
					<option valor="6">Jun</option>
					<option valor="7">Jul</option>
					<option valor="8">Ago</option>
					<option valor="9">Sep</option>
					<option valor="10">Oct</option>
					<option valor="11">Nov</option>
					<option valor="12">Dic</option>
					
				</options> 
       				<tipo>varchar</tipo>
			</field>
                    <field id="fecha" oculto="true">
                    </field>
                    <field id="year" oculto="true">
                        <expression>year(fecha)</expression>

                    </field>
			<field id="ventas" >
				<expression>(select sum(IVAVENTAS.totcom * (case when CCTCONCE.conimp = 1 then 1 else -1 end)) from IVAVENTAS
                                left join CCTCONCE on CCTCONCE.concod = IVAVENTAS.codcom and CCTCONCE.siscod = '02'
                                where
                                month(IVAVENTAS.feciva) = month(GEN_CALENDAR.fecha)  and
                                year(IVAVENTAS.feciva) = year(GEN_CALENDAR.fecha))
                                </expression>
				<label>Iva Ventas</label>
                                <tipo>numeric</tipo>
			</field>
			<field id="opagos">
				<expression>(select sum(movimp) from CCTMOVIM
                                where 
                                month(CCTMOVIM.movfec) = month( GEN_CALENDAR.fecha) and
                                year(CCTMOVIM.movfec) = year( GEN_CALENDAR.fecha) and
                                CCTMOVIM.concod = 4 and
                                CCTMOVIM.siscod = '01')
                                </expression>
				<label>O.Pago</label>
                                <tipo>numeric</tipo>
			</field>
			<group>
                <field id="year"></field>
				<field id="mes"></field>

			</group>

		</table>
			
	</form>	   
</histrix> 
