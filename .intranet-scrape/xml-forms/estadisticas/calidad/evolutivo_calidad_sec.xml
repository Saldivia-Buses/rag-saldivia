<?xml version="1.0" encoding="utf-8" ?>
<histrix tipo="chart">
	<title>Cantidad</title>
	<obs></obs>
	<form >
		<table id="PROD_CONTROL_MOVIM" >
		    <title>OBSERVACIONES POR UNIDAD</title>
		   <grafico id="internos" >
			   <ancho>400</ancho>
			   <tipo>C</tipo>
                           <title>Cantidad de Observaciones</title>
			   <etiquetas>mes</etiquetas>
			   <serie>cantidad</serie>
			   <subtitulo></subtitulo>
		   </grafico>
		    <filters>
			    <field id="fecha_control">
				    <label>Desde</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-1 month')) , 1, date("Y") - 1))</valor>
				    <operador>&gt;=</operador>
			    </field>
			    <field id="fecha_control">
                                    <label>Hasta</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-0 month')) , 1, date("Y") ) - 1)</valor>
				    
				    <operador>&lt;=</operador>
			    </field>
<!--                        <field id="idSeccion" >
                    	    <label>Seccion</label>
                    	    <operador>=</operador>
                        </field>                  -->
			    
		    </filters>
                    <field id="year" oculto="true">
                        <expression>year(fecha_control)</expression>
                    </field>

			<field id="fecha_control"></field>
			<field id="mes">
				<expression>month(fecha_control)</expression>
				<label>Mes</label>
				<options>
					<option valor="1">Ene</option>
					<option valor="2">Feb</option>
					<option valor="3">Mar</option>
					<option valor="4">Abr</option>
					<option valor="5">May</option>
					<option valor="6">Jun</option>
					<option valor="7">Jul</option>
					<option valor="8">Ago</option>
					<option valor="9">Sep</option>
					<option valor="10">Oct</option>
					<option valor="11">Nov</option>
					<option valor="12">Dic</option>

				</options>
       				<tipo>varchar</tipo>
			</field>

			
                        <field id="seccion_id" tabla="MOMENTO" >
                        </field>

<!--                         <field id="observaciones">
                              <label>Observacion</label>
				<condicion operador="!=">' '</condicion>
                        </field> -->

                     <field id="no_conforme">
				<condicion operador="=">1</condicion>
                        </field> 
                        
			<field id="cantidad"  tipoOrden="DESC">
			       <expression><![CDATA[count(*)]]></expression>
				<tipo>numeric</tipo>

			</field>
			<group>
                                <field id="year"></field>
				<field id="mes"></field>

			</group>

                        <order>
                                <field id="fecha_control"></field>
			</order>

		</table>
		<join tipo="left">
                    <table id="PROD_CONTROLES">
                        <field id="id_prodcontrol">
                            <condicion operador="=">prodcontrol_id</condicion>
                            </field>
                    </table>
                </join>
		<join tipo="left">
                    <table id="MOMENTO">
                        <field id="idMomento">
                            <condicion operador="=">PROD_CONTROLES.seccion_id</condicion>
                            </field>
                    </table>
                </join>


	</form>
</histrix>
