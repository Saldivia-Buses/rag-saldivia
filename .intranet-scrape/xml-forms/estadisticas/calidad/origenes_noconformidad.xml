<?xml version="1.0" encoding="utf-8" ?>
<histrix tipo="chart">
	<title>Origenes No Conformidad</title>
	<obs></obs>
	<form >
		<table id="GEN_CALENDAR" >
			<title>Origenes No Conformidad</title>

			<grafico id="Origenes No Conformidad" >
				<ancho>400</ancho>
				<tipo>P</tipo>
				<etiquetas>origen_nconf</etiquetas> 
				<datos>no_conformidades</datos>
				<title>Origenes No Conformidad</title>
				<subtitulo>x tipo de origen</subtitulo>
			</grafico>		

			<filters>
				<field id="fecha">
					<label>Desde</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-12 month')) , 1, date("Y") -  1 ))</valor>
					<operador>&gt;=</operador>
				</field>
				<field id="fecha">
					<label>Hasta</label>
					<valor eval="true">date('d/m/Y', strtotime('-1 second', strtotime(date('Y-m-01'))))</valor>
					<operador>&lt;=</operador>
				</field>
   							
  			</filters>

			<field id="mes">
				<expression>month(fecha)</expression>
				<label>Mes</label>
				<options>
					<option valor="1">Ene</option>
					<option valor="2">Feb</option>
					<option valor="3">Mar</option>
					<option valor="4">Abr</option>
					<option valor="5">May</option>
					<option valor="6">Jun</option>
					<option valor="7">Jul</option>
					<option valor="8">Ago</option>
					<option valor="9">Sep</option>
					<option valor="10">Oct</option>
					<option valor="11">Nov</option>
					<option valor="12">Dic</option>
				</options>
				<tipo>varchar</tipo>
			</field>

			<field id="fecha" oculto="true">
				<tipo>date</tipo>
			</field>

			<field id="year" oculto="true">
				<expression>year(fecha)</expression>
			</field>

			<field id="origen_nconf" tabla="CAL_ORIGEN_NCONF">
				<label>Origen</label>
			</field>

			<field id="origennconf_id" tabla="CAL_NOCONFORMIDADES">
				<label>Origen</label>
			</field>

			<field id="no_conformidades">
				<expression>COUNT(*)</expression>
				<label>Cantidad</label>
				<tipo>numeric</tipo>
			</field>

			<field id="noconformidades">
				<expression>CAL_NOCONFORMIDADES.origennconf_id</expression>
				<label>NoConf</label>
			</field>

			<group>
				<field id="origennconf_id"/>
			</group>

		</table>
	
		<join tipo="inner">
			<table id="CAL_NOCONFORMIDADES">
				<field id="fecha_nconf">
					<condicion operador="=">GEN_CALENDAR.fecha</condicion>
				</field>
			</table>
		</join>
		<join tipo="inner">
			<table id="CAL_ORIGEN_NCONF">
				<field id="id_origennconf">
					<condicion operador="=">CAL_NOCONFORMIDADES.origennconf_id</condicion>
				</field>
			</table>
		</join>
	</form>	   
</histrix> 
