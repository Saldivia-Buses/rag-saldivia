<?xml version="1.0" encoding="utf-8" ?>
<histrix tipo="chart">
	<title>Cantidad</title>
	<obs></obs>
	<form>
		<table id="PROD_CONTROL_MOVIM" >
		   <title>CANTIDAD DE OBSERVACIONES</title>

		   <grafico id="internos" pareto="true">
			   <ancho>400</ancho>
			   <tipo>C</tipo>
                           <title>Observaciones por sector auditado</title>
			   <etiquetas>descripcion</etiquetas>
			   <serie>cantidad</serie>
			   <subtitulo></subtitulo>
		   </grafico>

		    <filters>
			    <field id="fecha_control">
				    <label>Desde</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-1 month')) , 1, date("Y") ))</valor>
				    <operador>&gt;=</operador>
			    </field>
			    <field id="fecha_control">
                                    <label>Hasta</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-0 month')) , 1, date("Y") ) - 1)</valor>

				    <operador>&lt;=</operador>
			    </field>
			    <field id="nrofab_id">
                                    <label>Coche</label>
				    <operador>=</operador>
			    </field>
		    </filters>
       			<field id="nrofab_id">
                                    <label>Coche</label>
				   <ayuda_ex id="PEDCOTIZ">
					<field id="nrocha"/>
					<field id="nrocha"/>
				   </ayuda_ex>
		       </field>
			<field id="fecha_control"></field>

                        <field id="seccion_id" noshow="true" tabla="PROD_CONTROLES">
                             <condicion operador="!=">0</condicion>
                        </field>
			 <field id="descripcion" tabla="MOMENTO">
                              <label>Seccion</label>
                        </field>
		
                         <field id="no_conforme">
                              <label>Observacion</label>
				<condicion operador="=">1</condicion>
                        </field>
			<field id="cantidad"  tipoOrden="DESC">

                            
			       <expression><![CDATA[count(*)]]></expression>
				<label>Observaciones</label>

			</field>
			<field id="graficar" tabla="MOMENTO" noshow="true">
				<condicion operador="=">1</condicion>
			</field>
			
                      
			<group>
                                <field id="seccion_id" tabla="PROD_CONTROLES"></field>
			</group>
                        <order>
                                <field id="cantidad" tipoOrden="DESC"></field>
			</order>
    
		</table>
		<join tipo="left">
                    <table id="PROD_CONTROLES">
                        <field id="id_prodcontrol">
                            <condicion operador="=">prodcontrol_id</condicion>
                            </field>
                    </table>
                </join>
		<join tipo="left">
                    <table id="MOMENTO">
                        <field id="idMomento">
                            <condicion operador="=">PROD_CONTROLES.seccion_id</condicion>
                            </field>
                    </table>
                </join>


	</form>
</histrix>
