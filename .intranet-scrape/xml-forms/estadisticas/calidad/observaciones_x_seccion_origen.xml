<?xml version="1.0" encoding="utf-8" ?>
<histrix tipo="chart" _tipo="consulta">
    <title>Observaciones Promedio x Seccion</title>
    <obs />
    <form>
        <table id="PROD_CONTROL_MOVIM">

            <grafico id="calidad">
                <ancho>500</ancho>
                <tipo>P</tipo>
                <title>Responsabilidad de Defectos</title>
                <etiquetas>nombre_seccion</etiquetas>
                <datos>cantidad</datos>

            </grafico>

            <filters>
                <field id="fecha_control">
                    <label>Desde</label>
                    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m") , 1, date("Y") ))</valor>
                    <operador>&gt;=</operador>
                </field>

                <field id="fecha_control" modpos="nobr">
                    <label>Hasta</label>
                    <valor eval="true">date('d/m/Y', mktime(0,0,0, date('m') ,date('t') ,date('Y')));</valor>
                    <operador>&lt;=</operador>
                </field>
            </filters>
	    
    	    <field id="seccion_origen_id" >
    		  <condicion operador="!=">0</condicion>
    	    </field>

    	    <field id="nombre_seccion">
    		  <expression>descripcion</expression>
    	    </field>

            <field id="fecha_control" noshow="true" />

            <field id="year" oculto="true" noshow="true">
                <label>Año</label>
                <expression>YEAR(PROD_CONTROL_MOVIM.fecha_control)</expression>
            </field>

            <field id="mes" noshow="true">
                <label>Mes</label>
                <expression>MONTH(PROD_CONTROL_MOVIM.fecha_control)</expression>
            </field>

            <field id="periodo">
                <label>Periodo</label>
                <expression>UPPER(CONCAT((CASE MONTH(PROD_CONTROL_MOVIM.fecha_control) 
                    WHEN 1 THEN 'Ene'                                                        
                    WHEN 2 THEN 'Feb'
                    WHEN 3 THEN 'Mar'
                    WHEN 4 THEN 'Abr'
                    WHEN 5 THEN 'May'
                    WHEN 6 THEN 'Jun'
                    WHEN 7 THEN 'Jul'
                    WHEN 8 THEN 'Ago'
                    WHEN 9 THEN 'Sep'
                    WHEN 10 THEN 'Oct'
                    WHEN 11 THEN 'Nov'
                    WHEN 12 THEN 'Dic' END), "'", RIGHT(YEAR(PROD_CONTROL_MOVIM.fecha_control), 2)))</expression>
            </field>

            <field id="coches">
                <expression><![CDATA[(select count(*) from PEDCOTIZ where
                            month(PEDCOTIZ.terminacion) = month(fecha_control) and
                            year(PEDCOTIZ.terminacion) = year(fecha_control))]]></expression>
                <label>Coches</label>
                <tipo>custom_numeric</tipo>
            </field>

    	    <field id="seccion_id" tabla="PROD_CONTROLES"/>
    	    
    	    <field id="cantidad">
    		    <label>cantidad</label>
    		    <expression>count(*)</expression>
    	    </field>

            <!-- <field id="cantidad_terminacion">
                <label>Terminacion</label>
                <expression>SUM(CASE WHEN PROD_CONTROLES.seccion_id = '5' THEN 1 ELSE 0 END)</expression>
                <tipo>custom_numeric</tipo>
            </field> -->


           <!--  <field id="cantidad_entrega">
                <label>Entrega</label>
                <expression>SUM(CASE WHEN PROD_CONTROLES.seccion_id = '6' THEN 1 ELSE 0 END)</expression>
                <tipo>custom_numeric</tipo>
            </field> -->


            <field id="no_conforme" noshow="true">
                <condicion operador="=">1</condicion>
            </field>

            <group>
                <field id="seccion_origen_id" />
            </group>

            <order>
                <field id="fecha_control" />
            </order>

        </table>

        <join>
            <table id="PROD_CONTROLES">
                <field id="id_prodcontrol">
                    <condicion operador="=">PROD_CONTROL_MOVIM.prodcontrol_id</condicion>
                </field>
            </table>
        </join>
        <join>
            <table id="MOMENTO">
                <field id="idMomento">
                    <condicion operador="=">seccion_origen_id</condicion>
                </field>
            </table>
        </join>

    </form>
</histrix>