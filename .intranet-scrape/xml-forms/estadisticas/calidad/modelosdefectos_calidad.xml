<?xml version="1.0" encoding="utf-8" ?>
<histrix tipo="chart">
	<title>COCHES</title>
	<obs>(Observaciones / Controles realizados) por Modelo Terminados %</obs>
	<form >
		<table id="PEDCOTIZ" >
			<title>(Observaciones / Controles realizados) por Modelo Terminados %</title>
	 
		   <grafico id="modelosfab">
			   <ancho>400</ancho>
			   <tipo>L</tipo>			   
			   <etiquetas>desabv</etiquetas> 
			   <serie type="C">coches</serie>
			   <serie type="L">defectos</serie>
			   <title>Modelos Terminados y %defecto</title>
			   <subtitulo></subtitulo>
		   </grafico>
		
		    <filters>
			    <field id="terminacion">
				    <label>Desde</label>
<!--				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-1 month')) , 1, date("Y") ))</valor>-->
<valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m") , date("d"), (date("Y") - 1)))</valor>
				    <operador>&gt;=</operador>
			    </field>
			    <field id="terminacion">
                                    <label>Hasta</label>
<!--				    <valor eval="true">date('d/m/Y', strtotime('-1 second', strtotime(date('Y-m-01'))))</valor>-->
<valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m") , date("d"), date("Y")))</valor>

				    <operador>&lt;=</operador>
			    </field>
		    </filters> 

			<field id="mes">
				<expression>month(terminacion)</expression>
				<label>Mes</label>
				<options>
					<option valor="1">Ene</option>
					<option valor="2">Feb</option>
					<option valor="3">Mar</option>
					<option valor="4">Abr</option>
					<option valor="5">May</option>
					<option valor="6">Jun</option>
					<option valor="7">Jul</option>
					<option valor="8">Ago</option>
					<option valor="9">Sep</option>
					<option valor="10">Oct</option>
					<option valor="11">Nov</option>
					<option valor="12">Dic</option>
				</options>
       			<tipo>varchar</tipo>
			</field>
            
            <field id="terminacion" oculto="true">
				<tipo>date</tipo>
            </field>
            
            <field id="year" oculto="true">
                <expression>year(terminacion)</expression>
            </field>

			<field id="coches">
                <expression><![CDATA[(count(distinct nrocha))]]></expression>
				<label>Coches</label>
                <tipo>numeric</tipo>
			</field>

			<field id="defectos">
                <expression><![CDATA[(100*SUM(no_conforme)/ count(*))]]></expression>
				<label>% Defectos</label>
                <tipo>numeric</tipo>
			</field>

			<field id="seccion_id" tabla="PROD_CONTROLES">
				<condicion operador="!=">0</condicion>
			</field>

			<field id="no_aplica" tabla="PROD_CONTROL_MOVIM">
				<condicion operador="!=">1</condicion>
			</field>

			<field id="nrocar" noshow="true" />
			<field id="desabv" tabla="CARROCERIA" />
			
			<group>
				<field id="nrocar" tabla="HOMOLOGMOD"></field>
                <field id="year"></field>
				<field id="mes"></field>
			</group>
		</table>

		<join tipo="left">
		    <table id="HOMOLOGMOD">
			<field id="id_homologacion">
			    <condicion operador="=">PEDCOTIZ.homologacion_id</condicion>
			</field>
		    </table>
		</join>
		<join tipo="left">
		    <table id="CARROCERIA">
			<field id="nrocar">
			    <condicion operador="=">HOMOLOGMOD.nrocar</condicion>
			</field>
		    </table>
		</join>
		<join tipo="left">
		    <table id="PROD_CONTROL_MOVIM">
			<field id="nrofab_id">
			    <condicion operador="=">PEDCOTIZ.nrocha</condicion>
			</field>
		    </table>
		</join>

		<join tipo="left">
            <table id="PROD_CONTROLES">
	            <field id="id_prodcontrol">
                    <condicion operador="=">PROD_CONTROL_MOVIM.prodcontrol_id</condicion>
                </field>
            </table>
        </join>

	</form>	   
</histrix> 
