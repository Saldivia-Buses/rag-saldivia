<?xml version="1.0" encoding="utf-8" ?>
<histrix tipo="chart">
	<title>Tipo</title>
	<obs></obs>
	<form >
		<table id="SERVICE_TURNOS" >
		   <title>Por año</title>
	 
		   <grafico id="Tareas" >
			   <ancho>400</ancho>
			   <tipo>P</tipo>
			   
			   <etiquetas>year</etiquetas>  
			   <datos>cantYear</datos>
			   
			   <title>Cantidad de Tareas Realizadas</title>
			   <subtitulo>x Año</subtitulo>
		   </grafico>		
		    <filters>
			    <field id="fecha">
				    <label>Desde</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-12 month')) , 1, date("Y") -  1 ))</valor>
				    <operador>&gt;=</operador>
			    </field>
			    <field id="fecha">
                                    <label>Hasta</label>
				    <valor eval="true">date('d/m/Y', strtotime('-1 second', strtotime(date('Y-m-01'))))</valor>
				    <operador>&lt;=</operador>
			    </field>
		    </filters> 
			<field id="fecha"></field>

			<field id="year">
			    <expression>year(PEDCOTIZ.pedfec)</expression>
			</field>
			<field id="cantYear"  tipoOrden="DESC">
			    <expression>count(year(PEDCOTIZ.pedfec))</expression>
				<condicion operador="!=">0</condicion>
			</field>
			
			

			<group>
                                <field id="year" ></field>
			</group>
			<order>
                                <field id="cantYear" ></field>
			</order>
			
			
		</table>

		<join tipo="INNER">
		    <table id="PEDCOTIZ">
			<field id="nrocha">
			    <condicion operador="=">SERVICE_TURNOS.nrofab</condicion>
			</field>
		    </table>
		</join>
		
		
	</form>	   
</histrix> 
