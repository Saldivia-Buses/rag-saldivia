<?xml version="1.0" encoding="utf-8" ?>
<histrix tipo="chart">
	<title>COCHES</title>
	<obs></obs>
	<form >
		<table id="GEN_CALENDAR" >
			<title>Coches</title>
	 

		   <grafico id="CochesPer" >
			   <ancho>400</ancho>
			   <tipo>L</tipo>
			   
			   <etiquetas>mes</etiquetas> 
			   <serie>cochesper</serie>
			   
			   <title>Personal necesario para terminar un coche x Mes</title>
			   <subtitulo></subtitulo>
		   </grafico>		

		    <filters>
			    <field id="fecha">
				    <label>Desde</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-12 month')) , 1, date("Y") -  1 ))</valor>
				    <operador>&gt;=</operador>
			    </field>
			    <field id="fecha">
                                    <label>Hasta</label>
				    <valor eval="true">date('d/m/Y', strtotime('-1 second', strtotime(date('Y-m-01'))))</valor>
				    <operador>&lt;=</operador>
			    </field>
		    </filters> 

			<field id="mes">
				<expression>month(GEN_CALENDAR.fecha)</expression>
				<label>Mes</label>
				<options>
					<option valor="1">Ene</option>
					<option valor="2">Feb</option>
					<option valor="3">Mar</option>
					<option valor="4">Abr</option>
					<option valor="5">May</option>
					<option valor="6">Jun</option>
					<option valor="7">Jul</option>
					<option valor="8">Ago</option>
					<option valor="9">Sep</option>
					<option valor="10">Oct</option>
					<option valor="11">Nov</option>
					<option valor="12">Dic</option>
				</options>
				<tipo>varchar</tipo>
			</field>
				
			<field id="fecha" _oculto="true">
				<!--                        <condicion operador="&gt;="> DATE_FORMAT(date_sub(date(now()) , interval 1 year) ,'%Y-%m-01') and GEN_CALENDAR.fecha &lt;= now()</condicion> -->
				<tipo>date</tipo>
			</field>

		    <field id="year" oculto="true">
		        <expression>year(GEN_CALENDAR.fecha)</expression>

		    </field>

            <field id="personal">
<!--            	<expression>avg((select count(distinct(tarjeta)) from FICHADAS where FICHADAS.fecha = GEN_CALENDAR.fecha ) )</expression>  -->
                            <expression>count(distinct(FICHADADIA.tarjeta))</expression> 
                <label>Personal</label>
                <help></help>
                <tipo>integer</tipo>
            </field>

			<field id="coches">
<!--				<expression sql="true"><![CDATA[(select count(*) from PEDCOTIZ where month(PEDCOTIZ.terminacion)  = [__mes__] and year(PEDCOTIZ.terminacion) = [__year__] )]]></expression> -->
				    <expression>count(distinct PEDCOTIZ.id)</expression>
				<label>Coches</label>
				<tipo>numeric</tipo>
			</field>

            <field id="cochesper" _local="true">
                            <expression>count(distinct(FICHADADIA.tarjeta)) / count(distinct PEDCOTIZ.id)</expression> 
<!--
        	    <if exp="true">
        		<true>round((personal / coches),1)</true>
        		<false>0</false>
        	    </if>
-->
                <tipo>numeric</tipo>
				<label>Cantidad</label>
            </field>

			<group>
                <field id="year"></field>
				<field id="mes"></field>
			</group>
		</table>
		<join tipo="left">
			<table id="PEDCOTIZ">
				<field id="terminacion">
					<condicion operador="=">GEN_CALENDAR.fecha</condicion>
				</field>
			</table>
		</join>

		<join tipo="left">
			<table id="FICHADADIA">
				<field id="fecha">
					<condicion operador="=">GEN_CALENDAR.fecha</condicion>
				</field>
			</table>
		</join>
	</form>	   
</histrix> 
