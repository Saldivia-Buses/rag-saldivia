<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="chart">
	<title>Relacion Directos e Indrectos</title>
	<obs></obs>
	<form >
		<table id="PERSONAL" label="Relacion Directos e Indrectos">
		   <grafico id="Personal" >
			   <ancho>400</ancho>
			   <tipo>P</tipo>
			   <etiquetas>seccion_productiva</etiquetas>
			   <datos>personal</datos>
			   <title>Relacion Directos e Indrectos</title>
		   </grafico>		

			<field id="personal">
				<expression> count(distinct(IdPersona))</expression>								
				<label>Cantidad</label>
				<help></help>
				<tipo>integer</tipo>
			</field>

			<field id="fechaEgreso">
				<condicion operador="=">'0000-00-00'</condicion>
			</field>

  			<field id="seccion_productiva" tabla="SECCION">
				<label>Seccion Tipo</label>
                <options>
                    <option valor="0">Prod.</option>
                    <option valor="1">No Prod.</option>
                </options>				
			</field>

	 		<group>
	 			<field id="seccion_productiva" tabla="SECCION" />
			</group>

		</table>
		<join tipo="left">
			<table id="SECCION">
				<field id="id_seccion">
					<condicion operador="=">PERSONAL.id_seccion</condicion>
				</field>
			</table>
		</join>

	</form>
</histrix>
