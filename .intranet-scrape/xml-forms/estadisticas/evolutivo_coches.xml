<?xml version="1.0" encoding="utf-8" ?>
<histrix tipo="chart">
	<title>COCHES</title>
	<obs></obs>
	<form >
		<table id="GEN_CALENDAR" >
			<title>Cantidad Mensual de Coches</title>
	
		   <grafico id="Ventas" >
			    <objective>22</objective>
			   <ancho>400</ancho>
			   <tipo>L</tipo>
			   
			   <etiquetas>mes</etiquetas> 
			   <serie>coches</serie>
			   
			   <title>Cantidad de coches fabricados x Mes</title>
			   <subtitulo></subtitulo>
		   </grafico>		

		    <filters>
			    <field id="fecha">
				    <label>Desde</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-12 month')) , 1, date("Y") -  1 ))</valor>
				    <operador>&gt;=</operador>
			    </field>
			    <field id="fecha">
                                    <label>Hasta</label>
<!--				    <valor eval="true">date('d/m/Y', strtotime('-1 second', strtotime(date('Y-m-01'))))</valor> -->
<valor>today</valor>
				    <operador>&lt;=</operador>
			    </field>
			    <field id="linea_id" deshabilitado="false">
                                    <label>Linea</label>
				    <operador>=</operador>
			    </field>
		    </filters> 

			<field id="mes">
				<expression>month(fecha)</expression>
				<label>Mes</label>
				<options>
					<option valor="1">Ene</option>
					<option valor="2">Feb</option>
					<option valor="3">Mar</option>
					<option valor="4">Abr</option>
					<option valor="5">May</option>
					<option valor="6">Jun</option>
					<option valor="7">Jul</option>
					<option valor="8">Ago</option>
					<option valor="9">Sep</option>
					<option valor="10">Oct</option>
					<option valor="11">Nov</option>
					<option valor="12">Dic</option>

				</options>
       				<tipo>varchar</tipo>
			</field>
                    <field id="fecha" oculto="true">
<!--                        <condicion operador="&gt;="> DATE_FORMAT(date_sub(date(now()) , interval 1 year) ,'%Y-%m-01') and GEN_CALENDAR.fecha &lt;= now()</condicion> -->
			<tipo>date</tipo>
                    </field>
                    <field id="year" oculto="true">
                        <expression>year(fecha)</expression>

                    </field>
			<field id="coches">
			<expression>count(*)</expression>
<!--                             <expression><![CDATA[(select count(*) from PEDCOTIZ where
                                month(PEDCOTIZ.terminacion) = month(GEN_CALENDAR.fecha) and
                                year(PEDCOTIZ.terminacion) = year(GEN_CALENDAR.fecha))]]></expression>
    -->

				<label>Coches</label>
                                <tipo>numeric</tipo>
			</field>
			<field id="linea_id">
                             <expression having="false"><![CDATA[(select linea_id from TURNOSPRODUCCION where nrofab = nrocha limit 1)]]></expression>
				<helper type="combo" id="PROD_LINEAS" empty="true">
				    <field id="id_linea" />
				    <field id="nombre_linea" />
				</helper>

                                <tipo>numeric</tipo>
			</field>
			<group>
                                <field id="year"></field>
				<field id="mes"></field>

			</group>
		</table>
		<join>
		    <table id="PEDCOTIZ">
			<field id="terminacion">
			    <condicion operador="=">fecha</condicion>
			</field>
		    </table>
		</join>
		
	</form>	   
</histrix> 
