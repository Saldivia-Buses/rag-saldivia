<?xml version="1.0" encoding="UTF-8"?>
<histrix  tipo="abm-mini" subtipo="vertical" path="/fotos/coches/">
	<title>Entregas</title>
	<obs/>
	<form >
		<table id="CERTIFICADOLCM">
			<title>Certificado LCM</title>
			<field id="nrofab" oculto="true">
				<label >Nro.Fab.</label>
				<help>Número de Fabricación</help>
			</field>

			<field id="fecha" >
				<label>Fecha</label>
				<valor>today</valor>
			</field>
			<field id="nrocert" >
				<label>Nro Certificado</label>
			</field>			
			<field id="observ">
				<label>Observaciones</label>
				<help>Observaciones del Certificado</help>
				<size>60</size>
			</field>
			<field id="datosEntrega">
				<label>Datos de Entrega</label>
				<help>Observaciones con respecto a la Entrega del certificado</help>
				<size>60</size>
				

			</field>
    <field id="scans"  _imageWidth="165" noshow="true"> 
  <expression>CONCAT(nrofab,'/lcm/')</expression>
    </field>      
    <field id="escaneado" local="true" imageWidth="50" path="scans" view="true">  
  <expression>CONCAT('/fotos/coches/',nrofab,'/lcm/')</expression>

  <label>Archivos</label>
  <tipo>dir</tipo>
  <size>40</size>
    </field>      
		</table>

	</form>
</histrix>
