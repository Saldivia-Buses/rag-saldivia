<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="fichaing" limit="1" inserta="false" modifica="false" borra="false" procesa="false" imprime="true" export="true" PDForientation="L" calculateButton="Buscar">
	<title>IVA VENTAS</title>
	<obs/>	
	<form>
		<table id="REG_MOVIMIENTOS" label="IVA VENTAS">		

			<field id="iva_subsistema" local="true" PDFnoborder="true" export="false" print="false">
				<label>TIPO IVA:</label>
				<helper type="combo">
            <option value="2">Compras</option>
				    <option value="1">Ventas</option>
				</helper>
   				<actualiza>
   					<field id="detalle_movimientos" destino="iva_subsistema" />
   					<field id="detalle_alicuota" destino="iva_subsistema" />
   					<field id="detalle_conceptos" destino="iva_subsistema" />
   					<field id="detalle_tipo_afip" destino="iva_subsistema" />   	
            <field id="detalle_tipo_afip_alicuota" destino="iva_subsistema" />   				
   				</actualiza>
   				<jseval campodestino="titulo_impresion">\'Impresion Libro de IVA \' + ((iva_subsistema == 1) ? \'Ventas\' : \'Compras\')</jseval>
			</field>

			<field id="tip_fecha" local="true" PDFnoborder="true" export="false">
				<label posX="25" posY="+2" size="25">TIPO FECHA:</label>
				<helper type="combo">
					<option value="0">Registracion</option>
					<option value="1">Comprobante</option>
				</helper>
   				<actualiza>
   					<field id="detalle_movimientos" destino="tip_fecha" />
   					<field id="detalle_alicuota" destino="tip_fecha" />
   					<field id="detalle_conceptos" destino="tip_fecha" />
   					<field id="detalle_tipo_afip" destino="tip_fecha" />
            <field id="detalle_tipo_afip_alicuota" destino="tip_fecha" />
   				</actualiza>
			</field>

			<field id="desde_fecha" local="true" PDFnoborder="true" export="false">
				<label posX="120" posY="0" modpos="nobr" size="25">DESDE FECHA:</label>
				<tipo>date</tipo>
   				<valor eval="true">date("d/m/Y", mktime(0, 0, 0, date("m"), 1, date("Y")))</valor>
   				<actualiza>
   					<field id="detalle_movimientos" destino="desde_fecha" />
   					<field id="detalle_alicuota" destino="desde_fecha" />
   					<field id="detalle_conceptos" destino="desde_fecha" />
   					<field id="detalle_tipo_afip" destino="desde_fecha" />
            <field id="detalle_tipo_afip_alicuota" destino="desde_fecha" />
   				</actualiza>
			</field>

			<field id="hasta_fecha" local="true" PDFnoborder="true" export="false">
				<label posX="215" posY="0" modpos="nobr" size="25">HASTA FECHA:</label>
				<tipo>date</tipo>
				<valor>today</valor>
   				<actualiza>
   					<field id="detalle_movimientos" destino="hasta_fecha" />
   					<field id="detalle_alicuota" destino="hasta_fecha" />
   					<field id="detalle_conceptos" destino="hasta_fecha" />
   					<field id="detalle_tipo_afip" destino="hasta_fecha" />
            <field id="detalle_tipo_afip_alicuota" destino="hasta_fecha" />
   				</actualiza>
			</field>

			<field id="desde_puesto" local="true" mask="9999" PDFnoborder="true" export="false">
				<label posX="25" posY="+2" size="25">DESDE FECHA:</label>
				<valor>0001</valor>
   				<actualiza>
   					<field id="detalle_movimientos" destino="desde_puesto" />
   					<field id="detalle_alicuota" destino="desde_puesto" />
   					<field id="detalle_conceptos" destino="desde_puesto" />
   					<field id="detalle_tipo_afip" destino="desde_puesto" />
            <field id="detalle_tipo_afip_alicuota" destino="desde_puesto" />
   				</actualiza>
			</field>

			<field id="hasta_puesto" local="true" mask="9999" PDFnoborder="true" export="false">
				<label posX="120" posY="0" modpos="nobr" size="25">HASTA PUESTO:</label>
				<valor>9999</valor>
   				<actualiza>
   					<field id="detalle_movimientos" destino="hasta_puesto" />
   					<field id="detalle_alicuota" destino="hasta_puesto" />
   					<field id="detalle_conceptos" destino="hasta_puesto" />
   					<field id="detalle_tipo_afip" destino="hasta_puesto" />
            <field id="detalle_tipo_afip_alicuota" destino="hasta_puesto" />
   				</actualiza>
			</field>		

			<field id="letra_movimiento" local="true" PDFnoborder="true" export="false">
				<label posX="215" posY="0" modpos="nobr" size="25">LETRA:</label>
				<helper type="combo">
				    <option value="">Todos</option>
				    <option value="A">A</option>
				    <option value="B">B</option>
				    <option value="C">C</option>
				    <option value="M">M</option>
				    <option value="E">E</option>
				    <option value="X">X</option>
				</helper>
   				<actualiza>
   					<field id="detalle_movimientos" destino="letra" />
   					<field id="detalle_alicuota" destino="letra" />
   					<field id="detalle_conceptos" destino="letra" />
   					<field id="detalle_tipo_afip" destino="letra" />
            <field id="detalle_tipo_afip_alicuota" destino="letra" />
   				</actualiza>
			</field>

			<field id="concepto_id" local="true" PDFnoborder="true" export="false">
				<label posX="25" posY="+2" size="25">COMPROBANTE:</label>			
				<helper type="combo" xml="regconceptos_iva_qry.xml" dir="/ayudas/" empty="Todos" />
   				<actualiza>
   					<field id="detalle_movimientos" destino="concepto" />
   					<field id="detalle_alicuota" destino="concepto" />
   					<field id="detalle_conceptos" destino="concepto" />
   					<field id="detalle_tipo_afip" destino="concepto" />
            <field id="detalle_tipo_afip_alicuota" destino="concepto" />
   				</actualiza>
			</field>	
			
			<field id="tiposervicio_afip" local="true" PDFnoborder="true" export="false">
				<label posX="120" posY="0" modpos="nobr" size="25">TIPO:</label>
				<helper type="combo" id="GEN_TIPO_SERVICIO_AFIP" empty="Todos">
					<field id="id_tiposervicio" />
					<field id="nombre_tiposervicio" />
				</helper>
   				<actualiza>
   					<field id="detalle_movimientos" destino="tiposervicio" />
   					<field id="detalle_alicuota" destino="tiposervicio" />
   					<field id="detalle_conceptos" destino="tiposervicio" />
   					<field id="detalle_tipo_afip" destino="tiposervicio" />
            <field id="detalle_tipo_afip_alicuota" destino="tiposervicio" />
   				</actualiza>
			</field>

			<field id="provincia_id" local="true" PDFnoborder="true" export="false">
				<label posX="215" posY="0" modpos="nobr" size="25">PROVINCIA:</label>
				<helper type="combo" xml="provincia_qry.xml" dir="/ayudas" empty="Todas" />
   				<actualiza>
   					<field id="detalle_movimientos" destino="provincia" />
   					<field id="detalle_alicuota" destino="provincia" />
   					<field id="detalle_conceptos" destino="provincia" />
   					<field id="detalle_tipo_afip" destino="provincia" />
            <field id="detalle_tipo_afip_alicuota" destino="provincia" />
   				</actualiza>
			</field>

			<field id="separador1" local="true" colspan="8" deshabilitado="true" style="height:2px;" print="false" export="false" />

			<field id="titulos_movimientos" local="true" colspan="8" deshabilitado="true" style="font-weight: bold; color: #fff; background-color: #000; font-size: 13px;" PDFbackgroundColor="#000" PDFcolor="#fff" PDFnoborder="true" PDFbold="true" >
                <label posX="5" posY="+2" />
                <valor>DETALLE DE COMPROBANTES</valor>
                <size>50</size>
            </field>

            <field id="detalle_movimientos" local="true" colspan="8">
                <label posX="5" posY="+1" />
                <helper type="object" xml="movimientos_iva_ventas_qry.xml" />
            </field>

			<field id="separador2" local="true" colspan="8" deshabilitado="true" style="height:2px;" print="false" export="false" />

            <field id="titulos_alicuotas" local="true" colspan="8" deshabilitado="true" style="font-weight: bold; color: #fff; background-color: #000; font-size: 13px;" PDFbackgroundColor="#000" PDFcolor="#fff" PDFnoborder="true" PDFbold="true" >
                <label posX="5" posY="+2" />
                <valor>RESUMEN POR ALICUOTAS</valor>
                <size>50</size>
            </field>

            <field id="detalle_alicuota" local="true" colspan="8">
                <label posX="5" posY="+1" />
                <helper type="object" xml="alicuotas_iva_ventas_qry.xml" />
            </field>

			<field id="separador3" local="true" colspan="8" deshabilitado="true" style="height:2px;" print="false" export="false" />

            <field id="titulos_conceptos" local="true" colspan="8" deshabilitado="true" style="font-weight: bold; color: #fff; background-color: #000; font-size: 13px;" PDFbackgroundColor="#000" PDFcolor="#fff" PDFnoborder="true" PDFbold="true" >
                <label posX="5" posY="+2" />
                <valor>RESUMEN POR CONCEPTOS</valor>
                <size>50</size>
            </field>

            <field id="detalle_conceptos" local="true" colspan="8">
                <label posX="5" posY="+1" />
                <helper type="object" xml="conceptos_iva_ventas_qry.xml" />
            </field>

			<field id="separador4" local="true" colspan="8" deshabilitado="true" style="height:2px;" print="false" export="false" />

            <field id="titulos_tipo_afip" local="true" colspan="8" deshabilitado="true" style="font-weight: bold; color: #fff; background-color: #000; font-size: 13px;" PDFbackgroundColor="#000" PDFcolor="#fff" PDFnoborder="true" PDFbold="true" >
                <label posX="5" posY="+2" />
                <valor>RESUMEN POR BIENES / SERVICIOS</valor>
                <size>50</size>
            </field>

            <field id="detalle_tipo_afip" local="true" colspan="8">
                <label posX="5" posY="+1" />
                <helper type="object" xml="tipo_iva_ventas_qry.xml" />
            </field>

      <field id="separador5" local="true" colspan="8" deshabilitado="true" style="height:2px;" print="false" export="false" />

            <field id="titulos_tipo_afip_alicuota" local="true" colspan="8" deshabilitado="true" style="font-weight: bold; color: #fff; background-color: #000; font-size: 13px;" PDFbackgroundColor="#000" PDFcolor="#fff" PDFnoborder="true" PDFbold="true" >
                <label posX="5" posY="+2" />
                <valor>RESUMEN POR BIENES / SERVICIOS Y ALICUOTAS</valor>
                <size>50</size>
            </field>

            <field id="detalle_tipo_afip_alicuota" local="true" colspan="8">
                <label posX="5" posY="+1" />
                <helper type="object" xml="tipo_alicuota_iva_ventas_qry.xml" />
            </field>

			<field id="titulo_impresion" local="true" noshow="true" print="false" export="false">
				<setvar>titulo_div</setvar>
				<size>80</size>
			</field>
			
		</table>			
	</form>
</histrix>