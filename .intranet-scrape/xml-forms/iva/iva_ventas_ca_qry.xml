<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" margintabs="true" PDForientacion="L">
  <title>IVA VENTAS</title>
  <obs/>
  <form >
    <table id="REG_MOVIMIENTOS" label="IVA VENTAS" _styleTbody="height:300px;overflow-x:hidden;">
      
      <field id="id_regmovim" esClave="true" noshow="true" />
      
      <field id="reg_fecha" oculto="true">
        <label>Registrado</label>
        <help></help>
      </field>
      
      <field id="numero_cae" noshow="true">
	        <condicion operador="!=">''</condicion>
      </field>

      <field id="fecha_movimiento">
        <label>Fecha</label>
        <help></help>
      </field>

      <field id="puesto_movimiento" oculto="true">
        <label>Puesto1</label>
        <help></help>
      </field>
      
      <field id="puesto_movimiento" noshow="true">
        <label>Puesto</label>
        <help></help>
      </field>
      
      <field id="regcuenta_id" noshow="true">
        <label>Cta1</label>
        <size>10</size>
      </field>
      
      <field id="concepto_id" noshow="true">
        <label>Comprobante</label>
        <help></help>
        <tabla_ex id="REG_CONCEPTOS" vacio="true">
          <field id="id_concepto"/>
          <field id="descripcion_concepto"/>
          <field id="subsistema_id">
            <condicion operador="=">'02'</condicion>
          </field>
          <field id="tipo_concepto">
            <condicion operador="=">1</condicion>
          </field>
        </tabla_ex>
      </field>
      <field id="tipo_concepto" tabla="REG_CONCEPTOS" noshow="true">
        <condicion operador="=">1</condicion>
      </field>
      <field id="subsistema_id" noshow="true">
        <label>subsistema</label>
        <condicion operador="=">'21' or REG_MOVIMIENTOS.subsistema_id = '02'</condicion>
      </field>
      <field id="nro_movimiento" _linkint="reg_detalles_qry.xml" _linkdir="/cuentas" _linkdes="Ver detalle del Comprobante">
        <expression>
          CONCAT(REG_CONCEPTOS.abreviacion_concepto,' ', letra_movimiento,' ',LPAD(puesto_movimiento,4,'0'),'-',LPAD(nro_movimiento,8,'0'))
        </expression>
        <label _style="font-size:8px;">Nro Comprobante</label>
      </field>
      <field id="nombre_cuenta" tabla="REG_CUENTA">
        <expression>
          case when nombre_movimiento != '' then nombre_movimiento else nombre_cuenta end
        </expression>
        <label>Razon Social</label>
      </field>
      <field id="iva_id" tabla="REG_CUENTA">
        <label>Categoria</label>
        <tabla_ex id="GEN_IVA">
          <field id="id_iva"/>
          <field id="abreviacion_iva"/>
        </tabla_ex>
      </field>
      <field id="cuit_cuenta" tabla="REG_CUENTA">
        <label>CUIT</label>
        <expression>
          case when nombre_movimiento = 'ANULADA' then cuit_movimiento else cuit_cuenta end
        </expression>
      </field>
      <field id="neto_movimiento" suma="true" noZero="true">
        <label>Imp. Gravado</label>
        <expression>
          neto_movimiento * (case when imputacion_concepto = 1 then -1 else 1 end)
        </expression>
        <tipo>numeric</tipo>
      </field>
      <field id="mult" local="true" noshow="true">
        <expression>(case when imputacion_concepto = 1 then -1 else 1 end)</expression>
      </field>
      <field id="importe_iva" local="true" _norepeat="true" suma="true"  _local="true" noZero="true">
        <label>IVA</label>
        <expression>
          importe_iva * (case when imputacion_concepto = 1 then -1 else 1 end)
        </expression>
        <tipo>numeric</tipo>
      </field>
      <field id="percepcion" local="true" _norepeat="true" suma="true"  _local="true"  noZero="true">
        <label>Percepcion</label>
        <expression>
          importe_percepcion * (case when imputacion_concepto = 1 then -1 else 1 end)
        </expression>
        <tipo>numeric</tipo>
      </field>
      <field id="importe_exento" norepeat="true" suma="true"  noZero="true">
        <expression>
          importe_exento * (case when imputacion_concepto = 1 then -1 else 1 end)
        </expression>
        <label>Exento</label>
        <tipo>numeric</tipo>
      </field>
      <field id="impmi" norepeat="true" suma="true" noZero="true">
        <expression>
          importe_percepcion * (case when imputacion_concepto = 1 then -1 else 1 end)
        </expression>
        <label>Monotributo</label>
        <tipo>numeric</tipo>
      </field>
      <!--      
        <field id="totcom" norepeat="true" suma="true">
      <label>Total</label>
    </field>
    -->
    <field id="importe_movimiento" _norepeat="true" suma="true"  _local="true" noZero="true">
      <expression>
        importe_movimiento * (case when imputacion_concepto = 1 then -1 else 1 end)
      </expression>
      <label>Total</label>
      <tipo>numeric</tipo>
    </field>
    <field id="provincia_id" tabla="REG_CUENTA" colstyle="display:none;">
      <label>Provincia</label>
      <helper type="combo" xml="provincia_qry.xml" dir="/ayudas" empty="true"/>
      <tipo>varchar</tipo>
    </field>
    <field id="titulo" local="true" oculto="true" print="false">
      <valor>Libro IVA Ventas</valor>
      <setvar>titulo_div</setvar>
    </field>
    <group>
      <field id="id_regmovim"></field>
    </group>
    <order>
      <field id="REG_MOVIMIENTOS.reg_fecha" />
      <field id="REG_MOVIMIENTOS.puesto_movimiento" />
      <field id="REG_MOVIMIENTOS.nro_movimiento" />
    </order>
    <filters>
      <field id="fecha_movimiento">
        <operador>&gt;=</operador>
        <label>Desde Fecha</label>
        <valor>today</valor>
      </field>
      <field id="fecha_movimiento">
        <operador>&lt;=</operador>
        <label modpos="nobr">Hasta Fecha</label>
        <valor>today</valor>
      </field>
      <field id="puesto_movimiento">
        <operador>&gt;=</operador>
        <label>Desde Puesto</label>
      </field>
      <field id="puesto_movimiento">
        <operador>&lt;=</operador>
        <label modpos="nobr">Hasta Puesto</label>
      </field>
      <field id="concepto_id">
        <operador>=</operador>
        <label>Comprobante</label>
      </field>
      <field id="provincia_id">
        <operador>=</operador>
        <label modpos="nobr">Provincia</label>
      </field>
    </filters>
  </table>
  <join tipo="left">
    <table id="REG_CONCEPTOS">
      <field id="id_concepto">
        <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
      </field>
    </table>
  </join>
  <join tipo="left">
    <table id="REG_CUENTA">
      <field id="id_regcuenta">
        <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
      </field>
    </table>
  </join>
</form>
</histrix>