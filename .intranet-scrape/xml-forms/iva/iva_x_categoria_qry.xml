<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" margintabs="true">
  <title>IVA COMPRAS</title>
  <obs/>
  <consulta>
    <table id="REG_MOVIMIENTOS" label="Total por categoria" styleTbody="height:300px;overflow-x:hidden;">
      <field id="reg_fecha" oculto="true">
        <label>Registrado</label>
        <help></help>
      </field>
      <field id="reg_fecha" noshow="true">
        <label modpos="nobr">Fecha</label>
        <help></help>
      </field>
    
    
      <field id="id_regmovim" esClave="true" noshow="true">
        <label>movimiento</label>
        
      </field>
     
      <field id="subsistema_id" noshow="true">
	<label>subsistema</label>
	<condicion operador="=">'01'</condicion>
      </field>


      <field id="regcuenta_id" noshow="true">
        <label>Cta</label>
      </field>
       
     <field id="iva_id" tabla="REG_CUENTA">
        <label>iva</label>
	<tabla_ex id="GEN_IVA">
	   <field id="id_iva"/>
	    <field id="nombre_iva"/>
	</tabla_ex>
      </field>
