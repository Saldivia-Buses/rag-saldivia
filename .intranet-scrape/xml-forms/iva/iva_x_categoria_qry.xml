	 <field id="neto_movimiento" suma="true" >
         <label>Imp. Gravado</label>
    <expresion>CASE WHEN concepto_id= 3 or concepto_id=2 THEN SUM(neto_movimiento * -1) else SUM(neto_movimiento) END</expresion>
	 <tipo>numeric</tipo>
      </field>
     
      <field id="importe_iva" local="true" retroalimenta="true" suma="true"  _local="true">
          <label>IVA</label>
	  <expresion>SUM(REG_DETALLES.iva_detalle)</expresion>
	  <tipo>numeric</tipo>
      </field>
     
     
    
      <field id="percepcion" local="true" _norepeat="true" suma="true"  _local="true">
        <label>Percepcion</label>
	<expresion>SUM(REG_DETALLES.total_percepcion)</expresion>
	<tipo>numeric</tipo>
      </field>
     
    
                                                                <!--
      <field id="impmi" norepeat="true" suma="true">
	<expresion>CASE WHEN concepto_id= 3 or concepto_id=2 THEN impmi * -1 else impmi END</expresion>
        <label>Importe Monotributo</label>
        <tipo>numeric</tipo>
        
      </field>
      
      -->
      
       <field id="impexe" norepeat="true" suma="true">
	<expresion>CASE WHEN concepto_id= 3 or concepto_id=2 THEN importe_exento * -1 else importe_exento END</expresion>
        <label>Importe Exento</label>
        <tipo>numeric</tipo>
      </field>
      <field id="importe_movimiento" _norepeat="true" suma="true"  _local="true">
       <expresion>SUM(REG_DETALLES.total_detalle)</expresion>
        <label>Importe Total</label>
	<tipo>numeric</tipo>
      </field>

        <group>
	     <field id="iva_id" tabla="REG_CUENTA"/> 
	   
        </group>
            
