<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="ing" inserta="false" modifica="false" borra="false" deleteRow="false" procesa="false" tableHeight="100%">
	<title />
	<obs/>
	<form>
		<table id="REG_MOVIMIENTOS">

			<fieldGroup noshow="true">
				<field id="id_regmovim" esClave="true" />

				<field id="subsistema_id" />

				<field id="regcuenta_id" />

				<field id="iva_subsistema" tabla="GEN_SUBSISTEMAS" />

				<field id="concepto_id">
					<condicion operador="=">(CASE WHEN IFNULL('[__concepto__]', 0) = 0 THEN REG_MOVIMIENTOS.concepto_id ELSE '[__concepto__]' END)</condicion>
				</field>

				<field id="concepto" local="true" />

				<field id="letra_movimiento">
					<condicion operador="=">(CASE WHEN IFNULL('[__letra__]', 0) = 0 THEN REG_MOVIMIENTOS.letra_movimiento ELSE '[__letra__]' END)</condicion>
				</field>

				<field id="letra" local="true" />

				<field id="imprime_concepto1">
					<expresion>IFNULL(REG_NUMERADORES.ejecuta,'')</expresion>
				</field>

				<field id="desde_fecha" local="true">
					<tipo>date</tipo>
				</field>

				<field id="hasta_fecha" local="true">
					<tipo>date</tipo>
				</field>

				<field id="tip_fecha" local="true" />

				<field id="filtro_fecha">
					<expression>IF('[__tip_fecha__]' = 0, reg_fecha, fecha_movimiento)</expression>				
					<tipo>date</tipo>
	   				<condicion operador="&gt;=">STR_TO_DATE('[__desde_fecha__]', '%d/%m/%Y') AND IF('[__tip_fecha__]' = 0, REG_MOVIMIENTOS.reg_fecha, REG_MOVIMIENTOS.fecha_movimiento) &lt;= STR_TO_DATE('[__hasta_fecha__]', '%d/%m/%Y')</condicion>
				</field>

				<field id="desde_puesto" local="true" />
				
				<field id="hasta_puesto" local="true" />
				
				<field id="puesto_movimiento">
					<condicion operador="&gt;=">'[__desde_puesto__]' AND REG_MOVIMIENTOS.puesto_movimiento &lt;= '[__hasta_puesto__]'</condicion>
				</field>
			</fieldGroup>

			<fieldGroup>
				<field id="reg_fecha">
					<label>Registrado</label>
					<tipo>date</tipo>
				</field>

				<field id="fecha_movimiento">
					<label>Fecha</label>
					<tipo>date</tipo>
				</field>

				<field id="nro_movimiento">
					<expression>CONCAT(REG_CONCEPTOS.abreviacion_concepto,' ', letra_movimiento,' ',LPAD(puesto_movimiento,4,'0'),'-',LPAD(nro_movimiento,8,'0'))</expression>
					<label>Nro Comprobante</label>
					<helper type="link">
						<parameter source="id_regmovim" target="id_regmovim" />
					</helper>
					<attribute id="linkint">imprime_concepto1</attribute>
					<tipo>varchar</tipo>
				</field>
		  
				<field id="nombre_cuenta">
					<expression>CASE WHEN REG_MOVIMIENTOS.nombre_movimiento != '' THEN REG_MOVIMIENTOS.nombre_movimiento ELSE REG_CUENTA.nombre_cuenta END</expression>
					<label>Razon Social</label>
				</field>

				<field id="iva_id">
					<label>Categoria</label>
					<helper type="combo" id="GEN_IVA" empty="true">
						<field id="id_iva"/>
						<field id="abreviacion_iva"/>
					</helper>
					<tipo>varchar</tipo>
				</field>

				<field id="cuit_cuenta">
					<label>CUIT</label>
					<expression>IF(REG_MOVIMIENTOS.cuit_movimiento != '', REG_MOVIMIENTOS.cuit_movimiento, REG_CUENTA.cuit_cuenta)</expression>
				</field>

				<field id="neto_movimiento" suma="true" noZero="true">
					<label>Imp. Gravado</label>
					<expression>REG_MOVIMIENTOS.neto_movimiento * (CASE WHEN GEN_SUBSISTEMAS.iva_subsistema = 1 THEN IF(imputacion_concepto = 0, 1, -1) ELSE IF(imputacion_concepto = 0, -1, 1) END)</expression>
					<tipo>custom_numeric</tipo>
				</field>

				<field id="importe_iva" suma="true" noZero="true">
					<label>IVA</label>
					<expression>REG_MOVIMIENTOS.importe_iva * (CASE WHEN GEN_SUBSISTEMAS.iva_subsistema = 1 THEN IF(imputacion_concepto = 0, 1, -1) ELSE IF(imputacion_concepto = 0, -1, 1) END)</expression>
					<tipo>custom_numeric</tipo>
				</field>

				<field id="percepcion" suma="true" noZero="true">
					<label>Percepcion</label>
					<expression>REG_MOVIMIENTOS.importe_percepcion * (CASE WHEN GEN_SUBSISTEMAS.iva_subsistema = 1 THEN IF(imputacion_concepto = 0, 1, -1) ELSE IF(imputacion_concepto = 0, -1, 1) END)</expression>
					<tipo>custom_numeric</tipo>
				</field>

				<field id="importe_exento" suma="true" noZero="true">
					<expression>REG_MOVIMIENTOS.importe_exento * (CASE WHEN GEN_SUBSISTEMAS.iva_subsistema = 1 THEN IF(imputacion_concepto = 0, 1, -1) ELSE IF(imputacion_concepto = 0, -1, 1) END)</expression>
					<label>Exento</label>
					<tipo>custom_numeric</tipo>
				</field>

				<field id="importe_ibr" suma="true" noZero="true">
					<expression>REG_MOVIMIENTOS.importe_ibr * (CASE WHEN GEN_SUBSISTEMAS.iva_subsistema = 1 THEN IF(imputacion_concepto = 0, 1, -1) ELSE IF(imputacion_concepto = 0, -1, 1) END)</expression>
					<label>IBR</label>
					<tipo>custom_numeric</tipo>
				</field>

				<field id="importe_nogravado" suma="true" noZero="true">
					<expression>REG_MOVIMIENTOS.importe_nogravado * (CASE WHEN GEN_SUBSISTEMAS.iva_subsistema = 1 THEN IF(imputacion_concepto = 0, 1, -1) ELSE IF(imputacion_concepto = 0, -1, 1) END)</expression>
					<label>No Gravado</label>
					<tipo>custom_numeric</tipo>
				</field>

				<field id="importe_movimiento" suma="true" noZero="true">
					<expression>REG_MOVIMIENTOS.importe_movimiento * (CASE WHEN GEN_SUBSISTEMAS.iva_subsistema = 1 THEN IF(imputacion_concepto = 0, 1, -1) ELSE IF(imputacion_concepto = 0, -1, 1) END)</expression>
					<label>Total</label>
					<tipo>custom_numeric</tipo>
				</field>
			
				<field id="tiposervicio_afip">
					<label>Tipo</label>
					<helper type="combo" id="GEN_TIPO_SERVICIO_AFIP" empty="true">
						<field id="id_tiposervicio" />
						<field id="nombre_tiposervicio" />
					</helper>
					<expression having="false">IFNULL(REG_MOVIMIENTOS.tiposervicio_afip, 0)</expression>
					<condicion operador="=">(CASE WHEN IFNULL('[__tiposervicio__]', 0) = 0  OR '[__tiposervicio__]' = '' THEN IFNULL(REG_MOVIMIENTOS.tiposervicio_afip, 0) ELSE '[__tiposervicio__]' END)</condicion>
					<tipo>varchar</tipo>
				</field>

				<field id="tiposervicio" noshow="true" local="true" />

				<field id="provincia_id" tabla="REG_CUENTA">
					<label>Provincia</label>
					<helper type="combo" xml="provincia_qry.xml" dir="/ayudas" empty="true" />
					<condicion operador="=">(CASE WHEN IFNULL('[__provincia__]', 0) = 0 THEN REG_CUENTA.provincia_id ELSE '[__provincia__]' END)</condicion>
				</field>

				<field id="provincia" noshow="true" local="true" />

				<field id="asiento" print="false" noshow="true">
					<label>Asiento</label>
					<helper type="link" xml="minuta_ficha_qry.xml" dir="/contabilidad/qry" title="Asiento contable">
						<parameter source="id_regmovim" target="regmovim_id" />
					</helper>
					<expression>(SELECT nro_minuta FROM CTB_MOVIMIENTOS WHERE regmovim_id = REG_MOVIMIENTOS.id_regmovim LIMIT 1)</expression>
					<attribute id="noshow">modulocontable</attribute>
				</field>

				<field id="modulocontable" local="true" noshow="true">
					<valor eval="true">(strpos($_SESSION['properties']['modulos'],'contabilidad') != false ? 'false' : 'true' )</valor>
				</field>
			</fieldGroup>

			<group>
				<field id="id_regmovim" />
			</group>

			<order>
				<field id="filtro_fecha" />
				<field id="puesto_movimiento" />
				<field id="letra_movimiento" />
				<field id="nro_movimiento" />
			</order>

		</table>

		<join>
			<table id="GEN_SUBSISTEMAS">
				<field id="id_subsistema">
					<condicion operador="=">REG_MOVIMIENTOS.subsistema_id</condicion>
				</field>				
			</table>
		</join>

		<join>
			<table id="REG_CONCEPTOS">
				<field id="id_concepto">
					<condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
				</field>
				<field id="tipo_concepto">
					<condicion operador="=">1</condicion>
				</field>
			</table>
		</join>

		<join>
			<table id="REG_CUENTA">
				<field id="id_regcuenta">
					<condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
				</field>
			</table>
		</join>

		<join tipo="left">
			<table id="REG_NUMERADORES">
				<field id="subsistema_id">
					<condicion operador="=">REG_MOVIMIENTOS.subsistema_id</condicion>
				</field>
				<field id="regconcepto_id">
					<condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
				</field>
				<field id="puesto">
					<condicion operador="=">REG_MOVIMIENTOS.puesto_movimiento</condicion>
				</field>
				<field id="letra">
					<condicion operador="=">REG_MOVIMIENTOS.letra_movimiento</condicion>
				</field>
			</table>
		</join>

	</form>
</histrix>