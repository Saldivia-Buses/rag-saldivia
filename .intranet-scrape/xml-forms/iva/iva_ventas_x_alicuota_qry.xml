<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" margintabs="true" PDForientacion="L">
	<title>IVA VENTAS</title>
	<obs/>
	<form >
		<table id="REG_MOVIMIENTOS" label="IVA VENTAS">

		<fieldGroup noshow="true">

			<field id="id_regmovim" esClave="true" noshow="true" />

			<field id="subsistema_id" noshow="true" />

			<field id="puesto_movimiento" noshow="true" />

			<field id="bonificaciones_movimiento" noshow="true" />

			<field id="regcuenta_id" noshow="true" />
			
			<field id="imprime_concepto1" noshow="true">
				<expresion>IFNULL(REG_NUMERADORES.ejecuta,'')</expresion>
			</field>

			<field id="concepto_id" noshow="true">
				<label>Comprobante</label>
				<help/>
				<tabla_ex id="REG_CONCEPTOS" vacio="true">
					<field id="id_concepto"/>
					<field id="descripcion_concepto"/>
					<field id="subsistema_id">
						<condicion operador="=">'02'</condicion>
					</field>
					<field id="tipo_concepto">
						<condicion operador="=">1</condicion>
					</field>
				</tabla_ex>
			</field>

			<field id="puesto_movimiento" noshow="true" />

			<field id="letra_movimiento" noshow="true">
				<helper type="combo">
				    <option value=""/>
				    <option value="A">A</option>
				    <option value="B">B</option>
				    <option value="C">C</option>
				    <option value="M">M</option>
				    <option value="E">E</option>
				    <option value="X">X</option>
				</helper>
				<size>5</size>
			</field>

		</fieldGroup>


		<fieldGroup colstyle="text-align:center;padding:2px 2px 2px 2px !important;">

			<field id="reg_fecha">
				<label>Registrado</label>
			</field>

			<field id="fecha_movimiento">
				<label>Fecha</label>
			</field>

			<field id="nro_movimiento">
				<expression>CONCAT(REG_CONCEPTOS.abreviacion_concepto,' ', letra_movimiento,' ',LPAD(puesto_movimiento,4,'0'),'-',LPAD(nro_movimiento,8,'0'))</expression>
				<label>Nro Comprobante</label>
				<helper type="link">
					<parameter source="id_regmovim" target="id_regmovim" />
				</helper>
				<attribute id="linkint">imprime_concepto1</attribute>
			</field>
	  
			<field id="nombre_cuenta">
				<expression>case when nombre_movimiento != '' then nombre_movimiento else REG_CUENTA.nombre_cuenta end</expression>
				<label>Razon Social</label>
			</field>

			<field id="iva_id">
				<label>Categoria</label>
				<tabla_ex id="GEN_IVA">
					<field id="id_iva"/>
					<field id="abreviacion_iva"/>
				</tabla_ex>
			</field>

			<field id="cuit_cuenta">
				<label>CUIT</label>
				<expression>CASE WHEN nombre_movimiento != 'ANULADA' THEN IF(cuit_movimiento != '',  cuit_movimiento, REG_CUENTA.cuit_cuenta) ELSE '' END</expression>
			</field>

			<field id="neto_movimiento" suma="true" noZero="true">
				<label>Imp. Gravado</label>
				<expression>neto_movimiento * IF(imputacion_concepto = 0, 1, -1)</expression>
				<tipo>numeric</tipo>
			</field>

			<field id="mult" local="true" noshow="true">
				<expression>IF(imputacion_concepto = 0, 1, -1)</expression>
			</field>

			<!-- DETALLE -->
            <field id="neto_iva_10" local="true" suma="true" noZero="true">
                <label>NETO 10,5%</label>
                <expression sql="true">select ((CASE WHEN '[__bonificaciones_movimiento__]' = 0 THEN SUM(neto_detalle) ELSE (SUM(neto_detalle) - ((SUM(neto_detalle * '[__bonificaciones_movimiento__]') / 100))) END) * '[__mult__]') from REG_DETALLES where alicuota_iva = '10.50' and regmovim_id = '[__id_regmovim__]'</expression>
                <tipo>numeric</tipo>
            </field>
            <field id="neto_iva_21" local="true" suma="true" noZero="true">
                <label>NETO 21%</label>
                <expression sql="true">select ((CASE WHEN '[__bonificaciones_movimiento__]' = 0 THEN SUM(neto_detalle) ELSE (SUM(neto_detalle) - ((SUM(neto_detalle * '[__bonificaciones_movimiento__]') / 100))) END) * '[__mult__]') from REG_DETALLES where alicuota_iva = '21.00' and regmovim_id = '[__id_regmovim__]'</expression>
                <tipo>numeric</tipo>
            </field>
            <field id="neto_iva_27" local="true" _norepeat="true" suma="true"  _local="true" noZero="true">
                <label>NETO 27%</label>
                <expression sql="true">SELECT ((CASE WHEN '[__bonificaciones_movimiento__]' = 0 THEN SUM(neto_detalle) ELSE (SUM(neto_detalle) - ((SUM(neto_detalle * '[__bonificaciones_movimiento__]') / 100))) END) * '[__mult__]') from REG_DETALLES where alicuota_iva = '27.00' and regmovim_id = '[__id_regmovim__]'</expression>
                <tipo>numeric</tipo>
            </field>
            <field id="importe_iva_10" local="true" suma="true" noZero="true">
                <label>IVA 10,5%</label>
                <expression sql="true">select ((CASE WHEN '[__bonificaciones_movimiento__]' = 0 THEN SUM(iva_detalle) ELSE (SUM(iva_detalle) - ((SUM(iva_detalle * '[__bonificaciones_movimiento__]') / 100))) END) * '[__mult__]') from REG_DETALLES where alicuota_iva = '10.50' and regmovim_id = '[__id_regmovim__]'</expression>
                <tipo>numeric</tipo>
            </field>
            <field id="importe_iva_21" local="true" suma="true" noZero="true">
                <label>IVA 21%</label>
                <expression sql="true">select ((CASE WHEN '[__bonificaciones_movimiento__]' = 0 THEN SUM(iva_detalle) ELSE (SUM(iva_detalle) - ((SUM(iva_detalle * '[__bonificaciones_movimiento__]') / 100))) END) * '[__mult__]') from REG_DETALLES where alicuota_iva = '21.00' and regmovim_id = '[__id_regmovim__]'</expression>
                <tipo>numeric</tipo>
            </field>
            <field id="importe_iva_27" local="true" _norepeat="true" suma="true"  _local="true" noZero="true">
                <label>IVA 27%</label>
                <expression sql="true">SELECT ((CASE WHEN '[__bonificaciones_movimiento__]' = 0 THEN SUM(iva_detalle) ELSE (SUM(iva_detalle) - ((SUM(iva_detalle * '[__bonificaciones_movimiento__]') / 100))) END) * '[__mult__]') from REG_DETALLES where alicuota_iva = '27.00' and regmovim_id = '[__id_regmovim__]'</expression>
                <tipo>numeric</tipo>
            </field>

			<field id="percepcion" local="true" _norepeat="true" suma="true"  _local="true"  noZero="true">
				<label>Percepcion</label>
				<expression>SUM(REG_DETALLES.total_percepcion) * IF(imputacion_concepto = 0, 1, -1)</expression>
				<tipo>numeric</tipo>
			</field>

			<field id="importe_exento" norepeat="true" suma="true"  noZero="true">
				<expression>importe_exento * IF(imputacion_concepto = 0, 1, -1)</expression>
				<label>Exento</label>
				<tipo>numeric</tipo>
			</field>

			<field id="impmi" norepeat="true" suma="true" noZero="true">
				<expression>importe_percepcion * IF(imputacion_concepto = 0, 1, -1)</expression>
				<label>Monotributo</label>
				<tipo>numeric</tipo>
			</field>

			<field id="importe_movimiento" suma="true" noZero="true">
				<expression>importe_movimiento * (case when imputacion_concepto = 1 then -1 else 1 end)</expression>
				<label>Total</label>
				<tipo>numeric</tipo>
			</field>
			
			<field id="tiposervicio_afip">
				<label>Tipo</label>
				<helper type="combo">
					<option value="">Todos</option>
					<option value="1">Bienes</option>
					<option value="2">Servicios</option>
					<option value="3">Bienes/Servicios</option>
				</helper>
			</field>

			<field id="provincia_id" tabla="REG_CUENTA">
				<label>Provincia</label>
				<helper type="combo" xml="provincia_qry.xml" dir="/ayudas" empty="true"/>
				<tipo>varchar</tipo>
			</field>

			<field id="asiento" print="false" noshow="true">
				<label>Asiento</label>
				<helper type="link" xml="minuta_ficha_qry.xml" dir="/contabilidad/qry" title="Asiento contable">
					<parameter source="id_regmovim" target="regmovim_id" />
				</helper>
				<expression>(SELECT nro_minuta FROM CTB_MOVIMIENTOS WHERE regmovim_id = REG_MOVIMIENTOS.id_regmovim LIMIT 1)</expression>
				<attribute id="noshow">modulocontable</attribute>
			</field>

			<field id="titulo" local="true" oculto="true" print="false">
				<valor>Libro IVA Ventas</valor>
				<setvar>titulo_div</setvar>
			</field>

			<field id="tip_fecha" local="true" oculto="true" print="false">
				<label></label>
				<helper type="combo">
					<option value="0">Registracion</option>
					<option value="1">Comprobante</option>
				</helper>
			</field>

			<field id="filtro_fecha" noshow="true" print="false">
				<expression>IF('[__tip_fecha__]' = 0, reg_fecha, fecha_movimiento)</expression>
				<tipo>date</tipo>
			</field>

			<field id="modulocontable" local="true" noshow="true">
				<valor eval="true">(strpos($_SESSION['properties']['modulos'],'contabilidad') != false ? 'false' : 'true' )</valor>
			</field>

		</fieldGroup>

			<group>
				<field id="id_regmovim"/>
			</group>

			<order>
				<field id="filtro_fecha" />
				<field id="puesto_movimiento" />
				<field id="letra_movimiento" />
				<field id="nro_movimiento" />
			</order>

			<filters>
			
				
				<field id="tip_fecha">
					<operador>=</operador>
					<label>Filtrar Fecha por</label>
				</field>
				<field id="filtro_fecha" deshabilitado="false">
					<operador>&gt;=</operador>
					<label  modpos="nobr">Desde Fecha</label>
					<valor>today</valor>
				</field>
				<field id="filtro_fecha" deshabilitado="false">
					<operador>&lt;=</operador>
					<label modpos="nobr">Hasta Fecha</label>
					<valor>today</valor>
				</field>

				
				<field id="puesto_movimiento">
					<operador>&gt;=</operador>
					<label>Desde Puesto</label>
				</field>
				<field id="puesto_movimiento">
					<operador>&lt;=</operador>
					<label modpos="nobr">Hasta Puesto</label>
				</field>
				<field id="letra_movimiento">
					<operador>=</operador>
					<label modpos="nobr">Letra</label>
				</field>
				<field id="concepto_id">
					<operador>=</operador>
					<label>Comprobante</label>
				</field>
				
				<field id="tiposervicio_afip">
					<label modpos="nobr">Tipo</label>
					<operador>=</operador>
				</field>
				
				<field id="provincia_id">
					<operador>=</operador>
					<label modpos="nobr">Provincia</label>
				</field>
			</filters>
		</table>

		<join>
			<table id="GEN_SUBSISTEMAS">
				<field id="id_subsistema">
					<condicion operador="=">REG_MOVIMIENTOS.subsistema_id</condicion>
				</field>			
				<field id="iva_subsistema">
					<condicion operador="=">1</condicion>
				</field>				
			</table>
		</join>

		<join>
			<table id="REG_CONCEPTOS">
				<field id="id_concepto">
					<condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
				</field>
				<field id="tipo_concepto">
					<condicion operador="=">1</condicion>
				</field>
			</table>
		</join>

		<join tipo="left">
			<table id="REG_CUENTA">
				<field id="id_regcuenta">
					<condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
				</field>
			</table>
		</join>

		<join tipo="left">
			<table id="REG_DETALLES">
				<field id="regmovim_id">
					<condicion operador="=">REG_MOVIMIENTOS.id_regmovim</condicion>
				</field>
			</table>
		</join>

		<join tipo="left">
			<table id="REG_NUMERADORES">
				<field id="subsistema_id">
					<condicion operador="=">REG_MOVIMIENTOS.subsistema_id</condicion>
				</field>
				<field id="regconcepto_id">
					<condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
				</field>
				<field id="puesto">
					<condicion operador="=">REG_MOVIMIENTOS.puesto_movimiento</condicion>
				</field>
				<field id="letra">
					<condicion operador="=">REG_MOVIMIENTOS.letra_movimiento</condicion>
				</field>
			</table>
		</join>

	</form>
</histrix>