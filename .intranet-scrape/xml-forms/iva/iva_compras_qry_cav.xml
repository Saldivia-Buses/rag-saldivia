			<!-- ESTA ES LA VERSION MAS NUEVA PERO TIENE ERRORES EN EL CALCULO DE IVA. SI SE MULTIPLICA EL TOTAL POR 0.21 ESTA MUY POR DEBAJO DE LO ESPERADO.
				CORREGIR!
             <field id="importe_iva_10" local="true" suma="true" noZero="true">
                <label>IVA 10,5%</label>
                <expression sql="true">select (iva_detalle * (case when '[__imputacion_concepto__]' = 0 then -1 else 1 end)) from REG_DETALLES where alicuota_iva = '10.50' and regmovim_id = '[__id_regmovim__]'</expression>
                <tipo>numeric</tipo>
            </field>

            <field id="importe_iva_21" local="true" suma="true" noZero="true">
                <label>IVA 21%</label>
                <expression sql="true">select (iva_detalle * (case when '[__imputacion_concepto__]' = 0 then -1 else 1 end)) from REG_DETALLES where alicuota_iva = '21.00' and regmovim_id = '[__id_regmovim__]'</expression>
                <tipo>numeric</tipo>
            </field>

            <field id="importe_iva_27" local="true" _norepeat="true" suma="true"  _local="true" noZero="true">
                <label>IVA 27%</label>
                <expression sql="true">select (iva_detalle * (case when '[__imputacion_concepto__]' = 0 then -1 else 1 end)) from REG_DETALLES where alicuota_iva = '27.00' and regmovim_id = '[__id_regmovim__]'</expression>
                <tipo>numeric</tipo>
            </field> -->
            <!-- HASTA AQUI LA VERSION NUEVA -->

			
			<group>
				<field id="id_regmovim"/>
			</group>
			
			<order>

				<!-- <field id="reg_fecha" /> -->
				<field id="fecha_movimiento" />
				<!--<field id="filtro_fecha" />
				<field id="puesto_movimiento" />
				<field id="letra_movimiento" /> -->
				<field id="nro_movimiento" />
			</order>

		</table>
		
		<join>
			<table id="GEN_SUBSISTEMAS">
				<field id="id_subsistema">
					<condicion operador="=">REG_MOVIMIENTOS.subsistema_id</condicion>
				</field>
				<field id="iva_subsistema">
					<condicion operador="=">2</condicion>
				</field>
			</table>
		</join>
		
		<join>
			<table id="REG_CONCEPTOS">
				<field id="id_concepto">
					<condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
				</field>
			</table>
		</join>
		
		<join tipo="left">
			<table id="REG_CUENTA">
				<field id="id_regcuenta">
					<condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
				</field>
			</table>
		</join>
		
		<join tipo="left">
			<table id="REG_DETALLES">
				<field id="regmovim_id">
					<condicion operador="=">REG_MOVIMIENTOS.id_regmovim</condicion>
				</field>
			</table>
		</join>
	</form>
</histrix>