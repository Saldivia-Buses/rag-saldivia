				<label>10,5 %</label>
				<expression>select SUM(REG_DET.iva_detalle) * (case when imputacion_concepto = 0 then -1 else 1 end) from REG_DETALLES  REG_DET where REG_DET.regmovim_id = id_regmovim AND REG_DET.alicuota_iva = 10.5</expression>
