				<label>21 %</label>
				<expression>(case when (select SUM(REG_DET.iva_detalle) from REG_DETALLES as REG_DET where REG_DET.regmovim_id = id_regmovim and REG_DET.alicuota_iva = 21) != 0 then (select SUM(REG_DET.iva_detalle) from REG_DETALLES as REG_DET where REG_DET.regmovim_id = id_regmovim and REG_DET.alicuota_iva = 21) else importe_iva * (case when REG_MOVIMIENTOS.alicuota_iva = 21 then 1 else 0 end) end) * (case when imputacion_concepto = 0 then -1 else 1 end)</expression>
				<tipo>numeric</tipo>
			</field>
