<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" margintabs="true" PDForientacion="L">
  <title>IVA VENTAS</title>
  <obs/>
  <form>
    <table id="REG_MOVIMIENTOS" label="IVA VENTAS">

        <field id="id_regmovim" esClave="true" noshow="true" />

        <field id="imputacion_concepto" tabla="REG_CONCEPTOS" noshow="true" />

        <field id="reg_fecha" oculto="true">
            <label>Registrado</label>
        </field>

        <field id="fecha_movimiento">
            <label>Fecha</label>
        </field>

        <field id="puesto_movimiento" oculto="true">
            <label>Puesto1</label>
        </field>

        <field id="puesto_movimiento" noshow="true">
            <label>Puesto</label>
        </field>

        <field id="regcuenta_id" noshow="true">
            <label>Cta1</label>
            <size>10</size>
        </field>

        <field id="concepto_id" _noshow="true">
            <label>Tipo Comp</label>
            <tabla_ex id="REG_CONCEPTOS" vacio="true">
                <field id="id_concepto"/>
                <field id="descripcion_concepto"/>
                <field id="subsistema_id">
                    <condicion operador="=">'02'</condicion>
                </field>
                <field id="tipo_concepto">
                    <condicion operador="=">1</condicion>
                </field>
            </tabla_ex>
        </field>

        <field id="tipo_concepto" tabla="REG_CONCEPTOS" noshow="true">
            <condicion operador="=">1</condicion>
        </field>

        <field id="subsistema_id" noshow="true">
            <label>subsistema</label>
            <condicion operador="=">'21' or REG_MOVIMIENTOS.subsistema_id = '02'</condicion>
        </field>

        <field id="letra_movimiento">
            <label>Letra</label>
        </field>

        <field id="puesto">
            <expression>LPAD(puesto_movimiento,4,'0')</expression>
            <label>Puesto</label>
        </field>

        <field id="numero">
            <expression>LPAD(nro_movimiento,8,'0')</expression>
            <label>Número</label>
        </field>

        <field id="nro_cuenta" tabla="REG_CUENTA">
            <label>Nro.Cuenta</label>
        </field>

        <field id="nombre_cuenta" tabla="REG_CUENTA">
            <expression>case when nombre_movimiento != '' then nombre_movimiento else REG_CUENTA.nombre_cuenta end</expression>
            <label>Razon Social</label>
        </field>

        <field id="regcategoria_id" tabla="REG_CUENTA">
            <label>Categoria</label>
            <helper type="combo" id="REG_CATEGORIAS">
                <field id="id_regcategoria" />
                <field id="nombre_Categoria" />
                <field id="subsistema_id" oculto="true">
                    <condicion operador="=">'02'</condicion>
                </field>
            </helper>
        </field>

        <field id="oculta_cmadre" local="true" noshow="true">
            <helper type="parameter" id="SIS::02::oculta_cuenta_madre">
                <label>Oculta columna de cuenta madre</label>
                <defaultValue>true</defaultValue>
            </helper>
        </field>

        <field id="nombre_admin">
            <label>C.Madre</label>
            <expression>ADMIN.nombre_cuenta</expression>
            <size>50</size>
            <attribute id="noshow">oculta_cmadre</attribute>
        </field>

        <field id="iva_id" tabla="REG_CUENTA">
            <label>Categoria</label>
            <tabla_ex id="GEN_IVA">
                <field id="id_iva"/>
                <field id="abreviacion_iva"/>
            </tabla_ex>
        </field>

        <field id="cuit_cuenta" tabla="REG_CUENTA">
            <label>CUIT</label>
            <expression>case when nombre_movimiento = 'ANULADA' then REPLACE(cuit_movimiento,'-', '') else REPLACE(REG_CUENTA.cuit_cuenta,'-', '') end</expression>
        </field>

        <field id="neto_movimiento" suma="true" noZero="true">
            <label>Imp. Gravado</label>
            <expression>((importe_movimiento * (case when imputacion_concepto = 1 then -1 else 1 end)) - (importe_exento * (case when imputacion_concepto = 1 then -1 else 1 end)) - (importe_iva * (case when imputacion_concepto = 1 then -1 else 1 end)))</expression>
            <tipo>numeric</tipo>
        </field>

        <field id="mult" local="true" noshow="true">
            <expression>(case when imputacion_concepto = 1 then -1 else 1 end)</expression>
        </field>

        <field id="importe_iva_10" local="true" suma="true" noZero="true">
            <label>IVA 10,5%</label>
            <!--<expression>case when GEN_IVA_ALICUOTAS.alicuota = '10.50' then (importe_iva * (case when imputacion_concepto = 1 then -1 else 1 end)) else '' end</expression>-->
            <expression sql="true">select sum(iva_detalle) * (case when '[__imputacion_concepto__]' = 1 then -1 else 1 end) from REG_DETALLES where regmovim_id = '[__id_regmovim__]' and alicuota_iva = '10.5' group by alicuota_iva</expression>
            <tipo>numeric</tipo>
        </field>

        <field id="importe_iva_21" local="true" suma="true" noZero="true">
            <label>IVA 21%</label>
            <expression sql="true">select sum(iva_detalle) * (case when '[__imputacion_concepto__]' = 1 then -1 else 1 end) from REG_DETALLES where regmovim_id = '[__id_regmovim__]' and alicuota_iva = '21' group by alicuota_iva</expression>
            <tipo>numeric</tipo>
        </field>

        <field id="importe_iva_27" local="true" suma="true" noZero="true">
            <label>IVA 27%</label>
            <expression sql="true">select sum(iva_detalle) * (case when '[__imputacion_concepto__]' = 1 then -1 else 1 end) from REG_DETALLES where regmovim_id = '[__id_regmovim__]' and alicuota_iva = '27' group by alicuota_iva</expression>
            <tipo>numeric</tipo>
        </field>

        <field id="percepcion" local="true" suma="true" noZero="true">
            <label>Percepcion</label>
            <expression>importe_percepcion * (case when imputacion_concepto = 1 then -1 else 1 end)</expression>
            <tipo>numeric</tipo>
        </field>

        <field id="importe_exento" norepeat="true" suma="true" noZero="true">
            <expression>importe_exento * (case when imputacion_concepto = 1 then -1 else 1 end)</expression>
            <label>Exento</label>
            <tipo>numeric</tipo>
        </field>

        <field id="impmi" norepeat="true" suma="true" noZero="true">
            <expression>importe_percepcion * (case when imputacion_concepto = 1 then -1 else 1 end)</expression>
            <label>Monotributo</label>
            <tipo>numeric</tipo>
        </field>

        <field id="importe_movimiento" suma="true" noZero="true">
            <expression>importe_movimiento * (case when imputacion_concepto = 1 then -1 else 1 end)</expression>
            <label>Total</label>
            <tipo>numeric</tipo>
        </field>

        <field id="provincia_id" tabla="REG_CUENTA" colstyle="display:none;">
            <label>Provincia</label>
            <helper type="combo" xml="provincia_qry.xml" dir="/ayudas" empty="true"/>
            <tipo>varchar</tipo>
        </field>

        <field id="titulo" local="true" oculto="true" print="false">
            <valor>Libro IVA Ventas</valor>
            <setvar>titulo_div</setvar>
        </field>

        <group>
            <field id="id_regmovim"></field>
        </group>

        <order>
            <field id="REG_MOVIMIENTOS.reg_fecha" />
            <field id="REG_MOVIMIENTOS.puesto_movimiento" />
            <field id="REG_MOVIMIENTOS.nro_movimiento" />
        </order>

        <filters>
            <field id="fecha_movimiento">
                <operador>&gt;=</operador>
                <label>Desde Fecha</label>
                <valor>today</valor>
            </field>
            <field id="fecha_movimiento">
                <operador>&lt;=</operador>
                <label modpos="nobr">Hasta Fecha</label>
                <valor>today</valor>
            </field>
            <field id="puesto_movimiento">
                <operador>&gt;=</operador>
                <label>Desde Puesto</label>
            </field>
            <field id="puesto_movimiento">
                <operador>&lt;=</operador>
                <label modpos="nobr">Hasta Puesto</label>
            </field>
            <field id="concepto_id">
                <operador>=</operador>
                <label>Comprobante</label>
            </field>
            <field id="provincia_id">
                <operador>=</operador>
                <label modpos="nobr">Provincia</label>
            </field>
        </filters>

    </table>

    <join>
        <table id="REG_CONCEPTOS">
            <field id="id_concepto">
                <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
            </field>
        </table>
    </join>

    <join>
        <table id="REG_CUENTA">
            <field id="id_regcuenta">
                <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
            </field>
        </table>
    </join>

    <join tipo="left">
        <table id="REG_CUENTA_RELACIONES">
            <field id="regcuenta_id">
                <condicion operador="=">id_regcuenta</condicion>
            </field>
        </table>
    </join>

    <join tipo="left">
        <table id="REG_CUENTA" as="ADMIN">
            <field id="id_regcuenta">
                <condicion operador="=">REG_CUENTA_RELACIONES.regcuentarelacionada_id</condicion>
            </field>
        </table>
    </join>

  </form>
</histrix>