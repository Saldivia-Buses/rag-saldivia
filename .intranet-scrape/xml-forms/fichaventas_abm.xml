  <field id="body" noshow="true">
    <expression><![CDATA[ CONCAT('Atención. Debajo le detallo los datos del cliente que solicitó/consultó alguno de sus productos, por favor comunicarse con el para confirmar su colocación.', '</br></br>',

'Nro. de Unidad: ', PEDCOTIZ.nrocha, '</br>', 'Modelo: ', (SELECT modcar FROM CARROCERIA where nrocar = PEDCOTIZ.nrocar), '</br>', 'Cliente: ', CCTCUENT.ctafan, '</br>', 'Contactos: ', '</br>', (SELECT REPLACE(
                      GROUP_CONCAT(
                            DISTINCT CONCAT(nombre, (CASE WHEN Telefono = '' THEN '' ELSE CONCAT(' - ', Telefono) END), (CASE WHEN mail = '' THEN '' ELSE CONCAT(' - ', mail) END)
                                    )
                            )
                      , ",", "</br>")
               FROM CCTCONTA WHERE ctacod = PEDCOTIZ.ctacod and CCTCONTA.siscod = '02' ORDER BY principal DESC))

    ]]></expression>
  </field>

  <field id="subject" noshow="true">
