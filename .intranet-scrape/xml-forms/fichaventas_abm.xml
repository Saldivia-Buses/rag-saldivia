      <field id="nrocha" esClave="true" tipoOrden="DESC" deshabilitado="false" _required="true" style="width:6em;">
        <helper id="CHASIS" type="external">
          <field id="nrocha"></field>
          <field id="desc">
              <expression having="false">CONCAT(nrocha, ' Chasis:', chasis ,' Motor:', nromotor)</expression>
          </field>
          <field id="marcod" oculto="true">
              <detalle>marcod</detalle> 
          </field>
          <field id="modcod">
              <label>Modelo</label>
              <detalle>modcod</detalle> 
          </field>    
        </helper>
        <label size="25" modpos="nobr" posx="110" posy="0" PDFsize="11">N.Fab.</label>
        <help>Numero de Fabricacion</help>
        <jseval>nrocha != 0</jseval>
        <valor>-1</valor>
        <size>6</size>
      </field>

      <field id="marcod" _local="true" deshabilitado="true">
        <expression>CHASIS.marcod</expression>
        <label colstyle="display:none;">Marca Chasis</label>
        <help>Marca del Chasis</help>
        <tabla_ex id="MARCHASIS" vacio="true">
          <field id="marcod" clave="true">
            <label>Codigo</label>
            <help>Codigo de Chasis</help>
          </field>
          <field id="mardes">
            <help>Abreviatura a Utilizar</help>
          </field>
        </tabla_ex>
        <actualiza>
          <field destino="marcod" id="modcod"/>
        </actualiza>      
      </field>

      <field id="modcod" deshabilitado="true">
        <label colstyle="display:none;" modpos="nobr">Modelo Chasis</label>
        <expression>CHASIS.modcod</expression>
        <help>Modelo del Chasis</help>
        <tabla_ex id="MODCHASIS" vacio="true">
          <field clave="true" id="modcha">
            <label>Modelo</label>
            <help>Codigo del Modelo de Chasis</help>
          </field>
          <field id="moddes">
                <label>Descripcion</label>
                <help>Descripcion del Modelo</help>
                <expression>CONCAT(MODCHASIS.desabv, ' ', (case when MODCHASIS.euro_id = 1 then 'E3' else (case when MODCHASIS.euro_id = 2 then 'E5' else '' end) end))</expression>
          </field>
          <field id="marcod" oculto="true" />
          <field id="id_modelo" oculto="true" />
          <order>
              <field id="moddes" />
          </order>
        </tabla_ex>     
        </field>

      <field id="nrocar" >
