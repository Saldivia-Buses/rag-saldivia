                    <field id="id_proydetalle" autoinc="true" noshow="true">
                    </field>

                    <field id="proyecto_id" noshow="true" valauto="true">   
                    </field>


                	<field id="tipodetalle_id">
                	    <helper xml="proy_tipodetalle.xml" type="combo" _empty="true" />
                        <label>Tipo</label>
                    <!--    <jseval campodestino="pathdet" >\'proyecto_id/detalle/directorio\'</jseval> -->
                	</field>

                    <field id="fecha_detalle" valauto="true">
                        <label modpos="nobr">Fecha</label>
                        <help>Fecha del Proyecto</help>
                        <valor>today</valor>
                    </field>

                    <field id="descripcion_detalle">
                        <label colspan="4">Descripción</label>
                        <size>100</size>
