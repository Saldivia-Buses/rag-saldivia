                    <field id="verificado" _refresh="true" deshabilitado="true">
                        <label>Verificado</label>
                        <tipo>check</tipo>
                    </field>
                    <field id="verif" noshow="true">
                        <expression sql="true">update PROY_DETALLE set verificado = [__verificado__] where id_proydetalle = [__id_proydetalle__]</expression>
                    </field>

                    <field id="login_verificado" valauto="true" noshow="true" refresh="true">
                        
                        <valor eval="true">$_SESSION['usuario']</valor>
                    </field>
                    <field id="fecha">
                        <label>Fecha V.</label>
                        <expression>date(time_verificado)</expression>
                        <tipo>date</tipo>
                    </field>

                    <field id="archivos_etapa" local="true" path="pathdet" colstyle="display:none;">
                       <expression>CONCAT('/fotos/proyectos/', proyecto_id, '/detalle/', directorio, '/' )  </expression>
                            <label >Archivos</label>
                            <help>Archivos de la etapa</help>
                            <tipo>dir</tipo>
                    </field>

                    <order>
                        <field id="tipodetalle_id" />
                    </order>

                </table>
