                    <field id="directorio" deshabilitado="true"  noshow="true" />
                    
                    <field id="dircalc" local="true"  Formstyle="display:none;" path="pathdet"  >
                      <expression>CONCAT( '/fotos/proyectos/',proyecto_id, '/detalle/', id_proydetalle, '/' )</expression> 

                            <label >Archivos</label>
                            <help>Archivos de la etapa</help>
                            <tipo>dir</tipo>
			    <size>40</size>
                    </field>


