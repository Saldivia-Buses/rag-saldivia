<?xml version="1.0" encoding="UTF8" ?>
<histrix tipo="consulta"   path="/fotos/proyectos">
        <title>Proyectos</title>
        <obs></obs>.
        <eventos>
            <event id="insert">refresh</event>
        </eventos>
        <form>
                <table id="PROY_DETALLE" >
