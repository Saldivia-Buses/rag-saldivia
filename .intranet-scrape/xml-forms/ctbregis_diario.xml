			<campo id="regref">
				<label>Referencia</label>
				<help>Referencia</help>
			</campo>
			<campo id="debe" suma="true" >
				<expresion>regimp * (case when regdoh = 1 then 1 else 0 end)</expresion>
				
				<label>Debe</label>
				<help>Importe del Movimiento en el Debe</help>
			</campo>
			
			<campo id="haber" suma="true" >
				<expresion>regimp * (case when regdoh = 2 then 1 else 0 end)</expresion>
				<label>Haber</label>
				<help>Importe del Movimiento en el Haber</help>
			</campo>
			
