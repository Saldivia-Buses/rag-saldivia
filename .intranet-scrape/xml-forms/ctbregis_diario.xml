			<campo id="regdoh" oculto="true">
				<label>Tipo Mov.</label>
				<help>Tipo Movimiento</help>
				<opciones>
					<opcion valor="1">Debe </opcion>
					<opcion valor="2">Haber</opcion>
				</opciones>
				
			</campo>
