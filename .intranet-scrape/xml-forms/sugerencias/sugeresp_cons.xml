<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" >
	<title>Respuesta</title>
	<form >
		<table id="SUGERESP">
			<title>Sugerencias</title>
			
			
			<field id="idSugerencia" oculto="true">
			</field>
			<field id="login" deshabilitado="true">
				<label>Usuario </label>
				<help>Usuario que hace el pedido</help>
				<tabla_ex id="HTXUSERS">
					<field id="login"></field>
					<field id="nombre"></field>
					<order>
						<field id="nombre"></field>
					</order>
				</tabla_ex>
			</field>
			
			<field id="fecha" deshabilitado="true" esclave="true" valauto="true">
				<label>Fecha</label>
				<help>Fecha</help>
				<valor>today</valor>
			</field>


			<field id="respuesta" _deshabilitado="true">
				<label >Respuesta</label>
				<help>Descripcion </help>
				<size>200</size>
				
			</field>
		</table>
	</form>
</histrix>
