		</table>
					<join tipo="left">
						<table id="HTX_EMPRESAS">
							<field id="id_empresa">
								<condicion operador="=">PEDCOTIZ.empresa_id</condicion>
							</field>
						</table>
					</join>				
			<join tipo="left">
				<table id="HOMOLOGMOD">
				    	<field id="id_homologacion">
					    <condicion operador="=">PEDCOTIZ.homologacion_id</condicion>
			        	</field>
					
				</table>
			</join>	
    <join tipo="left">
      <table id="CARROCERIA">
          <field id="nrocar">
                 <condicion operador="=">HOMOLOGMOD.nrocar</condicion>
          </field>
        </table>     
    </join>    

			<join tipo="left">
			<table id="CHASIS">
				<field id="nrocha">
					<condicion operador="=">PEDCOTIZ.nrocha</condicion>
				</field>
			</table>
		</join>		
		<join tipo="left">
			<table id="MARCHASIS">
				<field id="marcod">
					<condicion operador="=">CHASIS.marcod</condicion>
				</field>
			</table>
		</join>
		<join tipo="left">
			<table id="CCTCUENT">
				<field id="siscod" oculto="true">
					<condicion operador="=">'02'</condicion>
				</field>

				<field id="ctacod">
					<condicion operador="=">PEDCOTIZ.ctacod</condicion>
				</field>
			</table>
		</join>						
		<join tipo="left">
			<table id="CCTCONTA">
				<field id="siscod" oculto="true">
					<condicion operador="=">CCTCUENT.siscod</condicion>
				</field>

				<field id="ctacod">
					<condicion operador="=">PEDCOTIZ.ctacod</condicion>
				</field>
				<field id="idconta">
					<condicion operador="=">PEDCOTIZ.idconta</condicion>
				</field>
				
			</table>
		</join>			
		<join tipo="left">
			<table id="MODCHASIS">
					<field clave="true" id="modcha">
						<condicion operador="=">CHASIS.modcod</condicion>

					</field>
					<field id="marcod">
						<condicion operador="=">CHASIS.marcod</condicion>
					</field>			
			</table>
		</join>				
