<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="abm-mini" subtipo="vertical">
    <title>ENTRADA SALIDA STOCK POR CODIGO</title>
    <obs/>
    <form>
        <table id="STKINMOV" label="ENTRADA SALIDA STOCK">
            <preconsultas>
                <xmlfile id="stkinmov_mod_pre.xml"/>
            </preconsultas>
            <filters>
                <field id="nrocha">
                    <label>NroFab</label>
                    <operador>=</operador>
                    <valor>0</valor>
                </field>
                <field id="artcod" >
                    <label>Artículo</label>
                    <operador>=</operador>
                    <valor>0</valor>
                </field>
                <field id="movfec_d">
                    <label>Desde Fecha</label>
                    <operador>&gt;=</operador>
                    <valor>today</valor>
                </field>
                <field id="movfec_h">
                    <label>Hasta Fecha</label>
                    <operador>&lt;=</operador>
                    <valor>today</valor>
                </field>
            </filters>
            
            <field id="movfec">
                <label>Remito</label>
                <help>Fecha Remito</help>
                <condicion operador="&gt;=">STR_TO_DATE('[__movfec_d__]', '%d/%m/%Y') and movfec &lt;= STR_TO_DATE('[__movfec_h__]', '%d/%m/%Y')</condicion>
            </field>
            <field id="movfec_d" local="true" noshow="true">
                <label>mdes</label>
                <preparam campo="movfec_d" operador="=">true</preparam>
                <tipo>date</tipo>
            </field>
            <field id="movfec_h" local="true" noshow="true">
        	<label>mhas</label>
        	<tipo>date</tipo>
    	    </field>
    	    
            <field id="siscod" noshow="true" valauto="true">
                <valor>'01'</valor>
                <condicion operador="=">'01'</condicion>
            </field>
            
            <field id="nrocha">
                <label>NroFab</label>
<!---                <preparam campo="nrocha" operador="=">true</preparam> --><!-- Por algún motivo no anda la precunsulta cuando se manda este parametro -->
		<tipo>integer</tipo>
            </field>

            <!--<field id="opecod" noshow="></field>  -->

            <field id="artcod" >
                <label>Codigo Articulo</label>
                <help>Codigo de Articulo.</help>
                <ayuda_ex condes="true" id="STKINSUM">
                    <clave>artcod</clave>
                    <field id="artcod"/>
                    <field id="artdes"/>
                    <field id="siscod" oculto="true">
                        <condicion operador="=">'01'</condicion>
                    </field>
                </ayuda_ex>
                <preparam campo="artcod" operador="=">true</preparam>
            </field>
            <field id="movref">
                <label modpos="nobr">Referencia</label>
                <help></help>
                <format>%10s</format>
            </field>
            <field id="movcod">
                <tabla_ex xml="stkconce.xml">
                </tabla_ex>
                <label modpos="nobr">Movim.</label>
                <help>Codigo de Movimiento.</help>
            </field>
            <field id="movuso">
                <label modpos="nobr">Cantidad</label>
            </field>

            <field id="Entrada" suma="true">
                <expression>movuso * (case when contip = '1' then 1 else 0 end)</expression>
                <label >Entrada</label>
                <help></help>
            </field>
            <field id="Salida" suma="true">
                <expression>movuso * (case when contip = '2' then 1 else 0 end)</expression>
                <label modpos="nobr">Salida</label>
                <help></help>
            </field>
            <!--      <field id="opecodEx">
                                <expression>CONCAT(PERSONAL.apellido, ', ', PERSONAL.Nombre)</expression>
                                <label>Operador</label>
                                <help></help>
                                <tipo>string</tipo>
                        </field>
 -->
            <field id="EntSal" suma="true">
                <expression>movuso * (case when contip = '1' then 1 else -1 end)</expression>
                <label modpos="nobr">Mov</label>
                <help></help>
            </field>
            
            <field id="color" clasefila="true" local="true" noshow="true" />

            <order>
                <field id="movfec" />
            </order>
        </table>
        <join tipo="left">
            <table id="STKCONCE">
                <field id="siscod" oculto="true">
                    <condicion operador="=">'06'</condicion>
                </field>
                <field id="movcod" oculto="true">
                    <condicion operador="=">STKINMOV.movcod</condicion>
                </field>
                <field id="contip" oculto="true"/>
                <field id="conabv" oculto="true"/>
            </table>
        </join>

        <!--    <join tipo="left">
                        <table id="PERSONAL">
                                <field id="opecod" oculto="true">
                                        <condicion operador="=">STKINMOV.opecod and PERSONAL.opecod != 0</condicion>
                                </field>
                        </table>
                </join>
 -->
    </form>
</histrix>
