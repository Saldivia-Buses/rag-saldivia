<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" subtipo="vertical">
    <title>ENTRADA SALIDA STOCK POR CODIGO</title>
    <obs/>
    <form>
        <table id="STKINMOV" label="ENTRADA SALIDA STOCK">
            
            <field id="movfec">
                <label>Remito</label>
                <help>Fecha Remito</help>
                <condicion operador="&lt;">'[__movfec_d__]'</condicion>
            </field>
            <field id="movfec_d" local="true" noshow="true">
                <label>mdes</label>
                <tipo>date</tipo>
            </field>
            <field id="movfec_h" local="true" noshow="true">
        	<label>mhas</label>
        	<tipo>date</tipo>
    	    </field>
    	    
            <field id="siscod" noshow="true" valauto="true">
                <valor>'01'</valor>
                <condicion operador="=">'01'</condicion>
            </field>
            
            
            <field id="nrocha">
                <label>NroFab</label>
                <tipo>integer</tipo>
            </field>

            <!--<field id="opecod" noshow="></field>  -->

            <field id="artcod" >
                <label>Codigo Articulo</label>
                <help>Codigo de Articulo.</help>
                <ayuda_ex condes="true" id="STKINSUM">
                    <clave>artcod</clave>
                    <field id="artcod"/>
                    <field id="artdes"/>
                    <field id="siscod" oculto="true">
                        <condicion operador="=">'01'</condicion>
                    </field>
                </ayuda_ex>
                <condicion operador="!=">0</condicion>
            </field>
            <field id="movref">
                <label modpos="nobr">Referencia</label>
                <help></help>
                <format>%10s</format>
            </field>
            <field id="movcod">
                <expression>'SALDO INICIAL'</expression>
                <label modpos="nobr">Movim.</label>
                <help>Codigo de Movimiento.</help>
            </field>
            <field id="movuso">
        	<expression>SUM(movuso)</expression>
                <label modpos="nobr">Cantidad</label>
            </field>

            <field id="Entrada" suma="true">
                <expression>SUM(movuso * (case when contip = '1' then 1 else 0 end))</expression>
                <label >Entrada</label>
                <help></help>
            </field>
            <field id="Salida" suma="true">
                <expression>SUM(movuso * (case when contip = '2' then 1 else 0 end))</expression>
                <label modpos="nobr">Salida</label>
                <help></help>
            </field>
            <!--      <field id="opecodEx">
                                <expression>CONCAT(PERSONAL.apellido, ', ', PERSONAL.Nombre)</expression>
                                <label>Operador</label>
                                <help></help>
                                <tipo>string</tipo>
                        </field>
 -->
            <field id="EntSal" suma="true">
                <expression>SUM(movuso * (case when contip = '1' then 1 else -1 end))</expression>
                <label modpos="nobr">Mov</label>
                <help></help>
            </field>

	    <field id="color" clasefila="true" local="true" noshow="true" >
		<valor>resaltado</valor>
	    </field>
	    
	    <group>
		<field id="artcod" />
	    </group>
            <order>
                <field id="movfec" />
            </order>
        </table>
        <join tipo="left">
            <table id="STKCONCE">
                <field id="siscod" oculto="true">
                    <condicion operador="=">'06'</condicion>
                </field>
                <field id="movcod" oculto="true">
                    <condicion operador="=">STKINMOV.movcod</condicion>
                </field>
                <field id="contip" oculto="true"/>
                <field id="conabv" oculto="true"/>
            </table>
        </join>

        <!--    <join tipo="left">
                        <table id="PERSONAL">
                                <field id="opecod" oculto="true">
                                        <condicion operador="=">STKINMOV.opecod and PERSONAL.opecod != 0</condicion>
                                </field>
                        </table>
                </join>
 -->
    </form>
</histrix>
