<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" paginar="200">
  <title>Consulta general</title>
  <obs/>
  <form>
    <table id="STK_MOVIMIENTOS" label="Consulta general">
   
      <filters>

          <field id="id_stkarticulo" tabla="STK_ARTICULOS" >
            <label>Código Artículo</label>
            <operador>=</operador>
          </field>

          <field id="nombre_articulo" tabla="STK_ARTICULOS" deshabilitado="true"/>
<!--
          <field id="stkconcepto_id">
            <operador>=</operador>
            <label>Concepto</label>
            <help>Concepto elegido</help>
          </field>
-->
          <field id="stkrubro_id">
            <operador>=</operador>
            <label modpos="nobr">Rubro</label>
          </field>

          <field id="stksubrubro_id">
            <operador>=</operador>
            <label modpos="nobr">Sub Rubro</label>
          </field>

          <field id="stkdeposito_id">
            <operador>=</operador>
            <label modpos="nobr">Depósito</label>
          </field>


          <field id="fecha_mov2" deshabilitado="false">
            <valor>today</valor>
            <operador>&lt;=</operador>
            <label>Hasta Fecha</label>
            <help>Fecha movimiento</help>
          </field>

      </filters>

      <fieldGroup >

            <field id="id_stkmovimiento" noshow="true" />

            <field id="id_stkarticulo" tabla="STK_ARTICULOS" >
              <label>Código Artículo</label>
              <helper type="external" xml="stkarticulo_qry.xml" dir="/ayudas">
                <field id="wstklista_id" local="true">
                  <valor>1</valor>
                </field>
              </helper>
              <apreparam campo="id_stkarticulo" operador="=">true</apreparam>
            </field>
	    <field id="stkarticulo_id" noshow="true">
		<condicion operador="!=">''</condicion>
	    </field>

            <field id="nombre_articulo" tabla="STK_ARTICULOS">
              <label modpos="nobr">Nombre</label>
              <help>Referencia del movimiento</help>
            </field>

            <field id="stkconcepto_id" noshow="true">
              <helper type="combo" xml="stkconcepto_qry.xml" dir="/ayudas" empty="true"></helper>
              <label>Concepto</label>
              <help>Código de concepto</help>
              <detalle>concepto_id</detalle>
            </field>

<!--
            <field id="nombre_concepto" tabla="STK_CONCEPTOS" print="false">
              <label>Concepto</label>
              <help>Código de concepto</help>
            </field>
-->
            <field id="entrada" local="true" _suma="true" noZero="true">
              <label>Entrada</label>
              <expression>
                sum(CASE WHEN STK_CONCEPTOS.tipo_concepto = 0 THEN cantidad ELSE 0 END)
              </expression>
              <tipo>numeric</tipo>
            </field>

            <field id="salida" local="true" _suma="true" noZero="true">
              <label>Salida</label>
              <expression>
                sum(CASE WHEN STK_CONCEPTOS.tipo_concepto = 1 THEN cantidad ELSE 0 END)
              </expression>
              <tipo>numeric</tipo>
            </field>

	    <field id="stock" style="color:blue;font-weight:bold">
		<expression>sum(CASE WHEN STK_CONCEPTOS.tipo_concepto = 0 THEN cantidad ELSE 0 END) - sum(CASE WHEN STK_CONCEPTOS.tipo_concepto = 1 THEN cantidad ELSE 0 END)</expression>
              <tipo>numeric</tipo>
	    </field>
            <field id="stkdeposito_id">
              <label>Depósito</label>
              <helper type="combo" xml="stkdeposito_qry.xml" dir="/ayudas" empty="true"></helper>
            </field>

            <field id="stkrubro_id" noshow="true" tabla="STK_ARTICULOS">
              <label>Rubro</label>
              <helper type="combo" xml="stkrubro_qry.xml" dir="/ayudas" empty="true"></helper>
              <actualiza>
                <field destino="stkrubro_id" id="stksubrubro_id"/>
              </actualiza>
              <apreparam campo="stkrubro_id" operador="=">true</apreparam>
            </field>

            <field id="stksubrubro_id" tabla="STK_ARTICULOS">
              <label modpos="nobr">SubRubro</label>
              <helper type="combo" xml="stksubrubro_qry.xml" dir="/ayudas" empty="true" />
              <apreparam campo="subrubro_id" operador="=">true</apreparam>
            </field>

            <field id="fecha_movimiento" noshow="true">
              <label>Fecha</label>
              <help>Fecha movimiento</help>
              <tipo>date</tipo>
            </field>

<!--
            <field id="user_id" >
              <label modpos="nobr">Usuario</label>
              <helper type="combo" id="HTXUSERS"  empty="true" >
                <field id="Id_usuario" esClave="true"/>
                <field id="nombre_user">
                  <expression>CONCAT(ifnull(HTXUSERS.nombre, ''),' ', ifnull(HTXUSERS.apellido, ''))</expression>
                </field>
                <order>
                  <field id="nombre_user"/>
                </order>
              </helper>
              
            </field>
-->
            <field id="fecha_mov1" noshow="true">
              <expression having="false">fecha_movimiento</expression>
              <help>Fecha movimiento</help>
              <apreparam campo="fecha_movimiento" operador="&gt;=">true</apreparam>
              <tipo>date</tipo>
            </field>

            <field id="fecha_mov2" noshow="true">
              <expression having="false">fecha_movimiento</expression>
              <help>Fecha movimiento</help>
              <apreparam campo="fecha_movimiento" operador="&lt;=">true</apreparam>
              <tipo>date</tipo>
            </field>

            <field id="color" local="true" clasefila="true" noshow="true"/>

            <field id="recibido_compra" local="true" noshow="true"></field>
	    
	    <field id="subsistema_id" noshow="true">
		<condicion operador="!=">50</condicion>
	    </field>

      <field id="costo" noZero="true">
        <label style="font-weight:bold;">Últ.Compra</label>
        <expression>round(case WHEN (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = id_stkarticulo and bom_variacion_id = 0 limit 1) != 0 then (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STK_ARTICULOS.id_stkarticulo and bom_variacion_id = 0 limit 1)
    			      when valor_compra &gt; valor_uso then costo_calculado * valor_compra
    			      when valor_compra &lt; valor_uso then costo_calculado 
    			      when ( costo_calculado * STK_ARTICULOS.valor_compra / STK_ARTICULOS.valor_uso) > 0  then (costo_calculado * STK_ARTICULOS.valor_compra / STK_ARTICULOS.valor_uso) else STK_ARTICULOS.precio_costo end, 2)</expression>
        <tipo>decimal</tipo>
      </field>
	<field id="total" local="true" suma="true">
	    <if exp="true">
		<true>costo * stock</true>
		<false />
	    </if>
	    <tipo>custom_numeric</tipo>
	</field>
<!--
      <field id="costo_reposicion" local="true">
        <expression>@costo_reposicion :=ifnull(getCostConDtoFunc(id_stkarticulo, ifnull(STK_COSTO_REPOSICION.moneda_id, 1), STR_TO_DATE('[__fecha_mov2__]', '%d/%m/%Y')  ), 0) * (case when (select count(*) from STKPIEZA where STKPIEZA.idPadre = id_stkarticulo and bom_variacion_id = 0) then 1 else (valor_compra / valor_uso) end)</expression>
        <label>Costo repo</label>
        <tipo>numeric</tipo>
      </field>
-->
      </fieldGroup>


      <group>
        <field id="id_stkarticulo"/>
      </group>

    </table>

    <join tipo="left">
      <table id="STK_CONCEPTOS">
        <field id="id_stkconcepto">
          <condicion operador="=">STK_MOVIMIENTOS.stkconcepto_id</condicion>
        </field>
      </table>
    </join>
    <join _tipo="left">
      <table id="STK_ARTICULOS">
        <field id="id_stkarticulo">
          <condicion operador="=">STK_MOVIMIENTOS.stkarticulo_id</condicion>
        </field>
      </table>
    </join>
<!--
    <join tipo="left">
      <table id="HTXUSERS">
        <field id="Id_usuario">
          <condicion operador="=">STK_MOVIMIENTOS.user_id</condicion>
        </field>
      </table>
    </join>
-->

   <join tipo="left">
     <table id="STK_COSTO_REPOSICION">
       <field id="stkarticulo_id">
         <condicion operador="=">id_stkarticulo</condicion>
       </field>
     </table>
   </join>

  </form>
</histrix>
