<?xml version="1.0" encoding="ISO-8859-1"?>
<histrix tipo="consulta" autofiltro="true">
	<title>ENTRADA SALIDA STOCK POR CODIGO</title>
	<obs></obs>
	<form >
		<table id="STKINMOV" label="ENTRADA SALIDA STOCK">
			<preconsultas>
				<xmlfile id="stkinmov_nro_pre.xml"/>
			</preconsultas>			
			<filtro_ex>
				<label>Numero Fabricacion</label>
				<tabla_ex id="CHASIS">
					<!-- campos a agregar al contenedor Filtro-->
					<field id="nrocha"></field>
					<field id="chades"></field>
					<order>
						<field id="nrocha" />
					</order>
					<!-- Campo que se filtra (clave del filtro)-->
					<filtra>nrocha</filtra>
				</tabla_ex>
			</filtro_ex>
			
			<field id="nrocha">
				<label>Num.Fabric</label>
				<tipo>integer</tipo>
				<help>Nro de Fabricacion</help>
				<preparam operador="=">true</preparam>				
			</field>
			
			<field id="movfec">
				<label>Fecha Remito </label>
				<help>Fecha Remito </help>
			</field>
			<field id="movfec2" local="true" noshow="true">
				<label>test</label>
				<help>Fecha Remito</help>
				<preparam campo="movfec" operador="&lt;">true</preparam>							
			</field>		
			<field id="siscod" oculto="true">
				<label>Codigo Sistema.. </label>
				<help>
				</help>
				<condicion operador="=">'01'</condicion>
				
			</field>
			
			<field id="movref">
				<label>Referencia . </label>
				<help>
				</help>
				<format>%10s</format>
			</field>

			
			<field id="artcod">
				<label>Articulo</label>
				<help>Codigo de Articulo. </help>
			</field>
			
			<field id="opecod" oculto="true">
			</field>
						<field id="Entrada" suma="true">
							<expression>movuso * (case when contip = '1' then 1 else 0 end)</expression>
							
							<label>Entrada</label>
							<help>
							</help>
						</field>
						<field id="Salida" suma="true">
							<expression>movuso * (case when contip = '2' then 1 else 0 end)</expression>
							
							<label>Salida</label>
							<help>
							</help>
						</field>			
			<field id="opecodEx">
				<expression>CONCAT(PERSONAL.apellido, ', ', PERSONAL.Nombre)</expression>
				<label>Operador</label>
				<help>
				</help>
				<tipo>string</tipo>
				
			</field>
			<filters>
				
				<field id="movfec" copia="movfec2">
					<operador>>=</operador>
					<label>Desde Fecha</label>
					<valor>today</valor>
					
				</field>
				<field deshabilitado="true" id="movfec2" local="true" noshow="true">
					<label modpos="nobr"/>
					<preparam campo="movfec" operador="&lt;=">true</preparam>
					<operador>=</operador>
					<valor>today</valor>
				</field>				
				<field id="movfec">
					<operador>&lt;=</operador>
					<label>Hasta Fecha</label>
					<valor>today</valor>
				</field>
			</filters>
			<order>
				<field id="movfec" />
			</order>
		</table>
		
		<!--
		<join tipo="left">
		<table id="stkconce">
		<field id="siscod" oculto="true">
		<condicion operador="=">'06'</condicion>
		
		</field>
		<field id="movcod" oculto="true">
		<condicion operador="=">STKINMOV.movcod</condicion>
		</field>
		<field id="contip" oculto="true"></field>
		</table>
		</join>
		-->
		  <join tipo="left">
		    <table id="STKCONCE">
			<field id="siscod" oculto="true">
			    <condicion operador="=">'06'</condicion>

			</field>
			<field id="movcod" oculto="true">
			    <condicion operador="=">STKINMOV.movcod</condicion>
			</field>
	    		<field id="contip" oculto="true"></field>
	    		<field id="conabv" oculto="true"></field>
			
		    </table>
		  </join>		
		<join tipo="left">
			<table id="PERSONAL">
				<field id="opecod" oculto="true">
					<condicion operador="=">STKINMOV.opecod and PERSONAL.opecod != 0</condicion>
				</field>
			</table>
		</join>
		
		
	</form>
</histrix>