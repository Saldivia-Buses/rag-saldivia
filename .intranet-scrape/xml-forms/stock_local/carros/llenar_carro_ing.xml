<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="grid"    path="fotos/articulos" deleteRow="false" process="true" inserta="false">
  <titulo>Artículo por Locación</titulo>
  <obs/>
  <form>
    <table id="STK_ARTICULO_CARRO">
      <movimientos>
        <relacion id="llenar_carro_resta.xml" />
        <relacion id="llenar_carro_update.xml" />
      </movimientos>

    <title>Artículo por locación </title>
      <field id="id_stkarticulocarro" noshow="true" autoinc="true" />

      <field id="stkcarro_id" oculto="true" />
      
    <field id="stkarticulo_id">
      <label>Artículo</label>
      <helper id="STK_ARTICULOS" type="external">
        <field id="id_stkarticulo">
        </field>
        <field id="nombre_articulo" >
          <detalle>nombre_articulo</detalle>
        </field>
        <field id="baja_articulo" noshow="true">
          <condicion operador="=">0</condicion>
        </field >

      </helper>
    </field>

    <field id="nombre_articulo" tabla="STK_ARTICULOS" deshabilitado="true">
      <label>Nombre</label>
	<size>40</size>

    </field>
<!--
      <field id="fotopath" local="true" noshow="true">
        <if exp="true">
          <true>'stkarticulo_id/'</true>
          <false>''</false>
        </if>
        <tipo>varchar</tipo>
      </field>

      <field id="foto" path="fotopath" _open="true"  download="false" _viewer="true" watermark="artcod">
          <expression>select ARTICULO_FOTO.foto from ARTICULO_FOTO where ARTICULO_FOTO.idArticulo = id_stkarticulo and ARTICULO_FOTO.foto != '' order by revision desc limit 1</expression> 
          <label>Imagen</label>
          <tipo Type="Image">file</tipo>
          <size>40</size> 
      </field>
-->
    <field id="cantidad_carro">
      <label>Cantidad</label>
      <tipo>custom_numeric</tipo>
    </field>

    <field id="stkdeposito_id" local="true" editable="true">
      <label>Origen</label>
      <helper id="STK_STOCKACTUAL" type="combo">
          <field id="stkdeposito_id" />
          <field id="nombre_depo">
            <expression>(select nombre_deposito from STK_DEPOSITOS where id_stkdeposito = STK_STOCKACTUAL.stkdeposito_id)</expression>
          </field>
          <field id="stkarticulo_id" >
            <condicion valorde="stkarticulo_id"></condicion>
          </field>
          <parameter source="stkarticulo_id" target="stkarticulo_id" />
      </helper>
      <expression>select stkdeposito_id from STK_ARTICULO_LOCACION join STK_LOCACION on stklocacion_id = id_stklocacion where stkarticulo_id = id_stkarticulo and stock_actual &gt;= cantidad_carro limit 1</expression>
    </field>

    <field id="stkarticulo_locacion_id" editable="true" local="true" style="width:20em;" deshabilitado="false">
      <label>Locación</label>
       <helper xml="locaciones_por_articulo.xml" type="combo">
          <field id="stkarticulo_id" >
            <condicion valorde="stkarticulo_id"></condicion>
          </field>

          <!--
          <field id="stkdeposito_id">
            <detalle>stkdeposito_id</detalle>
          </field>
        -->
          <parameter source="stkarticulo_id" target="stkarticulo_id" />
       </helper>
       <expression>select stklocacion_id from STK_ARTICULO_LOCACION where stkarticulo_id = id_stkarticulo and stock_actual &gt;= cantidad_carro limit 1</expression>
    </field>

    <field id="cantidad_actual" editable="true" deshabilitado="true">
      <label>Cantidad Actual</label>
      <tipo>custom_numeric</tipo>
    </field>
    <field id="grabar">
      <expression>case when cantidad_actual &lt; cantidad_carro and (select count(*) from STK_ARTICULO_LOCACION where stkarticulo_id = id_stkarticulo and stock_actual &gt;= cantidad_carro) &gt; 0 then 1 end</expression>
      <tipo>check</tipo>
    </field>
    <field id="unidad_id" noshow="true" >
      <expression>unidad_uso_id</expression>
    </field>
    <field id="referencia" noshow="true">
      <expression>concat('carga de carro ', nombre_carro)</expression>
    </field>

    <order>
	     <field id="nombre_articulo" />
    </order>
    </table>
    <join>
      <table id="STK_ARTICULOS">
        <field id="id_stkarticulo">
          <condicion operador="=">stkarticulo_id</condicion>
        </field>
      </table>
    </join>
    <join >
      <tabla id="STK_CARRO">
        <field id="id_stkcarro">
          <condicion operador="=">stkcarro_id</condicion>
        </field>
      </tabla>
    </join>

  </form>
</histrix>
