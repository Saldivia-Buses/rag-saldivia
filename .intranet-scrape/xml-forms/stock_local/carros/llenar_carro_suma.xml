<?xml version="1.0" encoding="UTF-8" ?>
    <histrix tipo="insert">
	<title>Ingreso Movimiento</title>
	 <obs></obs>
		<form >
		    <table id="STK_MOVIMIENTOS" idCampoCond="resta">
				<field id="stkarticulo_id"         id_temp="stkarticulo_id"/>
				<field id="stklocacion_id" id_temp="stklocacion_destino_id">
				</field>
				<field id="stkdeposito_id" id_temp="stkdeposito_id">
				    
				</field>
				<field id="fecha_movimiento" >
					<valor>now()</valor>
					<tipo>integer</tipo>
				</field>
				<field id="alta_movimiento">
					<valor>now()</valor>
					<tipo>integer</tipo>
				</field>
				<field id="stkconcepto_id"	>
					<valor>(select id_stkconcepto from STK_CONCEPTOS where transferencia_concepto = 1 and tipo_concepto = 0 limit 1)</valor>
				</field>
				<field id="puesto_movimiento" 	   id_temp="puesto_movimiento"/>
				<field id="numero_movimiento" 	   id_temp="numero_movimiento"/>
<!--				<field id="regcuenta_id" 	   	   id_temp="regcuenta_id"/> -->
				<field id="orden_movimiento" 	   id_temp="_ORDEN"/>
				<field id="unidad_id" 	           id_temp="unidad_id"/>
				<field id="cantidad" 	           id_temp="cantidad_carro"/>
				<field id="referencia" 	           id_temp="referencia"/>
				<field id="user_id" >
				    <valor eval="true">$_SESSION['idUser']</valor>
				</field>
		    </table>
		</form>
    </histrix>	


