<?xml version="1.0" encoding="ISO-8859-1" standalone="no"?>
<histrix tipo="consulta">
  <title>Momentos de Fabricación</title>
  <obs/>
  <form >
    <table id="MOMENTO" >
      <title>Secciones de Fabricación</title>
           <field id="idMon">
		   <expresion>select count(*)  from MOMENTO AS MON left JOIN POSICIONESFAB as POS on MON.idMomento = POS.idMomento  where concat(MON.idMomento, POS.idPosicion ) &lt;= concat(MOMENTO.idMomento, POSICIONESFAB.idPosicion) </expresion>
	   </field>

		<field id="nombre" tabla="POSICIONESFAB">
			<label>nombre</label>
		</field>
                <field id="orden" noshow="true"/>
		<order>
			<field id="orden"/>
		</order>
    </table>
		<join tipo="left">
			<table id="POSICIONESFAB">
				<field id="idMomento">
					<condicion operador="=">MOMENTO.idMomento</condicion>
				</field>
			</table>
		</join>	  
  </form>
</histrix>
