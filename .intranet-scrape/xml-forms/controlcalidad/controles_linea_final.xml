        	    <helper type="combo" xml="cct_cliente_linea.xml" dir="/clientes" empty="true"/>
            </field>
-->    
        <field id="ninterno" tabla="PEDCOTIZ">
        	<expression>PEDCOTIZ.ninterno</expression>
            </field>
