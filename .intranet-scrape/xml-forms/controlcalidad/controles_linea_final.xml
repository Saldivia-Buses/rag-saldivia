        <table id="TURNOSPRODUCCION" label="Programa de Produccion"  _showCantidad="false" _styleTbody="height:500px; overflow-x:hidden;">
            <filters auto="true">

                <field id="sale2" deshabilitado="false" noshow="true">
                    <help>Fecha de Ingreso a Línea</help>
                    <operador>&gt;=</operador>
                    <valor eval="true">date("d/m/Y", mktime(0, 0, 0, date("m"), date("d")-20, date("Y")))</valor>
                </field>
    	        <field id="nrofab" >
    	    	    <help>Número de Fabricación</help>
    	    	    <operador>=</operador>
        		</field>
            </filters>
            
            <field id="siscli" local="true" oculto="true" >
                <valor>'02'</valor>
            </field>
            <field id="tieneFicha" noshow="true">
                <expression>case when PEDCOTIZ.nrocha != 0  then 'fichaventas.xml' else '' end</expression> 
            </field>
