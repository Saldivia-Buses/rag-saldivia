                <expression>(case when PEDCOTIZ.terminacion != '0000-00-00' then PEDCOTIZ.terminacion else (DATE_ADD((case when ingresoLinea != '0000-00-00' then ingresoLinea else fechaing end), INTERVAL 25 DAY)) end)</expression>
                <help>Fecha de Salida de Linea</help>
                <tipo>date</tipo>
                <format>d/m</format> 
                
            </field>
            <field id="chasis_entrada" noshow="true">
                <expression>CONCAT('Fecha de entrada del Chasis: ', date_format(CHASIS.entrada, '%d/%m/%Y'))</expression>
                <tipo>date</tipo>
            </field>

      <field id="numero_solicitud" tabla="CHASIS" noZero="true">
        <label>Solicitud</label>
        <help>Numero de Solicitud</help>
      </field>
    -->
<!--
               <field id="max_fec" noshow="true">
                <expression> GREATEST((SELECT MAX(fecha) from HTXLOG  where ( HTXLOG.xmlprog = 'Fichaventas_abm.xml' or xmlprog = 'accesorios_coche.xml' ) 
                    and ( HTXLOG.obs like concat('%N.Fab.: ',nrofab,'%')   or  HTXLOG.obs like concat('% Coche: ',nrofab,'%')))  , (select max(ACC.fecha) from PEDCOTIZ AS PED1 left join ACCESORIOS_COCHE as ACC on ACC.ficha_id = PED1.id where PED1.id = PEDCOTIZ.id ))
                </expression>
                
            </field>

-->            
            <field id="max_fec" noshow="true">
        	    <expression>  GREATEST( PEDCOTIZ.revfec ,
                    (select max(ACC.fecha) from PEDCOTIZ AS PED1 left join ACCESORIOS_COCHE as ACC on ACC.ficha_id = PED1.id where PED1.id = PEDCOTIZ.id ))</expression>
                
            </field>

            <field id="cantok" Class="ui-li-count" >
                <attribute id="style">mal</attribute>
                <expression>concat(ifnull(sum(conforme),0),'/', count(*) )</expression>
            </field>
            <group>
                <field id="nrofab" />
            </group>
            <order>
                <field id="terminado"/>
                <field id="fechaing2"/>
            </order>
        </table>
        <join tipo="left">
            <table id="PEDCOTIZ">
                <field id="nrocha">
                    <condicion operador="=">TURNOSPRODUCCION.nrofab and PEDCOTIZ.nrocha != 0</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="CHASIS">
                <field id="nrocha">
                    <condicion operador="=">TURNOSPRODUCCION.nrofab and CHASIS.nrocha != 0</condicion>
                </field>
            </table>
        </join>
<!--        <join tipo="left">
            <table id="MODCHASIS">
                <field id="modcha">
                    <condicion operador="=">CHASIS.modcod</condicion>
                </field>
                <field id="marcod">
                    <condicion operador="=">CHASIS.marcod</condicion>
                </field>
            </table>
        </join>
        -->
          <join tipo="left">
            <table id="PROD_CONTROLES">
                    <field id="seccion_id">
                        <condicion operador="=">0</condicion>
                    </field>
                    
            </table>
        </join>

          <join tipo="left">
            <table id="PROD_CONTROL_HOMOLOG">
                    <field id="prodcontrol_id">
                        <condicion operador="=">id_prodcontrol</condicion>
                    </field>
                    <field id="homologacion_id">
                        <condicion operador="=">PEDCOTIZ.homologacion_id</condicion>
                    </field>        
                    
            </table>
        </join>
        <join tipo="left">
            <table id="PROD_CONTROL_MOVIM">
            <field id="nrofab_id">
                <condicion operador="=">nrofab</condicion>
            </field>
            <field id="prodcontrol_id">
                <condicion operador="=">id_prodcontrol</condicion>
            </field>            </table>
        </join>        
        <join tipo="left">
            <table id="CONCESIONARIO">
                <field id="idconces">
                    <condicion operador="=">(case when CHASIS.conces != '' then CHASIS.conces else TURNOSPRODUCCION.idconces end)</condicion>
                </field>
            </table>
        </join>
	<join tipo="left">
	    <table id="CCTCUENT">
		<field id="ctacod">
		    <condicion operador="=">(case when PEDCOTIZ.ctacod != 0 then PEDCOTIZ.ctacod else TURNOSPRODUCCION.ctacod end)</condicion>
		</field>		
		<field id="siscod">
		    <condicion operador="=">02</condicion>
		</field>
	    </table>
	</join>
        
    </form>
</histrix>