                    <field id="nrocar">
                    </field>
                    <field id="desabv">
                    </field>

                    <field id="siscod" oculto="true">
                        <condicion operador="=">03</condicion>
                    </field>
                </tabla_ex>
                <tipo>varchar</tipo>
            </field>

            <field deshabilitado="true" id="ctanom" tabla="PEDCOTIZ" >
  <!--              <expression>case when PEDCOTIZ.ctacod != '' then PEDCOTIZ.ctacod else TURNOSPRODUCCION.ctacod end</expression> -->
                        <expression>ctanom</expression>

		<!--
                <label >Cliente</label>
                <help>Codigo de Cuenta</help>
