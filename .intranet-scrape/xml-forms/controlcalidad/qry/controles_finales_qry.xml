		<group>
		    <field id="id_prodcontrol" />
		</group>
-->
		</table>

		<join tipo="left">
		    <table id="PROD_CONTROL_MOVIM">
			<field id="prodcontrol_id">
			    <condicion operador="=">id_prodcontrol</condicion>
			</field>
			<field id="nrofab_id">
			    <condicion operador="=">[__nrofab_id__]</condicion>
			</field>
		    </table>
		</join>

		<join tipo="left">
		    <table id="HTXUSERS">
			<field id="login">
			    <condicion operador="=">user_id</condicion>
			</field>
		    </table>
		</join>

