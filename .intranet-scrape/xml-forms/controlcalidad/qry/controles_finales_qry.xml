<?xml version="1.0" encoding="UTF-8"?>
<histrix  tipo="consulta" 
	
 deleteRow="false"  path="/fotos/archivo/coches/" autoprint="true">
	<title>Control Calidad</title>
	<obs/>
	<form>
		
		<table id="PROD_CONTROLES">
			<title>Control de Calidad</title>
			<field id="_ORDEN" local="true" print="false" />
			
			<field id="habilitado" oculto="true">
			    <condicion operador="=">0</condicion>
			</field>
			<field id="id_prodcontrol" noshow="true" esClave="true">
			</field>
			
			<field id="nrofab_id" noshow="true" tabla="PROD_CONTROL_MOVIM" local="true">
				<label>coche</label>
			</field>
<!--
			<field id="tit" break="true">
			    <expression>concat(descripcion)</expression>
			</field>
-->
<!--
			<field id="homologacion_id" noshow="true" tabla="PROD_CONTROL_HOMOLOG" />
-->
			<field id="id_controlmovim" noshow="true">
			    <expression>id_controlmovim</expression>
			</field>

			<field id="seccion_id" noshow="true" >
			    <condicion operador="=">0</condicion>
			</field>
			<field id="modelo_control" noshow="true" _break="true" />
<!--			<field id="orden_control" noshow="true" /> -->

			<!--
			<field id="tipo_control" >
				<label>Tipo</label>
				<options>
				    <option valor="0"></option>
				    <option valor="1">Externa</option>
				    <option valor="2">Interna</option>

                                </options>
			</field>
-->


			<field id="nombre_control" PDFsize="18px" print="false">
			</field>
		
			<field id="test" local="true" PDFsize="18px">
			    <label>Control</label>
			    <if exp="true">
				<true>'_ORDEN- nombre_control'</true>
				<false>0</false>
			    </if>
			</field>
			<field id="observacion_control" tabla="PROD_CONTROL_MOVIM"  PDFsize="18px">
			    <label>Observación</label>
			    <size>10</size>
			</field>
			
<!--

			<field id="fot" path="fotos" local="true" _editable="true">	
			    <tipo>file</tipo>
			</field>
-->		    
<!--<tipo>file</tipo> -->
