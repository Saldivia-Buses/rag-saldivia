			<field id="muestracontrol" local="true" noshow="true">
				<if exp="no_conforme != 1">
					<true>'display:none;'</true>
					<false>'background-color:red;text-align:center;'</false>
				</if>
			</field>

			<field id="muestraconforme" local="true" noshow="true">
