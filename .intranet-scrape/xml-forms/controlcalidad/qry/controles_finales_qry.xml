			<field id="conforme"   tabla="PROD_CONTROL_MOVIM" _local="true"  deshabilitado="true"
				colstyle="background-color:greenyellow;text-align:center;" PDFcolWidth="10" >
    				<label>si</label>
				<tipo>check</tipo>
			</field>


			<field id="no_conforme"   tabla="PROD_CONTROL_MOVIM" _inputstyle="width:2em;height:2em;" _local="true"
			colstyle="background-color:pink;text-align:center;" PDFcolWidth="10" deshabilitado="true" >
				<label>no</label>
				<tipo>check</tipo>
			</field>
