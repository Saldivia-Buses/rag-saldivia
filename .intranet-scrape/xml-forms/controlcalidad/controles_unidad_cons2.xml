			<field id="idMomento" noshow="true" />

			<field id="nrofab_id"  noshow="true" local="true">
			</field>
			<field id="homologacion_id"   local="true"  noshow="true">

			</field>

			<field id="descripcion" PDFcolWidth="30">
			    <label>Sección</label>
