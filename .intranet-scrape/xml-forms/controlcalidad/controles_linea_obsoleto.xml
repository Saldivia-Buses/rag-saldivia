            <field id="fechaing"  esClave="true" _PDFanchofijo="true" noshow="true">
                <attribute id="style">colorFec</attribute>
                <expression having="false">(case when PEDCOTIZ.ingresoLinea != '0000-00-00' then PEDCOTIZ.ingresoLinea else fechaing end)</expression>
                <label >Entra</label>
                <tipo>date</tipo>
                <help>Fecha de Ingreso a Linea</help>
                <format>d/m</format> 
                <condicion operador="&lt;">ADDDATE(CURDATE(),INTERVAL 35 DAY)</condicion>
            </field>

            <field id="colorFecTer"  oculto="true">
                <expression>case when PEDCOTIZ.terminacion != '0000-00-00' then 'color:green; font-size:11px;font-weight:bold;' else 'color:#B32600; font-weight:bold;' end</expression>
                <tipo>varchar</tipo>
            </field>
            
            <field id="sale2" esClave="true" noshow="true" required="false">
                <label modpos="nobr" >terminado</label>
                <expression having="false">DATE_ADD((case when ingresoLinea != '0000-00-00' then ingresoLinea else fechaing end), INTERVAL 25 DAY)</expression>
                <tipo>date</tipo>
<!--                <preparam campo="sale2" operador="&lt;">true</preparam> -->
            </field>

