<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta"  imprime="false">
	<title>Entregas</title>
	<obs/>
	<form >
		<table id="MOMENTO">
			<title>Controles de Calidad</title>

			<field id="idMomento" noshow="true"/>
			<field id="nrofab_id"  noshow="true" local="true">
			</field>
			<field id="certif"  noshow="true" local="true">
			</field>
			<field id="homologacion_id"  oculto="true" tabla="PEDCOTIZ">
			</field>


			<field id="descripcion"  style="font-size:12px;width:100px;">
			    <helper type="link" xml="prod_control_movim_ficha.xml" dir="/controlcalidad" modal="true" width="50%">
				<parameter source="idMomento" target="seccion_id" />
				<parameter source="nrofab_id"  target="nrofab_id" />
				<parameter source="certif"  target="certif" />
				<parameter source="homologacion_id"  target="homologacion_id" />				
			    </helper>

			</field>
			
			<field id="estado_control" noshow="true">
			    <expression>(select AVG(valor_control) from PROD_CONTROL_MOVIM join PROD_CONTROLES on PROD_CONTROLES.id_prodcontrol = PROD_CONTROL_MOVIM.prodcontrol_id 
			    where PROD_CONTROLES.seccion_id = idMomento and  PROD_CONTROL_MOVIM.nrofab_id = [__nrofab_id__])</expression>
			</field>
			<field id="estado_ctr_str" _noshow="true" style="text-align:center;font-size:12px;">
			    <expression>(select CONCAT(SUM(valor_control), '/', count(valor_control)) from PROD_CONTROL_MOVIM join PROD_CONTROLES on PROD_CONTROLES.id_prodcontrol = PROD_CONTROL_MOVIM.prodcontrol_id 
			    where PROD_CONTROLES.seccion_id = idMomento and  PROD_CONTROL_MOVIM.nrofab_id = [__nrofab_id__])</expression>
			</field>
			
			
			<field id="imag" local="true" style="text-align:right">
			
			    <if exp="'estado_control' == 1">
				<true><![CDATA['<img src="../img/ok.png" />']]></true>
				<false><![CDATA[('estado_control' == '')?'&nbsp;':'<img src="../img/cancel.png" />']]></false>
			    </if>
			</field>
			
			<group>
			    <field id="descripcion" />
			</group>
		</table>
		<join tipo="inner">
		    <table id="PROD_CONTROLES">
			<field id="seccion_id">
			    <condicion operador="=">idMomento</condicion>
			</field>
			<field id="habilitado" >
			    <condicion operador="=">0</condicion>
			</field>
		    </table>
		</join>
		<join >
		    <table id="PEDCOTIZ">
			<field id="nrocha">
			    <condicion operador="=">[__nrofab_id__]</condicion>
			</field>
		    </table>
		</join>		
		<join tipo="inner">
			<table id="PROD_CONTROL_HOMOLOG">
					<field id="prodcontrol_id">
						<condicion operador="=">id_prodcontrol</condicion>
					</field>
					<field id="homologacion_id">
						<condicion operador="=">PEDCOTIZ.homologacion_id</condicion>
					</field>					
			</table>
		</join>		

	</form>
</histrix>
