<?xml version="1.0" encoding="UTF-8"?>
<histrix  tipo="grid"  deleteRow="false" imprime="false" procesa="true" inserta="false" tableHeight="500px;" path="/fotos/archivo/Coches/">
	<title>Control Calidad</title>
	<obs/>
        <eventos>
                <event id="procesar">close</event>
        </eventos>	
        <customScript><![CDATA[

        	window.setTimeout(function(){
        		$('[campo="observacion_control"] > div').css({'border':'0px'});

			}, 1000);
<!--
			$('[name="observacion_control"]').each(function(){
				if ($(this).val() == '') 
					$(this).hide();
			});

-->

		$('[name="observacion_control"]').show();
        	// refresh update check
			$('[campo] :input:checkbox').change(function(){
					var tr = $(this).closest('tr');

					$('td[campo="update"] input', tr).val('1');
			});


        	$('td[campo="conforme"] input:checkbox').change(function(){
        		var tr = $(this).closest('tr');


        		if ($(this).prop('checked')){

	        		

	        		//$(tr).css({'background-color':'greenyellow'});

	        		$('td[campo="no_conforme"] input:checkbox', tr).prop('checked', !$(this).prop('checked')).checkboxradio("refresh");
        		} else {
        			tr.css({'background-color':'transparent'});
        		}
        	});
        	$('td[campo="no_conforme"] input:checkbox').change(function(){
        		var tr = $(this).closest('tr');
        		if ($(this).prop('checked')){

	        		tr.css({'background-color':'transparent'});
	        		$('td[campo="conforme"] input:checkbox', tr).prop('checked', !$(this).prop('checked')).checkboxradio("refresh");
        		} else {

        		}
        	});        	
        	]]>
        </customScript>           
	<form>
		<table id="PROD_CONTROLES">
		    <movimientos>
		    	<relacion id="prod_controlmovim_update.xml" />
				<relacion id="prod_controlmovim_ins_movil.xml" />
		    </movimientos>

			<title>Controles</title>
			<field id="habilitado" oculto="true">
			    <condicion operador="=">0</condicion>
			</field>
			<field id="id_prodcontrol" noshow="true">
			</field>
			<field id="nrofab_id" noshow="true" local="true">
				    <setvar>titulo</setvar>
			</field>
			<field id="id_controlmovim" noshow="true">
			    <expression>id_controlmovim</expression>
			</field>
			<!--
			<field id="seccion_coche_id" style="font-size:16px;color:green;" PDFcolWidth="30">
				<label>Seccion Coche</label>
				<options>
				    <option valor="1">Frente Ext</option>
				    <option valor="2">Lateral Izquierdo</option>
				    <option valor="3">Lateral Derecho</option>
				    <option valor="4">Culata</option>
				    <option valor="5">Interior</option>
				    
				    
				</options>
				
			</field>
		-->

			<field id="seccion_id" noshow="true">
				<condicion operador="=">0</condicion>
			</field>
			<field id="nombre_control" noshow="true"  _style="font-size:16px;" PDFcolWidth="90">
			</field>
<!--			<field id="valor_control"   tabla="PROD_CONTROL_MOVIM" style="font-size:16px;" _local="true" PDFcolWidth="10">
				<label>Valor</label>
				<tipo>check</tipo>
			</field>
		-->
			<field id="observacion_control"  tabla="PROD_CONTROL_MOVIM"   _style="font-size:16px;"  editable="true" conLabel="true">
				<attribute id="Etiqueta">nombre_control</attribute> 
				<help>Observación</help>
				<size>10</size>
			</field>

			<field id="fotopath" noshow="true" >
			    <expression>concat(nrofab_id,'/controlcalidad/',id_prodcontrol)</expression>
			</field>

	        <field id="foto" >
				<helper type="link" xml="prod_control_foto.xml">
				    <parameter source="id_controlmovim" target="id_controlmovim" />
				    <parameter source="fotopath" target="fotopath" />
				</helper>
				<expression>'Foto'</expression>
<!-- 				<expression>case when isnull(id_controlmovim) then '' else (case when foto != '' then '1 Foto' else 'Foto' end) end</expression>
 -->		    </field>

			<field id="conforme"   tabla="PROD_CONTROL_MOVIM" inputstyle="width:3em;height:3em;font-size:14px;background-color:green;" _local="true" 
				colstyle="background-color:greenyellow;text-align:center;" PDFcolWidth="10">
				<checklabel>si</checklabel>
				<label>Conf.</label>
				<tipo>check</tipo>
			</field>
			<field id="no_conforme"   tabla="PROD_CONTROL_MOVIM"  
			colstyle="background-color:pink;text-align:center;" PDFcolWidth="10">
				<checklabel>no</checklabel>
				<label>No Conf.</label>
				<tipo>check</tipo>
			</field>
			<field id="muestracontrol" local="true" noshow="true">
				<if exp="no_conforme != 1">
					<true>'display:none;'</true>
					<false>'background-color:pink;text-align:center;'</false>
				</if>
			</field>
			<field id="controlado"   tabla="PROD_CONTROL_MOVIM"  
			 PDFcolWidth="10">
				<attribute id="style">muestracontrol</attribute>			
				<checklabel>Aprob</checklabel>
				<tipo>check</tipo>
			</field>

			<field id="fecha_control"  tabla="PROD_CONTROL_MOVIM"  editable="true" deshabilitado="false" noshow="true">

				<label>Fecha</label>
				<tipo>date</tipo>
				<expression>ifnull(fecha_control, date(now()))</expression>
			</field>
			<field id="graba" local="true" noshow="true">
			    <label>g</label>
			    <if exp="'id_controlmovim' > '0'">
				<true>0</true>
				<false>1</false>
			    </if>
			</field>

			<field id="update" noshow="true" local="true" _colstyle="display:none;" editable="true" deshabilitado="true">
				

			</field>
			<field id="user_id" local="true" noshow="true">
			    <valor eval="true">$_SESSION['usuario']</valor>
			</field>

			
		</table>
		<join tipo="left">
		    <table id="PROD_CONTROL_MOVIM">
			<field id="nrofab_id">
			    <condicion operador="=">[__nrofab_id__]</condicion>
			</field>
			<field id="prodcontrol_id">
			    <condicion operador="=">id_prodcontrol</condicion>
			</field>
		    </table>
		</join>

	</form>
</histrix>
