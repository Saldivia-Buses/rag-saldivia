<histrix tipo="liveGrid" preloadData="false" deleteRow="false" inserta="false">
    <title>Controles de calidad pendientes por seccion</title>
    <obs/>
    <form>
        <table id="PROD_CONTROL_MOVIM" label="Retrabajos">

        <filters>
			<field id="nrofab_id">
                <label>Unidad</label>
                <operador>=</operador>
	        </field>
	        	<field id="linea_id">
                <label modpos="nobr">Línea</label>
                <operador>=</operador>
                <valor>1</valor>
	        </field>

			<field id="seccion_id">
				<label modpos="nobr">Sección</label>
				<operador>=</operador>
			</field>

			<!--<field id="conforme">
				<label modpos="nobr">Conforme</label>
				<operador>=</operador>
			</field>

			<field id="no_conforme">
				<label modpos="nobr">No Confome</label>
				<operador>=</operador>
			</field>

			<field id="controlado">
				<label modpos="nobr">Aprobado</label>
				<operador>=</operador>
			</field>
			<field id="no_aplica">
				<label modpos="nobr">No Aplica</label>
				<operador>=</operador>
			</field>-->

	  	</filters>

    	<field id="id_controlmovim" esClave="true" noshow="true"/>
	    
    	<field id="nrofab_id" noshow="true">
			<label>Unidad</label>
	    </field>

	    <field id="linea_id" local="true" noshow="true">
            <helper type="combo" xml="lineas.xml" dir="/produccion" empty="true"/>
            <label >Línea</label>
			<actualiza>
				<field id="seccion_id" destino="linea_id" /> 
			</actualiza>
	    </field>

		<field id="seccion_id" tabla="PROD_CONTROLES" colstyle="display:none;">
			<label>Sección</label>
			<helper id="MOMENTO" type="combo" empty="true">
                <field id="idMomento" />
                <field id="descripcion" />
                <field id="linea_id" oculto="true">
                	<condicion operador="=">1</condicion>
                </field>
		    </helper>
		</field>

		<field id="nombre_control" tabla="PROD_CONTROLES">
			    <label>Control</label>
		</field>

<!-- 		<field id="nombre_controlcausal" tabla="PROD_CONTROL_CAUSAL">
			<label>Causa</label>
	    </field> -->

	    <field id="controlcausal_id" editable="true">
			<label>Causa</label>
			<helper id="PROD_CONTROL_CAUSAL" type="combo" empty="true">
                <field id="id_controlcausal" />
                <field id="nombre_controlcausal" />
                <field id="habilitado_controlcausal" oculto="true">
                	<condicion operador="=">1</condicion>
                </field>
		    </helper>
	    </field>

		<field id="conforme" editable="true" style="height:1em;" colstyle="background-color:greenyellow;text-align:center;">
			<label>SI</label>
            <!--<options>
                <option valor=""></option>
                <option valor="0">No</option>
                <option valor="1">SI</option>
            </options>-->
            <tipo>check</tipo>
        </field>

		<field id="no_conforme" editable="true" style="height:1em;" colstyle="background-color:pink;text-align:center;">
			<label>NO</label>
            <!--<options>
                <option valor=""></option>
                <option valor="0">No</option>
                <option valor="1">SI</option>
            </options>-->
		<tipo>check</tipo>
        </field>

    	<field id="controlado" editable="true" style="height:1em;">
    		<label>Aprobado</label>
<!--            <options>
                <option valor="0">No</option>
                <option valor="1">SI</option>
            </options>-->
		<tipo>check</tipo>		
        </field>

		<field id="no_aplica" editable="true" style="height:1em;">
			<label>No Aplica</label>
<!--            <options>
                <option valor="0">No</option>
                <option valor="1">SI</option>
            </options>		-->
		<tipo>check</tipo>
        </field>

		<field id="userid" >
			    <label>Controló</label>
			    <expression>CONCAT(Nombre, '  ',apellido)</expression>
		</field> 

		<field id="fecha_control" _editable="true">
			    <label>Fecha</label>
		</field> 

		<field id="hora_control" _editable="true">
			    <label>Hora</label>
			    <size>50</size>
		</field> 

        <field id="hi" deshabilitado="true" clasefila="true" noshow="true">
            <expression>case when (no_conforme = 1) then 'resaltadoRojo' else '' end</expression>
            <tipo>varchar</tipo>
        </field>

		<order>
			<field id="nrofab_id" />
		</order>

	</table>
		<join tipo="left">
		    <table id="PROD_CONTROLES">
			<field id="id_prodcontrol">
			    <condicion operador="=">prodcontrol_id</condicion>
			</field>
		    </table>
		</join>
		<join tipo="left">
		    <table id="MOMENTO">
			<field id="idMomento">
			    <condicion operador="=">PROD_CONTROLES.seccion_id</condicion>
			</field>
		    </table>
		</join>
		<join tipo="left">
		    <table id="PROD_CONTROL_CAUSAL">
			<field id="id_controlcausal">
			    <condicion operador="=">PROD_CONTROL_MOVIM.controlcausal_id</condicion>
			</field>
		    </table>
		</join>
		<join tipo="left">
		    <table id="PEDCOTIZ">
			<field id="nrocha">
			    <condicion operador="=">PROD_CONTROL_MOVIM.nrofab_id</condicion>
			</field>
		    </table>
		</join>
<!-- 		<join tipo="left">
            <table id="CCTCUENT">
                <field id="ctacod">
                    <condicion operador="=">PEDCOTIZ.ctacod</condicion>
                </field>
                <field id="siscod">
                    <condicion operador="=">'02'</condicion>
                </field>   
            </table>
        </join>
        <join tipo="left">
            <table id="CHASIS">
                <field id="nrocha">
                    <condicion operador="=">PEDCOTIZ.nrocha</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="MODCHASIS">
                <field id="modcha">
                    <condicion operador="=">CHASIS.modcod</condicion>
                </field>
                <field id="marcod">
                    <condicion operador="=">CHASIS.marcod</condicion>
                </field>
            </table>
        </join>
 -->		<join tipo="left">
		    <table id="HTXUSERS">
			<field id="login">
			    <condicion operador="=">user_id</condicion>
			</field>
		    </table>
		</join>

    </form>
</histrix>
