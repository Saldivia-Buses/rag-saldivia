<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="abm-mini" path="/fotos/archivo/Comunicaciones/">
	<title>Respuesta</title>
	<consulta>
		<table id="CRM_COMUNIC_EVENTOS">
			<title>Comunicaciones</title>
			
			
			<field id="comunicacion_id" oculto="true">
			</field>
			<field id="id_evento" noshow="true">
			</field>
			<field id="login" deshabilitado="true" >
				<label>Usuario </label>
				<help>Usuario que hace el pedido</help>
				<tabla_ex id="HTXUSERS">
					<field id="login"></field>
					<field id="nombre"></field>
					<order>
						<field id="nombre"></field>
					</order>
				</tabla_ex>
				<valor eval="true">$_SESSION['usuario']</valor>
			</field>


			<field id="fecha" deshabilitado="true"  valauto="true">
				<label>Fecha</label>
				<help>Fecha</help>
				<valor>today</valor>
                                <tipo>date</tipo>
			</field>


			<field id="evento" _deshabilitado="true" >
				<label >Respuesta</label>
				<help>Descripcion </help>
				<size>200</size>
				
			</field>
					<field id="cierre" >
				<label >Cierre</label>
				<help>Cierre</help>
				<tipo>check</tipo>
				
			</field>
			<field id="fieldpath" noshow="true" local="true">
	                    <expresion>CONCAT(comunicacion_id,'/', id_evento,'/')  </expresion>
			</field>
            <field id="fotos" local="true" imageWidth="80" path="fieldpath">
                <label  posX="5" posY="+2" >Dir</label>
	                    <expresion>CONCAT('/fotos/archivo/Comunicaciones/',comunicacion_id,'/', id_evento,'/')  </expresion>

                <tipo>dir</tipo>
            </field>
	                
			<order>
				<field id="fecha" ></field>
			</order>

		</table>
	</consulta>
</histrix>
