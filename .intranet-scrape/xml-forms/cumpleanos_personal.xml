      <field id="mail_to" local="true" email="to" print="false" oculto="true" colstyle="display:none;">
        <expression>CCTCONTA.mail</expression>
      </field>

      <field id="mail_subj" local="true" email="subject" print="false" oculto="true" colstyle="display:none;">
        <expression>CONCAT('FELIZ CUMPLEAÑOS, ', CCTCONTA.nombre)</expression>
      </field>

      <field id="enviomail" local="true" >
          <label>Mail</label>
          <helper type="link" xml="mails_send.xml" dir="/histrix/mensajeria">
            <parameter source="mail_msg"  target="mensaje" />
            <parameter source="mail_to"   target="para" />
            <parameter source="mail_subj" target="subject" />
          </helper>
          <expression><![CDATA[IFNULL(('<img src="../img/mail_generic.png"/>'), '')]]></expression>
      </field>
-->
    </table>
  
   
  </form>
</histrix>
