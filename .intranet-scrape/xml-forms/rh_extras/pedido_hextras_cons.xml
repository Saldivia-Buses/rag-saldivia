<?xml version="1.0" encoding="UTF-8"?>
	<histrix  tipo="consulta" >
		<title>Autorización de Horas Extras</title>
		<obs></obs>
		<form  detalle="pedido_hextras_detail_cons.xml" inline="true">
			<table id="RH_AUTH_EXTRAS" label="Horas Extras">
              
            <filters>
				<field id="fecha_auth">
					<operador>&gt;=</operador>
					<label>Desde Fecha</label>
                    <valor eval="true">date("d/m/Y", mktime(0, 0, 0, date("m"), 01, date("Y")))</valor>
				</field>
				<field id="fecha_auth">
					<operador>&lt;=</operador>
					<label modpos="nobr">Hasta Fecha</label>
            		<valor eval="true">date("d/m/Y", mktime(0, 0, 0, date("m"), date("d"), date("Y")))</valor>
				</field>
			</filters>
			
			<field id="login_auth" deshabilitado="true" noshow="true">
				<label>Usuario</label>
				<valor eval="true">$_SESSION['usuario']</valor>
			</field>
			
			<field id="id_auth" deshabilitado="true" noshow="true">
			    <label modpos="nobr">Número</label>
			    <detalle>auth_id</detalle>
			</field>			
			
			<field id="userid" >
			    <label>Solicitó</label>
			    <expression>concat(HTXUSERS.Nombre,' ', HTXUSERS.apellido)</expression>
			</field>

			<field id="fecha_auth" deshabilitado="true">
			    <label modpos="nobr">Fecha</label>
			    <valor>today</valor>
			</field>
			
			<field id="desdeFecha" local="true">
			    <label >Desde Fecha</label>
			    <valor>today</valor>
			    <tipo>date</tipo>
			</field>		
			<field id="hastaFecha" local="true">
			    <label modpos="nobr">Hasta Fecha</label>
			    <valor>today</valor>
			    <tipo>date</tipo>
			</field>		
				
				
			<field id="motivo_auth" >
			    <label colspan="4">Motivo</label>
			    <size>100</size>
			</field>
			</table>
			
			<join tipo="left">
			    <table id="HTXUSERS">
				<field id="login">
				    <condicion operador="=">login_auth</condicion>
				</field>
		    </table>
		</join>
		</form>
	</histrix>