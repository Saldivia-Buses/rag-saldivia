<histrix tipo="consulta">
	<title>Impuestos</title>
	<obs></obs>
	<consulta>
		<table id="FAC_IMPUESTOS" label="Impuestos">

		  <field id="id_facimpuesto" autoinc="true" noshow="true" />

		  <field id="nombre_impuesto">
			<label>Nombre</label>
		  </field>

		  <field id="facservicio_id" noshow="true" />
   
