<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="ayuda" >
    <title>Movimientos</title>
    <obs></obs>
    <form  >
        <table id="REG_CUENTA" >
	  
	     <field id="id_regcuenta" autoinc="true" _noshow="true" esClave="true">
                <label>Numero Cuenta</label>
		<detalle>regcuenta_id</detalle>
            </field>
            <field id="nombre_cuenta">
                <label>Nombre</label>
                <detalle>nombre</detalle>
            </field>
            <field id="tel_cuenta">
                <label>Telefono</label>
                <detalle>tel_cuenta</detalle>
            </field>
            <field id="cuit_cuenta">
                <label>CUIT</label>
                <detalle>CUIT</detalle>
            </field>
            <field id="percepcion">
                <label>Percepcion</label>
                <detalle>percepcion</detalle>
            </field>
            <field id="subsistema_id" noshow="true" valauto="true">
                <label>subsistema</label>
            </field>

            <field id="direccion">
		<expression>
			concat(GEN_CALLES.nombre_calle, ' '  , REG_CUENTA.nro_direccion , ' ', 
 			case when REG_CUENTA.bis_direccion = 1 then 'Bis' else '' end) 
		</expression>
                <label>Direccion</label>
                <detalle>direccion</detalle>
            </field> 
            <field id="cp" tabla="GEN_LOCALIDADES">
                <label>CP</label>
                <detalle>CP</detalle>
            </field>

            <field id="nombre_localidad" tabla="GEN_LOCALIDADES">
                <label>Localidad</label>
                <detalle>nombre_localidad</detalle>
            </field>
            <field id="nombre_provincia" tabla="GEN_PROVINCIAS">
                <label>Provincia</label>
                <detalle>nombre_provincia</detalle>
            </field>
            <field id="id_iva" tabla="GEN_IVA" noshow="true">
                <label>Iva</label>
                <detalle>iva</detalle>
            </field>
            <field id="nombre_iva" tabla="GEN_IVA">
                <label>Categoria Iva</label>
                <detalle>categoria_iva</detalle>
            </field>
	<order>
		<field id="nombre_cuenta">
                </field>
	</order>
	
<!--
-->
	</table>


	<join tipo="left">
	    <table id="GEN_CALLES">
		<field id="id_calle">
		    <condicion operador="=">REG_CUENTA.calle_id</condicion>
		</field>
	     </table>
	</join>
	<join tipo="left">
	    <table id="GEN_LOCALIDADES">
		<field id="id_localidad">
		    <condicion operador="=">REG_CUENTA.localidad_id</condicion>
		</field>
	     </table>
	</join>
	<join tipo="left">
	    <table id="GEN_IVA">
		<field id="id_iva">
		    <condicion operador="=">REG_CUENTA.iva_id</condicion>
		</field>
	     </table>
	</join>
	<join tipo="left">
	    <table id="GEN_PROVINCIAS">
		<field id="id_provincia">
		    <condicion operador="=">REG_CUENTA.provincia_id</condicion>
		</field>
	     </table>
	</join>	
    </form>
</histrix>

