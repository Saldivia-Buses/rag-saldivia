<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="ayuda" >
  <title>Pedidos Pendientes</title>
  <obs></obs>
  <form >
	<table id="REG_MOVIMIENTOS" label="Facturas">
		<field id="id_regmovim" autoinc="true" noshow="true">
<!--		<condicion operador="not in">(SELECT  RM.id_regmovim  FROM REG_MOVIMIENTOS 
			JOIN REG_DETALLES ON REG_DETALLES.regmovim_id = REG_MOVIMIENTOS.id_regmovim
			JOIN REG_IMPUTACIONESDETALLES ON REG_IMPUTACIONESDETALLES.regdetalleped_id = REG_DETALLES.id_regdetalle
			JOIN REG_DETALLES RD ON RD.id_regdetalle = REG_IMPUTACIONESDETALLES.regdetallefac_id	
			JOIN REG_MOVIMIENTOS RM  ON RM.id_regmovim = RD.regmovim_id 
			where REG_MOVIMIENTOS.concepto_id  =  (select option_value from HTXOPTIONS where option_name = 'ID_NOTA_PEDIDOS') )
		</condicion>
-->
		</field>


		<field id="comprobante"  >
			<label>Comprobante</label>
			<expresion>(concat(fecha_movimiento,' ',descripcion_concepto ,' ',LPAD(REG_MOVIMIENTOS.nro_movimiento,8,'0')))</expresion>
		</field>
		<field id="el_concepto_id" >
			<expresion>concepto_id</expresion>
			<condicion operador="=">(select option_value from HTXOPTIONS where option_name = 'ID_NOTA_PEDIDOS')</condicion>
		</field>


		<field id="domicilio_movimiento" >
			<detalle>domicilio_movimiento</detalle>
		</field>
		
                <field id="regcuenta_id_fac" noshow="true" esClave="true">
                    <expresion>regcuenta_id</expresion>
                </field>
 		<field id="regcuentatransporte_id" noshow="true" esClave="true">
			<detalle>regcuentatransporte_id</detalle>
		</field>
		<field id="regcuentavendedor_id" noshow="true" esClave="true">
			<detalle>regcuentavendedor_id</detalle>
		</field>

		<field id="cantidadStk" >
			<label>Stock</label>
			<tipo>numeric</tipo>			
			<expresion>SELECT case when isnull(cantidad) then 0 else  sum(cantidad * case when tipo_concepto  =  0 then 1 else -1 end)  end
			FROM STK_ARTICULOS
			LEFT JOIN STK_MOVIMIENTOS  	ON STK_MOVIMIENTOS.stkarticulo_id = STK_ARTICULOS.id_stkarticulo
			LEFT JOIN STK_CONCEPTOS 	ON STK_MOVIMIENTOS.stkconcepto_id = STK_CONCEPTOS.id_stkconcepto
			join REG_DETALLES rd ON STK_ARTICULOS.id_stkarticulo = rd.codigo_detalle
			WHERE rd.regmovim_id = REG_MOVIMIENTOS.id_regmovim and rd.codigo_detalle= REG_DETALLES.codigo_detalle
			GROUP BY codigo_detalle,rd.regmovim_id
			order by case when isnull(cantidad) then 0 else  sum(cantidad * case when tipo_concepto  =  0 then 1 else -1 end)  end desc	limit 1
			</expresion>
		</field>

		<field id="pendientes" oculto="true">
			<label>Pendientes</label>
			<expresion>ifnull(cantidad_detalle,0) -  sum(ifnull(cantidad_imputada,0))</expresion>

<!--			<expresion having="false">(case when isnull(REG_DETALLES.cantidad_detalle) then 0 else REG_DETALLES.cantidad_detalle end - ifnull((SELECT sum(RI1.cantidad_imputada) FROM REG_IMPUTACIONESDETALLES RI1 
JOIN REG_DETALLES RD1 ON RD1.id_regdetalle = RI1.regdetallefac_id
JOIN REG_MOVIMIENTOS RM1 ON RM1.id_regmovim = RD1.regmovim_id and RM1.concepto_id = (select option_value from HTXOPTIONS where option_name = 'ID_REMITOS')
where RI1.regdetallefac_id= REG_DETALLES.id_regdetalle),0))
			</expresion> 
			<condicion operador="&gt;">0</condicion>  -->
		</field>
		<field id="wcontrolstk" noshow="true"/> 
		<field id="paraelhaving" noshow="true"> <!-- Fuerza el havin -->
			<expresion>1</expresion>
			<condicion operador="=">1 and (( Stock &gt; 0 and ('[__wcontrolstk__]' = '0' or '[__wcontrolstk__]' = '' ))
						or ('[__wcontrolstk__]' = '1')) 
			</condicion>   			
		</field>
		<group>
			<field id="id_regmovim"  />
			<field id="codigo_detalle"  />
			<field id="comprobante"  >
				<expresion>(concat(fecha_movimiento,' ',descripcion_concepto ,' ',LPAD(REG_MOVIMIENTOS.nro_movimiento,8,'0')))</expresion>
			</field>
			<field id="concepto_id" />
			<field id="domicilio_movimiento" />
			<field id="regcuenta_id" />
			<field id="regcuentatransporte_id" />
			<field id="regcuentavendedor_id" />
		</group>
	</table>
	<join>
		<table id="REG_CONCEPTOS">  
			<field id="id_concepto">
				<condicion operador="=">REG_MOVIMIENTOS.concepto_id  and
				REG_CONCEPTOS.id_concepto in
				(select option_value from HTXOPTIONS where option_name = 'ID_NOTA_PEDIDOS' or  option_name = "ID_FACTURAS") 
				</condicion>
			</field>
		</table>
	</join>
	<join>
		<table id="REG_DETALLES">  
			<field id="regmovim_id">
				<condicion operador="=">REG_MOVIMIENTOS.id_regmovim</condicion>
			</field>
		</table>
	</join>
	<join tipo="LEFT">
		<table id="REG_IMPUTACIONESDETALLES">  
			<field id="regdetalleped_id ">
				<condicion operador="=" >id_regdetalle</condicion>
			</field>
		</table>
	</join> 
  </form>
</histrix>
