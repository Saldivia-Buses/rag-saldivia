<?xml version="1.0" encoding="UTF-8" ?>
<!--

	Ayuda Puestos de Caja

-->
<histrix tipo="consulta">
  <title>Puestos</title>
  <obs></obs>
  <form>
  
    <table id="CAJ_PUESTOS" label="Puestos" >
      
      <field id="id_cajpuesto">
        <label>Código</label>
      </field>

      <field id="descripcion_puesto">
        <label>Descripcion</label>
        <detalle>cajpuesto_nombre</detalle>
      </field>

      <field id="login" local="true">
        <valor eval="true">$_SESSION['usuario']</valor>
      </field>
      
      <field id="cajpuesto_superior_id">
      	<expression>ifnull(CAJ_PUESTOS.cajpuesto_id,0)</expression>
      	<detalle>cajpuesto_superior_id</detalle>
      </field>
      
    </table>

    <join>
      <table id="CAJ_PUESTO_USERS">
        <field id="cajpuesto_id">
          <condicion operador="=">CAJ_PUESTOS.id_cajpuesto</condicion>
        </field>
        <field id="usuario_id">
          <condicion operador="=">( SELECT Id_usuario FROM HTXUSERS where login = '[__login__]') </condicion>
        </field>
      </table>  
    </join>

  </form>
</histrix>
