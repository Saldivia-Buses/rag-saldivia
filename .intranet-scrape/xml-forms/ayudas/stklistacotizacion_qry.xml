<histrix tipo="consulta">
	<title>Listas de Precios</title>
	<obs></obs>
	<form >	    
		<table id="STK_LISTAS" label="Listas de Precios">

		  <field id="id_stklista" autoinc="true" _noshow="true">
			<label>Código</label>
		  </field>

		  <field id="stklista_nombre">
			<label>Nombre</label>
			<help>Nombre de Lista de Precio</help>
		  </field>
		  <field id="moneda_id" noshow="true">
			<label>Moneda</label>
			<detalle>moneda_id</detalle>
		  </field>
		  <field id="fecha_movimiento" local="true" noshow="true" oculto="true">
		    <tipo>date</tipo>
		  </field>
		  <field id="cotizacion" local="true"  deshabilitado="true">		
			<tipo>decimal(18,4)</tipo>
			<expresion>GEN_FN_COTIZACION(STK_LISTAS.moneda_idvta , '[__fecha_movimiento__]')</expresion>
			<detalle>cotizacion</detalle>
		  </field>
		  <field id="moneda_idvta" noshow="true">
			<label>Moneda Venta</label>
			<detalle>wmoneda_idvta</detalle>
		  </field>
		
		</table>
	</form>

</histrix>	
