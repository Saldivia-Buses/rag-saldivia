<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="ayuda" >
    <title>Vendedores</title>
    <obs></obs>
    <form  >
        <table id="REG_CUENTA" >
	     <field id="id_regcuenta" autoinc="true" _noshow="true" esClave="true">
                <label>Numero Cuenta</label>
		        <detalle>regcuenta_id</detalle>
            </field>
            <field id="nombre_cuenta">
                <label>Nombre</label>
                <detalle>nombre</detalle>
            </field>
            <field id="subsistema_id" noshow="true">
                <label>subsistema</label>
            </field>
            
            <field id="regcuenta_id" tabla="REG_CUENTA_RELACIONES" noshow="true" />
            <order>
                <field id="nombre_cuenta" />
            </order>
	</table>
	<join tipo="left">
	    <table id="REG_CUENTA_RELACIONES">
	        <field id="regcuentarelacionada_id">
	            <condicion operador="=">REG_CUENTA.id_regcuenta</condicion>
	        </field>
	    </table>
	</join>
    </form>
</histrix>

