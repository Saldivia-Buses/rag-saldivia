<?xml version="1.0" encoding="UTF-8"?>
<abm tipo="ing"  borra="no" inserta="no"  llenoreferente="true" imprime="false" barraDrag="false">
	<!-- <referentes>ordenpago_cajmovim_ing.xml</referentes> -->
	<titulo>RECIBOS</titulo>
	<obs/>
	<consulta>
		<tabla id="CCTMOVIM" label="RECIBOS" idCampoCond="imputar">

			<campo id="siscod" oculto="true">
				<label>Cod.</label>
				<help></help>
				<valor>'02'</valor>
				<condicion operador="=">'02'</condicion>
			</campo>

			<campo id="ctacod" noshow="true">
				<label>Cuenta</label>
				<help>Codigo de Cuenta</help>
<!--				<detalle>ctacodCAB</detalle>			-->
			</campo> 
			<campo id="movfec" deshabilitado="true">
				<label modpos="nobr">Fecha</label>
				<help></help>
				<!--  <formato>d  m  y</formato> -->
				<detalle>movfecCAB</detalle>				
			</campo>
			<campo id="concod"  tabla="CCTMOVIM" oculto="true">
				<label>concod</label>
				<help>Tipo</help>
				<detalle>concodCAB</detalle>
			</campo>

			<campo id="condes"  tabla="CCTCONCE" deshabilitado="true">
				<label>Tipo</label>
				<help>Tipo de Comprobante</help>
				<tipo>varchar</tipo>
				<detalle>concepto</detalle>				
			</campo>
			<campo id="movnpv" deshabilitado="true">
				<label modpos="nobr">Numero</label>
				<help>Comprobante</help>
				<formato>%04d</formato>
				<detalle>movnpvCAB</detalle>				
			</campo>
			<campo id="movnro" deshabilitado="true">
				<label modpos="nobr"/>
				<help>Numero Comprobante</help>
				<formato>%012d</formato>
				<detalle>movnroCAB</detalle>				
			</campo>
			<campo id="movimp" deshabilitado="true">
				<label PDFsize="12" posx="130" posy="+1">Total Pago</label>
				<help></help>
				<formato>%01.2f</formato>
				<detalle>movimpCAB</detalle>
				
			</campo>
			<campo id="movsal" deshabilitado="true">
				<label>saldo</label>
				<help></help>
<!--				<condicion operador="!=">0</condicion>-->
				<detalle>movsalCAB</detalle>				
				<detalle>salantCAB</detalle>				
				<condicion operador="&lt;">0</condicion> 
				
			</campo>
			
			<campo id="imputar" local="true" refresh="true">
				<label>imputar</label>
				<help>Seleccion</help>
				<tipo>check</tipo>  
				<valor>0</valor>
			</campo>			
			<campo id="movcta" deshabilitado="true" noshow="true">
				<label modpos="nobr">movcta</label>
				<detalle>movctaCAB</detalle>				
			</campo>	
			<campo id="movlet"  noshow="true">
				<detalle>movletCAB</detalle>				

			</campo>			
			<campo id="movipv"  noshow="true">
				<detalle>movipvCAB</detalle>				
			</campo>			
			<campo id="movinc"  noshow="true">
				<detalle>movincCAB</detalle>				
			</campo>			
			<campo id="zoncod"  noshow="true">
				<detalle>zoncodCAB</detalle>				

			</campo>			
			<campo id="impgra" noshow="true" suma="true">
				<label>Neto</label>
				<expresion>sum(IVAIMPORTES.impgra)</expresion>
				<tipo>numeric</tipo>
				<detalle>impgraCAB</detalle>	
			</campo>


			<group>
				<campo id="ctacod" tabla="CCTMOVIM" />
				<campo id="movnro" />
				<campo id="movnpv" />
				
			</group>			
		</tabla>
		<join tipo="left">
			<tabla id="CCTCONCE">
				<campo id="siscod" oculto="true">
					<label>cctcuent.siscod</label>
					<condicion operador="=">CCTMOVIM.siscod</condicion>
				</campo>
				<campo id="concod" oculto="true">
					<condicion operador="=">CCTMOVIM.concod</condicion>
				</campo>
				<campo id="condes" oculto="true"></campo>
			</tabla>
		</join>
		<join tipo="left">
			<tabla id="CCTCUENT">
				<campo id="siscod" oculto="true">
					<label>cctcuent.siscod</label>
					<condicion operador="=">CCTMOVIM.siscod</condicion>
				</campo>
				<campo id="ctacod" oculto="true">
					<condicion operador="=">CCTMOVIM.ctacod</condicion>
				</campo>
			</tabla>
		</join>
		<join tipo="left">
			<tabla id="IVAIMPORTES">
				<campo id="ctacod" oculto="true">
					<condicion operador="=">CCTMOVIM.ctacod</condicion>
				</campo>
				<campo id="codcom" oculto="true">
					<condicion operador="=">CCTMOVIM.concod</condicion>
				</campo>
				<campo id="nrocom" oculto="true">
					<condicion operador="=">CCTMOVIM.movnro</condicion>
				</campo>
				<campo id="nronpv" oculto="true">
					<condicion operador="=">CCTMOVIM.movnpv</condicion>
				</campo>
				<campo id="tipoiva" oculto="true">
					<condicion operador="=">1</condicion>
				</campo>
				
			</tabla>
		</join>				
