<?xml version="1.0" encoding="ISO-8859-1"?>
<histrix tipo="consulta" style="height:100%;" PDForientacion="L"  paginar="100">
    <title>DETALLE</title>
    <obs></obs>
    <form _detalle="ocprecib_qry.xml" inline="true">
        <table id="CPSMOVIM" label="DETALLE">
            <filters>
                <field id="movfec" >
                    <label>Desde Fecha</label>
                    <operador>&gt;=</operador>
                    <valor>today</valor>
                </field>
                <field id="movfec" >
                    <label>Hasta Fecha</label>
                    <operador>&lt;=</operador>
                    <valor>today</valor>

                </field>

            </filters>

            <field id="artcod" deshabilitado="true">
                <label>Art.</label>
                <help>Codigo de Articulo</help>
                <detalle>artcod</detalle>
            </field>
            <field id="movfec" tabla="CPSMOVIM" noshow="true">
                <label>Fecha</label>
            </field>

            <field id="siscod" oculto="true">
                <help></help>
                <condicion operador='='>''</condicion>

            </field>

            <field id="detalle" deshabilitado="true">
                <label>Detalle</label>
                <help>Detalle de linea de la Orden de Compra para Art S.C. </help>
            </field>

<!--            <field id="movuso" deshabilitado="true">
            <field id="observaciones"  tabla="CPSMOVIM" noshow="true">
                <label modpos="nobr">Observaciones</label>
                <tipo>varchar</tipo>
            </field>
            <field id="movuso" deshabilitado="true">
                <label>Ped.</label>
                <help>Pedido (expresado en la unidad de uso)</help>
            </field>
	     
            <field id="movcps" deshabilitado="true">
                <label>Ped.cps</label>
                <help>Pedido (expresado en la unidad de compra)</help>
            </field> -->
            <field id="costo" deshabilitado="true" tipoOrden="DESC" useAlias="true" noshow="true">
                <label>Total</label>
                <expression>(sum(movcps - pencps) * (select STKINSPR.artcos from STKINSPR
                where STKINSPR.artcod = CPSMOVIM.artcod and
            	      STKINSPR.siscod = '01' and
            	      month(STKINSPR.movfec) &lt;= 12 and
            	      year(STKINSPR.movfec) = year(CPSMOVIM.movfec) order by movfec DESC limit 1))</expression>
              <tipo>numeric</tipo>
            </field>


