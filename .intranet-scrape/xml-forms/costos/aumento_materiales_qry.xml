            <field id="cantEne" noZero="true">
                <expression>sum( case when month(CPSMOVIM.movfec) = 1 then (movcps - pencps) else 0 end)</expression>
                <tipo>numeric</tipo>
                <label>Ene</label>
             
            </field>
            <field id="totEne" local="true" noZero="true">
                <if exp="true">
                    <true>cantEne * mov_penEne + 0</true>
                    <false>0</false>
                </if>
                <tipo>numeric</tipo>
            </field>
