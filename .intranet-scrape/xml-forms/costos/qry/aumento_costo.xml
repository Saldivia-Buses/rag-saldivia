<?xml version="1.0" encoding="ISO-8859-1"?>
<histrix tipo="consulta" borra="no" inserta="no" limit="100" subtipo="vertical" >
	<title>Insumos</title>
	<obs></obs>
	<form detalle="cctcuent_x_insumo.xml" inline="true">
		<table id="STKINSUM">
			<title>Insumos</title>


			<filters>
				<field id="artcod" deshabilitado="false">
					<label>Cod.</label>
					<operador modificador="left">=</operador>
				</field>
				<field id="artdes" deshabilitado="false">
					<label>Articulo</label>
					<operador>like</operador>
				</field>

				<field id="fecha_desde">
					<label>Desde</label>
					<valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-6 month')) , 1, date("Y")  ))</valor>
				</field>
				<field id="fecha_hasta">
					<label>Hasta</label>
					<tipo>date</tipo>
					<valor>today</valor>
				</field>
			</filters>


			<field id="artcod" deshabilitado="true" _Formstyle="display:none;">
				<ayuda_ex id="STKINSUM">
					<field id="artcod" oculto="true">
						<label>Cod</label>
					</field>
					<field id="artdes">
						<label>Nombre</label>
						<detalle>artdes</detalle>
					</field>
					<field id="siscod" oculto="true">
						<condicion operador="=">'01'</condicion>
					</field>

				</ayuda_ex>

				<label>Cod.</label>
				<detalle>artcod</detalle>
			</field>
			<field id="artdes" _autocompletar="true" deshabilitado="true" _Formstyle="display:none;">
				<label>Articulo</label>
				<ayuda_ex id="STKINSUM">
					<field id="artcod" noshow="true">
						<label>cod</label>
						<detalle>artcod</detalle>
					</field>

					<field id="artdes">
						<label>Nombre</label>
						<detalle>artdes</detalle>
					</field>

					<field id="siscod" oculto="true">
						<condicion operador="=">'01'</condicion>
					</field>

				</ayuda_ex>

			</field>

			<field id="costo_inicial">
			    <label>Costo Inicial</label>
			    <expression having="false"> 
			    @cini:=(SELECT artcos FROM STKINSPR use index (fecha)
			    WHERE STKINSPR.artcod = STKINSUM.artcod
			    and STKINSPR.fecult &lt;= STR_TO_DATE('[__fecha_desde__]', '%d/%m/%Y')
			    ORDER BY STKINSPR.fecult DESC LIMIT 1)
			    </expression>
			    <tipo>numeric</tipo>
		        </field>
			<field id="costo_final">
			    <label>Costo Final</label>
			    <expression having="false"> 
			    @cfin:=(SELECT artcos FROM STKINSPR use index (fecha)
			    WHERE STKINSPR.artcod = STKINSUM.artcod
			    and STKINSPR.fecult &lt;= STR_TO_DATE('[__fecha_hasta__]', '%d/%m/%Y')
			    ORDER BY STKINSPR.fecult DESC LIMIT 1)
			    </expression>
			    <tipo>numeric</tipo>
		        </field>

			<field id="porc_aumento">  
			    <label>% Aumento</label>
			    <expression having="false"> 
			    CAST((((SELECT artcos FROM STKINSPR use index (fecha)
			    WHERE STKINSPR.artcod = STKINSUM.artcod
			    and STKINSPR.fecult &lt;= STR_TO_DATE('[__fecha_hasta__]', '%d/%m/%Y')
			    ORDER BY STKINSPR.fecult DESC LIMIT 1) / (SELECT artcos FROM STKINSPR use index (fecha)
			    WHERE STKINSPR.artcod = STKINSUM.artcod
			    and STKINSPR.fecult &lt;= STR_TO_DATE('[__fecha_desde__]', '%d/%m/%Y')
			    ORDER BY STKINSPR.fecult DESC LIMIT 1)) - 1) * 100 AS DECIMAL)
			    </expression>

			    <tipo>decimal</tipo>
		        </field>

			<field id="fecha_desde" local="true" noshow="true">
				<label>Desde</label>
				<tipo>date</tipo>
			</field>
			<field id="fecha_hasta" local="true" noshow="true">
				<label>Hasta</label>
				<tipo>date</tipo>
			</field>

			<field id="valcps" noshow="true">
				<label>Val.Compra</label>
				<help>Valor de Compra</help>

			</field>

			<field id="unicps" noshow="true">
				<label modpos="nobr">Unidad</label>
				<help>Unidad de Compra</help>
				<tabla_ex id="FSMUNIDS">
					<field id="unicod"></field>
					<field id="uninom"></field>
				</tabla_ex>
			</field>
			<field id="valuso" noshow="true">
				<label>Val.Uso</label>
				<help>Valor de Uso</help>
			</field>

			<field id="artuni" noshow="true">
				<label modpos="nobr">U.Uso</label>
				<help>Unidad de Uso</help>
				<tabla_ex id="FSMUNIDS">
					<field id="unicod"></field>
					<field id="uninom"></field>
				</tabla_ex>
			</field>

			<field id="baja" oculto="true">
				<condicion operador="!=">1</condicion>
			</field>

