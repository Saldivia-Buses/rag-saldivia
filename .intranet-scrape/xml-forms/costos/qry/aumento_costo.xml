			<field id="siscod" oculto="true">
				<label>siscod</label>
			</field>
<!--
			<group>
				<field id="artcod" tabla="STKINSUM"></field>
			</group>
-->

			<order>
			   <field id="porc_aumento" tipoOrden="desc"></field>
			</order>


		</table>
