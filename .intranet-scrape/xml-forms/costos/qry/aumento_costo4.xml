<abm tipo="consulta">
	<titulo>COSTOS</titulo>
	<obs></obs>
	<consulta>
		<tabla id="VISTA_STK_COSTOS" label="CONSULTA DE COSTOS" _styleTbody="height:500px; overflow-x: hidden;">
<!--			<filtro_ex>
				<label>Presupuesto</label>
