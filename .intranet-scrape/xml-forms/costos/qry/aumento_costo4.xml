			<filtros>
				<campo id="fecha">
					<label>Fecha</label>
					<operador>&lt;=</operador>
				<valor>today</valor>					
				</campo>
			</filtros>
			<campo id="siscod" esclave="true">
					<condicion operador="=">'PR'</condicion>
					<valor>PR</valor>
			</campo> 
			<campo id="movcod" noshow="true">
					<label>movcod</label>
				<condicion operador="=">1</condicion>
			</campo>			
			<campo id="movnro" esclave="true">
					<label>Numero</label>
			</campo>
			<campo id="fecha" local="true">
				<label>Fecha</label>
				<operador>&lt;=</operador>
				<valor>today</valor>
				<tipo>date</tipo>
			</campo>			
			<campo id="artcod" esclave="true">
				<label>codigo</label>
					<ayuda_ex id="STKINSUM" xml="HLPstkinsum.xml" dir="/help_local">
						<campo id="artcod">
							<label>Cod.</label>
							<detalle>artcod</detalle>
						</campo>
						<campo id="artdes">
							<label>Insumo</label>
							<detalle>artdes</detalle>
						</campo>

						<campo id="unicps" oculto="true">
<!--							<detalle>unimed</detalle> -->
							<detalle>unicps</detalle>

						</campo>
						<campo id="artuni" oculto="true">
<!--							<detalle>unimed</detalle> -->
							<detalle>artuni</detalle>
						</campo>

						<campo id="valcps" oculto="true">
							<detalle>valcps</detalle>
						</campo>
						<campo id="valuso" oculto="true">
							<detalle>valuso</detalle>
						</campo>						
						<campo id="siscod" oculto="true">
							<condicion operador="=">'01'</condicion>
						</campo>
						<clave>artcod</clave>
						<descripcion>artdes</descripcion>
					</ayuda_ex>				
			</campo>
			<campo id="artdes" tabla="STKINSUM" >
				<expresion>STKINSUM.artdes</expresion>
				<label>Articulo</label>
				<tipo>varchar</tipo>
			</campo>
			<campo id="movpes"  >
				<label>Cantidad</label>
				<tipo>numeric</tipo>
			</campo> 
						<campo id="valcps" noshow="true" tabla="STKINSUM">
						</campo>
						<campo id="valuso" noshow="true" tabla="STKINSUM">
						</campo>				
			<campo id="uninom" tabla="FSMUNIDS" deshabilitado="true">
				<expresion>FSMUNIDS.uninom</expresion>
				<label>Unidad</label>
				<tipo>char</tipo>
			</campo> 
<!--			<campo id="costo" >
				<label>Costo</label>
				<expresion>STKINSUM.artcos * STKINSUM.valcps / STKINSUM.valuso</expresion>
			</campo> -->
			<campo id="costo" >
				<label>Costo</label>
				<expresion>round(case when ((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = VISTA_STK_COSTOS.artcod and STR_TO_DATE('[__fecha__]', '%d/%m/%Y') >= STKINSPR.fecult  and STKINSPR.siscod='01' order by fecult DESC limit 1) * STKINSUM.valcps / STKINSUM.valuso) > 0  then ((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = VISTA_STK_COSTOS.artcod and STR_TO_DATE('[__fecha__]', '%d/%m/%Y') >= STKINSPR.fecult  and  STKINSPR.siscod='01' order by fecult DESC limit 1) * STKINSUM.valcps / STKINSUM.valuso) else STKINSUM.artcos end, 2)</expresion>
			</campo>
			
			<campo id="parcial"  suma="true">
				<label>Parcial</label>
				<expresion>(case when ((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = VISTA_STK_COSTOS.artcod and STR_TO_DATE('[__fecha__]', '%d/%m/%Y') >= STKINSPR.fecult  and STKINSPR.siscod='01' order by fecult DESC limit 1) * STKINSUM.valcps / STKINSUM.valuso) > 0  then ((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = VISTA_STK_COSTOS.artcod and STR_TO_DATE('[__fecha__]', '%d/%m/%Y') >= STKINSPR.fecult and STKINSPR.siscod='01' order by fecult DESC limit 1) * STKINSUM.valcps / STKINSUM.valuso) else STKINSUM.artcos end) * movpes</expresion>
				<tipo>numeric</tipo>
			</campo> 
			<campo id="fecult" tabla="STKINSPR" tipoOrden="DESC">
				<expresion>max(STKINSPR.fecult)</expresion>
				<label>ult.compra</label>
				<tipo>date</tipo>
			</campo>
			<campo id="fec2ult" tabla="STKINSPR" _noshow="true">
				<expresion sql="true"><![CDATA[ select max(STKINS.fecult) from STKINSPR as STKINS where STKINS.artcod ='[__artcod__]' and '[__fecult__]' > STKINS.fecult  and STKINS.siscod='01' order by fecult DESC limit 1 ]]></expresion>
				<label>compra Ant</label>
				<tipo>date</tipo>
			</campo>			
			<campo id="cos2to" noshow="true">
				<label>Costo Ant</label>
				<expresion sql="true"><![CDATA[ select round(STKINS.artcos * [__valcps__] / [__valuso__], 2) from STKINSPR as STKINS where STKINS.artcod ='[__artcod__]' and '[__fecult__]' > STKINS.fecult  and STKINS.siscod='01' order by fecult DESC limit 1 ]]></expresion>
			</campo> 
			<campo id="inc" local="true">
				<label>% Inc.</label>
				<if exp="0cos2to &lt; 0costo &amp;&amp; 0cos2to != 0">
					<verdadero>round((0costo - 0cos2to) / 0cos2to * 100, 2)</verdadero>
					<falso>0</falso>
				</if>
			</campo>								
            <campo id="hilite"  clasefila="true" local="true" noshow="true">
                            <if exp="0inc > 0">
                                        <verdadero>'resaltado'</verdadero>
                                        <falso>'0'</falso>
                                </if>
                                <tipo>varchar</tipo>
            </campo>
			<campo id="ctacod" tabla="STKINSPR" >
				<expresion>(select ctacod from STKINSPR where STKINSPR.artcod = VISTA_STK_COSTOS.artcod and STR_TO_DATE('[__fecha__]', '%d/%m/%Y') >= STKINSPR.fecult  and STKINSPR.siscod='01' order by fecult DESC limit 1) </expresion>
				<label>Proveedor</label>
				<tipo>varchar</tipo>
				<tabla_ex id="CCTCUENT">
					<campo id="ctacod" />
					<campo id="ctafan" />					
					<campo id="siscod" oculto="true">
						<condicion operador="=">'01'</condicion>
					</campo>
				</tabla_ex>
			</campo>	
			<campo id="ctbcod" print="false" tabla="CTBCUENT">
				<label>Nro Cta</label>
				<tipo>varchar</tipo>
			</campo>

			<campo id="ctbnom" tabla="CTBCUENT" print="false">
				<expresion>ctbnom</expresion>
				<label>CtaCtb</label>
				<tipo>varchar</tipo>
			</campo>				
			<group>
				<campo id="VISTA_STK_COSTOS.artcod" />
				<campo id="VISTA_STK_COSTOS.movfec" />
			</group>
			<orden>
				<campo id="artdes"></campo>
				<campo id="fecult" />
				
			</orden>
		</tabla>
		<join tipo="left">
		
			<tabla id="STKINSUM">
				<campo id="siscod" oculto="true">
					<label>siscod</label>
					<condicion operador="=">'01'</condicion>
		
				</campo>
				<campo id="artcod" oculto="true">
					<condicion operador="=">VISTA_STK_COSTOS.artcod</condicion>
				</campo>
		
			</tabla>
		</join>
		<join tipo="left">
		
			<tabla id="CTBCUENT">
<!--				<campo id="siscod" oculto="true">
					<condicion operador="=">'10'</condicion>
				</campo>
-->				
				<campo id="ctbcod" oculto="true">
					<condicion operador="=">STKINSUM.artctb</condicion>
				</campo>
		
			</tabla>
		</join>				
		<join tipo="left">
		
			<tabla id="FSMUNIDS">
				<campo id="unicod" oculto="true">
					<condicion operador="=">STKINSUM.artuni</condicion>
				</campo>
		
			</tabla>
		</join>		
		<join tipo="left">
		
			<tabla id="STKINSPR">
				<campo id="siscod" >
					<condicion operador="=">'01'</condicion>
				</campo>
				<campo id="fecult" >
					<condicion operador="&lt;=">STR_TO_DATE('[__fecha__]', '%d/%m/%Y')</condicion>
				</campo>				
				<campo id="artcod" >
					<condicion operador="=">VISTA_STK_COSTOS.artcod</condicion>
				</campo>

		
			</tabla>
		</join>		
					
	</consulta>
</abm>