<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" preloadData="false" imprime="false" width="45%">
  <title>Modificación de Movimientos</title>
  <obs/>
  <form detalle="regmovimientos_modif_ing.xml">
    <table id="REG_MOVIMIENTOS" label="Ingreso de Movimientos" >
      <filters>
        
        <field id="nro_cuenta">
          <label>Cod.</label>
          <operador>=</operador>
          <size>5</size>
        </field>

        <field id="nombre_cuenta" deshabilitado="true">
          <label modpos="nobr">Cuenta</label>
        </field>
        
        <field id="fecha_movimiento">
          <operador>&gt;=</operador>
          <label>Desde Fecha</label>
          <valor>today</valor>
        </field>
        
        <field id="fecha_movimiento">
          <operador>&lt;=</operador>
          <label modpos="nobr">Hasta Fecha</label>
          <valor>today</valor>
        </field>

        <field id="concepto_id">
          <label>Comprobante</label>
          <operador>=</operador>
        </field>

        <field id="nro_movimiento">
          <label modpos="nobr">Nro. Comprobante</label>
          <operador>=</operador>
        </field>

      </filters>

      <field id="id_regmovim" esClave="true" noshow="true" >
        <detalle>id_regmovim</detalle>
      </field>
      
      <field id="subsistema_id" oculto="true" valauto="true" >
<!--        <detalle>subsistema_id</detalle> -->
      </field>
      
      <field id="nro_cuenta">
        <label>Cod.Cta.</label>
        <help>Código de Cuenta </help>
        <helper type="external" id="REG_CUENTA">
          <field id="nro_cuenta">
            <detalle>nro_cuenta</detalle>
          </field>
          <field id="NOM">
            <expression having="false">CONCAT(nombre_fantasia, ' (',  nombre_cuenta,')')</expression>
            <label>Nombre</label>
            <detalle>nombre_cuenta</detalle>
          </field>
          <field id="id_regcuenta">
            <detalle>regcuenta_id</detalle>
          </field>
          <field id="subsistema_id" oculto="true">
            <condicion operador="=">'01'</condicion>
          </field>
          <field id="baja" oculto="true">
            <condicion operador="=">0</condicion>
          </field>
          <order>
            <field id="nombre_cuenta"></field>
          </order>
        </helper>
        <detalle>nro_cuenta</detalle>
      </field>
      
      <field id="letra_movimiento">
        <label modpos="nobr">Letra</label>
        <helper type="combo">
          <option value=""></option>
          <option value="A">A</option>
          <option value="B">B</option>
          <option value="C">C</option>
        </helper>
        <tipo>varchar</tipo>
      
      </field>
      
      <field id="puesto_movimiento" >
        <label modpos="nobr">P.V.</label>
        <size>4</size>
        <tipo>integer</tipo>
<!--        <detalle>puesto_movimiento</detalle> -->
      </field>
      
      <field id="nro_movimiento" >
        <label modpos="nobr">Nro.</label>
        <size>8</size>
        <tipo>integer</tipo>
<!--        <detalle>nro_movimiento</detalle> -->
      </field>
      
      <field id="concepto_id">
        <label>Comprobante</label>
        <helper type="combo" xml="regconcepto_qry.xml" dir="/ayudas" empty="true" >
          <field id="subsistema_id">
            <condicion operador="=" valorde="subsistema_id" />
          </field>
        </helper>
<!--        <detalle>concepto_id</detalle> -->
      </field>

      <!-- <field id="concepto_id">
        <label>Comprobante</label>
        <helper type="combo" id="REG_CONCEPTOS" _dir="/ayudas" empty="true" >
          <field id="id_concepto" esClave="true" noshow="true" />
          <field id="descripcion_concepto">
            <label>Nombre</label>
          </field>
          <field id="ctbcuenta_concepto_id" noshow="true">
            <expression>ctbcuenta_id</expression>
          </field>
          <field id="subsistema_id">
            <condicion operador="=" valorde="subsistema_id" />
          </field>
        </helper>
       <detalle>concepto_id</detalle>
      </field> -->
      
      <field id="fecha_movimiento" >
        <label>Fecha</label>
        <help>Fecha movimiento</help>
        <tipo>date</tipo>
<!--        <detalle>fecha_movimiento</detalle> -->
      </field>
      <field id="importe_movimiento">
        <label style="font-size: 16px">Importe Total</label>
<!--        <detalle>importe_movimiento</detalle> -->
        <tipo>numeric</tipo>
        <size>17</size>
      </field>
      
      <field id="reg_fecha" noshow="true"><!-- 
        <detalle>reg_fecha</detalle> -->
      </field>
      <field id="saldo_movimiento" noshow="true">
<!--        <detalle>saldo_movimiento</detalle> -->
      </field>
      <field id="referencia_movimiento" noshow="true">
<!--        <detalle>referencia_movimiento</detalle> -->
      </field>
      <field id="regcuenta_id" noshow="true">
	    <detalle>regcuenta_id</detalle> 
      </field>
      <field id="nombre_cuenta" local="true" noshow="true">
        <label modpos="nobr">Nombre</label>
        <expression>REG_CUENTA.nombre_cuenta</expression>
        <size>20</size>
<!--        <detalle>nombre_cuenta</detalle>-->
      </field>
      <field id="id" tabla="IVAUNIFICADO" noshow="true">
        <detalle>ivacv_id</detalle> 
      </field>
    </table>
    <join tipo="left">
      <table id="IVAUNIFICADO">
        <field id="regmovim_id">
          <condicion operador="=">REG_MOVIMIENTOS.id_regmovim</condicion>
        </field>
      </table>
    </join>
    <join tipo="left">
      <table id="REG_CUENTA">
        <field id="id_regcuenta">
          <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
        </field>
      </table>
    </join>
  </form>
</histrix>
