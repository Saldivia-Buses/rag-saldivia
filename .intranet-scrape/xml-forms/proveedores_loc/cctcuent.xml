<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="ficha" conBusqueda="true">
  <title>ABM CUENTA</title>
  <obs></obs>
  <form >
    <table id="REG_CUENTA" label="ABM CUENTA">

      <field id="subsistema_id" esClave="true" oculto="true">
        <label>Codigo Sistema</label>
      </field>

      <field id="proxnro" local="true" deshabilitado="true" valauto="true">
        <label style="color:red;">Próximo Número Disponible</label>
        <helper type="combo" id="REG_CUENTA" >
          <field id="subsistema_id" noselect="true">
            <tipo>varchar</tipo>
          </field>
          <field id="ctacod1">
            <expression>max(nro_cuenta) + 1</expression>
          </field>          
          <field id="ctacod2">
            <expression>max(nro_cuenta) + 1</expression>
          </field>        
          <field id="nro_cuenta" noselect="true">
            <condicion operador="&lt;">10000</condicion>
          </field>   
        </helper>      
      </field>

          <field id="baja">
        <label style="background-color:#7ff67f; color:white; font-size:15px" modpos="nobr">Estado</label>
        <help>Cuenta Activa - De Baja</help>
        <options>
          <option valor="1">Baja</option>
          <option valor="0">Activo</option>
        </options> 
      </field>  

      <field id="nro_cuenta" clave="true" esClave="true">
        <!--
        <ayuda_ex id="CCTCUENT" xml="HLPcctcuent.xml" dir="/help_local">
          
          <field id="ctacod">
            <label>Nro</label>
          </field>
          <field id="ctanom">
            <label>Nombre</label>            
          </field>
            
          <clave>ctacod</clave>
          <descripcion>ctanom</descripcion>
        </ayuda_ex>
        -->
        <label>Cuenta</label>
        <help>Código de Cuenta</help>
      </field>

      <field id="nombre_cuenta">
        <label modpos="nobr">Nombre</label>
        <help>Nombre de Cuenta </help>
        <size>50</size>
      </field>
  
      <field id="nombre_fantasia" required="true">
        <label modpos="nobr">Nom.Fantasía</label>
        <help>Nombre de fantasía</help>
        <size>12</size>
      </field>

      <field id="cod_direccion">
        <label colspan="4">Domicilio Fiscal</label>
        <size>60</size>
      </field>
        <field id="empresa_id" _modpos="nobr" required="true">
          <label >Empresa Asignada</label>
          <helper type="combo" id="HTX_EMPRESAS" empty="true">
              <field id="id_empresa"></field>
              <field id="razon_social"></field>
          </helper>
        </field>		

      <field id="codigo_postal">
        <label>Código Postal</label>
      </field>

      <field id="nacionalidad_id" style="padding:2px 2px 2px 2px;width:250px;vertical-align:middle;">
          <label >País</label>
          <helper id="GEN_NACIONALIDADES" type="combo" empty="true">
              <field id="id_nacionalidad" >
                <condicion operador="=">14 OR id_nacionalidad = 16</condicion>
              </field>
              <field id="pais" />
            <order>
                    <field id="pais" />
            </order>
          </helper>
          <actualiza>
                <field id="provincia_id" destino="nacionalidad_id"/>
            </actualiza>
        </field>    

        <field id="provincia_id" style="padding:2px 2px 2px 2px;width:250px;vertical-align:middle;">
              <label>Provincia</label>
              <helper id="GEN_PROVINCIAS" type="combo" empty="true">
              <field id="id_provincia" />
              <field id="nombre_provincia" />
              <field id="nacionalidad_id" oculto="true"/>
            <order>
                    <field id="nombre_provincia" />
            </order>
          </helper>
              <actualiza>
                <field id="localidad_id" destino="provincia_id"/>
              </actualiza>
          </field>

          <field id="localidad_id" style="padding:2px 2px 2px 2px;width:300px;vertical-align:middle;" >
            <label modpos="nobr"> Localidad </label>
            <helper type="combo" xml="localidad_qry.xml" dir="/ayudas" empty="true">
              <field id="provincia_id" oculto="true">
                <condicion operador="=">-1</condicion>
              </field>
            </helper>
          </field>

      <field id="tel_cuenta">
        <label>Teléfono</label>
          <size>20</size>
      </field>

      <field id="fax_cuenta">
        <label modpos="nobr">Tel/Fax</label>
          <size>20</size>
      </field>

      <field id="entrega_direccion">
        <label colspan="1" style="color:blue;">Domicilio Real</label>
      </field>

      <field id="entrega_codigopostal">
        <label modpos="nobr" style="color:blue;">Código Postal Envío</label>
      </field>

      <field id="entrega_nacionalidad_id" style="padding:2px 2px 2px 2px;width:300px;vertical-align:middle;">
          <label style="color:blue;">País de envío</label>
          <helper id="GEN_NACIONALIDADES" type="combo" empty="true">
              <field id="id_nacionalidad" >
                <condicion operador="=">14 OR id_nacionalidad = 16</condicion>
              </field>
              <field id="pais" />
            <order>
                    <field id="pais" />
            </order>
          </helper>
          <actualiza>
                <field id="entrega_provincia_id" destino="nacionalidad_id"/>
            </actualiza>
        </field>   

      <field id="entrega_provincia_id" style="padding:2px 2px 2px 2px;width:250px;vertical-align:middle;">
        <label  style="color:blue;">Prov. Env.</label>
        <helper id="GEN_PROVINCIAS" type="combo" empty="true">
              <field id="id_provincia"/>
              <field id="nombre_provincia"/>
          <field id="nacionalidad_id" oculto="true"/>
            <order>
                    <field id="nombre_provincia" />
            </order>
          </helper>
          <actualiza>
                <field id="entrega_localidad_id" destino="provincia_id"/>
              </actualiza>
      </field>

      <field id="entrega_localidad_id" style="padding:2px 2px 2px 2px;width:300px;vertical-align:middle;" >
            <label modpos="nobr" style="color:blue;"> Localidad de Envío </label>
            <helper type="combo" xml="localidad_qry.xml" dir="/ayudas" empty="true">
              <field id="provincia_id" oculto="true">
                <condicion operador="=">-1</condicion>
              </field>
            </helper>
          </field>
            
      <field id="iva_id">
        <label>Categoría I.V.A. </label>
        <tabla_ex id="FSMCTIVA">
          <field id="ivacod"></field>
          <field id="ivanom"></field>
        </tabla_ex>
      </field>

      <field id="logregion_id">
        <label modpos="nobr">Región</label>
        <help>Región de Logística</help>
	<helper xml="log_region_crud.xml" dir="/logistica" type="combo" empty="true">
	</helper>        
      </field>
<!--      <field id="ctadgr">
        <label modpos="nobr">D.G.R.</label>
        <help> Inscripcion en DGR</help>
        <options>
          <option valor="1">Inscripto</option>
          <option valor="0">No Inscripto</option>
        </options>
      </field>
-->      
      <field id="tipo_documento_id">
        <label>Documento</label>
        <tabla_ex id="FSMDOCUM">
          <field id="doccod"></field>
          <field id="docnom"></field>
        </tabla_ex>
	<valor>80</valor>
      </field>

      <field id="cuit_cuenta" _cuit="true">
        <label modpos="nobr">Número</label>
      </field>

      <field id="regzona_id">
        <label>Código de Zona</label>
      </field>

      <field id="horario">
        <label colspan="2" modpos="nobr">Horario de Atención</label>
        <size>50</size>
      </field>      

      <field id="regcategoria_id">
        <label>Código Categoría </label>
        <tabla_ex id="CCTCATGS">
          <field id="catcod"></field>
          <field id="catnom"></field>
          <field id="siscod">
            <condicion operador="=">'01'</condicion>
          </field>
        </tabla_ex>
      </field>


      <field id="cal_regcategoria_id" required="true">
        <label>Categoría Calidad</label>
    
        <helper id="REG_CATEGORIAS" type="combo" empty="true">
          <field id="id_regcategoria"></field>
          <field id="nombre_categoria"></field>
          <field id="subsistema_id">
            <condicion operador="=">'CA'</condicion>
          </field>
        </helper>
      </field>

      <field id="ctbcod">
        <label modpos="nobr">Cuenta Contable</label>
        <tabla_ex id="CTBCUENT" >
          <field id="ctbcod"></field>
          <field id="ctbnom">
	    <expression>concat(ctbnom,' - ', ctbcod)</expression>
	    </field>
          <field id="ctbhab">
            <condicion operador="=">1</condicion>
          </field>    
<!--    
          <field id="siscod">
            <condicion operador="=">'10'</condicion>
          </field>        
    -->
          <order>
            <field id="ctbnom"></field>
          </order>  
        </tabla_ex>
        <valor>711106</valor>
      </field>
      
      <field id="regforma_id">
        <label>Código</label>
        <tabla_ex id="FACCONDI">
          <field id="vtacod"></field>
          <field id="condes"></field>
        </tabla_ex>
	<valor>29</valor> 
      </field>
      
      <field id="formaPago">
        <label modpos="nobr">Forma de Pago</label>
        <tabla_ex id="FORMAPAGO">
            <field id="formaPago"></field>
            <field id="nombrePago"></field>
        </tabla_ex>
      </field>
      
      <field id="categoria_ganancia">
        <label>Cond. Ganancias</label>
        <help>Inscripto Ganancias</help>
        <tabla_ex id="REG_CATEGORIAS">
          <field id="id_regcategoria"></field>
          <field id="nombre_categoria"></field>
          <field id="tipo_categoria">
              <condicion operador="=">'ganancias'</condicion>
          </field>
        </tabla_ex>
      </field>

      <field id="catganancias_id">
        <label modpos="nobr">Categoría Ganancias</label>
        <help>Categoría de Ganancias</help>
        <helper type="combo" id="RETCONCE" empty="true">
          <field id="retcod"></field>
          <field id="retdes"></field>
        </helper>
      </field>

      <field id="categoria_ingbrutos">
        <label _modpos="nobr">Ing.Brutos</label>
        <help>Categoría Ingresos Brutos</help>
        <helper type="combo" id="REG_CATEGORIAS" >
          <field id="id_regcategoria"></field>
          <field id="nombre_categoria"></field>
          <field id="tipo_categoria">
              <condicion operador="=">'ingbrutos'</condicion>
          </field>
        </helper>
      </field>

      <field id="nro_ingbrutos">
        <label modpos="nobr">Nro.Ing.Brutos.</label>
        <help>Número de Ingresos Brutos</help>
        <size>20</size>
      </field>

      <field id="categoria_rg1598">
        <label>Ing.Brutos Res.1598</label>
        <help>Tipo de Inscripción en Ing.Brutos Res. 1598</help>
        <tabla_ex id="REG_CATEGORIAS">
          <field id="id_regcategoria"></field>
          <field id="nombre_categoria"></field>
          <field id="tipo_categoria">
              <condicion operador="=">'categoria_rg1598'</condicion>
          </field>
        </tabla_ex>
<!--
        <options>
          <option valor="1">Convenio Multilateral</option>
          <option valor="2">Comun</option>
          <option valor="3">No Inscripto</option>
          <option valor="4">Exento</option>
        </options>
        -->
      </field>

      <field id="porcentaje_rg1598">
        <label modpos="nobr">Porcentaje Retención</label>
        <help>Porcentaje de Retención</help>
        <format>%01.2f</format>
      </field>

      <field id="numero_cai">
        <label>Nro.CAI</label>
        <help>Número de CAI</help>
      </field>

      <field id="vencimiento_cai">
        <label modpos="nobr">Vto.Cai </label>
        <help>Vencimiento de CAI</help>
      </field>

      <field id="ref_cuenta">
        <label colspan="5">Obs. </label>
        <help>Observaciones</help>
      </field>

      <field id="estcod">
        <label >No influye en costo</label>
        <help>No se tiene en cuenta en el armado de costos</help>
        <tipo>check</tipo>
      </field>      

      <field id="auditable">
	  <label modpos="nobr">Auditable</label>
	  <helper type="combo">
	    <option value="0">No</option>
	    <option value="1">Si</option>
	  </helper>
	  <tipo>radio</tipo>
      </field>
<!--
      <field id="cert_iso">
          <label modpos="nobr">Certificado ISO9000</label>
          <helper type="combo">
        <option value="0"></option>
        <option value="1">No</option>
        <option value="2">Si</option>
          </helper>
          <tipo>radio</tipo>
      </field>
-->
      <field id="id_regcuenta" noshow="true" />

      <field id="certpath" noshow="true">
	    <expression>CONCAT(id_regcuenta, '/certificados')</expression>
      </field>

      <field id="emails" showTablaObj="true" local="true">
        <helper type="object" xml="contaemail_list_qry.xml" dir="/email">
            <parameter target="ctacod" source="nro_cuenta" />
            <parameter target="siscod" source="subsistema_id" />
        </helper>
        <label >Correos</label>
      </field>

      <field id="rubros" showTablaObj="true" local="true">
        <helper type="object" xml="regcuenta_rubros_crud.xml">
            <parameter target="regcuenta_id" source="id_regcuenta" />
        </helper>
        <label >Rubros</label>
      </field>      

      <field id="certificados" showTablaObj="true" local="true">
        <helper type="object" xml="regcuenta_certificados_crud.xml">
            <parameter target="regcuenta_id" source="id_regcuenta" />
	    <parameter target="certpath" source="certpath" />
        </helper>
        <label >Certificados</label>
      </field>      

      <field id="imputacioness" showTablaObj="true" local="true">
        <helper type="object" xml="cuenta_imputaciones_crud.xml" dir="/proveedores/man/">
            <parameter target="regcuenta_id" source="id_regcuenta" />
        </helper>
        <label >Imputaciones</label>
      </field>      
   
    </table>
  </form>
</histrix>
