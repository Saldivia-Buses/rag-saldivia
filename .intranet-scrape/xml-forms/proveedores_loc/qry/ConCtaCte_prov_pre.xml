<?xml version="1.0" encoding="ISO-8859-1" ?>
<histrix tipo="consulta">
    <title>Cuenta Corriente</title>
    <obs></obs>
    <form  detalle="imputaciones.xml" inline="true">
        <table id="REG_MOVIMIENTOS" label="Movimientos" styleTbody="height:500px;">

	       <field id="id_regmovim" noshow="true" />
	    
            <field id="subsistema_id" oculto="true">
                <label>Cod.</label>
                <help>
                </help>
            </field>
            
            <field id="nro_cuenta" noshow="true">
                <help>Codigo de Cuenta </help>
                    <ayuda_ex id="REG_CUENTA">
            		<field id="nro_cuenta">
                    	    <detalle>nro_cuenta</detalle>
                        </field>
                        <field id="nombre_cuenta">
                            <detalle>ctanom</detalle>
                        </field>
                        <field id="subsistema_id" oculto="true"></field>
                        <field id="baja">
                    	    <condicion operador="=">0</condicion>
                        </field>
                                                                                                                
                        <order>
                            <field id="nombre_cuenta"></field>
                        </order>
                                                                                
                        <filtra>nro_cuenta</filtra>
                    </ayuda_ex>
                    <detalle>nro_cuenta</detalle>
            </field>
                                                                                                                                                            
	    <field id="nombre_cuenta" tabla="REG_CUENTA" deshabilitado="true" local="true" noshow="true">
	        <label>Nombre</label>
	    </field>

            <field id="concod" noshow="true">
                <label>concod</label>
                <detalle>concod</detalle>
            </field>
            <field id="puesto_movimiento" noshow="true">
                <label>P.V.</label>
                <help> Punto Venta</help>
                <format>%04d</format>
                <detalle>movnpv</detalle>
            </field>
            <field id="nro_movimiento"> <!-- linkint="factura_detalle.xml" linkdes="Ver Detalle del Comprobante">-->
                <label>Numero</label>
                <help> Numero Comprobante</help>
                <format>%12d</format>
                <expression>''</expression>
                <detalle>movnro</detalle>
            </field>
            
            <field id="concepto">
                <expression>'SALDO ANTERIOR'</expression>
                <label>Comprobante </label>
            </field>  

            <field id="regmin" _oculto="true">
                <label>minuta</label>
                <expression>''</expression>
            </field>
            <field deshabilitado="true" id="OP" local="true" print="false">
                <label >Ot.</label>
                <expression>''</expression>
                <tipo>varchar</tipo>
            </field>
<!--            <field id="isedit" local="true" noshow="true">
              <valor eval="true">$_SESSION['EDITOR']</valor>
          </field>
            <field id="EDITOR" local="true" noshow="true">
          <if exp="'editor' = 'isedit'">
              <true>true</true>
              <false>false</false>
          </if>
          </field>
    -->      
          <!--
            <field deshabilitado="true" id="mod" local="true" linkint="cctmovim_modif.xml" linkdes="Modif" print="false">
    <attribute id="noshow">EDITOR</attribute>
                <label >Modif</label>
              <valor>Modif</valor>

        
                <paring destino="siscod">siscod</paring>
        
                <paring destino="ctacod">ctacod</paring>
                <paring destino="cajcta">ctacod</paring>
                <paring destino="movnpv">movnpv</paring>
                <paring destino="movnro">movnro</paring>
                <paring destino="concod">concod</paring>
               
                <paring destino="movfec">movfec</paring>

                            
              
