            </field>
         -->
            <field id="fecha_desde" local="true" noshow="true" required="false">
                <label>d</label>
                <tipo>date</tipo>
            </field>
            <field id="fecha_movimiento">
                <label>Fecha </label>
                <help>
                </help>
                <condicion operador="&lt;">(CASE '[__fecha_desde__]' WHEN '' THEN '1950-01-01' ELSE '[__fecha_desde__]' END)</condicion>
            </field>

            <!--          <field id="movvto">
            <label>Venc. </label>
            <help> </help>
            </field>
            -->
            <field id="importe_movimiento" noshow="true" />

            <field id="Debe" suma="true" noZero="true">
                <expression>sum(REG_MOVIMIENTOS.importe_movimiento * (case when (REG_CONCEPTOS.imputacion_concepto + 1) = 1 then 1 else 0 end))</expression>
                <label>Debe</label>
                <help>
                </help>
                <tipo>numeric</tipo>
              
            </field>

            <field id="Haber" suma="true"   noZero="true" link_int="cctmovim_comp.xml" linkdes="Ver Recibo">
		<expression>sum(REG_MOVIMIENTOS.importe_movimiento * (case when (REG_CONCEPTOS.imputacion_concepto + 1) = 2 then 1 else 0 end))</expression>
                <label>Haber</label>
                <help>
                </help>
                <paring destino="movnro">movnro</paring>
                <paring destino="carrec">movnro</paring>
                <paring destino="cajnro">movnro</paring>
                <paring destino="movinc">movnro</paring>
                <paring destino="movnpv">movnpv</paring>
                <paring destino="ctacod">ctacod</paring>
                <paring destino="movfec">movfec</paring>
                <paring destino="cajfec">movfec</paring>
                <tipo>numeric</tipo>
            </field>

            <field id="saldo_movimiento" suma="true">
                <label>Saldo</label>
                <help></help>
                <tipo>numeric</tipo>
            </field>
            <field id="acumulado" suma="true" acumula="true" local="true">
                <if exp="true">
                    <true>Haber - Debe</true>
                    <false>0</false>
                </if>
                <tipo>numeric</tipo>
                <label>Acumulado</label>
            </field>
            <field id="tiene_detalle" noshow="true">
                <expression>0</expression>
            </field>
            <field id="resaltado" clasefila="true" local="true" noshow="true">
                <expression>'resaltadoRojo'</expression>
                <tipo>varchar</tipo>
            </field>
            <order>
                <field id="fecha_movimiento"></field>
            </order>
        </table>

        <join tipo="left">
            <table id="REG_CUENTA">
        	<field id="id_regcuenta" >
	            <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="REG_CONCEPTOS">
                <field id="id_concepto" oculto="true">
                     <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
                 </field>
	    </table>
	</join>
                                                                                                             
    </form>
</histrix>