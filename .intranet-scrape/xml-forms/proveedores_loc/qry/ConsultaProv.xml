      <field id="ctatel">
        <label>Teléfono</label>
        <size>40</size>
      </field>

		<field id="ctatel2" noshow="true">
			<expression>REPLACE(REPLACE(MID(ctatel, LOCATE(' ', ctatel) + 1), '-', ''), ' ', '')</expression>
			<label>ctatel2</label>
		</field>
		<field id="ctatel5" noshow="true" local="true">
				<expression><![CDATA[@ctatel5:= (select REPLACE(
concat( 
'(', 
IFNULL(( case when ctatel != '' then concat('\'', replace(ctatel,' ',''), '\',') else '' end ) , "''"),
IFNULL(group_concat(replace(concat('\'', replace(movil,'15',''),'\''), ' ','')), "''"),
',', 
IFNULL(group_concat(replace(concat('\'', movil,'\''), ' ','')), "''"),
',' , 
IFNULL(group_concat(replace(concat('\'', Telefono,'\''), ' ','')), "''"),
 ')'
) 
, '-', '')
from CCTCONTA where CCTCONTA.ctacod = CCTCUENT.ctacod and CCTCONTA.siscod = CCTCUENT.siscod and (Telefono != '' or movil != ''))]]></expression>
		<label>ctatell5</label>
		</field>
      <field id="ctafax">
        <label modpos="nobr">Fax.</label>
      </field>      
      <field id="horario">
