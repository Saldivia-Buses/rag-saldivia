	</field>

	<field id="subrubros" noshow="true">
	    <expression>(CASE WHEN '[__stksubrubro_id__]' = '' THEN 1 ELSE 
	    (CASE WHEN '[__stksubrubro_id__]' IN ( SELECT stksubrubro_id FROM REG_CUENTA_RUBROS WHERE regcuenta_id = CCTCUENT.id_regcuenta) THEN 1 ELSE 0 END)
	    END)
	    </expression>
	    <condicion operador="=">1</condicion>
	</field>
