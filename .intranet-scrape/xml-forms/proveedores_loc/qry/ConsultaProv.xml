      </field>      
		<field id="cont" noshow="true" deshabilitado="false">
		    <expression>select group_CONCAT(nombre) from CCTCONTA where CCTCONTA.siscod = CCTCUENT.siscod and CCTCONTA.ctacod = CCTCUENT.ctacod</expression>
		    <label>Contacto</label>
		</field>
		<field id="Telef2" noshow="true" deshabilitado="false" >
		    <label>Telef.</label>
		    <expression having="false">concat(ctatel,(select group_CONCAT(Telefono , movil) from CCTCONTA where CCTCONTA.siscod = CCTCUENT.siscod and CCTCONTA.ctacod = CCTCUENT.ctacod))</expression>
		</field>
