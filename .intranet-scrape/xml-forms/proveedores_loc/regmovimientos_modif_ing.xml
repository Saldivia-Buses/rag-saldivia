<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="fichaing"
imprime="false"
inserta="false"
modifica="false"
transaccional="true"
preFetch="true"
>
	<title>Modificación de Movimientos</title>
	<confirmacion>
		<![CDATA[¿Desea modificar el comprobante?  ]]>
	</confirmacion>
	<obs/>
	<form>
		<table id="REG_MOVIMIENTOS" label="Ingreso de Movimientos" >

			<movimientos>
				<relacion id="regmovimiento_update.xml" />
				<relacion id="cctimput_update.xml" />
				<relacion id="cctimput0_update.xml" />
				<relacion id="ivacompras_update.xml" />
				<relacion id="ivaimportes_update.xml" />
				<relacion id="facdetal_update.xml" />
				<relacion id="facremimp_update.xml" />

				<!-- si "actacte" = 1 realiza los movimientos para pasarlo a Forma de pago = Cuenta corriente -->
				<relacion id="cctmovim_actacte_delete.xml" />
				<!-- <relacion id="cctmovim_actacte_update.xml" />
				-->
				<relacion id="cajmovim_actacte_delete.xml" />
				<relacion id="ctbregis_actacte_update.xml" />

				<!-- si "acontado" = 1 realiza los movimientos para pasarlo a Forma de pago = Contado -->
				<relacion id="cctmovim_acontado_insert.xml" />
				<relacion id="cajmovim_acontado_insert.xml" />
				<relacion id="ctbregis_acontado_update.xml" />
				
				<relacion id="ctbregis_update.xml" />

			</movimientos>

			<field id="id_regmovim" esClave="true" noshow="true" />

			<field id="subsistema_id" noshow="true">
			    <actualiza>
				<field id="concepto_id" destino="subsistema_id" />
			    </actualiza>
			</field>

			<field id="concepto_id" _Formstyle="display:none;" deshabilitado="true">
				<label>Comprobante</label>
				<helper type="combo" xml="regconcepto_qry.xml" dir="/ayudas" empty="true" >
-					<field id="subsistema_id" oculto="true" />
				</helper>
			</field>

			<field id="concod" noshow="true" >
				<helper type="combo" id="CCTCONCE" empty="true">
					<field id="concod" />
					<field id="condes" />
					<field id="siscod">
						<condicion operador="=">'01'</condicion>
					</field>
				</helper>
				<label>Tipo</label>
			</field>

      <field id="nro_cuenta" deshabilitado="true">
        <label>Cuenta</label>
      </field>

      <field id="nombre_cuenta" deshabilitado="true">
          <label _modpos="nobr">Nombre</label>
          <expression><![CDATA[IFNULL((select ctanom from CCTCUENT where ctacod = nro_cuenta and siscod ='01' ),'')]]></expression>                
      </field>

			<field id="cuit_cuenta" local="true" deshabilitado="true">
				<label modpos="nobr" colspan="2" />
				<tipo>varchar</tipo>
			</field>

			<field id="regcuenta_id" noshow="true"></field>

			<field id="letra_movimiento" deshabilitado="true">
				<label>Letra</label>
				<helper type="combo">
					<option value=""></option>
					<option value="A">A</option>
					<option value="B">B</option>
					<option value="C">C</option>
				</helper>
				<tipo>varchar</tipo>
			</field>

			<field id="puesto_movimiento">
				<label>P.V.</label>
				<size>4</size>
				<tipo>integer</tipo>
			</field>

			<field id="nro_movimiento">
				<label>Nro.</label>
				<size>8</size>
				<tipo>integer</tipo>
			</field>

			<field id="old_nro_movimiento" Formstyle="display:none;">
				<expression>nro_movimiento</expression>
			</field>

			<field id="fecha_movimiento">
				<label>Fecha</label>
				<help>Fecha movimiento</help>
				<tipo>date</tipo>
			</field>

			<field id="reg_fecha">
				<label>Registración</label>
				<help>Corresponde a la Fecha de Registración Contable</help>
				<tipo>date</tipo>
			</field>

			<field id="referencia_movimiento">
				<label colspan="4">Referencia</label>
				<help>Referencia del movimiento</help>
				<size>100</size>
				<tipo>varchar</tipo>
			</field>

			<field id="old_importe_movimiento" Formstyle="display:none;">
				<expression>importe_movimiento</expression>

			</field>
			<field id="importe_movimiento">
				<label _style="font-size: 16px">Importe Total</label>
				<tipo>numeric</tipo>
				<size>17</size>
				<jseval campodestino="razon_cambio_imp">importe_movimiento / old_importe_movimiento</jseval>
			</field>

			<field id="saldo_movimiento">
				<label _style="font-size: 16px">Saldo</label>
				<tipo>numeric</tipo>
				<size>17</size>
			</field>

			<field id="old_execom" Formstyle="display:none;">
				<expression>IVACOMPRAS.execom</expression>
			</field>

			<field id="execom" tabla="IVACOMPRAS">
			    <label>Exento</label>
			    <tipo>numeric</tipo>
			    <size>17</size>
			</field>

			<field id="regmin" deshabilitado="true">
				<label>Nro Minuta</label>
			</field>

			<field id="regref" local="true" Formstyle="display:none;">
				<if exp="true">
					<true>'concod - puesto_movimiento-nro_movimiento - nombre_cuenta'</true>
					<false>''</false>
				</if>
			</field>

			<field id="razon_cambio_imp" local="true" Formstyle="display:none;">
				<label>Razón</label>
				<valor default="true">1</valor>
			</field>

			<field id="old_formapago" noshow="true">
				<expression>
					ifnull((select 2 from CTBREGIS where CTBREGIS.ctbcod = '111102' and CTBREGIS.regmin = REG_MOVIMIENTOS.regmin and CTBREGIS.regnro = REG_MOVIMIENTOS.nro_movimiento and CTBREGIS.regfec = REG_MOVIMIENTOS.reg_fecha limit 1), 1)
				</expression>
			</field>

			<field id="formapago" local="true" deshabilitado="false">
                <expression having="false">ifnull((select 2 from CTBREGIS where CTBREGIS.ctbcod = '111102' and CTBREGIS.regmin = REG_MOVIMIENTOS.regmin and CTBREGIS.regnro = REG_MOVIMIENTOS.nro_movimiento and CTBREGIS.regfec = REG_MOVIMIENTOS.reg_fecha limit 1), 1)</expression>
				<helper type="combo" >
					<option value="1">Cta. Cte.</option>
					<option value="2">Contado</option>
				</helper>
				<label>Forma de Pago</label>
				<jseval campodestino="saldo_movimiento">(formapago == 2)? 0 : saldo_movimiento</jseval>
				<jseval campodestino="actacte">(formapago == 1 )? ((old_formapago == 2)? 1 : 0) : 0</jseval>
				<jseval campodestino="acontado">(formapago == 2 )? ((old_formapago == 1)? 1 : 0) : 0</jseval>

				<tipo>integer</tipo>
			</field>

			<field id="checkiva" local="true" editable="true" _refresh="true"  style="color:red;font-weight:bold;font-size:16px;">
				<label>Modifica IVA</label>
				<tipo>check</tipo>
				<valor>1</valor>
			</field>

			<field id="grabaiva"  local="true" noshow="true">
				<if exp="'checkiva' == 1">
					<true>1</true>
					<false>0</false>
				</if>
				<label>Graba IVA</label>
			</field>

			<field id="actacte" local="true" Formstyle="display:none;" >
				<!--<if exp="formapago == 1 &amp;&amp; old_formapago == 2">
				<true>(concod == 1)? 1 : 0</true>
				<false>0</false>
			</if>
			-->
			<label>A Cta.cte.</label>
		</field>

		<field id="acontado" local="true" Formstyle="display:none;">
			<!--<if exp="formapago == 2 &amp;&amp; old_formapago == 1">
			<true>(concod == 1)? 1 : 0</true>
			<false>0</false>
		</if>
		-->
		<label>A Contado</label>
	</field>
	<field id="concod4" local="true" Formstyle="display:none;">
		<valor default="true">4</valor>
	</field>
	<field id="movref__ctdo" local="true" Formstyle="display:none;">
		<valor default="true">'Factura Contado'</valor>
	</field>
	<field id="ivacv_id" local="true" noshow="true"/>
</table>
<join tipo="left">
    <table id="IVACOMPRAS">
	<field id="regmovim_id">
	    <condicion operador="=">REG_MOVIMIENTOS.id_regmovim</condicion>
	</field>
    </table>
</join>

</form>
</histrix>