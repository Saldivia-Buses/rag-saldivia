<histrix tipo="consulta" path="fotos/articulos">
  <title>COSTOS</title>
  <obs></obs>
  <form  detalle="cctcuent_x_insumo.xml" inline="true" >
    <table id="VISTA_STK_COSTOS" label="CONSULTA DE COSTOS" _styleTbody="height:500px; overflow-x: hidden;">
      <filtro_ex>
        <label>Presupuesto</label>
        <tabla_ex id="NOTAENCA">
          <!-- campos a agregar al contenedor Filtro-->

          <field id="movnro">
            <tipo>integer</tipo>
          </field>

          <field id="movref__1">
            <expression>CONCAT( CONVERT(movnro, CHAR), CONCAT(' - ', movref__1))</expression>
          </field>

          <field id="siscod" oculto="true">
            <condicion operador="=">'PR'</condicion>
          </field>

          <order>
            <field id="movnro"></field>
          </order>

          <!-- Campo que se filtra (clave del filtro)-->
          <filtra>movnro</filtra>
        </tabla_ex>
      </filtro_ex>
      <filters>
        <!--       <field id="fecha">
        <label>Fecha</label>
        <operador>&lt;=</operador>
        <valor>today</valor>
      </field>
      -->
    </filters>
    <field id="siscod" esclave="true" noshow="true">
      <condicion operador="=">'PR'</condicion>
      <valor>PR</valor>
    </field>
    <field id="movcod" noshow="true">
      <label>movcod</label>
      <condicion operador="=">1</condicion>
    </field>
    <field id="movnro" esclave="true">
      <label>Numero</label>
      <!--          <valor>1</valor>
    <condicion operador="=">1</condicion>
    -->
  </field>
  <field id="fecha" local="true" noshow="true">
    <label>Fecha</label>
    <operador>&lt;=</operador>
    <valor>today</valor>
    <tipo>date</tipo>
  </field>
  <field id="bom" noshow="true">
    <expression>
      ifnull((select 'stkpieza_qry.xml' from STKPIEZA where STKPIEZA.idPadre = STKINSUM.artcod limit 1),'')
    </expression>
  </field>
  <field id="artcod" esclave="true" linkdir="articulos">
    <label>codigo</label>
    <attribute id="linkint">bom</attribute>
    <paring destino="idPadre">artcod</paring>
    <detalle>idPadre</detalle>
    <ayuda_ex id="STKINSUM" xml="HLPstkinsum.xml" dir="/help_local">
      <field id="artcod">
        <label>Cod.</label>
        <detalle>artcod</detalle>
      </field>
      <field id="artdes">
        <label>Insumo</label>
        <detalle>artdes</detalle>
      </field>

      <field id="unicps" oculto="true">
        <!--              <detalle>unimed</detalle>
      -->
      <detalle>unicps</detalle>

    </field>
    <field id="artuni" oculto="true">
      <!--              <detalle>unimed</detalle>
    -->
    <detalle>artuni</detalle>
  </field>

  <field id="valcps" oculto="true">
    <detalle>valcps</detalle>
  </field>
  <field id="valuso" oculto="true">
    <detalle>valuso</detalle>
  </field>
  <field id="siscod" oculto="true">
    <condicion operador="=">'01'</condicion>
  </field>
  <clave>artcod</clave>
  <descripcion>artdes</descripcion>
</ayuda_ex>
<detalle>artcod</detalle>
</field>
<field id="artdes" tabla="STKINSUM" >
<expression>STKINSUM.artdes</expression>
<label>Articulo</label>
<tipo>varchar</tipo>
</field>
<field id="movpes"  >
<label>Cantidad</label>
<tipo>numeric</tipo>
</field>
<field id="valcps" noshow="true" tabla="STKINSUM"></field>
<field id="valuso" noshow="true" tabla="STKINSUM"></field>
<field id="uninom" tabla="FSMUNIDS" deshabilitado="true">
<expression>FSMUNIDS.uninom</expression>
<label>Unidad</label>
<tipo>char</tipo>
</field>
<!--      <field id="costo" >
<label>Costo</label>
<expression>STKINSUM.artcos * STKINSUM.valcps / STKINSUM.valuso</expression>
</field>
-->
<field id="costo" >
<label >Costo</label>
<!-- NO TOCAR, TE MATO -->

<expression having="false" >
(
        ifnull((select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1), 
        (select ROUND(INSPR.artcos * valcps / valuso, 2) from STKINSPR as INSPR where  INSPR.siscod = STKINSPR.siscod and INSPR.fecult= max(STKINSPR.fecult) and INSPR.artcod = STKINSPR.artcod limit 1)))
</expression>
1
<expresion_1 having="false" >
(
        case when (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1) != 0 then 
                  (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1)
          else  (select ROUND(INSPR.artcos * valcps / valuso, 2) from STKINSPR as INSPR where INSPR.fecult= max(STKINSPR.fecult) and INSPR.artcod = STKINSPR.artcod and INSPR.siscod = STKINSPR.siscod limit 1) end)
</expresion_1>

<!--
        <expresion2 having="false" >
(
        case when (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1) != 0 then (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1)
          else  (select INSPR.artcos / (case when valuso &gt; valcps then valuso else 1 end) from STKINSPR as INSPR where INSPR.fecult= max(STKINSPR.fecult) and INSPR.artcod = STKINSPR.artcod and INSPR.siscod = STKINSPR.siscod limit 1) end)
</expresion2>
-->
<tipo>numeric</tipo>
</field>

<!--
      <field id="costo" >
<label>Costo</label>
<expression>
COALESCE((select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1), 
  round((costo_calculado * STKINSUM.valcps / STKINSUM.valuso), 2))
</expression>
</field>
-->
<field id="parcial"  suma="true" local="true">
<label>Parcial</label>
<!--  <expression>
COALESCE((select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1), 
  round((costo_calculado * STKINSUM.valcps / STKINSUM.valuso), 2)) * movpes
</expression>
-->
<if exp="true">
<true>(costo + 0) * movpes</true>
<false></false>
</if>

<!--
        <expression>
(case when ((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = VISTA_STK_COSTOS.artcod and STR_TO_DATE('[__fecha__]', '%d/%m/%Y') >= STKINSPR.fecult  and STKINSPR.siscod='01' order by fecult DESC limit 1) * STKINSUM.valcps / STKINSUM.valuso) > 0  then ((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = VISTA_STK_COSTOS.artcod and STR_TO_DATE('[__fecha__]', '%d/%m/%Y') >= STKINSPR.fecult and STKINSPR.siscod='01' order by fecult DESC limit 1) * STKINSUM.valcps / STKINSUM.valuso) else STKINSUM.artcos end) * movpes
</expression>
-->
<tipo>numeric</tipo>
</field>

<field id="dto" noshow="true">
<expression having="false" >
(
        case when (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1) != 0 then (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1)
          else  (select ROUND(((INSPR.artcos * valcps / valuso) - ((INSPR.artcos * valcps / valuso) * (artpor__1 / 100))) - 
            (((INSPR.artcos * valcps / valuso) - ((INSPR.artcos * valcps / valuso) * (artpor__1 / 100))) * (artpor__2 / 100)) , 2) from STKINSPR as INSPR where INSPR.siscod = STKINSPR.siscod and INSPR.fecult= max(STKINSPR.fecult) and INSPR.artcod = STKINSPR.artcod limit 1) end)
</expression>

<expresion2 having="false" >
(
        case when (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1) != 0 then (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1)
          else  ROUND(((INSPR.artcos * valcps / valuso) - ((INSPR.artcos * valcps / valuso) * (artpor__1 / 100))) - 
            (((INSPR.artcos * valcps / valuso) - ((INSPR.artcos * valcps / valuso) * (artpor__1 / 100))) * (artpor__2 / 100)) , 2) from STKINSPR as INSPR where INSPR.siscod = STKINSPR.siscod  and INSPR.fecult= max(STKINSPR.fecult) and INSPR.artcod = STKINSPR.artcodlimit 1) end)
</expresion2>
<label>dto</label>
<tipo>numeric</tipo>
</field>

<field id="parcialdto" suma="true" local="true">
<label>Parcial Dto.</label>
<if exp="true">
<true>(dto + 0) * movpes</true>
<false></false>
</if>
<tipo>numeric</tipo>
</field>

<field id="fecult" tabla="STKINSPR" tipoOrden="DESC">
<expression>max(STKINSPR.fecult)</expression>
<label>ult.compra</label>
<tipo>date</tipo>
</field>
<field id="fec2ult" tabla="STKINSPR" _noshow="true">
<expression _sql="true">
<![CDATA[ select max(STKINS.fecult) from STKINSPR as STKINS where STKINS.artcod = STKINSUM.artcod and STKINSUM.fecult >
STKINS.fecult  and STKINS.siscod='01' order by fecult DESC limit 1 ]]>
</expression>
<label>compra Ant</label>
<tipo>date</tipo>
</field>
<field id="cos2to" noshow="true">
<label>Costo Ant</label>
<expression _sql="true">
<![CDATA[ select round(STKINS.artcos * STKINSUM.valcps / STKINSUM.valuso, 2) from STKINSPR as STKINS where STKINS.artcod = STKINSUM.artcod and STKINSUM.fecult >
STKINS.fecult  and STKINS.siscod='01' order by fecult DESC limit 1 ]]>
</expression>
</field>
<field id="inc" local="true">
<label>% Inc.</label>
<if exp="0cos2to &lt; 0costo &amp;&amp; 0cos2to != 0">
<true>round((0costo - 0cos2to) / 0cos2to * 100, 2)</true>
<false>0</false>
</if>
</field>
<field id="hilite"  clasefila="true" local="true" noshow="true">
<if exp="0inc >
0">
<true>'resaltado'</true>
<false>'0'</false>
</if>
<tipo>varchar</tipo>
</field>

<field id="ctacod" tabla="STKINSPR" >
<expression>
(select ctacod from STKINSPR SPR where SPR.siscod='01' and SPR.artcod = STKINSUM.artcod   order by fecult DESC limit 1)
</expression>

<!--        <expression>
(select ctacod from STKINSPR SPR where SPR.siscod='01' and  SPR.fecult &lt;= STR_TO_DATE('[__fecha__]', '%d/%m/%Y')   and SPR.artcod = STKINSUM.artcod   order by fecult DESC limit 1)
</expression>
-->
<label>Proveedor</label>
<tipo>varchar</tipo>
<tabla_ex id="CCTCUENT">
<field id="ctacod" />
<field id="ctanom" />
<field id="siscod" oculto="true">
<condicion operador="=">'01'</condicion>
</field>
</tabla_ex>
</field>

<field id="ctbcod" print="false" tabla="CTBCUENT">
<label>Nro Cta</label>
<tipo>varchar</tipo>
</field>

<field id="ctbnom" tabla="CTBCUENT" print="false">
<expression>ctbnom</expression>
<label>CtaCtb</label>
<tipo>varchar</tipo>
</field>

<order>
<field id="ctbnom"></field>
</order>

<field id="salida" >
<label>Ultima Salida</label>
<expression  sql="true" >
select max(STKINMOV.movfec) from STKINMOV  where STKINMOV.artcod = '[__artcod__]' and  STKINMOV.siscod = '01' and STKINMOV.movcod = 10
</expression>
<tipo>date</tipo>
</field>
<field id="fotopath" local="true" noshow="true">
<if exp="true">
<true>'artcod/'</true>
<false>''</false>
</if>
<tipo>varchar</tipo>
</field>

<field id="foto" path="fotopath" download="true">
              <expression>select ARTICULO_FOTO.foto from ARTICULO_FOTO where ARTICULO_FOTO.idArticulo = STKINSUM.artcod and ARTICULO_FOTO.foto != '' order by revision desc limit 1</expression> 
<label>Imagen</label>
<tipo >file</tipo>
<size>40</size>
</field>
<group>
<field id="VISTA_STK_COSTOS.artcod" />
<field id="VISTA_STK_COSTOS.movfec" />
</group>

</table>
<join tipo="left">

<table id="STKINSUM">
<field id="siscod" oculto="true">
<label>siscod</label>
<condicion operador="=">'01'</condicion>

</field>
<field id="artcod" oculto="true">
<condicion operador="=">VISTA_STK_COSTOS.artcod</condicion>
</field>

</table>
</join>
<join tipo="left">

<table id="CTBCUENT">
<!--
<field id="siscod" oculto="true">
<condicion operador="=">'10'</condicion>
</field>
-->
<field id="ctbcod" oculto="true">
<condicion operador="=">STKINSUM.artctb</condicion>
</field>

</table>
</join>
<join tipo="left">

<table id="FSMUNIDS">
<field id="unicod" oculto="true">
<condicion operador="=">STKINSUM.artuni</condicion>
</field>

</table>
</join>
<join tipo="left">

<table id="STKINSPR">
    <field id="siscod" >
	<condicion operador="=">'01'</condicion>
    </field>
    <field id="fecult" >
	<condicion operador="&lt;=">STR_TO_DATE('[__fecha__]', '%d/%m/%Y')</condicion>
    </field>
    <field id="artcod" >
	<condicion operador="=">VISTA_STK_COSTOS.artcod</condicion>
    </field>

</table>
</join>

</form>
</histrix>