        <!--<field id="costo">
            <label>Costo</label>
            <expression>COALESCE((select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1), 
                round((costo_calculado * STKINSUM.valcps / STKINSUM.valuso), 2))</expression>
        </field>-->

        <field id="parcial" suma="true" local="true">
            <label>Parcial</label>
            <!--<expression>COALESCE((select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1), 
                round((costo_calculado * STKINSUM.valcps / STKINSUM.valuso), 2)) * movpes</expression>-->
            <if exp="true">
                <true>(costo + 0) * movpes</true>
                <false></false>
            </if>
            <!--<expression>(case when ((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = VISTA_STK_COSTOS.artcod and STR_TO_DATE('[__fecha__]', '%d/%m/%Y') >= STKINSPR.fecult  and STKINSPR.siscod='01' order by fecult DESC limit 1) * STKINSUM.valcps / STKINSUM.valuso) > 0  then ((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = VISTA_STK_COSTOS.artcod and STR_TO_DATE('[__fecha__]', '%d/%m/%Y') >= STKINSPR.fecult and STKINSPR.siscod='01' order by fecult DESC limit 1) * STKINSUM.valcps / STKINSUM.valuso) else STKINSUM.artcos end) * movpes</expression>-->
            <tipo>numeric</tipo>
        </field>

        REPOSICION
        <field id="cotizacion" sincelda="true" modpos="nobr" noshow="true">
            <label>Cotización</label>
            <expression>@cotiz:=(select cotizacion_genmonedahis  from GEN_MONEDA_HIS where GEN_MONEDA_HIS.moneda_id = STK_COSTO_REPOSICION.moneda_id order by fecha_genmonedahis DESC limit 1)</expression>
        </field>

        <!-- <field id="costo_final_moneda_local" style="font-weigth:bold;color:blue;">
            <label>Costo Repos.</label>
            <expression>round(@cotiz * (costo_proveedor + (costo_proveedor / 100 * gasto_importacion))  + (flete_local_ars / @cotiz), 2)</expression>
            <tipo>numeric</tipo>
        </field>-->

        <field id="costo_final_func" style="font-weigth:bold;color:blue;">
            <label>Costo Repo.</label>
            <expression>ifnull(getCostFunc(VISTA_STK_COSTOS.artcod, ifnull(STK_COSTO_REPOSICION.moneda_id, 1), STR_TO_DATE('[__fecha__]', '%d/%m/%Y')  ), 0) * (case when (select count(*) from STKPIEZA where IdPadre = VISTA_STK_COSTOS.artcod) then 1 else (valcps / valuso) end)</expression> 
<!--            <expression>ifnull(getCostFunc(VISTA_STK_COSTOS.artcod, ifnull(STK_COSTO_REPOSICION.moneda_id, 1), STR_TO_DATE('[__fecha__]', '%d/%m/%Y')  ), 0) </expression> -->

            <!--<expression>(case when costo_proveedor = 0 then costo_reposicion(VISTA_STK_COSTOS.artcod,DATE(NOW()), STK_COSTO_REPOSICION.moneda_id) else round(@cotiz * (costo_proveedor + (costo_proveedor / 100 * gasto_importacion))  + (flete_local_ars / @cotiz), 2) end) * valcps / valuso</expression> -->
            <tipo>numeric</tipo>
        </field>
        <field id="parcialR"  suma="true" local="true">
            <label>Parcial Repos</label>
            <if exp="true">
                <true>(costo_final_func + 0) * movpes</true>
                <false></false>
            </if>
            <tipo>numeric</tipo>
        </field>

        <field id="costo_final_func_cdesc" style="font-weigth:bold;color:red;">
            <label>Costo Repo.c/Desc</label>
            <expression>ifnull(getCostConDtoFunc(VISTA_STK_COSTOS.artcod, ifnull(STK_COSTO_REPOSICION.moneda_id, 1), STR_TO_DATE('[__fecha__]', '%d/%m/%Y'), 0  ), 0) * (case when (select count(*) from STKPIEZA where IdPadre = VISTA_STK_COSTOS.artcod) then 1 else (valcps / valuso) end)</expression>            <tipo>numeric</tipo>
        </field>

        <field id="parcialRCD"  suma="true" local="true">
            <label>Parcial Repos c/Desc</label>
            <if exp="true">
                <true>(costo_final_func_cdesc + 0) * movpes</true>
                <false></false>
            </if>
            <tipo>numeric</tipo>
        </field>

        <field id="dto" noshow="true">
            <expression having="false" >(
            case when (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1) != 0 then (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1)
                else  (select ROUND(((INSPR.artcos * valcps / valuso) - ((INSPR.artcos * valcps / valuso) * (artpor__1 / 100))) - 
                (((INSPR.artcos * valcps / valuso) - ((INSPR.artcos * valcps / valuso) * (artpor__1 / 100))) * (artpor__2 / 100)) , 2) from STKINSPR as INSPR where INSPR.siscod = STKINSPR.siscod and INSPR.fecult= max(STKINSPR.fecult) and INSPR.artcod = STKINSPR.artcod limit 1) end)</expression>
        <expresion2 having="false" >(
        case when (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1) != 0 then (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1)
    	    else  ROUND(((INSPR.artcos * valcps / valuso) - ((INSPR.artcos * valcps / valuso) * (artpor__1 / 100))) - 
						(((INSPR.artcos * valcps / valuso) - ((INSPR.artcos * valcps / valuso) * (artpor__1 / 100))) * (artpor__2 / 100)) , 2) from STKINSPR as INSPR where INSPR.siscod = STKINSPR.siscod  and INSPR.fecult= max(STKINSPR.fecult) and INSPR.artcod = STKINSPR.artcodlimit 1) end)</expresion2>
			<label>dto</label>
			<tipo>numeric</tipo>
	  </field>
<!--
	  <field id="parcialdto" suma="true" local="true">
		<label>Parcial Dto.</label>
		<if exp="true">
			<true>(dto + 0) * movpes</true>
			<false></false>
		</if>
		<tipo>numeric</tipo>
	  </field>
-->

      <field id="fecult" tabla="STKINSPR" tipoOrden="DESC" local="true">
        <expression>max(STKINSPR.fecult)</expression>
        <label>Últ.compra</label>
        <tipo>date</tipo>
      </field>
      <field id="fec2ult" tabla="STKINSPR" _noshow="true">
        <expression sql="true"><![CDATA[ (select max(STKINS.fecult) from STKINSPR as STKINS where STKINS.artcod ='[__artcod__]' and CASE WHEN '[__fecult__]' = '' THEN '0000-00-00' ELSE '[__fecult__]' END > STKINS.fecult  and STKINS.siscod='01' order by fecult DESC limit 1) ]]></expression>
        <label>Compra Ant</label>
        <tipo>date</tipo>
      </field>      
      <field id="cos2to" noshow="true">
        <label>Costo Ant</label>
        <expression sql="true"><![CDATA[ (select round(STKINS.artcos * 0[__valcps__] / 0[__valuso__], 2) from STKINSPR as STKINS where STKINS.artcod ='[__artcod__]' and CASE WHEN '[__fecult__]' = '' THEN '0000-00-00' ELSE '[__fecult__]' END > STKINS.fecult  and STKINS.siscod='01' order by fecult DESC limit 1) ]]></expression>
      </field> 
      <field id="inc" local="true">
        <label>% Inc.</label>
        <if exp="0cos2to &lt; 0costo &amp;&amp; 0cos2to != 0">
          <true>round((0costo - 0cos2to) / 0cos2to * 100, 2)</true>
          <false>0</false>
        </if>
      </field>          
            <field id="hilite"  clasefila="true" local="true" noshow="true">
                            <if exp="0inc > 0">
                                        <true>'resaltado'</true>
                                        <false>'0'</false>
                                </if>
                                <tipo>varchar</tipo>
            </field>
            
      <field id="ctacod" tabla="STKINSPR" >
        <expression>(select ctacod from STKINSPR SPR where SPR.siscod='01' and SPR.artcod = STKINSUM.artcod   order by fecult DESC limit 1)</expression> 
<!--        <expression>(select ctacod from STKINSPR SPR where SPR.siscod='01' and  SPR.fecult &lt;= STR_TO_DATE('[__fecha__]', '%d/%m/%Y')   and SPR.artcod = STKINSUM.artcod   order by fecult DESC limit 1) </expression> -->
        <label>Proveedor</label>
        <tipo>varchar</tipo>
        <tabla_ex id="CCTCUENT">
          <field id="ctacod" />
          <field id="ctafan" />          
          <field id="siscod" oculto="true">
            <condicion operador="=">'01'</condicion>
          </field>
        </tabla_ex>
      </field>  
      
      <field id="ctbcod" print="false" tabla="CTBCUENT">
        <label>Nro Cta</label>
        <tipo>varchar</tipo>
      </field>

      <field id="ctbnom" tabla="CTBCUENT" print="false">
        <expression>ctbnom</expression>
        <label>CtaCtb</label>
        <tipo>varchar</tipo>
      </field>
      <field id="salida" >
        <label>Última Salida</label>
        <expression  sql="true" >select max(STKINMOV.movfec) from STKINMOV  where STKINMOV.artcod = '[__artcod__]' and  STKINMOV.siscod = '01' and STKINMOV.movcod = 10</expression>
        <tipo>date</tipo>
      </field>  
      <field id="fotopath" local="true" noshow="true">
        <if exp="true">
          <true>'artcod/'</true>
          <false>''</false>
        </if>
        <tipo>varchar</tipo>
      </field>

      <field id="foto" path="fotopath" download="true">
            <expression>select ARTICULO_FOTO.foto from ARTICULO_FOTO where ARTICULO_FOTO.idArticulo = STKINSUM.artcod and ARTICULO_FOTO.foto != '' order by revision desc limit 1</expression> 
            <label>Imagen</label>
            <tipo >file</tipo>
            <size>40</size>
      </field>
      <group>
        <field id="VISTA_STK_COSTOS.artcod" />
        <field id="VISTA_STK_COSTOS.movfec" />
      </group>
      <order>
        <field id="artdes"></field>
        <field id="fecult" />
        
      </order>
    </table>
    <join tipo="left">
    
      <table id="STKINSUM">
        <field id="siscod">
          <label>siscod</label>
          <condicion operador="=">'01'</condicion>
    
        </field>
        <field id="artcod">
          <condicion operador="=">VISTA_STK_COSTOS.artcod</condicion>
        </field>
    
      </table>
    </join>
    <join tipo="left">
      <table id="STK_COSTO_REPOSICION">
        <field id="stkarticulo_id" >
          <condicion operador="=">STKINSUM.artcod</condicion>
        </field>
      </table>
    </join>
    <join tipo="left">
    
      <table id="CTBCUENT">
<!--
        <field id="siscod" oculto="true">
          <condicion operador="=">'10'</condicion>
        </field>
    -->    
        <field id="ctbcod" oculto="true">
          <condicion operador="=">STKINSUM.artctb</condicion>
        </field>
    
      </table>
    </join>        
    <join tipo="left">
    
      <table id="FSMUNIDS">
        <field id="unicod" oculto="true">
          <condicion operador="=">STKINSUM.artuni</condicion>
        </field>
    
      </table>
    </join>    
    <join tipo="left">
    
      <table id="STKINSPR">
        <field id="siscod" >
          <condicion operador="=">'01'</condicion>
        </field>
        <field id="fecult" >
          <condicion operador="&lt;=">STR_TO_DATE('[__fecha__]', '%d/%m/%Y')</condicion>
        </field>        
        <field id="artcod" >
          <condicion operador="=">VISTA_STK_COSTOS.artcod</condicion>
        </field>

    
      </table>
    </join>    
          
  </form>
</histrix>
