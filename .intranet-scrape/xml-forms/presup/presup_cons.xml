<histrix tipo="consulta" path="fotos/articulos" preloadData="false">
  <title>COSTOS</title>
  <obs></obs>
  <form detalle="cctcuent_x_insumo.xml" inline="true">
    <table id="VISTA_STK_COSTOS" label="CONSULTA DE COSTOS">
        
        <filters>

            <field id="movnro">
                <label>Presupuesto</label>
                <operador>=</operador>
            </field>

            <field id="fecha">
                <label>Fecha</label>
                <operador>&lt;=</operador>
                <valor>today</valor>
            </field>
            <field id="artcod">
                <label>Cod</label>
                <operador>=</operador>
            </field>
        </filters>

        <field id="siscod" esclave="true" noshow="true">
             <condicion operador="=">'PR'</condicion>
            <valor>PR</valor>
        </field>

        <field id="movcod" noshow="true">
            <label>movcod</label>
            <condicion operador="=">1</condicion>
        </field>

        <field id="movnro" esclave="true" noshow="true">
            <label>Presupuesto</label>
            <helper type="combo" id="NOTAENCA">
                <field id="movnro">
                    <tipo>integer</tipo>
                    <detalle>movnro</detalle>
                </field>
                <field id="movref__1">
                    <expression>CONCAT( CONVERT(movnro, CHAR), CONCAT(' - ', movref__1)) </expression>
                </field>
                <field id="siscod" oculto="true">
                    <condicion operador="=">'PR'</condicion>
                </field>
                <order>
                    <field id="movnro" />
                </order>
            </helper>
        </field>

        <field id="fecha" local="true" noshow="true">
            <label>Fecha</label>
            <operador>&lt;=</operador>
            <valor>today</valor>
            <tipo>date</tipo>
            <detalle>fecha</detalle>
        </field>

        <field id="bom" noshow="true">
            <expression>ifnull((select 'stkpieza_qry.xml' from STKPIEZA where STKPIEZA.idPadre = STKINSUM.artcod limit 1),'')</expression>
        </field>

        <field id="artcod" esclave="true" linkdir="articulos">
            <label>Código</label>
            <attribute id="linkint">bom</attribute>
            <attribute id="linkdes">artcod</attribute>
            <paring destino="idPadre">artcod</paring>
            <paring destino="fecha">fecha</paring>
            <detalle>idPadre</detalle>
            <ayuda_ex id="STKINSUM" xml="HLPstkinsum.xml" dir="/help_local">
                <field id="artcod">
                    <label>Cod.</label>
                    <detalle>artcod</detalle>
                </field>
                <field id="artdes">
                    <label>Insumo</label>
                    <detalle>artdes</detalle>
                </field>
                <field id="unicps" oculto="true">
                    <detalle>unicps</detalle>
                </field>
                <field id="artuni" oculto="true">
                    <detalle>artuni</detalle>
                </field>
                <field id="valcps" oculto="true">
                    <detalle>valcps</detalle>
                </field>
                <field id="valuso" oculto="true">
                    <detalle>valuso</detalle>
                </field>
                <field id="siscod" oculto="true">
                    <condicion operador="=">'01'</condicion>
                </field>
                <clave>artcod</clave>
                <descripcion>artdes</descripcion>
            </ayuda_ex>
            <detalle>artcod</detalle>
        </field>

        <field id="artdes" tabla="STKINSUM">
            <expression>STKINSUM.artdes</expression>
            <label>Artículo</label>
            <tipo>varchar</tipo>
        </field>

        <field id="movpes">
            <label>Cantidad</label>
            <tipo>numeric</tipo>
        </field> 

        <field id="valcps" noshow="true" tabla="STKINSUM" />

        <field id="valuso" noshow="true" tabla="STKINSUM" />

        <field id="uninom" tabla="FSMUNIDS" deshabilitado="true">
            <expression>FSMUNIDS.uninom</expression>
            <label>Unidad</label>
            <tipo>char</tipo>
        </field>

        <!--<field id="costo">
            <label>Costo</label>
            <expression>STKINSUM.artcos * STKINSUM.valcps / STKINSUM.valuso</expression>
        </field>-->

        <!--<field id="costo">
            <label>Costo</label>
            // NO TOCAR, TE MATO
            <expression having="false">(
                ifnull((select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1), 
                (select ROUND(INSPR.artcos * valcps / valuso, 2) from STKINSPR as INSPR where  INSPR.siscod = STKINSPR.siscod and INSPR.fecult= max(STKINSPR.fecult) and INSPR.artcod = STKINSPR.artcod limit 1)))</expression>
                1        <expresion_1 having="false" >(
                case when (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1) != 0 then 
                (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1)
                else  (select ROUND(INSPR.artcos * valcps / valuso, 2) from STKINSPR as INSPR where INSPR.fecult= max(STKINSPR.fecult) and INSPR.artcod = STKINSPR.artcod and INSPR.siscod = STKINSPR.siscod limit 1) end)</expresion_1>
            <tipo>numeric</tipo>
        </field>-->

        <field id="costo" Formstyle="display:none;">
            <label style="font-weight:bold;">Costo</label>
            <!-- NO TOCAR, TE MATO -->
            <expression having="false">
                (case when (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1) != 0 then 
                    (select sum(round( (costo_automatico  * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1)
                        else  STKINSUM.costo_calculado * valcps / valuso  end)</expression>
            <!--<expression having="false">
                (case when (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1) != 0 then (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1)
                    else  (select ROUND(INSPR.artcos * valcps / valuso, 2) from STKINSPR as INSPR where INSPR.siscod = STKINSPR.siscod and  INSPR.artcod = STKINSPR.artcod and INSPR.fecult= max(STKINSPR.fecult)  limit 1) end)
            </expression>-->
            <!--<expression having="false">
                (case when (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1) != 0 then (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1)
                    else  (select INSPR.artcos / (case when valuso &gt; valcps then valuso else 1 end) from STKINSPR as INSPR where INSPR.artcod = STKINSUM.artcod and INSPR.siscod = STKINSUM.siscod order by fecult DESC limit 1) end)
            </expression>-->
            <tipo>numeric</tipo>
        </field>

        <!--<field id="costo" style="font-weight:bold;">
            <expression>SELECT (ROUND((((((STKINSPR.artcos * valcps / valuso) - ((STKINSPR.artcos * valcps / valuso) * (artpor__1 / 100))) - (((STKINSPR.artcos * valcps / valuso) - ((STKINSPR.artcos * valcps / valuso) * (artpor__1 / 100))) * (artpor__2 / 100))) * (1 - (REG_MOVIMIENTOS.descuento_1 / 100))) * (1 - (REG_MOVIMIENTOS.descuento_2 / 100))), 2))
