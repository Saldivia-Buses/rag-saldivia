<?xml version="1.0" encoding="ISO-8859-1"?>
<histrix tipo="abm-mini"  subtipo="vertical">
	<title>MODIFICACION</title>
	<obs></obs>
	<form >
		<table id="STKINMOV" label="MODIFICACION DE COSTOS">
			<field id="siscod" esClave="true" noshow="true" valauto="true">
			<valor>PR</valor>
			</field> 
			<field id="movnro" esClave="true" oculto="true">
					<label>Numero</label>
			</field>
			<field id="movcod"  oculto="true">
					<label>movcod</label>
					<valor>1</valor>
			</field>			
			<field id="artcod" esClave="true" deshabilitado="true">
				<label>codigo</label>
					<ayuda_ex id="STKINSUM" xml="HLPstkinsum.xml" dir="/help_local">
						<field id="artcod">
							<label>Cod.</label>
							<detalle>artcod</detalle>
						</field>
						<field id="artdes">
							<label>Insumo</label>
							<detalle>artdes</detalle>
						</field>
						<field id="unicps" oculto="true">
							<detalle>unicps</detalle>
						</field>
						<field id="artuni" oculto="true">
							<detalle>artuni</detalle>
						</field>
						<field id="valcps" oculto="true">
							<detalle>valcps</detalle>
						</field>
						<field id="valuso" oculto="true">
							<detalle>valuso</detalle>
						</field>						
						<field id="siscod" oculto="true">
							<condicion operador="=">'01'</condicion>
						</field>
						<clave>artcod</clave>
						<descripcion>artdes</descripcion>
					</ayuda_ex>			
			</field>
			<field id="artdes" tabla="STKINSUM" >
				<expression>STKINSUM.artdes</expression>
				<label modpos="nobr">Articulo</label>
				<tipo>char</tipo>
			</field>
			<field id="movpes"  >
				<label >Cantidad</label>
			</field>
			<field id="uninom" tabla="FSMUNIDS" deshabilitado="true">
				<expression>FSMUNIDS.uninom</expression>
				<label modpos="nobr">Unidad</label>
				<tipo>char</tipo>
			</field> 
      <field id="costo" >
        <label style="font-weight:bold;">Costo.</label>

        <!-- NO TOCAR, TE MATO 

		*********************FÃRUMULA ORIGINAL***********************

		<expression having="false" >(
		case when (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1) != 0 then (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1)
		else  (select INSPR.artcos from STKINSPR as INSPR where INSPR.fecult= max(STKINSPR.fecult) and INSPR.artcod = STKINSPR.artcod and INSPR.siscod = STKINSPR.siscod limit 1) end)</expression> 

		*************************************************************-->

        <expression having="false" >(
        case when (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1) != 0 then (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1)
    	    else  (select INSPR.artcos from STKINSPR as INSPR where  INSPR.artcod = artcod and INSPR.siscod = siscod ORDER BY fecult DESC limit 1) end)</expression>

<!--INSPR.fecult= max(STKINSPR.fecult) and
        <expression having="false" >(
        case when (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1) != 0 then (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1)
    	    else  (select INSPR.artcos / (case when valuso &gt; valcps then valuso else 1 end) from STKINSPR as INSPR where INSPR.artcod = STKINSUM.artcod and INSPR.siscod = STKINSUM.siscod order by fecult DESC limit 1) end)</expression>
    -->
        <tipo>numeric</tipo>
      </field>     

<!--			<field id="costo" >
				<label modpos="nobr">Costo</label>
				<expression>case when ((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = STKINMOV.artcod and STKINSPR.siscod='01' order by fecult DESC limit 1) * STKINSUM.valcps / STKINSUM.valuso) > 0  then ((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = STKINMOV.artcod and STKINSPR.siscod='01' order by fecult DESC limit 1) * STKINSUM.valcps / STKINSUM.valuso) else STKINSUM.artcos end</expression>
			</field>
-->			
    
			<field id="parcial"  suma="true" local="true">
				<label modpos="nobr" Formstyle="display:none;">Parcial</label>
			<!--	<expression>(STKINSUM.artcos * STKINSUM.valcps / STKINSUM.valuso) * movpes</expression>  -->
			<!--	<expression>((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = STKINMOV.artcod and STKINSPR.siscod='01' order by fecult DESC limit 1) * STKINSUM.valcps / STKINSUM.valuso) * movpes</expression>  -->
<!--				<expression>(case when ((select round(STKINSPR.artcos, 2) from STKINSPR where STKINSPR.artcod = STKINMOV.artcod and STKINSPR.siscod='01' order by fecult DESC limit 1) * STKINSUM.valcps / STKINSUM.valuso) > 0  then ((select round(STKINSPR.artcos, 2) from STKINSPR where STKINSPR.artcod = STKINMOV.artcod and STKINSPR.siscod='01' order by fecult DESC limit 1) * STKINSUM.valcps / STKINSUM.valuso) else STKINSUM.artcos end) * movpes</expression> -->
				<if exp="true">
					<true>(costo + 0) * movpes</true>
					<false></false>
				</if>
				<tipo>numeric</tipo>
			
			</field>

			<field id="fecult"  tipoOrden="DESC">
				<expression>(select fecult from STKINSPR where STKINSPR.artcod = STKINMOV.artcod and STKINSPR.siscod='01' order by fecult DESC limit 1) </expression>
				<label>ult.compra</label>
				<tipo>date</tipo>
			</field>			
			<field id="ctacod"  >
				<expression>(select ctacod from STKINSPR where STKINSPR.artcod = STKINMOV.artcod and STKINSPR.siscod='01' order by fecult DESC limit 1) </expression>
				<label modpos="nobr" colspan="5">Proveedor</label>
				<tipo>integer</tipo>
				<tabla_ex id="CCTCUENT">
					<field id="ctacod" />
					<field id="ctanom" />					
					<field id="siscod" oculto="true">
						<condicion operador="=">'01'</condicion>
					</field>
				</tabla_ex>
			</field>					
			
<!--			<group>
				<field id="STKINMOV.artcod" />
				<field id="STKINMOV.movfec" />
			</group> -->
			<order>
				<field id="artdes"></field>
				<field id="fecult" />
				
			</order>
		</table>
		<join tipo="left">
		    
			<table id="STKINSUM">
				<field id="siscod" oculto="true">
					<label>siscod</label>
					<condicion operador="=">'01'</condicion>
		
				</field>
				<field id="artcod" oculto="true">
					<condicion operador="=">STKINMOV.artcod</condicion>
				</field>
		
			</table>
		</join>		
		<join tipo="left">
		
			<table id="FSMUNIDS">
				<field id="unicod" oculto="true">
					<condicion operador="=">STKINSUM.artuni</condicion>
				</field>
		
			</table>
		</join>		
	</form>
</histrix>
