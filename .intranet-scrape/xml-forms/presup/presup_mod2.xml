<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="ing" subtipo="vertical" _class="consultaing3"  path="fotos/articulos" log="false" _preloadData="false" _deleteRow="false" _confirma="GUARDAR" _inserta="false" imprime="true" preloadData="true">
	<title>MODIFICACION</title>
	<obs></obs>
	<form>
		<table id="VISTA_STK_COSTOS" label="MODIFICACION DE COSTOS" >
			<importar xml="prod_proc_art_cons.xml" label="Importar Proc Art" titulo="Seleccionar Procesos Art" dir="/produccion/linea/" >
				<field id="homologacion_id">homologacion_id</field>
			</importar>
			<movimientos>
				<relacion id="presup_stkinmov_del.xml" />
				<relacion id="presup_stkinmov_ins.xml" />
			</movimientos>
			<filters>
				<field id="artcod" _deshabilitado="false" >
					<label >Artículo</label>
					<tipo>varchar</tipo>
					<operador>=</operador>
				</field>
			</filters>
			<field id="id_stkinmov" noshow="true" esClave="true" deshabilitado="true" />
			<field id="siscod"   oculto="true">
				<condicion operador="=">'PR'</condicion>
				<valor>'PR'</valor>
			</field>
			<field id="movnro" _esClave="true" oculto="true">
				<label >Numero</label>
			</field>
			<field id="bom" noshow="true">
				<expression>ifnull((select 'stkpieza_qry.xml' from STKPIEZA where STKPIEZA.idPadre = STKINSUM.artcod limit 1),'')</expression>
			</field>
			<field id="artcod" _esClave="true" linkint="" linkdir="articulos">
				<attribute id="linkint">bom</attribute>
				<paring destino="idPadre">artcod</paring>
				<label>Código</label>
				<ayuda_ex xml="HLPstkinsum2.xml" dir="/help_local">
					<field id="artcod">
						<label>Cod.</label>
						<detalle>artcod</detalle>
					<attribute id="linkint">bom</attribute>
					<helper type="link" xml="stkpieza_qry.xml" dir="/articulos" modal="true">
		                <parameter source="artcod" target="idPadre" operator="=" />
		            </helper>
					</field>
					<field id="artdes">
						<label>Insumo</label>
						<detalle>artdes</detalle>

			
					</field>

					<field id="bom" noshow="true" oculto="true">
						<expression>ifnull((select 'stkpieza_qry.xml' from STKPIEZA where STKPIEZA.idPadre = STKINSUM.artcod limit 1),'')</expression>
					</field>
					<field id="unicps" oculto="true">
						<detalle>unicps</detalle>
					</field>
					<field id="artuni" oculto="true">
						<detalle>artuni</detalle>
					</field>
					<field id="valcps" oculto="true">
						<detalle>valcps</detalle>
					</field>
					<field id="valuso" oculto="true">
						<detalle>valuso</detalle>
					</field>
					<field id="siscod" oculto="true">
						<condicion operador="=">'01'</condicion>
					</field>
					<field id="ultima_compra" oculto="true">
					    <detalle>fecult</detalle>
					</field>
					<field id="movcod" local="true" noshow="true">
						<valor>1</valor>
						<detalle>movcod</detalle>
					</field>
					<clave>artcod</clave>
					<descripcion>artdes</descripcion>
				</ayuda_ex>
			
			
				<jseval fielddestino="modificar">1</jseval>
			</field>
			<field id="movcod" oculto="true" _esClave="true" deshabilitado="true">
				<label>movcod</label>
				<condicion operador="=">1</condicion>
				<valor default="true">1</valor>
			</field>
			<field id="artdes" tabla="STKINSUM" deshabilitado="true">
				<expression>STKINSUM.artdes</expression>
				<label modpos="nobr">Art</label>
				<tipo>char</tipo>
				<size>50</size>
			</field>
			<field id="movpes">
				<label modpos="nobr">Cantidad</label>
			</field>

			<field id="artuni" tabla="STKINSUM" deshabilitado="true">
				<helper type="combo" id="FSMUNIDS">
				    <field id="unicod" />
				    <field id="uniabv" />
				</helper>
				<label modpos="nobr" Formstyle="display:none;">Unidad</label>
				<tipo>varchar</tipo>
			</field>

			<field id="inlinedetail" noshow="true">
 	<!--          <expression>case when @tinehijos = 1 then 'articulos/stkpieza_qry.xml' else 'cctcuent_x_insumo.xml' end</expression>-->
      
     <expression>ifnull((select 'produccion/linea/materiales_comp_qry.xml' from STKPIEZA where STKPIEZA.idPadre = STKINSUM.artcod limit 1),'')</expression> 

     </field>

			<!--			
			<field id="costo" >
				<label>Costo</label>
				<expression>STKINSUM.artcos * STKINSUM.valcps / STKINSUM.valuso</expression>
			</field>
		-->
		<!--			
			<field id="ultcos" noshow="true">
				<expression>
					select (round(STKINSPR.artcos, 2) * STKINSUM.valcps / STKINSUM.valuso) from STKINSPR where STKINSPR.artcod = VISTA_STK_COSTOS.artcod and STKINSPR.siscod='01' order by fecult DESC limit 1
				</expression>
			</field>
			<field id="artcos" noshow="true">
				<expression>round(STKINSUM.artcos, 2)</expression>
			</field>
			<field id="costo" local="true" >
				<label Formstyle="display:none;">Costo</label>
				<if exp="ultcos + 0 != 0">
					<true>ultcos</true>
					<false>artcos</false>
				</if>
				<tipo>numeric</tipo>
			</field>
		-->
			<field id="costo" Formstyle="display:none;">
				<label style="font-weight:bold;">Costo</label>
				<!-- NO TOCAR, TE MATO -->
				<expression having="false" >
					( case when (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1) != 0 then 
				  (select sum(round( (costo_automatico  * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1)
				    else  STKINSUM.costo_calculado * valcps / valuso  end)
				</expression>
				<!--
			    <expression having="false" >
				(
			    case when (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1) != 0 then (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1)
				    else  (select ROUND(INSPR.artcos * valcps / valuso, 2) from STKINSPR as INSPR where INSPR.siscod = STKINSPR.siscod and  INSPR.artcod = STKINSPR.artcod and INSPR.fecult= max(STKINSPR.fecult)  limit 1) end)
			</expression>
			-->
			<!--
			    <expression having="false" >
			(
			    case when (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1) != 0 then (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1)
				    else  (select INSPR.artcos / (case when valuso &gt; valcps then valuso else 1 end) from STKINSPR as INSPR where INSPR.artcod = STKINSUM.artcod and INSPR.siscod = STKINSUM.siscod order by fecult DESC limit 1) end)
			</expression>
			-->
			<tipo>numeric</tipo>
			</field>
			<!--

			<field id="costo" >
				<label style="font-weight:bold;">Costo.</label>
				<expression>
				round(case when valcps &gt; valuso then costo_calculado 
				when ( costo_calculado * STKINSUM.valcps / STKINSUM.valuso) > 0  then (costo_calculado * STKINSUM.valcps / STKINSUM.valuso) else STKINSUM.artcos end, 2)
				</expression>
				<tipo>numeric</tipo>
			</field>
			-->
			<!--
			<field id="difs" local="true" >
				<label Formstyle="display:none;">difs</label>
				<if exp="true">
				<true>cosT - costo</true>
				<false>artcos</false>
				</if>
				<tipo>numeric</tipo>
			</field>
			-->
			<field id="parcial"  suma="true" local="true">
				<label modpos="nobr" Formstyle="display:none;">Parcial</label>
<!--	<expression>(STKINSUM.artcos * STKINSUM.valcps / STKINSUM.valuso) * movpes</expression>
-->
<!--	<expression>((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = VISTA_STK_COSTOS.artcod and STKINSPR.siscod='01' order by fecult DESC limit 1) * STKINSUM.valcps / STKINSUM.valuso) * movpes</expression>
-->
<!--				<expression>(case when ((select round(STKINSPR.artcos, 2) from STKINSPR where STKINSPR.artcod = VISTA_STK_COSTOS.artcod and STKINSPR.siscod='01' order by fecult DESC limit 1) * STKINSUM.valcps / STKINSUM.valuso) > 0  then ((select round(STKINSPR.artcos, 2) from STKINSPR where STKINSPR.artcod = VISTA_STK_COSTOS.artcod and STKINSPR.siscod='01' order by fecult DESC limit 1) * STKINSUM.valcps / STKINSUM.valuso) else STKINSUM.artcos end) * movpes</expression>
-->
				<if exp="true">
					<true>(costo + 0) * movpes</true>
					<false></false>
				</if>
				<tipo>numeric</tipo>
			</field>
			<field id="valcps" noshow="true">
				<expression>STKINSUM.valcps</expression>
			</field>
			<field id="valuso" noshow="true">
				<expression>STKINSUM.valuso</expression>
			</field>
			<field id="cos2to" noshow="true">
				<label>Costo Ant</label>
				<expression _sql="true">
					<![CDATA[ select round(STKINS.artcos * STKINSUM.valcps / STKINSUM.valuso, 2) from STKINSPR as STKINS where STKINS.artcod = STKINSUM.artcod and STKINS.fecult < STKINSUM.ultima_compra  and STKINS.siscod='01' order by fecult DESC limit 1 ]]></expression>
			</field>
			<field id="inc" local="true" noZero="true">
				<label>% Inc.</label>
				<if exp="0cos2to &lt; 0costo &amp;&amp; 0cos2to != 0">
					<true>round((0costo - 0cos2to) / 0cos2to * 100, 2)</true>
					<false>0</false>
				</if>
				<tipo>decimal</tipo>
			</field>
			<field id="fecult"  tipoOrden="DESC">
				<expression>STKINSUM.ultima_compra</expression>
					<!--
								<expression>
					(select max(STKINSPR.fecult) from STKINSPR where STKINSPR.artcod = VISTA_STK_COSTOS.artcod and STKINSPR.siscod='01')
				</expression>
				-->
				<label modpos="nobr" Formstyle="display:none;">Últ.compra</label>
				<tipo>date</tipo>
			</field>
		<field id="ultsalida" >
			<label Formstyle="display:none;">Última Salida</label>
			<expression>
				select max(STK.movfec) from STKINMOV as STK where STK.artcod =VISTA_STK_COSTOS.artcod and STK.siscod = '01' and STK.movcod = 10
			</expression>
			<tipo>date</tipo>
		</field>
		<field id="ctacod"  >
			<expression>
				(select ctacod from STKINSPR where STKINSPR.artcod = VISTA_STK_COSTOS.artcod and STKINSPR.siscod='01' order by fecult DESC limit 1)
			</expression>
			<label colspan="4" modpos="nobr" Formstyle="display:none;">Proveedor</label>
			<tipo>integer</tipo>
			<tabla_ex id="CCTCUENT">
				<field id="ctacod" />
				<field id="ctafan" />
				<field id="siscod" oculto="true">
					<condicion operador="=">'01'</condicion>
				</field>
			</tabla_ex>
		</field>
		<field id="fotopath" local="true" noshow="true">
			<if exp="true">
				<true>'artcod/'</true>
				<false>''</false>
			</if>
			<tipo>varchar</tipo>
		</field>
		<field id="foto" path="fotopath" download="true">
          	<expression>select ARTICULO_FOTO.foto from ARTICULO_FOTO where ARTICULO_FOTO.idArticulo = STKINSUM.artcod and ARTICULO_FOTO.foto != '' order by revision desc limit 1</expression> 
			<label  Formstyle="display:none;">Imagen</label>
			<tipo >file</tipo>
			<size>40</size>
		</field>
		<field id="ctbnom" tabla="CTBCUENT" >
			<expression>ctbnom</expression>
			<label modpos="nobr" Formstyle="display:none;">CtaCtb</label>
			<tipo>varchar</tipo>
		</field>
		<field id="borrarchk" local="true" refresh="true">
			<label Formstyle="display:none;">Borrar</label>
			<tipo>check</tipo>
		</field><!--
		<field id="modificar" local="true" _noshow="true">
			<label>mod</label>
		</field>-->
		<field id="tst_grabar" local="true" noshow="true">
			<if exp="borrarchk == 1">
				<true>0</true>
				<false>1</false>
			</if>
		</field>
<!--
			<group>
<field id="VISTA_STK_COSTOS.artcod" />
<field id="VISTA_STK_COSTOS.movfec" />
</group>
-->
		<group>
			<field id="VISTA_STK_COSTOS.artcod" />
			<field id="VISTA_STK_COSTOS.movfec" />
		</group>
		<order>
			<field id="artdes"></field>
		</order>
	</table>
	<join tipo="left">
		<table id="STKINSUM">
			<field id="siscod" >
				<label>siscod</label>
				<condicion operador="=">'01'</condicion>
			</field>
			<field id="artcod" oculto="true">
				<condicion operador="=">VISTA_STK_COSTOS.artcod</condicion>
			</field>
		</table>
	</join>
	<join tipo="left">
		<table id="ARTICULO_FOTO">
			<field id="idArticulo" >
				<condicion operador="=">STKINSUM.artcod</condicion>
			</field>
		</table>
	</join>
	<join tipo="left">
		<table id="CTBCUENT">
<!--			<field id="siscod" >
				<condicion operador="=">'10'</condicion>
			</field>
-->
			<field id="ctbcod" >
				<condicion operador="=">STKINSUM.artctb</condicion>
			</field>
		</table>
	</join>
	<join tipo="left">
		<table id="FSMUNIDS">
			<field id="unicod" oculto="true">
				<condicion operador="=">STKINSUM.artuni</condicion>
			</field>
		</table>
	</join>
<!--
    <join tipo="left">
<table id="STKINSPR">
<field id="siscod" >
<condicion operador="=">'01'</condicion>
</field>
<field id="artcod" >
<condicion operador="=">VISTA_STK_COSTOS.artcod</condicion>
</field>
</table>
</join>
-->
	</form>
</histrix>
