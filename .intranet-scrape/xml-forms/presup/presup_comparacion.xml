<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta"  path="fotos/articulos">
	<title>COSTOS</title>
	<obs></obs>
	<form  detalle="presup_renglon_mod.xml">
		<table id="VISTA_STK_COSTOS" label="CONSULTA DE COSTOS">
			<filters>
				<field id="movnro"  copia="pres1">
						<label>Presupuesto a Modificar</label>
						<operador oplogico="or">=</operador>
						<valor default="true">9999</valor>
						<detalle>movnro</detalle>						
				</field>			
				<field id="pres1" local="true" noshow="true" deshabilitado="true">
					<label modpos="nobr"></label>
				</field>
				<field id="movnro"  copia="pres2">
						<label>Presupuesto Patrón</label>
						<operador oplogico="or">=</operador>
						<valor dafault="true">9999</valor>
						
				</field>		

				<field id="pres2" local="true" noshow="true" deshabilitado="true">
					<label modpos="nobr"></label>	
				</field>				
			</filters>			
			
			<field id="siscod" esclave="true" oculto="true">
					<condicion operador="=">'PR'</condicion>
					
					<valor>PR</valor>
					<detalle>siscod</detalle>
			</field> 
			<field id="movnro" esclave="true" noselect="true" noshow="true">
					<label>Numero</label>
						<valor default="true">9999</valor>
				
			</field>
			<field id="movcod" oculto="true" esclave="true">
					<label>movcod</label>
				<condicion operador="=">1</condicion>
				<valor>1</valor>
				<detalle>movcod</detalle>
			</field>				


			<field id="artcod" esclave="true">
			
				<label>codigo</label>
					<ayuda_ex id="STKINSUM" xml="HLPstkinsum.xml" dir="/help_local">
						<field id="artcod">
							<label>Cod.</label>
							<detalle>artcod</detalle>
						</field>
						<field id="artdes">
							<label>Insumo</label>
							<detalle>artdes</detalle>
						</field>

						<field id="unicps" oculto="true">
<!--							<detalle>unimed</detalle> -->
							<detalle>unicps</detalle>

						</field>
						<field id="artuni" oculto="true">
<!--							<detalle>unimed</detalle> -->
							<detalle>artuni</detalle>
						</field>

						<field id="valcps" oculto="true">
							<detalle>valcps</detalle>
						</field>
						<field id="valuso" oculto="true">
							<detalle>valuso</detalle>
						</field>						
						<field id="siscod" oculto="true">
							<condicion operador="=">'01'</condicion>
						</field>
						<clave>artcod</clave>
						<descripcion>artdes</descripcion>
					</ayuda_ex>				
					<detalle>artcod</detalle>
			</field>
			<field id="artdes" tabla="STKINSUM" >
				<expression>STKINSUM.artdes</expression>
				<label>Articulo</label>
				<tipo>varchar</tipo>
			</field>
			<field id="pres1" local="true" noshow="true">
					<label modpos="nobr"></label>			
				<detalle>movnro</detalle>
			</field>
			<field id="pres2" local="true" noshow="true">
					<label modpos="nobr"></label>				
								
			</field>

			<field id="movpes1"  >
				<expression>(select sum(STK1.movpes) from VISTA_STK_COSTOS as STK1 where STK1.siscod = VISTA_STK_COSTOS.siscod and STK1.artcod = VISTA_STK_COSTOS.artcod and STK1.movnro = pres1 and STK1.movcod = VISTA_STK_COSTOS.movcod) </expression>
				<label>Cant.Actual</label>
				<tipo>numeric</tipo>
			</field>
			<field id="movpes2"  >
				<expression>(select sum(STK2.movpes) from VISTA_STK_COSTOS as STK2 where STK2.siscod = VISTA_STK_COSTOS.siscod and STK2.artcod = VISTA_STK_COSTOS.artcod and STK2.movnro = pres2 and STK2.movcod = VISTA_STK_COSTOS.movcod) </expression>
				<label>Cant. Anterior</label>
				<tipo>numeric</tipo>				
			</field>			
			
			<field id="uninom" tabla="FSMUNIDS" deshabilitado="true">
			
				<expression>FSMUNIDS.uninom</expression>
				<label>Unidad</label>
				<tipo>char</tipo>
			</field> 
			<field id="diff"  local="true">
				<label>Diferencia</label>
					<if exp="true" operador="=">
						<true>movpes1 - movpes2 </true>
						<false>0</false>
					</if>				
			</field>		
			<field id="fecult"  tipoOrden="DESC" noshow="true">
				<expression>(select STKINSPR.fecult from STKINSPR where STKINSPR.artcod = VISTA_STK_COSTOS.artcod and STKINSPR.siscod='01' order by fecult DESC limit 1) </expression>
				<label>ult.compra</label>
				<tipo>date</tipo>
			</field>	
			<field id="fotopath" local="true" noshow="true">
				<if exp="true">
					<true>'artcod/'</true>
					<false>''</false>
				</if>
				<tipo>varchar</tipo>
			</field>

			<field id="foto" path="fotopath" download="true">
          		<expression>select ARTICULO_FOTO.foto from ARTICULO_FOTO where ARTICULO_FOTO.idArticulo = STKINSUM.artcod and ARTICULO_FOTO.foto != '' order by revision desc limit 1</expression> 
				<label>Imagen</label>
                <tipo >file</tipo>
                <size>40</size>
			</field>
						
<!--			<field id="costo" >
				<label>Costo</label>
				<expression>STKINSUM.artcos * STKINSUM.valcps / STKINSUM.valuso</expression>
			</field> 
			<field id="costo" >
				<label>Costo</label>
				<expression>case when ((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = VISTA_STK_COSTOS.artcod and STKINSPR.siscod='01' order by fecult DESC limit 1) * STKINSUM.valcps / STKINSUM.valuso) > 0  then ((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = VISTA_STK_COSTOS.artcod and STKINSPR.siscod='01' order by fecult DESC limit 1) * STKINSUM.valcps / STKINSUM.valuso) else STKINSUM.artcos end</expression>
			</field>
			
			<field id="parcial"  suma="true">
				<label>Parcial</label>
				<expression>(case when ((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = VISTA_STK_COSTOS.artcod and STKINSPR.siscod='01' order by fecult DESC limit 1) * STKINSUM.valcps / STKINSUM.valuso) > 0  then ((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = VISTA_STK_COSTOS.artcod and STKINSPR.siscod='01' order by fecult DESC limit 1) * STKINSUM.valcps / STKINSUM.valuso) else STKINSUM.artcos end) * movpes</expression>
			
			</field>
			<field id="fecult" tabla="STKINSPR" tipoOrden="DESC">
				<expression>max(STKINSPR.fecult)</expression>
				<label>ult.compra</label>
				<tipo>date</tipo>
			</field>			
			<field id="ctacod" tabla="STKINSPR" >
				<expression>(select ctacod from STKINSPR where STKINSPR.artcod = VISTA_STK_COSTOS.artcod and STKINSPR.siscod='01' order by fecult DESC limit 1) </expression>
				<label>Proveedor</label>
				<tipo>integer</tipo>
				<tabla_ex id="CCTCUENT">
					<field id="ctacod" />
					<field id="ctanom" />					
					<field id="siscod" oculto="true">
						<condicion operador="=">'01'</condicion>
					</field>
				</tabla_ex>
			</field>					
			-->
			<group>
				<field id="VISTA_STK_COSTOS.artcod" />
			<!--	<field id="VISTA_STK_COSTOS.movfec" /> -->
			</group>
			<order>
				<field id="artdes"></field>
				<!-- <field id="fecult" /> -->
				
			</order>
		</table>
		<join tipo="left">
		
			<table id="STKINSUM">
				<field id="siscod" >
					<label>siscod</label>
					<condicion operador="=">'01'</condicion>
		
				</field>
				<field id="artcod" >
					<condicion operador="=">VISTA_STK_COSTOS.artcod</condicion>
				</field>
		
			</table>
		</join>		
		<join tipo="left">
		
			<table id="FSMUNIDS">
				<field id="unicod" >
					<condicion operador="=">STKINSUM.artuni</condicion>
				</field>
		
			</table>
		</join>		
		<join tipo="left">
		
			<table id="STKINSPR">
				<field id="siscod" >
					<condicion operador="=">'01'</condicion>
				</field>
				<field id="artcod">
					<condicion operador="=">VISTA_STK_COSTOS.artcod</condicion>
				</field>

		
			</table>
		</join>				
	</form>
</histrix>