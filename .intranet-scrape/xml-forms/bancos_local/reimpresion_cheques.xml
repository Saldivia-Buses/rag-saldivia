		    <field id="grabar" local="true">
				<label>Imprimir</label>
			<tipo>check</tipo>
		    </field>
			<field id="bcsmov" noshow="true">
			    <condicion operador="=">2</condicion>
			</field>
	<field id="IMPORTE" aletras="true" deshabilitado="true" noshow="true" local="true">
                <if exp="true">
                    <true>bcsimp</true>
                    <false>'0'</false>
                </if>
                <tipo>varchar</tipo>
            </field>

            <field id="Let1" local="true" deshabilitado="true" noshow="true">
                <if exp="true">
                    <true>urlencode(substrWords( 'IMPORTE.-', 0, 7))</true>
                    <!--<true>substr('bcsimp', 0 ,40)</true> -->
                    <false>'0'</false>
                </if>
                <tipo>varchar</tipo>
            </field>
            <field id="Let2" local="true" deshabilitado="true" noshow="true">
                <if exp="true">
                    <true>urlencode(substrWords('IMPORTE.-', 7 ))</true>
                    <false>'0'</false>
                </if>
                <tipo>varchar</tipo>
            </field>
            <field id="printer" _deshabilitado="true" tabla="CHEQUERAS">
              <label _modpos="nobr">Impresora</label>
              <!--
              <helper type="combo" xml="htxprinters_qry.xml" dir="/ayudas" empty="true" >
              </helper>
            -->
            </field>
     		<order>
				<field id="bcsnro"></field>
			</order>


        </table>

		  <join tipo="left">
		    <table id="BCSCONCE">
			<field id="siscod" oculto="true">
			    <condicion operador="=">BCSMOVIM.siscod</condicion>

			</field>

			<field id="cnbcod" oculto="true">
			    <condicion operador="=">BCSMOVIM.bcsmov</condicion>
			</field>
	    		<field id="cnbtip" oculto="true"></field>
		    </table>
		  </join>
      <join tipo="left">
        <table id="CHEQUERAS">
          <field id="ccbcod">
            <condicion operador="=">BCSMOVIM.bcscta</condicion>
          </field>
          <field id="tipo">
            <condicion operador="=">1</condicion>
          </field>          
        </table>
      </join>

		  
  </form>
</histrix>
