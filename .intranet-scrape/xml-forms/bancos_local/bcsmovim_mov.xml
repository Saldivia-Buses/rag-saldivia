		  <filters>
			<field id="bcsfec"> 
			    <operador>>=</operador>
			    <label>Desde Fecha Movimiento</label>
			    <valor>today</valor>    
			</field>  
			<field id="bcsfec"> 
			    <operador>&lt;=</operador>
			    <label>Hasta Fecha Movimiento</label>
			    <valor>today</valor>    

			</field>
		  </filters>

	    		<order>
				<field id="bcsfec"></field>
			</order>


                  </table>

		  <join tipo="left">
		    <table id="BCSCONCE">
			<field id="siscod" oculto="true">
			    <condicion operador="=">BCSMOVIM.siscod</condicion>

			</field>

			<field id="cnbcod" oculto="true">
			    <condicion operador="=">BCSMOVIM.bcsmov</condicion>
			</field>
	    		<field id="cnbtip" oculto="true"></field>
		    </table>
		  </join>
		  
               </form>
        </histrix>