<?xml version="1.0" encoding="UTF-8" ?>
   <histrix tipo="insert">
       <title>Mov Bancario</title>
        <obs></obs>
           <form >
		<table id="BCSMOVIM" label="MOVIMIENTOS" idCampoCond="Grabar">
			<field id="siscod"  >
			    <valor>04</valor>
			</field>
			<field id="bcscta" id_temp="nro_cuenta"/>
			<field id="bcsfec" id_temp="fecha_movimiento"/>
			<field id="bcsfev" id_temp="fecha_movimiento"/>
			<field id="bcsmov" id_temp="cod_concepto"/>
			<field id="bcsnro" id_temp="nro_movimiento"/>
			<field id="bcsimp" id_temp="importefinal"/>

			<field id="presentado" >
			    <valor>1</valor>
			</field>
			<field id="conciliado" >
			    <valor>date(now())</valor>
			    <tipo>integer</tipo>
			</field>

			<field id="regmin" >
			    <valor>(select numapr from CTBNUMER where siscod = '10' and nummes = substring('[__fecha_movimiento__]',4,2))</valor>
			</field>

			<field id="bcsref__1" >
			    <valor>'Ingreso Automático'</valor>
			</field>
		</table>
           </form>
    </histrix>