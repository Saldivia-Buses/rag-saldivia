<?xml version="1.0" encoding="ISO-8859-1"?>
<histrix tipo="ing" borra="no" inserta="no" modifica="false" noform="true" form="false" imprime="false" log="false">
	<title>Movimientos Bancarios</title>
	<obs></obs>
	<form >
		<table id="BCSMOVIM" label="Movimientos Bancarios">
			<preconsultas>
				<xmlfile id="bcsmovim_conci_pre2_old.xml"/>	  
				<xmlfile id="bcsmovim_conci_pre_old.xml"/>
			
			</preconsultas>			
			<movimientos>
				<relacion id="bcsmovim_movcon.xml"></relacion>
			</movimientos>

			<filters>
			    <field id="bcscta">
				<label>CUENTA</label>
				<tabla_ex id="BCSCUENT">
					<field id="ccbcod"></field>
					<field id="ccbnom"></field>
					<order>
							<field id="ccbcod"></field>
					</order>
				</tabla_ex>
				<operador>=</operador>				
			    </field>

			    <field id="bcsfev" copia="bcsfevpre" >
					<operador>>=</operador>
					<label>Desde Fecha Acreditación</label>
					<valor>today</valor>
			    </field>
			    <field id="bcsfevpre" local="true" noshow="true" deshabilitado="true">
					<label modpos="nobr"></label>
					<preparam campo="bcsfev" operador="&lt;">true</preparam>
					<valor>today</valor>												
			    </field>						
			    <field id="bcsfev">
				<operador>&lt;=</operador>
				<label>Hasta Fecha Acreditación</label>
				<valor>today</valor>
			    </field>
			    <field id="presentado">
				<label>Conciliado</label>
				<help>conciliado</help>
				<tipo>radio</tipo> 
				
				<operador>=</operador>
			    </field>				
			</filters>
			<field id="id_bcsmovim" _noshow="true" esClave="true"/>

			<field id="bcscta">
				<label>Codigo Cuenta</label>
				<tabla_ex id="BCSCUENT">
					<field id="ccbcod"></field>
					<field id="ccbnom"></field> -
					<field id="siscod" oculto="true"></field>
					<order>
							<field id="ccbcod"></field>
					</order>
					<filtra>bcscta</filtra>
				</tabla_ex>				
				<help>Codigo de Cuenta Bancaria </help>
				<preparam operador="=">true</preparam>	
			</field>
			
			<field id="siscod" oculto="true" />

			<field id="bcsmov" oculto="true">
				<label>bcsmov</label>
			</field>
							
			<field id="bcsfev" oculto="true">
				<label>Acreditacion2 </label>
				<help>Acreditacion</help>
			</field>
			<field id="bcsfevpre" local="true" noshow="true" deshabilitado="true">
				<label>test</label>
				<preparam campo="bcsfev" operador="&lt;">true</preparam>							
			           <tipo>date</tipo>
			</field>			
			<field id="bcsfev2">
				<expression>bcsfev</expression>
				<label>Acreditac.</label>
				<help>Fecha del Acreditación</help>
				<tipo>date</tipo>
			</field>
			
			<field id="bcsnro" deshabilitado="true">
				<label>Nro. Movimiento</label>
				<help>Numero de Movimiento </help>
				<format>%010d</format>
				
			</field>
			<field id="cnbabvE">
				<expression>cnbabv</expression>
				<label>Tipo</label>
				<help>Codigo de tipo de Movimiento </help>
				<tipo>varchar</tipo>
			</field>
			
			<field id="referencia" esClave="true">
				<expression>bcsref__1</expression>
				<tipo>varchar</tipo>
				<label>Referencia</label>
				<help>Referencia Adicional</help>
			</field>
			
			<field id="debe" suma="true" noZero="true">
				<expression>bcsimp * (case when cnbtip = '1' then 1 else 0 end)</expression>
				
				<label>Debe</label>
				<help>Importe del Movimiento en el Debe</help>
			</field>
			
			<field id="haber" suma="true"  noZero="true">
				<expression>bcsimp * (case when cnbtip = '2' then 1 else 0 end)</expression>
				
				<label>Haber</label>
				<help>Importe del Movimiento en el Haber</help>
			</field>
			<field id="diferencia" local="true" suma="true" acumula="true" _retroalimenta="true">
				<label>Saldo</label>
				<expression>bcsimp * (case when cnbtip = '2' then -1 else 1 end)</expression>
			</field>
			
			<field id="bcsfec2">
				<expression>bcsfec</expression>
				<label>Fecha Mov.</label>
				<help>Fecha Movimiento</help>
				<tipo>date</tipo>
			</field>
			<field id="bcsfec" >
				<label>Fecha Mov1</label>
				<help>Fecha Movimiento</help>
			</field>
			
			<field id="presentado" _refresh="true">
				<label>Conc.</label>
				<help>conciliado</help>
				<tipo>check</tipo> 
				<options>
					<option valor="1">Conciliados</option>
					<option valor="0">No conciliado</option>
				</options>

			</field>
			<!--
			<field id="color" _noshow="true" clasefila="true" local="true">
			    <if exp="'presentado' == '1'">
				<true>'error'</true>
				<false>'presentado'</false>
			    </if>
			</field>
			    -->
			<order>
				<field id="bcsfev"></field>
			</order>
			
		</table>
		
		<join tipo="left">
			<table id="BCSCONCE">
				<field id="siscod" oculto="true">
					<condicion operador="=">BCSMOVIM.siscod</condicion>
				</field>
				
				<field id="cnbcod" oculto="true">
					<condicion operador="=">BCSMOVIM.bcsmov</condicion>
				</field>
				<field id="cnbtip" oculto="true"></field>
			</table>
		</join>
		
	</form>
</histrix>
