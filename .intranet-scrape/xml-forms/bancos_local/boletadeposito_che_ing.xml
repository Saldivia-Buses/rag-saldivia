<?xml version="1.0" encoding="ISO-8859-1"?>
<histrix tipo="ing" llenoTemporal="false" graboasiento="true">
	<title>BOLETA DE DEPOSITO</title>
	<obs></obs>
	<form >
		
		<table id="CARCHEQU" label="Cheques">
	
			<movimientos cabecera="boletadeposito_cab.xml">
				<relacion id="bcsmovim_boleta_ingmov.xml">	</relacion>  
				<relacion id="carchehi_boleta_ingmov.xml">	</relacion>  
				<relacion id="carchequ_boleta_ingmov.xml">	</relacion>  
				
			</movimientos>
			
			<field id="siscod" oculto="true">
				<label>siscod</label>
				<help> Cod sistema</help>
				<parametro id="fsmparam_paralf.xml" retorna="paralf">
					<field id="parcla" >
						<condicion operador="=">'sisbcs'</condicion>
					</field>
				</parametro>						
			</field>
			<field id="carint">
				<label>Nro Cheque Int</label>
				<help>Codigo de Concepto</help>
				<ayuda_ex id="BCSCONCE" xml="HLPcarchequ.xml" dir="/help_local">
					<field id="carint"></field>
					<field id="carnro" deshabilitado="true" oculto="true">
						<detalle>carnro</detalle>
					</field>
					<field id="carbco" >
						<detalle>carbco</detalle>
					</field>
					<field id="carimp" >
						<detalle>carimp</detalle>
					</field>
					<field id="carimp2" >
						<expression>carimp</expression>
						<detalle>carimp2</detalle>
					</field>
					
					<field id="carfec" >
						<detalle>carfec</detalle>
					</field>
					<field id="caralt" >
						<detalle>caralt</detalle>
					</field>
					<field id="ctacod" >
						<detalle>ctacod</detalle>
					</field>
					<field id="carpla" >
						<detalle>carpla</detalle>
					</field>
					<field id="succod" >
						<detalle>succod</detalle>
					</field>
					<field id="cartip" >
						<detalle>cartip</detalle>
					</field>
					<field id="carobv" >
						<detalle>carobv</detalle>
					</field>
					<field id="ccbcod" >
						<detalle>ccbcod</detalle>
					</field>
					<field id="carcui" >
						<detalle>carcui</detalle>
					</field>
					<field id="cardes" >
						<detalle>cardes</detalle>
					</field>
					<field id="carrec" >
						<detalle>carrec</detalle>
					</field>
					
					
				</ayuda_ex>

			</field>				
			<field id="carnro" deshabilitado="true">
				<label>Numero</label>
			</field>				
			<field id="carfec" deshabilitado="true">
				<label>Fecha</label>
				<tipo>date</tipo>
			</field>				
			<field id="caralt" deshabilitado="true">
				<label>Acreditacion</label>
				<tipo>date</tipo>
				
			</field>				
			<field id="carbco" deshabilitado="true">
				<label>Banco</label>
			</field>				
			<field id="carimp" deshabilitado="true" suma="true" ctbimporte="1" ctbsuma="true">
				<label>Importe</label>
			</field>		
			<field id="carimp2" deshabilitado="true" suma="true" ctbimporte="2" ctbsuma="true">
				<label>Importe2</label>
			</field>					
			<field id="ctacod" deshabilitado="true" noshow="true">
				<label>ctacod</label>
			</field>				
			<field id="carpla" deshabilitado="true" noshow="true">
				<label>carpla</label>
			</field>				
			<field id="hoy" deshabilitado="true" noshow="true">
				<tipo>date</tipo>
				<valor>today</valor>
			</field>				
			<field id="succod" deshabilitado="true" noshow="true">
				<label>succod</label>
			</field>				
			<field id="cartip" deshabilitado="true" noshow="true">
				<label>cartip</label>
			</field>				
			<field id="carobv" deshabilitado="true" noshow="true">
				<label>carobv</label>
			</field>				
			<field id="ccbcod" deshabilitado="true" noshow="true">
				<label>ccbcod</label>
			</field>				
			<field id="carcui" deshabilitado="true" noshow="true">
				<label>carcui</label>
			</field>				
			<field id="cardes" deshabilitado="true" noshow="true">
				<label>cardes</label>
			</field>				
			<field id="carrec" deshabilitado="true" noshow="true">
				<label>carrec</label>
			</field>				
			<field id="ctbtip1" ctbtipo="1"  noshow="true">
				<valor>1</valor>
			</field>			
			<field id="ctbtip2" ctbtipo="2" noshow="true">
				<valor>2</valor>
			</field>			
			<field id="_ORDEN" oculto="true">
				<label>Orden</label>
			</field>

		<order>
			<field id="bcsnro"></field>
		</order>

		</table>
		
		<join tipo="left">
			<table id="BCSCONCE">
				<field id="siscod" oculto="true">
					<label>BCSCONCE.siscod</label>
					<condicion operador="=">BCSMOVIM.siscod</condicion>
					
				</field>
				
				<field id="cnbcod" oculto="true">
					<condicion operador="=">BCSMOVIM.bcsmov</condicion>
				</field>
				
				<field id="cnbnom" oculto="true">
				</field>
			</table>
		</join>

	</form>
</histrix>