    <join tipo="left">
      <table id="CHASIS">
        <field id="nrocha">
          <condicion operador="=">PEDCOTIZ.nrocha</condicion>
        </field>
      </table>
    </join>
    <join tipo="left">
      <table id="MARCHASIS">
        <field id="marcod">
          <condicion operador="=">CHASIS.marcod</condicion>
        </field>
      </table>
    </join>
    <join tipo="left">
      <table id="MODCHASIS">
        <field id="modcha">
          <condicion operador="=">CHASIS.modcod</condicion>
        </field>
        <field id="marcod">
          <condicion operador="=">MARCHASIS.marcod</condicion>
        </field>
      </table>
    </join>
    <join tipo="left">
      <table id="CONCESIONARIO">
        <field id="idconces">
          <condicion operador="=">CHASIS.conces</condicion>
        </field>
      </table>
    </join>
      <join tipo="left">
            <table id="HOMOLOGMOD">
                <field id="id_homologacion">
                    <condicion operador="=">PEDCOTIZ.homologacion_id</condicion>
                </field>
            </table>
        </join>

      <join tipo="left">
            <table id="CCTCUENT">
                <field id="ctacod">
                    <condicion operador="=">PEDCOTIZ.ctacod</condicion>
                </field>
                <field id="siscod">
                  <condicion operador="=">'02'</condicion>
                </field>                
            </table>
        </join>  

