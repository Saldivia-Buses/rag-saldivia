<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="insert" >
	<title>RETENCIONES</title>
	<obs/>
	<form >
		<table id="RETGANAN" label="retenciones" idCampoCond="pagarRR">

            <field id="printer" id_padre="printer_orden" local="true" >
                <detalle>printer</detalle>
                <detalle>directprint</detalle>
                <setvar>directprint</setvar>
            </field> 
			<field id="cajcod"  _id_cab="concod" local="true">
			    <valor>29</valor>
			</field>

			<field id="concod" id_temp="RGcajtip">
				<valor>2</valor>
				<detalle>concod</detalle> 
			</field>

			<field id="ctacod"   id_temp="ctacod"  >
				<detalle>ctacod</detalle>
			</field>

			<field id="ganacu" id_temp="acuret"></field>
			<field id="ganbru"  id_temp="impgra"></field>
			<field id="ganfec"  id_padre="movfec"  ></field>
			<field id="gannet"  id_temp="sumanetos"></field>
			
			<field id="gannro"  >
				<valor>(select max(rt.gannro) + 1 from RETGANAN as rt)</valor>
			</field>
			<field id="ganpor" id_temp="RGcajtip" >
					<valor>2</valor>
			</field>
			<field id="gantot"  id_temp="RR" >
			</field>
			<field id="catganancias_id"  id_temp="catganancias_id" >
			</field>
			<field id="movnro"    >
				<valor>(select parent from CAJPARAM where parcla = 'nropag' limit 1)</valor>
			</field>
			<field id="regmin" >
				    <valor>(select numapr from CTBNUMER where siscod = '10' and nummes = substring('[__movfec__]',4,2))</valor>

			</field>
			<field id="siscod">
				<valor>10</valor>
			</field>
		</table>
	</form>
</histrix>
