<?xml version="1.0" encoding="ISO-8859-1"?>
<histrix tipo="ing" llenoTemporal="false" imprime="false" llenoreferente="true" exportasuma="true">
	<title>TRANSFERENCIA BANCARIA</title>
	<obs></obs>
	<form >
		
		<table id="BCSMOVIM" label="Transferencia Bancaria" idCampoCond="imputar">
			
			<movimientos >
				<relacion id="ordenpago_transf_ingmov.xml"></relacion>

			</movimientos> 
						
			<field id="sisbcs" noshow="true">
				<label>sisbcs</label>
				<help>Cod sistema</help>
				<parametro id="fsmparam_paralf.xml" retorna="paralf">
					<field id="parcla">
						<condicion operador="=">'sisbcs'</condicion>
					</field>
				</parametro>
				<tipo>varchar</tipo>
			</field>
			<field id="bcsmov" noshow="true">
<!--				<label>Concepto</label>
				<help>Codigo de Concepto</help>
				<tabla_ex id="BCSCONCE">
					<field id="cnbcod"></field>
					<field id="cnbdes"></field>
				</tabla_ex>
				<tipo>integer</tipo>
				-->
				<valor>4</valor>
	
			</field>			
			<field id="movnroOP" noshow="true" local="true">
				<label>Numero</label>
				<tipo>integer</tipo>
				<format>%08d</format>
			</field>			 
			<field id="ctanom" local="true" noshow="true">
				<tipo>varchar</tipo>
			</field>			
			
			<field id="bcscta">
				<label>Concepto</label>
				<help>Codigo de Concepto</help>
				<tabla_ex id="BCSCUENT">
					<field id="ccbcod"></field>
					<field id="ccbnom"></field>
					<field id="ctbcod"></field>
				</tabla_ex>
				<tipo>integer</tipo>
			</field>			
			
			<field id="ctbcod"  noshow="true">
				<detalle>caj_ctb</detalle>
				<tabla_ex id="BCSCUENT">
					<field id="ctbcod"/>
					<field id="ccbnom" />
				</tabla_ex>
        			<valor>111203</valor>
			</field>

				<field id="bcsfec">
					<label>Fecha</label>
					<valor>today</valor>
				</field>		
				<field id="bcsfev">
					<label>Vto.</label>
					<valor>today</valor>
				</field>					
						
			<field id="bcsimp" suma="true">
				<label>Importe</label>
				<help>Importe del Movimiento</help>
				<tipo>numeric</tipo>
				<valor>0</valor>
				
				<detalle>cajimp</detalle>
			</field>	
			<field id="cajcod" local="true" noshow="true">
				<label>cajcod</label>
				<valor>13</valor>
				<detalle>cajcod</detalle>
			</field>
			<field id="imputar" local="true"  noshow="true">
				<valor>1</valor>
			</field>				
			<!-- NUMERADOR INTERNO NOMBRE DE CAMPO RESERVADO-->
			<field id="_ORDEN" oculto="true">
				<label>Orden</label>
			</field>
			<field id="nrorec" noshow="true">
			</field>
			<field id="referencia" local="true" deshabilitado="true" noshow="true">
				<label>Referencia</label>
<!--				<if exp="true" operador="=">
					<true>"'O.P.:[__movnroOP__] - ctanom'"</true>
					<false>'test'</false>
				</if> -->
			<valor>O.P.:[__movnroOP__] - [__ctanom__]</valor>					
				<tipo>varchar</tipo>
			</field>
		<order>
			<field id="bcsnro"></field>
		</order>

		</table>
		
		<join tipo="left">
			<table id="BCSCONCE">
				<field id="siscod" oculto="true">
					<label>BCSCONCE.siscod</label>
					<condicion operador="=">BCSMOVIM.siscod</condicion>
					
				</field>
				
				<field id="cnbcod" oculto="true">
					<condicion operador="=">BCSMOVIM.bcsmov</condicion>
				</field>
				
				<field id="cnbnom" oculto="true">
				</field>
			</table>
		</join>

	</form>
</histrix>