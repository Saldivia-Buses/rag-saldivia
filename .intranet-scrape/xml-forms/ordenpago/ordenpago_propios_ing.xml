<?xml version="1.0" encoding="UTF-8"?>
<histrix exportasuma="true" imprime="false" llenoTemporal="false" llenoreferente="true" tipo="ing">
	<title>MOVIMIENTOS BANCARIOS</title>
	<obs/>
	<form >
		<table id="BCSMOVIM" idCampoCond="imputar" label="Mov Bancarios">
			<movimientos>
				<relacion id="ordenpago_propios_ingmov.xml"></relacion>
			</movimientos>
			<field id="sisbcs" local="true" noshow="true">
				<label>sisbcs</label>
				<help>Cod sistema</help>
				<parametro id="fsmparam_paralf.xml" retorna="paralf">
					<field id="parcla">
						<condicion operador="=">'sisbcs'</condicion>
					</field>
				</parametro>
				<tipo>varchar</tipo>
			</field>
			<field id="bcsmov" noshow="true">
				<!--				<label>Concepto</label>
				<help>Codigo de Concepto</help>
				<tabla_ex id="BCSCONCE">
					<field id="cnbcod"></field>
					<field id="cnbdes"></field>
				</tabla_ex>
				<tipo>integer</tipo>
				-->
				<valor>2</valor>
			</field>
			<field id="bcsnro">
				<label>Numero</label>
				<help>Numero de Movimiento</help>
				<tipo>integer</tipo>
				<valor>0</valor>
				<format>%08d</format>
			</field>
			<field id="bcscta">
				<label>Concepto</label>
				<help>Codigo de Concepto</help>
				<tabla_ex id="BCSCUENT">
					<field id="ccbcod"/>
					<field id="ccbnom"/>
					<field id="ctbcod" />
				</tabla_ex>
				<tipo>integer</tipo>
			</field>
			<field id="bcsfec">
				<label>Fecha</label>
				<valor>today</valor>
			</field>
			<field id="bcsfev">
				<label>Vto.</label>
				<valor>today</valor>
			</field>
			<field id="bcsimp" suma="true">
				<label>Importe</label>
				<help>Importe del Movimiento</help>
				<tipo>numeric</tipo>
				<valor>0</valor>

				<detalle>cajimp</detalle>
			</field>
			<field id="cajcod" local="true" noshow="true">
				<label>cajcod</label>
				<valor>8</valor>
				<detalle>cajcod</detalle>
			</field>
			<field id="ctbcod"  noshow="true">
				<detalle>caj_ctb</detalle>
				<tabla_ex id="BCSCUENT">
					<field id="ctbcod"/>
					<field id="ccbnom" />
				</tabla_ex>
    			<valor>111203</valor>
			</field>
			<field id="imputar" local="true" noshow="true">
				<valor>1</valor>
			</field>
			<!-- NUMERADOR INTERNO NOMBRE DE CAMPO RESERVADO-->
			<field id="_ORDEN" oculto="true">
				<label>Orden</label>
			</field>
			<field id="movnroOP" noshow="true" local="true">
				
			</field>
			<field id="ctanom" noshow="true" local="true">
				<tipo>varchar</tipo>
			</field>

			<field deshabilitado="true" id="referencia" local="true" noshow="true">
				<label>Referencia</label>
<!--				<if exp="true" operador="=">
					<true>"'O.P.:[__movnroOP__] - ctanom'"</true>
					<false>'test'</false>
				</if> -->
			<valor>O.P.:[__movnroOP__] - [__ctanom__]</valor>				
				<tipo>varchar</tipo>
			</field>
			<field ctbtipo="2" id="cajtip" local="true" noshow="true">
				<valor>2</valor>
				<detalle>cajtip</detalle>
			</field>
			<field id="opecla" local="true" noshow="true">
				<valor eval="true">$_SESSION['usuario']</valor>
			</field>			
			<!--
			<filters>
				<field id="regfec">
					<operador>=</operador>
					<label>Fecha</label>
					<valor>today</valor>
				</field>
			</filters>
				-->
			<order>
				<field id="bcsnro"/>
			</order>
		</table>

		<join tipo="left">
			<table id="BCSCONCE">
				<field id="siscod" >
					<condicion operador="=">BCSMOVIM.siscod</condicion>
				</field>
				<field id="ccbcod" >
					<condicion operador="=">BCSMOVIM.bcsmov</condicion>
				</field>
			</table>
		</join>

		<join tipo="left">
			<table id="BCSCUENT">
				<field id="siscod" >
					<label>BCSCONCE.siscod</label>
					<condicion operador="=">BCSMOVIM.siscod</condicion>
				</field>
				<field id="cnbcod" >
					<condicion operador="=">BCSMOVIM.bcscta</condicion>
				</field>
			</table>
		</join>
	</form>
</histrix>
