				</field>
			</table>
		</join>			
		<join tipo="left">
			<table id="RETTABLA">
				<field id="siscod" oculto="true">
					<condicion operador="=">'10'</condicion>
				</field>

				<field id="retcod" oculto="true">
					<condicion operador="=">2</condicion>
				</field>
				<field id="tabmes" oculto="true">
					<condicion operador="=">1</condicion>
				</field>				
				<field id="ctagan" oculto="true">
					<condicion operador="=">CCTCUENT.ctagan</condicion>
				</field>
				</table>
		</join>		-->					
	</form>
</histrix>
