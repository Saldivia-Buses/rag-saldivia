<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="abm-mini" logReference="referencia">
	<title>Respuesta</title>
	<consulta>
		<table id="NOCONFORMESP">
			<title>No Conformidades</title>
			
			
			<field id="idNoConformidad" oculto="true">
			</field>
			<field id="referencia" noshow="true" >
			<expresion>noconformidad</expresion>
			</field>
			<field id="idResp" noshow="true"  esClave="true" autoinc="true">
			</field>
			<field id="login" deshabilitado="true" >
				<label>Usuario </label>
				<help>Usuario que hace el pedido</help>
				<tabla_ex id="HTXUSERS">
					<field id="login"></field>
					<field id="nombre"></field>
					<order>
						<field id="nombre"></field>
					</order>
				</tabla_ex>
				<valor eval="true">$_SESSION['usuario']</valor>
			</field>


			<field id="fecha" deshabilitado="true" valauto="true">
				<label>Fecha</label>
				<help>Fecha</help>
				<valor>today</valor>
			</field>


			<field id="respuesta" _deshabilitado="true">
				<label >Respuesta</label>
				<help>Descripcion </help>
				<size>200</size>
				
			</field>
			<field id="cierre" >
				<label >Cierre</label>
				<help>Cierre de la No conformidad </help>
				<tipo>check</tipo>
				
			</field>
			
			
		
			<order>
				<field id="idNoConformidad" ></field>
			</order>

		</table>
		<join tipo="left">
		    <table id="NOCONFORMIDADES">
			<field id="idNoConformidad">
			    <condicion operador="=">NOCONFORMESP.idNoConformidad</condicion>
			</field>
		    </table>
		</join>
	</consulta>
</histrix>
