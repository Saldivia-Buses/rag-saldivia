         path="/fotos/accesorios"
         _impresion="factura_reimptpl.xml" barraDrag="false">
    <!--comando de impresion -->

    <title>Punto de Venta</title>
    <obs/>
    <form>
        <table id="FACDETAL" label="Ingreso de Facturas"
               styleTbody="height:150px;overflow-x:hidden;">
            <!--
            <cierraproceso id="pos_cobranza.xml">
                <paring destino="total">total</paring>
