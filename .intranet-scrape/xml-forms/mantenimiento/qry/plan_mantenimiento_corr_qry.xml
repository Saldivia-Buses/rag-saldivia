<?xml version="1.0" encoding="UTF-8"?>
<!-- 
*******************************************************************************
Tipo:  CURD
Tarea: PLAN DE MANTENIMIENTO
Autor: Lmm
Fecha: 17/08/11
*******************************************************************************
-->
<histrix tipo="crud" inserta="false">
  <title>Mantenimiento</title>
  <obs/>
  <form>
    <table id="MANT_PLAN">
        <filters>
	    <field id="fecha_iniciotarea" >
		<label>Desde Fecha</label>
		<help>Fecha de la acción</help>
		<tipo>date</tipo>
		<operador>&gt;=</operador>
		<valor>today</valor>
	    </field>
	    <field id="fecha_iniciotarea" >
		<label>Hasta Fecha</label>
		<help>Fecha de la acción</help>
		<tipo>date</tipo>
		<operador>&lt;=</operador>
		<valor>today</valor>
	    </field>
            <field id="nombre_equipo" deshabilitado="false">
                <label>Nombre</label>
                <help>Nombre</help>
                <operador>like</operador>
            </field>
            <field id="tipoequipo_id" >
                <label>Tipo</label>
                <help>Tipo</help>
                <operador>=</operador>
		<valor>1</valor>
            </field>
        </filters>
	<field id="id_plan" noshow="true" />
                    
	<field id="rrule" noshow="true" >
	    <expression>''</expression>
	</field>

        <field id="equipo_id" noshow="true" _valauto="true">
        </field>
    
	<field id="nombre_equipo" deshabilitado="true"> 
	    <label>Equipo</label>
	    <expression>MANT_EQUIPOS.nombre_equipo</expression>
	    <size>50</size>
	</field>
    
        <field id="fecha_accion">
	    <label>Fecha Ingreso Reclamo</label>
	    <help>Fecha de la acción</help>
	    <tipo>date</tipo>
	</field>

	<field id="hora_accion">
	    <label modpos="nobr">Hora Reclamo</label>
	    <tipo>time</tipo>
	</field>

        <field id="fecha_iniciotarea">
	    <label>Inicio Tarea</label>
	    <help>Fecha de la acción</help>
	    <tipo>date</tipo>
	</field>

	<field id="hora_iniciotarea">
	    <label modpos="nobr">Hora Inicio Tarea</label>
	    <tipo>time</tipo>
	</field>

        <field id="fecha_terminacion" valauto="true">
	    <label>Fin Tarea</label>
	    <tipo>date</tipo>
	</field>

	<field id="hora_terminacion">
	    <label modpos="nobr">Hora Fin Tarea</label>
	    <tipo>time</tipo>
	</field>
        <field id="fecha_salida" valauto="true">
	    <label>Fecha Terminación</label>
	    <tipo>date</tipo>
	</field>

	<field id="hora_salida">
	    <label modpos="nobr">Hora Terminación</label>
	    <tipo>time</tipo>
	</field>
      


	<field id="horas_man" suma="true">
	    <label>Horas de Mantenimiento</label>
	    <expression>ROUND((((CASE WHEN (accion_id = 52 and hora_iniciotarea != '00:00:00' and hora_terminacion != '00:00:00'
and fecha_iniciotarea = fecha_terminacion)
THEN time_to_sec(timediff(hora_terminacion, hora_iniciotarea)) else (CASE WHEN (accion_id = 52 and hora_iniciotarea != '00:00:00' and hora_terminacion != '00:00:00'
 and fecha_iniciotarea &lt; fecha_terminacion)
THEN (timediff((SELECT egreso FROM HORARIOHIST WHERE dia = DAYOFWEEK(fecha_iniciotarea) ORDER BY desdeFecha DESC LIMIT 1), hora_iniciotarea) +
     timediff(hora_terminacion, (SELECT ingreso FROM HORARIOHIST WHERE dia = DAYOFWEEK(fecha_terminacion) ORDER BY desdeFecha DESC LIMIT 1)))
ELSE 0 END ) END)) / 3600), 2)</expression>
	    <tipo>numeric</tipo>
        </field>	

	<field id="horas_sinuso" suma="true">
	    <label>Horas sin usar</label>
	    <expression>ROUND((((CASE WHEN (accion_id = 52 and hora_accion != '00:00:00' and hora_salida != '00:00:00' and fecha_accion = fecha_salida)
THEN time_to_sec(timediff(hora_salida, hora_accion)) else (CASE WHEN (accion_id = 52 and hora_accion != '00:00:00' and hora_salida != '00:00:00'
 and fecha_accion &lt; fecha_salida)
THEN (timediff((SELECT egreso FROM HORARIOHIST WHERE dia = DAYOFWEEK(fecha_accion) ORDER BY desdeFecha DESC LIMIT 1), hora_accion) +
     timediff(hora_salida, (SELECT ingreso FROM HORARIOHIST WHERE dia = DAYOFWEEK(fecha_salida) ORDER BY desdeFecha DESC LIMIT 1)))
ELSE 0 END ) END)) / 3600), 2)</expression>
	    <tipo>numeric</tipo>
        </field>

	<field id="deposito_id" tabla="MANT_EQUIPOS" noshow="true">
	    <label>Deposito</label>
	    <helper type="combo" id="DEPOSITO" empty="true">
		<field id="idDeposito">
		    <label>Cod</label>
		    <help>Codigo</help>
		</field>
		<field id="direccion">
		    <label>Direccion</label>
		    <help>Direccion</help>
		</field>
	    </helper>
	</field>

	<field id="tipoequipo_id" tabla="MANT_EQUIPOS" noshow="true">
	    <helper type="combo" id="MANT_TIPO_EQUIPO" empty="true">
		<field id="id_tipo_equipo"/>
		<field id="nombre_tipoequipo"/>
	    </helper>
	    <label>Tipo</label>
	    </field>
    
        <field id="accion_id" valauto="true" noshow="true">
        </field>

	<field id="nombre_accion" local="true" deshabilitado="true" valauto="true">
	    <valor>Mantenimiento Correctivo</valor>
	    <label colspan="4">Tarea</label>
	    <size>70</size>
	</field>

	<field id="observaciones">
	    <label colspan="4">Observaciones</label>
	    <size>100</size>
	</field>

	<field id="login" valauto="true" noshow="true">
	    <valor eval="true">$_SESSION['usuario']</valor>
	</field>
    </table>
    <join tipo="left">
	<table id="MANT_EQUIPOS">
	    <field id="id_equipo">
		<condicion operador="=">equipo_id</condicion>
            </field>
	</table>
    </join>
    <join tipo="left">
         <table id="STK_ARTICULOS">
	    <field id="id_stkarticulo">
	        <condicion operador="=">articulo_id</condicion>
	    </field>
	    <field id="subsistema_id">
	        <condicion operador="=">'01'</condicion>
	    </field>
	 </table>
    </join>
  </form>
</histrix>
