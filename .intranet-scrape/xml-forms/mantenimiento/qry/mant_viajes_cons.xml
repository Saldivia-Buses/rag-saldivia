                </helper>
        </field>

	    <field id="fecha_salida" _deshabilitado="true" calendarStartDate="true">
			<label>Fecha salida</label>
			<help>Fecha de salida</help>
			<tipo>date</tipo>
		</field>

                       
		<field id="hora_salida" _deshabilitado="true" calendarStartTime="true">
			<label>Hora salida</label>
			<help>Hora de salida</help>
