		</field>

		<field id="fecha_regreso" _deshabilitado="true" calendarEndDate="true">
			<label>Fecha regreso</label>
			<help>Fecha de regreso</help>
			<tipo>date</tipo>
		</field>

		<field id="hora_regreso" _deshabilitado="true" calendarEndTime="true">
			<label>Hora regreso</label>
			<help>Hora de regreso</help>
			<tipo>time</tipo>
		</field>

		
