<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="chart">
	<title>ESTADISTICAS DE COMBUSTIBLE CONSUMIDO</title>
	<obs></obs>
	<form>
		<table id="GEN_CALENDAR" label="Combustible">
		   
		   <grafico id="gasto_combustible" >
			   <ancho>400</ancho>
			   <tipo>L</tipo>

			   <etiquetas>mes</etiquetas>
			   <serie>litros</serie>
			   <title>litros consumidos x vehiculo</title>
			   <subtitulo>x mes</subtitulo>
			   
		   </grafico>	

		   	
		    <filters>
			    <field id="fecha">
				    <label>Desde</label>
				    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-12 month')) , 1, date("Y") -  1 ))</valor>
				    <operador>&gt;=</operador>
			    </field>
			    <field id="fecha">
                    <label>Hasta</label>
				    <valor eval="true">date('d/m/Y', strtotime('-1 second', strtotime(date('Y-m-01'))))</valor>
				    <operador>&lt;=</operador>
			    </field>
			    <field id="mantvehiculo_id" deshabilitado="false">
                    <label>Vehiculo</label>
                    <operador>=</operador>
            	</field>

		    </filters> 

		    <field id="mantvehiculo_id">
			<expression having="false">MANT_VEHICULOS.id_mantvehiculo</expression>
	                <helper type="combo" id="MANT_VEHICULOS" _empty="true">
    	                    <field id="id_mantvehiculo" />
        	            <field id="descripcion_vehiculo" />
                	    <order>
                    	        <field id="descripcion_vehiculo" />
                            </order>
	                </helper>
	                <label>Vehiculo</label>
	            </field>
			
			
			<field id="mes">
				<expression>month(GEN_CALENDAR.fecha)</expression>
				<label>Mes</label>
				<options>
					<option valor="1">Ene</option>
					<option valor="2">Feb</option>
					<option valor="3">Mar</option>
					<option valor="4">Abr</option>
					<option valor="5">May</option>
					<option valor="6">Jun</option>
					<option valor="7">Jul</option>
					<option valor="8">Ago</option>
					<option valor="9">Sep</option>
					<option valor="10">Oct</option>
					<option valor="11">Nov</option>
					<option valor="12">Dic</option>

				</options>
       				<tipo>varchar</tipo>
			</field>

            <field id="fecha" oculto="true">
               	<condicion operador="&gt;="> DATE_FORMAT(date_sub(date(now()) , interval 1 year) ,'%Y-%m-01') and GEN_CALENDAR.fecha &lt;= now()</condicion> 
				<tipo>date</tipo>
            </field>
            <field id="year" oculto="true">
                <expression>year(GEN_CALENDAR.fecha)</expression>
            </field>

            <field id="litros">
                <label>litros</label>
               <!-- <expression><![CDATA[SELECT SUM(km_final - km_inicial) FROM MANT_VIAJES_VEHICULO 
                WHERE
                	month(MANT_VIAJES_VEHICULO.fecha_regreso) = month(GEN_CALENDAR.fecha) and
                    year(MANT_VIAJES_VEHICULO.fecha_regreso) = year(GEN_CALENDAR.fecha)	
                    GROUP BY mantvehiculo_id 
                    ]]>
                </expression> 
            -->
            	<expression>IFNULL(SUM(cant_inicial_combustible - cant_final_combustible),0)</expression>
               
                <tipo>numeric</tipo>
            </field>



	 		<group>
				<field id="year"></field>
				<field id="mes"></field>
				<field id="mantvehiculo_id"></field>
			
			</group>

		</table>

		<join tipo="left">
			<table id="MANT_VEHICULOS">
			    <field id="id_mantvehiculo">
				<condicion operador="!=">0</condicion>
			    </field>
			</table>
		</join>


		<join tipo="left">
			<table id="MANT_VIAJES_VEHICULO">
				<field id="fecha_solicitud">
					<condicion operador="=">GEN_CALENDAR.fecha</condicion>	
				</field>
				<field id="mantvehiculo_id">
					<condicion operador="=">MANT_VEHICULOS.id_mantvehiculo</condicion>
				</field>
			</table>
		</join>
		
	</form>
</histrix>
