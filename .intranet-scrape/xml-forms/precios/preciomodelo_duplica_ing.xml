<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="ing" subtipo="vertical"  imprime="false" >
  <title>PRECIOS POR MODELO</title>
  <obs/>
  <form >
    <table id="PRECIOMODELO" styleTbody="height:250px;">
      <movimientos cabecera="preciomodelo_duplica_cab.xml">
        <relacion id="preciomodelo_duplica_cab_ingmov.xml"></relacion> 
      
        <relacion id="preciomodelo_duplica_ingmov.xml"></relacion> 
      </movimientos>        Dos Ejes .
      <title>Precios por modelo</title>

      <filters>

        <field id="idLista" PDFsize="10">
          <label modpos="nobr">Lista</label>
          <help>Lista</help>
          <operador>=</operador>
          <tipo>integer</tipo>
        </field>
        
      </filters>   
  
      <field id="idLista" noshow="true" PDFsize="10" tabla="PRECIOMODELO">
        <tabla_ex id="LISTAPRECIOMODELO">
          <field id="idLista" >
          </field>
          <field id="nom" >
            <expression>concat('Nro ',idLista,' - Vigencia Desde: ' , DATE_FORMAT(fecha, '%d/%m/%Y'))</expression>
          </field>
          <field id="fecha" orden="true" tipoOrden="DESC">
          </field>         
          <order>
            <field id="fecha"></field>
          </order>
        </tabla_ex>        
        <label modpos="nobr">Lista</label>
        <help>Lista</help>
      </field>
        
      <field id="nrocar">
        <label modpos="nobr">Carroceria</label>
        <tabla_ex id="CARROCERIA">
          <field id="nrocar">
            <label>Codigo</label>
          </field>
          <field id="desabv">
            <label>Modelo</label>
          </field>
          <order>
            <field id="desabv" />
          </order>
          <field id="vigente">
              <condicion operador="=">1</condicion>
          </field>          
        </tabla_ex>
      </field>
      
      <field id="idGrupo">
        <label modpos="nobr">Grupo</label>
      </field>
