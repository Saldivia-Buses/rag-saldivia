            <label>Marca Chasis</label>
          </field>
        </tabla_ex>
      </field>    
      
      
      <field id="moddes" tabla="MODCHASIS" >
        <expression>MODCHASIS.moddes</expression>
        <label Formstyle="display:none;" modpos="nobr">Modelo de Chasis</label>
        <tipo>varchar</tipo>
      </field> -->
      <field id="asientos">
        <label>Asientos</label>
        <label>Cantidad de Asientos</label>
      </field>
      <field id="tipserv">
        <label modpos="nobr">Tipo</label>
        <label>Tipo de Servicio</label>
              <tabla_ex id="TIPOSERVICIO">
                        <field id="tipserv">
                        </field>
                        <field id="servdes">
                        </field>          
        </tabla_ex>

        
      </field>
      
      <field id="banbar">
        <label modpos="nobr">Baño Mbar</label>
        <help>Baño / Minibar</help>
        <options>
          <option valor="0">--</option>
          <option valor="1">Si</option>          
        </options>
      </field>
      <field id="bastidor">
        <label modpos="nobr">Bastidor</label>
        <options>
          <option valor="0">--</option>
          <option valor="1">Si</option>          
        </options>
        <help>Bastidor</help>
        
      </field>      
      <field id="largo">
        <label modpos="nobr">Largo (m3)</label>
        <help>Largo Expresado en Metros</help>
      </field>            
      <field id="bodega">
        <label modpos="nobr">Bodega (m3)</label>
        <help>Capacidad de Bodega expresado en Metros Cúbicos</help>
      </field>            
      
      <field id="precio">
        <label  style="color:green; font-size:16px;">Precio conces.</label>
        <help>Precio</help>
        <tipo>decimal</tipo>
      </field>
      <field id="margen" _noshow="true">
        <label modpos="nobr">% Rec</label>
        <help>Recargo precio al público</help>
<!--        <valor>0.035</valor> -->
      </field>
      <field id="precio2" noshow="true">
        <expression>precio * (1 + margen)</expression>
        <label modpos="nobr" style="color:red; font-size:16px;">Precio público</label>
        <help>Precio</help>
      </field>
      <field id="prec2" local="true" >
        
        <label modpos="nobr" style="color:red; font-size:16px;">Nuevo Precio conces.</label>
        <if exp="true">
          <true>precio + precio / 100 *  aumento</true>
          <false>0</false>
        </if>
        <help>Nuevo Precio Conces.</help>
        <tipo>decimal</tipo>
      </field>        
      <order>
        <field id="nrocar" tabla="PRECIOMODELO"></field>
        <field id="idGrupo" tabla="PRECIOMODELO"></field>
        <field id="asientos" tabla="PRECIOMODELO"></field>        
        
        
      </order>
    </table>
    <join tipo="left">
               <table id="CARROCERIA">
          <field id="nrocar">
                 <condicion operador="=">PRECIOMODELO.nrocar</condicion>
          </field>
        </table>    
    </join>    
