<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="abm-mini"   PDFlineColor="0,0,0">
	<title>PRECIOS POR MODELO</title>
	<obs/>
	<form >
		<table id="PRECIOMODELO" >
			<title></title>
			<field id="idLista" noshow="true">
				<label modpos="nobr">Lista</label>
			</field>			
			<field id="nrocar" noshow="true">
			</field>		
			<field id="idGrupo" noshow="true">
			</field>			
<!--			<field id="marcod" noshow="true">
			</field>
			
			<field id="modcha" noshow="true">
			</field>	
	-->		
			<field id="asientos">
				<expression>asientos + acompaña</expression>
				<label colstyle="width:50px;" style="color:blue; font-size:16px;">Asi</label>
				<label>Cantidad de Asientos</label>
			</field>
			<field id="banbar">
				<label>B/B</label>

				<options>
					<option valor="0">--</option>
					<option valor="1">B/B</option>					
				</options>
			</field>
			
			<!--<field id="bastidor">
				<label>Bastidor</label>
				<options>
					<option valor="0">  - </option>
					<option valor="1">Si</option>					
				</options>
				<help>Bastidor</help>
				
			</field>			-->
			<field id="largo">
				<label>Largo</label>
				<help>Largo Expresado en Metros</help>
			</field>						
			<field id="bodega">
				<label>Bodega</label>
				<help>Capacidad de Bodega expresado en Metros Cúbicos</help>
			</field>	

			<field id="tipserv">
				<label>Habilitación</label>
				<label>Tipo de Servicio</label>
				<tabla_ex id="TIPOSERVICIO">
	    		    	<field id="tipserv">
                    		</field>
                            <field id="servdes">
	                    </field>					
	    			</tabla_ex>
			</field>						
			<field id="precio">
				<label modpos="nobr" style="color:green; font-size:16px;">Concesionario</label>
				<help>Precio</help>
				<tipo>custom_numeric</tipo>				 
				
				
			</field>
			<field id="margen" noshow="true">
				<expression>max(margen)</expression>
				<label>% Rec</label>
				<help>Recargo precio al público</help>
			</field> 
			<field id="pubPrecio" PDFcolor="#00b100">
				<expression>max(round(precio * (1 + margen), 2))</expression>
				<label modpos="nobr" style="color:red; font-size:16px;">Prec.Público</label>
				<help>Precio</help>
				<tipo>custom_numeric</tipo>				 
			</field>
            <field id="difAs" noshow="true">
                <label >dif</label>
                <expression>select difAsiento from LISTAPRECIOMODELO where LISTAPRECIOMODELO.idLista = PRECIOMODELO.idLista</expression>
            </field>
			<field id="preCAsientos" local="true">
				<label modpos="nobr" style="color:green; font-size:16px;">Concesionario </label>
				<tipo>custom_numeric</tipo>				 
				
				<if exp="true">
					<true>precio + (asientos * difAs)</true>
					<false>0</false>
				</if>
			</field>

			<field id="prePAsientos" local="true" PDFcolor="#0000ff">
				<label modpos="nobr" style="color:green; font-size:16px;">Prec. Público</label>
				<if exp="true">
					<true>pubPrecio + (asientos * difAs)</true>
					<false>0</false>
				</if>
				<tipo>custom_numeric</tipo>				 
                
			</field>

			<field id="idPrecio" noshow="true">
			</field>
			<field id="nrounico" local="true" noshow="true">
				<if exp="true">
					<true>'nrocar'.'idGrupo'.'asientos'</true>
					<false>0</false>
				</if>
			</field>				
<!--			<field id="Carac" linkdir="cotizacion" linkint="cotizopciones.xml" linkdes="caracteristicas" local="true" print="false">
				<label>Características</label>
				<paring destino="idPrecio" operador="="   >nrounico</paring>
				<valor>'Características'</valor>
				<tipo>varchar</tipo>
			</field> 			
			<field id="Cotiz" linkdir="cotizacion" linktab="true" linkint="cotizacion_ing.xml" linkdes="Cotizar" local="true" print="false">
				<label>Cotizar</label>
				<paring destino="modcar"   operador="="   >nrocar</paring>
				<paring destino="nrocar"   operador="="   >nrocar</paring>				
				<paring destino="idGrupo"   operador="="   >idGrupo</paring>
				
				<paring destino="precio"   operador="="   >precio</paring>				
				<paring destino="prePub"   operador="="   >precio2</paring>								
				<paring destino="idPrecio" operador="="   >nrounico</paring>
				<paring destino="asientos" operador="="   >asientos</paring>				
				<valor>'Cotizar'</valor>
				<tipo>varchar</tipo>
			</field> 
			-->
			<group>
				<field id="asientos" tabla="PRECIOMODELO"></field>
                                <field id="tipserv" tabla="PRECIOMODELO"></field>
				<field id="banbar" tabla="PRECIOMODELO"></field>				
				<field id="bastidor" tabla="PRECIOMODELO"></field>				
			</group> 
		</table>
	</form>
</histrix>
