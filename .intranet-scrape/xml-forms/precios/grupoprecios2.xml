<?xml version="1.0" encoding="ISO-8859-1" ?>
<histrix tipo="abm">
		<title>Grupos de Precios</title>
        <obs></obs>
		<form >
			<table id="GRUPOPRECIOS">
    				<title>Grupo de Precios</title>
				<field id="idGrupoPrecio" autoinc="true" noshow="true">
				</field>
				<field id="nrocar">
					<label>Carroceria</label>
					<tabla_ex id="CARROCERIA">
						<field id="nrocar">
							<label>Codigo</label>
						</field>
						<field id="desabv">
							<label>Modelo</label>
						</field>
						<field id="siscod" oculto="true">
							<condicion operador="=">'03'</condicion>
						</field>
					</tabla_ex>
					<help>Modelo de Carroceria</help>
					<detalle>nrocar</detalle>
				</field>
				
				<field id="idGrupo">
					<label>Grupo</label>
					<help>Grupo</help>
					<detalle>idGrupo</detalle>
				</field>
				
				<field id="marcod">
					<label >Marca</label>
					<help>Marca del Chasis</help>
					<tabla_ex id="MARCHASIS">
						<field id="marcod" clave="true">
							<label>Codigo</label>
							<help>Codigo de Chasis</help>
						</field>
						<field id="mardes">
						</field>
					</tabla_ex>
					<actualiza>
						<field destino="marcod" id="modcha"/>
					</actualiza>
				</field>
				
				<field id="moddes" tabla="MODCHASIS">
					<expression>MODCHASIS.moddes</expression>
					<label Formstyle="display:none;" _modpos="nobr">Modelo de Chasis.</label>
					<tipo>varchar</tipo>
				</field>
				<field id="modcha">
					<label  colstyle="display:none;">Modelo de Chasis</label>
					<help>Modelo del Chasis</help>
					<tabla_ex id="MODCHASIS" vacio="true">
						<field clave="true" id="modcha">
							<label>Modelo</label>
							<help>Codigo del Modelo de Chasis</help>
						</field>
						<field id="moddes">
							<label>Descripcion</label>
							<help>Descripcion del Modelo</help>
						</field>
						<field id="marcod">
							<label>Marca Chasis</label>
						</field>
					</tabla_ex>
				</field>
			<field id="descripcion">
					<label _colspan="4" colstyle="display:none;" >Descripción</label>
					<tipo>editor</tipo>
				</field>			
				<order> 
					<field id="nrocar"></field>
					<field id="idGrupo"></field>
					
				</order>
				
			</table>
			<join tipo="left">
				<table id="MARCHASIS">
					<field id="marcod">
						<condicion operador="=">GRUPOPRECIOS.marcod</condicion>
					</field>
				</table>
			</join>
			<join tipo="left">
				<table id="MODCHASIS">
					<field id="modcha">
						<condicion operador="=">GRUPOPRECIOS.modcha</condicion>
					</field>
					<field id="marcod">
						<condicion operador="=">GRUPOPRECIOS.marcod</condicion>
					</field>
				</table>
			</join>
		</form>
</histrix>