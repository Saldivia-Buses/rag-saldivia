    <table id="PRECIOMODELO" >
      <title>Precios por modelo</title>

      <filters>
        <field id="idLista" PDFsize="10">
        
          <label modpos="nobr">Lista</label>
          <help>Lista</help>
          <operador>=</operador>
          <tipo>integer</tipo>
  
        </field>
    <!--  <field id="act" local="true" noshow="true">
        <label modpos="nobr"></label>        
      </field> -->
        
      </filters>

      <field id="nrocar" noshow="true">
      <tipo>integer</tipo>
      </field>
      <field id="idLista" noshow="true" PDFsize="10">
        <tabla_ex id="LISTAPRECIOMODELO">
          <field id="idLista" >
          </field>
          <field id="nom" >
            <expression>concat('Nro ',idLista,' - Vigencia Desde: ' , DATE_FORMAT(fecha, '%d/%m/%Y'))</expression>
          </field>
          <field id="fecha" orden="true" tipoOrden="DESC">
          </field>
          
          <order>
            <field id="fecha"></field>
          </order>

        </tabla_ex>        
        <actualiza>
          <field destino="act" id="act"/>
        </actualiza>        
        <label modpos="nobr">Lista</label>
        <help>Lista</help>
      </field>
      <field id="pie" tabla="LISTAPRECIOMODELO" noshow="true">
      </field>      
      <field id="act" local="true" noshow="true">
        <label modpos="nobr"></label>
      </field>
      <field id="modcar" tabla="CARROCERIA">
		
        <help>Modelo de Carroceria</help>
        <tipo>varchar</tipo>

      </field>
      <field id="cons2" obj="preciomodelo_cons2.xml" showObjTabla="true"   local="true"  >
        <paring destino="nrocar" operador="=">nrocar</paring>
        <paring destino="idLista" operador="=">idLista</paring>
      </field> 
  

                
    
