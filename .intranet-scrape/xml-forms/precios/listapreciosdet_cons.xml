<?xml version="1.0" encoding="ISO-8859-1" ?>
<histrix tipo="consulta"  PDFfontSize="10" PDFlineColor="0,0,0">
	<title>LISTAS DE PRECIOS</title>
	<obs></obs>
	<pie size="17" align="C" style="B">[__pie__]</pie>
	<form >
		<table id="LISTAPRECIOSDET" >
		    <title>Listas de precios</title>
			   <filters>
			    <field id="idLista" PDFsize="12" >
				<label>Lista</label>
				    <operador>=</operador>
				</field>		   
<!--
			    <field id="artsup" tabla="STKINSUM">
				<label>Cod. Interno</label>
				    <operador>=</operador>
					<valor>910004</valor>
				</field>
-->
			   </filters>
			   
				<field id="idLista"  PDFsize="12" noshow="true">
					<label>Lista</label>
				    <helper type="combo" id="LISTAPRECIOSCAB">
					<field id="idLista" orden="true" tipoOrden="DESC"></field>
						<field id="descr">
							<label>Lista</label>
							<expression>CONCAT('Nro ', idLista,' - Vigencia desde ', DATE_FORMAT(fecha, '%d/%m/%Y'))</expression>
						</field>
						<order>
							<field id="idLista" ></field>
						</order>
				    </helper>				   
					<label>Lista</label>
					<help>Lista</help>

				</field>

				<field id="artcod" tabla="STKINSUM">
					<label>cod</label>
					<tipo>varchar</tipo>
				</field>
				<field id="artdes" tabla="STKINSUM">
					<label>Nombre</label>
					<tipo>varchar</tipo>
				</field>
			    <field id="obs">
					<label>Observaciones</label>
					<tipo>varchar</tipo>
				</field>
				<field id="vigencia" tipoOrden="DESC" noshow="true">
					<label>vig</label>
					<tipo>date</tipo>
				</field>

				<field id="fecha" local="true" noshow="true">
        			<label>Fecha</label>
        			<valor>today</valor>
        			<tipo>date</tipo>
       				<detalle>fecha</detalle>
    			</field>
      	    
			    <field id="artsup" tabla="STKINSUM">
				<label>Cod. Interno</label>

			            <helper type="link" xml="stkpieza_qry.xml" dir="/articulos"  >
					<parameter source="artsup" target="idPadre"/>
					<parameter source="fecha" target="fecha"/>
			            </helper>

			    </field>

		        <field id="cosT" noZero="true" >
			        <label >Costo.</label>
			        <!-- NO TOCAR, TE MATO -->
    				<expression having="false" >
						( case when artsup != '' and (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artsup limit 1) != 0 then 
					    (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artsup) end )</expression>
					<tipo>numeric</tipo>
1 			    </field>


        	<field id="cotizacion" sincelda="true" modpos="nobr" noshow="true">
          	  	<label>Cotizacion</label>
          	  	<expression>@cotiz:=(select cotizacion_genmonedahis from GEN_MONEDA_HIS where GEN_MONEDA_HIS.moneda_id = STK_COSTO_REPOSICION.moneda_id order by fecha_genmonedahis DESC limit 1)</expression>
      		</field>

        	<field id="costo_final_func" style="font-weigth:bold;color:blue;">
            	<label>Costo Repo.</label>
<!--
<expression>select sum( ifnull(getCostFunc(STKPIEZA.articulo_hijo, ifnull(STK_COSTO_REPOSICION.moneda_id, 1), STR_TO_DATE('[__fecha__]', '%d/%m/%Y')  ), 0) * 
			cantidad * (1 +  STKPIEZA.recargo / 100)
			    ) from STKPIEZA where idPadre = STKINSUM.artsup</expression> -->

            	<expression>ifnull(getCostConDtoFunc(STKINSUM.artsup, ifnull(STK_COSTO_REPOSICION.moneda_id, 1), STR_TO_DATE('[__fecha__]', '%d/%m/%Y'), 0  ), 0) * (case when (select count(*) from STKPIEZA where IdPadre = STKINSUM.artsup) then 1 else (STKINSUM.valcps / STKINSUM.valuso) end)</expression> 
            	<tipo>numeric</tipo>
        	</field>


			    <field id="precio1">
				    <expression>select precio1 from LISTAPRECIOSDET LD where LD.idLista = LISTAPRECIOSDET.idLista  and LD.idArticulo = LISTAPRECIOSDET.idArticulo order by vigencia DESC limit 1</expression>
                  <label>Precio (u$d s/iva)</label>
					<tipo>custom_numeric</tipo>
					<helper xml="listapreciosdet_crud.xml" type="link">
					    <parameter source="artcod" target="idArticulo" />
					    <parameter source="idLista" target="idLista" />
					</helper>
				</field>

			    <field id="pie" tabla="LISTAPRECIOSCAB" noshow="true">
				</field>
			<order>
				<field id="artdes"></field>
			</order>			
			<group>
				<field id="artcod"></field>
	
			</group>
		</table>
		<join tipo="left">
			<table id="STKINSUM">
				<field id="siscod" >
					<condicion operador="=">'02'</condicion>
				</field>
				<field id="artcod">
					<condicion operador="=">LISTAPRECIOSDET.idArticulo</condicion>
				</field>
			</table>
		</join>
		<join tipo="left">
			<table id="LISTAPRECIOSCAB">
				<field id="idLista">
					<condicion operador="=">LISTAPRECIOSDET.idLista</condicion>
				</field>
			</table>
		</join>

<!--
	<join tipo="left">
        <table id="STKINMOV">
            <field id="artcod">
                <condicion operador="=">STKINSUM.artcod</condicion>
            </field>
        </table>
    </join>
-->
	<join tipo="left">
        <table id="STK_COSTO_REPOSICION">
            <field id="stkarticulo_id">
                <condicion operador="=">STKINSUM.artcod</condicion>
            </field>
        </table>
    </join>
<!--
    <join tipo="left"> 
      <table id="STKINSPR">
        <field id="siscod" >
          <condicion operador="=">'01'</condicion>
        </field>
        <field id="fecult" >
          <condicion operador="&lt;=">STR_TO_DATE('[__fecha__]', '%d/%m/%Y')</condicion>
        </field>        
        <field id="artcod" >
          <condicion operador="=">STKINSUM.artcod</condicion>
        </field>
      </table>
    </join>		
-->
	</form>	   
</histrix>
