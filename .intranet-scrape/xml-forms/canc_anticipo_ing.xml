						</orden>
					</tabla>
					
					<join tipo="left">
						<tabla id="CCTCONCE">
							<campo id="siscod" oculto="true">
								<label>cctcuent.siscod</label>
								<condicion operador="=">
									CCTMOVIM.siscod</condicion>
							</campo>
							
							<campo id="concod" oculto="true">
								<condicion operador="=">
									CCTMOVIM.concod</condicion>
							</campo>
							
							<campo id="condes" oculto="true">
							</campo>
							
						</tabla>
