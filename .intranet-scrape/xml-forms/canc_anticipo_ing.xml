							<help>Imputado</help>
							<condicion operador="!=">0</condicion>
						</campo>
						<campo id="salant" local="true" noshow="true">
							<label>salant</label>
							<help></help>
						</campo>
						<campo id="newsaldo" local="true" deshabilitado="true">
							<label>Saldo</label>
							<if exp="true" operador="=">
								<verdadero>salant - movsal </verdadero>
								<falso>0</falso>
							</if>
							<tipo>numeric</tipo>
						</campo>	
						<orden>
