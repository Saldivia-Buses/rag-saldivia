						<campo id="movfec" deshabilitado="true">
							<label>Fecha </label>
							<help></help>
						</campo>
						<!--          <campo id="movvto">
						<label>Venc. </label>
						<help> </help>
						</campo>
						-->
						<campo id="movimp" deshabilitado="true">
							<label>Importe</label>
							<help>
							</help>
						</campo>
