							<formato>%04d</formato>
						</campo>
						<campo id="movnro" deshabilitado="true">
							<label>Numero</label>
							<help> Numero Comprobante</help>
							<formato>%12d</formato>
							
						</campo>
						<campo id="concod" noshow="true" deshabilitado="true">
							<label>concod</label>
