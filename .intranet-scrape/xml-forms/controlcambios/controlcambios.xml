<?xml version="1.0" encoding="utf-8" ?>
<histrix tipo="crud" _width="60" >
        <title>Control de Cambios</title>
        <obs></obs>
        <form >
                <table id="CONTROLCAMBIOS" >
                    <title>Control de Cambios en los coches</title>
                                        
                        <field id="idCambio" autoinc="true" noshow="true" esclave="true">
                                <label>id</label>
                        </field>

                        <field id="fecha" tipoOrden="DESC">
                                <label>Fecha</label>
                                <help>Fecha</help>
                <valor>today</valor>
                        </field>
                        
                        <field id="nrofab">
                                <label>Nro Fab</label>
                          <help>Número de Fabricación</help>
                        </field>
                        <field id="descripcion">
                          <label>Descripción</label>
                                <help>Descripción del Cambio realizado</help>
                <size>200</size>
                        </field>
                        <field id="motivo">
                                <label>Motivo</label>
                                <help>Motivo del Cambio realizado</help>
                        <size>200</size>
                        </field>

                        <field id="impacto">
                                <label>Impacto</label>
                                <help>Impacto del Cambio realizado</help>
                        <size>200</size>
                        </field>            
             <field id="condicion">
              <label>Condición</label>
              <options>
                <option valor="0">Provisorio</option>
                <option valor="1">Definitivo</option>
              </options>
            </field>
            <field id="aprobo">
              <label>Aprobó</label>
            </field>
                        <field id="validacion1">
                                <label>Validación 1</label>
                                <help>Seguimiento de la efectividad</help>
                        <size>200</size>
                        </field>                                                
<!--                         <field id="validacion2">
                                <label>Validacion 2</label>
                                <help>Seguimiento de la efectividad</help>
                        <size>200</size>
                        </field>                                                
 -->          
                        <order>
                          <field id="fecha" orderType="DESC" />
                        </order> 
                </table>
        </form>           
</histrix>