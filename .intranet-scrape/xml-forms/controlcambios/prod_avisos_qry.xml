<?xml version="1.0" encoding="utf-8" ?>
<histrix tipo="consulta" _width="60" _preFetch="true" _autoprint="true">
        <title>Control de Cambios</title>
        <obs></obs>
        <form >
                <table id="PROD_AVISOS_HOMOLOGACION" >
                    <title>Control de Cambios en los coches</title>
                    <field id="id_prodaviso" autoinc="true" esClave="true" noshow="true" tabla="PROD_AVISOS">
                        <label>id_prodaviso</label>
                    </field>
                    <field id="descripcion_cambio"  tabla="PROD_AVISOS">
                        <label>descripcion del cambio</label>
                        <size>400</size>
                        <tipo>varchar</tipo>
                    </field>

                    <field id="login" noshow="true"  tabla="PROD_AVISOS">
                        <label>login</label>
                    </field>
                    <field id="fecha_creacion" noshow="true"  tabla="PROD_AVISOS">
                        <label>fecha_creacion</label>
                    </field>
                    <field id="fecha_desde"  tabla="PROD_AVISOS">
                        <label>Desde Fecha</label>
                        <tipo>date</tipo>
                    </field>
                    <field id="fecha_hasta"  tabla="PROD_AVISOS">
                        <label>Hasta Fecha</label>
                        <tipo>date</tipo>
                    </field>
                    <field id="homologacion_id" tabla="PROD_AVISOS_HOMOLOGACION" noshow="true" />

                    <field id="desde_unidad"  tabla="PROD_AVISOS">
                        <label>Desde Unidad</label>
                    </field>
                    <field id="hasta_unidad"  tabla="PROD_AVISOS">
                        <label>Hasta Unidad</label>
                    </field>
                    <field id="fecha_aviso"  tabla="PROD_AVISOS">
                        <label>fecha de Aviso</label>
                        <tipo>date</tipo>
                    </field>
                    <field id="cantidad_unidades_aviso" noshow="true"  tabla="PROD_AVISOS">
                        <label>cant. unidades previas al aviso</label>
                    </field>

                    <field id="chasis_marcod"  tabla="PROD_AVISOS">
                        <label>Marca</label>
                        <help>Marca del Chasis</help>
                        <helper type="combo" empty="true" id="MARCHASIS">
                            <field clave="true" id="marcod">
                                <label>Código</label>
                                <help>Coódigo de Chasis</help>
                            </field>
                            <field id="desabv">
                                <label>Abrev.</label>
                                <help>Abreviatura a Utilizar</help>
                            </field>
                            <field id="marca_activo">
                                <condicion operador="=">0</condicion>
                            </field>
                        </helper>

                    </field>
                    
                    <!--                        <actualiza>
                            <field destino="marcod" id="chasis_modcod"/>
                        </actualiza> -->
