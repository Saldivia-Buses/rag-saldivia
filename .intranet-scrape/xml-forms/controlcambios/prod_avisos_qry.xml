                    <field id="chasis_numero_desde"  tabla="PROD_AVISOS">
                        <label>Nro chasis desde</label>
                    </field>
                    <field id="chasis_numero_hasta"  tabla="PROD_AVISOS">
                        <label>Nro chasis hasta</label>
                    </field>
                    <field id="email_destinatarios" noshow="true"  tabla="PROD_AVISOS">
                        <label>email destinatarios</label>
                    </field>
                    <field id="fecha_email" noshow="true"  tabla="PROD_AVISOS">
                        <label>fecha_email</label>
                        <tipo>date</tipo>
                    </field>                                        
                    <field id="cumplido" noshow="true"  tabla="PROD_AVISOS">
                        <label>cumplido</label>
                        <tipo>check</tipo>
                        <condicion operador="=">0</condicion>
                    </field>
                    <field id="login_cumplido" noshow="true" tabla="PROD_AVISOS">
                        <label>login_cumplido</label>
                    </field>
<!--
                    <order>
                        <field id="fecha_desde" orderType="DESC" />
                    </order> 
                    -->
                </table>
            <join  >
                <tabla id="PROD_AVISOS">
                    <field id="id_prodaviso">
                    <condicion operador="=">prodaviso_id</condicion>
                    </field>
                </tabla>
            </join >

        </form>           
</histrix>