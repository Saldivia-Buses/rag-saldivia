			<field id="fax_cuenta">
				<label modpos="nobr">Tel/Fax</label>
			</field>

			<field id="horario">
				<label colspan="2" >Horario de Atención</label>
				<size>50</size>
			</field>

			<field id="entrega_direccion">
				<label colspan="5" style="color:blue;">Domicilio Real</label>
			</field>

			<field id="entrega_codigopostal">
				<label style="color:blue;">Código Postal Envío</label>
			</field>

			<field id="entrega_nacionalidad_id" style="padding:2px 2px 2px 2px;width:300px;vertical-align:middle;">
			    <label style="color:blue;">País de envío</label>
			    <helper id="GEN_NACIONALIDADES" type="combo" empty="true">
			        <field id="id_nacionalidad" >
			        	<condicion operador="=">14 OR id_nacionalidad = 16</condicion>
			        </field>
			        <field id="pais" />
						<order>
		           			<field id="pais" />
						</order>
		    	</helper>
		    	<actualiza>
            		<field id="entrega_provincia_id" destino="nacionalidad_id"/>
         		</actualiza>
		    </field>   

			<field id="entrega_provincia_id" sincelda="true" style="padding:2px 2px 2px 2px;width:250px;vertical-align:middle;">
				<label modpos="nobr" style="color:blue;">Prov. Env.</label>
				<helper id="GEN_PROVINCIAS" type="combo" empty="true">
			        <field id="id_provincia"/>
			        <field id="nombre_provincia"/>
					<field id="nacionalidad_id" oculto="true"/>
						<order>
		           			<field id="nombre_provincia" />
						</order>
		    	</helper>
		    	<actualiza>
            		<field id="entrega_localidad_id" destino="provincia_id"/>
          		</actualiza>
			</field>

			<field id="entrega_localidad_id" style="padding:2px 2px 2px 2px;width:300px;vertical-align:middle;" >
	          <label modpos="nobr" style="color:blue;"> Localidad de Envío </label>
	          <helper type="combo" xml="localidad_qry.xml" dir="/ayudas" empty="true">
	            <field id="provincia_id" oculto="true">
