<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="cabecera">
    <title>Cuenta Corriente</title>
    <obs/>
    <consulta>
        <table id="CCTCUENT" label="Movimientos">
            <field id="siscod" oculto="true">
                <label>Cod.</label>
            </field>
            <field id="sisprv" oculto="true">
                <label>Cod.</label>
                <valor>01</valor>
            </field>
            <field id="consaldo" local="true">
                <label>Proveedores con saldo</label>
                <tabla_ex  xml="cctcuent_c_saldo_neg.xml">
                    <field id="ctacod2">
                        <expresion>CCTCUENT.ctacod</expresion>
                    </field>
                    <field id="ctanom2">
                        <expresion>concat(CCTCUENT.ctanom, ' (',CCTCUENT.ctacod,')')</expresion>
                        <label>Nom</label>
                    </field>
                <field id="ctacod" >
                    <detalle>ctacod</detalle>
                </field>
                    <field id="ctanom">
                        <detalle>ctanom</detalle>
                    </field>
                    <field id="siscod" oculto="true">
                        <condicion operador="=">01</condicion>
                    </field>
                </tabla_ex>
<!--		<actualiza>
                    <field destino="ctacod" id="ctacod" />
                </actualiza> -->

            </field>
            <field id="nroimp" deshabilitado="true">
                <label modpos="nobr" >Numero</label>
                <help>Numero de Imputacion</help>
                <parametro id="cajparam_parent.xml" retorna="parent">
                    <field id="parcla" oculto="true">
                        <condicion operador="=">'nroimp'</condicion>
                    </field>
                    <field id="parent">
                        <complete>parent + 1</complete>
                    </field>
                </parametro>
                <tipo>integer</tipo>
                <formato>%04d</formato>
                <detalle>nroimp</detalle>
            </field>
            <field id="ctacod" _deshabilitado="true">
                <label>Proveedor</label>
                <ayuda_ex id="CCTCUENT" xml="cctcuent_c_saldo_neg.xml">
                    <field id="ctacod">
                        <label>Cod.</label>
                    </field>
                    <field id="ctanom">
                        <label>Nombre</label>
                        <detalle>ctanom</detalle>
                    </field>
                    <field id="siscod" oculto="true">
                        <condicion operador="=">01</condicion>
                    </field>
                    <field id="baja" oculto="true">
                        <condicion operador="=">0</condicion>
                    </field>
                    <order>
                        <field id="CCTCUENT.ctanom" />
                    </order>
                    <clave>ctacod</clave>
                    <descripcion>ctanom</descripcion>
                </ayuda_ex>
            </field>
            <field deshabilitado="true" id="ctanom">
                <label modpos="nobr">Nombre</label>
            </field>
            <field deshabilitado="true" id="mvsl">
                <label>test</label>

            </field>
            <field id="fecha" local="true">
                <label modpos="nobr">Fecha</label>
                <help/>
                <tipo>date</tipo>
                <valor>today</valor>
            </field>
            <field id="Opago" local="true" obj="imputacion_op_cctmovim_ing.xml">
                <label colspan="6">Orden de Pago</label>
            </field>
        </table>
    </consulta>
</histrix>
