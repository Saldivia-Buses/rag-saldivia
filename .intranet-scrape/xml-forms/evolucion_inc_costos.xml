			<field id="costo1" >
				<label>1er Costo</label>
				<expression>case when ((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = STKINSUM.artcod and STKINSPR.siscod='01' and STKINSPR.idCosto != (select STKINSPR.idCosto from STKINSPR where STKINSPR.artcod = STKINSUM.artcod and STKINSPR.siscod='01' order by fecult DESC limit 1) order by fecult DESC limit 1) * STKINSUM.valcps / STKINSUM.valuso) > 0  then ((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = STKINSUM.artcod and STKINSPR.siscod='01' and STKINSPR.idCosto != (select STKINSPR.idCosto from STKINSPR where STKINSPR.artcod = STKINSUM.artcod and STKINSPR.siscod='01' order by fecult DESC limit 1) order by fecult DESC limit 1) ) else STKINSUM.artcos end</expression>
			</field> 
			-->
			<field id="costo2" >
				<label>2do Costo</label>				
				<expression>case when ((select STK_COSTO_HIST.costo_hist from STK_COSTO_HIST where STK_COSTO_HIST.articulo_id = STKINSUM.artcod order by periodo_hist DESC limit 1) * STKINSUM.valcps / STKINSUM.valuso) > 0  then (select STK_COSTO_HIST.costo_hist from STK_COSTO_HIST where STK_COSTO_HIST.articulo_id = STKINSUM.artcod order by periodo_hist DESC limit 1) else STKINSUM.artcos end</expression>
        <tipo>numeric</tipo>

			</field>
			
			

<coment>
      <field id="cosT" >
        <label >Costo.</label>
        <!-- NO TOCAR, TE MATO -->
        <expression having="false" >(
        case when (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1) != 0 then (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1)
    	    else  (select ROUND(INSPR.artcos * valcps / valuso, 2) from STKINSPR as INSPR where INSPR.fecult= max(STKINSPR.fecult) and INSPR.artcod = STKINSPR.artcod and INSPR.siscod = STKINSPR.siscod limit 1) end)</expression>

        <tipo>numeric</tipo>
      </field>     
	</coment>		
