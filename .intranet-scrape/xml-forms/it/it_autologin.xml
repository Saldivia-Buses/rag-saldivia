<?xml version="1.0" encoding="UTF-8" ?>
	<histrix tipo="crud" >
		<title>Autologin</title>
		<obs></obs>

		<form>

			<table id="HTXOPTIONS" label="OPCIONES">
				<field id="id_option" deshabilitado="true"  noshow="true" autoinc="true">
				</field>


				<field id="option_value" _editable="true">
					<label>IP</label>
					<size>20</size>
					
				</field>
              
              
				<field id="mac" _editable="true">
					<label>Mac</label>
					<size>22</size>
					
				</field>
              
              
				<field id="login"  >
					<label>Login</label>
					<size>30</size>
				</field>
              
               <field id="option_name" _editable="true" _noshow="true" >
				  <label>Option</label>	
                  <size>20</size>
                  <condicion operador="like">'autologin_ip%'</condicion>
                 <valor>autologin_ip</valor>
					
				</field>
				<order>
				    <field id="login" />
				</order>

			</table>
		</form>
	</histrix>
