		    <field id="sugerencia">
			<label colspan="4">Sugerencia</label>
			<size>300</size>
		    </field>
		    
		    <field id="comentario">
			<label colspan="4">Comentario</label>
			<size>300</size>
		    </field>
		</table>
	</form>
</histrix>
