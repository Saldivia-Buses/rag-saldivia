		    <field id="contenido" oculto="true" obj="encuesta_get.xml" >
		    
				<label>Contenido</label>
				<valor>contenido</valor>
		    </field >
		    <field id="__mail" noshow="true">
				<label modpos="nobr">mail</label>
			<valor>contenido</valor>
			<tipo>varchar</tipo>
		    </field>
		    <field id="clave" noshow="true">
				<label modpos="nobr">clave</label> 
				<valor>idEncuesta</valor>
