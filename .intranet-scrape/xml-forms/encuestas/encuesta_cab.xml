<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="cabecera" preFetch="true">
	<title>Newsletters</title>
	<obs/>
	<form  >
<!--		<table id="NEWSLETTER" label="Newsletters">
-->
	    <table id="ENCUESTA_CLIENTE">
		<field id="ctacod" noshow="true">
		</field>
        	<field id="numero" autoInc="true" noshow="true">
        	    <label>Numero</label>
        	    <condicion operador="=">0</condicion>
			</field>
		
		<field id="fecha">
		    	<label modpos="nobr">Fecha</label>
				<help>Fecha</help>
				<valor>today</valor>
				<tipo>date</tipo>
		</field>
	
		<field id="idEncuesta" deshabilitado="false">
		    <label modpos="nobr">Envia Encuesta</label>
		    <help></help>
			<tabla_ex id="ENCUESTA" _vacio="true" >
					
					<field id="idEncuesta" >
					</field>
	
					<field id="descripcion" ></field>
					<field id="fecha2" tipoOrden="DESC">
					<expression>fecha</expression>
					    <tipo>date</tipo>
					</field>
					<order>
						<field id="fecha" />
					</order>
			</tabla_ex>
			<expression sql="true">select MAX(idEncuesta) from ENCUESTA</expression> 

		</field>
		  		 

