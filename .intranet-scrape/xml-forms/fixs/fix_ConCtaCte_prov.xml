            <field id="movfec" required="true">
                <label>Fecha </label>
                <help></help>
            </field>
            <field id="regfec" >
                <label>RegistraciÃ³n</label>
                <help></help>
                <tipo>date</tipo>
            </field>


	    <field id="fecha_desde" local="true" noshow="true" required="true">
		<label>d</label>
		<tipo>date</tipo>
		<preparam campo="movfec" operador="&lt;">true</preparam>
	    </field>

            <field id="movvto" noshow="true">
            <label>Venc. </label>
            <help> </help>
            </field>
            
            <field id="movimp" noshow="true" />
            <field id="zoncod" noshow="true" />
            <field id="movlet" noshow="true" />

            <field id="Debe" suma="true" noZero="true">
                <expression>round(movimp * (case when conimp = 1 then 1 else 0 end), 2)</expression>
                <label>Debe</label>
                <help>
        
                </help>
                <tipo>numeric</tipo>
              
            </field>

            <field id="Haber" suma="true"   noZero="true" link_int="cctmovim_comp.xml" linkdes="Ver Recibo">
                <expression>round(movimp * (case when conimp = 2 then 1 else 0 end),2)</expression>
                <label>Haber</label>
                <help>
                </help>
            <!-- <paring destino="siscod">siscod</paring>              -->
                <paring destino="movnro">movnro</paring>
                <paring destino="carrec">movnro</paring>
                <paring destino="cajnro">movnro</paring>
                <paring destino="movinc">movnro</paring>
                <paring destino="movnpv">movnpv</paring>
                <paring destino="ctacod">ctacod</paring>
                <paring destino="movfec">movfec</paring>
                <paring destino="cajfec">movfec</paring>
                <tipo>numeric</tipo>
            </field>
            <field id="opecla" noshow="true" />

            <field id="movsal" suma="true" noZero="true">
                <label>Saldo</label>
                <help></help>
                <tipo>numeric</tipo>
            </field>
            <field id="acumulado" suma="true" acumula="true" local="true">
                <if exp="true">
                    <true>Haber - Debe</true>
                    <false>0</false>
                </if>
                <tipo>numeric</tipo>
                <label>Acumulado</label>
            </field>
	    <field id="caj" >
                <expression having="false">ifnull((select 2 from CTBREGIS where CTBREGIS.ctbcod = '111102' and CTBREGIS.regmin = CCTMOVIM.regmin and CTBREGIS.regnro = movnro and CTBREGIS.regfec = CCTMOVIM.regfec limit 1), 1)</expression>
                <condicion operador="=">2</condicion>

	    </field>            
        <field id="buscop">
            <expression having="false">ifnull((select 0 from CCTMOVIM AS CCT where CCT.movnro = CCTMOVIM.movnro and CCT.movnpv = CCTMOVIM.movnpv and CCT.ctacod = CCTMOVIM.ctacod and CCT.siscod = CCTMOVIM.siscod and  CCT.concod = 4 and CCT.movimp = CCTMOVIM.movimp LIMIT 1),1)</expression>
            <condicion operador="=">1</condicion> 
	    
        </field>
            
            <filters>
                <field id="ctacod">
                    <label>Cod.</label>
                    <help>Codigo de Cuenta </help>
                    <ayuda_ex id="CCTCUENT">
                        <field id="ctacod">
                            <detalle>ctacod</detalle>
                        </field>
                        <field id="NOM">
                            <expression having="false">CONCAT(ctafan, ' (',  ctanom,')')</expression>
                            <label>Nombre</label>
                            <detalle>ctanom</detalle>
                        </field>
                                                    <!--                    <field id="ctanom"></field> -->
                        <field id="siscod" oculto="true">
                            <condicion operador="=">'01'</condicion>
                        </field>
                        <field id="ctafan" noshow="true"></field>
                        <order>
                            <field id="ctafan"></field>
                        </order>
                        <field id="baja" oculto="true">
                            <condicion operador="=">0</condicion>
                        </field>
                    </ayuda_ex>
                    <detalle>ctacod</detalle>
                    <operador>=</operador>
                </field>
                <field id="ctanom2" local="true" deshabilitado="true">
                    <label modpos="nobr">Nombre </label>

                </field>
                <field id="movfec" copia="fecha_desde">
                    <operador>>=</operador>
                    <label>Desde Fecha</label>
                    <valor>today</valor>

                </field>
	    <field id="fecha_desde" local="true" noshow="true" deshabilitado="true" required="true">
		<label modpos="nobr">d</label>
		<tipo>date</tipo>
		<preparam campo="movfec" operador="&lt;">true</preparam>

	    </field>
                
                <field id="movfec">
                    <operador>&lt;=</operador>
                    <label modpos="nobr">Hasta Fecha</label>
                    <valor>today</valor>

                </field>
            <field id="regfec" required="true">
                <label>Desde registracion</label>
                <help></help>
                <operador>&gt;=</operador>

            </field>
                
            <field id="regfec" required="true">
                <label modpos="nobr">Hasta registracion</label>
                <help></help>
                <operador>&lt;=</operador>

            </field>

                <field id="movimp">
                    <operador>>=</operador>
                    <label>Desde Importe</label>
                </field>
                <field id="movimp">
                    <operador>&lt;=</operador>
                    <label modpos="nobr">Hasta Importe</label>

                </field>

                
            </filters>
            <order>
                <field id="ctanom"></field>
                <field id="movfec"></field>
            </order>
        </table>

        <join tipo="left">
            <table id="CCTCONCE">
                <field id="siscod" oculto="true">
                    <label>cctcuent.siscod</label>
                    <condicion operador="=">
                  CCTMOVIM.siscod
                    </condicion>
                </field>

                <field id="concod" oculto="true">
                    <condicion operador="=">
                  CCTMOVIM.concod
                    </condicion>
                </field>

                <field id="condes" oculto="true">
                </field>

            </table>
        </join>
    </form>
</histrix>