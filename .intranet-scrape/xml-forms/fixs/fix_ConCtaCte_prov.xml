<?xml version="1.0" encoding="ISO-8859-1" ?>
<histrix tipo="ing" inserta="false" modifica="false">
    <title>Cuenta Corriente</title>
    <obs></obs>
<!--        <form  detalle="cctmovim_comp_prov.xml"> -->
    <form  _detalle="imputaciones.xml" inline="true">
        <table id="CCTMOVIM" label="Movimientos" styleTbody="height:500px;">
<!--	    <preconsultas>
		<xmlfile id="ConCtaCte_prov_pre2.xml"/>
	    </preconsultas>                            
