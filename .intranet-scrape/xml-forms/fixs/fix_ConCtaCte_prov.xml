      <movimientos >
        <relacion id="fix_factura_cctmovim_ctdo_ingmov.xml"/>
        <relacion id="fix_factura_cajmovim_ingmov.xml"/>

      </movimientos>

            <field id="siscod" oculto="true">
                <label>Cod.</label>
                <help>
                </help>
            </field>
            <field id="ctacod">

                <help>Codigo de Cuenta </help>
                <ayuda_ex id="CCTCUENT">
                    <field id="ctacod">
                        <detalle>ctacod</detalle>
                    </field>
                    <field id="NOM">
                        <expression having="false">CONCAT(ctafan, ' (',  ctanom,')')</expression>
                        <label>Nombre</label>
                        <detalle>ctanom2</detalle>

                    </field>
                    <field id="siscod" oculto="true">
                        <condicion operador="=">'01'</condicion>
                    </field>
                    <field id="baja" oculto="true">
                        <condicion operador="=">0</condicion>
                    </field>

                    <order>
                        <field id="ctanom"></field>
                    </order>
                
                    <filtra>ctacod</filtra>
                </ayuda_ex>
                <detalle>ctacod</detalle>
                <preparam campo="ctacod" operador="=">true</preparam>
                
            </field>

            <field id="ctanom2"  local="true" deshabilitado="true" noshow="true" />

            <field id="ctanom"  deshabilitado="true" _noshow="true">
		<expression>ctanom</expression>
                <label modpos="nobr">Nombre</label>

            </field>


            <field id="concod" noshow="true">
                <label>concod</label>
                <detalle>concod</detalle>
                <condicion operador="=">1</condicion>
            </field>
            <field id="movnpv">
                <label>P.V.</label>
                <help> Punto Venta</help>
                <format>%04d</format>
                <detalle>movnpv</detalle>
            </field>
            <field id="movnro"> <!-- linkint="factura_detalle.xml" linkdes="Ver Detalle del Comprobante">-->
                <label>Numero</label>
                <help> Numero Comprobante</help>
                <format>%12d</format>
                <detalle>movnro</detalle>
            </field>

            <field id="concepto">
                <expression>condes</expression>
                <label>Cod.Concepto</label>
                <help>
                </help>
                <tipo>string</tipo>
              <!--          <tabla_ex id="CCTCONCE">

              <field id="concod"></field>
              <field id="condes"></field>
              </tabla_ex>
              -->
            </field>
				<field id="regfec" noshow="true"/>
				<field id="regmin" linkint="ctbregis2.xml" linkdir="ctb_old">
					<label>Min</label>
					<help>
					</help>
				<!--	<format>%010d</format> -->
					<paring destino="regnro">movnro</paring>					
					<paring destino="regmin">regmin</paring>
					<paring destino="regfec">regfec</paring>
					
				</field>

            <field deshabilitado="true" id="OP" local="true" linkint="cctmovim_OP.xml" linkdes="Orden de Pago" print="false">

                <label >Ot.</label>
                <if exp="concod == 4">
                    <true>'Ver'</true>
                    <false>''</false>
                </if>
                <help>Codigo de Cuenta</help>
        
                <paring destino="ctacod">ctacod</paring>
                <paring destino="cajcta">ctacod</paring>
                <paring destino="regmin">regmin</paring>
                <paring destino="movnpv">movnpv</paring>
                <paring destino="movnro">movnro</paring>
                <paring destino="nrocom">movnro</paring>
                <paring destino="carpag">movnro</paring>
                <paring destino="nropag">movnro</paring>
                <paring destino="referencia">movnro</paring>
                <paring destino="carrec">movnro</paring>
                <paring destino="cajnro">movnro</paring>
                <paring destino="movfec">movfec</paring>
                <paring destino="cajfec">movfec</paring>

                            
              
                <tipo>varchar</tipo>
            </field>

           

            <field id="fact" deshabilitado="true" local="true" _linkint="factura_detalle.xml" linkint="factura_facremit.xml" linkdes="Factura" print="false">
                <label>Fact</label>
                <if exp="concod == 1">
                    <true>'verF'</true>
                    <false>''</false>
                </if>
                <paring destino="ctacod">ctacod</paring>
                <paring destino="movnpv">movnpv</paring>
                <paring destino="movnro">movnro</paring>
<!--                <paring destino="regfec">regfec</paring> -->
               
                <paring destino="siscod">siscod</paring>

            </field>    
             

