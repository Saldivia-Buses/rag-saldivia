                <paring destino="movfec">movfec</paring>

                            
              
                <tipo>varchar</tipo>
            </field>
         -->
            <field id="movfec" required="true">
                <label>Fecha </label>
                <help>
                </help>
                <tipo>date</tipo>
            </field>

            <!--          <field id="movvto">
            <label>Venc. </label>
            <help> </help>
            </field>
            -->
            <field id="movimp" noshow="true" />

            <field id="Debe" suma="true" noZero="true">
                <expression>sum(round(movimp * (case when conimp = 1 then 1 else 0 end), 2))</expression>
                <label>Debe</label>
                <help>
        
                </help>
                <tipo>numeric</tipo>
              
            </field>

            <field id="Haber" suma="true"   noZero="true" link_int="cctmovim_comp.xml" linkdes="Ver Recibo">
                <expression>sum(round(movimp * (case when conimp = 2 then 1 else 0 end),2))</expression>
                <label>Haber</label>
                <help>
                </help>
            <!-- <paring destino="siscod">siscod</paring>              -->
                <paring destino="movnro">movnro</paring>
                <paring destino="carrec">movnro</paring>
                <paring destino="cajnro">movnro</paring>
                <paring destino="movinc">movnro</paring>
                <paring destino="movnpv">movnpv</paring>
                <paring destino="ctacod">ctacod</paring>
                <paring destino="movfec">movfec</paring>
                <paring destino="cajfec">movfec</paring>
                <tipo>numeric</tipo>
            </field>

            <field id="movsal" suma="true">
            <expression>sum(movsal )</expression>
                <label>Saldo</label>
                <help></help>
                <tipo>numeric</tipo>
            </field>
            <field id="acumulado" suma="true" acumula="true" local="true">
                <if exp="true">
                    <true>Haber - Debe</true>
                    <false>0</false>
                </if>
                <tipo>numeric</tipo>
                <label>Acumulado</label>
            </field>
            
            
        </table>

        <join tipo="left">
            <table id="CCTCONCE">
                <field id="siscod" oculto="true">
                    <label>cctcuent.siscod</label>
                    <condicion operador="=">
                  CCTMOVIM.siscod
                    </condicion>
                </field>

                <field id="concod" oculto="true">
                    <condicion operador="=">
                  CCTMOVIM.concod
                    </condicion>
                </field>


            </table>
        </join>
    </form>
</histrix>