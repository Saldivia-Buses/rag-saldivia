<?xml version="1.0" encoding="ISO-8859-1" ?>
<histrix tipo="consulta">
    <title>Cuenta Corriente</title>
    <obs></obs>
<!--        <form  detalle="cctmovim_comp_prov.xml"> -->
    <form  detalle="imputaciones.xml" inline="true">
        <table id="CCTMOVIM" label="Movimientos" styleTbody="height:500px;">
            <field id="siscod" oculto="true">
                <label>Cod.</label>
                <help>
                </help>
            </field>
            <field id="ctacod">
                <help>Codigo de Cuenta </help>
                <ayuda_ex id="CCTCUENT">
                    <field id="ctacod">
                        <detalle>ctacod</detalle>
                    </field>
                    <field id="NOM">
                        <expression having="false">CONCAT(ctafan, ' (',  ctanom,')')</expression>
                        <label>Nombre</label>
                        <detalle>ctanom</detalle>

                    </field>
                    <field id="siscod" oculto="true">
                        <condicion operador="=">'01'</condicion>
                    </field>
                    <field id="baja" oculto="true">
                        <condicion operador="=">0</condicion>
                    </field>

                    <order>
                        <field id="ctanom"></field>
                    </order>
                
                    <filtra>ctacod</filtra>
                </ayuda_ex>
                <detalle>ctacod</detalle>
                
            </field>
            <field id="ctanom" local="true" deshabilitado="true" noshow="true">
                <label modpos="nobr">Nombre</label>

            </field>


            <field id="concod" noshow="true">
                <label>concod</label>
                <detalle>concod</detalle>
            </field>
            <field id="movnpv">
                <label>P.V.</label>
                <help> Punto Venta</help>
                <format>%04d</format>
                <detalle>movnpv</detalle>
            </field>
            <!-- linkint="factura_detalle.xml" linkdes="Ver Detalle del Comprobante">-->
            <!--
            <field id="movnro"> 
                <label>Numero</label>
                <help> Numero Comprobante</help>
                <format>%12d</format>
                <detalle>movnro</detalle>
            </field>
                -->
            <field id="concepto">
                <expression>'Saldo Inicial'</expression>
                <label>Cod.Concepto</label>
                <help>
                </help>
                <tipo>string</tipo>
              <!--          <tabla_ex id="CCTCONCE">

              <field id="concod"></field>
              <field id="condes"></field>
              </tabla_ex>
              -->
            </field>
            <field id="regmin" oculto="true">
                <label>minuta</label>
             </field>
            <field deshabilitado="true" id="OP" local="true" linkint="cctmovim_OP.xml" linkdes="Orden de Pago" print="false">

                <label >Ot.</label>
                <if exp="concod == 4">
                    <true>'Ver'</true>
                    <false>''</false>
                </if>
                <help>Codigo de Cuenta</help>
        
                <paring destino="ctacod">ctacod</paring>
                <paring destino="cajcta">ctacod</paring>
                <paring destino="regmin">regmin</paring>
                <paring destino="movnpv">movnpv</paring>
                <paring destino="movnro">movnro</paring>
                <paring destino="nrocom">movnro</paring>
                <paring destino="carpag">movnro</paring>
                <paring destino="nropag">movnro</paring>
                <paring destino="referencia">movnro</paring>
                <paring destino="carrec">movnro</paring>
                <paring destino="cajnro">movnro</paring>
                <paring destino="movfec">movfec</paring>
                <paring destino="cajfec">movfec</paring>

                            
              
                <tipo>varchar</tipo>
            </field>
<!--            <field id="isedit" local="true" noshow="true">
              <valor eval="true">$_SESSION['EDITOR']</valor>
          </field>
            <field id="EDITOR" local="true" noshow="true">
          <if exp="'editor' = 'isedit'">
              <true>true</true>
              <false>false</false>
          </if>
          </field>
    -->      
          <!--
            <field deshabilitado="true" id="mod" local="true" linkint="cctmovim_modif.xml" linkdes="Modif" print="false">
    <attribute id="noshow">EDITOR</attribute>
                <label >Modif</label>
              <valor>Modif</valor>

        
                <paring destino="siscod">siscod</paring>
        
                <paring destino="ctacod">ctacod</paring>
                <paring destino="cajcta">ctacod</paring>
                <paring destino="movnpv">movnpv</paring>
                <paring destino="movnro">movnro</paring>
