<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="card" subtipo="vertical" _imprime="false" _autoprint="true"  grid="96%,10"   inserta="false"
 path="fotos/coches" 

>
<title>Seccion</title>
<obs></obs>
<form >
    <table id="PRODUCTO_SECCION">
        <title>Ficha de Producto</title>

    <field id="producto_id" local="true" noshow="true">
        <detalle>producto_id</detalle>
        <label>Undiad</label>
    </field>

    <field id="cotizacion_id" local="true" noshow="true">
        <detalle>cotizacion_id</detalle>
        <label>Cotiz</label>
    </field>

    <field id="activa_seccion" noshow="true">
        <condicion operador="=">0</condicion>
    </field>

        <field id="id_prdseccion" autoinc="true" noshow="true">
            <label>Codigo</label>
            <detalle>prdseccion_id</detalle>
        </field>
        <field id="orden_seccion" noshow="true">
            <label>Orden</label>
            <help>Orden de impresion</help>
        </field>
        <field id="nrofab" noshow="true" local="true" />
                                          
        <field id="nombre_seccion"  style="font-weight:bold;" lblsize="90"  PDFbold="true" PDFsize="15"   PDFcolor="ffffff" PDFbackgroundColor="555555">
            <label >Secciones</label>
            <help>Nombre de la Sección</help>
        </field>
<!--
        <field id="hasData" noshow="true">
    	    <expresion>((select count(*) from PRODUCTO_ATRIB_VALORES join PRODUCTO_ATRIBUTOS on id_prdatributo = prdatributo_id where prdseccion_id = id_prdseccion and producto_id = '[__producto_id__]') 
    	             + (select count(*) from ACCESORIOS_COCHE where prdseccion_id = id_prdseccion and ficha_id = producto_id))</expresion>
    	             <condicion operador="!=">0</condicion>
        </field>-->

        <field id="valores" local="true" showObjTabla="true" >
    <!--	    <attribute id="Etiqueta">nombre_seccion</attribute> -->
    	    <label posx="5" posy="+1"></label>
    	    <helper xml="producto_atributos_valores_qry.xml" type="object" dir="/producto">
            <parameter source="producto_id" target="producto_id" />
            <parameter source="cotizacion_id" target="cotizacion_id" />
    		<parameter source="id_prdseccion" target="prdseccion_id" />
    	    </helper>
        </field>
      
        <field id="Panas" local="true" showObjTabla="true" >
    	    <label posx="5" posy="+0.5"></label>
    	    <helper xml="producto_panas.xml" type="object" dir="/">
            <parameter source="cotizacion_id" target="cotizacion_id" />
    		<parameter source="producto_id" target="producto_id" />
    		<parameter source="id_prdseccion" target="prdseccion_id" /> 
    	    </helper>
        </field>

        <field id="muestra_fv" noshow="true" local="true">
            <valor>1</valor>
        </field>

        <field id="showprecios" noshow="true" local="true">
            <valor>1</valor>
        </field>

        <field id="obs" local="true" showObjTabla="true" >
    	    <label posx="5" posy="+0.5"></label>
    	    <helper xml="accesorios_coche_qry.xml" type="object" dir="/produccion/man/">
            <parameter source="cotizacion_id" target="cotizacion_id" />
    		<parameter source="nrofab" target="nrofab" />
    		<parameter source="id_prdseccion" target="prdseccion_id" />
            <parameter source="muestra_fv" target="muestra_fv" /> 
            <parameter source="showprecios" target="showprecios" /> 
    	    </helper>
        </field>

        <order>
            
            <field id="orden_seccion" />
            <field id="nombre_seccion" />

        </order>
    </table>
</form>	   
</histrix>