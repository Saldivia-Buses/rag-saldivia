				<expression>concat(MARCHASIS.desabv,' ', MODCHASIS.moddes)</expression>
				<label colstyle="width:100px;"></label>
				<tipo>varchar</tipo>
			</field>		-->	
			<field id="cons3" >
	                    <expression>GRUPOPRECIONOM.descripcion</expression>
			</field>
