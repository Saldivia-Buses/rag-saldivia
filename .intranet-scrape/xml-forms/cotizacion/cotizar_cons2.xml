			<title>Precios por modelo</title>



	
			<field id="nrocar" noshow="true">
			    <tipo>integer</tipo>
			</field>		
			<field id="idGrupo" noshow="true">
			</field>			
			<field id="idLista" local="true" noshow="true">
			    <tipo>integer</tipo>
			</field>			
