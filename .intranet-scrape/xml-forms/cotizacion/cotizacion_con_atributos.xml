<?xml version='1.0' encoding='UTF-8' ?>
<histrix tipo="fichaing" clase="claseancha" processFirst="true" log="false" modifica="false" inserta="false" borra="false">
    <title>COTIZACION</title>
    <obs></obs>
    <form >
        <table id="COTIZACION" label="COTIZACION">
	    <movimientos>
		<relacion id="cotizacion_con_atributos_ins.xml" />
	    </movimientos>
								
            <validation>
                <condition>('ctanom' == '0')</condition>
                <message>Debe Ingresar el Nombre.</message>
            </validation>
            <validation >
                <condition>(homologacion_id == 0)</condition>
                <message>Debe Seleccionar una homologacion</message>
            </validation>
            <field id="idLista" deshabilitado="true" noshow="true">
                <tabla_ex id="PRECIOMODELO">
                    <field id="id">
                        <expression>max(idLista)</expression>
                    </field>
                    <field id="id2">
                        <expression>max(idLista)</expression>
                    </field>
						
                </tabla_ex>
                <tipo>integer</tipo>
            </field>
			
            <field id="ctacod" required="true" autocompletar="true" deshabilitado="true" noshow="true">
                <label modpos="nobr">Cliente </label>
                <help>Codigo de Cuenta </help>
                <valor>0</valor>
                <actualiza>
                    <field destino="ctacod" id="contactos"/>
                </actualiza>
                <detalle>ctacod</detalle>
                <tipo>integer</tipo>
            </field>
            <field id="ctanom" required="true" autocompletar="true" searchRecord="false">
                <label colspan="2">Nombre</label>
                <ayuda_ex id="CCTCUENT" condes="true" xml="HLPcctcuent_conta_cot.xml" dir="/help_local">
                    <field id="ctacod" noshow="true">
                        <detalle>ctacod</detalle>
                    </field>
						
                    <field id="ctanom2">
                        <expression having="false">concat(CCTCUENT.ctanom, ' - ', CCTCUENT.ctafan)</expression>
                        <tipo>varchar</tipo>
                    </field>
                    <field id="siscod" oculto="true" >
                        <condicion operador="=">'02'</condicion>
                    </field>
                    <field id="ctatel" class="informal" noshow="true">
                        <detalle>ctatel</detalle>
                    </field>
						
                    <clave>ctanom</clave>
                    <descripcion>ctanom</descripcion>
                    <order>
                        <field id="ctanom"></field>
                    </order>
                </ayuda_ex>
	
                <size>40</size>
                <valor></valor>
            </field>
            <field id="idCotiz" _autoinc="true" deshabilitado="true" _noshow="true">
                <label modpos="nobr" style="font-size:15px; color:green;font-weight:bold;">Nro Cotiz.</label>

                <tabla_ex id="COTIZACION">
                    <field id="id">
                        <expression>max(idCotiz) + 1</expression>
							
                    </field>
                    <field id="id2">
                        <expression>max(idCotiz) + 1</expression>
							
                    </field>
						
                </tabla_ex>

                <tipo>varchar</tipo>

                <help>Numero de Cotizacion</help>
                <detalle>idCotiz</detalle>
            </field>


            <field id="fecha" deshabilitado="true">
                <label modpos="nobr">Fecha</label>
                <help>Fecha de Cotización</help>
		<tipo>date</tipo>
                <valor>today</valor>
            </field>
            
            <field id="contactos" required="true">
                <label colspan="2">Contactos</label>
                <helper type="combo" id="CCTCONTA" vacio="true">
                    <field id="idconta"></field>
                    <field id="nombre" >
                   <!--      <expression>CCTCONTA.nombre</expression>
                        <tipo>varchar</tipo> -->
                    </field>
						
                    <field id="ctamail" >
                        <expression>CCTCONTA.mail</expression>
                        <tipo>varchar</tipo>
                    </field>
                    <field id="ctatel" >
                        <expression>CCTCONTA.Telefono</expression>
                        <tipo>varchar</tipo>
                    </field>
                    <field id="ctacon" >
                        <expression>CCTCONTA.nombre</expression>
                        <tipo>varchar</tipo>
                    </field>
                    <field id="ctacod" oculto="true">
                        <condicion operador="=">0</condicion>
                    </field>
                    <order>
                        <field id="nombre"></field>
                    </order>
                </helper>
            </field>

            <field id="ctatel">
                <label modpos="nobr" colspan="6">Teléfono</label>
                <size>40</size>
                <tipo>varchar</tipo>
            </field>
<!--				<field id="ctadir">
					<label>Dirección</label>
					<size>40</size>
				</field>
				<field id="ctanro">
					<label modpos="nobr">CUIT</label>
				</field> -->
            <field id="ctacon" >
                <label colspan="2">Contacto</label>
                <size>40</size>
            </field>
            <field id="ctamail" >
                <label modpos="nobr" colspan="6">e-mail</label>
                <size>40</size>
					
            </field>

	    <field id="moneda_id">
		<label>Moneda</label>
                <helper id="GEN_MONEDAS" type="combo">
                    <field id="id_moneda"></field>
                    <field id="descripcion_moneda"></field>
                </helper>		
	    </field>

            <field id="showPrecioCon" >
                <label>Concesionario</label>
                <tipo>check</tipo>
            </field>
            <field id="precio" _sincelda="true">
                <label  modpos="nobr"></label>
                <tipo>decimal</tipo>
                <size>20</size>
            </field>

					
          <field id="homologacion_id" required="true" _deshabilitado="true">
            <label modpos="nobr">Homologación</label>
             <helper type="combo" xml="combo_homologacion_modelo.xml" dir="/fabricacion" empty="true" />
  <!--         <expression><![CDATA[IFNULL((SELECT CONCAT( IFNULL(CARROCERIA.desabv,''),' ', IFNULL(MARCHASIS.mardes,''),' ', 
                                            IFNULL(MODCHASIS.desabv,''), ' ', IFNULL(EURO_TIPO.abrev_euro,''), ' ',
