 -->          
		<field id="baja2">
		    <expression having="false">baja</expression>
		<condicion operador="=">0</condicion>
		</field>
                <actualiza>
                    <field destino="homologacion_id" id="atributos"/>
                </actualiza>
            </field> 

            <field id="idGrupo" deshabilitado="true" noshow="true" >
                <label modpos="nobr">idGrupo</label>
                <tipo>integer</tipo>
            </field>
				<!-- SELECCIONO LAS POSIBLES CARROCERIAS A FABRICAR -->
            <field id="modcar" tabla="CARROCERIA" deshabilitado="true" noshow="true">
                <label _colspan="2" _modpos="nobr">Carroceria</label>
                <tabla_ex id="CARROCERIA">
                    <field id="nrocar"></field>
                    <field id="desabv"></field>
                </tabla_ex>
                <tipo>varchar</tipo>
            </field>
            <field id="asientos2"  local="true" deshabilitado="true" noshow="true" _sincelda="true">
                <label _modpos="nobr"> Asientos</label>
                <tipo>integer</tipo>
                <size>2</size>
            </field>

            <field id="showPrecioPub" >
                <label>Venta</label>
                <tipo>check</tipo>
            </field>
            <field id="prePub" _sincelda="true">
                <label  modpos="nobr" ></label>
                <tipo>decimal</tipo>
                <size>20</size>
            </field>
            <field id="leyenda_precio">
        	<label colspan="2">Leyenda Precio</label>
        	<valor>(Incluye Iva del  10,5 % )</valor>
        	<size>40</size>
    	    </field>
				<!-- SELECCIONO EL MODELO DE CHASIS -->
				
             <field id="grupo" noshow="true">
                <label colspan="4" modpos="nobr" style="color:red;">Seleccione Modelo</label>
					
                <tabla_ex id="GRUPOPRECIOS" xml="grupoprecios_select.xml" _expand="true"	vacio="true">
                    <field id="idGrupoPrecio">
                        <condicion operador=""></condicion>
                    </field>
                    <field id="desabv">
                        <expression>concat(MARCHASIS.desabv,' ',	MODCHASIS.moddes)</expression>
                        <label colstyle="width:100px;">Chasis</label>
                        <tipo>varchar</tipo>
                    </field>
                    <field id="marcod">
                        <detalle>marcod</detalle>
                    </field>
                    <field id="modcha">
                        <detalle>modcha</detalle>
                    </field>
						
                    <field id="nrocar">
                        <detalle>nrocar</detalle>
                        <condicion operador=""></condicion>
							
                    </field>
                    <field id="idGrupo">
                        <detalle>idGrupo</detalle>
                    </field>
                </tabla_ex>
                <tipo>integer</tipo>
					<!-- <tipo>radio</tipo> -->
            </field>

															
            <field id="marcod" deshabilitado="true" noshow="true">
                <label>marcod</label>
                <tipo>integer</tipo>
            </field>
				
            <field id="modcha" deshabilitado="true" noshow="true">
                <label modpos="nobr">modcha</label >
                <tipo>integer</tipo>
            </field>
				
		


            <field id="pie" deshabilitado="false">
                   <label rowspan="2" colspan="2">Pie</label>
		    <expression sql="true">select group_CONCAT(texto order by orden separator ' ') from COTIZPIE</expression>
<!--
                   <valor><![CDATA[La operaci&oacute;n se concreta mediante la aceptaci&oacute;n fehaciente de la presente cotizaci&oacute;n.
Los turnos de fabricaci&oacute;n se otorgar&aacute;n a partir del cierre de la operaci&oacute;n.
COTIZACI&Oacute;N V&Aacute;LIDA POR 10 DIAS CORRIDOS.
]]></valor>-->
                   <size>200</size>
            </field>
            <field id="plazo">
                <label modpos="nobr" colspan="5">Plazo de entrega</label>
                <tipo>varchar</tipo>
                <size>70</size>
                <valor>45 días a partir de entrada a producción</valor>
            </field>
            <field id="formaPago">
                <label _modpos="nobr" colspan="5">Forma de Pago</label>
                <tipo>varchar</tipo>
                <size>120</size>
                <valor>A PROCESO</valor>
            </field>

      <field id="filtro_cotiz" noshow="true" local="true">
        <valor>1</valor>
      </field>    

    <field id="atributos" local="true" colspan="8">
    <label>Attributos</label>
    <helper xml="configurador_atributos_cotizacion.xml" type="object" dir="/producto/ing">
      <parameter source="homologacion_id" target="homologacion_id" />
      <parameter source="filtro_cotiz" target="activo_cotizacion" /> 
    </helper>
        <label colspan="2" colstyle="display:none;">Atributos</label>
    </field>

<!--             <field id="accesorios" local="true" obj="cotiz_accesorios_coche.xml">
                <label colspan="7"></label>
                <paring destino="cotizacion_id">idCotiz</paring>
            </field> -->

        </table>
    </form>
</histrix>
