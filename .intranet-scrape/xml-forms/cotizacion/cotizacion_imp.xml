				<field id="opciones" local="true" obj="cotizopmovim_cons.xml" >
					<label  size="25" posx="10" posy="+4" PDFsize="12"></label>
					<paring destino="idCotiz">idCotiz</paring>
					
				</field>  			
				<field id="pre_pub" noshow="true" local="true" oculto="true">
					<expression>case when showPrecioPub = 0 then 'true' end</expression>  
					<tipo>varchar</tipo>
				</field>				
				<field id="pre_con" noshow="true" local="true" oculto="true">
					<expression>case when showPrecioCon = 0 then 'true' end</expression>  
					<tipo>varchar</tipo>
				</field>
				<field id="preC" local="true" PDFbold="true" print="false" >
					<attribute id="oculto">pre_con</attribute>
	
	
					<label size="43" posx="5" posy="+2" PDFsize="12">Precio Concesionario</label>
					<expression>case when showPrecioCon != 0 then precioCon end</expression>
					<tipo>decimal</tipo>
					<prefijo>$ </prefijo>
				</field> 
				<field id="prePub" local="true" PDFbold="true" print="false" >
					<attribute id="oculto">pre_pub</attribute>					
					<label size="43" posx="5" posy="+2" PDFsize="12">Precio Venta</label>
					<expression>case when showPrecioPub != 0 then precioPub end</expression>
					<prefijo>$ </prefijo>					
					<tipo>decimal</tipo> 
				</field>
				<field id="formaPago"  noshow="true" print="false"  >
					<label size="43" posx="5" posy="+2" PDFsize="12">Forma de Pago</label>
				</field>				
				<field id="plazo" noshow="true" print="false" >
					<label size="43" posx="5" posy="+2" PDFsize="12">Plazo</label>
				</field>	
