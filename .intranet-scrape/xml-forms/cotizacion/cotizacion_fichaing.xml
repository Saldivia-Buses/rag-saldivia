<?xml version="1.0" encoding="ISO-8859-1" ?>
	<abm tipo="fichaing" subtipo="vertical" _conBusqueda="true"
		llenoTemporal="false" _imprime="false"
		inserta="false"                                                         
        modifica="false"
		>
		<titulo>COTIZACION</titulo>
		<obs></obs>
		<consulta>
			<tabla id="COTIZACION" label="COTIZACION">
								
				<movimientos >
					<relacion id="cotizacion_ingmov.xml"/>					
				</movimientos>
				
				<validation>
					<condition>('ctanom' == '0')</condition>
					<message>Debe Ingresar el Nombre.</message>
				</validation> 
				<validation >
					<condition>(modcar == 0)</condition>
					<message>Debe Seleccionar el Modelo</message>
				</validation>
				<campo id="idLista" deshabilitado="true" noshow="true">
					<tabla_ex id="PRECIOMODELO">
						<campo id="id">
							<expresion>max(idLista)</expresion>
						</campo>
						<campo id="id2">
							<expresion>max(idLista)</expresion>
						</campo>
						
					</tabla_ex>
				</campo>
				<campo id="idCotiz" _autoinc="true" deshabilitado="true" noshow="true">
					<label>Nro Cotiz.</label>
					<tabla_ex id="COTIZACION">
						<campo id="id">
							<expresion>count(*) + 1</expresion>
							
						</campo>
						<campo id="id2">
							<expresion>count(*) + 1</expresion>
							
						</campo>
						
					</tabla_ex>

					<help>Numero de Cotizacion</help>
					<valor default="true">0</valor>
				</campo>  

				<campo id="ctacod" required="false">
					<label>Cliente </label>
					<help>Codigo de Cuenta </help>
					<ayuda_ex id="CCTCUENT" condes="true">
						<campo id="ctacod"></campo>
						<campo id="ctanom">
							<detalle>ctanom</detalle>
						</campo>
						<campo id="ctatel">
							<detalle>ctatel</detalle>
						</campo>
						<campo id="ctadir">
							<detalle>ctadir</detalle>
						</campo>
						<campo id="ctanro">
							<detalle>ctanro</detalle>
						</campo>
						
						<campo id="siscod" oculto="true">
							<condicion operador="=">'02'</condicion>
						</campo>
						<clave>ctacod</clave>
						<descripcion>ctanom</descripcion>
					</ayuda_ex>
				</campo>
				<campo id="fecha">
					<label modpos="nobr">Fecha</label>
					<help>Fecha de Cotización</help>
					<valor>today</valor>
				</campo>				
				<campo id="ctanom" required="true">
					<label>Nombre</label>
					<size>50</size>
					<valor></valor>
				</campo>
				
				<campo id="ctatel">
					<label modpos="nobr">Teléfono</label>
					<size>50</size>
				</campo>
				<campo id="ctadir">
					<label>Dirección</label>
					<size>50</size>
				</campo>
				<campo id="ctanro">
					<label modpos="nobr">CUIT</label>
				</campo>
				<campo id="ctacon">
					<label>Contacto</label>
					<size>50</size>
				</campo>
				<campo id="ctamail">
					<label modpos="nobr">e-mail</label>
					<size>50</size>
					
				</campo>
				
				<!-- SELECCIONO LAS POSIBLES CARROCERIAS A FABRICAR -->
				<campo id="modcar">
					<label >Carroceria</label>
					<tabla_ex id="PRECIOMODELO" xml="preciomodelo_modelos.xml" vacio="true" _expand="true">
					</tabla_ex>
					<help>Modelo de Carroceria</help>
					<tipo>varchar</tipo>
					<actualiza>
						<campo destino="nrocar" id="grupo"/>
						<campo destino="nrocar" id="opciones"/>
						
					</actualiza>
				</campo>
				<!-- SELECCIONO EL MODELO DE CHASIS -->
				
				<campo id="grupo">
					<label modpos="nobr">Modelo</label>
					
					<tabla_ex id="GRUPOPRECIOS" xml="grupoprecios_select.xml" _expand="true"	vacio="true">
						<campo id="idGrupoPrecio">
							<condicion operador=""></condicion>
						</campo>
						<campo id="desabv">
							<expresion>concat(MARCHASIS.desabv,' ',	MODCHASIS.moddes)</expresion>
							<label colstyle="width:100px;">Chasis</label>
							<tipo>varchar</tipo>
						</campo>
						<campo id="marcod">
							<detalle>marcod</detalle>
						</campo>
						<campo id="modcha">
							<detalle>modcha</detalle>
						</campo>
						
						<campo id="nrocar">
						</campo>
						<campo id="idGrupo">
							<detalle>idGrupo</detalle>
						</campo>
					</tabla_ex>
				</campo>
				<campo id="marcod" deshabilitado="true" noshow="true">
					<label>marcod</label>
				</campo>
				<campo id="modcha" deshabilitado="true" noshow="true">
				 	<label modpos="nobr">modcha</label >
					
				</campo>
				<campo id="idGrupo" deshabilitado="true" noshow="true">
					<label modpos="nobr">gr</label>
					<actualiza>
						<campo destino="migrupo" id="opciones"/>
					</actualiza>
				</campo>
				
				<!-- SELECCIONO ASIENTOS -->
				<campo id="opciones">
					<label colspan="4">Opciones</label>
					
					<tabla_ex id="GRUPOPRECIOS" xml="preciomodelo_select.xml" 	vacio="true" _expand="true">
						<campo id="precio">
							<detalle>precio</detalle>
						</campo>
						<campo id="prePub">
							<expresion>ROUND(max(precio * (1 + margen)), 2)</expresion>
							
							<detalle>prePub</detalle>
						</campo>
						<campo id="NAS">
							<expresion>(asientos + acompaÃ±ante)</expresion>
						</campo>
						<campo id="ref" >
							<label>ref</label>
							<expresion>CONCAT(asientos + 1, ' Asientos, ', TIPOSERVICIO.servdes, (case when banbar then ' B/B ' else ' ---- ' end), (case when bastidor then ' Con Bastidor ' else ' Con Bastidor ' end), 'Largo:', largo, ' Bodega: ',bodega )</expresion>
						</campo>							
						
					</tabla_ex>
				</campo>
				<campo id="NAS" deshabilitado="true" noshow="true">
						
				</campo>
				<campo id="ref" deshabilitado="true">
					<label colspan="4">Descripcion</label>
					<size>100</size>
					<tipo>varchar</tipo>
				</campo>
				<campo id="precio" deshabilitado="true" noshow="true">
					<label _style="font-size:16px; color:green">concesionario</label>
<!--					<jseval campodestino="TOTAL">precio + TAdicion</jseval> -->
						<jseval campodestino="TOTAL">(tipoCli==1)?precio + TAdicion:prePub + TAdicion</jseval>										
						<jseval campodestino="precCar">(tipoCli==1)?precio:prePub</jseval>
					
					<tipo>decimal</tipo>
					<size>20</size>
				</campo>
				<campo id="prePub" deshabilitado="true" noshow="true">
					<label  _modpos="nobr" style="font-size:16px; color:red">Venta</label>
						<jseval campodestino="TOTAL">(tipoCli==1)?precio + TAdicion:prePub + TAdicion</jseval>										
						<jseval campodestino="precCar">(tipoCli==1)?precio:prePub</jseval>
					
					<tipo>decimal</tipo>
					<size>20</size>
				</campo>
				<campo id="tipoCli">
					<label>Tipo de Cliente</label>
					<opciones>
						<opcion valor="0">Venta</opcion>
						<opcion valor="1">Concesionario</opcion>
					</opciones>
					<valor>0</valor>
					<jseval campodestino="TOTAL">(tipoCli==1)?precio + TAdicion:prePub + TAdicion</jseval>
					<jseval campodestino="precCar">(tipoCli==1)?precio:prePub</jseval>
				</campo>
				<campo id="precCar" local="true" deshabilitado="true" noshow="true">
				</campo>
<!--				<campo id="adicionales" local="true" obj="cotizacion_adicionales.xml">
					<label colspan="4">Adicionales:</label>
				</campo>  -->
<!--				<campo id="opciones" local="true" obj="cotizopmovim.xml">
					<label colspan="4">Caracteristicas:</label>
				</campo>  -->				
				<campo id="TAdicion" local="true" deshabilitado="true" noshow="true">
					<label>Total Adicionales</label>
					<jseval campodestino="TOTAL">(tipoCli==1)?precio + TAdicion:prePub + TAdicion</jseval>
				</campo>
				<campo id="TOTAL" local="true" deshabilitado="true">
					<label style="color:red;font-size:20px;">Total</label>
				</campo>
			</tabla>
		</consulta>
	</abm>
