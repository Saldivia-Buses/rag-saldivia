<?xml version='1.0' encoding='UTF-8' ?>
<histrix tipo="cabecera" llenaTemporal="false">
    <title>COTIZACION</title>
    <obs></obs>
    <form>
        <tabla id="COTIZACION" label="COTIZACION">

            <field id="ficha_id"  deshabilitado="true" local="true" noshow="true">
            </field>

            <field id="nrofab_id"  deshabilitado="true" local="true" _valauto="true">
                    <label style="font-size:15px; color:green;font-weight:bold;">Nro Fab.</label>
            </field>


            <field id="idCotiz" _autoinc="true" deshabilitado="true" _noshow="true" local="true">
                    <label modpos="nobr" style="font-size:15px; color:green;font-weight:bold;">Nro Cotiz.</label>
                    <parametro id="cotizacion_numero.xml" retorna="idCotiz" ></parametro>
                    <tipo>varchar</tipo>

                <help>Número de Cotización</help>
                <detalle>idCotiz</detalle>
            </field>
            <field id="fecha"  deshabilitado="true" _local="true">
                    <label modpos="nobr" >Fecha</label>
            </field>
            <field id="aprobado"  deshabilitado="true" local="true" noshow="true">
        	<tipo>date</tipo>
        	<valor>today</valor>
            </field>
            
            
            <field id="ctacod"  deshabilitado="true" local="true">
                <label >Cliente </label>
                <help>Código de Cuenta </help>
                <detalle>ctacod</detalle>
                <tipo>integer</tipo>
            </field>

            <field id="ctanom" deshabilitado="true">
                <label  modpos="nobr" colspan="4">Nombre</label>
                <size>60</size>
               
            </field>

