<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="ing" imprime="false" procesa="false">
    <title>Accesorios por coche</title>
    <obs/>
    <form >
        <table id="ACCESORIOS_COCHE" label="Accesorios Estandar" style__Tbody="height:100px;overflow-x:hidden;">
	    <movimientos>
		<relacion id="cotiz_accesorios_coche_dup_ingmov.xml"></relacion>
	    </movimientos>
        
            <field id="id_accesorio" noshow="true" esClave="true" autoinc="true">
            </field>
            <field id="cotizacion_id" oculto="true" >
            </field>
            <field id="ficha_id" oculto="true" >
            </field>

            <field id="fecha">
                <label>fecha</label>
                <tipo>date</tipo>
                <valor>today</valor>
            </field>
            <field id="artcod" deshabilitado="true" >
                <valor default="true">0</valor>
            </field>
			 
            <field id="artdes" autocompletar="true" >
                <ayuda_ex id="STKINSUM" >

                    <field id="artcod" noshow="true">
                        <detalle>artcod</detalle>
                    </field>
                    <field id="artdes" >
                        <label>Descripcion</label>
                        <detalle>artdes</detalle>
                    </field>
                    <field id="Precio" class="informal" noshow="true" >
                        <label>Precio</label>
                        <expression having="false">concat( (select precio1 from LISTAPRECIOSDET as PREC where PREC.idArticulo = STKINSUM.artcod order by idLista DESC limit 1) )</expression>
                        <detalle>precio_adicional</detalle>
                    </field>
                    <field id="siscod" oculto="true" >
                        <condicion operador="=">'02'</condicion>
                    </field>
                    <clave>artcod</clave>
                    <descripcion>artdes2</descripcion>
                </ayuda_ex>
                <label>Accesorio</label>
                <size>70</size>
            </field>
            <field id="cantidad" >
                  <label>Cant</label>
                  <tipo>integer</tipo>
            </field>

                                 <field id="actualiz" local="true" refresh="true">
                                    <tipo>check</tipo>
                                    <label modpos="nobr" >Actualizar Precio</label>
                                 </field>
            
            <field id="precio_adicional" suma="true" >
                  <label>Precio </label>
            </field>
            <field id="precio_nuevo"  noshow="true">

                <expression having="false">(select precio1 from LISTAPRECIOSDET as PREC where PREC.idArticulo = STKINSUM.artcod order by idLista DESC limit 1)</expression>
		<tipo>decimal</tipo>
            </field>
            <field id="precio_final" suma="true" local="true" deshabilitado="true">
                  <label>Actualizado</label>
		    <if exp="precio_nuevo == 0 || actualiz == 0">
			<true>precio_adicional</true>
			<false>precio_nuevo</false>
		    </if>
		<tipo>decimal</tipo>
            </field>

            <field id="estado" >
                <options>
                    <option valor="0">A Confirmar</option>
                    <option valor="1">Confirmado</option>
                    <option valor="2">Rechazado</option>
                </options>
            </field>

			 
			 
        </table>
        <join tipo="left">
            <table id="STKINSUM">
                <field id="artcod">
                    <condicion operador="=">ACCESORIOS_COCHE.artcod</condicion>
                </field>
                <field id="siscod">
                    <condicion operador="=">'02'</condicion>
                </field>
	    	    
            </table>
        </join>
    </form>
</histrix>
