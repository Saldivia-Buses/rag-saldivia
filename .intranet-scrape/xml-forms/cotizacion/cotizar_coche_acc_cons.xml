<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" paginar="200" width="22">
    <title>CONSULTA DE FICHA DE VENTAS</title>
    <form  detalle="cotizar_coche_acc_ing.xml">
        <table id="PEDCOTIZ" label="Ficha de Ventas">
            <field id="id" noshow="true">
                <detalle>ficha_id</detalle>
                <detalle>id</detalle>
            </field>
            <field id="nrocha" linkint="fichaventas.xml" linkdes="Ver Ficha de Ventas" tipoOrden="DESC" >
                
                <label modpos="nobr" style="text-align:center;color:#444;font-size:14px;width:auto;">Nro.</label>
                <help>Numero de Fabricacion</help>
                <ayuda_ex id="CHASIS">
                    <field id="nrocha"/>
                    <field id="chades"/>
                </ayuda_ex>
                <paring destino="nrocha">nrocha</paring>
                <paring destino="showprecios">1</paring>
                
                <detalle>nrofab_id</detalle>
                <detalle>nrofab</detalle>
            </field>
            
            <field id="ctacod" noshow="true">
                <label >Cod</label>
                <help>Codigo de Cuenta</help>
                <detalle>ctacod</detalle>
            </field>
            <field id="ctanom" noshow="true">
                    <expresion>ctanom</expresion>
                <detalle>ctanom</detalle>

	    </field>            
            <field id="ctafan">
                    <expresion>ctafan</expresion>
                <label PDFsize="12" posx="6" posy="+1" size="23">Cliente</label>
            </field>
<!--            <field id="email" noshow="true">
            
                    <expresion>select mail from CCTCONTA where CCTCONTA.ctacod = CCTCUENT.ctacod and CCTCONTA.siscod = CCTCUENT.siscod and principal=1 limit 1</expresion>
                <detalle>ctamail</detalle>
            </field>
            -->
            
            <field id="nrocar">
                <label size="23" posx="110" posy="0" PDFsize="10">Carroceria</label>
                <help></help>
                <tabla_ex xml="carroceria.xml">
                    <field id="siscod" oculto="true">
                        <condicion operador="=">'03'</condicion>
                    </field>
                </tabla_ex>
            </field>
            <field id="terminacion" noshow="true">
        	<condicion operador="=">'0000-00-00'</condicion>
            </field>
            
            <field id="ninterno">
                <label  size="23" posx="160" posy="0" PDFsize="10"  colspan="2">Interno</label>
                <help></help>
            </field>
			
<!--            <field id="marcod" tabla="CHASIS">
                <label PDFsize="10" posx="6" posy="+2" size="23">Chasis Marca</label>
                <help/>
                <tabla_ex xml="marchasis.xml">
                    <field id="siscod" oculto="true">
                        <condicion operador="=">'03'</condicion>
                    </field>
                </tabla_ex>
                <tipo>integer</tipo>
            </field>
            -->
            <field id="moddes" tabla="MODCHASIS" >
                <label size="23" posx="60" posy="0" modpos="nobr" PDFsize="10">Modelo</label>
                <help></help>
                <tipo>varchar</tipo>
            </field>
            <order>
                <field id="nrocha" tabla="PEDCOTIZ"/>
            </order>
            <group>
                <field id="nrocha" tabla="PEDCOTIZ"/>
            </group>
            
            
        </table>
        <join tipo="left">
            <table id="CHASIS">
                <field id="nrocha">
                    <condicion operador="=">PEDCOTIZ.nrocha</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="CCTCUENT">
                <field id="ctacod">
                    <condicion operador="=">PEDCOTIZ.ctacod</condicion>
                </field>
                <field id="siscod">
                    <condicion operador="=">'02'</condicion>
                </field>

            </table>
        </join>
        <join tipo="left">
            <table id="MODCHASIS">
                <field clave="true" id="modcha">
                    <condicion operador="=">CHASIS.modcod</condicion>

                </field>
                <field id="marcod">
                    <condicion operador="=">CHASIS.marcod</condicion>
                </field>
            </table>
        </join>
    </form>
</histrix>
