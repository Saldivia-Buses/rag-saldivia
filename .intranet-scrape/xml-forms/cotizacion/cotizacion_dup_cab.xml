				<field id="razonAumento">

				<expression>
				(SELECT P.precio FROM PRECIOMODELO P WHERE P.nrocar = COTIZACION.modcar AND P.asientos = (HOMOLOGMOD.asientos) AND P.idGrupo = COTIZACION.idGrupo AND P.idLista = (SELECT MAX(idLista) FROM PRECIOMODELO) )	/	(SELECT P.precio FROM PRECIOMODELO P WHERE P.nrocar = COTIZACION.modcar AND P.asientos = (HOMOLOGMOD.asientos) AND P.idGrupo = COTIZACION.idGrupo AND P.idLista = '[__lista_old__]' )

				 </expression>
					<label>Razon aum</label>
				</field>
				
				<field id="old_precio" noshow="true">
					<expression>'[__precio__]'</expression>
				</field>

				<field id="old_prePub" noshow="true">
					<expression>'[__prePub__]'</expression>
				</field>

				<field id="showPrecioCon" >
					<label>Concesionario</label>
					<tipo>check</tipo>
				</field>

				<field id="precio" _sincelda="true" local="true">
					<label  modpos="nobr"></label>
<!--					<jseval campodestino="TOTAL">precio + TAdicion</jseval> -->
<!--					<jseval campodestino="TOTAL">(tipoCli==1)?precio + TAdicion:prePub + TAdicion</jseval>										
						<jseval campodestino="precCar">(tipoCli==1)?precio:prePub</jseval> -->
					<tipo>decimal</tipo>
					<size>20</size>
				</field>



				<field id="formaPago">
					<label modpos="nobr" colspan="5">Forma de Pago</label>
					<tipo>varchar</tipo>
					<size>40</size>
					<valor>A PROCESO</valor>
				</field>
				<field id="showPrecioPub" >
					<label>Venta</label>
					<tipo>check</tipo>
				</field>			



				<field id="prePub" _sincelda="true" local="true">
					<label  modpos="nobr" ></label>
<!--						<jseval campodestino="TOTAL">(tipoCli==1)?precio + TAdicion:prePub + TAdicion</jseval>										
						<jseval campodestino="precCar">(tipoCli==1)?precio:prePub</jseval>
	-->
					<tipo>decimal</tipo>
					<size>20</size>
				</field>


				<field id="plazo">
					<label modpos="nobr" colspan="5">Plazo de entrega</label>
					<tipo>varchar</tipo>
					<size>40</size>
					<valor>45 dias a partir de entrada a produccion</valor>
				</field>		

				<field id="actualizar" local="true">
					<label>Actualizar</label>
					<tipo>check</tipo>
					<jseval campodestino="precio">(actualizar == 1)?(precio * razonAumento):(old_precio)</jseval>
					<jseval campodestino="prePub">(actualizar == 1)?(prePub * razonAumento):(old_prePub)</jseval>
				 </field>

				 <field id="pie">
                                     <label colspan="4">Pie</label>
                                     <size>200</size>
                                     <tipo>varchar</tipo>
                                 </field>
