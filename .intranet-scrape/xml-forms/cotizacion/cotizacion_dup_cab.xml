							<expression>CONCAT(asientos + 1, ' Asientos, ', TIPOSERVICIO.servdes, (case when banbar then ' B/B ' else ' ____ ' end), (case when bastidor then ' Con Bastidor ' else ' Con Bastidor ' end), 'Largo:', largo, ' Bodega: ',bodega )</expression>
						</field>			
						<field id="idPrecio" noshow="true">
							<label>idPrecio</label>
							<detalle>idPrecio</detalle>
						</field>										
					</tabla_ex> 
				</field>
