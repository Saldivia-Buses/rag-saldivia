					<label colspan="6">Otros</label>
				</field> -->
				<field id="accesorios" local="true" obj="cotiz_accesorios_coche_dup_ing.xml">
                		    <label colspan="8">Otros</label>
                                    <paring destino="cotizacion_id">oldCotiz</paring>
                                </field>
                                                   				
				
