				</field>
				<field id="ctanro">
					<label modpos="nobr">CUIT</label>
				</field> -->
				<field id="ctacon" >
					<label colspan="2">Contacto</label>
					<size>40</size>
				</field>
				<field id="ctamail" _sincelda="true">
					<label modpos="nobr" colspan="6">e-mail</label>
					<size>40</size>
					
				</field>
				<field id="idGrupo" deshabilitado="true" noshow="true" >
					<label _modpos="nobr">idGrupo</label>
					<tipo>integer</tipo>
<!--					<actualiza>
						<field destino="migrupo" id="opciones"/>
					</actualiza> -->
				</field>				
				<!-- SELECCIONO LAS POSIBLES CARROCERIAS A FABRICAR -->
				<field id="asientos" _deshabilitado="true" >
					<label modpos="nobr">Asientos</label>
					<tipo>integer</tipo>
					<size>3</size>
				</field>				
				<field id="modcar" tabla="CARROCERIA" deshabilitado="true" local="true">
					<label>Carroceria</label><!--
					<tabla_ex id="CARROCERIA">
						<field id="nrocar"></field>
						<field id="desabv"></field>
					</tabla_ex>-->
					<tipo>varchar</tipo>
				</field>
					
						
				<!-- SELECCIONO EL MODELO DE CHASIS -->
				
				<field id="grupo" local="true">
					<label _colspan="2" modpos="nobr" style="color:red;">Seleccione Modelo</label>
					
					<tabla_ex id="GRUPOPRECIOS" xml="grupoprecios_select.xml" _expand="true"	vacio="true">
						<field id="idGrupoPrecio">
							<condicion operador=""></condicion>
						</field>
						<field id="desabv">
							<expression>concat(MARCHASIS.desabv,' ',	MODCHASIS.moddes)</expression>
							<label colstyle="width:100px;">Chasis</label>
							<tipo>varchar</tipo>
						</field>
						<field id="marcod">
							<detalle>marcod</detalle>
						</field>
						<field id="modcha">
							<detalle>modcha</detalle>
						</field>
						
						<field id="nrocar">
							<detalle>nrocar</detalle>							
							<condicion operador=""></condicion>
							
						</field>
						<field id="idGrupo">
							<detalle>idGrupo</detalle>
						</field>
					</tabla_ex>
					<tipo>integer</tipo>
					<!-- <tipo>radio</tipo> -->
				</field>

															
				<field id="marcod" deshabilitado="true" noshow="true">
					<label>marcod</label>
					<tipo>integer</tipo>
				</field>
				
				<field id="modcha" deshabilitado="true" noshow="true">
				 	<label modpos="nobr">modcha</label >
					<tipo>integer</tipo>
				</field>
				
				
				<!-- SELECCIONO ASIENTOS -->
