<?xml version="1.0" encoding="ISO-8859-1" ?>
	<histrix tipo="cabecera">
		<title>COTIZACION</title>
		<obs></obs>
		<form >
			<table id="COTIZACION" label="COTIZACION">
								
				<validation>
					<condition>('ctanom' == '0')</condition>
					<message>Debe Ingresar el Nombre.</message>
				</validation> 
				<validation >
					<condition>(modcar == 0)</condition>
					<message>Debe Seleccionar el Modelo</message>
				</validation>
				<field id="idLista" >
					<label>Lista</label>
					<tabla_ex id="PRECIOMODELO">
						<field id="id">
							<expression>max(idLista)</expression>
						</field>
						<field id="id2">
							<expression>max(idLista)</expression>
						</field>
					</tabla_ex>
				</field>
				<field id="lista_old" deshabilitado="true" local="true">
					<label modpos="nobr">Lista original</label>
				</field>
				<field id="NewCotiz" _autoinc="true" deshabilitado="true" _noshow="true" local="true">
					<label modpos="nobr" style="font-size:15px; color:green;font-weight:bold;">N.Cotiz. </label>
					<tipo>varchar</tipo>

					<help>Numero de Cotizacion</help>
					<detalle>idCotiz</detalle>	
				</field>  


				<field id="fecha" _deshabilitado="true">
					<label modpos="nobr" >Fecha</label>
					<help>Fecha de CotizaciÃ³n</help>
					<valor>today</valor>
				</field>					
				<field id="oldCotiz" noshow="true" local="true">
				</field>

				<!--<field id="lista" local="true" >
					<label>Lista Original</label>
