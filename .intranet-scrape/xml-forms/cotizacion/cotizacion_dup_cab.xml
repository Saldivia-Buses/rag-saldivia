				</field>
			-->
				<field id="ctacod" required="false" _autocompletar="true" _noshow="true" _deshabilitado="true" >
					<label _modpos="nobr">Cliente </label>
					<help>Codigo de Cuenta </help>
					
					<actualiza>                                                                                                  
						<field destino="ctacod" id="contactos"/>                                                                
					</actualiza>   				
					<detalle>ctacod</detalle>	
					<tipo>integer</tipo>
				</field>				
				<field id="ctanom" required="true" autocompletar="true" searchRecord="false">
					<label modpos="nobr"></label>
					<ayuda_ex id="CCTCUENT" condes="true" xml="HLPcctcuent_conta_cot.xml" dir="/help_local">
						<field id="ctacod" noshow="true">
							<detalle>ctacod</detalle>
						</field>
						
						<field id="ctanom2">
                                                  <expression having="false">concat(CCTCUENT.ctanom, ' - ', CCTCUENT.ctafan)</expression>
							<tipo>varchar</tipo>
						</field>
						<field id="siscod" oculto="true" >
							<condicion operador="=">'02'</condicion>
						</field>
						<field id="ctatel" class="informal">
							<detalle>ctatel</detalle>
						</field>
						
						<clave>ctanom</clave>
						<descripcion>ctanom</descripcion>
						<order>
							<field id="ctanom"></field>
						</order>
					</ayuda_ex>
	
					<size>40</size>
				</field>
				<field id="contactos" local="true">
					<label colspan="2">Contactos</label>
					<tabla_ex id="CCTCONTA" vacio="true">
						<field id="idconta"></field>
						<field id="nombre" >
							<expression>CCTCONTA.nombre</expression>
							<tipo>varchar</tipo>
						</field>
						
						<field id="ctamail" >
							<expression>CCTCONTA.mail</expression>
							<tipo>varchar</tipo>							
						</field>						
						<field id="ctatel" >
							<expression>CCTCONTA.Telefono</expression>
							<tipo>varchar</tipo>
						</field>				
						<field id="ctacon" >
							<expression>CCTCONTA.nombre</expression>
							<tipo>varchar</tipo>
						</field>								
						<field id="ctacod">
							<condicion operador="=">0</condicion>
						</field>
						<order>
							<field id="nombre"></field>
						</order>
					</tabla_ex>
				</field>
				<field id="ctatel">
					<label modpos="nobr" colspan="6">Teléfono</label>
					<size>40</size>
					<tipo>varchar</tipo>
				</field>
<!--				<field id="ctadir">
					<label>Dirección</label>
