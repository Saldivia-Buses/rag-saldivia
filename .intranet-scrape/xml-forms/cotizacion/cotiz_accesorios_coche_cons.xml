<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="abm-mini" path="fotos/accesorios">
    <title>Accesorios por coche</title>
    <obs/>
    <form >
        <table id="ACCESORIOS_COCHE" label="Accesorios Estandar" style__Tbody="height:100px;overflow-x:hidden;">
            <field id="id_accesorio" noshow="true" esClave="true" autoinc="true">
            </field>
            <field id="cotizacion_id" oculto="true" >
            </field>
            <field id="ficha_id" oculto="true" >
            </field>

            <field id="fecha" noshow="true">
                <label>fecha</label>
                <tipo>date</tipo>
                <valor>today</valor>
            </field>
            <field id="artcod" deshabilitado="true" >
        	<label>Cod.</label>
                <valor default="true">0</valor>
            </field>
			 
            <field id="artdes" autocompletar="true" >
                <ayuda_ex id="STKINSUM" >

                    <field id="artcod" noshow="true">
                        <detalle>artcod</detalle>
                    </field>
                    <field id="artdes" >
                        <label>Descripcion</label>
                        <detalle>artdes</detalle>
                    </field>
                    <field id="Precio" class="informal" noshow="true" >
                        <label>Precio</label>
                        <expression having="false">concat( (select precio1 from LISTAPRECIOSDET as PREC where PREC.idArticulo = STKINSUM.artcod order by idLista DESC limit 1) )</expression>
                        <detalle>precio_adicional</detalle>
                    </field>
                    <field id="siscod" oculto="true" >
                        <condicion operador="=">'02'</condicion>
                    </field>
                    <clave>artcod</clave>
                    <descripcion>artdes2</descripcion>
                </ayuda_ex>
                <label>Accesorios</label>
                <size>70</size>
            </field>
                  <field id="fotopath" local="true" noshow="true">
        <if exp="true">
          <true>'artcod/'</true>
          <false>''</false>
        </if>
        <tipo>varchar</tipo>
      </field>
      
    <!--  <field id="foto" path="fotopath" download="true">
        <expression>select ARTICULO_FOTO.foto from ARTICULO_FOTO where ARTICULO_FOTO.idArticulo = STKINSUM.artcod order by revision desc limit 1</expression>
        <label>Imagen</label>
        <tipo >file</tipo>
        <size>40</size>
      </field>    
-->
            <field id="cantidad" noZero="true" noEmpty="true">
                  <label>Cant</label>
                  <tipo>integer</tipo>
            </field>

            <field id="precio_adicional"  >
                  <label>P.Unit</label>
                  <tipo>numeric</tipo>
            </field>
            <field id="total" suma="true" >
        	<expression>case when cantidad != 0 then cantidad * precio_adicional else precio_adicional end</expression>
                  <label>Total (Iva no inc.)</label>
                  <tipo>numeric</tipo>
            </field>

<!--            <field id="estado" >
                <options>
                    <option valor="0">A Confirmar</option>
                    <option valor="1">Confirmado</option>
                    <option valor="2">Rechazado</option>
                </options>
            </field> -->

			 
			 
        </table>
        <join tipo="left">
            <table id="STKINSUM">
                <field id="artcod">
                    <condicion operador="=">ACCESORIOS_COCHE.artcod</condicion>
                </field>
                <field id="siscod">
                    <condicion operador="=">'02'</condicion>
                </field>
	    	    
            </table>
        </join>
    </form>
</histrix>
