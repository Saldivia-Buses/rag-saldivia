            </field>

            <field id="ctacod" required="false" _autocompletar="true" _noshow="true" _deshabilitado="true" valid="true">
                <label _modpos="nobr">Cliente</label>
                <help>Código de Cuenta </help>
                <actualiza>
                    <field destino="ctacod" id="contactos"/>
                </actualiza>
                 <ayuda_ex id="CCTCUENT" _condes="true" _xml="HLPcctcuent_conta.xml" dir="/help_local">
                      <field id="ctacod" >
                        <label>cuenta</label>
                   </field>

  
                    <field id="nombre">
                      <expression>ctanom</expression>
                        <tipo>varchar</tipo>
                      <detalle>ctanom</detalle>
                    </field>
                  
                    <field id="siscod" oculto="true" >
                        <condicion operador="=">'02'</condicion>
                    </field>
                    <field id="baja" oculto="true" >
                        <condicion operador="=">0</condicion>
                    </field>                   
                    <field id="ctatel" class="informal">
                        <detalle>ctatel</detalle>
                    </field>

                    <clave>ctacod</clave>
                    <descripcion>ctanom</descripcion>
                    <order>
                        <field id="ctanom"></field>
                    </order>
                </ayuda_ex>              
                <detalle>ctacod</detalle>
            </field>

            <field id="ctanom" _deshabilitado="true">
                <label modpos="nobr">Nombre</label>
            </field>

            <field id="fecha" _deshabilitado="true">
                <label _modpos="nobr">Fecha</label>
                <help>Fecha de Cotizaci</help>
            </field>
