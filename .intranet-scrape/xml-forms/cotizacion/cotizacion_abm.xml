<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="ficha" preFetch="true" borra="false" inserta="false">
    <title>COTIZACION</title>
    <obs></obs>
    <form  >
        <table id="COTIZACION" label="COTIZACIONES">
            <validation>
                <condition>('ctanom' == '0')</condition>
                <message>Debe Ingresar el Nombre.</message>
            </validation>
            <validation >
                <condition>(homologacion_id == 0)</condition>
