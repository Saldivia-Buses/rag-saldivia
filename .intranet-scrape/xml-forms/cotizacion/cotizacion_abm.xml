                <label _modpos="nobr">idGrupo</label>

            </field>

          <field id="homologacion_id" required="true">
            <label colstyle="display:none;" colspan="3">Homologación</label>
            <helper type="combo" xml="combo_homologacion_modelo.xml" dir="/fabricacion" empty="true">
              <field id="nrocar" oculto="true" />
            </helper>
          </field>
	    <field id="moneda_id">
		<label>Moneda</label>
                <helper id="GEN_MONEDAS" type="combo">
                    <field id="id_moneda"></field>
                    <field id="descripcion_moneda"></field>
                </helper>		
	    </field>
            <field id="showPrecioCon" >
                <label>Concesionario</label>
                <tipo>check</tipo>
            </field>
            <field id="precioCon" _sincelda="true">
                <label  modpos="nobr" ></label>
                <tipo>decimal</tipo>
                <size>20</size>
