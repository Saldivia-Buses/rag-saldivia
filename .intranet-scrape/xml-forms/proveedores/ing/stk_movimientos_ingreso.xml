<?xml version="1.0" encoding="UTF-8" ?>
   <histrix tipo="insert">
       <title>MOVIMIENTOS DE STOCK</title>
               <form>
			<table id="STK_MOVIMIENTOS" label="MOVIMIENTOS" idCampoCond="acepta">
				<field id="stkarticulo_id"	id_temp="stkarticulo_id" />
				<field id="stkconcepto_id"	id_temp="stkconcepto_id"/>
				<field id="alta_movimiento">
				    <valor>date(now())</valor>
				    <tipo>integer</tipo>
				</field>
				<field id="fecha_movimiento">
					<valor>(SELECT fecha_movimiento FROM REG_MOVIMIENTOS WHERE id_regmovim = [__regmovimiento_ins.xml__] LIMIT 1)</valor>
					<tipo>integer</tipo>
				</field>
				<field id="stkdeposito_id"	id_temp="stkdeposito_id" />
				<field id="cantidad" 		id_temp="cantidad" />
				<field id="unidad_id"		id_temp="stkunidad_compra_id" />
				<field id="referencia"		id_padre="nombre_cuenta" />
				<field id="precio_costo"	id_temp="precio_costo" />
				<field id="precio_venta"	id_temp="precio_unitario" /> 
				<field id="precio_total"	id_temp="total" />
				<field id="regmovimiento_id" lastId="regmovimiento_ins.xml" />
			</table>
               </form>
        </histrix>