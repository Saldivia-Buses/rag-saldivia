        <field id="nombre_movimiento" />
      </fieldGroup>-->
        
        <field id="mod" local="true" noshow="true" />
        <field id="grabar" local="true" noshow="true">
            <if exp="mod + 0 != 0">
                <true>'true'</true>
        	<false>'false'</false>
	    </if>
        </field>
        
        <field id="hi" local="true" clasefila="true" noshow="true">
    	    <if exp="grabar">
    		<true>'resaltadoVioleta'</true>
    		<false>''</false>
    	    </if>
    	</field>
        
	<filters auto="true">
	    <field id="regcuenta_id">
		<label>Cuenta</label>
		<operador>=</operador>
		<size>5</size>
	    </field>
	    <field id="nro_movimiento">
		<label>Nro. Comprobante</label>
		<operador>=</operador>
	    </field>
	</filters>
    </table>
    
    <join>
      <tabla id="REG_CONCEPTOS">
        <field id="id_concepto">
          <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
        </field>
        <field id="subsistema_id">
          <condicion operador="=">REG_MOVIMIENTOS.subsistema_id</condicion>
        </field>
      </tabla>
    </join>
    <join>
      <tabla id="REG_CUENTA">
        <field id="id_regcuenta">
          <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
        </field>
      </tabla>
    </join>
    <join>
      <tabla id="GEN_SUBSISTEMAS">
        <field id="id_subsistema">
          <condicion operador="=">REG_MOVIMIENTOS.subsistema_id</condicion>
        </field>
      </tabla>
    </join>

  </form>
</histrix>
