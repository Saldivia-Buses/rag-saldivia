<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="ficha" imprime="false" conBusqueda="true" accordion="false">
    <title>Ficha de Proveedores</title>
    <obs></obs>
    <form>

        <table id="REG_CUENTA" label="Ficha de Proveedores">

            <field id="id_regcuenta" noshow="true" esClave="true" autoinc="true">
              <valor>0</valor>   <!-- ESTE VALOR CERO HACE QUE LAS GRILLAS INTERIORES NO CARGEN DATOS INUTILMENTE -->
            </field>

            <field id="subsistema_id" oculto="true" esClave="true" valauto="true" />

            <field id="subsistemarelacionada_id" local="true" oculto="true" valauto="true" />

            <field id="nro_cuenta" esClave="true">
              <label colspan="8">Número</label>
              <help>Numero de la Cuenta</help>
            </field>
            
            <field id="prox_nro" local="true" deshabilitado="true" sincelda="true" valauto="true" colstyle="display: none;">
                <label modpos="nobr" style="color:red;">  Proximo Nº</label>
                <helper type="combo" id="REG_CUENTA" >
                    <field id="nro_cuenta1">
                        <expresion>max(nro_cuenta) + 1</expresion>
                    </field>          
                    <field id="nro_cuenta2">
                        <expresion>max(nro_cuenta) + 1</expresion>
            	    </field>        
                    <field id="subsistema_id"/>
        	</helper>
            </field>

            <field id="nombre_cuenta">
                <label colspan="8">Nombre</label>
                <help>Nombre de la cuenta</help>
                <size>80</size>
            </field>

            <field id="provincia_id">
                <label colspan="9">Provincia</label>
                <tabla_ex xml="provincia_qry.xml" dir="/ayudas" vacio="true" />
                <actualiza>
                    <field id="localidad_id" destino="provincia_id" />
                </actualiza>
            </field>


            <field id="codigo_postal">
                <label >Codigo Postal</label>
                <tipo>varchar</tipo>
            </field>

            <field id="localidad_id">
                <label colspan="9">Localidad</label>
                <helper type="combo" xml="localidad_qry.xml" dir="/ayudas" empty="true" > 
                    <field id="provincia_id">
                        <condicion operador="=">-1</condicion>
                    </field>
                </helper>
            </field>
		    
	    <!-- Dirección -->	  
		    
            <field id="cod_direccion">
                <label>Calle</label>
                <size>40</size>
            </field>

            <field id="bis_direccion" sincelda="true">
                <label modpos="nobr">Bis</label>
                <tipo>check</tipo>
            </field>

            <field id="nro_direccion">
                <label modpos="nobr">Nº</label>
                <size>10</size>
            </field>

            <field id="abreviacion_direccion">
                <label modpos="nobr">Piso/Dpto</label>
                <size>15</size>
            </field>
                        
            <field id="email_cuenta">
                <label colspan="5">email</label>
                <help>email de la cuenta</help>
                <size>60</size>
            </field>

	    <!-- Fechas -->

            <field id="alta_cuenta">
                <label>Fecha de Alta</label>
                <help>Fecha de alta de la cuenta</help>
                <tipo>date</tipo>
            </field>

            <field id="baja_cuenta">
                <label modpos="nobr">Fecha de Baja</label>
                <help>Fecha de Baja de la cuenta</help>
                <tipo>date</tipo>
            </field>

	    <!-- Fiscales -->

            <field id="iva_id">
                <tabla_ex xml="iva_qry.xml" dir="/ayudas" vacio="true" />
                <label>Cat. IVA</label>
                <help>Categoria de IVA</help>
            </field>

            <field id="cuit_cuenta">
                <label modpos="nobr">Nº CUIT</label>
                <help>Número de CUIT</help>
                <jsfunction event="onchange"><![CDATA[ var RE=/^(20|23|27|30|33)-[0-9]{8}-[0-9]$/; if(!RE.test(this.value)) alert('CUIT ERRONEO: Formato XX-XXXXXXXX-X'); ]]></jsfunction>
                <size>15</size>
            </field>

            <field id="nro_ingbrutos">
                <label modpos="nobr">Nº IBR</label>
                <help>Numero de ingresos brutos de la cuenta</help>
            </field>

            <field id="percepcion">
                <label>Agente Percepcion</label>
                <options exp="true">
                    <option valor=""></option>
                    <option valor="0">NO</option>
                    <option valor="1">SI</option>
                </options>
            </field>

            <field id="regforma_id">
                <label>Forma Pago</label>
                <tabla_ex id="REG_FORMAS" vacio="true">
                    <field id="id_regforma" />
                    <field id="nombre_forma" />
                    <field id="subsistema_id" />
                </tabla_ex>
            </field>

            <field id="limite_credito">
                <label modpos="nobr">Limite de Crédito</label>
                <tipo>numeric</tipo>
                <help>Límite de Crédito que el proveedor otorga para la compra</help>
                <size>20</size>
            </field>

            <field id="categoria_ganancia">
                <tabla_ex id="REG_CATEGORIAS" vacio="true">
                    <field id="id_regcategoria" />
                    <field id="nombre_categoria" />
                    <field id="subsistema_id" />
                </tabla_ex>
                <label>Categoria</label>
            </field>
			
			<field id="afipcategoria_id" local="true" >
			    <helper type="external" xml="actividades_afip_qry.xml" dir="/ayudas"/>
			    <label>Cod. Actividad</label>
				<help>Código de actividad principal según AFIP</help>
		    </field>

            <field id="regzona_id">
                <tabla_ex id="REG_ZONAS" vacio="true">
                    <field id="id_regzona" />
                    <field id="nombre_zona" />
                    <field id="subsistema_id" />
                </tabla_ex>
                <label >Zona</label>
            </field>
            

      <fieldGroup>
            <field id="contacto" obj="cuenta_contactos_crud.xml" local="true">
                <paring destino="regcuenta_id">id_regcuenta</paring>
            </field>
      </fieldGroup>

      <fieldGroup>
        <if> if (strpos($_SESSION['properties']['modulos'],'transportistas') != false) return true; </if>
        <field id="subsistematransporte_id" valauto="true" local="true" noshow="true">
          <detalle>subsistematransporte_id</detalle>
        </field>
        <field id="transportes" obj="cuenta_relaciontr_crud.xml" local="true">
          <paring destino="regcuenta_id">id_regcuenta</paring>
          <paring destino="subsistematransporte_id">subsistematransporte_id</paring>
          <paring destino="subsistemarelacionada_id">subsistematransporte_id</paring>
        </field>
      </fieldGroup>
      <fieldGroup>
	        <if> if (strpos($_SESSION['properties']['modulos'],'contabilidad') != false) return true; </if>  
            <field id="contable" obj="cuenta_imputaciones_crud.xml" local="true">
                <paring destino="regcuenta_id">id_regcuenta</paring>
            </field>
      </fieldGroup>
      

            <group>
                <field id="nombre_cuenta" />
            </group>
	           
        </table>
        <join tipo="left">
            <table id="GEN_LOCALIDADES">
                <field id="id_localidad">
                    <condicion operador="=">REG_CUENTA.localidad_id</condicion>
                </field>
            </table>
        </join>

    </form>
</histrix>
