<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="crud"  _imprime="false" _conBusqueda="true">
    <title>Transportistas</title>
    <obs></obs>
    <form>
        <table id="REG_CUENTA" label="Transportistas">

        <filters>
            <field id="nombre_cuenta">
                <label colspan="8">Nombre</label>
                <operador>like</operador>
            </field>
        </filters>

        <fieldGroup colstyle="text-align:center; vertical-align:middle; padding: 2px 2px 2px 2px;">

            <field id="id_regcuenta" autoinc="true" esClave="true" noshow="true" />

            <field id="subsistema_id" noshow="true" esClave="true" valauto="true" />

            <field id="nro_cuenta" >
               <label>nro cuenta</label>
            </field>
        
            <field id="nombre_cuenta">
                <label colspan="8">Nombre</label>
                <help>Nombre de la cuenta</help>
                <size>80</size>
            </field>

            <field id="provincia_id" >
                <label colspan="9">Provincia</label>
                <tabla_ex xml="provincia_qry.xml" dir="/ayudas" empty="true" />
                <actualiza>
                    <field id="localidad_id" destino="provincia_id" />
                </actualiza>
            </field>

            <field id="localidad_id" colstyle="display:none;">
                <label colspan="9">Localidad</label>
                <helper type="combo" xml="localidad_qry.xml" dir="/ayudas" empty="true" > 
                    <field id="provincia_id" oculto="true">
                        <condicion operador="=">-1</condicion>
                    </field>
                </helper>
            </field>

            <field id="nombre_localidad" tabla="GEN_LOCALIDADES" Formstyle="display:none;">
                <label>Localidad</label>
            </field>

        <!-- Dirección -->    
            
            <field id="cod_direccion">
                <label>Calle</label>
                <size>40</size>
            </field>

            <field id="bis_direccion" sincelda="true">
                <label modpos="nobr">Bis</label>
                <tipo>check</tipo>
            </field>

            <field id="nro_direccion">
                <label modpos="nobr">Nº</label>
                <size>10</size>
            </field>

            <field id="abreviacion_direccion">
                <label modpos="nobr">Piso/Dpto</label>
                <size>15</size>
            </field>

        <!-- Fechas -->

            <field id="alta_cuenta" valauto="true">
                <label >Fecha de Alta</label>
                <help>Fecha de alta de la cuenta</help>
                <tipo>date</tipo>
                 <valor>today</valor>
            </field>

            <field id="baja_cuenta">
                <label modpos="nobr">Fecha de Baja</label>
                <help>Fecha de Baja de la cuenta</help>
                <tipo>date</tipo>
            </field>

            <field id="ref_cuenta">
                <label >Referencia</label>
                <help>Referencia</help>
            </field>

        <!-- Fiscales -->

