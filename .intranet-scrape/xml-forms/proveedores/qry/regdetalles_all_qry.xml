<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" _paginar="500">
  <title>Movimientos</title>
  <obs/>
  <form detalle="programa_detalle" inline="true" >
  
    <table id="REG_MOVIMIENTOS" label="Resumen Cta Cte">
       
        <preconsultas>
           <xmlfile id="regdetalles_pre2.xml"/>
        </preconsultas>

        <filters>

            <field id="fecha_movimiento" table="REG_MOVIMIENTOS" noshow="true" copia="desde">
                <help>Fecha movimiento</help>
                <label>Desde</label>
                <operador>&gt;=</operador>
                <preparam campo="fecha_movimiento" operador="&lt;=">true</preparam>
                <valor eval="true">date("d/m/Y",strtotime("-1 year"))</valor>
            </field>

              <field id="separador" local="true" deshabilitado="true" noshow="true" modpos="nobr" />

            <field id="fecha_movimiento" table="REG_MOVIMIENTOS" noshow="true"  modpos="nobr">
                <help>Fecha movimiento</help>
                <label>Hasta</label>
                <operador>&lt;=</operador>
            </field>

              <field id="separador" local="true" deshabilitado="true" noshow="true" modpos="nobr" />
            
            <field id="desplegar" local="true"  modpos="nobr">
              <tipo>button</tipo>
              <valor>'Desplegar todos'</valor>
            </field>

             <field id="separador" local="true" deshabilitado="true" noshow="true" modpos="nobr" />

            <!-- <field id="desde" deshabilitado="true" modpos="nobr">
                <valor eval="true">date("d/m/Y",strtotime("-1 year"))</valor>
            </field>
         -->
        </filters>


        <fieldGroup colstyle="text-align:center;padding:2px 2px 2px 2px; vertical-align:middle;">

            <field id="separador" local="true" deshabilitado="true" noshow="true">
              <size>1</size>
            </field>
          
            <field id="subsistema_id" valauto="true" noshow="true">
                <preparam operador="=">true</preparam>
                <tipo>varchar</tipo>
            </field>

            <field id="programa_detalle" noshow="true">
                <expresion>IF( REG_CONCEPTOS.imputacion_concepto = 1, 'regimputaciones_qry.xml', 'regdet_fact_qry.xml')</expresion>
            </field>

            <field id="desplegar" local="true" noshow="true">
                <tipo>button</tipo>
                <valor>'desplegar'</valor>
                <jsfunction event="onclick">$('.detailCell', '#regdetalles_all_qry_xml').click();</jsfunction>
            </field>

            <field id="tipo" valauto="true" local="true"  oculto="true" />

            <field id="regcuenta_id"  valauto="true" oculto="true">
                <preparam operador="=">true</preparam>
            </field>

            <field id="id_regmovim" noshow="true">
                <detalle>regmovim_id</detalle>
            </field>

            <field id="nombre" _local="true" print="false" noshow="true">
                <expresion>REG_CUENTA.nombre_cuenta</expresion>
                <setvar>titulo_div</setvar>
            </field>

            <field id="cajmovimiento_id" tdWidth="200" noshow="true" /> 

            <field id="xml_llamar"  local="true" noshow="true">
              <if exp="cajmovimiento_id==0">
                <true>'regmovimiento_ficha.xml'</true>
                <false>'cajmovimiento_ficha.xml'</false>
              </if>
            </field>
        </fieldGroup>
  
        <fieldGroup>
            <if>if( $_SESSION['admin'] == true) return true;</if>
            <field id="eliminacion" tdWidth="20" linkdir="/caja/proc/del/"  >
              <attribute id="linkint">xml_llamar</attribute>
                  <expresion>'An.'</expresion>
                <paring destino="id_regmovimheader" >id_regmovim</paring>
            </field>
        </fieldGroup>
    
     <fieldGroup colstyle="text-align:center;padding:2px 2px 2px 2px; vertical-align:middle;">

        <field id="fecha_movimiento" table="REG_MOVIMIENTOS" noshow="true">
            <help>Fecha movimiento</help>
        </field>

        <field id="desde" local="true" noshow="true" required="true">
            <preparam campo="fecha_movimiento" operador="&lt;">true</preparam>
            <valor eval="true">date("d/m/Y",strtotime("-1 year"))</valor>
            <tipo>date</tipo>
        </field>

        <field id="Fecha" >
            <label>Fecha</label>
            <expresion>fecha_movimiento</expresion>
            <tipo>date</tipo>
        </field>

        <field id="vencimiento_movimiento" table="REG_MOVIMIENTOS" >
            <label>Vto</label>
        </field>

        <field id="abreviacion_concepto" tabla="REG_CONCEPTOS">
          <label>Comp</label>
        </field>

        <field id="imprime_concepto1" noshow="true">
          <expresion>
            CASE WHEN IFNULL(REG_NUMERADORES.ejecuta,'') = '' THEN trim(CAJ_CONCEPTOS.imprime_concepto) ELSE trim(REG_NUMERADORES.ejecuta) END
          </expresion>
        </field>

        <field id="nro_movimiento"  linkdes="Detalle del Comprobante" linkmodal="true">
          <label>Numero</label>
          <expresion>
            CONCAT(REG_MOVIMIENTOS.letra_movimiento,' ',LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,'0'),'-',LPAD(REG_MOVIMIENTOS.nro_movimiento  ,8,'0'))
          </expresion>
          <helper type="link" dir="/caja/qry" >
              <parameter source="id_cajmovimiento" target="id_cajmovimiento" />
              <parameter source="id_regmovim" target="id_regmovim" />
          </helper>
          <attribute id="linkint">imprime_concepto1</attribute>
       </field>

        <field id="importe_movimiento" noshow="true">
            <label>Importe</label>
            <tipo>numeric</tipo>
        </field>

        <field id="imputacion_concepto" tabla="REG_CONCEPTOS" noshow="true" />

        <field id="debe"  suma="true" noZero="true">
            <label>debe</label>
          <expresion>case when REG_CONCEPTOS.imputacion_concepto = 0 then REG_MOVIMIENTOS.importe_movimiento else 0  end</expresion>
          <tipo>numeric</tipo>
        </field>

        <field id="haber"  suma="true" noZero="true">
            <label>haber</label>
          <expresion>case when REG_CONCEPTOS.imputacion_concepto = 1 then REG_MOVIMIENTOS.importe_movimiento else 0 end</expresion>
          <tipo>numeric</tipo>
        </field>
        
        <field id="imputaciones" noshow="true">
          <expresion>sum(case when isnull(REG_IMPUTACIONES.subsistema0_id) then 0 else  REG_IMPUTACIONES.movimiento_imputacion end)</expresion>
          <tipo>numeric</tipo>
        </field>

      <!-- SI tiene  -->

        <field id="has2imp" noshow="true">
          <expresion>CASE WHEN sum(case when REG_IMPUTACIONES.subsistema0_id = REG_MOVIMIENTOS.subsistema_id then 0 else 1 end ) != 0 THEN false ELSE true END</expresion>
          <label>detalle</label>
        </field>
        
        <field id="color" local="true" clasefila="true" noshow="true">
          <label>color</label>
          <if exp="saldo_movimiento != 0">
            <true>'resaltado'</true>
            <false>(debe + has2imp == 0 ) ? 'resaltadoVioleta' : ''</false>
          </if>
        </field>
        
        <field id="muestro_saldo" local="true" noshow="true" valauto="true">
            <helper type="parameter" id="SIS::02::muestro_saldo" >
                <label>Cuenta Corriente: Oculta columna Saldo</label>
                <defaultValue>false</defaultValue>
            </helper>
        </field>          
        
        <field id="saldo_movimiento" suma="true" noZero="true">
          <expresion>REG_MOVIMIENTOS.saldo_movimiento * (case when REG_CONCEPTOS.imputacion_concepto = 0 then 1 else -1 end)</expresion> 
          <attribute id="noshow">muestro_saldo</attribute>   
          <label>Saldo</label> 
          <tipo>numeric</tipo>
      </field>
      
      <field id="acumulado" suma="true" acumula="true"  local="true">
        <attribute id="colstyle">visiblep</attribute>   
        <label>Acumulado</label> 
        <if exp="true">
          <true>debe - haber</true>
          <false>0</false>
        </if>
        <tipo>numeric</tipo>
      </field>
                          
      <field id="tabreg" local="true" noshow="true">
           <valor>REG_MOVIMIENTOS</valor>
      </field>
                      
      <field id="observaciones" >
           <tipo>varchar</tipo>
         <helper type="link" xml="regmovim_obs_qry.xml" dir="/clientes/qry">
             <parameter source="id_regmovim" target="regmovim_id" />
              <parameter source="tabreg" target="tabla_origen" />
           </helper>
           <expresion>ifnull((select 'Ver Obs' from REG_MOVIMIENTO_OBS RO where RO.regmovim_id = id_regmovim  limit 1),'>>')</expresion>
           <label>Observaciones</label>
      </field>  
    
    </fieldGroup>

    <order>
      <field id="fecha_movimiento" tabla="REG_MOVIMIENTOS" />
      <field id="imputacion_concepto"/>
      <field id="nro_movimiento"/>
    </order>

  <group>
    <field id="id_regmovim" tabla="REG_MOVIMIENTOS"/>
  </group>

    </table>
    
    <join>
      <table id="REG_CONCEPTOS">
        <field id="id_concepto">
          <condicion operador="=">concepto_id and informa_calculo = 0</condicion>
        </field>
      </table>
    </join>
   <join tipo="left">
      <table id="CAJ_CONCEPTOS">
        <field id="regconcepto_id">
          <condicion operador="=">REG_CONCEPTOS.id_concepto</condicion>
        </field>
      </table>
    </join>
    <join tipo="left">
      <table id="REG_CUENTA">
        <field id="id_regcuenta">
          <condicion operador="=">regcuenta_id</condicion>
        </field>
      </table>
    </join>
    <join tipo="left">
      <table id="REG_IMPUTACIONES">
        <field id="regmovim_id">
          <condicion operador="=">REG_MOVIMIENTOS.id_regmovim</condicion> 
        </field>
        <field id="subsistema0_id">
          <condicion operador="=">REG_MOVIMIENTOS.subsistema_id</condicion> 
        </field>
      </table>
    </join>

    <join tipo="left">
      <table id="REG_NUMERADORES">
        <field id="subsistema_id">
          <condicion operador="=">REG_MOVIMIENTOS.subsistema_id</condicion>
        </field>
        <field id="regconcepto_id">
          <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
        </field>
        <field id="puesto">
          <condicion operador="=">REG_MOVIMIENTOS.puesto_movimiento</condicion>
        </field>
        <field id="letra">
          <condicion operador="=">REG_MOVIMIENTOS.letra_movimiento</condicion>
        </field>
      </table>
    </join>
    
  </form>
</histrix>
