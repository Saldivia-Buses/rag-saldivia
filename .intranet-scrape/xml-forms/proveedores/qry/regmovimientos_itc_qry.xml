<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" showcantidad="true">
  <title>Movimientos ITC</title>
  <obs/>
  <form >
    <table id="REG_MOVIMIENTOS" label="Movimientos ITC">

      <filters>
	<field id="etiqueta1" local="true" deshabilitado="true">
	  <label colspan="4"></label>
	  <valor>Por Fecha de Registracion</valor>
	  <size>50</size>
	</field>
	<field id="reg_fecha" print="false">
          <label>Desde</label>
          <operador>&gt;=</operador>
	  <valor eval="true">date("d/m/Y", mktime(0, 0, 0, date("m"), 1, date("Y")))</valor>
        </field>
	<field id="reg_fecha" print="false">
          <label modpos="nobr">Hasta</label>
          <operador>&lt;=</operador>
	  <valor>today</valor>
        </field>
	<field id="etiqueta2" local="true" deshabilitado="true" grupo="avanzado">
	  <label colspan="4"></label>
	  <valor>Por Fecha de Facturacion</valor>
	  <size>50</size>
	</field>
	<field id="fecha_movimiento" print="false" grupo="avanzado">
          <label>Desde</label>
          <operador>&gt;=</operador>
        </field>
	<field id="fecha_movimiento" print="false" grupo="avanzado">
          <label modpos="nobr">Hasta</label>
          <operador>&lt;=</operador>
        </field>
        <field id="regcuenta_id" print="false">
          <label colspan="4">Proveedor</label>
          <operador>=</operador>
        </field>
	<field id="filtro_itc" deshabilitado="false">
	  <label>ITC</label>
	  <operador>=</operador>
	</field>
      </filters>
	
      <field id="id_regmovim" noshow="true" />

      <field id="regcuenta_id" noshow="true">
	<helper type="combo" id="REG_CUENTA" empty="true">
		<field id="id_regcuenta" />
		<field id="nombre_cuenta" />
		<field id="subsistema_id" oculto="true">
			<condicion operador="=">'01'</condicion>
		</field>
	</helper>
      </field>

      <field id="etiqueta1" local="true" noshow="true">
	<size>50</size>
      </field>	

      <field id="etiqueta2" local="true" noshow="true">
	<size>50</size>
      </field>	

      <field id="fecha_movimiento">
        <label>Fec. Fac.</label>
        <tipo>date</tipo>
      </field>

      <field id="reg_fecha">
        <label>Fec. Reg.</label>
        <tipo>date</tipo>
      </field>

      <field id="subsistema_id" noshow="true">
	<condicion operador="=">'01'</condicion>
      </field>

      <field id="nombre_cuenta" tabla="REG_CUENTA">
        <label>Proveedor</label>
      </field>

      <field id="descripcion_concepto" tabla="REG_CONCEPTOS">
        <label>Comprobante</label>
      </field>

      <field id="nro_movimiento">
        <label>Nro. Comp.</label>
        <expresion>CONCAT(REG_MOVIMIENTOS.letra_movimiento,' ',LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,'0'),'-',LPAD(REG_MOVIMIENTOS.nro_movimiento  ,8,'0'))</expresion>
      </field>
	
      <field id="importe_nogravado" suma="true">
        <label>Imp. ITC</label>
	<expression>case when REG_CONCEPTOS.imputacion_concepto = 1 then importe_nogravado else (importe_nogravado * -1) end</expression>
	<!--<condicion operador="!=">0</condicion>-->
      </field>
	
      <field id="cantidad_bultos" suma="true">
	<expression>case when REG_CONCEPTOS.imputacion_concepto = 1 then cantidad_bultos else (cantidad_bultos * -1) end</expression>
	<label>Litros</label>
        <tipo>decimal</tipo>
	<condicion operador="!=">0</condicion>
        <size>7</size>
      </field>

      <field id="filtro_itc" noshow="true">
	<expression>case when importe_nogravado = 0 then '0' else '1' end</expression>
	<options>
	  <option valor=""></option>
	  <option valor="0">SIN ITC</option>
	  <option valor="1">CON ITC</option>
	</options>
      </field>

      <field id="pun_movimiento" suma="true">
        <label>Precio x Litro</label>
        <tipo>decimal</tipo>
        <size>7</size>
      </field>

      <field id="importe_movimiento" suma="true">
        <label>Imp. Comp.</label>
	<expression>case when REG_CONCEPTOS.imputacion_concepto = 1 then importe_movimiento else (importe_movimiento * -1) end</expression>
      </field>

      <field id="saldo_movimiento" suma="true" noshow="true">
        <label>Saldo</label>
        <tipo>numeric</tipo>
      </field>

      <order>
        <field id="nombre_cuenta" tabla="REG_CUENTA" />
        <field id="fecha_movimiento" />
      </order>

      <group>
        <field id="id_regmovim" />
      </group>

    </table>

    <join>
      <table id="REG_CUENTA">
        <field id="id_regcuenta">
          <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
        </field>
      </table>
    </join>

    <join tipo="left">
      <table id="REG_CONCEPTOS">
        <field id="id_concepto">
          <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
        </field>
        <field id="informa_calculo">
          <condicion operador="=">0</condicion>
        </field>
      </table>
    </join>

  </form>
</histrix>
