					<help></help>
				   </field> 
				   
				<field id="id_regdetalle" noshow="true">
					<label>Codigo de detalle </label>
					<help>codigo del detalle</help>
				</field>
				<field id="codigo_detalle" noshow="true">
				</field>
			        
				<field id="orden" esClave="true" noshow="true">
