<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" paginar="100" preloadData="false">
  <title>Consulta de movimientos</title>
  <obs/>
  <form  detalle="regdetalles_qry.xml" idCampoCond="omitir">

    <table id="REG_CUENTA" label="Cta Cte Proveedores">
      
      <filters>

        <field id="fecha_movimiento_desde">
    	    <label> Desde</label>
	        <operador>&gt;=</operador>
        </field>
  
        <field id="fecha_movimiento_hasta">
    	    <label> Hasta</label>
	        <operador>&lt;=</operador>
	        <valor>today</valor>
        </field>

		    <field id="nro_cuenta">
		       <label> Cuenta</label>
			     <operador>=</operador>
        </field>
    
        <field id="omitir">
          <label>Omitir Sin Pendiente</label>
          <valor>0</valor>
		    </field>	
		
    		<field id="arrastrasaldo">
    		  <label>Con arrastre</label>
    		  <valor>1</valor>
    		</field> 

        <field id="solo_diferencia">
          <label>Solo Diferencias</label>
          <valor>0</valor>
        </field> 

      </filters>
      
  <fieldGroup colstyle="vertical-align:middle; padding: 2px 2px 2px 2px;">

        <!-- CONSULTA -->
        <field id="nro_cuenta"  esClave="true" colstyle="vertical-align:middle; padding: 2px 2px 2px 2px;text-align:center;">
          	<label>Nro</label>
      		  <helper type="external" xml="regcuenta_solamente_nro_qry.xml" dir="/ayudas" empty="true" />
        </field>
        
        <field id="id_regcuenta" noshow="true">
  		      <detalle>regcuenta_id</detalle>
        </field>
       
        <field id="fecha_movimiento_desde" local="true" noshow="true">
          	<tipo>date</tipo>
          	<detalle>desde</detalle>
    	  </field>
    	  
        <field id="fecha_movimiento_hasta" local="true" noshow="true">
          	<tipo>date</tipo>
          	<detalle>hasta</detalle>
    	  </field>

        <field id="fecha_movimiento" tabla="REG_MOVIMIENTOS" noshow="true">
            <condicion operador="&lt;=">
              (CASE WHEN '[__fecha_movimiento_hasta__]' != '' 
                          THEN STR_TO_DATE('[__fecha_movimiento_hasta__]','%d/%m/%Y') ELSE '9999-12-31' END) 
                            AND REG_MOVIMIENTOS.fecha_movimiento &gt;= (CASE WHEN '[__arrastrasaldo__]'= 0 
                          THEN STR_TO_DATE('[__fecha_movimiento_desde__]','%d/%m/%Y') ELSE '0000-00-00' END)
            </condicion>
            <tipo>date</tipo>
        </field>

        <field id="subsistema_id" oculto="true">
             <detalle>subsistema_id</detalle>
        </field>
              
        <field id="nombre_cuenta">
             <label>Nombre Cuenta</label>
        </field>
        
        <field id="acumulado" suma="true">
  	       	<expression>
              SUM(CASE WHEN REG_CONCEPTOS.imputacion_concepto = 0  then REG_MOVIMIENTOS.importe_movimiento else 0 END)
  		         - SUM(CASE WHEN REG_CONCEPTOS.imputacion_concepto = 1  then REG_MOVIMIENTOS.importe_movimiento else 0 END)
             </expression>
      	     <label>Acumulado</label>
              <tipo>numeric</tipo>
        </field>

        <field id="saldo_movimiento" suma="true">
            <label>Pendiente</label>
            <expression>SUM(REG_MOVIMIENTOS.saldo_movimiento)</expression>
            <tipo>numeric</tipo>
        </field>

        <field id="filtro" noshow="true">
      	    <expression>(case when [__omitir__] = 1 AND SUM(REG_MOVIMIENTOS.saldo_movimiento) = 0 THEN 0 ELSE 1 END)</expression>
  		      <condicion operador="=">1</condicion>
        </field>

        <field id="color" local="true" clasefila="true" noshow="true">
            <label>color</label>
            <if exp="saldo &lt; 0">
              <true>'resaltadoRojo'</true>
              <false>''</false>
            </if>
        </field>
        
        <field id="omitir" noshow="true" local="true">
            <tipo>check</tipo>
            <valor>0</valor>
        </field>
        
      <field id="filtr2" noshow="true">
        <expression>CASE WHEN [__solo_diferencia__] = 1 AND (SUM(CASE WHEN REG_CONCEPTOS.imputacion_concepto = 0
then REG_MOVIMIENTOS.importe_movimiento else 0 END) - SUM(CASE WHEN REG_CONCEPTOS.imputacion_concepto = 1
then REG_MOVIMIENTOS.importe_movimiento else 0 END)) = SUM(REG_MOVIMIENTOS.saldo_movimiento) THEN 0 ELSE 1 END</expression>
        <condicion operador="=">1</condicion>
      </field>

  	  <field id="arrastrasaldo" noshow="true" local="true">
  		      <tipo>check</tipo>
  	  </field>
        
      <field id="solo_diferencia" local="true" noshow="true">
        <label>Solo Diferencias</label>
        <tipo>check</tipo>
        <valor>0</valor>
      </field>

  	  <field id="arrastraCheck" noshow="true" local="true">
        		<if exp="arrastrasaldo + 0 != 0 &amp;&amp; 'fecha_movimiento_desde' != ''">
        		  <true>'1'</true>
        		  <false>''</false>
        		</if>
        		<detalle>arrastrasaldo</detalle>
  	  </field>
  	  
  </fieldGroup>

      <group>
        <field id="id_regcuenta"/>
      </group>
      
      <order>
        <field id="nombre_cuenta"/>
      </order>

    </table>

    <join tipo="left">
      <table id="REG_MOVIMIENTOS">
        <field id="subsistema_id">
          <condicion operador="=">REG_CUENTA.subsistema_id</condicion>
        </field>
        <field id="regcuenta_id">
          <condicion operador="=">REG_CUENTA.id_regcuenta</condicion>
        </field>
      </table>
    </join>

    <join>
      <table id="REG_CONCEPTOS">
        <field id="id_concepto">
          <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
        </field>
      </table>
    </join>
    
  </form>
</histrix>
