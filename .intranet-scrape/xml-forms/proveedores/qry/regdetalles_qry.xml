<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta">
  <title>Movimientos</title>
  <obs/>
  <form detalle="regimputaciones_qry.xml" inline="true" hasDetail="imputacion_concepto">

    <table id="REG_MOVIMIENTOS" label="Resumen de Cuenta">

    <preconsultas>
        <xmlfile id="regdetalles_pre.xml" />
    </preconsultas>
    
    <filters auto="true">
    
      <field id="concepto_id">
        <label>Concepto</label>
        <operador>=</operador>
      </field>

      <field id="omitirpend" print="false">
        <label>Omitir S/Pendiente</label>
        <operador>=</operador>
        <valor>1</valor>
      </field>
      
    </filters>


    <fieldGroup id="entorno" noshow="true">

          <field id="subsistema_id" valauto="true">
            <preparam operador="=">true</preparam>
            <tipo>varchar</tipo>
          </field>

          <field id="tipo" valauto="true" local="true" />

          <field id="regcuenta_id" valauto="true">
            <preparam operador="=">true</preparam>
          </field>

          <field id="desde" _valauto="true" local="true" >
            <preparam campo="fecha_movimiento" operador="&lt;=">true</preparam>
            <tipo>date</tipo>
          </field>

          <field id="hasta" valauto="true" local="true">
            <tipo>date</tipo>
          </field>

          <field id="arrastrasaldo" local="true" >
            <preparam operador="=">true</preparam>
          </field>

          <field id="omitirpend" local="true" noshow="true" print="false">
            <tipo>check</tipo>
            <valor>1</valor>
          </field>

          <field id="filtro" noshow="true">
            <expression>
              (case when [__omitirpend__] = 1 AND (REG_MOVIMIENTOS.saldo_movimiento) = 0 THEN 0 ELSE 1 END)
            </expression>
            <condicion operador="=">1</condicion>
          </field>

    </fieldGroup>
    
    <fieldGroup colstyle="vertical-align:middle; padding: 2px 2px 2px 2px;">

          <field id="id_regmovim" noshow="true">
            <detalle>regmovim_id</detalle>
          </field>

          <field id="nombre_cuenta" noshow="true">
            <expression>REG_CUENTA.nombre_cuenta</expression>
            <setvar>nombre_div</setvar>
            <setvar>titulo</setvar>
          </field>

          <field id="cajmovimiento_id" noshow="true" />

          <field id="xml_llamar"  local="true" noshow="true">
            <if exp="cajmovimiento_id + 0 != 0">
              <true>'cajmovimiento_ficha.xml'</true>
              <false>'regmovimiento_ficha.xml'</false>
            </if>
          </field>

          <field id="xml_borrar"  local="true" noshow="true">
            <expression>
              CASE WHEN ((SELECT 0 FROM REG_IMPUTACIONES where regmovim0_id = REG_MOVIMIENTOS.id_regmovim  limit 1) = 0 OR (SELECT 0 FROM REG_IMPUTACIONES where regmovim_id = REG_MOVIMIENTOS.id_regmovim  limit 1) = 0 ) THEN '' ELSE 'fac_provee_anu.xml' END
            </expression>
          </field>
          <field id="imprime_concepto1" noshow="true">
            <expression>
              case when cajmovimiento_id != 0 then (case when isnull(CAJ_CONCEPTOS.imprime_concepto) then REG_NUMERADORES.ejecuta else CAJ_CONCEPTOS.imprime_concepto end) end
            </expression>
          </field>

          <field id="concepto_id" noshow="true">
            <helper type="combo" xml="regconcepto_qry.xml" dir="/ayudas" empty="true" />
          </field>

          <field id="fecha_movimiento" colstyle="vertical-align:middle; padding: 2px 2px 2px 2px; text-align:center;">
            <label>Fec.Mov.</label>
            <help>Fecha movimiento</help>
            <condicion operador="BETWEEN">
              IF('[__desde__]' = '', '0000-00-00', STR_TO_DATE('[__desde__]','%d/%m/%Y')) AND  IF('[__hasta__]' = '', '9999-99-99', STR_TO_DATE('[__hasta__]','%d/%m/%Y'))
            </condicion>
            <tipo>date</tipo>
          </field>

          <field id="abreviacion_concepto" tabla="REG_CONCEPTOS" colstyle="vertical-align:middle; text-align:center;">
            <label>Comp</label>
          </field>

          <field id="nro_movimiento" linkdes="Detalle del Comprobante" linkmodal="true" colstyle="vertical-align:middle; padding: 2px 2px 2px 2px; text-align:center;">
            <label>Numero</label>
            <expression>
              CONCAT(REG_MOVIMIENTOS.letra_movimiento,' ',LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,'0'),'-',LPAD(REG_MOVIMIENTOS.nro_movimiento  ,8,'0'))
            </expression>
            <helper type="link" dir="/caja/qry" >
              <parameter source="cajmovimiento_id" target="id_cajmovimiento" />
              <parameter source="id_regmovim" target="id_regmovim" />
            </helper>
            <tipo>varchar</tipo>
            <attribute id="linkint">imprime_concepto1</attribute>
          </field>

          <field id="referencia_movimiento">
            <label>Ref</label>
          </field>

          <!-- Cambiar de Acuerdo a como se quiere visualizar las imputaciones de CtaCte -->

          <field id="imputacion_concepto" noshow="true">
            <expression>
              CASE WHEN REG_CONCEPTOS.imputacion_concepto = 0 THEN 1 ELSE 0 END
            </expression>
          </field>

          <!-- Importes -->

          <field id="debe" suma="true" noZero="true">
            <label>debe</label>
            <expression>
              (case when REG_CONCEPTOS.imputacion_concepto = 0 then REG_MOVIMIENTOS.importe_movimiento else 0  end)
            </expression>
            <tipo>numeric</tipo>
          </field>

          <field id="haber" suma="true" noZero="true">
            <label>haber</label>
            <expression>
              (case when REG_CONCEPTOS.imputacion_concepto = 1 then REG_MOVIMIENTOS.importe_movimiento else 0 end)
            </expression>
            <tipo>numeric</tipo>
          </field>

          <field id="acumulado" suma="true" acumula="true" _local="true">
            <label>Acumulado</label>
            <expression>(case when REG_CONCEPTOS.imputacion_concepto = 0 then REG_MOVIMIENTOS.importe_movimiento else 0  end) - (case when REG_CONCEPTOS.imputacion_concepto = 1 then REG_MOVIMIENTOS.importe_movimiento else 0 end)</expression>
            <tipo>numeric</tipo>
          </field>

          <field id="saldo_movimiento" suma="true" noZero="true">
            <label>Pendiente</label>
            <tipo>numeric</tipo>
          </field>

        <!-- Funciones -->

          <field id="detalle" linkdir="/caja/proc/del" local="true" print="false" colstyle="text-align:center;width:4em;padding:2px 2px 2px 2px;">
            <attribute id="linkint">xml_llamar</attribute>
            <label>Detalle</label>
            <if exp="'xml_llamar' != ''">
              <true>'>>'</true>
              <false>''</false>
            </if>
          <paring destino="id_cajmovimiento" >cajmovimiento_id</paring>
          <paring destino="id_regmovim">id_regmovim</paring>
        </field>

        <field id="referencia_movimiento" noshow="true" />

        <field id="observaciones" local="true" print="false" colstyle="text-align:center;width:4em;padding:2px 2px 2px 2px;">
          <helper type="link" xml="regmovim_obs_qry.xml" dir="/proveedores/qry" width="600px" height="350px" title="Observaciones">
            <parameter source="id_regmovim" target="regmovim_id" operator="="/>
            <parameter source="referencia_movimiento" target="obsmov" operator="="/>
          </helper>
          <label>Obs</label>
          <valor>+</valor>
          <attribute id="style">tieneObs</attribute>
        </field>

    </fieldGroup>
    
    <fieldGroup>
      <if> if ($_SESSION['EDITOR'] == 'editor') return true; </if>
       
      <field id="modificacion" local="true" print="false" colstyle="text-align:center;width:4em;padding:2px 2px 2px 2px;">
          <helper type="link" xml="regmovimiento_crud2.xml" dir="/proveedores/ing" width="600px" height="350px" title="Modificar Comprobante">
	      <parameter source="id_regmovim" target="id_regmovim" />
    	    </helper>        
        <label>Mod</label>
	       <valor>Mod</valor>
      </field>

    </fieldGroup>

    <fieldGroup>
     
      <field id="tieneObs" noshow="true">
        <expression>
          IFNULL((SELECT 'color:red;font-weight:bold;text-align:center;width:4em;' FROM REG_MOVIMIENTO_OBS WHERE REG_MOVIMIENTO_OBS.regmovim_id = REG_MOVIMIENTOS.id_regmovim limit 1), 'text-align:center;width:4em;')
        </expression>
      </field>
      
      <field id="color" local="true" clasefila="true" oculto="true" />

    </fieldGroup>

    <!-- Fin -->

    <order>
        <field id="fecha_movimiento" tabla="REG_MOVIMIENTOS" />
        <field id="imputacion_concepto"/>
    </order>

    <group>
        <field id="id_regmovim" tabla="REG_MOVIMIENTOS"/>
    </group>



  </table>

  <join tipo="left">
    <table id="REG_CUENTA">
      <field id="id_regcuenta">
        <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
      </field>
    </table>
  </join>
  <join>
    <table id="REG_CONCEPTOS">
      <field id="id_concepto">
        <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
      </field>
    </table>
  </join>
  <join tipo="left">
    <table id="CAJ_CONCEPTOS">
      <field id="regconcepto_id">
        <condicion operador="=">REG_CONCEPTOS.id_concepto</condicion>
      </field>
    </table>
  </join>
  <join tipo="left">
    <table id="REG_NUMERADORES">
      <field id="regconcepto_id">
        <condicion operador="=">REG_CONCEPTOS.id_concepto</condicion>
      </field>
    </table>
  </join>
</form>
</histrix>