<?xml version="1.0"?>
<histrix tipo="consulta">
    <title>Planilla de Pendientes</title>
    <obs/>
    <form>
        <table id="REG_MOVIMIENTOS" label="Planilla de Pendientes">

            <filters>
                <field id="fecha_movimiento">
                    <label>Desde Fecha</label>
                    <operador>&gt;=</operador>
                    <valor>today</valor>
                </field>
                <field id="fecha_movimiento">
                    <label modpos="nobr">Hasta Fecha</label>
                    <operador>&lt;=</operador>
                    <valor>today</valor>
                </field>
                <field id="nro_cuenta">
                    <label>Cuenta</label>
                    <operador>=</operador>
                </field>
            </filters>

            <field id="id_regmovim" noshow="true" esClave="true" />

            <field id="subsistema_id" noshow="true" />

            <field id="regcuenta_id" noshow="true"/>

            <field id="nro_cuenta" tabla="REG_CUENTA">
                <label>Codigo</label>
                <helper type="external" xml="regcuenta_solamente_nro_qry.xml" dir="/ayudas" empty="true"/>
            </field>

            <field id="nombre_cuenta" tabla="REG_CUENTA">
                <label>Nombre</label>
            </field>

            <field id="fecha_movimiento">
                <label>Fec.Mov.</label>
                <tipo>date</tipo>
            </field>

            <field id="nro_movimiento" tdWidth="150" linkdes="Detalle del Comprobante" linkmodal="true" style="text-align: center">
                <label>Numero</label>
                <expresion>CONCAT(REG_CONCEPTOS.abreviacion_concepto, ' ', REG_MOVIMIENTOS.letra_movimiento,' ',LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,'0'),'-',LPAD(REG_MOVIMIENTOS.nro_movimiento  ,8,'0'))</expresion>
            </field>

            <field id="vencimiento_movimiento">
                <label>Fec.Vto</label>
            </field>

            <field id="importe_movimiento">
                <label>Imp. Original</label>
            </field>

            <field id="saldo_movimiento" suma="true">
                <label>Pendiente</label>
                <condicion operador="!=">0</condicion>
                <tipo>decimal</tipo>
            </field>

            <field id="dias_restantes" local="true">
                <label>Días restantes</label>
                <attribute id="style">color_fondo</attribute>
                <expression>DATEDIFF(vencimiento_movimiento, NOW())</expression>
            </field>

            <field id="fecha_hoy" local="true" noshow="true">
                <tipo>date</tipo>
                <valor>today</valor>
            </field>

            <field id="color_fondo" noshow="true" local="true">
                <expression>CASE WHEN vencimiento_movimiento &gt; NOW() THEN 'background-color:#9EEC76;text-align:center;'
                                 WHEN vencimiento_movimiento &lt; NOW() THEN 'background-color:#E69191;text-align:center;'
                                 WHEN vencimiento_movimiento = NOW()    THEN 'background-color:yellow;text-align:center;' END</expression>
            </field>

            <order>
                <field id="nombre_cuenta" />
                <field id="fecha_movimiento" />
                <field id="nro_movimiento" />
            </order>

        </table>

        <join>
            <table id="REG_CONCEPTOS">
                <field id="id_concepto">
                    <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
                </field>
            </table>
        </join>

        <join>
            <table id="REG_CUENTA">
                <field id="id_regcuenta">
                    <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
                </field>
            </table>
        </join>

    </form>
</histrix>