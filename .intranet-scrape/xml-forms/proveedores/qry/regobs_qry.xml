<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" limit="10">
    <title>Cuentas Corrientes</title>
    <obs/>
    <consulta>
        <table id="REG_MOVIMIENTO_OBS" label="Observaciones">

      <!-- CONSULTA -->
		<field id="id_regmovimientoobs" noshow="true">
		</field>

		<field id="regmovim_id" noshow="true"/>

		<field id="fec_observacion">
			<label>Fecha</label>
			<help>Fecha de la observación</help>
			<tipo>date</tipo>
			<valor>today</valor>
		</field>
		<field id="hora_observacion">
			<label>Hora</label>
			<help>Hora de la observación</help>
			<tipo>hora</tipo>
			<valor eval="true">date("H:i:s")</valor>
		</field>
		<field id="gencontacto_id">
			<helper type="combo" id="GEN_TIPO_CONTACTOS" empty="true">
				<field id="id_contacto"/>
				<field id="tipo_contacto"/>
			</helper>
			<label>Tipo Contacto</label>
		</field>
		<field id="observacion">
			<label>Observación</label>
			<help>Observación</help>
			<size>300</size>
		</field>
		<field id="login" _local="true" noshow="true">
			<label>Usuario</label>
			<tipo>varchar</tipo>
		</field>    

        </table>

    </consulta>
</histrix>
