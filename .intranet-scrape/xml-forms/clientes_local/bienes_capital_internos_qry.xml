						<valor>today</valor>
					</field> 
				</filters>

				<field id="movfec">
					<label>Fec.</label>
				</field>
				
				<field id="concod" noshow="true">
				    <condicion operador="=">16</condicion>
				</field>

				<field id="conabv" tabla="CCTCONCE">
					<label>Conc</label>
					<tipo>varchar</tipo>
				</field>

				<field id="movnpv">
					<label>Npv</label>
					<format>%04d</format>
				</field>
				<field id="regmin" tabla="CCTMOVIM" noshow="true">
					<label>regmin</label>
					<tipo>integer</tipo>
					<valor>0</valor>
				</field>

				<field id="regfec" noshow="true"/>
								
				<field id="movnro" linkint="ctbregis2.xml" linkdir="ctb_old">
					<label>Número</label>
				<!--	<format>%010d</format> -->
					<paring destino="regnro">movnro</paring>					
					<paring destino="regmin">regmin</paring>
					<paring destino="regfec">regfec</paring>
					
				</field>
				
				<field id="ctacod" oculto="true">
					<label>Cuenta</label>
				</field>
				<field id="ctanom">
					<label>Cliente</label>
				</field>
