				<order>
					<field id="IVAVENTAS.ivafec"></field>
					<field id="IVAVENTAS.concod"></field>
					<field id="IVAVENTAS.nronpv"></field>
					<field id="IVAVENTAS.nrocom"></field>
					
				</order>
			</table>
		<join tipo="left">

			<table id="CCTCONCE">
				<field id="siscod" oculto="true">
					<condicion operador="=">"02"</condicion>
				</field>				
				<field id="concod" >
					<condicion operador="=">CCTMOVIM.concod</condicion>
				</field>
			</table>
		</join>				
		
		<join tipo="left">

			<table id="CCTIMPUT">
				<field id="siscod" >
					<condicion operador="=">"02"</condicion>
				</field>				
				<field id="concod" >
					<condicion operador="=">CCTMOVIM.concod</condicion>
				</field>
				<field id="ctacod" >
					<condicion operador="=">CCTMOVIM.ctacod</condicion>
				</field>
				<field id="movnro" >
					<condicion operador="=">CCTMOVIM.movnro</condicion>
				</field>
				<field id="movnpv" >
					<condicion operador="=">CCTMOVIM.movnpv</condicion>
				</field>

			</table>
		</join>			
		<join tipo="left">
			<table id="REG_MOVIMIENTOS">
				<field id="subsistema_id" >
					<condicion operador="=">CCTIMPUT.siscod</condicion>
				</field>
				<field id="nro_cuenta" >
					<condicion operador="=">CCTIMPUT.ctacod</condicion>
				</field>
				<field id="nro_movimiento" >
					<condicion operador="=">CCTIMPUT.movinc</condicion>
				</field>
				<field id="puesto_movimiento" >
					<condicion operador="=">CCTIMPUT.movipv</condicion>
				</field>
			</table>
		</join>								
	</form>
</histrix>