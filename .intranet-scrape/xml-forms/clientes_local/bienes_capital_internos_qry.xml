	<!--			
				<field id="totcom" norepeat="true" suma="true">
					<label>Total</label>
				</field>				
				-->
				<field id="Total" _norepeat="true" suma="true">
			      <expression>CCTMOVIM.movimp * (case when conimp = 1 then 1 else -1 end)</expression>
					<tipo>numeric</tipo>
			      
					<label>Total</label>
				</field>
				<field id="concod2" >
			      <expression>CCTIMPUT.movicc</expression>
					<label>Cod.</label>
					<tabla_ex id="CCTCONCE">
						<field id="concod"></field>
						<field id="conabv"></field>
						<field id="siscod">
						<condicion operador="=">02</condicion>
						</field>
					</tabla_ex>
				</field>				
								
				<field id="movnro2" >
			    	    <expression>CCTIMPUT.movinc</expression>
					<label>Nro</label>
				</field>				

				<field id="imputado" >
			    	    <expression>CCTIMPUT.movimp</expression>
					<label>Imputado</label>
					<tipo>numeric</tipo>
					
				</field>								
				<field id="incfec" >
			    	<expression>REG_MOVIMIENTOS.fecha_movimiento</expression>
					<label>Imput</label>
					<tipo>date</tipo>
				</field>				

				<field id="movimp2" >
				      <expression>SELECT CCT.movimp from CCTMOVIM as CCT where 
				    				CCT.siscod = CCTIMPUT.siscod and 
				    				CCT.movnro = CCTIMPUT.movinc and 
				    				CCT.ctacod = CCTIMPUT.ctacod and 
				    				CCT.movnpv = CCTIMPUT.movipv and 
				    				CCT.concod = CCTIMPUT.movicc limit 1</expression>
					<label>Importe</label>
					<tipo>numeric</tipo>
				</field>				
							
