<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="fichaing"
  imprime="false"
  inserta="false"
  modifica="false"
  transaccional="true"
  preFetch="true"
>
  <title>Modificación de Movimientos</title>
  <confirmacion>
    <![CDATA[¿Desea modificar el comprobante?  ]]> </confirmacion>
  <obs/>
  <form>
    <table id="REG_MOVIMIENTOS" label="Ingreso de Movimientos" >
      <movimientos>
        <relacion id="regmovimiento_update.xml" />
        <relacion id="ivaventas_update.xml" />
<!--         <relacion id="ivaimportes_update.xml" /> lo comente porque lo guardo en el detalle: regmov_modif_detalle_iva.xml
 -->        <!-- si "actacte" = 1 realiza los movimientos para pasarlo a Forma de pago = Cuenta corriente -->
        <!--<relacion id="cctmovim_actacte_delete.xml" />-->
        <!-- <relacion id="cctmovim_actacte_update.xml" />
        --><!--
        <relacion id="cajmovim_actacte_delete.xml" />
        <relacion id="ctbregis_actacte_update.xml" />-->
        <!-- si "acontado" = 1 realiza los movimientos para pasarlo a Forma de pago = Contado -->
        <!--<relacion id="cctmovim_acontado_insert.xml" />
        <relacion id="cajmovim_acontado_insert.xml" />
        <relacion id="ctbregis_acontado_update.xml" />-->
        <relacion id="ctbregis_update.xml" />
      </movimientos>
      <field id="id_regmovim" esClave="true" noshow="true" />
      <field id="subsistema_id" noshow="true" />
      <field id="concepto_id" Formstyle="display:none;">
        <label modpos="nobr">Comprobante</label>
        <helper type="combo" xml="regconcepto_qry.xml" dir="/ayudas" empty="true" >
          <field id="subsistema_id">
            <condicion operador="=" valorde="subsistema_id" />
          </field>
        </helper>
      </field>

      <field id="concod" noshow="true" >
        <helper type="combo" id="CCTCONCE" empty="true">
          <field id="concod" />
          <field id="condes" />
          <field id="siscod">
            <condicion operador="=">'01'</condicion>
          </field>
        </helper>
        <label>Tipo</label>
      </field>

      <field id="nro_cuenta" deshabilitado="true">
        <label>Cuenta</label>
      </field>

      <field id="nombre_cuenta">
          <label _modpos="nobr">Nombre</label>
          <expression><![CDATA[IFNULL((select ctanom from CCTCUENT where ctacod = nro_cuenta and siscod ='02' ),'')]]></expression>   
          <size>30</size>             
      </field>

      <field id="regcuenta_id" noshow="true" />

      <field id="letra_movimiento" deshabilitado="true">
        <label modpos="nobr">Letra</label>
        <helper type="combo">
          <option value=""></option>
          <option value="A">A</option>
          <option value="B">B</option>
          <option value="C">C</option>
        </helper>
        <tipo>varchar</tipo>
      </field>

      <field id="puesto_movimiento" _deshabilitado="true">
        <label>P.V.</label>
        <size>4</size>
        <tipo>integer</tipo>
      </field>

      <field id="nro_movimiento" _deshabilitado="true">
        <label>Nro.</label>
        <size>8</size>
        <tipo>integer</tipo>
      </field>

      <field id="old_nro_movimiento" Formstyle="display:none;">
        <expression>nro_movimiento</expression>
      </field>

      <field id="fecha_movimiento" _deshabilitado="true">
        <label>Fecha</label>
        <help>Fecha movimiento</help>
        <tipo>date</tipo>
      </field>
      <field id="reg_fecha">
        <label>Registración</label>
        <help>Corresponde a la Fecha de Registración Contable</help>
        <tipo>date</tipo>
      </field>
      <field id="referencia_movimiento">
        <label>Referencia</label>
        <help>Referencia del movimiento</help>
        <size>100</size>
        <tipo>varchar</tipo>
      </field>
      <field id="old_importe_movimiento" Formstyle="display:none;">
        <expression>importe_movimiento</expression>
      </field>
      <field id="importe_movimiento">
        <label _style="font-size: 16px">Importe Total</label>
        <tipo>numeric</tipo>
        <size>17</size>
        <tipo>numeric</tipo>
        <jseval fielddestino="razon_cambio_imp">importe_movimiento / old_importe_movimiento</jseval>
      </field>
      <field id="saldo_movimiento">
        <label _style="font-size: 16px">Saldo</label>
        <tipo>numeric</tipo>
        <size>17</size>
        <tipo>numeric</tipo>
      </field>
      <field id="regmin" _deshabilitado="true" required="true">
        <label>Nro Minuta</label>
      </field>
      <field id="regref" local="true" Formstyle="display:none;">
        <if exp="true">
          <true>'concod - puesto_movimiento-nro_movimiento - nombre_cuenta'</true>
          <false>''</false>
        </if>
      </field>
      <field id="razon_cambio_imp" local="true" Formstyle="display:none;">
        <label>Razon</label>
        <valor default="true">1</valor>
      </field>

      <!-- <field id="alicuota"  deshabilitado="false">
        <label>Alícuota</label>
        <expression>select impali from IVAIMPORTES where ivacv_id = '[__ivacv_id__]' and ctacod = '[__nro_cuenta__]' and feciva = '[__reg_fecha__]'</expression>
        <options>
          <option valor="21.00">21.00 %</option>
          <option valor="27.00">27.00 %</option>
          <option valor="10.50">10.50 %</option>
          <option valor="0.00">0 %</option>
        </options> 
        <tipo>numeric</tipo>
        <jseval campodestino="impcod">(alicuota == 21.00 ? 1: (alicuota == 27.00 ? 3 : (alicuota == 10.50 ? 2 : 9)))</jseval>
      </field>

      <field id="impcod" local="true" _noshow="true">
        <label modpos="nobr"></label>
        <if exp="true" operador="=">
          <true>(alicuota == 21.00 ? 1: (alicuota == 27.00 ? 3 : (alicuota == 10.50 ? 2 : 9)))</true>
          <false>0</false>
        </if>
        <tipo>numeric</tipo>
      </field> -->

      <field id="checkiva" local="true" editable="true" _refresh="true"  style="color:red;font-weight:bold;font-size:16px;">
        <label>Modifica IVA</label>
        <tipo>check</tipo>
        <valor>1</valor>
      </field>
      <field id="grabaiva"  local="true" noshow="true">
        <if exp="'checkiva' == 1">
          <true>1</true>
          <false>0</false>
        </if>
        <label>Graba IVA</label>
      </field>

      <field id="concod4" local="true" Formstyle="display:none;">
        <valor default="true">4</valor>
      </field>

      <field id="tipoiva" local="true" Formstyle="display:none;">
        <valor default="true">2</valor>
      </field>

      <field id="ivacv_id" local="true" noshow="true"/>

      <field id="detalle_iva" local="true" colspan="3">
        <helper type="object" xml="regmov_modif_detalle_iva.xml">
          <parameter source="ivacv_id" target="ivacv_id" />
          <parameter source="nro_cuenta" target="ctacod" />
          <parameter source="concod" target="codcom" />
          <parameter source="letra_movimiento" target="codlet" />
          <parameter source="puesto_movimiento" target="nronpv" />
          <parameter source="nro_movimiento" target="nrocom" />
          <parameter source="reg_fecha" target="feciva" />
          <parameter source="razon_cambio_imp" target="razon_cambio_imp" />
        </helper>
      </field>

    </table>
  </form>
</histrix>