<?xml version="1.0" encoding="utf-8" ?>
   <histrix tipo="consulta" >
       <title>Cuenta Corriente</title>
        <obs></obs>
				<form  _detalle="imputaciones_rec.xml">
					<table id="CCTMOVIM" label="Movimientos" styleTbody="height:500px;">

						<filters>
							<field id="movfec">
								<operador>&gt;=</operador>
								<label>Desde Fecha</label>
								<valor>today</valor>
							</field>

							<field id="movfec">
								<operador>&lt;=</operador>
								<label>Hasta Fecha</label>
								<valor>today</valor>
							</field>
						</filters>
						
						<field id="siscod" oculto="true">
							<label>Cod.</label>
							<help>
							</help>
						</field>
<!--						<filters_ex>
							<label>Cuenta</label>
							<ayuda_ex id="CCTCUENT">
								<field id="ctacod"></field>
								<field id="ctanom"></field>
								<field id="siscod" oculto="true"></field>
								<field id="baja">
									<condicion operador="=">0</condicion>
								</field>

								<order>
									<field id="ctanom"></field>
								</order>
								
								<filtra>ctacod</filtra>
							</ayuda_ex>
						</filtro_ex> -->
						<field id="ctacod">
							<label>Cod.Cta.</label>
							<help>Código de Cuenta </help>
							<ayuda_ex id="CCTCUENT">
								<field id="ctacod">
									<detalle>ctacod</detalle>
								</field>
								<field id="ctanom">
									<detalle>ctanom</detalle>
								</field>
								<field id="siscod" oculto="true"></field>
								<field id="baja">
									<condicion operador="=">0</condicion>
								</field>

								<order>
									<field id="ctanom"></field>
								</order>
								
								<filtra>ctacod</filtra>
							</ayuda_ex>
							<detalle>ctacod</detalle>	
						</field>
							<field id="ctanom" tabla="CCTCUENT">
								<label>Nombre</label>
							</field>								

							<!--		        <condicion operador="=">20</condicion> 
							-->
						<field id="concod" noshow="true">
							<label>concod</label>
							<detalle>concod</detalle>	
							<condicion operador="=">15 or CCTMOVIM.concod = 16</condicion>						

		    			</field>
				<field id="regfec" _noshow="true">
				    <label>registrado</label>
				</field>
				<field id="regmin2" linkint="ctbregis2.xml" linkdir="ctb_old">
					<expression> select CTB.regmin from CTBREGIS CTB where regnro = movnro and CTB.regmin = CCTMOVIM.regmin and CTB.regfec = CCTMOVIM.regfec limit 1</expression>
					<label>Min</label>
					<help>
					</help>
				<!--	<format>%010d</format> -->
					<paring destino="regnro">movnro</paring>					
					<paring destino="regmin">regmin2</paring>
					<paring destino="regfec">regfec</paring>
					
				</field>
				

						<field id="movnpv">
							<label>P.V.</label>
							<help> Punto Venta</help>
							<format>%04d</format>
							<detalle>movnpv</detalle>
						</field>
						<field id="movnro" >
							<label>Número</label>
							<help> Número Comprobante</help>
							<format>%012d</format>
							<detalle>movnro</detalle>	
						</field>
						
						<field id="concepto">
							<expression>condes</expression>
							<label>Cod.Concepto</label>
							<help>
							</help>
							<tipo>string</tipo>
							<!--		      <tabla_ex id="CCTCONCE">
							
							<field id="concod"></field>
							<field id="condes"></field>
							</tabla_ex>
							-->
						</field>
						
						<field id="movfec">
							<label>Fecha </label>
							<help>
							</help>
						</field>
						
						<!--          <field id="movvto">
						<label>Venc. </label>
						<help> </help>
						</field>
						-->
						<field id="Debe" suma="true"  noZero="true">
							<expression>movimp * (case when conimp = 1 then 1 else 0 end)</expression>
							<label>Debe</label>
							<help>
							</help>
						</field>
						
						<field id="Haber" suma="true" link_int="cctmovim_comp.xml" linkdes="Ver Recibo" noZero="true">
							<expression>movimp * (case when conimp = 2 then 1 else 0 end)</expression>
							<label>Haber</label>
							<help>
							</help>
						<!-- <paring destino="siscod">siscod</paring>							-->
							<paring destino="movnro">movnro</paring>
							<paring destino="carrec">movnro</paring>
							<paring destino="cajnro">movnro</paring>
							<paring destino="movinc">movnro</paring> 
							<paring destino="movnpv">movnpv</paring>
							<paring destino="ctacod">ctacod</paring>
							<paring destino="movfec">movfec</paring>
							<paring destino="cajfec">movfec</paring>							
						</field>

						<field id="movsal" suma="true"  noZero="true">
							<label>Saldo</label>
							<help></help>
							<tipo>numeric</tipo>
						</field>
						<!--
						<field id="resaltado" clasefila="true" local="true" noshow="true">
							<expression>case when movsal != 0 then 'resaltado' end</expression>
							<tipo>varchar</tipo>
						</field>
						-->
						<field id="clase" clasefila="true" local="true" noshow="true">
						    <if exp="'regmin2' != ''">
							<true>''</true>
							<false>'error'</false>
						    </if>
						</field>
						
						<order>
							<field id="movfec"></field>
						</order>
					</table>
					<join tipo="left">
						<table id="CCTCUENT">
							<field id="siscod" >
								<condicion operador="=">CCTMOVIM.siscod</condicion>
							</field>
							<field id="ctacod" >
								<condicion operador="=">CCTMOVIM.ctacod</condicion>
							</field>
						</table>
					</join>					
					<join tipo="left">
						<table id="CCTCONCE">
							<field id="siscod" oculto="true">
								<label>cctcuent.siscod</label>
								<condicion operador="=">CCTMOVIM.siscod</condicion>
							</field>
							
							<field id="concod" oculto="true">
								<condicion operador="=">CCTMOVIM.concod</condicion>
							</field>
							
							<field id="condes" oculto="true">
							</field>
							
						</table>
					</join>
				</form>
        </histrix>