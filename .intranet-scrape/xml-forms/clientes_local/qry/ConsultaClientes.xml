            <order>
                <field id="nombre_cuenta"></field>
            </order>

            <group>
                <field id="nro_cuenta" tabla="REG_CUENTA"></field>
            </group>

        </table>

        <join tipo="left">
            <table id="GEN_PROVINCIAS">
                <field id="id_provincia">
                    <condicion operador="=">REG_CUENTA.provincia_id</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="PEDCOTIZ">
                <field id="ctacod">
                    <condicion operador="=">REG_CUENTA.nro_cuenta</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="CHASIS">
                <field id="nrocha">
                    <condicion operador="=">PEDCOTIZ.nrocha</condicion>
                </field>
            </table>
        </join>
		<join tipo="left">
			<table id="MODCHASIS">
				<field id="modcha">
					<condicion operador="=">CHASIS.modcod</condicion>
				</field>
				<field id="marcod">
					<condicion operador="=">CHASIS.marcod</condicion>
				</field>
			</table>
		</join>
    </form>
</histrix> 
