            <field deshabilitado="true" id="nro_cuenta2" local="true" linkint="fichas_x_cliente.xml" linkdes="Total de Coches" print="false">
                <expression>select count(*) from VUNIDADES as PED where PED.ctacod = REG_CUENTA.nro_cuenta</expression>
                <label >Ot.</label>
                <help>Codigo de Cuenta</help>
                <paring destino="ctacod">nro_cuenta</paring>
                <tipo>varchar</tipo>
            </field>
        -->
            <field id="cuit_cuenta">
                    <label  colspan="8">CUIT</label> 
            </field>

            <field id="cod_direccion">
                <label colspan="4">Dirección</label>
                <size>50</size>
            </field>
            
            <field id="codigo_postal">
                <label>C.P.</label>
                <help>
                </help>
            </field>

            <field id="localidad_nombre">
                <label >Localidad</label>
                <help>
                </help>
            </field>

            <field id="nombre_provincia" tabla="GEN_PROVINCIAS">
                <label modpos="nobr">Provincia</label>
            </field>

            <field id="tel_cuenta">
                <label>Teléfono</label>
            </field>
          
          <!--
			<field id="ctatel2" noshow="true">
				<expression>REPLACE(REPLACE(MID(ctatel, LOCATE(' ', replace(ctatel,' ','')) + 1), '-', ''), ' ', '')</expression>
				<label>ctatel2</label>
			</field> -->

<!--
			<field id="ctatel3" _noshow="true">
				<expression>concat(ctatel, ', ' ,ctafax , ',' )</expression>
				<label>ctatel2</label>
			</field>
    -->
            <field id="fax_cuenta">
                <label modpos="nobr" >Tel/Fax.</label>
            </field>

            <field id="baja" oculto="true">
                <condicion operador="!=">1</condicion>
            </field>

            <field id="entrega_direccion">
                <label>Dir.Envío</label>
            </field>

            <field id="entrega_localidad">
                <label modpos="nobr">Loc.Envío</label>
            </field>

			<field id="entrega_codigopostal">
                <label>Expreso.Envío</label>
            </field>
