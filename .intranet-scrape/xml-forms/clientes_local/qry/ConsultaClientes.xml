            <field id="llamadas" local="true" linkdes="Ultimas llamadas">
                <label modpos="nobr">Llamadas</label>
                <helper type="link" xml="tel_log_cdr_xcuenta_qry.xml" dir="/tel">
    				<parameter source="ctatel5" target="tels" operator="="/> 
				</helper>
