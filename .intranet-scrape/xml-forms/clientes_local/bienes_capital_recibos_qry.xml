		<join tipo="left">

			<table id="CCTMOVIM">
				<field id="siscod" oculto="true">
					<condicion operador="=">"02"</condicion>
				</field>				
				<field id="concod" >
					<condicion operador="=">IVAVENTAS.codcom</condicion>
				</field>
				<field id="ctacod" >
					<condicion operador="=">IVAVENTAS.ctacod</condicion>
				</field>
				<field id="movnro" >
					<condicion operador="=">IVAVENTAS.nrocom</condicion>
				</field>
				<field id="movnpv" >
					<condicion operador="=">IVAVENTAS.nronpv</condicion>
				</field>

			</table>
		</join>		
		
		<join tipo="left">

			<table id="CCTIMPUT">
				<field id="siscod" >
					<condicion operador="=">"02"</condicion>
				</field>				
				<field id="concod" >
					<condicion operador="=">IVAVENTAS.codcom</condicion>
				</field>
				<field id="ctacod" >
					<condicion operador="=">IVAVENTAS.ctacod</condicion>
				</field>
				<field id="movnro" >
					<condicion operador="=">IVAVENTAS.nrocom</condicion>
				</field>
				<field id="movnpv" >
					<condicion operador="=">IVAVENTAS.nronpv</condicion>
				</field>

			</table>
		</join>			
		<join tipo="left">

			<table id="REG_MOVIMIENTOS">
				<field id="subsistema_id" >
					<condicion operador="=">CCTIMPUT.siscod</condicion>
				</field>
				<field id="nro_cuenta" >
					<condicion operador="=">CCTIMPUT.ctacod</condicion>
				</field>
				<field id="nro_movimiento" >
					<condicion operador="=">CCTIMPUT.movinc</condicion>
				</field>
				<field id="puesto_movimiento" >
					<condicion operador="=">CCTIMPUT.movipv</condicion>
				</field>

			</table>
		</join>									
