<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="abm-mini" subtipo="vertical">
	<title>Personas</title>
	<obs></obs>
	<form >
		<table id="CAL_AUDITORIA_PERSONAS">
		    <title>Personas</title>

			<field id="id_auditoriapersona" autoinc="true" noshow="true">
				<label>Codigo</label>
			</field>

			<field id="auditoriaint_id" oculto="true"/>

			<field id="usuario_id" _print="false">
				<label>Nombre</label>
				<helper type="combo" id="HTXUSERS">		
					<field id="id_usuario"/>
					<field id="nombre">
						<expression>CONCAT(apellido, ' ', nombre)</expression>
					</field>
					<field id="baja">
						<condicion operador="=">0</condicion>
					</field>
					<order>
						<field id="nombre"/>
					</order>
				</helper>
			</field>


			<field id="entrevistado" deshabilitado="false" print="false">
				<label>Entrevistado</label>
				<helper type="combo" >
				   <option value="1">Si</option>
				   <option value="0">No</option>
				</helper><!--
				<tipo>check</tipo>-->
			</field>

			<field id="notificado" deshabilitado="false" print="false">
				<label modpos="nobr">Notificado</label>
				<helper type="combo" >
				   <option value="1">Si</option>
				   <option value="0">No</option>
				</helper><!--
				<tipo>check</tipo>-->
			</field>
			
			<field id="nombre" tabla="HTXPROFILES">
				<label Formstyle="display:none;">Perfil</label>
			</field>
		</table>
		<join tipo="left">
			<table id="HTXUSERS">
				<field id="id_usuario">
					<condicion operador="=">CAL_AUDITORIA_PERSONAS.usuario_id</condicion>
				</field>
			</table>
		</join>
		<join tipo="left">
			<table id="HTXPROFILES">
				<field id="id_perfil">
					<condicion operador="=">HTXUSERS.id_perfil</condicion>
				</field>
			</table>
		</join>
	</form>
</histrix>
