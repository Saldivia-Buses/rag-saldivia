<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="calendar" imprime="false" inserta="false" modifica="false" detailDir="/compras/calendario">
	<title>DETALLE</title>
	<obs></obs>
	<form _detalle="cpsencab_cabreimp.xml" detalle="cpsencab_cabreimp_detalle.xml" >
		<table id="CPSMOVIM" label="DETALLE">
		
			<filters>
				<field id="ocpest">
					<operador>=</operador>
					<label modpos="nobr">Estado</label>
					<valor>1</valor>
				</field>
				<field id="fecreq">
					<operador>&gt;</operador>
					<label modpos="nobr">Desde</label>
					<valor eval="true">date("d/m/Y", mktime(0, 0, 0, 1, 1, date("Y")))</valor>
				</field>
			</filters>

			<field id="id_cpsmovim" deshabilitado="true" calendarId="true" />

			<field id="ocpest" noshow="true" tabla="CPSENCAB">
				<label _modpos="nobr">Estado</label>
				<help>Estado Actual</help>
				<options>
					<option valor=""></option>
					<option valor="0">No Autorizada</option>
					<option valor="1">Pendiente</option>
					<option valor="2">Cumplida</option>
					<option valor="3">Parcial</option>
					<!-- <option valor="4">Anulada</option> -->
				</options>
			</field> 

			<field id="anuladas" noshow="true">
				<expression having="false">ocpest</expression>
				<condicion operador="!=">4</condicion>
			</field>

			<field id="ctacod" deshabilitado="true">
				<expression>CPSENCAB.ctacod</expression>
				<detalle>ctacod</detalle>
			</field>
			<field id="siscod" oculto="true">
				<label>Codigo Sistema..</label>
				<help></help>
				<condicion operador='='>''</condicion>

			</field>
			<field id="movfec">
				<label>Emision</label>
				<help>Fecha de Orden de Compra.</help>
<!--				<detalle>ocpfec</detalle> -->
			</field>
			<!--
			<field id="detalle" deshabilitado="true" >
			<label>Detalle</label>
			<help>Detalle de linea de la Orden de Compra para Art S.C.</help>
		</field>
		<field id="observaciones"  tabla="CPSMOVIM" >
			<label modpos="nobr">Observaciones</label>
			<tipo>varchar</tipo>
		</field>
		<field id="movuso" deshabilitado="true">
			<label>Ped.</label>
			<help>Pedido (expresado en la unidad de stock)</help>
		</field>
		<field id="movcps" deshabilitado="true">
			<label>Ped.cps</label>
			<help>Pedido (expresado en la unidad de compra)</help>

		</field>
		<field id="movrec" deshabilitado="true">
			<expression>round(movrec, 2)</expression>
			<label>Rec</label>
			<help>Recibido (expresado en la unidad de compra)</help>
			<tipo>decimal</tipo>
		</field>
		<field id="pencps" >
			<expression>round(movcps - movrec, 2)</expression>
			<tipo>decimal</tipo>

			<label>Pend.cps</label>
			<help>Pendiente (expresado en la unidad de compra)</help>
		</field>
		<field id="artuni_exp3" deshabilitado="true">
			<expression>STKINSUM.unicps</expression>
			<label>U.Compra</label>
			<help>Unidad de Compra</help>
			<tabla_ex id="FSMUNIDS">

				<field id="unicod" clave="true"></field>
				<field id="uninom"></field>
			</tabla_ex>
			<tipo>varchar</tipo>
		</field>
		-->
		<field id="fecreq"  deshabilitado="true" calendarStartDate="true">
			<label>Fecha Entrega</label>
			<tipo>date</tipo>
		</field>
		<field id="nrocha"  >
			<label>Nro</label>
			<tipo>varchar</tipo>
			<size>5</size>
		</field>
		<field id="observaciones" deshabilitado="true">
			<label>Obs</label>
		</field>

		<field id="ocpnro"  >
			<label>Nro</label>
			<help>Numero de Orden de Compra</help>
			<detalle>ocpnro</detalle>
		</field>

		<field id="estilo" >
			<expression>
				(case when ocpest = 2 then 'text-decoration:line-through;' 
						
						else '' end)
			</expression>
		</field>

		<field id="desc" calendarSubject="true" >
			<attribute id="style">estilo</attribute>

			<expression>concat(CPSMOVIM.ocpnro,' -', CCTCUENT.ctanom)</expression>
		</field>
		<!--
			<field id="costo" noshow="true">
		<expression>
			case when ((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = STKINSUM.artcod and STKINSPR.siscod='01' order by fecult DESC limit 1) ) > 0  then ((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = STKINSUM.artcod and STKINSPR.siscod='01' order by fecult DESC limit 1) ) else STKINSUM.artcos end
		</expression>
		<tipo>decimal</tipo>

	</field>
	<field id="Total" suma="true" deshabilitado="true" local="true">
		<label>Total</label>

		<if exp="true">
			<true>costo * movcps</true>
			<false>0</false>
		</if>
		<tipo>decimal</tipo>
	</field>
	-->

	<field id="color" calendarColor="true">
		<attribute id="style">estilo</attribute>
		<expression>(case when ocpest = 2 then '#006600' 
							when ocpest = 1 then 
							(CASE WHEN sum(movrec) != 0 then '#FFaa00' else '#ff0000' END)
							when ocpest = 3 then '#FFAB00'
							<!-- when ocpest = 4 then '#FFFFFF' -->
							
							else ''	
							
					 end)</expression>
	</field>

	
	<group>
		<field id="ocpnro"  tabla="CPSENCAB"/>
		<field id="fecreq" />
	</group>

</table>

<join tipo="left">
	<table id="CPSENCAB">
		<field id="ocpnro" >
			<condicion operador="=">CPSMOVIM.ocpnro</condicion>
		</field>
		<field id="ocpfec" >
			<condicion operador="=">CPSMOVIM.movfec</condicion>
		</field>
	</table>
</join>
<join tipo="left">
	<table id="CCTCUENT">
		<field id="ctacod" >
			<condicion operador="=">CPSENCAB.ctacod</condicion>
		</field>
		<field id="siscod" >
			<condicion operador="=">'01'</condicion>
		</field>
	</table>
</join>

<join tipo="left">
	<table id="STKINSUM">
		<field id="siscod" oculto="true">
			<label>STKINSUM.siscod</label>
			<condicion operador="=">'01'</condicion>
		</field>
		<field id="artcod" oculto="true">
			<condicion operador="=">CPSMOVIM.artcod</condicion>
		</field>
		<field id="artuni" oculto="true"></field>
		<field id="unicps" oculto="true"></field>
	</table>
</join>
</form>
</histrix>
