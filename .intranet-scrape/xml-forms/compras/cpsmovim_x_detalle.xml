<?xml version="1.0" encoding="ISO-8859-1"?>
<histrix tipo="consulta" style="height:100%;" PDForientacion="L">
  <title>DETALLE</title>
  <obs></obs>
  <form  detalle="ocprecib_qry.xml" inline="true">
    <table id="CPSMOVIM" label="DETALLE">

      <field id="artcod" deshabilitado="true">
        <label>Art.</label>
        <help>Codigo de Articulo</help>
        <detalle>artcod</detalle>
      </field>
      <field id="siscod" oculto="true">
        <label>Codigo Sistema..</label>
        <help></help>
        <condicion operador='='>''</condicion>

      </field>
      <field id="movfec">
        <label>Emision</label>
        <help>Fecha de Orden de Compra.</help>
      </field>

      <field id="detalle" deshabilitado="true">
        <label>Detalle</label>
        <help>Detalle de linea de la Orden de Compra para Art S.C.</help>
	<tipo>varchar</tipo>
      </field>
      <field id="observaciones"  tabla="CPSMOVIM" >
        <label modpos="nobr">Observaciones</label>
        <tipo>varchar</tipo>
      </field>
      <field id="movuso" deshabilitado="true">
        <label>Ped.</label>
        <help>Pedido (expresado en la unidad de uso)</help>
      </field>


      <!--        <field id="mov_pen" deshabilitado="true">
      <expression>movuso - penuso</expression>
      <label>Rec.</label>
      <help>Recibido (expresado en la unidad de uso)</help>
    </field>
    <field id="penuso" deshabilitado="true">
      <label>Pend</label>
      <help>Pendiente (expresado en la unidad de uso)</help>
    </field>

    <field id="artuni_exp2" deshabilitado="true">
      <expression>STKINSUM.artuni</expression>
      <label>U.Uso</label>
      <help>Unidad de Uso</help>
      <tabla_ex id="FSMUNIDS">

        <field id="unicod" clave="true"></field>
        <field id="uninom"></field>
      </tabla_ex>
    </field>
    -->
    <field id="movcps" deshabilitado="true">
      <label>Ped.cps</label>
      <help>Pedido (expresado en la unidad de compra)</help>

    </field>
    <field id="mov_pen2" deshabilitado="true">
      <expression>movcps - pencps</expression>
      <label>Rec</label>
      <help>Recibido (expresado en la unidad de compra)</help>
    </field>
   <!-- <field id="pencps" >
      <label>Pend.cps</label>
      <help>Pendiente (expresado en la unidad de compra)</help>
      <condicion operador="!=">0</condicion>
    </field>-->
    <field id="artuni_exp3" deshabilitado="true">
      <expression>STKINSUM.unicps</expression>
      <label>U.Compra</label>
      <help>Unidad de Compra</help>
      <tabla_ex id="FSMUNIDS">
        <field id="unicod" clave="true"></field>
        <field id="uninom"></field>
      </tabla_ex>
      <tipo>varchar</tipo>
    </field>
    <field id="fecreq" local="true" deshabilitado="true" >
      <expression>fecreq</expression>
      <label>Fecha Requerido</label>
      <tipo>date</tipo>
    </field>
    <field id="nrocha"  >
      <label>Nro</label>
      <tipo>varchar</tipo>
      <size>5</size>
    </field>
    <field id="observaciones" deshabilitado="true">
      <label>Obs</label>
    </field>

    <field id="ocpnro" oculto="true">
      <label>Nro</label>
      <help>Numero de Orden de Compra</help>
      <detalle>ocpnro</detalle>
    </field>
    <field id="costo" noshow="true">
      <expression>
        case when ((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = STKINSUM.artcod and STKINSPR.siscod='01' order by fecult DESC limit 1) ) > 0  then ((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = STKINSUM.artcod and STKINSPR.siscod='01' order by fecult DESC limit 1) ) else STKINSUM.artcos end
      </expression>

    </field>
    <field id="Total" suma="true" deshabilitado="true" local="true">
      <label>Total</label>

      <if exp="true">
        <true>costo * movcps</true>
        <false>0</false>
      </if>
    </field>

  </table>
  <join tipo="left">
    <table id="STKINSUM">
      <field id="siscod" oculto="true">
        <label>STKINSUM.siscod</label>
        <condicion operador="=">'01'</condicion>
      </field>
      <field id="artcod" oculto="true">
        <condicion operador="=">CPSMOVIM.artcod</condicion>
      </field>
      <field id="artuni" oculto="true"></field>
      <field id="unicps" oculto="true"></field>
    </table>
  </join>
  <order>
    <field id="ocpren"></field>
  </order>

</form>
</histrix>