<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="abm-mini">
    <title>CONTACTOS</title>
    <obs></obs>
    <form >
        <table id="CCTCONTA" label="Contactos">
            
            <field id="siscod" noshow="true">
                <label>Codigo Sistema</label>
            </field>
            
            <field id="idconta" autoinc="true" noshow="true">
                <label>id</label>
                <help>
                </help>
            </field>
            
            <field id="ctacod" noshow="true">
                <label>Cuenta</label>
            </field>
            
            <field id="nrocta" noshow="true">
                 <expression having="false">ifnull(rc.nro_cuenta, CCTCONTA.ctacod)</expression>
            </field>
            
            <field id="nombre" ldifName="cn,sn">
                <label>Nombre </label>
                <help>Nombre del contacto</help>
                 <size>18</size>
            </field>
            
            <field id="ctafan" local="true" deshabilitado="true" ldifName="o" noshow="true" />
            
            <field id="cargo">
                <label>Cargo </label>
                <help>Cargo </help>
                <tabla_ex id="CARGOS">          
                    <field id="cargo" clave="true"></field>
                    <field id="nombre"></field>
                    <order>
                        <field id="nombre"></field>
                    </order>
                </tabla_ex>
            </field>

            <field id="Telefono" ldifName="mobile">
                <label>Telefono </label>
                <help></help>
                <size>12</size>
            </field>

            <field id="interno" ldifName="mobile">
                <label>Interno </label>
                <size>5</size>
            </field>

            <field id="movil" >
                <label>Celular</label>
                <size>12</size>
            </field>

            <field id="mail" ldifName="mail" ldifKey="true">
                <label>Mail </label>
                <help>
                </help>a
                <size>30</size>
                <tipo>email</tipo>
            </field>

	        <field id="pasww" deshabilitado="true" style="color:#bbb;">
		      <expression>case when mail != '' then lower(concat( left(replace(replace((case when nombre != '' then REG_CUENTA.nombre_cuenta else mail end),' ',''),'.','') , 5), REG_CUENTA.id_regcuenta)) end</expression>
	        </field>

			<field id="fecha_cump">
				<label>Cumpleaños</label>	
				<tipo>date</tipo>
			</field>

            <field id="principal" conLabel="true">
                <label>Principal</label>
                <tipo>check</tipo>
                <help></help>                                        
            </field>

            <field id="compras"  conLabel="true">
                <label>Compras</label>
                <tipo>check</tipo>
                <help></help>                            
            </field>
            <field id="pagos"  conLabel="true">
                <label>Pagos</label>
                <tipo>check</tipo>
                <help></help>
            </field>

            <group>
                <field id="idConta" />
            </group>

        </table>

        <join tipo="left">
            <table id="REG_CUENTA">
                <field id="nro_cuenta">
                    <condicion operador="=">CCTCONTA.ctacod</condicion>
                </field>
            </table>
        </join>

        <join tipo="left">
            <table id="REG_CUENTA_RELACIONES">
                <field id="regcuenta_id">
                    <condicion operador="=">REG_CUENTA.id_regcuenta</condicion>
                </field>
            </table>
        </join>

        <join tipo="left">
            <table id="REG_CUENTA" as="rc">
                <field id="id_regcuenta">
                    <condicion operador="=">REG_CUENTA_RELACIONES.regcuentarelacionada_id</condicion>
                </field>
            </table>
        </join>
    </form>
</histrix>