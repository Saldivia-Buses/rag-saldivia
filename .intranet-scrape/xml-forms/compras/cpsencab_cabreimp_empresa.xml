			'<td>', CPSMOVIM.artcod, '</td>',
			'<td>', LEFT(CPSMOVIM.detalle, 20), '</td>',
			'<td>', ROUND(CPSMOVIM.pencps, 2), '</td>',
			'<td>', FSMUNIDS.uninom, '</td>',
			'<td>', CPSMOVIM.nrocha, '</td>',
			'</tr>'

				)), ',', '')

from CPSENCAB cab left JOIN CPSMOVIM on  
( CPSMOVIM.siscod = cab.siscod )  and  ( CPSMOVIM.ocpnro = cab.ocpnro )  and  ( CPSMOVIM.movfec = cab.ocpfec )  
left JOIN STKINSUM on  ( STKINSUM.siscod = '01' )  and  ( STKINSUM.artcod = CPSMOVIM.artcod ) LEFT JOIN FSMUNIDS ON (STKINSUM.unicps = FSMUNIDS.unicod)
where ( ( cab.siscod = CPSENCAB.siscod ) ) and ( ( cab.ocpfec <= current_date() ) ) and ( ( cab.ctacod = CPSENCAB.ctacod ) ) and ( ( cab.ocpest = '1' ) ) and ((CPSMOVIM.pencps > 0)) order by ocpfec)



, '</table>'
                 , ifnull((select body_mail from GEN_MAILS where id_mail = 4), ''))]]></expression>

