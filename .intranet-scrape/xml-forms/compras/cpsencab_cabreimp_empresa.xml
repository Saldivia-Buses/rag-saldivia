            <pdf PDForientacion="P">
            <code><![CDATA[

		$pdf->SetDrawColor(0);
		$pdf->SetXY(10,10);

		$tp = 05;
		$ap = $pdf->anchoPagina - 5;
		$mp = ($ap / 2);
		$lp = $pdf->largoPagina;

		// Frame Principal
		//$pdf->Rect(005, 005, $ap, $lp, 0.1);

		// Nombre Empresa
		//$pdf->Rect(005, 005, $mp, 045, 0.1);

		$datapath = $_SESSION['datapath'];

        $dataContainer = $pdf->Container;
        
        if (method_exists($dataContainer, 'getCampo') ){
            $field = $dataContainer->getCampo('logo_pdf');
            $filename = $field->getValor();
          
        } else {
            $field = $dataContainer->getField('logo_pdf');
            $filename = $field->getValue();
        }
        

		$file = HTX_ROOT_DIR."/database/$datapath/img/$filename"; 

		if (is_file($file))
		{
		    $posx = 1;
		    $posy = 1;
		    $width = 45;
            $height = 10;
		    $pdf->Image($file, $posx + $pdf->offsetX, $posy + $pdf->offsetY, 0, $height);
		} else {
            die($file);
        }
	
		// Datos Comprobante
		//$pdf->Rect($mp + 5, 005, $mp, 045, 0.1);
		$pdf->RoundedRect($pdf->offsetX, 2 + $pdf->offsetY, $pdf->anchoPagina - 2, 15, 2);
		
		

       

        $pdf->SetFont($pdf->defaultFont, '', 9);
        $fecha = utf8_decode( $pdf->i18n['printDate'].':' . date('d/m/Y'));
        $anchoFecha = $pdf->GetStringWidth($fecha) + 3;
        $anchorecuadro = $anchoFecha + 2;
        $posRecuadro = $pdf->offsetX + $pdf->anchoPagina - $anchorecuadro;

            $pdf->RoundedRect($posRecuadro, 3 + $pdf->offsetY, $anchoFecha, 8, 2);
            $pdf->setXY($posRecuadro , 5 + $pdf->offsetY);
            $pdf->Cell(0, 0, $fecha, 0, 0, 'L');

        $nonum = (isset($pdf->sinNumero)) ? $pdf->sinNumero : 'false';
        $hoja = '';
        if ($nonum != 'true') {
            $hoja = $pdf->i18n['page'] .': '. $pdf->PageNo() ;
            if ($pdf->pageNumber == 0){
                $hoja .= '/{nb}';
            }
            $pdf->setXY($posRecuadro + 1, 8 + $pdf->offsetY);
            $pdf->Cell(0, 0, $hoja, 0, 0, 'L');
        }



		// DATOS EMPRESA
		$pdf->SetFontSize(8);
		

            ]]></code>
        </pdf>
