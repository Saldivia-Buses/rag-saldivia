<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta">
  <title>ORDENES DE COMPRA</title>
  <obs></obs>
  <form  >
    <table id="CPSENCAB" label="ORDENES DE COMPRA" styleTbody="height:300px;">
      <field id="siscod" oculto="true">
        <label>Codigo Sistema</label>
       
        <detalle>siscod</detalle>
      </field>
      <field id="nrocha" tabla="CPSMOVIM">
        <label>NroFab.</label>
        <tipo>varchar</tipo>
      </field>
      <field id="ocpnro" esclave="true" >
        <label>Nº</label>
        <help>Numero de Orden de Compra. </help>
        <detalle>ocpnro</detalle>
      </field>
      
      <field id="ocpfec" >
        <label>Emision </label>
        <help>Fecha de Emisión</help>
      </field>
      
<!--      <field id="ocpfen">
        <label>Entrega</label>
        <help>Fecha de Entrega </help>
      </field> -->
      
	  <field id="fecreq" local="true" deshabilitado="true"  >
        <expression>CPSMOVIM.fecreq</expression>
        <label>Fecha Entrega</label>
        <tipo>date</tipo>
      </field>
      <field id="ctacod" noshow="true">
        <label>Proveedor</label>
        <help>Codigo de Cuenta PROVEEDOR. </help>
        <tabla_ex id="CCTCUENT">
          
          <field id="ctacod" clave="true" muestra="false"></field>
          <field id="ctanom"></field>
          <field id="siscod" oculto="true">
            <condicion operador="=">'01'</condicion>
          </field>
          <field id="baja">
            <condicion operador="!=">1</condicion>
          </field>          
          <order>
            <field id="ctanom"></field>
          </order>
          
        </tabla_ex>
      </field>
      <field id="ocpest" noshow="true">
        <label>Estado</label>
        <help>Estado Actual</help>
	    <condicion operador="!=">4</condicion>
                <options>

                    <option valor="">Todas</option>

                    <option valor="0">No Autorizada</option>
                    <option valor="1">Pendiente</option>
		    <option valor="2">Cumplida</option>
                    <option valor="3">Parcial</option>
                    <option valor="4">Anulada</option>
                </options>

        
      </field>
  <!--    <field id="ocpimp" suma="true" >
        <label>Monto </label>
        <help> Monto de la Orden de compra</help>
        <tipo>decimal</tipo>
      </field> -->
      
      
      <field id="artcod" deshabilitado="true" tabla="CPSMOVIM">
        <label>Art.</label>
        <help>Codigo de Articulo</help>
        <tipo>varchar</tipo>        
      </field>

      <field id="detalle" deshabilitado="true" tabla="CPSMOVIM">
        <label>Detalle</label>
        <help>Detalle de linea de la Orden de Compra para Art S.C. </help>
        <tipo>varchar</tipo>
      </field>
      <field id="observaciones" deshabilitado="true" tabla="CPSMOVIM">
        <label>Obs</label>
        <tipo>varchar</tipo>
      </field>

      <field id="movuso" deshabilitado="true" tabla="CPSMOVIM">
        <label>Ped.</label>
	<expression>ROUND(movuso, 2)</expression>
        <help>Pedido (expresado en la unidad de uso)</help>
      </field>
      <!--<field id="mov_pen" deshabilitado="true">
        <expression>movuso - penuso</expression>
        <label>Rec.</label>
        <help>Recibido (expresado en la unidad de uso) </help>
      </field>-->
      <field id="penuso" deshabilitado="true" tabla="CPSMOVIM">
        <label>Pend</label>
	<expression>ROUND(penuso, 2)</expression>
        <help>Pendiente (expresado en la unidad de uso) </help>
      </field>
      
      <field id="artuni_exp2" deshabilitado="true">
        <expression>STKINSUM.artuni</expression>
        <label>U.Uso</label>
        <help>Unidad de Uso</help>
        <tabla_ex id="FSMUNIDS">
          
          <field id="unicod" clave="true"></field>
          <field id="uninom"></field>
        </tabla_ex>
      </field>

      <field id="movcps" deshabilitado="true" tabla="CPSMOVIM">
        <label>Ped.cps</label>
        <help>Pedido (expresado en la unidad de compra)</help>
         <expression>ROUND(movcps, 2)</expression>
      </field>
    <!--  <field id="mov_pen2" deshabilitado="true">
        <expression>movcps - pencps</expression>
        <label>Rec</label>
        <help>Recibido (expresado en la unidad de compra)</help>
      </field> -->
      <field id="pencps" tabla="CPSMOVIM">
        <label>Pend.cps</label>
	<expression>ROUND(pencps, 2)</expression>
        <help>Pendiente (expresado en la unidad de compra)</help>
      </field>
      <field id="artuni_exp3" deshabilitado="true">
        <expression>STKINSUM.unicps</expression>
        <label>U.Compra</label>
        <help>Unidad de Compra</help>
        <tabla_ex id="FSMUNIDS">
          
          <field id="unicod" clave="true"></field>
          <field id="uninom"></field>
        </tabla_ex>
      </field>      
      <order>
        <field id="CPSENCAB.ocpnro" />
        <field id="ocpfec" />

      </order>
<!--
      <filters>
        
        <field id="ctacod">
          <operador>=</operador>
          <label>Proveedor</label>
          <valor>0</valor>
        </field>

        
        <field id="ocpfec">
          <operador>>=</operador>
          <label>Desde Fecha</label>
        </field>
        <field id="ocpfec">
          <operador>&lt;=</operador>
          <label>Hasta Fecha</label>
          <valor>today</valor>
        </field>
        <field id="ocpest">
          <operador>=</operador>
          <label>Estado</label>
          <valor>1</valor>
          
        </field>
        
      </filters>
-->      
    </table>
    <join tipo="left">
      <table id="CPSMOVIM">
        <field id="siscod" oculto="true">
          <condicion operador="=">CPSENCAB.siscod</condicion>
        </field>
        <field id="ocpnro" oculto="true">
          <condicion operador="=">CPSENCAB.ocpnro</condicion>
        </field>
	 <field id="movfec" oculto="true">
          <condicion operador="=">CPSENCAB.ocpfec</condicion>
        </field>
        <!--<field id="pencps" oculto="true">
          <condicion operador="!=">0</condicion>
        </field>
        -->
      </table>
    </join>        
    <join tipo="left">
      <table id="STKINSUM">
        <field id="siscod" oculto="true">
          <label>STKINSUM.siscod</label>
          <condicion operador="=">'01'</condicion>
        </field>
        <field id="artcod" oculto="true">
          <condicion operador="=">CPSMOVIM.artcod</condicion>
        </field>
        <field id="artuni" oculto="true">
        </field>
        <field id="unicps" oculto="true">
        </field>
      </table>
    </join>        
  </form>
</histrix>
