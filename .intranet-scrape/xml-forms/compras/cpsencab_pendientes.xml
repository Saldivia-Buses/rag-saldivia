<?xml version="1.0" encoding="ISO-8859-1"?>
<histrix tipo="consulta" noTabs="true" paginar="5">
    <title>ORDENES DE COMPRA</title>
    <obs></obs>
    <form _detalle="cpsmovim.xml" _inline="true">
        <table id="CPSENCAB" label="ORDENES DE COMPRA">
            <field id="siscod" oculto="true">
                <condicion operador="=">''</condicion>
            </field>

            <field id="ocpest" oculto="true">
                <label>Estado </label>
                <help>Estado Actual</help>
                <condicion operador="=">1</condicion>

            </field>
            <field id="ocpfec" tipoOrden="DESC">
                <label>Fecha</label>
                <help>Fecha de Orden de Compra. </help>
            </field>
            <field id="ocpnro" linkint="cpsmovim.xml" linkdes="Detalle OC">
        	<paring destino="ocpnro">ocpnro</paring>
                <label>Nro</label>
                <help>Numero de Orden de Compra. </help>
                <detalle>ocpnro</detalle>
            </field>
            <field id="ctacod" noshow="true">
                <label>Proveedor</label>
                <help>Proveedor</help>
                <ayuda_ex id="CCTCUENT" xml="HLPcctcuent.xml" dir="/help_local">


                    <field id="ctacod">
                        <label>Nro</label>

                    </field>
                    <field id="ctanom">
                        <label>Nombre</label>
                        <detalle>ctanom</detalle>

                    </field>
                    <field id="baja" noshow="true">
                        <label>baja</label>
                        <condicion operador="!=">1</condicion>
                    </field>
                    <field id="siscod" oculto="true">
                        <label>siscod</label>
                        <condicion operador="=">'01'</condicion>
                    </field>
                    <clave>ctacod</clave>
                    <descripcion>ctanom</descripcion>
                </ayuda_ex>
                <condicion operador="=">0</condicion>
                <!--<jseval campodestino="codprv">ctacod</jseval>				-->

            </field>
            <!--<field id="ctanom" local="true" deshabilitado="true">
                                <label modpos="nobr"></label>
                                <tipo>varchar</tipo>
                        </field> -->
            <field id="ctacod2">
                <expression>CONCAT(ctafan, ' (',ctanom,')')</expression>
                <label>Proveedor </label>
                <!--
                                <help>Codigo de Cuenta PROVEEDOR. </help>
                                <tabla_ex id="CCTCUENT">
                                <field id="ctacod"></field>
                                <field id="ctanom"></field>
                                </tabla_ex>
                                -->
                <tipo>string</tipo>

            </field>

            <field id="ocpfen2">
                <label>Entrega</label>
                <help>Fecha de Entrega </help>
                <expression>select max(fecreq) from CPSMOVIM where CPSMOVIM.ocpnro = CPSENCAB.ocpnro</expression>
                <tipo>date</tipo>
            </field>
            <order>
                <field id="ocpfec"></field>
            </order>
        </table>

        <join tipo="left">
            <table id="CCTCUENT">
                <field id="siscod" oculto="true">
                    <label>cctcuent.siscoc</label>
                    <condicion operador="=">'01'</condicion>

                </field>

                <field id="ctacod" oculto="true">
                    <condicion operador="=">CPSENCAB.ctacod</condicion>
                </field>

                <field id="ctanom" oculto="true">
                </field>
            </table>
        </join>

    </form>
</histrix>