<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="consulta">
	<title>HISTORICO</title>
	<obs></obs>
	<form >
		<table id="HTXLOG" label="Historico">

			<field id="xmlprog" oculto="true">
			    <condicion operador="in">('cps_movimientos_crud.xml' , 'cpsmovim_crud.xml', 'cps_movimientos_fichaing.xml' ) </condicion>
			</field>
			
			<field id="limit" local="true" noshow="true">
			    <setvar>limit</setvar>
			</field>
			<field id="maxfec" local="true" noshow="true" print="false">
				<label>1</label>
				<expression>case when fecha = DATE(NOW()) then 'font-size:14px;color:red;font-weight:bold;' 
				when fecha = DATE(NOW()) -1  then 'font-size:14px;color:blue;font-weight:bold;' 
				end</expression>
				<tipo>varchar</tipo>
            </field>
			<field id="num" noshow="true" local="true" />
			<field id="fec" noshow="true" local="true" />
			<field id="fecha" _noshow="true" style="text-align:left;"  tipoOrden="DESC" PDFnolabel="true" PDFcolWidth="25">
				 <label getStyle="maxfec">Fecha</label>
				 <condicion operador="&gt;=">'[__fec__]'</condicion>
				 
			</field>
			<field id="idLog" noshow="true"  tipoOrden="DESC">
			</field>
			
			<field id="hora2" _noshow="true" style="text-align:right;text-indent:15px;" PDFcolWidth="20">
			    <expression>TIME_FORMAT(hora, '%h:%i')</expression>
			    <label>hora</label>
			    <size>15</size>
			</field>
			<field id="color" deshabilitado="true" clasefila="true" noshow="true">
				<expression>case when fecha = DATE(NOW()) then 'resaltado font17' 
		                        when fecha = DATE(NOW()) - 1 then 'resaltadoVioleta font14' else '' end </expression>
			</field>
			
			<field id="user" _noshow="true"  style="text-align:center;text-indent:10px;" PDFcolWidth="30">
				<expression>CONCAT(HTXUSERS.apellido, ' ', LEFT(HTXUSERS.Nombre, 1), '.')</expression>
			<label>Usuario</label>
			
			</field>
						
			<field id="tipo" _noshow="true" PDFcolWidth="20">
				<label>Acción</label>
				<expression>CASE tipo
					    WHEN "INSERT" THEN 'Creó'
					    WHEN "UPDATE" THEN 'Editó'
					    WHEN "" THEN 'Editó'
					    WHEN "DELETE" THEN 'Borró'
					    END
				</expression>
			</field>
			<field id="obs" noshow="true">
			    <condicion operador="like">
			    CONCAT('%Numero O.C%',[__num__],', Fecha%','[__fec__]','%') or HTXLOG.obs like CONCAT('%',[__num__],'%') or HTXLOG.valorViejo = [__num__]
			    </condicion>
			    <label>obs</label>
			</field> 

							
			<field id="acc">
				<label></label><!--
				<expression>case when tipo="UPDATE" then CONCAT('&lt;b&gt; ', campo, '&lt;/b&gt;: ' , valorNuevoTxt ) else 
					'' end</expression> -->
				<expression>case tipo
				when "UPDATE" then CONCAT('&lt;b&gt; ', campo, '&lt;/b&gt;: ' , valorNuevoTxt )
				when "INSERT" then CONCAT('&lt;b&gt; ', REPLACE(SUBSTRING(obs, LOCATE('Articulo',obs, 1)), "'", ""), '&lt;/b&gt;: ')
				when "" then HTXLOG.obs
				else 'Artículo de la OC' end</expression>
				<tipo>editor</tipo>
				<size>180</size>
			</field>
			<order>
			<field id="idLog"/>

			</order>			
		</table>
		<join tipo="left">
			<table id="HTXUSERS">
				<field id="login">
					<condicion operador="=">HTXLOG.usuario</condicion>
				</field>
			</table>
			
		</join>
	</form>	   
</histrix> 
