<?xml version="1.0" encoding="UTF-8"?>
<histrix  tipo="consulta">
    <title>MAILS</title>
    <obs/>
    <form >
        <table id="HTXMAIL" label="enviar Correo" styleTbody="height:325px;overflow-x:hidden;">
            <field  id="idMail" noshow="true" tipoOrden="DESC" oculto="true">
                <label>id</label>
            </field>
            <field id="fecha"  deshabilitado="true" >
		        <helper type="link" xml="email_qry.xml" dir="/histrix/mensajeria">
		            <parameter source="idMail" target="idMail" operator="="/>
		        </helper>
                <tipo>date</tipo>
            </field>
            <field  id="hora"  deshabilitado="true" noshow="true">
                <label modpos="nobr">Hora</label>
                <valor eval="true">date('H:i:s')</valor>
                <tipo>varchar</tipo>
            </field>
            <field deshabilitado="true" id="fromMail"  oculto="true">
                <label>de</label>
                <help></help>
            </field>
            <field id="to_email" noshow="true">
                <label colspan="4">Para</label>
                <size>60</size>
            </field>
            <field id="subject" noshow="true">
                <label colspan="4">Asunto</label>
                <tipo>varchar</tipo>
                <size>60</size>
            </field>
<!--            <field id="checkAdjunto" >
                 <label colspan="4">Adjunto</label>
                <tipo>check</tipo>
            </field> -->
            <field id="fileAttach" noshow="true">
                <label colspan="4">Adjuntos</label>
                <size>50</size>
            </field>

            <field id="body"  noshow="true">
                <label colspan="3">mensaje</label>
                <help>Texto del mensaje</help>
                <size>200</size>
				<tipo>editor</tipo>
            </field>
	    <order>
		<field id="idMail" />
	    </order>
        </table>
    </form>
</histrix>
