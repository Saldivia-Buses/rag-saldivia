		<field id="movcps" tabla="CPSMOVIM">
		    <label>Pedido</label>
		    <tipo>custom_numeric</tipo>
		</field>
		<field id="movrec" tabla="CPSMOVIM" noZero="true">
		    <label>Recibido</label>
		    <expression>CPSMOVIM.movcps - CPSMOVIM.pencps</expression>
		    <tipo>custom_numeric</tipo>
		</field>
		<field id="pencps" tabla="CPSMOVIM">
		    <label>Pendiente</label>
		    <tipo>custom_numeric</tipo>
		</field>
            	 <field id="pendiente" noshow="true">
		    <expression having="false">movcps - pencps</expression>
		    <condicion operador="&lt;">movcps</condicion>
		</field>
