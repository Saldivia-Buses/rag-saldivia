<?xml version="1.0"  encoding="UTF-8" ?>
   <histrix tipo="consulta" _imprime="false" >
   <title>MOVIMIENTOS</title>
    <obs></obs>
      <form detalle="cpsmovim.xml" xmldir="/compras" inline="true">
      <table id="CPSENCAB" label="MOVIMIENTOS">
                
		<filters>
			<field id="ctacod">
				<operador>=</operador>
				<label>Proveedor</label>
			</field> 

			<field id="ocpnro" >
				<label modpos="nobr">O.Compra</label>
				<operador>=</operador>
			</field>


			<field id="ocpest">
				<operador>=</operador>
				<label modpos="nobr">Estado</label>
				<valor>1</valor>
			</field>

			<field id="artcod" tabla="CPSMOVIM">
			  <operador>=</operador>
			  <label>Cod.Art</label>
			</field>

			<field id="artdes" modpos="nobr">
			  <operador>like</operador>
			  <label>Nombre Artículo</label>
			  <size>30</size>
			</field>
			
			<field id="hastareq" local="true">
			    <label >Hasta Fec. Req.</label>
			    <tipo>date</tipo>
			    <valor>today</valor>
			</field>

		</filters>

		<field id="ocpnro2" tipoOrden="DESC" noshow="true">
			<expression>CPSENCAB.ocpnro</expression>
		</field>

		<field id="ocpnro" _linkint="cpsencab_marco_cum2.xml" _linkdes="Marcar Como Cumplida">
			<paring destino="ocpnro">ocpnro</paring>
			<label>O.Compra</label>
			<help>Número de Orden de Compra</help>
			<detalle>ocpnro</detalle>
		</field>

		<field id="siscod" noshow="true">
			<detalle>siscod</detalle>
		</field>

		<field id="ctacod" print="false">
			<label>Proveedor</label>
			<help>Código de Cuenta PROVEEDOR</help>
			<ayuda_ex id="CCTCUENT">
				<field id="ctacod" clave="true" muestra="false"></field>
				<field id="nombre">
				    <expression>CONCAT(ctanom, ' (', ctafan,')')</expression>
				</field>
				<field id="siscod" oculto="true">
					<condicion operador="=">'01'</condicion>
				</field>
				<field id="baja">
					<condicion operador="!=">1</condicion>
				</field>
				<order>
					<field id="ctanom"></field>
				</order>
			</ayuda_ex>
			<tipo>integer</tipo>
		</field>
        
		<field id="ctanom" tabla="CCTCUENT"  print="false">
			<tipo>varchar</tipo>
			<label>Nombre</label>
		</field> 
		
		<field id="subjectpr" noshow="true">
		    <expression>CONCAT('Orden de Compra Nro ',CPSENCAB.ocpnro)</expression>
		    <detalle>subjectpr</detalle>
		</field>
		<field id="artcod" tabla="CPSMOVIM" >
		    <label>Cod</label>
          <ayuda_ex id="STKINSUM" xml="HLPstkinsum.xml" dir="/help_local">
            <field id="artcod">
              <label>Cod.</label>
              <detalle>artcod</detalle>
            </field>
            <field id="artdes">
              <label>Insumo</label>
              <detalle>artdes</detalle>
            </field>
            <field id="unicps" oculto="true">
              <detalle>unimed</detalle>
            </field>
            <field id="artuni" oculto="true">
              <detalle>artuni</detalle>
            </field>
            <field id="siscod" oculto="true">
              <condicion operador="=">'01'</condicion>
            </field>
            <clave>artcod</clave>
            <descripcion>artdes</descripcion>
          </ayuda_ex>

		</field>
		<field id="artdes" tabla="STKINSUM" >
		    <label>nombre</label>
			  <size>30</size>

		</field>

