		    <tipo>date</tipo>
		</field>
		<field id="fecrec" >
			<label>Entrega</label>
			<expression having="false">CPSMOVIM.fecreq</expression>
			<condicion operador="&lt;=">STR_TO_DATE('[__hastareq__]', '%d/%m/%Y')</condicion>
			<tipo>date</tipo>
