<?xml version="1.0"  encoding="UTF-8" ?>                 
<histrix tipo="ing" subtipo="vertical" procesa="false" _deleteRow="false" log="false">
    <title>DETALLE</title>
    <obs></obs>
    <form  >
        <table id="CPSMOVIM" label="DETALLE">
	    <movimientos>
		<relacion id="cpsmovim_insert_upd.xml" />
		<relacion id="pedidoint_return.xml" />
		<relacion id="cpsmovim_del.xml" />
	    </movimientos>
	    <field id="id_cpsmovim" noshow="true" esClave="true"/>


            <field id="ocpnro" Formstyle="display:none;" colstyle="display:none;" oculto="true">
		<label>Numero O.C.</label>
            </field>

            <field id="movfec" Formstyle="display:none;" colstyle="display:none;" oculto="true">
		<label>Fecha</label>
		<tipo>date</tipo>
            </field>


            <field id="artcod">
                <label>Articulo</label>
                <help>Codigo de Articulo</help>
                <ayuda_ex id="STKINSUM" xml="HLPstkinsum.xml" dir="/help_local">
                    <field id="artcod" >
                        <label>Cod.</label>
                    </field>
                    <field id="artdes">
                        <label>Insumo</label>
                        <detalle>detalle</detalle>
                    </field>


                    <field id="unicps" oculto="true">
                        <detalle>unicps</detalle>
                    </field>

                    <field id="valcps" >
                        <detalle>valcps</detalle>
                    </field>
                    <field id="valuso" >
                        <detalle>valuso</detalle>
                    </field>
                    <field id="artuni" oculto="true">
                        <detalle>artuni</detalle>
                    </field>
                    <field id="siscod" oculto="true">
                        <condicion operador="=">'01'</condicion>
                    </field>
                    <field id="artiva" oculto="true">
                        <expression>select IVAIMPUESTOS.impali from IVAIMPUESTOS where impcod = artiva limit 1</expression>
                        <detalle>alicuota</detalle>
                    </field>
<!--
                    <field id="costo" >
                        <label>Costo</label>
                        <expression>round(case when ((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = STKINSUM.artcod and
			    STKINSPR.siscod='01' order by fecult DESC limit 1) ) > 0
			then ((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = STKINSUM.artcod and
			STKINSPR.siscod='01' order by fecult DESC limit 1))
			else STKINSUM.artcos end, 2)</expression>
                        <tipo>decimal</tipo>
                        <detalle>artcos</detalle>
                    </field>
-->


                                        <clave>artcod</clave>
                    <descripcion>artdes</descripcion>
                </ayuda_ex>
		<size>10</size>
            </field>
            <field id="detalle">
                <label modpos="nobr">Descripcion</label>
                <help>Detalle de linea de la Orden de Compra para Art S.C. </help>
		<size>40</size>
		<tipo>varchar</tipo>

            </field>
            <field id="observaciones">
                <label>Obs</label>
		<size>40</size>
            </field>
            <field id="movcps" incdec="true" preventLoop="true"><!-- Este campo está provocando error en algunas grabaciones -->
                <label>Pedido</label>
                <help>Pedido (expresado en la unidad de compra)</help>
                <jseval campodestino="movuso">(valcps == 1)?(movcps * valuso):(movcps / valcps)</jseval>
 <jseval campodestino="neto">((artcos * movcps ) - ((artcos * movcps) / 100 * bonificacion_1)) - (((artcos * movcps ) - ((artcos * movcps) / 100 * bonificacion_1)) / 100 * bonificacion_2)</jseval>
                <tipo>decimal</tipo>
            </field>

        <field id="pencps">
            <label>Pendi</label>
        </field>

        <field id="movcan" noshow="true"/>

        <field id="movpen" noshow="true"/>

        <field id="penuso" noshow="true"/>   

            <field id="unicps" deshabilitado="true" tabla="STKINSUM">
                <label modpos="nobr">U.Compra</label>
                <help>Unidad de Compra</help>
                <tabla_ex id="FSMUNIDS">
                    <field id="unicod" clave="true"></field>
                    <field id="uninom"></field>
                </tabla_ex>
                <tipo>integer</tipo>
            </field>
            <field id="valcps" noshow="true" tabla="STKINSUM">
                <label modpos="nobr">conversion1</label>
                <valor>1</valor>
		<tipo>numeric</tipo>
            </field>

            <field id="valuso" noshow="true" tabla="STKINSUM">
                <label modpos="nobr">conversion2</label>
                <valor>1</valor>
		<tipo>numeric</tipo>
            </field>
            <field id="movuso" preventLoop="true">
                <label>uso</label><!--
                <if exp="true" operador="=">
                    <true> (movcps / valcps) * valuso</true>
                    <false>0</false>
                </if>-->
                <jseval campodestino="movcps">(valuso == 1)?(movuso * valcps):(movuso / valuso)</jseval>
             <jseval campodestino="neto">((artcos * movcps ) - ((artcos * movcps) / 100 * bonificacion_1)) - (((artcos * movcps ) - ((artcos * movcps) / 100 * bonificacion_1)) / 100 * bonificacion_2)</jseval>                
   
                <tipo>decimal</tipo>
            </field>
            <field id="artuni" deshabilitado="true" tabla="STKINSUM">
                <label modpos="nobr" >U.uso</label>
                <help>Unidad de Uso</help>
                <tabla_ex id="FSMUNIDS">
                    <field id="unicod" clave="true"></field>
                    <field id="uninom"></field>
                </tabla_ex>
                <tipo>integer</tipo>
            </field>

	    <field id="bonificacion_1">
		<label>B1%</label>
            <jseval campodestino="neto">((artcos * movcps ) - ((artcos * movcps) / 100 * bonificacion_1)) - (((artcos * movcps ) - ((artcos * movcps) / 100 * bonificacion_1)) / 100 * bonificacion_2)</jseval>
	    </field>
	    <field id="bonificacion_2">
		  <label modpos="nobr">B2%</label>
           <jseval campodestino="neto">((artcos * movcps ) - ((artcos * movcps) / 100 * bonificacion_1)) - (((artcos * movcps ) - ((artcos * movcps) / 100 * bonificacion_1)) / 100 * bonificacion_2)</jseval>
	    </field>
            <field id="moneda_id">
                <label modpos="nobr"> Moneda</label>
                <helper type="combo" xml="moneda_qry.xml" dir="/ayudas" _empty="true" />
            </field>
<!--	    
        <field id="abreviatura_moneda" tabla="GEN_MONEDAS" deshabilitado="true">
              <label modpos="nobr">Moneda</label>
        </field>
    -->    
            <field id="artcos" _deshabilitado="true">
                <tipo>decimal</tipo>
                <label _colspan="3">Precio</label>
<!--    <true>(((artcos * movcps ) - ((artcos * movcps) / 100 * bonificacion_1)) - (((artcos * movcps ) - 
((artcos * movcps) / 100 * bonificacion_1)) / 100 * bonificacion_2))</true>
-->
                <jseval campodestino="neto">((artcos * movcps ) - ((artcos * movcps) / 100 * bonificacion_1)) - (((artcos * movcps ) - ((artcos * movcps) / 100 * bonificacion_1)) / 100 * bonificacion_2)</jseval>                
            </field>

	    <field id="neto" local="true" suma="true" deshabilitado="true">
		<label modpos="nobr">Neto</label>
		<if exp="true">
		<true>round(((artcos * movcps ) - ((artcos * movcps) / 100 * bonificacion_1)) - (((artcos * movcps ) - ((artcos * movcps) / 100 * bonificacion_1)) / 100 * bonificacion_2) , 2)</true>
		<false>0</false>
		</if>
                <jseval campodestino="importe_iva">neto / 100 * alicuota</jseval>
                <jseval campodestino="importe_total">neto + importe_iva</jseval>

	    </field>

            <field id="alicuota" deshabilitado="true">
                <label modpos="nobr">Alic</label>
                <expression>select IVAIMPUESTOS.impali from IVAIMPUESTOS where impcod = STKINSUM.artiva limit 1</expression>
		<jseval campodestino="importe_iva">artcos * movcps / 100 * alicuota</jseval>
                <jseval campodestino="importe_total">artcos * movcps + importe_iva</jseval>

            </field>

            <field id="importe_iva" deshabilitado="true" suma="true">
                <label modpos="nobr">Iva</label>
                <if exp="alicuota + 0 &gt; 0">
                    <true>round(neto * alicuota / 100, 2)</true>
                    <false>0</false>
                </if>

            </field>
            <field id="importe_total" suma="true" deshabilitado="true">
                <label colspan="3" modpos="nobr">Total</label>
		<jseval fielddestino="new_total" total="true">(importe_total).toFixed(2)</jseval>

                <if exp="true">
                    <true> round(neto + importe_iva, 2)</true>
                    <false>0</false>
                </if>
		<tipo>numeric</tipo>
            </field>

            <field id="fecreq" >
                <label>F.Entrega</label>
                <tipo>date</tipo>
            </field>
            <field id="nrocha" _Formstyle="display:none;">
                <label>N.Fab</label>
                <tipo>varchar</tipo>
                <size>5</size>
            </field>
	    <field id="idPed" noshow="true">
	    </field>
	    <field id="nrocom" tabla="PEDIDOINT" Formstyle="display:none;">
		<label>N.Ped</label>
	    </field>
	    <field id="borrar" local="true" Formstyle="display:none;">
		<label>Borrar</label>
		<tipo>check</tipo>
	    </field>
            <order>
                <field id="fecreq"></field>
            </order>
        </table>
        <join tipo="left">
            <table id="STKINSUM">
                <field id="siscod" >
                    <condicion operador="=">'01'</condicion>
                </field>
                <field id="artcod">
                    <condicion operador="=">CPSMOVIM.artcod</condicion>
                </field>
                <field id="artuni">
                </field>
                <field id="unicps">
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="PEDIDOINT">
                <field id="idPed" >
                    <condicion operador="=">CPSMOVIM.idPed</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="GEN_MONEDAS">
                <field id="id_moneda" >
                    <condicion operador="=">CPSMOVIM.moneda_id</condicion>
                </field>
            </table>
        </join>
    </form>
</histrix>
