            <field id="count" local="true">
                <label>Cantidad</label>
                <size>3</size>
                <jseval campodestino="recurringrule" actxml="false">\'FREQ=\' + \'freq\'+\';\'+\'COUNT=\'+ count +\';\'+\'BYDAY=\'+ \'dia\'+\';\'</jseval>
                </field>
            <field id="dia" local="true">
                <label>dia</label>
                <options>
                    <option valor=""></option>
