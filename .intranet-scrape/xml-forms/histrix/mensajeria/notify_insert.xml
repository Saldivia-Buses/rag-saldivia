<?xml version="1.0" encoding="UTF-8"?>
<histrix before="false" evento="insert" tipo="insert">
  <title>read message</title>
  <obs/>
  <form>
    <table id="HTXMESSAGES" label="Marca Leidos">
      <field id="de">
        <valor eval="true">$_SESSION['usuario']</valor>
      </field>
      <field id="para" id_temp="to_login"/>
      <field id="mensaje" id_temp="message"/>
      <field id="fecha">
        <valor>date(now())</valor>
        <tipo>integer</tipo>
      </field>
      <field id="hora">
        <valor>TIME_FORMAT(NOW(), '%H:%i:%s')</valor>
        <tipo>integer</tipo>
      </field>
      <field id="idEvento">
        <valor>-1</valor>
      </field>
    </table>
  </form>
</histrix>
