<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta">
  <title>Agenda</title>
  <obs/>
  <form>
    <table id="HTXADDRESSBOOK">
      <field id="name1">
        <label>Nombre</label>
        <expression>concat(first_name, ' ', last_name)</expression>
      </field>
      <field id="value">
        <label>email</label>
      </field>
      <field id="vcard_type" noshow="true">
        <condicion operador="like">'%EMAIL%'</condicion>
      </field>
      <order>
        <field id="name"/>
      </order>
    </table>
  </form>
</histrix>
