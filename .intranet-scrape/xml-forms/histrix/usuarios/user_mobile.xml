<?xml version="1.0" encoding="UTF-8"?>
<histrix path="fotos/usuarios" tipo="ficha" onDuplicateKey="true"
imprime="false"
borra="false" preFetch="true">
    <title>Usuarios</title>
    <obs/>
    <form >
        <table id="HTXUSERS" label="Usuarios">
			
            <field id="Id_usuario" esClave="true" noshow="true" autoinc="true">
                <label>ID Usuario</label>
                <help></help>
            </field>
            <field id="login" deshabilitado="true">
                <label>Login</label>
                <help>Login de entrada al sistema</help>
            </field>
            <field id="Nombre">
                <label>Nombre</label>
                <help></help>
            </field>
            <field id="apellido">
                <label>Apellido</label>
                <help></help>
            </field>
            
            <field foto="true" id="foto" path="Id_usuario">
                <label >Foto</label>
                <tipo Type="Image">file</tipo>
                <size>60</size>
            </field>
            
            
            <field id="pass">
                <label>password</label>
                <help>Password de entrada al sistema</help>
                <tipo Type="password" >varchar</tipo>
            </field>
		
            <field id="telefono">
                <label >Teléfono</label>
			
            </field>
            <!--
            <field id="interno">
                <label >Nro Interno</label>
            </field>
            -->
