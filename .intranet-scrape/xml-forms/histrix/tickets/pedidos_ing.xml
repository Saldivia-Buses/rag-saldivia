<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="abm-mini" class="consultaancha" _width="50" subtipo="vertical" path="/archivo/htxtickets/" paginar="100">
  <title>Pedidos de Soporte</title>
  <form>
    <table id="HTXTICKETS">
      <title>Pedidos de Soporte</title>
      <filters>
        <field id="CUMP" deshabilitado="false">
          <label>Cumplido</label>
          <operador>=</operador>
        </field>
      </filters>

      <field id="id_ticket" deshabilitado="true" autoinc="true"  tipoOrden="DESC">
        <label>Nro Pedido</label>
        <help>Numero de Pedido</help>
      </field>

      <field id="login_ticket" deshabilitado="true">
        <label>Usuario</label>
        <help>Usuario que hace el pedido</help>

        <valor eval="true">$_SESSION['usuario']</valor>
      </field>

      <field id="yo" local="true" noshow="true">
        <valor eval="true">"'".$_SESSION['usuario']."'"</valor>
        <tipo>varchar</tipo>
      </field>

      <field id="editable" local="true" bloqueafila="true" noshow="true" >
        <label>Editable</label>
        <if exp="'yo'=='login'">
          <true>"1"</true>
          <false>"0"</false>
        </if>
        <tipo>varchar</tipo>
      </field>

      <field id="fecha_ticket" deshabilitado="true" esclave="true" valauto="true">
        <label>Fecha</label>
        <help>Fecha</help>
        <valor>today</valor>
      </field>

      <field id="tktprioridad_id">
        <label>Prioridad</label>
        <helper type="combo">
           <option value="1">Baja</option>
           <option value="2">Media</option>
           <option value="3">Alta</option>
           <option value="4">Urgente</option>
         </helper>
      </field>


      <field id="libro_ticket" >
        <label colspan="4" style="color:green">Pedido</label>
        <help>Encabezado del Pedido</help>
        <size>250</size>
        <tipo>varchar</tipo>
      </field>

      <field id="observaciones_ticket" deshabilitado="true">
        <label colspan="4">Observaciones</label>
        <help>Descripcion y Observaciones del Pedido</help>
        <tipo>varchar</tipo>
      </field>
<!--
      <field id="fotos" local="true" imageWidth="165" path="id_ticket">
        <expresion>CONCAT('/archivo/htxtickets/',id_ticket,'/')</expresion>
        <label posX="5" posY="+2" formStyle="display:none;">Dir</label>
        <tipo>dir</tipo>
      </field>
-->
      <field id="fotos" local="true" imageWidth="165" path="id_ticket">
        <expresion>CONCAT('/archivo/htxtickets/',id_ticket,'/')  </expresion>
        <label posX="5" posY="+2" formStyle="display:none;">Dir</label>
        <tipo>dir</tipo>
      </field>

      <field id="cumplido" deshabilitado="true">
        <label>Cumplido</label>
        <help>Cumplido</help>
      </field>

      <field id="CUMP" noshow="true">
        <expresion>case when cumplido ='0000-00-00' then 1 else 0 end</expresion>
        <options>
          <option valor="">Todos</option>
          <option valor="0">Cumplidos</option>
          <option valor="1">Pendientes</option>
        </options>
      </field>

      <field id="pend" local="true" clasefila="true" noshow="true" >
        <expresion>case when cumplido ='0000-00-00' then 'resaltado' else '' end</expresion>
        <tipo>varchar</tipo>
      </field>

      <order>
        <field id="id_ticket" ></field>
        <field id="fecha_ticket" ></field>
        <field id="cumplido" ></field>
      </order>

    </table>

  </form>

</histrix>
