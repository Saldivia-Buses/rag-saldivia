			<field id="carnro">
			<label>Nro. Cheque</label>
			<help>Numero de Cheque.</help>
			</field>
			<!--
			<field id="carobv">
			<label>Plaza Bancaria </label>
			<help>Plaza Bancaria. </help>
			</field>
			<field id="carpla">
			<label>Cod.Plaza            . </label>
