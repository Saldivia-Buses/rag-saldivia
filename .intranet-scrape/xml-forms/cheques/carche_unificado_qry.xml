<?xml version="1.0" encoding="ISO-8859-1"?>
<histrix tipo="consulta" preloadData="false">
	<title>CARTERA DE CHEQUES GRAL</title>
	<obs></obs>
	<form >
	<!-- detalle="cctmovim_OP.xml" -->
		<table id="CARCHE_UNIFICADA" label="CARTERA DE CHEQUES GRAL">
			<filters>
				<field id="carint">
					<label>Numero Interno</label>
					<valor></valor>
					<operador >=</operador>

				</field>
				<field id="carcui">
				    <label>CUIT</label>
				    <operador>like</operador>
				</field>

				<field id="carnro">
					<!-- Creo un modificador al operador que cambia 
					la parte izquierda de las comparaciones
					Aca Agrego right(valor, length(valor ingresado))
					-->
					<operador modificador="right">=</operador>
					<label>Numero Cheque</label>
					<valor></valor>
				</field>

				<field id="tabla">
					<label modpos="nobr">Estado</label>
					<operador>like</operador>
					<valor></valor>
				</field>
				<field id="caralt">
					<label>Desde Fecha Alta</label>
					<help>Fecha del cheque Alta. </help>
					<operador>&gt;=</operador>
				</field>
				<field id="caralt">
					<label modpos="nobr">Hasta Fecha Alta</label>
					<help>Fecha del cheque Alta. </help>
					<operador>&lt;</operador>
				</field>
				<field id="caring">
					<label modpos="br">Desde Fecha Salida</label>
					<help>Fecha del cheque ingresado. </help>
					<operador>&gt;=</operador>
				</field>
				<field id="caring">
					<label modpos="nobr">Hasta Fecha Salida</label>
					<help>Fecha del cheque ingresado. </help>
					<operador>&lt;</operador>
				</field>			
				<field id="carfec">
					<label>Desde Fecha Cobro</label>
					<help>Fecha del cheque</help>
					<operador>&gt;=</operador>
				</field>
				<field id="carfec">
					<label modpos="nobr">Hasta Fecha Cobro</label>
					<help>Fecha del cheque</help>
					<operador>&lt;</operador>
					<valor>today</valor>

                </field>


				<field id="carimp">
					<label>Desde Importe</label>
					<operador>&gt;=</operador>
				</field>			
				<field id="carimp">
					<label modpos="nobr">Hasta Importe</label>
					<operador>&lt;=</operador>
				</field>			
				<field id="cartera_id">
					<label>Cartera</label>
					<operador>=</operador>
				</field>
			        <field id="ctanom" tabla="CCTCUENT" deshabilitado="false" >
				         <label>Cuenta</label>
					<operador>like</operador>
				
			        </field>				

			</filters>

			<field id="siscod" oculto="true">
				<label>Codigo Sistema.. </label>
				<help>
				</help>
			</field>

			<field id="carint">
				<label>Nro.Interno</label>
				<help>
				</help>
			</field>
				<field id="carcui">
				    <label>CUIT</label>
				</field>

			<field id="tabla">
				<label>Estado</label>
				<helper type="combo">
					<option value="">Todos</option>
					<option value="CARCHEHI">Historico</option>
					<option value="CARCHEQU">En cartera</option>
				</helper>
				<size>40</size>
			</field>
			<!--                  <field id="cartip">
			<label>Tipo Cheque </label>
			<help>[1/Enter] = Al Portador   *   [2] = A la orden </help>
			</field>
			-->
			<field id="carfec">
				<label>Fec.Cobro</label>
				<help>Fecha del cheque ingresado. </help>
			</field>
			<field id="caralt">
				<label>Fecha Alta </label>
				<help>Fecha de Ingreso del cheque en cartera. </help>
			</field>
		<!--	<field id="fecha_emision">
				<label>Fec.Emision</label>
				<help>Fecha de emision. </help>
				<tipo>date</tipo>
			</field>-->
			<field id="ctanom" tabla="CCTCUENT">
				<label>Cuenta</label>
				<help>
				</help>
				<tipo>varchar</tipo>
			</field>
			<field id="carbco">
				<label>Banco</label>
				<help>Nombre de Banco de Procedencia. </help>
			</field>
			<field id="carimp" suma="true">
				<label>Importe</label>
				<help>Importe del cheque. </help>
			</field>
			<field id="carpag" linkint="cctmovim_OP.xml" linkdes="Orden de Pago" print="false">
				<label>O.Pago</label>
				<help></help>
				<detalle>movnro</detalle>
				
				<expression>case when CCTMOVIM.concod = 4 then carpag else '' end</expression>
              
                <paring destino="movnro">movnro</paring>
                
                <paring destino="movfec">caring</paring>
             
      
                <tipo>varchar</tipo>
			</field>		
			

			
			<field id="carrec">
				<label>Recibo</label>
				<help></help>
			</field>			

			<!--
			<field id="bcsnro">
			<label>Bol.Deposito </label>
			<help>Boleta de Deposito. </help>
			</field>
			<field id="cajpla">
			<label>Nro.de Caja. </label>
			<help> </help>
