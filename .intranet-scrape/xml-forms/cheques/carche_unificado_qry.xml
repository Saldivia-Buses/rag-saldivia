			<field id="movnpv" noshow="true">
			<label>Nro. Punto Venta </label>
			<help> </help>
			</field>

			<field id="movnro" noshow="true">
			<label>Nro. Comprobante </label>
			<help> </help>
			</field>
			<!--
			<field id="opecla">
			<label>Firma Electronica </label>
			<help>Firma Electronica </help>
			</field>
			<field id="opecod">
			<label>Cod.Operador </label>
			<help> </help>
			</field> -->
			<field id="caring" >
				<label modpos="nobr">Ingreso</label>
				<help> </help>
				<detalle>movfec</detalle>
			</field>			
			<field id="regmin">
			<label>Minuta</label>
			<help>Numero de Minuta</help>
			</field>
			<field id="ctacod" _tabla="CCTMOVIM">
				<label>Prov.</label>
			</field>
			<field id="ctanom2" _tabla="CCTMOVIM">
				<expression>CCTMOVIM.ctanom</expression>
				<label>Nombre P.</label>
				<tipo>varchar</tipo>
			</field>			
<!--			<field id="succod">
			<label>Cod. Sucursal </label>
			<help>Codigo de Sucursal </help>
			</field>
			-->

			<field id="hihistorico" local="true" clasefila="true" noshow="true">
		       	<expression>CASE WHEN CARCHE_UNIFICADA.tabla = 'CARCHEHI' THEN 'resaltadoVioleta' ELSE '' END</expression>
    	    </field>
	    <field id="cartera_id" noshow="true">
			<helper type="combo" id="REG_CARTERAS_CHEQ" empty="true">
			    <field id="id_cartera" />
			    <field id="nombre_cartera" />
			</helper>
	    </field>
	    <field id="carref" noshow="true">
	    </field>
	    <field id="test">
	    	<label>Imagen</label>
	    	<expression>case when carref != '' then 'Imprimir' end</expression>
	    	<helper type="link" xml="cheque_imagenes.xml">
	    		<parameter source="carint" target="carint" />
	    		<parameter source="carref" target="carref" />

	    	</helper>
	    </field>



			<group>
				<field id="carint"></field>
			</group>

			<order>
				<field id="carint"></field>
			</order>
		</table>
		
		<join tipo="left">
			<table id="CCTCUENT">
				<field id="siscod" oculto="true">
					<label>cctcuent.siscoc</label>
					<condicion operador="=">'02'</condicion>
				</field>
				
				<field id="ctacod" oculto="true">
					<condicion operador="=">CARCHE_UNIFICADA.ctacod</condicion>
				</field>

			</table>
		</join>

		<join tipo="left">
			<table id="CCTMOVIM">
				<field id="siscod" >
					<condicion operador="=">'01'</condicion>
				</field>
				<field id="concod">
					<condicion operador="=">4</condicion>
				</field>
				<field id="movnro" >
					<condicion operador="=">CARCHE_UNIFICADA.carpag</condicion>
				</field>
				
			</table>
		</join>		
	</form>
</histrix>
