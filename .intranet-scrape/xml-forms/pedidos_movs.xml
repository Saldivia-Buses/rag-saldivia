<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="crud" subtipo="vertical" path="/fotos/archivo/pedidos_sistemas/" _inserta="false" paginar="50">
  <title>Movimiento de PEDIDOS</title>
  <obs></obs>
  <form  >
    <table id="PEDIDO_SITEMAS" label="CONSULTA DE PEDIDOS AL SISTEMA">

    <filters>
        <field id="idEstado" deshabilitado="false">
            <label>Cumplido</label>
            <operador>=</operador>
            <valor>1</valor>
        </field>
        <field id="login">
          <label modpos="nobr">De</label>
          <operador>=</operador>
        </field>
        <field id="user_administrador">
          <label modpos="nobr">Para</label>
          <operador>=</operador>
        </field>
        <field id="causa_sistema_pedido_id">
          <label modpos="nobr">Causa</label>
          <operador>=</operador>
        </field>
    </filters>

      <field id="idPedido" deshabilitado="true" tipoOrden="DESC" Formstyle="display:none;">
        <label >Nro Pedido</label>
        <help>Numero de Pedido</help>
        <attribute id="colstyle">pend</attribute>
      </field>

      <field id="idEstado" deshabilitado="false">
        <helper type="combo" xml="estadospedidos.xml" empty="true"/>
        <label>Estado Pedido</label>
        <help>Estado del Pedido</help>
        <attribute id="colstyle">pend</attribute>
      </field>

      <field id="fecha">
        <label>Fecha</label>
        <help>Fecha de Movimiento</help>
        <tipo>date</tipo>
        <valor>today</valor>
        <attribute id="colstyle">pend</attribute>
      </field>

      <field id="vencimiento">
        <label _modpos="nobr">Vencimiento</label>
        <help>Vencimiento</help>
        <tipo>date</tipo>
        <attribute id="colstyle">pend</attribute>
      </field>

      <field id="cumplido">
        <label _modpos="nobr">Cumplido</label>
        <help>Cumplido</help>
        <tipo>date</tipo>
        <attribute id="colstyle">pend</attribute>
      </field>

      <field id="login" _deshabilitado="true">
        <label>De</label>
        <help>Quien realizo el pedido</help>
        <helper type="combo" id="HTXUSERS" empty="true">
          <field id="login"></field>
          <field id="nombre">
            <expression>concat(Nombre, ' ', apellido)</expression>
            <condicion operador="!=">''</condicion>
          </field>
          <field id="baja">
            <condicion operador="=">0</condicion>
          </field>
          <order>
            <field id="nombre"></field>
          </order>
        </helper>
        <attribute id="colstyle">pend</attribute>
      </field>

      <field id="user_administrador" _deshabilitado="true">
        <label>Para</label>
        <help>Quien realiza el pedido</help>
        <helper type="combo" id="HTXUSERS" empty="true">
          <field id="login"></field>
          <field id="nombre">
            <expression>concat(Nombre, ' ', apellido)</expression>
            <condicion operador="!=">''</condicion>
          </field>
          <field id="baja">
            <condicion operador="=">0</condicion>
          </field>
          <field id="seccion_id">
            <condicion operador="=">30</condicion>
          </field>
          <order>
            <field id="nombre"></field>
          </order>
        </helper>
        <attribute id="colstyle">pend</attribute>
      </field>

      <field id="libro" cellMaxLength="250">
        <label>Pedido</label>
        <size>250</size>        
        <tipo>varchar</tipo>
        <attribute id="colstyle">pend</attribute>
      </field>
      
      <field id="observaciones">
        <label>Observaciones </label>
        <tipo>varchar</tipo>
        <size>250</size>
        <attribute id="colstyle">pend</attribute>
      </field>

      <field id="comentarios_internos">
        <label>Coment. Internos</label>
        <tipo>varchar</tipo>
        <size>250</size>
        <attribute id="colstyle">pend</attribute>
      </field>

     <field id="fotos" local="true" imageWidth="165" path="idPedido">
       <expression>CONCAT('/fotos/archivo/pedidos_sistemas/',idPedido,'/')  </expression>
       <label   posX="5" posY="+2">Dir</label>
       <tipo>dir</tipo>
        <attribute id="colstyle">pend</attribute>
     </field>


      <field id="idPrioridad">
        <label>Prioridad</label>
        <tabla_ex xml="prioridades.xml"></tabla_ex>
        <valor>2</valor>
        <attribute id="colstyle">pend</attribute>
      </field>

      <field id="fecha_hoy" local="true" noshow="true">
        <label>Fecha</label>
        <help>Fecha de Movimiento</help>
        <tipo>date</tipo>
        <valor>today</valor>
      </field>

      <field id="causa_sistema_pedido_id" _deshabilitado="true">
        <label>Causa</label>
        <help>Cual fue la causa</help>
        <helper type="combo" id="PEDIDO_SITEMAS_CAUSA" empty="true">
          <field id="id_pedido_sistema_causa"></field>
          <field id="nombre_pedido_sistema_causa"></field>
          <field id="esta_activo">
            <condicion operador="=">1</condicion>
          </field>
          <order>
            <field id="nombre_pedido_sistema_causa"></field>
          </order>
        </helper>
        <attribute id="colstyle">pend</attribute>
      </field>

      
      <field id="mailto"  deshabilitado="true" noshow="true">
        <expression>HTXUSERS.email</expression>
      </field>

      <field id="mailsubj" noshow="true" >
        <expression>CONCAT('Pedido IT ', idPedido)</expression>
      </field>

      <field id="mailbody" noshow="true">
        <expression><![CDATA[CONCAT('Recibimos su pedido: ', libro,' </br>Observaciones:', observaciones, ' </br>Fecha estimada de finalizacion: ', DATE_FORMAT(vencimiento, '%d/%m/%Y'),'</br></br>Saludos'   )]]>
        </expression>
      </field>

      <field id="mailbody_finish" noshow="true">
        <expression><![CDATA[CONCAT('Su pedido fue realizado: ', libro,' </br>Observaciones:', observaciones, '</br></br>Saludos'   )]]>
        </expression>
      </field>

        <field id="filtmail" noshow="true">
          <expression>CONCAT('+"Pedido IT" +', idPedido)</expression>
        </field>

      <field id="email" colstyle="width:auto;" deshabilitado="false" local="true" Formstyle="display:none;">
          <label>Inicio</label>
          <helper type="link" xml="mails_send.xml" dir="/histrix/mensajeria/" title="Pedido IT" width="700" height="600">
              <parameter source="mailto"  target="para" />
              <parameter source="mailsubj" target="subject" />
              <parameter source="mailbody" target="mensaje" />
          </helper>
          <expression><![CDATA['<img src="../img/mail_generic.png"/>']]></expression>
          <attribute id="colstyle">pend</attribute>
      </field>

      <field id="email_finish" colstyle="width:auto;" deshabilitado="false" local="true" Formstyle="display:none;">
          <label>Fin</label>
          <helper type="link" xml="mails_send.xml" dir="/histrix/mensajeria/" title="Pedido IT" width="700" height="600">
              <parameter source="mailto"  target="para" />
              <parameter source="mailsubj" target="subject" />
              <parameter source="mailbody_finish" target="mensaje" />
          </helper>
          <expression><![CDATA['<img src="../img/mail_generic.png"/>']]></expression>
          <attribute id="colstyle">pend</attribute>
      </field>

      <field id="filtmail_param" noshow="true">
        <expression>CONCAT('Pedido IT ', idPedido)</expression>
      </field>
      
      <field id="Emails" _showTablaObj="true" local="true" Formstyle="display:none;">
          <helper type="link" xml="email_subj_qry.xml" dir="/email">
              <parameter target="subject" source="filtmail_param" operator="like"/>
          </helper>
          <label>Correos</label>
          <help></help>
         <expression sql="true"><![CDATA[
          SELECT CONCAT(
          (SELECT COUNT(*)  FROM HTXMAIL WHERE MATCH(subject) AGAINST ('[__filtmail__]' IN BOOLEAN MODE)),' Env.')]]></expression>
          <attribute id="colstyle">pend</attribute>
      </field>

      <field id="pend" local="true" _clasefila="true" noshow="true" >
        <!--<expression>case when idEstado = 1 then (case when vencimiento &lt; str_to_date('[__fecha_hoy__]', '%d/%m/%Y') then 'resaltadoRojo' else 'resaltado' end) else (case when idEstado = 3 then 'resaltadoVerde' else '' end) end</expression>-->
        <expression>case when idEstado = 1 then (case when vencimiento &lt; str_to_date('[__fecha_hoy__]', '%d/%m/%Y') then 'background-color: #F5A9A9;' else 'background-color: #F2F5A9;' end) else (case when idEstado = 3 then 'background-color: #A9F5A9;' else '' end) end</expression>
        <tipo>varchar</tipo>
      </field>     

    <field id="xml_consulta" local="true" noshow="true">
      <valor>'pedidos_movs.xml'</valor>
    </field>

    <field id="nombre_id_registro" local="true" noshow="true">
      <valor>'Nro Pedido'</valor>
    </field>

    <field id="id_registro" local="true" noshow="true">
      <expression>idPedido</expression>
    </field>

    <field id="log" local="true" linkint="registros_log_qry.xml" linkdir="/calidad/qry/" linkdes="Historial" print="false" >
          <label>Hist</label>
          <paring destino="xml_consulta">xml_consulta</paring>   
          <paring destino="id_registro">id_registro</paring>   
          <paring destino="nombre_id_registro">nombre_id_registro</paring>   
      <expression>'Hist.'</expression>  
      <attribute id="colstyle">pend</attribute>
    </field>

      <order>
        <field id="pend" tipoOrden="ASC"></field>
        <field id="idPedido" ></field>
        <field id="fecha" ></field>
      </order>
      
    </table>

    <join tipo="left">
      <table id="HTXUSERS">
        <field id="login">
          <condicion operador="=">PEDIDO_SITEMAS.login</condicion>
        </field>
      </table>
    </join> 

  </form>
</histrix>
