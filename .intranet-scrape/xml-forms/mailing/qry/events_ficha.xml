<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="list" _dataSource="HtxMailgunEvents" _filter="true" _serverSide="true"  paginar="500" preFetch="true" sololectura="true" imprime="false" export="false">
  <title>Estadisticas</title>
  <obs/>
  <form >
    <table id="HtxMailgunEvents">

      <field id="id" noshow="true" esClave="true"/>

      <field id="fecha"  noshow="true">
	<expression>str_to_date(left(timestamp, 10), '%d/%c/%Y')</expression>
        <label>fecha</label>
	<tipo>date</tipo>
      </field>


      <field id="timestamp" noshow="true">
        <label>time</label>
      </field>

      <field id="event" noshow="true" >
        <label>event</label>
        <helper type="combo" >
          <option value=""></option>
          <option value="opened">Abierto</option>
          <option value="delivered">Enviado</option>
          <option value="accepted">Aceptado</option>
          <option value="rejected">Rechazado</option>

          <option value="failed">Fallo</option>
          <option value="unsubscribed">Desuscripto</option>
          <option value="complained">Reportado como Spam</option>

        </helper>
      </field>

<!--

      <field id="sender">
        <label>Sender</label>
      </field>
      <field id="from" >
        <label>From</label>

      </field>
      <field id="targets" noshow="true">
        <label>targets</label>
      </field>
      <field id="recipient">
        <label>recipient</label>
      </field>
      <field id="subject">
        <label>subject</label>
      </field>
      <field id="log_level" clasefila="true">
        <label>log-level</label>
      </field>
-->
      <field id="item" tdWidth="10em"  style="width:10em" noshow="true">
<!--	<expression><![CDATA[concat('<div style="width:40em;"><pre >', item, '</pre></div>')]]></expression> -->
        <label>item</label>
	<tipo>editor</tipo>
	<size>1000</size>
      </field>

      <field id="item2" _tdWidth="10em"  _style="width:10em" local="true">
	<if exp="true">
	    <true><![CDATA['<pre >'. json_encode(json_decode('item'), JSON_PRETTY_PRINT). '</pre>']]></true>
	    <false>''</false>
	</if>
        <label>item</label>
	<size>1000</size>
      </field>

      <field id="domain" noshow="true" local="true">
            <label>Domain</label>
            <valor eval="true">$_SESSION['properties']['domain']</valor>
      </field>

    </table>
  </form>
</histrix>