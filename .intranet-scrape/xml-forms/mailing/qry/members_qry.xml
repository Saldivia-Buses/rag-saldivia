<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="crud" dataSource="HtxMailgunMembers" filter="true" _serverSide="true">
  <title>Miembros</title>
  <obs/>
  <form >
    <table id="members" label="Miembros de la Lista">

      <field id="member_count" noshow="true" local="true"/>

      <field id="skip" noshow="true" local="true"/>

      <field id="list_id" oculto="true" />

      <field id="address" forceUpdate="true">
        <label>email</label>
        <size>80</size>
      </field>

      <field id="name">
        <label>Nombre</label>
        <size>80</size>
      </field>


      <field id="subscribed">
        <label>Suscripto</label>
        <tipo>check</tipo>
      </field>

      <!--field id="is_valid">
        <label>Valido</label>
        <tipo>check</tipo>
      </field -->

    </table>
  </form>
</histrix>