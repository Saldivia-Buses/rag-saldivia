      <field id="costoult" >
        <label>Costo</label>
        <expression>
round(
CASE WHEN tipocalculo_costo = 0 THEN

(case WHEN (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1) != 0 then (select sum(round( (costo_automatico * cantidad) * (1 + recargo / 100) , 2)) from STKPIEZA where idPadre  = STKINSUM.artcod limit 1)
                when valcps &gt; valuso then costo_calculado * valcps
                when valcps &lt; valuso then costo_calculado 

                when ( costo_calculado * STKINSUM.valcps / STKINSUM.valuso) > 0  then (costo_calculado * STKINSUM.valcps / STKINSUM.valuso) else STKINSUM.artcos end)

ELSE (SELECT artcos FROM STKINSPR sr WHERE sr.artcod = STKINSUM.artcod and sr.siscod = '01' ORDER BY fecult DESC LIMIT 1)

END                , 2)
              </expression>
        <tipo>numeric</tipo>
      </field>     
			
