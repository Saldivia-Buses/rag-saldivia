<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="crud" subtipo="vertical"  path="/fotos/archivo/Services/Envios" paginar="50" PDForientacion="L">
  <title>ENVIO DE REPUESTOS</title>
  <obs/>
  <form>
    <table id="SERVICE_ENVIOS" label="Envío de Repuestos">
      
      <filters>
	<field id="ctacod">
	    <label>Cliente</label>
	    <operador>=</operador>
	</field>
	<field id="nrofab">
	    <label modpos="nobr">Nro.</label>
	    <operador>=</operador>
	</field>

        <field id="sinfecha" deshabilitado="false">
          <label>Sin Fecha Fact</label>
          <operador>=</operador>
          <valor>1</valor>
        </field>

      <field id="fecha_envio">
        <label>Fecha Env Desde</label>
        <operador>&gt;=</operador>
      </field>
      
      <field id="fecha_envio">
        <label modpos="nobr">Fecha Env Hasta</label>
        <operador>&lt;=</operador>
      </field>

      </filters>

      <field id="id_serviceenvio" autoinc="true" esClave="true" deshabilitado="true" 
        _noshow="true" tipoOrden="DESC">
        <label modpos="nobr" Formstyle="display:none;">Envío</label>
        <help>Turno</help>
      </field>

      <field id="siscli" noshow="true" local="true">
        <valor>'02'</valor>
      </field>
<!--
      <field id="nro_envio" _deshabilitado="true">

        <label modpos="nobr" style="font-size:15px; color:red;">Numero</label>

        <help>Numero de Reparación/Service</help>
        <parametro id="envio_numerador.xml" retorna="numero2">
        <field id="nro_envio" noselect="true"></field>
      </parametro>
    </field>
  -->
    <field id="fecha_envio" tipoOrden="DESC" >
      <label modpos="nobr" >Fecha Env.</label>
      <tipo>date</tipo>
      <valor>today</valor>
    </field>
    <field id="fecha_recibido">
      <label modpos="nobr" >Fecha Rec.</label>
      <tipo>date</tipo>
    </field>
    <field id="fecha_factura">
      <label modpos="nobr">Fecha Factura</label>
      <tipo>date</tipo>
    </field>
    <field id="sinfecha" noshow="true">
      <expression>case when fecha_factura = '0000-00-00' then 1 else 0 end</expression>
      <label>sinfecha</label>
      <tipo>check</tipo>
    </field>

    <field id="ficha_id" noshow="true">
        <expression>PEDCOTIZ.id</expression>
    </field>

    <field id="nrofab"  noZero="true">
        <label modpos="nobr" style="text-align:center;color:#444;font-size:14px;">Fab</label>
        <help>Número de Fabricación</help>
            <paring destino="nrocha">nrofab</paring>
        <helper type="link" xml="ficha_producto1_qry.xml" dir="/producto" modal="true" title="Ficha Técnica">
            <parameter source="ficha_id" target="producto_id"/>
            <parameter source="nrofab" target="nrofab"/>
        </helper>
    </field>

      <field deshabilitado="true" id="ctacodot" local="true" linkint="fichas_x_cliente.xml" linkdes="Total de Coches" print="false">
      <expression>select count(*) from PEDCOTIZ as PED where PED.ctacod = SERVICE_ENVIOS.ctacod</expression>
      <label Formstyle="display:none;">Ot.</label>
      <help>Código de Cuenta</help>
      <paring destino="ctacod">ctacod</paring>
      <tipo>varchar</tipo>
    </field>

    <field id="ctacod" calendarSubject="true">
      <label modpos="nobr" >Cliente:</label>
      <help>Código de Cuenta</help>
      <helper type="external" id="CCTCUENT">
        <field id="ctacod"/>
        <field id="ctafan">
          <expression>LEFT(ctafan, 22)</expression>
        </field>
        <field id="siscod">
          <condicion operador="=">02</condicion>
        </field>
      </helper>
      <actualiza>
        <field destino="ctacod" id="idconta"/>
      </actualiza>
    </field>

    <field id="idconta" >
      <label modpos="nobr" colspan="4">Contacto</label>
      <help>Código de Cuenta</help>
      <helper type="combo" condes="true" id="CCTCONTA" empty="true">
        <field id="idconta"/>
        <field id="nombre">
          <expression>CONCAT(nombre,'-' , mail, ' - ', Telefono)</expression>
        </field>
        <field id="ctacod" oculto="true" ></field>
        <field id="siscod" oculto="true">
          <condicion operador="=">'02'</condicion>
        </field>
      </helper>
    </field>

    <field deshabilitado="true" id="ctacod2" tabla="PEDCOTIZ" linkint="cctconta_consulta.xml" linkdes="Ver medios de Contacto">
      <expression>SERVICE_ENVIOS.ctacod</expression>
      <label Formstyle="display:none;" style="width:auto;">Cliente</label>
      <help>Código de Cuenta</help>
      <tabla_ex condes="true" id="CCTCUENT">
        <field id="ctacod"/>
        <field id="ctafan">
          <expression>LEFT(ctafan, 17)</expression>
        </field>
        <field id="siscod" oculto="true">
          <condicion operador="=">'02'</condicion>
        </field>
      </tabla_ex>
      <paring destino="ctacod">ctacod</paring>
      <paring destino="siscod">siscli</paring>
      <tipo>button</tipo>
    </field>

    <field id="direccion">
      <label >Dirección</label>
      <size>50</size>
    </field>

    <field id="forma_envio" colspan="4" >
      <label modpos="nobr">Forma de Envío</label>
      <size>100</size>
    </field>

    <field id="articulos" obj="service_envio_articulo.xml" showObjTabla="true" showValor="true" linkint="service_envio_articulo.xml" linkdes="Artículos" local="true" >
      <label Formstyle="display:none;" colspan="5" >Artículos a enviar</label>
      <paring destino="serviceenvio_id" operador="=">id_serviceenvio</paring>
      <valor>Agregar / Modificar Artículos</valor>
      <tipo>varchar</tipo>
    </field>
    <!--
    <field id="numpath" noshow="true">
      <expression>nro_envio</expression>
    </field>
    <field id="archivos"   local="true" path="numpath" colstyle="display:none;" width="25">
      <label _Formstyle="width:10px;">Fotos.</label>
      <help></help>
      <tipo>file</tipo>
      <size>45</size>
    </field> 
  -->
    <field id="fotos" _imageWidth="165" watermark="chasis" style="white-space:nowrap;" Formstyle="display:none;" deshabilitado="true" _foto="true"  PDFcolWidth="11">
      <expression>CONCAT('/fotos/archivo/Services/Envios/', nro_envio,'/')</expression>
      <label>Fotos</label>
      <tipo>dir</tipo>
    </field>

    <field id="email"  colstyle="width:auto;" deshabilitado="false" local="true" Formstyle="display:none;">
      <helper type="link" xml="mails_send.xml" dir="/histrix/mensajeria/" title="Envio Repuestos" width="600" height="500">
        <!--<parameter source="mailto"  target="para" />
        <parameter source="mailsubj" target="subject" />
        <parameter source="mailbody" target="mensaje" />-->
      </helper>
      <expression >        <![CDATA['<img src="../img/mail_generic.png"/>' ]]>
      </expression>
    </field>

    <group>
      <field id="id_serviceenvio"/>
    </group>  

    <order>
      <field id="id_serviceenvio"/>
    </order>

  </table>
  <join tipo="left">
    <table id="PEDCOTIZ">
      <field id="nrocha">
        <condicion operador="=">SERVICE_ENVIOS.nrofab</condicion>
      </field>
    </table>
  </join>
</form>
</histrix>