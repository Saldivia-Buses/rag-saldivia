<?xml version="1.0" encoding="utf-8"?>
<histrix tipo="consulta" path="fotos/articulos">
  <title>COSTOS</title>
  <obs></obs>
  <form  detalle="cctcuent_x_insumo.xml" inline="true" >
    <table id="STKINMOV" label="CONSULTA DE COSTOS" _styleTbody="height:500px; overflow-x: hidden;">    
      
      <filters>
 <!--       <field id="fecha">
          <label>Fecha</label>
          <operador>&lt;=</operador>
        <valor>today</valor>          
        </field> -->

        <field id="movnro" esclave="true">
          <label>Presupuesto</label>
          <operador>=</operador>
        </field>

      </filters>

      <field id="siscod" esclave="true" noshow="true">
          <condicion operador="=">'SE'</condicion>
          <valor>SE</valor>
      </field>

      <field id="movcod" noshow="true">
          <label>movcod</label>
        <condicion operador="=">1</condicion>
      </field>    

      <field id="movnro" esclave="true">
          <label>Número</label>
<!--          <valor>1</valor>
          <condicion operador="=">1</condicion> -->
          <helper type="combo" id="NOTAENCA">
            <field id="movnro">
              <tipo>integer</tipo>
            </field>
            <field id="movref__1">
              <expression>CONCAT( CONVERT(movnro, CHAR), CONCAT(' - ', movref__1)) </expression>   
            </field>
            <field id="siscod" oculto="true">
              <condicion operador="=">'SE'</condicion>
            </field>
            <order>
              <field id="movnro"></field>
            </order>
            <filtra>movnro</filtra>
          </helper>
      </field>

      <field id="fecha" local="true" noshow="true">
        <label>Fecha</label>
        <operador>&lt;=</operador>
        <valor>today</valor>
        <tipo>date</tipo>
      </field>      

      <field id="artcod" esclave="true">
        <label>Código</label>
          <ayuda_ex id="STKINSUM" xml="HLPstkinsum.xml" dir="/help_local">
            <field id="artcod">
              <label>Cod.</label>
              <detalle>artcod</detalle>
            </field>
            <field id="artdes">
              <label>Insumo</label>
              <detalle>artdes</detalle>
            </field>
            <field id="unicps" oculto="true">
<!--              <detalle>unimed</detalle> -->
              <detalle>unicps</detalle>
            </field>
            <field id="artuni" oculto="true">
<!--              <detalle>unimed</detalle> -->
              <detalle>artuni</detalle>
            </field>
            <field id="valcps" oculto="true">
              <detalle>valcps</detalle>
            </field>
            <field id="valuso" oculto="true">
              <detalle>valuso</detalle>
            </field>            
            <field id="siscod" oculto="true">
              <condicion operador="=">'01'</condicion>
            </field>
            <clave>artcod</clave>
            <descripcion>artdes</descripcion>
          </ayuda_ex>     
        <detalle>artcod</detalle>
      </field>

      <field id="artdes" tabla="STKINSUM" >
        <expression>STKINSUM.artdes</expression>
        <label>Artículo</label>
        <tipo>varchar</tipo>
      </field>

      <field id="movpes"  >
        <label>Cantidad</label>
        <tipo>numeric</tipo>
      </field>

      <field id="valcps" noshow="true" tabla="STKINSUM">
      </field>

      <field id="valuso" noshow="true" tabla="STKINSUM">
      </field>

      <field id="uninom" tabla="FSMUNIDS" deshabilitado="true">
        <expression>FSMUNIDS.uninom</expression>
        <label>Unidad</label>
        <tipo>char</tipo>
      </field>
<!--      <field id="costo" >
        <label>Costo</label>
        <expression>STKINSUM.artcos * STKINSUM.valcps / STKINSUM.valuso</expression>
      </field> -->
      <field id="costo" >
        <label>Costo</label>
        <expression>round(case when ((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = STKINMOV.artcod and STR_TO_DATE('[__fecha__]', '%d/%m/%Y') >= STKINSPR.fecult  and STKINSPR.siscod='01' order by fecult DESC limit 1) * STKINSUM.valcps / STKINSUM.valuso) > 0  then ((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = STKINMOV.artcod and STR_TO_DATE('[__fecha__]', '%d/%m/%Y') >= STKINSPR.fecult  and  STKINSPR.siscod='01' order by fecult DESC limit 1) * STKINSUM.valcps / STKINSUM.valuso) else STKINSUM.artcos end, 2)</expression>
      </field>
      
      <field id="parcial"  suma="true">
        <label>Parcial</label>
        <expression>(case when ((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = STKINMOV.artcod and STR_TO_DATE('[__fecha__]', '%d/%m/%Y') >= STKINSPR.fecult  and STKINSPR.siscod='01' order by fecult DESC limit 1) * STKINSUM.valcps / STKINSUM.valuso) > 0  then ((select STKINSPR.artcos from STKINSPR where STKINSPR.artcod = STKINMOV.artcod and STR_TO_DATE('[__fecha__]', '%d/%m/%Y') >= STKINSPR.fecult and STKINSPR.siscod='01' order by fecult DESC limit 1) * STKINSUM.valcps / STKINSUM.valuso) else STKINSUM.artcos end) * movpes</expression>
        <tipo>numeric</tipo>
      </field>

      <field id="fecult" tabla="STKINSPR" tipoOrden="DESC">
        <expression>max(STKINSPR.fecult)</expression>
        <label>Últ.compra</label>
        <tipo>date</tipo>
      </field>

      <field id="fec2ult" tabla="STKINSPR" _noshow="true">
        <expression sql="true"><![CDATA[ select max(STKINS.fecult) from STKINSPR as STKINS where STKINS.artcod ='[__artcod__]' and '[__fecult__]' > STKINS.fecult  and STKINS.siscod='01' order by fecult DESC limit 1 ]]></expression>
        <label>Compra Ant</label>
        <tipo>date</tipo>
      </field>     

      <field id="cos2to" noshow="true">
        <label>Costo Ant</label>
        <expression sql="true"><![CDATA[ select round(STKINS.artcos * 0[__valcps__] / 0[__valuso__], 2) from STKINSPR as STKINS where STKINS.artcod ='[__artcod__]' and '[__fecult__]' > STKINS.fecult  and STKINS.siscod='01' order by fecult DESC limit 1 ]]></expression>
      </field>

      <field id="inc" local="true">
        <label>% Inc.</label>
        <if exp="0cos2to &lt; 0costo &amp;&amp; 0cos2to != 0">
          <true>round((0costo - 0cos2to) / 0cos2to * 100, 2)</true>
          <false>0</false>
        </if>
      </field>  

      <field id="hilite"  clasefila="true" local="true" noshow="true">
        <if exp="0inc > 0">
            <true>'resaltado'</true>
            <false>'0'</false>
        </if>
        <tipo>varchar</tipo>
      </field>

      <field id="ctacod" tabla="STKINSPR" >
        <expression>(select ctacod from STKINSPR where STKINSPR.artcod = STKINMOV.artcod and STR_TO_DATE('[__fecha__]', '%d/%m/%Y') >= STKINSPR.fecult  and STKINSPR.siscod='01' order by fecult DESC limit 1) </expression>
        <label>Proveedor</label>
        <tipo>varchar</tipo>
        <tabla_ex id="CCTCUENT">
          <field id="ctacod" />
          <field id="ctafan" />          
          <field id="siscod" oculto="true">
            <condicion operador="=">'01'</condicion>
          </field>
        </tabla_ex>
      </field>  

      <field id="ctbcod" print="false" tabla="CTBCUENT">
        <label>Nro Cta</label>
        <tipo>varchar</tipo>
      </field>

      <field id="ctbnom" tabla="CTBCUENT" print="false">
        <expression>ctbnom</expression>
        <label>CtaCtb</label>
        <tipo>varchar</tipo>
      </field>

      <field id="salida" >
        <label>Última Salida</label>
        <expression  sql="true" >select max(STKINMOV.movfec) from STKINMOV  where STKINMOV.artcod = '[__artcod__]' and  STKINMOV.siscod = '01' and STKINMOV.movcod = 10</expression>
        <tipo>date</tipo>
      </field>  

      <field id="fotopath" local="true" noshow="true">
        <if exp="true">
          <true>'artcod/'</true>
          <false>''</false>
        </if>
        <tipo>varchar</tipo>
      </field>

      <field id="foto" path="fotopath" download="true">
                <expression>select ARTICULO_FOTO.foto from ARTICULO_FOTO where ARTICULO_FOTO.idArticulo = STKINSUM.artcod limit 1</expression>
        <label>Imagen</label>
                <tipo >file</tipo>
                <size>40</size>
      </field>

      <group>
        <field id="STKINMOV.artcod" />
        <field id="STKINMOV.movfec" />
      </group>

      <order>
        <field id="artdes"></field>
        <field id="fecult" />
      </order>

    </table>
    <join tipo="left">
    
      <table id="STKINSUM">
        <field id="siscod" oculto="true">
          <label>siscod</label>
          <condicion operador="=">'01'</condicion>
    
        </field>
        <field id="artcod" oculto="true">
          <condicion operador="=">STKINMOV.artcod</condicion>
        </field>
    
      </table>
    </join>
    <join tipo="left">
    
      <table id="CTBCUENT">
<!--
        <field id="siscod" oculto="true">
          <condicion operador="=">'10'</condicion>
        </field>
-->        
        <field id="ctbcod" oculto="true">
          <condicion operador="=">STKINSUM.artctb</condicion>
        </field>
    
      </table>
    </join>        
    <join tipo="left">
    
      <table id="FSMUNIDS">
        <field id="unicod" oculto="true">
          <condicion operador="=">STKINSUM.artuni</condicion>
        </field>
    
      </table>
    </join>    
    <join tipo="left">
    
      <table id="STKINSPR">
        <field id="siscod" >
          <condicion operador="=">'01'</condicion>
        </field>
        <field id="fecult" >
          <condicion operador="&lt;=">STR_TO_DATE('[__fecha__]', '%d/%m/%Y')</condicion>
        </field>        
        <field id="artcod" >
          <condicion operador="=">STKINMOV.artcod</condicion>
        </field>

    
      </table>
    </join>    
          
  </form>
</histrix>
