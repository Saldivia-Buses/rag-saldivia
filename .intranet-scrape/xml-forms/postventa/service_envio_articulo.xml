    <field id="cantidad">
      <label>Cantidad</label>
      <tipo>integer</tipo>
    </field>
    <field id="precio">
      <label>Precio</label>
      <tipo>numeric</tipo>
    </field>
    <field id="observaciones" >
      <label>Observ</label>
      <help>Observaciones</help>
      <size>50</size>
    </field>
    <field id="cargo" >
      <label>Tipo</label>
      <options>
        <option valor="0">Sin Cargo</option>
        <option valor="1">Con Cargo</option>
        <option valor="2">Con Cargo 3ro</option>
              <option valor="3">Envio de Repuestos</option>
              <option valor="4">Viaje</option>

      </options>
    </field>
  </table>
  <join tipo="left">
    <table id="STK_ARTICULOS">
      <field id="id_stkarticulo">
        <condicion operador="=">SERVICE_ENVIOS_ARTICULOS.artcod</condicion>
      </field>
      <field id="subsistema_id">
        <condicion operador="=">'01'</condicion>
      </field>
    </table>
  </join>
