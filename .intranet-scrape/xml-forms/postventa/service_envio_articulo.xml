<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="abm-mini" subtipo="vertical" imprime="false" >
  <title>Artículos por envío</title>
  <obs></obs>
  <eventos>
    <event id="insert">refresh</event>
    <event id="update">refresh</event>
    <event id="delete">refresh</event>
  </eventos>
  <form >
    <table id="SERVICE_ENVIOS_ARTICULOS" label="Artículos - Envío de Repuestos">
      <field id="id_envioarticulo" autoinc="true" noshow="true">
        <label>id</label>
      </field>
      <field id="serviceenvio_id" noshow="true" valauto="true">
        <label>idService</label>
      </field>
      
      <field id="nombre_articulo" autocompletar="true" tabla="STK_ARTICULOS" _deshabilitado="true" required="true">
        <label>Artículo</label>
        <help>Descripción de Artículo</help>
        <ayuda_ex id="STKINSUM" >
          <field id="artcod" noshow="true">
            <label>cod</label>
            <detalle>artcod</detalle>
          </field>
          <field id="artdes">
            <label>Nombre</label>
            <detalle>nombre_articulo</detalle>
          </field>
          <field id="siscod" oculto="true">
            <condicion operador="=">'01'</condicion>
          </field>
        </ayuda_ex>
        <size>40</size>
      </field>

      <field id="artcod" _deshabilitado="true" >
       <!--  <ayuda_ex id="STKINSUM" >
          <field id="artcod" _oculto="true">
            <label>Cod</label>
          </field>
          <field id="artdes">
            <label>Nombre</label>
            <detalle>artdes</detalle>
          </field>
          <field id="siscod" oculto="true">
            <condicion operador="=">'01'</condicion>
          </field>
        </ayuda_ex> -->
        <label>Cod.</label>
        <detalle>artcod</detalle>
      </field>

