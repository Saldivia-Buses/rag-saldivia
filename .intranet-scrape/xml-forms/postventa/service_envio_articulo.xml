      <field id="artcod" >
      <label>Cod. Artículo</label>
      <helper type="external" id="STKINSUM" >
        <field id="artcod">
          <label>Cod</label>
        </field>
        <field id="artdes">
          <label>Nombre</label>
          <detalle>artdes</detalle>
        </field>
        <field id="siscod" noshow="true">
          <condicion operador="=">'01'</condicion>
        </field>
        <field id="repuesto" noshow="true">
          <condicion operador="=">1</condicion>
        </field>
      </helper>
      <label>Cod.</label>
    </field>
    <field id="artdes" deshabilitado="true" tabla="STKINSUM">
      <label modpos="nobr">Articulo</label>
      <help>Descripcion de Articulo.</help>
      <size>100</size>
    </field>
