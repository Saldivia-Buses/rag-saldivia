      <field id="Imputado" local="true" refresh="true">
        <label>Imputar</label>
        <tipo>check</tipo>       
      </field>

   <field id="total_imputado" local="true" suma="true" editable="true" _noshow="true">

      	<label>Total Imputado</label>
       <if exp="Imputado == 1">
		    <true>(total_imputado != 0)?total_imputado:Pendientes</true>
		    <false>0</false>
        </if> 
        <detalle>cantidad_compra</detalle>
	<tipo>numeric</tipo>
      </field>
                            
            <field id="impiva" deshabilitado="true"  local="true" noshow="true">
                <label modpos="nobr">Iva</label>
                <if exp="alicuota + 0 &gt; 0">
                    <true>round((( precio_costo + 0 )* (total_imputado + 0 ) ) * alicuota / 100, 4)</true>
                    <false>0</false>
                </if>
                <detalle>impiva</detalle>
            </field> 
            <field id="Total" deshabilitado="true" local="true" noshow="true">
                <label modpos="nobr">Total</label>
                <if exp="true">
                    <true> round(( precio_costo + 0) * ( total_imputado + 0) + impiva, 4)</true>
                    <false>0</false>
                </if>
                <detalle>Total</detalle>
            </field>
	                        
	       	  <field id="Orden_compra" local="true" linkint="ordencompra_imp.xml" linkdes="Ordenes de Compra" linkdir="compras/qry">
	           	      <label>Compra</label>
	    	    <expresion>select concat('O.Compra ', cpsmovim_id) from REG_DETALLE_CPS where regdetalle_id = id_regdetalle limit 1</expresion>
                      <paring destino="id_cpsmovimiento">Orden_compra</paring>
                  </field>

	<field id="colores" local="true" noshow="true" clasefila="true">
	    <if exp="'Orden_compra'  != ''">
		<true>'resaltado'</true>
		<false>''</false>
	    </if>
	    
	</field>
