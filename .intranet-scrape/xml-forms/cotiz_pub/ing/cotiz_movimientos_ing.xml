            <field id="stkarticulo_id"  _esClave="true" linkint="stk_hist_costos_qry.xml" linkdes="Precios" linkdir="/compras/qry">
                <label _colspan="5">Artículo</label>
                <paring destino="stkarticulo_id">stkarticulo_id</paring>
                <help>Código de Artículo</help>
		        <helper type="external" xml="stkarticulo_qry.xml" dir="/ayudas">
	           	    <field id="nombre_articulo">
        			 <detalle>nombre_articulo</detalle>
        		    </field>
        		    <field id="unidad_compra_id">
        			<detalle>unidad_compra_id</detalle>
        		    </field>
        		    <field id="unidad_uso_id">
        			<detalle>unidad_uso_id</detalle>
        		    </field>
                    <field id="valor_compra">
                	<expression>case when valor_compra = 0 then 1 else valor_compra end</expression>
                        <detalle>valor_compra</detalle>
                    </field>
                    <field id="valor_uso">
                	<expression>case when valor_uso = 0 then 1 else valor_uso end</expression>
                        <detalle>valor_uso</detalle>
                    </field>
                    <field id="precio_costo" >
                        <label>Costo</label>
                        <detalle>costo_unitario</detalle>
                    </field>
                    <field id="codigo_barra">
                         <detalle>codigo_barra</detalle>
                    </field>
                    <field id="subsistema_id" noshow="true">
                        <condicion operdor="=">'01'</condicion>
                    </field>
                    <field id="hlp" oculto="true">
                        <expression>CONCAT(ROUND(valor_compra,2),' ',(SELECT GEN_UNIDADES.nombre_unidad from GEN_UNIDADES where GEN_UNIDADES.id_unidad = STK_ARTICULOS.unidad_compra_id), ' = ',  ROUND(valor_uso, 2), ' ', (SELECT GEN_UNIDADES.nombre_unidad from GEN_UNIDADES where GEN_UNIDADES.id_unidad = STK_ARTICULOS.unidad_uso_id)  )</expression>
                        <detalle>hlp</detalle>
                    </field>
                </helper>
            </field>

            <field id="nombre_articulo"  tabla="STK_ARTICULOS" _esClave="true" deshabilitado="true">
