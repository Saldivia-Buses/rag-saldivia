            <field id="cantidad_compra" local="true" incdec="true" preventLoop="true" suma="true">
                <label>Pedido</label>
                <help>Pedido (expresado en la unidad de compra)</help>
                <valor>1</valor>
                <tipo>decimal</tipo>
                <jseval campodestino="convertido">(valor_compra == 1)?(cantidad_compra * valor_uso):(cantidad_compra / valor_compra)</jseval>
                <jseval campodestino="impiva">precio_costo * cantidad_compra / 100 * alicuota</jseval>
                <jseval campodestino="pallets">(cantidad_pallet + 0 != 0 ) ? convertido / cantidad_pallet : 0 </jseval>
                <jseval campodestino="Total">precio_costo * cantidad_compra + impiva</jseval>
            </field>

            <field id="unidad_compra_id" _deshabilitado="true" _sincelda="true">
                <label modpos="nobr">Unidad</label>
                <helper type="combo" xml="unidad_qry.xml" dir="/ayudas" empty="true"/>
                <tipo>integer</tipo>
            </field>
