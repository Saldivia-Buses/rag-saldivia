<?xml version="1.0" encoding="UTF-8"?>
<histrix  tipo="fichaing" preFetch="true" imprime="false" inserta="false" modifica="false" >
    <title>Solicitud de Cotización</title>
    <obs/>
    <form >
        <table id="CPS_MOVIMIENTOS" >
        	<movimientos>
        		<relacion id="cerrar_cotizacion_ins.xml" />
        	</movimientos>
		    <field id="id_cpsmovimiento" deshabilitado="true">
		    	<label modpos="nobr">Cotización Nro</label>
		    </field>

		    <field id="cpsfecha" deshabilitado="true">
		    	<label modpos="nobr">Fecha</label>
		    </field>
            <field id="cierre" local="true" noshow="true">
                <valor>today</valor>
                <tipo>date</tipo>
            </field>

		    <field id="detalle" local="true" colspan="4">
		    	<label  posX="5" posY="+4">Detalle</label>
		    	<helper xml="detalle_respuestas.xml" type="object">
		    		<parameter source="id_cpsmovimiento" target="cpsmovimiento_id" />
		    	</helper>
		    </field>

		    <group>
		    	<field id="id_cpsmovimiento" />
		    </group>
        </table>
        <join>
        	<table id="CPS_ENVIOS">
        		<field id="cpsmovimiento_id">
        			<condicion operador="=">id_cpsmovimiento</condicion>
        		</field>
        	</table>
        </join>
    </form>
</histrix>
