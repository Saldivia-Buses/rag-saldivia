<?xml version="1.0" encoding="UTF-8"?>
<histrix  tipo="consulta" >
    <title>COTIZADO</title>
    <obs/>
    <form _detalle="cotizaciones_contestadas.xml">
        <table id="CPS_MOVIMIENTOS" >
        	<filters>
			    <field id="cpsfecha">
			    	<label>Desde</label>
			    	<operador>&gt;=</operador>
			    	<valor>today</valor>
			    </field>
			    <field id="cpsfecha">
			    	<label>Hasta</label>
			    	<operador>&lt;=</operador>
					<valor>today</valor>			    	
			    </field>

        	</filters>

		    <field id="cpsfecha">
		    	<label>Fecha</label>
		    	<tipo>date</tipo>
		    </field>

		    <field id="id_cpsmovimiento" >
		    	<label>Cotización</label>
		    	<helper xml="cotizacion_imp.xml" type="link">
		    		<parameter source="id_cpsmovimiento" target="id_cpsmovimiento" />
		    	</helper>
		    	<detalle>id_cpsmovimiento</detalle>
		    </field>

		    <field id="cpsestado_id" noshow="true"/>
<!--
		    <field id="respuetas">
		    	<expression>(select count(distinct regcuenta_id) from CPS_DETALLE join  CPS_COTIZACION_DETALLE on CPS_DETALLE.id_cpsdetalle = CPS_COTIZACION_DETALLE.cpsdetalle_id where CPS_DETALLE.cpsmovimiento_id = CPS_MOVIMIENTOS.id_cpsmovimiento)</expression>
		    </field> -->

		    <field id="destinatarios">
		    	<label>Destinatarios</label>
		    	<expression>count(id_cpsenvio)</expression>
		    	<helper xml="cotizacion_destinatarios.xml" type="link">
		    		<parameter source="id_cpsmovimiento" target="cpsmovimiento_id" />
		    	</helper>
		    </field>

		    <field id="email" noZero="true">
		    	<label>Respuestas</label>
		    	<expression> (select count(distinct regcuenta_id) from CPS_DETALLE join  CPS_COTIZACION_DETALLE on CPS_DETALLE.id_cpsdetalle = CPS_COTIZACION_DETALLE.cpsdetalle_id where CPS_DETALLE.cpsmovimiento_id = CPS_MOVIMIENTOS.id_cpsmovimiento)</expression>
		    	<helper xml="cotizaciones_contestadas_qry.xml" type="link">
		    		<parameter source="id_cpsmovimiento" target="id_cpsmovimiento" />
		    	</helper>
		    </field>

		    <order>
		    	<field id="id_cpsmovimiento" orderType="DESC" />
		    </order>

		    <group>
		    	<field id="id_cpsmovimiento" />
		    </group>

        </table>

        <join>
        	<table id="CPS_ENVIOS">
        		<field id="cpsmovimiento_id">
        			<condicion operador="=">id_cpsmovimiento</condicion>
        		</field>
        	</table>
        </join>
    </form>
</histrix>
