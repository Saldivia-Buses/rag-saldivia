<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="calendar" imprime="true" calendarAspectRatio="2">
    <title>Evaluación de desempeño</title>
    <obs></obs>
    <form _detalle="evaluaciones_det.xml">
        <table id="RH_EVALUACIONES" >
            <title>Evaluación</title><!--
            <filters>
                <field id="legajo" deshabilitado="false">
                    <label>Legajo</label>
                    <operador>=</operador>
                </field>
               	<field id="id_seccion">
					<label>Sección</label>
					<operador>=</operador>
				</field>
                <field id="fec_evaluacion">
                    <label>Desde</label>
                    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ,strtotime('-1 month')) , 1, date("Y") - 1))</valor>
                    <operador>&gt;=</operador>
                </field>

                <field id="fec_evaluacion">
                    <label>Hasta</label>
                    <valor>today</valor>
                    <operador>&lt;=</operador>
                </field>

            </filters>-->
            
            <field id="id_rhevaluacion" autoinc="true" noshow="true" calendarId="true">
                <detalle>id_rhevaluacion</detalle>
            </field>

            <field id="fec_evaluacion" deshabilitado="true" calendarStartDate="true">
                <label>Fecha de Evaluación</label>
                <tipo>date</tipo>
            </field>

            <field id="legajo" tabla="PERSONAL" deshabilitado="true" linkint="personal_qry.xml" linkdes="Datos del personal" linkdir="/personal" print="false">
                <label>Legajo</label>
                <detalle>legajo</detalle>
				<paring destino="legajo">legajo</paring>
            </field>
			
            <field id="nombre" tabla="PERSONAL" deshabilitado="true">
                <label>Apellido y Nombre</label>
                <expression>CONCAT(apellido, ' ', Nombre)</expression>
                <detalle>evaluado</detalle>
				<size>40</size>
            </field>
			<field id="id_seccion" tabla="PERSONAL" Formstyle="display:none;" colstyle="display:none;">
				<helper type="combo" id="SECCION" empty="true">
					<field id="id_seccion" />
					<field id="nombre" />
					<field id="activa" noshow="true">
					    <condicion operador="=">1</condicion>
					</field>
				</helper>
				<label>Sección</label>
				<detalle>id_seccion</detalle>
			</field>

			<field id="subject" calendarSubject="true">
				<expression>CONCAT('Ev. Nº: ', id_rhevaluacion, ' - (', PERSONAL.legajo, ')', PERSONAL.apellido, ', ', PERSONAL.Nombre)</expression>
			</field>

            <order>
                <field id="nombre"/>
            </order>
        </table>
        <join tipo="left">
            <table id="PERSONAL">
                <field id="idPersona">
                    <condicion operador="=">RH_EVALUACIONES.rhpersona_id</condicion>
                </field>
            </table>
        </join>
    </form>
</histrix> 
