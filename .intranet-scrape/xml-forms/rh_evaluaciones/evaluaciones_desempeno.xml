        <field id="idSupervisor" _nodeText="true" tabla="SECCION">
                <label>Supervisor</label>

                        <tabla_ex id="PERSONAL" xml="HLPpersonal.xml" vacio="true" dir="/help_local">
                            <field id="legajo">
                                <condicion operador="!=">0</condicion>
                            </field>
                        </tabla_ex>
        </field>
<!--
            <field id="rhpersona_id" noshow="true" tabla="RH_EVALUACIONES" print="false"/>
-->
            <field id="evaluado">
                <expression>CONCAT(PERSONAL.apellido, ' ', PERSONAL.Nombre)</expression>
                <label colspan="2" posX="+5" posY="+1" size="18">Evaluado</label>
            </field>

            <field id="alias" >
		<label>Alias</label>
	    </field>

	    <field id="fotos" local="true" imageWidth="60" path="idPersona">
		<expression>CONCAT('/fotos/personal/', PERSONAL.idPersona,'/')  </expression>
		<label  posX="5" posY="+2" formStyle="display:none;">Foto</label>
