	    </field>

            <field id="id_seccion" deshabilitado="true">
                <helper type="combo" id="SECCION" empty="true">
                    <field id="id_seccion"/>
                    <field id="nombre"/>
		    <field id="activa" noshow="true">
			<condicion operador="=">1</condicion>
		    </field>
                </helper>
                <label posX="+5" posY="+2" size="18">Sección</label>
            </field>
         <!--
	
    	<field id="fec_evaluacion" tabla="RH_EVALUACIONES">
    	    <label>Fec Evaluacion</label>
        </field>   
     -->
	    <field id="id_rhevaluacion"  noshow="true" _tabla="RH_EVALUACIONES">
		
            <expression having="false">SELECT id_rhevaluacion FROM RH_EVALUACIONES rh WHERE rh.rhpersona_id = PERSONAL.idPersona order by rh.fec_evaluacion DESC limit 1</expression>
       		<label>idrhevaluacion</label>
	    </field>		

                	    
	    <field id="desem" _noshow="true" max="1" >
            <!--
		<expression>TRUNCATE(desempenio / (select sum(peso) * 5 from RH_EVALUACION_RESPUESTAS LEFT JOIN RH_EVALUACION_GRUPOS reg ON RH_EVALUACION_RESPUESTAS .rhevaluaciongrupo_id = reg.id_rhevaluaciongrupo where RH_EVALUACION_RESPUESTAS.rhevaluacion_id = RH_EVALUACIONES.id_rhevaluacion), 2)</expression>
    -->
        <expression>TRUNCATE((SELECT desempenio FROM RH_EVALUACIONES rh WHERE rh.rhpersona_id = PERSONAL.idPersona order by rh.fec_evaluacion DESC limit 1) / (select sum(peso) * 5 from RH_EVALUACION_RESPUESTAS LEFT JOIN RH_EVALUACION_GRUPOS reg ON RH_EVALUACION_RESPUESTAS .rhevaluaciongrupo_id = reg.id_rhevaluaciongrupo where RH_EVALUACION_RESPUESTAS.rhevaluacion_id = RH_EVALUACIONES.id_rhevaluacion), 2)</expression> 
		<tipo>grafico</tipo>
	    </field>			
	    <field id="desempe2" >
            <!--
		  <expression>TRUNCATE(desempenio / (select sum(peso) * 5 from RH_EVALUACION_RESPUESTAS LEFT JOIN RH_EVALUACION_GRUPOS reg ON RH_EVALUACION_RESPUESTAS .rhevaluaciongrupo_id = reg.id_rhevaluaciongrupo where RH_EVALUACION_RESPUESTAS.rhevaluacion_id = RH_EVALUACIONES.id_rhevaluacion), 2)</expression>
       
            <expression>TRUNCATE((SELECT desempenio FROM RH_EVALUACIONES rh WHERE rh.rhpersona_id = RH_EVALUACIONES.rhpersona_id order by rh.fec_evaluacion DESC limit 1) / (select sum(peso) * 5 from RH_EVALUACION_RESPUESTAS LEFT JOIN RH_EVALUACION_GRUPOS reg ON RH_EVALUACION_RESPUESTAS .rhevaluaciongrupo_id = reg.id_rhevaluaciongrupo where RH_EVALUACION_RESPUESTAS.rhevaluacion_id = RH_EVALUACIONES.id_rhevaluacion), 2)</expression> 
        -->
            <expression>TRUNCATE((SELECT desempenio FROM RH_EVALUACIONES rh WHERE rh.rhpersona_id = PERSONAL.idPersona order by rh.fec_evaluacion DESC limit 1) / (select sum(peso) * 5 from RH_EVALUACION_RESPUESTAS LEFT JOIN RH_EVALUACION_GRUPOS reg ON RH_EVALUACION_RESPUESTAS .rhevaluaciongrupo_id = reg.id_rhevaluaciongrupo where RH_EVALUACION_RESPUESTAS.rhevaluacion_id = RH_EVALUACIONES.id_rhevaluacion), 2)</expression> 
		  <label>Desempeño</label>
	    </field>			

           <field id="desempenio2">
            <!--
		<expression>CASE
		  WHEN ((SELECT desempenio FROM RH_EVALUACIONES rh WHERE rh.rhpersona_id = RH_EVALUACIONES.rhpersona_id order by rh.fec_evaluacion DESC limit 1) / (select sum(peso) * 5 from RH_EVALUACION_RESPUESTAS LEFT JOIN RH_EVALUACION_GRUPOS reg ON RH_EVALUACION_RESPUESTAS .rhevaluaciongrupo_id = reg.id_rhevaluaciongrupo where RH_EVALUACION_RESPUESTAS.rhevaluacion_id = RH_EVALUACIONES.id_rhevaluacion)) &lt;= 0.4 THEN 'REPROBADO' 
		  WHEN ((SELECT desempenio FROM RH_EVALUACIONES rh WHERE rh.rhpersona_id = RH_EVALUACIONES.rhpersona_id order by rh.fec_evaluacion DESC limit 1) / (select sum(peso) * 5 from RH_EVALUACION_RESPUESTAS LEFT JOIN RH_EVALUACION_GRUPOS reg ON RH_EVALUACION_RESPUESTAS .rhevaluaciongrupo_id = reg.id_rhevaluaciongrupo where RH_EVALUACION_RESPUESTAS.rhevaluacion_id = RH_EVALUACIONES.id_rhevaluacion)) &gt; 0.4 and (desempenio / (select sum(peso) * 5 from RH_EVALUACION_RESPUESTAS LEFT JOIN RH_EVALUACION_GRUPOS reg ON RH_EVALUACION_RESPUESTAS .rhevaluaciongrupo_id = reg.id_rhevaluaciongrupo where RH_EVALUACION_RESPUESTAS.rhevaluacion_id = RH_EVALUACIONES.id_rhevaluacion)) &lt;= 0.6 THEN 'REGULAR' 
		  WHEN ((SELECT desempenio FROM RH_EVALUACIONES rh WHERE rh.rhpersona_id = RH_EVALUACIONES.rhpersona_id order by rh.fec_evaluacion DESC limit 1) / (select sum(peso) * 5 from RH_EVALUACION_RESPUESTAS LEFT JOIN RH_EVALUACION_GRUPOS reg ON RH_EVALUACION_RESPUESTAS .rhevaluaciongrupo_id = reg.id_rhevaluaciongrupo where RH_EVALUACION_RESPUESTAS.rhevaluacion_id = RH_EVALUACIONES.id_rhevaluacion)) &gt; 0.6 and (desempenio / (select sum(peso) * 5 from RH_EVALUACION_RESPUESTAS LEFT JOIN RH_EVALUACION_GRUPOS reg ON RH_EVALUACION_RESPUESTAS .rhevaluaciongrupo_id = reg.id_rhevaluaciongrupo where RH_EVALUACION_RESPUESTAS.rhevaluacion_id = RH_EVALUACIONES.id_rhevaluacion)) &lt;= 0.7 THEN 'ACEPTABLE' 
		  WHEN ((SELECT desempenio FROM RH_EVALUACIONES rh WHERE rh.rhpersona_id = RH_EVALUACIONES.rhpersona_id order by rh.fec_evaluacion DESC limit 1) / (select sum(peso) * 5 from RH_EVALUACION_RESPUESTAS LEFT JOIN RH_EVALUACION_GRUPOS reg ON RH_EVALUACION_RESPUESTAS .rhevaluaciongrupo_id = reg.id_rhevaluaciongrupo where RH_EVALUACION_RESPUESTAS.rhevaluacion_id = RH_EVALUACIONES.id_rhevaluacion)) &gt; 0.7 and (desempenio / (select sum(peso) * 5 from RH_EVALUACION_RESPUESTAS LEFT JOIN RH_EVALUACION_GRUPOS reg ON RH_EVALUACION_RESPUESTAS .rhevaluaciongrupo_id = reg.id_rhevaluaciongrupo where RH_EVALUACION_RESPUESTAS.rhevaluacion_id = RH_EVALUACIONES.id_rhevaluacion)) &lt;= 0.8 THEN 'BUENO' 
		  WHEN ((SELECT desempenio FROM RH_EVALUACIONES rh WHERE rh.rhpersona_id = RH_EVALUACIONES.rhpersona_id order by rh.fec_evaluacion DESC limit 1) / (select sum(peso) * 5 from RH_EVALUACION_RESPUESTAS LEFT JOIN RH_EVALUACION_GRUPOS reg ON RH_EVALUACION_RESPUESTAS .rhevaluaciongrupo_id = reg.id_rhevaluaciongrupo where RH_EVALUACION_RESPUESTAS.rhevaluacion_id = RH_EVALUACIONES.id_rhevaluacion)) &gt; 0.8 THEN 'EXCELENTE' 
		END
		</expression>
		-->
        <expression>CASE
          WHEN ((SELECT desempenio FROM RH_EVALUACIONES rh WHERE rh.rhpersona_id = PERSONAL.idPersona order by rh.fec_evaluacion DESC limit 1) / (select sum(peso) * 5 from RH_EVALUACION_RESPUESTAS LEFT JOIN RH_EVALUACION_GRUPOS reg ON RH_EVALUACION_RESPUESTAS .rhevaluaciongrupo_id = reg.id_rhevaluaciongrupo where RH_EVALUACION_RESPUESTAS.rhevaluacion_id = RH_EVALUACIONES.id_rhevaluacion)) &lt;= 0.4 THEN 'REPROBADO' 

          WHEN (((SELECT desempenio FROM RH_EVALUACIONES rh WHERE rh.rhpersona_id = PERSONAL.idPersona order by rh.fec_evaluacion DESC limit 1) / (select sum(peso) * 5 from RH_EVALUACION_RESPUESTAS LEFT JOIN RH_EVALUACION_GRUPOS reg ON RH_EVALUACION_RESPUESTAS .rhevaluaciongrupo_id = reg.id_rhevaluaciongrupo where RH_EVALUACION_RESPUESTAS.rhevaluacion_id = RH_EVALUACIONES.id_rhevaluacion)) &gt; 0.4 and 
          ((SELECT desempenio FROM RH_EVALUACIONES rh WHERE rh.rhpersona_id = PERSONAL.idPersona order by rh.fec_evaluacion DESC limit 1) / (select sum(peso) * 5 from RH_EVALUACION_RESPUESTAS LEFT JOIN RH_EVALUACION_GRUPOS reg ON RH_EVALUACION_RESPUESTAS .rhevaluaciongrupo_id = reg.id_rhevaluaciongrupo where RH_EVALUACION_RESPUESTAS.rhevaluacion_id = RH_EVALUACIONES.id_rhevaluacion)) &lt;= 0.6) THEN 'REGULAR' 

          WHEN (((SELECT desempenio FROM RH_EVALUACIONES rh WHERE rh.rhpersona_id = PERSONAL.idPersona order by rh.fec_evaluacion DESC limit 1) / (select sum(peso) * 5 from RH_EVALUACION_RESPUESTAS LEFT JOIN RH_EVALUACION_GRUPOS reg ON RH_EVALUACION_RESPUESTAS .rhevaluaciongrupo_id = reg.id_rhevaluaciongrupo where RH_EVALUACION_RESPUESTAS.rhevaluacion_id = RH_EVALUACIONES.id_rhevaluacion)) &gt; 0.6 and 
          ((SELECT desempenio FROM RH_EVALUACIONES rh WHERE rh.rhpersona_id = PERSONAL.idPersona order by rh.fec_evaluacion DESC limit 1) / (select sum(peso) * 5 from RH_EVALUACION_RESPUESTAS LEFT JOIN RH_EVALUACION_GRUPOS reg ON RH_EVALUACION_RESPUESTAS .rhevaluaciongrupo_id = reg.id_rhevaluaciongrupo where RH_EVALUACION_RESPUESTAS.rhevaluacion_id = RH_EVALUACIONES.id_rhevaluacion)) &lt;= 0.7) THEN 'ACEPTABLE' 

          WHEN (((SELECT desempenio FROM RH_EVALUACIONES rh WHERE rh.rhpersona_id = PERSONAL.idPersona order by rh.fec_evaluacion DESC limit 1) / (select sum(peso) * 5 from RH_EVALUACION_RESPUESTAS LEFT JOIN RH_EVALUACION_GRUPOS reg ON RH_EVALUACION_RESPUESTAS .rhevaluaciongrupo_id = reg.id_rhevaluaciongrupo where RH_EVALUACION_RESPUESTAS.rhevaluacion_id = RH_EVALUACIONES.id_rhevaluacion)) &gt; 0.7 and 
          ((SELECT desempenio FROM RH_EVALUACIONES rh WHERE rh.rhpersona_id = PERSONAL.idPersona order by rh.fec_evaluacion DESC limit 1) / (select sum(peso) * 5 from RH_EVALUACION_RESPUESTAS LEFT JOIN RH_EVALUACION_GRUPOS reg ON RH_EVALUACION_RESPUESTAS .rhevaluaciongrupo_id = reg.id_rhevaluaciongrupo where RH_EVALUACION_RESPUESTAS.rhevaluacion_id = RH_EVALUACIONES.id_rhevaluacion)) &lt;= 0.8) THEN 'BUENO' 

          WHEN ((SELECT desempenio FROM RH_EVALUACIONES rh WHERE rh.rhpersona_id = PERSONAL.idPersona order by rh.fec_evaluacion DESC limit 1) / (select sum(peso) * 5 from RH_EVALUACION_RESPUESTAS LEFT JOIN RH_EVALUACION_GRUPOS reg ON RH_EVALUACION_RESPUESTAS .rhevaluaciongrupo_id = reg.id_rhevaluaciongrupo where RH_EVALUACION_RESPUESTAS.rhevaluacion_id = RH_EVALUACIONES.id_rhevaluacion)) &gt; 0.8 THEN 'EXCELENTE' 
        END
        </expression>
		<helper type="link" xml="evaluaciones_det.xml" _dir="/rh_evaluaciones">
		    <parameter source="id_rhevaluacion" target="id_rhevaluacion" operador="="/>
		    <parameter source="legajo" target="legajo" operador="=" />
		    <parameter source="evaluado" target="evaluado" operador="=" />
		    <parameter source="id_seccion" target="id_seccion" operador="=" />
            
		</helper>
                <label colspan="2" posX="+5" posY="+2" PDFancho="160" size="35">Calificación</label>
            </field>
            
            <field id="hiSinEv" local="true" clasefila="true" noshow="true">
                <!--
        	<expression>CASE WHEN RH_EVALUACIONES.id_rhevaluacion is null THEN 'resaltadoVioleta' ELSE '' END</expression>
        -->
            <expression>CASE WHEN (SELECT id_rhevaluacion FROM RH_EVALUACIONES rh WHERE rh.rhpersona_id = PERSONAL.idPersona order by rh.fec_evaluacion DESC limit 1)  is null THEN 'resaltadoVioleta' ELSE '' END</expression>
    	    </field>
<!--
    	<group>
    		<field id="idPersona" />
    	</group>
-->
	    <order>
	        <field id="evaluado"/>
		      <!-- <field id="fec_evaluacion" /> -->
	    </order>
        </table>
        
        <join tipo="left">
            <table id="RH_EVALUACIONES">
                <field id="rhpersona_id">
                    <condicion operador="=">idPersona</condicion>
                </field>
            </table>
        </join>
	
        <join tipo="left">
            <table id="SECCIONHISTORIA">
                <field id="idPersona">
                    <condicion operador="=">PERSONAL.idPersona</condicion>
                </field>
                <field id="id_seccion">
                    <condicion operador="=">PERSONAL.id_seccion</condicion>
                </field>
            </table>
        </join>
        
        <join tipo="left">
            <table id="SECCION">
                <field id="id_seccion">
                    <condicion operador="=">SECCIONHISTORIA.id_seccion</condicion>
                </field>
            </table>
        </join>
    </form>
</histrix> 
