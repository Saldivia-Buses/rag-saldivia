<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="ficha" autoprint="true">
  <title>Certificado de Discapacidad</title>
  <obs/>
  <form>
     <table id="RH_EVALUACIONES" >
            <title>Evaluación</title>

            <field id="id_rhevaluacion" autoinc="true" noshow="true"/>
				
            <field id="rhpersona_id" noshow="true" />

            <field id="legajo" tabla="PERSONAL" deshabilitado="true">
                <label>Legajo</label>
            </field>

            <field id="evaluado">
                <expresion>CONCAT(PERSONAL.apellido, ' ', PERSONAL.Nombre)</expresion>
                <label modpos="nobr" colspan="4">Evaluado</label>
			<size>50</size>
            </field>

	    	<field id="fec_evaluacion" deshabilitado="true">
                <label>Fecha Evaluación</label>
            </field>

           <field id="fecing" tabla="PERSONAL" noshow="true">
				<label>Fecha Ingreso</label>
			</field>
		
			<field id="antiguedades">
				<expresion>IF((YEAR(CURDATE()) - YEAR(fecing)) &gt; 0, (YEAR(CURDATE()) - YEAR(fecing)) - (MID(CURDATE(), 6, 5) &lt; MID(fecing, 6, 5)), IF((YEAR(CURDATE()) - YEAR(fecing)) &lt; 0, (YEAR(CURDATE()) - YEAR(fecing)) + (MID(fecing, 6, 5) &lt; MID(CURDATE(), 6, 5)), (YEAR(CURDATE()) - YEAR(fecing))))</expresion>
				<label>Antigüedad (años)</label>
				<help></help>
				<tipo>integer</tipo>
			</field>

            <field id="desempenio" deshabilitado="true">
				<expresion>desempenio / (select sum(peso) * 5 from RH_EVALUACION_RESPUESTAS LEFT JOIN RH_EVALUACION_GRUPOS reg ON RH_EVALUACION_RESPUESTAS .rhevaluaciongrupo_id = reg.id_rhevaluaciongrupo where RH_EVALUACION_RESPUESTAS.rhevaluacion_id = RH_EVALUACIONES.id_rhevaluacion) </expresion>
                <label>Desempeño</label>
            </field>

            <field id="puntos_fuertes">
                <label colspan="2">Puntos fuertes</label>
                <size>200</size>
            </field>

            <field id="puntos_a_mejorar">
                <label colspan="2">Puntos a mejorar</label>
                <size>200</size>
            </field>

            <field id="conclusiones">
                <label colspan="2">Conclusiones</label>
                <size>200</size>
            </field>

            <field id="descargo_evaluado">
                <label colspan="2">Descargo del evaluado</label>
                <size>200</size>
            </field>
			
			<field id="resultados" obj="evaluaciones_res.xml" local="true">
				<paring destino ="rhevaluacion_id">id_rhevaluacion</paring>
				<label>Resultados</label>
			</field>
  </form>
</histrix>
