			<field id="ctacod" deshabilitado="true">
				<!--
				<ayuda_ex id="CCTCUENT" xml="HLPcctcuent.xml" dir="/help_local">
					
					<field id="ctacod">
						<label>Nro</label>
					</field>
					<field id="ctanom">
						<label>Nombre</label>						
					</field>
						
					<clave>ctacod</clave>
					<descripcion>ctanom</descripcion>
				</ayuda_ex>
				-->
				
				<label>Cuenta</label>
				<help>Código de Cuenta </help>
			</field>

			<field id="ctanom" deshabilitado="true">
				<label >Nombre</label>
				<help>Nombre de Cuenta </help>
			</field>
			
			<field id="ctaobs">
				<label colspan="5">Obs. </label>
				<help>Observaciones</help>
			</field>

			<field id="ctbcod">
				<label>Cta Contable</label>
				<help>
				</help>
				<helper type="external" id="CTBCUENT" >
					<field id="ctbcod"></field>
					<field id="ctbnom">
						<detalle>ctbnom</detalle>
					</field>
					<field id="ctbhab">
						<condicion operador="=">1</condicion>
					</field>	
					<field id="siscod">
						<condicion operador="=">10</condicion>
					</field>	
					<order>
						<field id="ctbnom"></field>
					</order>				
				</helper>
			</field>	

			<field id="ctbnom" tabla="CTBCUENT" deshabilitado="true">
				<label modpos="nobr">Nombre cuenta</label>
				<tipo>varchar</tipo>
			</field>

			<field id="codigoNumero">
					<tabla_ex xml="codigonumero.xml" />
				<tipo>varchar</tipo>
				<label>Código Nro</label>
			</field>

			<field id="totatr">
				<label >No influye en costo</label>
				<help>No se tiene en cuenta en el armado de costos</help>
				<tipo>check</tipo>
			</field>

			<field id="ult" >
				<label>Última Compra</label>
				<expression >select max(INSPR.fecult)from STKINSPR as INSPR where  INSPR.ctacod = CCTCUENT.ctacod and INSPR.siscod = '01' limit 1</expression>
				<tipo>date</tipo>
			</field>

			<order>
				<field id="ctanom"></field>
			</order>	

		</table>
		<join tipo="left">
			<table id="CTBCUENT">
<!--				<field id="siscod" oculto="true">
					<condicion operador="=">'10'</condicion>
				</field>
-->
				<field id="ctbcod">
					<condicion operador="=">CCTCUENT.ctbcod</condicion>
				</field>
				
			</table>
		</join>
	</form>
