<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" width="20" showCantidad="false">
  <title>Configuracion del Puesto</title>
  <obs/>
  <form detalle="cajmovimientosheadercrecer_qry.xml">
    <table id="CAJ_PUESTOS">
      <filters auto="true">
        <field id="fecha_desde">
          <label>Desde Fecha</label>
          <operador>&gt;=</operador>
          <valor>today</valor>
        </field>
        <field id="fecha_hasta">
          <label>Hasta Fecha</label>
          <operador>&lt;=</operador>
          <valor>today</valor>
        </field>
        <field id="cajconcepto_id1">
          <label>descripcion</label>
          <operador>=</operador>
        </field>
      </filters>
      <field id="fecha_desde" local="true" noshow="true">
        <label>Fecha</label>
        <tipo>date</tipo>
        <detalle>fecha_desde</detalle>
      </field>
      <field id="fecha_hasta" local="true" noshow="true">
        <label>Fecha hasta</label>
        <tipo>date</tipo>
        <detalle>fecha_hasta</detalle>
      </field>
      <field id="cajconcepto_id1" noshow="true" local="true">
        <label>descripcion</label>
        <helper type="combo" xml="cajconceptos_qry.xml" dir="/ayudas" empty="true">
          <field id="ejecuta_concepto" noshow="true">
            <condicion operador="!=">''</condicion>
          </field>
        </helper>
        <detalle>cajconcepto_id1</detalle>
      </field>
      <field id="id_cajpuesto" noshow="true">
        <detalle>cajpuesto_id</detalle>
      </field>
      <field id="descripcion_puesto">
        <label>Puesto</label>
      </field>

      <field id="login" local="true" noshow="true">
        <valor eval="true">$_SESSION['usuario']</valor>
      </field>

    </table>

    <join>
      <table id="CAJ_PUESTO_USERS">
        <field id="cajpuesto_id">
          <condicion operador="=">CAJ_PUESTOS.id_cajpuesto</condicion>
        </field>
        <field id="usuario_id">
          <condicion operador="=">( SELECT Id_usuario FROM HTXUSERS where login = '[__login__]') </condicion>
        </field>
      </table>
    </join>

  </form>
</histrix>
