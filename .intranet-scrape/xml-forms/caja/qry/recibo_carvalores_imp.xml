<?xml version="1.0" encoding="UTF-8"  ?>
<histrix tipo="consulta" showCantidad="true">
  <title>Valores de Terceros</title>
  <obs></obs>

	  <form >
		
			<table id="CAR_MOVIMIENTOS">

			  <field id="cajmovimiento_id" esClave="true" noshow="true"/>

			  <field id="cajmovimientoforce_id" noshow="true" >
			  	<expression having="false">cajmovimiento_id</expression>
			  	<condicion operador="!=">0</condicion>

			  </field>

			  <field id="id_carvalor" tabla="CAR_VALORES" noshow="true">
				<label>codigo</label>
			  </field>
			  <field id="acreditacion_valor" tabla="CAR_VALORES" >
				<label>Fecha</label>
				<tipo>date</tipo>
			  </field>		  
			  <field id="nro_valor" tabla="CAR_VALORES">
				<label>Número</label>
				<format>%012d</format>				
			  </field>
			  <field id="nombre_banco" tabla="CAR_BANCOS">
				<label>Banco</label>
			  </field>
			  <field id="nombre_plaza" tabla="CAR_PLAZAS">
				<label>Plaza</label>
			  </field>
			  <field id="importe_valor" tabla="CAR_VALORES" suma="true">
				<label>Importe</label>
				<tipo>numeric</tipo>
			  </field>

