			<field id="egreso_id" noshow="true">
				<label>Cod. Egreso</label>
				<expression>select CAR0.cajmovimiento_id from CAR_MOVIMIENTOS as CAR0 
					where CAR0.carvalor_id  = CAR_MOVIMIENTOS.carvalor_id and CAR0.tipo_movimiento = 1 limit 1</expression>
			</field>
			<field id="ingreso_id" noshow="true">
				<label>Cod. Egreso</label>
				<expression>select CAR1.cajmovimiento_id from CAR_MOVIMIENTOS as CAR1 
					where CAR1.carvalor_id  = CAR_MOVIMIENTOS.carvalor_id and CAR1.tipo_movimiento = 0 limit 1</expression>
			</field>
			<field id="titular_valor" tabla="CAR_VALORES">
			    <label>Titular</label>
			</field>
			<field id="cuit_valor" tabla="CAR_VALORES">
			    <label>CUIT</label>
			</field>
			<!--
			<group>
			    <field id="nro_valor" />
			</group>
			    -->
			</table>

			 <join>
				<table id="CAR_VALORES">
					<field id="id_carvalor">
						<condicion operador="=">carvalor_id</condicion>
	   				</field>
				</table>
			</join>
			
			<join tipo="left">
				<table id="CAR_BANCOS">
					<field id="id_carbanco">
						<condicion operador="=">CAR_VALORES.carbanco_id</condicion>
	   			    </field>
				</table>
			</join>

			<join tipo="LEFT">
				<table id="CAR_PLAZAS">
					<field id="id_carplaza">
						<condicion operador="=">CAR_VALORES.carplaza_id</condicion>
	   			    </field>
				</table>
			</join>
			<join tipo="LEFT">
			   <table id="CAJ_MOVIMIENTOS">
				<field id="id_cajmovimiento">
				    <condicion operador="=">CAR_MOVIMIENTOS.cajmovimiento_id</condicion>
				</field>
			   </table>
			</join>
			<join tipo="LEFT">
				<table id="CAJ_CONCEPTOS">
					<field id="id_cajconcepto">
					    <condicion operador="=">CAJ_MOVIMIENTOS.cajconcepto_id</condicion>
					</field>
				</table>
			</join>

	</form>
	
</histrix>
