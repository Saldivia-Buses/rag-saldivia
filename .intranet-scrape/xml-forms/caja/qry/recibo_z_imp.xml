				$pdf->Rect($mp - 2 , 005, 015, 015, 0.1);

				// Cliente
				$pdf->Rect(005, 055, $ap, 040, 0.1);

				// DATOS EMPRESA
				//<---->$pdf->SetFontSize(8);
