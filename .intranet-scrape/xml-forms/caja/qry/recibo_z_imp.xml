<?xml version="1.0" encoding="UTF-8"  ?>
<histrix tipo="ficha" PDFsincabecera="true" sololectura="true" autoprint="true" PDFfontSize="8" PDFpageSize="A4" 
	PDForientacion="P"	path="fotos/archivos" pageBreak="true">

  <title>RECIBO</title>
  <obs></obs>
  <form >
            <pdf PDForientacion="P">
