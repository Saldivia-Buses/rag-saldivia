<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta">
  <title>Control de Arqueos</title>
  <obs/>
  <form>
    <table id="CAJ_REGISTROS">

      <fieldGroup>

        <field id="id_cajregistro" noshow="true"/>

        <field id="cajpuesto_id">
          <label>Puesto</label>
          <helper type="combo" xml="cajpuestousers_qry.xml" dir="/ayudas" empty="true"/>
        </field>
        <field id="fecha_registro">
          <label>Fecha</label>
          <tipo>date</tipo>
        </field>
        <field id="operador_nombre">
          <label>Operador</label>
        </field>
        <field id="turno_registro">
          <label>Turno</label>
          <helper type="combo">
            <option value="1">Mañana</option>
            <option value="2">Tarde</option>
            <option value="3">Noche</option>
          </helper>
        </field>
      </fieldGroup>

      <!-- DETALLE DEL ARQUEO -->

      <fieldGroup>
        <field id="id_cajarqueo" tabla="CAJ_ARQUEOS">
          <label>ID Arqueo</label>
        </field>
        <field id="apertura_arqueo" tabla="CAJ_ARQUEOS">
          <label>Apertura</label>
          <expression>CASE WHEN cierre_caja = 2 THEN 0 ELSE apertura_arqueo END</expression>
		  <tipo>numeric</tipo>
        </field>
        <field id="registrado_arqueo" tabla="CAJ_ARQUEOS">
          <label>Registrado</label>
          <expression>CASE WHEN cierre_caja = 2 THEN 0 ELSE registrado_arqueo END</expression>
		  <tipo>numeric</tipo>
        </field>
        <field id="total_arqueo" tabla="CAJ_ARQUEOS">
          <label style="color:blue;font-size:large;">Total</label>
          <expression>CASE WHEN cierre_caja = 2 THEN 0 ELSE total_arqueo END</expression>
		  <tipo>numeric</tipo>
        </field>
        <field id="conteo_arqueo" tabla="CAJ_ARQUEOS">
          <label>Recuento</label>
          <expression>CASE WHEN cierre_caja = 2 THEN 0 ELSE conteo_arqueo END</expression>
		  <tipo>numeric</tipo>
        </field>
        <field id="diferencia_arqueo" tabla="CAJ_ARQUEOS">
          <label style="color:red;font-size:large;">Diferencia</label>
          <expression>CASE WHEN cierre_caja = 2 THEN 0 ELSE diferencia_arqueo END</expression>
		  <tipo>numeric</tipo>
        </field>
        <field id="cajregistro_id" tabla="CAJ_ARQUEOS" noshow="true"/>
      </fieldGroup>
      
      
      <!-- OPERACIONES DE ADMINISTRACION -->

      <field id="esadmin" local="true" noshow="true">
        <if exp="$_SESSION['administrator'] == 1">
          <true>'false'</true>
          <false>'true'</false>
        </if>
      </field>

      <fieldGroup>
        <if>return $_SESSION['administrator'] != 1;</if>
        <field id="cierre_caja" style="display:none;" deshabilitado="true">
          <expression having="false">cierre_caja</expression>
          <condicion operador="=">1</condicion>
        </field>
      </fieldGroup>

      <fieldGroup>
        <if>return $_SESSION['administrator'] == 1;</if>
        <field id="cierre_caja">
          <label>Estado</label>
          <helper type="combo">
            <option value=""/>
            <option value="0">Abierta</option>
            <option value="1">Cerrada</option>
            <option value="2">Anulada</option>
            <option value="5">Aprobada</option>
            <option value="9">Integrada</option>
          </helper>
        </field>
        <field id="modificacion" local="true" print="false" tdWidth="50px">
          <expression>CASE WHEN cierre_caja = 0 THEN 'MODIFICAR' ELSE '' END</expression>
          <helper type="link" xml="modificacion_caja_ing.xml" dir="/caja/proc" modal="true">
            <parameter source="id_cajregistro" target="id_cajregistro" />
          </helper>
        </field>
        <field id="re_apertura" local="true" print="false" tdWidth="50px">
          <expression>CASE WHEN cierre_caja in (1,9) THEN 'REABRIR' ELSE '' END</expression>
          <helper type="link" xml="reapertura_caja_ing.xml" dir="/caja/proc" modal="true">
            <parameter source="id_cajarqueo" target="id_cajarqueo" />
          </helper>
        </field>
      </fieldGroup>

	<!-- MINUTA -->
	<field id="consulta_minuta" local="true" print="false" tdWidth="50px">
	    <expression>CASE WHEN cierre_caja = 9 THEN 'MINUTA' ELSE '' END</expression>
		<helper type="link" xml="minuta_ficha_qry.xml" dir="contabilidad/qry" title="Asiento Integrado" >
			<parameter source="id_cajregistro" target="cajregistro_id" />
		</helper>
	</field>

      <!-- IMPRESION -->
      <field id="imprimi_planilla" local="true" print="false" tdWidth="50px">
        <expression>CASE WHEN cierre_caja > 0 THEN 'IMPRIMIR' ELSE '' END</expression>
        <helper type="link" xml="cajresumen_qry.xml">
          <parameter source="id_cajregistro" target="id_cajregistro"/>
        </helper>
      </field>

      <!-- FILTRO -->
      <filters>
        <field id="cajpuesto_id">
          <label>Puesto</label>
        </field>
        <field id="fecha_registro">
          <label>Desde</label>
          <operador>&gt;=</operador>
          <valor>today</valor>
        </field>
        <field id="fecha_registro">
          <label>Hasta</label>
          <operador>&lt;=</operador>
          <valor>today</valor>
        </field>
        <field id="cierre_caja">
          <label>Cajas</label>
          <operador>=</operador>
          <valor>1</valor>
          <attribute id="noshow">esadmin</attribute>
        </field>
      </filters>
      
    </table>
    
    <join tipo="left">
      <table id="CAJ_ARQUEOS">
        <field id="cajregistro_id">
          <condicion operador="=">id_cajregistro</condicion>
        </field>
      </table>
    </join>
    
  </form>
</histrix>
