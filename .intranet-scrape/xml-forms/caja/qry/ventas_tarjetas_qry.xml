<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" showCantidad="false" preloadData="false">
  <title>Resumen de Movimientos</title>
  <obs/>
  <form>
    <table id="CAJ_MOVIMIENTOS" label="Movimientos">

      <filters>
        <field id="fecha_movimiento">
          <label>Desde</label>
          <operador>&gt;=</operador>
          <valor>today</valor>
          <tipo>date</tipo>
        </field>
        <field id="fecha_movimiento">
          <label>Hasta</label>
          <operador>&lt;=</operador>
          <valor>today</valor>
          <tipo>date</tipo>
        </field>
        <field id="cajconcepto_id">
          <label>Descripción</label>
          <operador>=</operador>
        </field>
        <field id="cajpuesto_id">
          <label>Puesto</label>
          <operador>=</operador>
        </field>
      </filters>

      <field id="id_cajmovimiento" esClave="true" noshow="true"/>

      <field id="id_regcuenta" tabla="REG_CUENTA" break="true" noshow="true"/>

      <field id="nombre_cuenta" tabla="REG_CUENTA" repeat="false">
        <label>Medio</label>
      </field>

      <field id="cajconcepto_id" noshow="true">
        <helper type="combo" id="CAJ_CONCEPTOS" empty="true">
          <field id="id_cajconcepto"/>
          <field id="descripcion_concepto"/>
          <field id="imputacion_concepto">
            <condicion operador="=">0</condicion>
          </field>
        </helper>
      </field>

      <field id="fecha_movimiento" _noshow="true">
        <label>fecha</label>
      </field>

      <field id="cajpuesto_id" _noshow="true">
        <helper type="combo" xml="cajpuestousers_qry.xml" dir="/ayudas" empty="true"/>
      </field>

      <field id="nro_comp" _tdWidth="200px" PDFcolWidth="100" linkdes="Detalle de Comprobante">
        <expression>CONCAT(CAJ_CONCEPTOS.abreviatura_concepto, ' 0000-',lpad(CAJ_MOVIMIENTOS.nro_movimiento,8,'0'))</expression>
        <helper type="link" dir="/caja/proc/del" xml="cajmovimiento_ficha.xml">
          <parameter source="id_cajmovimiento" target="id_cajmovimiento" operador="="/>
        </helper>
        <label>Comprobante</label>
      </field>

      <field id="puesto_movimiento" tabla="REG_MOVIMIENTOS">
        <label>Lote</label>
      </field>

      <field id="nro_movimiento" tabla="REG_MOVIMIENTOS">
        <label>Número</label>
        <formato>%08d</formato>
      </field>

      <field id="cuota_movimiento" tabla="REG_MOVIMIENTOS">
        <label>Ctas</label>
      </field>

      <field id="importe_movimiento" tabla="REG_MOVIMIENTOS" suma="true">
        <label>Importe</label>
        <tipo>numeric</tipo>
      </field>

      <field id="cajformapago_id" tabla="CAJ_VALORES" noshow="true">
        <condicion operador="=">[__formapago_tarjeta__]</condicion>
      </field>

      <field id="formapago_tarjeta" local="true" noshow="true">
        <helper type="parameter" id="SIS::04:forma_pago_tarjetas"/>
      </field>

      <group>
        <field id="id_cajmovimiento"/>
      </group>

      <order>
        <field id="nombre_cuenta" tabla="REG_CUENTA"/>
        <field id="fecha_movimiento" tabla="CAJ_MOVIMIENTOS"/>
      </order>
    </table>
    <join>
      <table id="CAJ_CONCEPTOS">
        <field id="id_cajconcepto">
          <condicion operador="=">CAJ_MOVIMIENTOS.cajconcepto_id</condicion>
        </field>
        <field id="imputacion_concepto">
          <condicion operador="=">0</condicion>
        </field>
      </table>
    </join>
    <join tipo="left">
      <table id="CAJ_VALORES">
        <field id="cajmovimiento_id">
          <condicion operador="=">CAJ_MOVIMIENTOS.id_cajmovimiento</condicion>
        </field>
      </table>
    </join>
    <join tipo="left">
      <table id="REG_MOVIMIENTOS">
        <field id="cajmovimiento_id">
          <condicion operador="=">CAJ_MOVIMIENTOS.id_cajmovimiento</condicion>
        </field>
      </table>
    </join>
    <join>
      <table id="REG_CUENTA">
        <field id="id_regcuenta">
          <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
        </field>
      </table>
    </join>
  </form>
</histrix>
