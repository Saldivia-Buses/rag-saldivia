<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" >
    <title>Cierre de Puesto de Caja</title>
    <obs></obs>
    <form detalle="cajintegracion_detalle_qry.xml" inline="true">
        <table id="CAJ_MOVIMIENTOS" label="Consulta de integraciones contables">

            <!--

            <movimientos cabecera="cierre_caja_cab.xml">
            <relacion id="cierre_ctbmovimiento_ins.xml"></relacion>
            <relacion id="cierre_ctbdetalle_ins.xml"></relacion>
            <relacion id="cierre_cajmovimiento_ins.xml"></relacion>
            <relacion id="cierre_cajdetalle_ins.xml"></relacion>
            <relacion id="cierre_cajregistro_upd.xml"></relacion>
        </movimientos>
        -->
        <filters>
            <field id="cajpuesto_id">
                <label>Puesto</label>
                <operador>=</operador>
            </field>
            <field id="cajconcepto_id">
                <label>Concepto</label>
                <operador>=</operador>
            </field>
            <field id="fecha_movimiento">
                <label>Desde</label>
                <operador>&gt;=</operador>
                <valor>today</valor>
            </field>
            <field id="fecha_movimiento">
                <label>Hasta</label>
                <operador>&lt;=</operador>
                <valor>today</valor>
            </field>
        </filters>
        <!-- ************************************************************ -->
        <!-- FILTROS **************************************************** -->
        <!-- ************************************************************ -->
        <field id="id_cajmovimiento" noshow="true" tipoOrden="DESC" >
            <detalle>cajmovimiento_id</detalle>
        </field>
        <field id="cajconcepto_id" noshow="true">
            <helper type="combo" id="CAJ_CONCEPTOS" >
                <field id="id_cajconcepto" />
                <field id="descripcion_concepto" />
                <field id="ejecuta_concepto" oculto="true">
                    <expresion>ifnull(ejecuta_concepto,'')</expresion>
                    <condicion operador="=">''</condicion>
                </field>
                <field id="alta_concepto" oculto="true">
                    <expresion>ifnull(alta_concepto,0)</expresion>
                    <condicion operador="=">0</condicion>
                </field>
                <field id="baja_concepto" oculto="true">
                    <expresion>ifnull(baja_concepto,0)</expresion>
                    <condicion operador="=">0</condicion>
                </field>
                <field id="modif_concepto" oculto="true">
                    <expresion>ifnull(modif_concepto,0)</expresion>
                    <condicion operador="=">0</condicion>
                </field>
            </helper>
            <label>Concepto</label>
        </field>
        <field id="importe_movimiento" noshow="true">
            <label>Importe</label>
            <condicion operador="=">0</condicion>
        </field>
        <field id="fecha_movimiento">
            <label>Fecha</label>
        </field>
        <field id="cajpuesto_id">
            <helper type="combo" xml="cajpuestousers_qry.xml" dir="/ayudas" empty="true" />
            <label>Puesto</label>
        </field>
        <field id="referencia_movimiento">
            <label>Referencia</label>
        </field>
        <field id="desintegrar" local="true">
            <label>Desintegrar</label>
            <helper type="link" xml="cajintegracion_fichaing.xml" dir="/caja/proc/">
                <parameter source="id_cajmovimiento" target="id_cajmovimiento" />
            </helper>
            <valor>&gt;&gt;</valor>
        </field>
        <order>
            <field id="id_cajmovimiento" />
        </order>
    </table>
    <join>
        <table id="CAJ_CONCEPTOS">
            <field id="id_cajconcepto">
                <condicion operador="=">CAJ_MOVIMIENTOS.cajconcepto_id</condicion>
            </field>
        </table>
    </join>
