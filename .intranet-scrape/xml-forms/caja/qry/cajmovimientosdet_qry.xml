<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" showCantidad="false" tooltip="false" preloadData="false">
    <title>Consulta Detallada</title>
    <obs/>
    <form >
        <table id="CAJ_MOVIMIENTOS">
		
	<filters>
                <field id="fecha_movimiento">
			<label>Desde Fecha</label>
		        <operador>&gt;=</operador>
		</field>
                <field id="fecha_movimiento">
			<label>Hasta Fecha</label>
			<operador>&lt;=</operador>
			<valor>today</valor>
	 	</field>
                <field id="cajconcepto_id"  >
			<label>descripcion</label>
	                <helper type="combo" xml="cajconceptos_qry.xml" dir="/ayudas" >
				<field id="id_cajconcepto" autoinc="true" noshow="true">
			      		<label>Código</label>
				</field>
				<field id="descripcion_concepto">
			      		<label>Descripcion</label>
				</field>

				<field id="imputacion_concepto" noshow="true">
				      <detalle>imputacion_concepto</detalle>
				</field>
			</helper>
			<operador>=</operador>
		</field>
	</filters>
	
                <field id="fecha_movimiento">
			<label>Fecha</label>
		</field>
                <field id="cajconcepto_id"  >
			<label>descripcion</label>
	                <helper type="combo" xml="cajconceptos_qry.xml" dir="/ayudas" empty="true">
				<field id="id_cajconcepto" autoinc="true" noshow="true">
			      		<label>Código</label>
				</field>
				<field id="descripcion_concepto">
			      		<label>Descripcion</label>
				</field>

				<field id="imputacion_concepto" noshow="true">
				      <detalle>imputacion_concepto</detalle>
				</field>
			</helper>
		</field>
                <field id="numero">
			<expresion>case when not isnull(REG_MOVIMIENTOS.cajmovimiento_id) then 
			concat(REG_MOVIMIENTOS.letra_movimiento,' ', LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,'0'), ' ' ,LPAD(REG_MOVIMIENTOS.nro_movimiento,8,'0'))
			else concat('X 0001 ' ,LPAD(CAJ_MOVIMIENTOS.id_cajmovimiento,8,'0')) end
			</expresion>
			<label>Numero</label>
		</field>
                <field id="abreviatura_forma"  tabla="CAJ_FORMAS_PAGO">
			<label>Valor</label>
		</field>
                <field id="debe">
			<expresion>sum(case when imputacion_concepto = 0 then CAJ_MOVIMIENTOS.importe_movimiento else 0 end)</expresion>
			<label>Debe</label>
			<tipo>numeric</tipo>
		</field>
                <field id="haber">
			<expresion>sum(case when imputacion_concepto = 0 then 0 else CAJ_MOVIMIENTOS.importe_movimiento end)</expresion>
			<label>Haber</label>
			<tipo>numeric</tipo>
		</field>
		    <group>
		        <field id="id_cajmovimiento" />
		    </group>
		    <order>
	                <field id="fecha_movimiento" tabla="CAJ_MOVIMIENTOS"/>

	                <field id="cajconcepto_id" />
		    </order>
        </table>


        <join tipo="LEFT" >
            <table id="REG_MOVIMIENTOS">
                <field id="cajmovimiento_id">
                    <condicion operador="=">CAJ_MOVIMIENTOS.id_cajmovimiento</condicion>
                </field>
            </table>
        </join>
        <join>
            <table id="CAJ_CONCEPTOS">
                <field id="id_cajconcepto">
                    <condicion operador="=">CAJ_MOVIMIENTOS.cajconcepto_id</condicion>
                </field>
            </table>
        </join>
        <join>
            <table id="CAJ_VALORES">
                <field id="cajmovimiento_id">
                    <condicion operador="=">CAJ_MOVIMIENTOS.id_cajmovimiento</condicion>
                </field>
            </table>
        </join>
        <join>
            <table id="CAJ_FORMAS_PAGO">
                <field id="id_cajformapago">
                    <condicion operador="=">CAJ_VALORES.cajformapago_id</condicion>
                </field>
            </table>
        </join>
    </form>
</histrix>
