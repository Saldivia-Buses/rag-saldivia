        <field id="porcentaje_desc0" noshow="true">
          <valor default="true">0.00</valor>
          <tipo>decimal</tipo>
        </field>
        
        <field id="porcentaje_desc1" noshow="true" >
          <tipo>decimal</tipo>
          <valor default="true">0.00</valor>
        </field>

        <field id="codigo_detalle" deshabilitado="false" esClave="true" valid="true">
          <label >Codigo</label>
          <helper type="external" xml="stkarticulo_cav.xml" dir="/ayudas">
              <field id="wstklista_id"      local="true" noshow="true" />
          </helper>
          <size>12</size>
        </field>
      
        <field id="descripcion_detalle" deshabilitado="true" activador="libre" modpos="nobr" >
          <label>Descripción</label>
          <size>50</size>
        </field>

        <field id="libre" activa="true" local="true" colstyle="display:none;" modpos="nobr" sincelda="true">
          <label>libre</label>
          <tipo>check</tipo>
        </field>

        <field id="precio_venta" local="true" deshabilitado="true" modpos="nobr">
          <label>Precio U.</label>
          <tipo>decimal</tipo>
          <valor default="true">0.00</valor>
        </field>

        <field id="cantidad_detalle" replace="true" _modpos="nobr">
          <label>Cantidad</label>
          <tipo>decimal</tipo>
          <valor dafault="true">1.00</valor> 
          <jseval fielddestino="neto_detalle" actxml="false" suma="true"> ( precio_venta * cantidad_detalle ).toFixed(2)</jseval> 
          <jseval fielddestino="iva_detalle" actxml="false" suma="true">( ( precio_venta * cantidad_detalle ) * ( iva_alicuota / 100 ) ).toFixed(2)</jseval> 
          <jseval fielddestino="total_detalle" actxml="false" suma="true">
             (( precio_venta * cantidad_detalle ) + ( ( precio_venta * cantidad_detalle ) * ( iva_alicuota / 100 ) )  ).toFixed(2)
          </jseval> 
        </field>
       
        <field id="neto_detalle" local="true" modpos="nobr" deshabilitado="true" suma="true">
          <label>Neto</label>
          <tipo>decimal</tipo>
          <!-- <valor default="true">0.00</valor> -->
          <jseval fielddestino="subtotal_movimiento" total="true">neto_detalle</jseval> 
        </field>


    <!-- ID_IVA_ALICUOTA  id del iva de articulo       IVA_ALICUOTA porcentaje de iva en numeros     IVA DETALLE iva discriminado del precio del producto -->


<field id="separator11" local="true" modpos="nobr" deshabilitado="true"/>

      <field id="id_iva_alicuota" esClave="true"  local="true" required="true" deshabilitado="true" modpos="nobr">
        <label>Alicuota Iva</label>
        <helper type="combo" xml="genalicuotas_qry_cav.xml" dir="/ayudas" empty="true" />
      </field>

      <field id="iva_alicuota"  local="true" deshabilitado="true" noshow="true">
        <label>Iva</label>
      </field>

      <field id="iva_detalle" suma="true" deshabilitado="true" _modpos="nobr">
        <label>Iva Detalle</label>
        <tipo>numeric</tipo>
          <jseval fielddestino="importe_IVA" total="true">iva_detalle</jseval> 
          <jseval fielddestino="mi_importe_iva" total="true">iva_detalle</jseval>    
      </field>

    <!-- FIN DETALLE DE IVA -->


    <field id="total_detalle" suma="true" modpos="nobr">
      <label>Total</label>
      <tipo>decimal</tipo>
      <valor default="true">0.00</valor>

      <jseval fielddestino="neto_detalle" actxml="false" suma="true"> ( total_detalle / (1 + (iva_alicuota/100)) ).toFixed(2) </jseval>
      <jseval fielddestino="iva_detalle" actxml="false" suma="true">( ( total_detalle / (1 + (iva_alicuota/100)) ) * (iva_alicuota/100) ).toFixed(2)</jseval>


      <jseval fielddestino="importe_movimiento" total="true">total_detalle</jseval> 
      <detalle>importe_movimiento</detalle>
    </field>
   
  </fieldGroup>

    <field id="id_regdetalle" autoinc="true" esClave="true" noshow="true"/>

