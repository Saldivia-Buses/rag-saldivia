<?xml version="1.0" encoding="UTF-8"?>
<!--
	Esta grabación tiene como objetivo grabar la partida referida 
	a la cuenta de iva en un asiento de caja
-->
<histrix tipo="insert">
  <title>Grabación Importe Percepcion en Detalle Movimiento de Caja</title>
  <obs/>
  <form >
    <table id="CAJ_DETALLES" idCampoCond="importe_percepcion">
      <field id="cajmovimiento_id"  lastId="cajmovimientos_ins.xml"/>
      <field id="cuenta_id"        id_temp="ctbcuenta_per_id"/>
      <field id="doh"              id_temp="ctbcuenta_per_doh">
      	<tipo>varchar</tipo>
      </field>     
      <field id="importe_detalle"  id_temp="importe_percepcion"/>
    </table>
  </form>
</histrix>
