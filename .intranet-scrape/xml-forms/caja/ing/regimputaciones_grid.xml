<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="grid" subtipo="vertical" inserta="false" borra="false" modifica="false" imprime="false" deleteRow="false" exportasuma="true" llenoreferente="true" llenotemporal="true">
  <title>Comprobantes a Imputar</title>
  <obs/>
  <form>
    <table id="REG_MOVIMIENTOS">
	
      <movimientos>
        <relacion id="regimputaciones_ins.xml"/>
      </movimientos>

      <fieldGroup>

            <field id="id_regmovim" esClave="true" noshow="true" />

            <field id="imputacion_concepto" local="true" noshow="true" />

            <field id="imputacion_concepto2" noshow="true" local="true">
              <expression>REG_CONCEPTOS.imputacion_concepto</expression>
            </field>

            <field id="deshabilita" noshow="true">
              <expression>CASE WHEN REG_CONCEPTOS.imputacion_concepto != '[__imputacion_concepto__]' OR (REG_NUMERADORES.fiscal = 1 AND REG_NUMERADORES.printer = 'WSAFIP' AND IFNULL(REG_MOVIMIENTOS.numero_cae + 0, 0) = 0) THEN 'true' ELSE 'false' END</expression>
            </field>

            <field id="colorea" noshow="true" clasefila="true">
              <expression>CASE WHEN REG_CONCEPTOS.imputacion_concepto != '[__imputacion_concepto__]' OR (REG_NUMERADORES.fiscal = 1 AND REG_NUMERADORES.printer = 'WSAFIP' AND IFNULL(REG_MOVIMIENTOS.numero_cae + 0, 0) = 0) THEN 'resaltadoRojo' ELSE '' END</expression>
            </field>

            <field id="subsistema_id" noshow="true"/>

            <field id="regcuenta_id" noshow="true">
              <condicion operador="=">-1</condicion>
            </field>


      </fieldGroup>

      <fieldGroup style="text-align:center;padding:2px 2px 2px 2px;">

        <field id="fecha">
          <label>Fecha</label>
          <tipo>date</tipo>
          <expression>fecha_movimiento</expression>          
        </field>

        <field id="vencimiento_movimiento">
          <label>Vto</label>
          <tipo>date</tipo>
        </field>

        <field id="comprobante">
          <label>Comprobante</label>
          <expression>CONCAT((IF(REG_NUMERADORES.fiscal = 1 AND REG_NUMERADORES.printer = 'WSAFIP' AND IFNULL(REG_MOVIMIENTOS.numero_cae + 0, 0) = 0, ' NO AUTORIZADA: ', '')), REG_CONCEPTOS.abreviacion_concepto, ' ', REG_MOVIMIENTOS.letra_movimiento, ' ', LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,'0'), '-', LPAD(REG_MOVIMIENTOS.nro_movimiento  ,8,'0'))</expression>
        </field>

        <field id="cuota_movimiento">
          <label>Cta</label>
        </field>

        <!-- Segun la imputacion del comprobante principal varia los comprobantes a imputar y el saldo de los mismos -->
        <field id="imputacion_concepto_comprobante_llama" local="true" noshow="true" />

        <!-- Normalizo para que solo traiga los comprobantes de la contrapartida -->
        <field id="imputacion_concepto_comprobante_imputa" noshow="true">
          <expression>REG_CONCEPTOS.imputacion_concepto</expression>
        </field>

      </fieldGroup>

      <fieldGroup style="text-align:right;padding:2px 2px 2px 2px;">

        <field id="importe_original">
          <expression>importe_movimiento</expression>
          <tipo>numeric</tipo>
          <label>Importe Original</label>
        </field>

        <!-- Normalizo el saldo para que siempre se vea en positivo -->

        <field id="saldo_movimiento22" suma="true" noshow="true">
          <label>Saldo</label>
          <expression having="false">IF( [__imputacion_concepto_comprobante_llama__] + 0 = 0, 1, -1) * saldo_movimiento</expression>
          <condicion operador="!=">0</condicion>
        </field>

        <field id="saldo_movimiento" suma="true" >
          <label>Saldo</label>
          <expression having="false">CASE WHEN REG_CONCEPTOS.imputacion_concepto != '[__imputacion_concepto__]' THEN abs(saldo_movimiento) ELSE  (IF( [__imputacion_concepto_comprobante_llama__] + 0 = 0, 1, -1) * saldo_movimiento) END</expression>
          <condicion operador="!=">0</condicion>
        </field>

        <field id="Imputado" local="true" refresh="true" style="text-align:center;">
          <label>Imputar</label>
          <tipo>check</tipo>       
          <attribute id="deshabilitado">deshabilita</attribute>
        </field>
      </fieldGroup>

      <field id="habil" local="true" noshow="true">
        <if exp="Imputado != 1">
          <true>'true'</true>
          <false>'false'</false>
        </if>
      </field>

      <field id="total_imputado" local="true" suma="true" editable="true" deshabilitado="true" >        
        <label>Total Imputado</label>
        <if exp="Imputado == 1">
          <true>(total_imputado != 0)?total_imputado:saldo_movimiento</true>
          <false>0</false>
        </if> 
        <jseval >total_imputado &lt;= saldo_movimiento</jseval>
        <jseval campodestino="importe_imputado" total="true">total_imputado</jseval>
        <detalle>importe_imputado</detalle>
        <tipo>numeric</tipo>
        <attribute id="deshabilitado">habil</attribute>
      </field>

      <!-- SE COMENTO EL ORDEN EN ESTE XML HASTA QUE SE RESUELVA PORQUE LA LISTA NO PUEDE SER ORDENADA
      <order>
        <field id="fecha_movimiento" tabla="REG_MOVIMIENTOS" />
      </order> -->

    </table>

    <join>
      <table id="REG_CONCEPTOS">
        <field id="subsistema_id">
          <condicion operador="=">REG_MOVIMIENTOS.subsistema_id</condicion>
        </field>
        <field id="id_concepto">
          <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
        </field>
        <field id="informa_calculo">
          <condicion operador="=">0</condicion>
        </field>
      </table>
    </join>

    <join tipo="left">
      <table id="REG_NUMERADORES">
        <field id="subsistema_id">
          <condicion operador="=">REG_MOVIMIENTOS.subsistema_id</condicion>
        </field>
        <field id="regconcepto_id">
          <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
        </field>
        <field id="puesto">
          <condicion operador="=">REG_MOVIMIENTOS.puesto_movimiento</condicion>
        </field>
        <field id="letra">
          <condicion operador="=">REG_MOVIMIENTOS.letra_movimiento</condicion>
        </field>
      </table>
    </join>

  </form>
</histrix>