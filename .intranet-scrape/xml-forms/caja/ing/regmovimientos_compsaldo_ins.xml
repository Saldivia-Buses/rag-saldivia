<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="insert">
    <title/>
    <obs/>
    <form>
        <table id="REG_MOVIMIENTOS" idCampoCond="imputado">
            <field id="subsistema_id"      	id_temp="subsistema_forma_id">
        	   <tipo>varchar</tipo>
            </field>
            <field id="regcuenta_id"     	id_temp="regcuenta_id" />
            <field id="concepto_id"      	id_temp="regconcepto_forma_id"/>


            <field id="fecha_movimiento"    id_temp="fecha_movimiento"/>
            <field id="reg_fecha"           id_temp="fecha_movimiento"/>
            <field id="neto_movimiento"     id_temp="imputado"/>
            <field id="importe_iva"         id_temp="importe_iva"/>
            <field id="importe_exento"      id_temp="importe_exento"/>
            <field id="importe_ibr"         id_temp="importe_ibr"/>
            <field id="alicuota_iva"        id_temp="alicuota_iva"/>
            <field id="conciliado"          id_temp="fecha_movimiento" />

            <field id="importe_movimiento"  id_temp="imputado"/>
            <field id="saldo_movimiento"    id_temp="importe_anticipo"/>

            <field id="referencia_movimiento"   id_temp="referencia_movimiento">
              <tipo>varchar</tipo>
            </field>
            <field id="vencimiento_movimiento"  id_temp="vencimiento_movimiento"/>
            
            <field id="cajmovimiento_id"    lastId="cajmovimientos_ins.xml"/>
            
            <field id="puesto_movimiento"       id_temp="puesto_movimiento"/>

            <field id="cajconcepto_id"    id_temp="cajconcepto_id" local="true" />
            <field id="nro_movimiento">
                <valor>(select numero from CAJ_NUMERADORES where subsistema_id = '03' and cajpuesto_id = '0' and cajconcepto_id = '[__cajconcepto_id__]')</valor>
            </field>

            <field id="letra_movimiento" id_temp="letra_movimiento" />

        </table>
    </form>
</histrix>	
