<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="fichaing" inserta="false" borra="false" modifica="false" imprime="false" tooltip="false" confirma="GRABAR" form="false" llenotemporal="true" limit="1"
 transaccional="true" preFetch="true">
    <title>Transferencia Entre Puestos</title>
    <obs></obs>
    <form>
        <table id="HTXMENU">

            <cierraproceso id="cajmovimientos_ing.xml" >
                <paring destino="moneda_id">moneda_id</paring>
                <paring destino="cajpuesto_id">cajpuesto_id</paring>
                <paring destino="cajconcepto_id">cajconcepto_id</paring>
                <paring destino="cajregistro_id">cajregistro_id</paring>
                <paring destino="importe_movimiento">importe_movimiento</paring>
                <paring destino="fecha_movimiento">fecha_movimiento</paring>
                <paring destino="referencia_movimiento">referencia_movimiento</paring>
                <paring destino="nro_movimiento">nro_movimiento</paring>
                <paring destino="imputacion_concepto">imputacion_concepto</paring>
                <paring destino="ctbcuenta_reg_id">ctbcuenta_reg_id</paring>
                <paring destino="ctbcuenta_reg_doh">ctbcuenta_reg_doh</paring>
            </cierraproceso>

            <movimientos>
                <relacion id="trans_cajmovim_ins.xml"/>
                <relacion id="trans_cajvalor_ins.xml"/>
                <relacion id="impresion_caja.xml"/>
            </movimientos>

            <field id="transferencia" local="true" style="background-color:#000;color:#fff;padding-top:5px;padding-bottom:5px;text-align:center;" colspan="12" deshabilitado="true" noshow="true">      
                <attribute id="noshow">oculta_titulos</attribute>
                  <valor>Transferencia entre Puestos</valor>
                  <size>40</size>
            </field>

            <field id="oculta_titulos" local="true" noshow="true">
              <helper type="parameter" id="SIS::02::oculta_titulos">
                  <label>Oculta titulos identificadores en programas de caja</label>
                  <defaultValue>false</defaultValue>
              </helper>
            </field>

            <field id="id_cajmovimiento" noshow="true" local="true">
                <detalle>id_cajmovimiento</detalle>
            </field>

            <fieldGroup id="DEBUG" local="true" noshow="true">
                <field id="cajpuesto_id" />
                <field id="cajconcepto_id" />
                <field id="cajregistro_id"  />
                <field id="fecha_movimiento" />
                <field id="imputacion_concepto"><label>IC</label></field>
                <field id="tipoimpre_concepto"/>
                <field id="imprime_concepto"/>
                <field id="moneda_id"><valor>1</valor></field>
                <field id="id_cajregistro" />
            </fieldGroup>

            <field id="cajpuestodestino_id" local="true">
                <label>Puesto Destino</label>
                <helper type="combo" xml="trans_cajmovim_qry.xml" empty="true">
                    <field id="id_cajpuesto">
                        <condicion operador="!=" valorde="cajpuesto_id" />
                    </field>
                    <field id="fecha_reg">
                        <condicion operador="=" valorde="fecha_movimiento"/>
                        <tipo>date</tipo>
                        <expression having="false">CAJ_REGISTROS.fecha_registro</expression>
                    </field>
                </helper>
            </field>
            
            <field id="nro_movimiento" deshabilitado="true" local="true">
                <label>Nº Comprobante</label>	
                <parametro id="cajnumerador_param.xml" retorna="numero">
                    <field id="numero">
                        <complete>numero + 1</complete>
                    </field>
                </parametro>
                <format>%08d</format>
                <size>8</size>
                <detalle>nro_movimiento</detalle>
            </field>
            
            <field id="referencia_movimiento" local="true" maxlength="144" deshabilitado="false" editable="true">
                <label>Referencia</label>
                <tipo>varchar</tipo>
                <size>144</size>
                <expression>CONCAT('Transferencia desde',': ',CAJ_PUESTOS.descripcion_puesto)</expression>
            </field>

            <field id="importe_movimiento" local="true" _deshabilitado="true">
                <label style="font-size: large;">Total</label>
            </field>

            <!-- REGISTRACION -->

            <field id="cajformapagodestino_id" noshow="true">
                <expression>CAJ_PUESTOS.cajformapagodif_id</expression>
            </field>

            <field id="cajconceptodestino_id" noshow="true">
                <expression>CAJ_CONCEPTOS.cajconceptorel_id</expression>
            </field>

            <field id="ctbcuenta_reg_id" noshow="true">
                <expression>CAJ_FORMAS_PAGO.ctbcuenta_forma_id</expression>
            </field>

            <field id="ctbcuenta_reg_doh" local="true" noshow="true">
                <if exp="imputacion_concepto == 0">
                    <true>1</true>
                    <false>0</false>
                </if>
            </field>

            <field id="muestracheck" local="true" noshow="true">
                <expression>IF('[__tipoimpre_concepto__]' != '2', 'display:none;', '')</expression>
            </field>

            <field id="CHKimprime" local="true">
                <attribute id="style">muestracheck</attribute>
                <label style="font-size: medium; align: right;" _modpos="nobr">Imprime Comprobante</label>
                <tipo>check</tipo>
            </field>

            <field id="impresion" local="true" noshow="true" deshabilitado="true">
                <label>Programa de Impresion</label>
                <if exp="CHKimprime == '1' || tipoimpre_concepto == '1'">
                    <true>'imprime_concepto'</true>
                    <false>''</false>
                </if>
            </field>

        </table>
        <join>
            <table id="CAJ_PUESTOS">
                <field id="id_cajpuesto">
                <condicion operador="=">'[__cajpuesto_id__]'</condicion>
                </field>
            </table>
        </join>

        <join>
            <table id="CAJ_CONCEPTOS">
                <field id="id_cajconcepto">
                    <condicion operador="=">'[__cajconcepto_id__]'</condicion>
                </field>
            </table>
        </join>

        <join tipo="left">
            <table id="CAJ_FORMAS_PAGO">
                <field id="id_cajformapago">
                    <condicion operador="=">CAJ_PUESTOS.cajformapagodif_id</condicion>
                </field>
            </table>
        </join>
   </form>
</histrix>