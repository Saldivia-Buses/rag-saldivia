<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="ing" subtipo="vertical" preloadData="false" procesa="false" llenoreferente="true" llenotemporal="true" tooltip="false" showCantidad="false" updateTotals="true" >

    <title>Detalle</title>
    <obs></obs>
    <form >
        <table id="REG_DETALLES" label="movimientos">

            <movimientos>
                <relacion id="mos_regdetalle_auto_ins.xml"/>
            </movimientos>

            <field id="id_regdetalle" noshow="true" esClave="true" />

            <field id="fecha_movimiento" local="true" noshow="true" />

            <field id="orden" esClave="true" noshow="true">
                <if exp="true">
                    <true>_ORDEN + 0</true>
                    <false>0</false>
                </if>
            </field>

            <field id="codigo_detalle" esClave="true" deshabilitado="true" noshow="true">
                <label>Cod.</label>
            </field>

            <field id="descripcion_detalle" rowspan="9">
                 <label>Detalle</label>
                 <tipo>simpleditor</tipo> 
            </field>

            <field id="cantidad_detalle">
                <label>Cant.</label>
                <tipo>numeric</tipo>
                <size>10</size>
                <valor dafault="true">1</valor>
                <jseval fielddestino="total_detalle">(cantidad_detalle * precio_vta).toFixed(2)</jseval>
            </field>

            <field id="precio_vta" local="true" preventLoop="true">
                <label Formstyle="width: 100px;">Importe</label>
                <tipo>numeric</tipo>
                <jseval fielddestino="neto_detalle"   actxml="false">(alicuota != 0) ? (( cantidad_detalle * precio_vta  ) / ( 1 + ( alicuota / 100)) ).toFixed(2) : 0</jseval>

                <jseval fielddestino="importe_iva"    actxml="false">(alicuota != 0) ? ( neto_detalle * ( ( alicuota / 100))  ).toFixed(2) : 0</jseval>

                <jseval fielddestino="exento_detalle" actxml="false">(alicuota == 0) ? (( cantidad_detalle * precio_vta  )                            ).toFixed(2) : 0</jseval>
                <jseval fielddestino="total_detalle"  actxml="fasle">(cantidad_detalle * precio_vta).toFixed(2)</jseval>
            </field>

            <!-- Alicuota de IVA a aplicar -->

            <field id="alicuota" local="true">
                <label>Alicuota</label>
                <options>
                        <option valor="0">Sin Iva</option>
                </options>

                <tabla_ex id="GEN_IVA_ALICUOTAS">
                    <field id="alicuota" />

                    <field id="alicuota2">
                        <expresion>alicuota</expresion>
                        <label>Alicuota</label>
                    </field>
                    <field id="iva_id" oculto="true">
                        <condicion operador="=">1</condicion>
                    </field>
                </tabla_ex>
                <valor>21</valor>

                <jseval fielddestino="neto_detalle"   actxml="false">(alicuota != 0) ? (( cantidad_detalle * precio_vta  ) / (  1 + ( alicuota  / 100)) ) ).toFixed(2) : 0</jseval>
                <jseval fielddestino="importe_iva"    actxml="false">(alicuota != 0) ? ( neto_detalle * ( ( alicuota / 100))  ).toFixed(2) : 0</jseval>                
                <jseval fielddestino="exento_detalle" actxml="false">(alicuota == 0) ? (( cantidad_detalle * precio_vta  )                            ).toFixed(2) : 0</jseval>
                <jseval fielddestino="total_detalle"  actxml="fasle">(cantidad_detalle * precio_vta).toFixed(2)</jseval>



            </field>


            <!-- Calculo de Importes segun alicuota -->

            <field id="neto_detalle" local="true" suma="true" deshabilitado="true">
                <label Formstyle="width: 100px;">neto</label>
                <tipo>numeric</tipo>
                <if exp="alicuota+0 != 0">
                    <true>(cantidad_detalle * precio_vta) / ( 1 + ( alicuota / 100))</true>
                    <false>0</false>
                </if>
                <jseval fielddestino="neto_movimiento" total="true" suma="true" >neto_detalle</jseval>
            </field>

            <field id="importe_iva" local="true" suma="true" deshabilitado="true">
                <label Formstyle="width: 100px;">iva</label>
                <tipo>numeric</tipo>
                <if exp="alicuota+0 != 0">
                    <true>neto_detalle * (alicuota / 100)</true>
                    <false>0</false>
                </if>
                <jseval fielddestino="importe_IVA" total="true" suma="true">importe_iva</jseval>
            </field>

            <field id="exento_detalle" local="true" suma="true" deshabilitado="true">
                <label Formstyle="width: 100px;">exento</label>
                <if exp="alicuota+0 == 0">
                  <true>(cantidad_detalle * precio_vta)</true>
                  <false>0</false>
                </if>
                <tipo>numeric</tipo>
                <jseval fielddestino="importe_exento" total="true" suma="true">exento_detalle</jseval>
            </field>

            <!-- Total Movimiento -->

            <field id="total_detalle" suma="true" deshabilitado="true">
                <label Formstyle="width: 100px;">Total </label>
                <tipo>numeric</tipo>
                <if exp="true">
                    <true>(cantidad_detalle * precio_vta)</true>
                    <false>0</false>
                </if>
                <detalle>importe_movimiento</detalle>
                <jseval fielddestino="importe_movimiento" total="true">total_detalle</jseval>
            </field>


        </table>
    </form>
</histrix>  
