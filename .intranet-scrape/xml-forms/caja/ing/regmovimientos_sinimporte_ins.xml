<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="insert">
    <title/>
    <obs/>
    <form>
        <table id="REG_MOVIMIENTOS">
            <field id="subsistema_id"      	id_temp="subsistema_id">
        	<tipo>varchar</tipo>
            </field>
            <field id="regcuenta_id"     	id_temp="regcuenta_id" />
            <field id="concepto_id"      	id_temp="regconcepto_id"/>

            <field id="fecha_movimiento"     	id_temp="fecha_movimiento"/>
            <field id="letra_movimiento"     	id_temp="regcuenta_ivaletra"/>
            <field id="puesto_movimiento"     	id_temp="puesto_movimiento"/>
            <field id="nro_movimiento" 	     	id_temp="nro_movimiento"/>
            <field id="reg_fecha" 	        id_temp="fecha_movimiento"/>
            <field id="vencimiento_movimiento" 	id_temp="vencimiento_movimiento"/>

            <field id="neto_movimiento"         id_temp="neto_movimiento"/>
            <field id="importe_iva"           	id_temp="importe_iva"/>
            <field id="importe_exento" 	     	id_temp="importe_exento"/>
            <field id="alicuota_iva" 	     	id_temp="alicuota_iva"/>

            <field id="cajmovimiento_id" 	lastId="cajmovimientos_ins.xml"/>

	    <field id="importe_movimiento"     	>
		<valor>(select CAJ_MOVIMIENTOS.importe_movimiento from CAJ_MOVIMIENTOS where id_cajmovimiento = [__cajmovimientos_ins.xml__] limit 1)</valor>
	    </field>

            <field id="referencia_movimiento"   id_temp="referencia_movimiento">
          	  <tipo>varchar</tipo>
          	</field>
            <field id="saldo_movimiento"        id_temp="importe_anticipo"/>

        </table>
    </form>
</histrix>	
