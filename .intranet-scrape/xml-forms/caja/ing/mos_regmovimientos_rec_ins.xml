<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="insert">
    <title/>
    <obs/>
    <form>
        <table id="REG_MOVIMIENTOS" idCampoCond="graba_recibo">
            <field id="subsistema_id"      	    id_temp="subsistema_id">
                <tipo>varchar</tipo>
            </field>
            <field id="regcuenta_id"     	    id_temp="regcuenta_id" />
            <field id="concepto_id">   		
                <valor>(SELECT regconceptoing_id FROM GEN_SUBSISTEMAS WHERE id_subsistema = '[__subsistema_id__]' LIMIT 1)</valor>
            </field>
            <field id="fecha_movimiento"     	id_temp="fecha_movimiento"/>
            <field id="letra_movimiento">
                <valor>'X'</valor>
            </field>
            <field id="puesto_movimiento"     	id_temp="puesto_movimiento"/>
            <field id="nro_movimiento" 	     	id_temp="nro_movimiento"/>
            <field id="reg_fecha" 	            id_temp="fecha_movimiento"/>
            <field id="vencimiento_movimiento" 	id_temp="vencimiento_movimiento"/>

            <field id="importe_movimiento"     	id_temp="importe_movimiento"/>
            <field id="referencia_movimiento"   id_temp="referencia_movimiento">
          		<tipo>varchar</tipo>
          	</field>
            <field id="saldo_movimiento"        id_temp="saldo_movimiento"/>
            <field id="pag_movimiento">
                <valor>'T'</valor>
            </field>
            <field id="cajmovimiento_id" 	    lastId="cajmovimientos_ins.xml"/>
            <field id="nombre_movimiento"           id_temp="regcuenta_nombre" />
        </table>
    </form>
</histrix>	
