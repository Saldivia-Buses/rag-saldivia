<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="insert">
    <title/>
    <obs/>
    <form>
        <table id="REG_DETALLES">
            <field id="regmovim_id"      	 lastId="regmovimientos_sinimporte_ins.xml" />
            <field id="descripcion_detalle"     id_temp="referencia_movimiento">
          	  <tipo>varchar</tipo>
          	</field>
            <field id="neto_detalle" 	     	id_temp="neto_movimiento"/>
            <field id="alicuota_iva" 	     	id_temp="alicuota_iva"/>
            <field id="iva_detalle"           	id_temp="importe_iva"/>
            <!-- <field id="total_detalle"     	    id_temp="importe_movimiento"/> -->
            <field id="total_detalle">
                <valor>(select CAJ_MOVIMIENTOS.importe_movimiento from CAJ_MOVIMIENTOS where id_cajmovimiento = [__cajmovimientos_ins.xml__] limit 1)</valor>
            </field>
        </table>
    </form>
</histrix>