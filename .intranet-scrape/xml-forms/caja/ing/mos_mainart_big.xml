                    </field>
                    <field id="imprime"   local="true">
                	<valor>1</valor>
                    </field>
                    
 	    	<field id="impresion">
			<expresion>case when '[__imprime__]' = 1 then ejecuta else '' end</expresion>
		</field>                      
                    
                    <field id="puesto"  oculto="true">
                        <condicion operador="=" valorde="puesto_movimiento"></condicion>
                    </field>
                </parametro>
            </field>


