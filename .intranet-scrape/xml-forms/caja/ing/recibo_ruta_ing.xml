<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" _width="18" showCantidad="false" imprime="false" preloadData="false">
  <title>Cobranza Por Ruta</title>
  <obs/>

  <form>

    <table id="REG_CUENTA">


      <filters>     
       
       <!--
        <field id="fecha_registro">
	  	  <label>fecha</label>
	  	  <tipo>date</tipo>
      	  <operador>=</operador>
      	  <valor>today</valor>
        </field>
        -->
        
        <field id="regzona_id">
      	    <label>Zona</label>
        </field>

      </filters>
      

            <fieldGroup id="DEBUG" local="true" noshow="true">
                <field id="cajpuesto_id"/>
                <field id="cajconcepto_id"/>
                <field id="cajregistro_id" />
                <field id="fecha_movimiento"/>
                <field id="regconcepto_id"/>
                <field id="tipoimpre_concepto" />
                <field id="imputacion_concepto" />
                <field id="imprime_concepto" />
                <field id="ctbcuenta_id"/>
                <field id="ctbcuenta_reg_doh">
                    <if exp="imputacion_concepto == 0">
                        <true>1</true>
                        <false>0</false>
                    </if>
                </field>
            </fieldGroup>                                                            

                                                        
                <field id="subsistema_id" noshow="true" />
      
      <field id="id_regcuenta" noshow="true">
    	<detalle>regcuenta_id</detalle>
    	<detalle>id_regcuenta</detalle>
      </field>

	  <field id="regzona_id" tabla="REG_CUENTA" noshow="true">
	     <helper type="combo" xml="regzonas_qry.xml" dir="/ayudas" empty="true"/>
	  </field>
      
      <field id="nro_cuenta" >
        <detalle>nro_cuenta</detalle>
      </field>
      
      <field id="nombre_cuenta">
        <helper type="link" xml="recibo_ing.xml" dir="/caja/ing" modal="true">


                <parameter source="cajpuesto_id"        target="cajpuesto_id"        />
                <parameter source="cajconcepto_id"      target="cajconcepto_id"      />
                <parameter source="cajregistro_id"      target="cajregistro_id"      />
                <parameter source="fecha_movimiento"    target="fecha_movimiento"    />
                <parameter source="subsistema_id"       target="subsistema_id"       />
                <parameter source="regconcepto_id"      target="regconcepto_id"      />
                <parameter source="tipoimpre_concepto"  target="tipoimpre_concepto"  />
                <parameter source="imputacion_concepto" target="imputacion_concepto" />
                <parameter source="imprime_concepto"    target="imprime_concepto"    />
                <parameter source="nro_cuenta"          target="nro_cuenta"          />
                <parameter source="id_regcuenta"        target="regcuenta_id"        />
	    </helper>
      </field>
      
      <field id="saldo_cuenta"><!--
      	<expresion having="false"> SELECT SUM(saldo_movimiento) 
					  	             FROM REG_MOVIMIENTOS 
					  	            WHERE REG_MOVIMIENTOS.subsistema_id = REG_CUENTA.subsistema_id 
					  	              AND REG_MOVIMIENTOS.regcuenta_id = REG_CUENTA.id_regcuenta 
      	</expresion>-->
    		<tipo>numeric</tipo>
    		<condicion operador="&gt;">0</condicion>
      </field>

      <field id="cobrado">
        <expresion> SELECT SUM(RM.importe_movimiento) 
                           FROM REG_MOVIMIENTOS RM 
                           JOIN CAJ_MOVIMIENTOS CM ON RM.cajmovimiento_id = CM.id_cajmovimiento
                           WHERE CM.cajregistro_id = '[__cajregistro_id__]' and RM.regcuenta_id = REG_CUENTA.id_regcuenta
        </expresion>
        <tipo>numeric</tipo>
      </field>

      
     
      <order>
        <field id="nombre_cuenta"/>
      </order>
      
    </table>



  </form>
</histrix>
