<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="grid" subtipo="vertical" inserta="false" borra="false" modifica="false" imprime="false" exportasuma="true" deleteRow="false" llenoreferente="true" confirma="CONFIRMAR" procesa="false" resume="true" 
    _styleTable="height:300px;">
  <title>Movimientos en Cuenta Corriente</title>
  <form>
    <table id="REG_MOVIMIENTOS" label="Movimientos en Cuenta Corriente">

      <movimientos>        
        <relacion id="cajdetalle_compsaldo_ins.xml"/>
        <relacion id="regmovimientos_compsaldo_ins.xml" />
        <relacion id="cajnumeradores_compsaldo_upd.xml" />
        <relacion id="regimputacion_compsaldo_ins.xml" />
      </movimientos>

      <validation>
        <condition><![CDATA[ newSALDO + 0 == 0 ]]></condition>
        <message>No puede imputar un monto mayor al saldo a imputar.</message>
      </validation>

      <fieldGroup noshow="true" valauto="true">
        <field id="cajformapago_id" local="true" esClave="true">
          <detalle>cajformapago_id</detalle>
        </field>
        <field id="subsistema_forma_id" local="true" />
        <field id="regconcepto_forma_id" local="true" />
        <field id="regcuentapadre_id" local="true" />
        <field id="moneda_id" local="true" />
        <field id="fecha_movimiento" local="true">
          <tipo>date</tipo>
        </field>
        <field id="imputacion_concepto" local="true">
          <label>IC</label>
        </field>
      </fieldGroup>  

      <field id="cajconcepto_id" local="true" noshow="true">
        <helper type="parameter" id="SIS::02::concepto_compensacion">
          <label>Concepto de caja de compensacion de saldos</label>
          <defaultValue>0</defaultValue>
        </helper>
      </field>
      <field id="letra_movimiento" local="true" valauto="true" noshow="true">
        <valor>X</valor>
      </field>

      <field id="nro_movimiento2" deshabilitado="true" local="true" sincelda="true" noshow="true">
        <label modpos="nobr">Nº</label>
        <parametro id="cajnumerador_param.xml" retorna="numero">
          <field id="numero" />
          <field id="cajconcepto_id" esClave="true">
            <condicion operador="=" valorde="cajconcepto_id" />
          </field>
        </parametro>
        <format>%08d</format>
        <size>8</size>
      </field>

      <field id="id_regmovim" esClave="true" noshow="true" />

      <field id="subsistema_id" noshow="true" />

      <field id="fecha_comp" deshabilitado="true">        
        <label>Fecha</label>
        <expression>REG_MOVIMIENTOS.fecha_movimiento</expression>
        <tipo>date</tipo>
      </field>

      <field id="concepto_id" noshow="true" deshabilitado="true" />

      <field id="regcuenta_id" noshow="true">
        <label>Cuenta</label>
        <condicion operador="=">regcuenta_id and find_in_set (regcuenta_id, (select group_concat(regcuentarelacionada_id) from REG_CUENTA_RELACIONES where subsistemarelacionada_id = '[__subsistema_forma_id__]' and regcuenta_id = '[__regcuentapadre_id__]'))</condicion>
      </field>

      <field id="nombre_cuenta">
        <label>Cuenta</label>
        <expression>case when REG_CUENTA.nombre_fantasia IS NULL or REG_CUENTA.nombre_fantasia = '' then REG_CUENTA.nombre_cuenta else REG_CUENTA.nombre_fantasia end</expression>
      </field>

      <field id="nro_movimiento" style="text-align: center" local="true">
        <label>Numero</label>
        <expression>CONCAT(REG_CONCEPTOS.abreviacion_concepto,' ',REG_MOVIMIENTOS.letra_movimiento,' ',LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,'0'),'-',LPAD(REG_MOVIMIENTOS.nro_movimiento  ,8,'0'))</expression>
      </field>

      <field id="importe_comprobante">
        <label>Importe</label>
        <expression>REG_MOVIMIENTOS.importe_movimiento</expression>
      </field>

      <field id="ctbcuenta_reg_id" local="true" noshow="true">
        <label>Cta contable</label>
        <expression>ifnull((SELECT cuenta_id FROM REG_CUENTA_IMPUTACION
       WHERE REG_CUENTA_IMPUTACION.regcuenta_id = REG_CUENTA.id_regcuenta
       AND REG_CUENTA_IMPUTACION.doh = (CASE WHEN '[__imputacion_concepto__]' = 0 THEN 0 ELSE 1 END)
        LIMIT 1), GEN_SUBSISTEMAS.cuenta_debe_id )</expression>
      </field>

      <field id="ctbcuenta_reg_doh" noshow="true" local="true">
        <if exp="'imputacion_concepto' == 0">
          <true>1</true>
          <false>0</false>
        </if>
      </field>

      <field id="saldo_movimiento">
        <label>Saldo Comp</label>
        <condicion operador="&gt;">0</condicion>
      </field>

      <field id="acum" local="true" deshabilitado="true"  acumula="true" retroalimenta="true" noshow="true">
        <if exp="true" operador="=">
          <true>salant</true>
          <false>salant - mov_sal</false>
        </if>
      </field>

      <field id="imputado" suma="true" local="true" editable="true">
        <label style="font-size:16px;">Imputado</label>
        <help>Imputar</help>
        <tipo>numeric</tipo>
        <jseval campodestino="importe_movimiento" total="true">imputado</jseval>
        <jseval campodestino="test_error">(imputado &gt; saldo_movimiento)?1:0</jseval>
        <jseval campodestino="newSALDO" actxml="false">(saldo_movimiento - imputado).toFixed(2)</jseval>
      </field>
            
      <field id="newSALDO" local="true" deshabilitado="true" editable="true">
        <label>Saldo</label>
        <if exp="true" operador="=">
          <true>saldo_movimiento - imputado</true>
          <false>0</false>
        </if>
        <tipo>numeric</tipo>
      </field>

      <field id="test_error" local="true" editable="true" suma="true" noshow="true">
        <label>Test</label>
        <jseval campodestino="test_imputaciones" total="true">test_error</jseval>
      </field> 

      <field id="grabar" local="true" noshow="true">
        <if exp="imputado != ''">
          <true>1</true>
          <false>0</false>
        </if>
      </field>

      <field id="imputacion_concepto" oculto="true" tabla="REG_CONCEPTOS">
        <condicion operador="=">0</condicion>
      </field>

      <order>
        <field id="fecha_movimiento"/>
      </order>

    </table>

    <join>
      <table id="GEN_SUBSISTEMAS">
        <field id="id_subsistema">
          <condicion operador="=">'[__subsistema_forma_id__]'</condicion>
        </field>
      </table>
    </join>

    <join>
      <table id="REG_CUENTA">
        <field id="id_regcuenta">
          <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
        </field>
      </table>
    </join>

    <join>
      <table id="REG_CONCEPTOS">
        <field id="subsistema_id">
          <condicion operador="=">REG_MOVIMIENTOS.subsistema_id</condicion>
        </field>
        <field id="id_concepto">
          <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
        </field>
        <field id="informa_calculo">
          <condicion operador="=">0</condicion>
        </field>
      </table>
    </join>

  </form>
</histrix>