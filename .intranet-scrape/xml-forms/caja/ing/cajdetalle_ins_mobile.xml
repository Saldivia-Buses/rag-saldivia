<?xml version="1.0" encoding="UTF-8"?>
<!--
	Esta grabación tiene como objetivo grabar la partida contable
	referida a la cuenta de disponibilidades
-->
<histrix tipo="insert">
    <title/>
    <obs/>
    <form>
        <table id="CAJ_DETALLES"            idCampoCond="grabar_ctb">
            <field id="cajmovimiento_id"       lastId="cajmovimientos_ins.xml"/>
            <field id="cuenta_id"                id_temp="ctbcuenta_detalle" required="true"/>
            <field id="referencia_detalle"       id_temp="ctbcuenta_referencia" />
            <field id="doh"                      id_temp="doh_detalle">
                <tipo>varchar</tipo>
            </field>
            <field id="importe_detalle"          id_temp="importe_movimiento" required="true"/>
        </table>
    </form>
</histrix>
