            <field id="nro_movimiento" >
            	<valor>ifnull(( select numero from REG_NUMERADORES RN 
            	                             where RN.subsistema_id = '[__subsistema_id__]'
            	                               and RN.letra = '[__letra_movimiento__]' 
            	                               and RN.puesto = [__puesto_movimiento__] 
            	                               and RN.regconcepto_id=[__regconcepto_id__] limit 1 ), 0)</valor>
                </field>
