<?xml version="1.0" encoding="UTF-8"?>
<!-- LAS NOTAS DE PEDIDOS SE DEJARON LOS CALCULOS DE PRECIOS IDEM A LA FACTURA POR SI ES NECESARIO COMO DATOS AL MOMENTO DE HACER LOS PEDIDOS Y LA FACTURACION
CON ESTA INFORMACION SE PUEDEN TOMAR LOS PRECIOS HISTORICOS DE SER NECESARIOS PARA ASIGNARLOS A LA FACTURA-->
<histrix tipo="ing" preloadData="false" procesa="false" tooltip="false" showCantidad="false" updateTotals="true" subtipo="vertical" unserializeParent="false" preventDuplication="true">
  <title>Detalle</title>
  <obs/>
  <form >
    <table id="REG_DETALLES" label="movimientos">
    <movimientos>
        <relacion id="mos_regdetalles_ins.xml"/>
        <relacion id="regimputaciondetalles_ins.xml"/>  // Imputacion entre la Np y la Factura    
        <relacion id="mos_regdetalles_rem_ins.xml"/>
        <relacion id="regimputaciondetallesrem_ins.xml"/>  // Imputacion entre el Remito y la Factura
        <relacion id="mos_stkmovimientos_rem_ins.xml"/>
        <relacion id="mos_stkmovimientos_ins.xml"/>
        <relacion id="mos_ctbdetalle_con.xml" />
        <relacion id="mos_ctbdetalle_iva.xml" />
    <!--
    <relacion id="cajdetalle_iva_padre_ins.xml" /> // Grabacion de la partida contable correspondiente al iva de los articulos
    <relacion id="cajdetalle_mos_ins.xml" /> // Grabacion de la partida contable correspondiente al neto de los articulos
    -->
  </movimientos>
  
  <fieldGroup>
    
      <field id="cmb_marca" local="true" noshow="true">
        <helper type="parameter" id="SIS::02:cmb_marca" >
            <label>Oculta combo de marcas en programa de facturación</label>
            <defaultValue>true</defaultValue>
        </helper>
      </field>
      
      <field id="filtro_familia" local="true" noshow="true" colstyle="display:none;">
        <label>Familia</label>
        <attribute id="noshow">cmb_marca</attribute>
        <helper type="combo" xml="stkfamilia_qry.xml" dir="/ayudas" empty="true"/>
        <actualiza>
            <field id="codigo_detalle" destino="stkfamilia_id" />
        </actualiza>
      </field>
      
      <field id="filtro_rubro" local="true" noshow="true" colstyle="display:none;">
        <label modpos="nobr">Rubro</label>
        <attribute id="noshow">cmb_marca</attribute>
        <helper type="combo" xml="stkrubro_qry.xml" dir="/ayudas" empty="true"/>
        <actualiza>
            <field id="codigo_detalle" destino="stkrubro_id" />
        </actualiza>
      </field>

      <field id="filtro_marca" local="true" noshow="true" colstyle="display:none;">
        <label modpos="nobr">Marca</label>
        <attribute id="noshow">cmb_marca</attribute>
        <helper type="combo" xml="stkmarca_qry.xml" dir="/ayudas" empty="true"/>
        <actualiza>
            <field id="codigo_detalle" destino="stkmarca_id" />
        </actualiza>
      </field>
  
  </fieldGroup>

  <fieldGroup colstyle="text-align:center;padding 2px 2px 2px 2px;" style="vertical-align:middle;padding: 3px 2px 3px 2px;">

    <field id="codigo_detalle" deshabilitado="false" esClave="true" valid="true">
      <label>Codigo</label>
      <helper type="external" xml="stkarticulo_mos2.xml" dir="/ayudas">
          <field id="regcuenta_id"      local="true" noshow="true" />
          <field id="stkdeposito_id"    local="true" noshow="true" />
          <field id="wstklista_id"      local="true" noshow="true" />
          <field id="stkmarca_id"       oculto="true" />
          <field id="wcontrolstk"       local="true" noshow="true">    // Receptores magico para el filtro
            <valor default="true">0</valor>
          </field>
          <field id="ctbcuenta_stk_id" noshow="true">
            <expression>IF( IFNULL(STK_ARTICULOS.cuentadebe_id,'') = '', STK_RUBROS.ctbcuentarubro_id, STK_ARTICULOS.cuentadebe_id)</expression>
            <detalle>ctbcuenta_stk_id</detalle>
          </field>
          <field id="baja_articulo" noshow="true">
                  <condicion operador="!=">1</condicion>
          </field>
      </helper>
      <size>12</size>
    </field>


    <field id="descripcion_detalle" deshabilitado="true" activador="libre" modpos="nobr" colspan="6">
      <label >Descripción</label>
      <tipo>varchar</tipo>
      <size>60</size>
    </field>

    <field id="libre" activa="true" local="true" colstyle="display:none;" modpos="nobr">
      <tipo>check</tipo>
    </field>

    <field id="cantidadStk" deshabilitado="true" >
      <label modpos="nobr">Stock</label>
      <tipo>decimal</tipo> 
      <size>4</size>
    </field>

    <field id="alerta_stock" deshabilitado="true" sincelda="true" local="true" colstyle="display:none;" noshow="true">
      <label modpos="nobr" style="text-decoration:blink;color:red;font-weight:bold;"></label>
    </field>
    
    <field id="cantidad_detalle" replace="true">
      <label>Cantidad</label>
      <tipo>decimal</tipo>
      <valor dafault="true">1.00</valor>  
      <jseval fielddestino="neto_detalle" actxml="false" suma="true">subtotal1 * cantidad_detalle</jseval>  
    </field>
   
<!-- DOLAR COTIZACION -->

    <field id="genmoneda_venta_id" local="true" deshabilitado="true" noshow="true" modpos="nobr" colstyle="display:none;">
      <label style="color:green;">MVTA</label>
    </field>

    <field id="precio_dolar" local="true" modpos="nobr" activador="cambia" colstyle="display:none;">
      <label>u$s</label>
      <size>6</size>
      <jseval fielddestino="precio_venta" actxml="false" suma="true">precio_dolar * mi_Cotizacion</jseval>
    </field>

    <field id="cambia" activa="true" local="true" colstyle="display:none;" modpos="nobr" sincelda="true" >
      <label></label>
      <tipo>check</tipo>
    </field>

    <field id="mi_Cotizacion" local="true" deshabilitado="true" _noshow="true" autoinc="true" 
      colstyle="text-align:center;padding 2px 2px 2px 2px;color:green;display:none;" >
      <label modpos="nobr">Cotizacion</label>
      <tipo>numeric</tipo>
      <valor>1</valor>
      <size>6</size>
    </field>


<!-- PRECIO PESOS -->

    <field id="precio_venta" local="true">
      <label >Precio</label>
      <valor default="true">0.00</valor>
      <tipo>decimal</tipo>   
       <jseval fielddestino="subtotal0" actxml="false" suma="true">( ( precio_venta + 0 ) - ( ( precio_venta + 0 )  * (porcentaje_desc0 + 0 ) / 100 ))</jseval>
      <jseval fielddestino="subtotal1" actxml="false" suma="true">(( subtotal0 + 0 ) - (( subtotal0 + 0 )  * ( porcentaje_desc1 + 0 ) / 100 ))</jseval>
      <jseval fielddestino="neto_detalle" actxml="false" suma="true">subtotal1 * cantidad_detalle</jseval>
      <jseval fielddestino="precio_dolar" actxml="false" suma="true">(genmoneda_venta_id ==2) ? ( precio_venta / mi_Cotizacion) : 0</jseval>
      <size>10</size>
    </field>

    <field id="precio_vta" local="true" noshow="true">
      <if exp="true">
        <true>precio_venta</true>
        <false>0</false>
      </if>
      <tipo>decimal</tipo>   
    </field> 

    <field id="porcentaje_desc0" deshabilitado="false" noZero="true">
      <label modpos="nobr">% 1</label>
      <valor default="true">0.00</valor>
      <tipo>decimal</tipo>
      <size>5</size>
      <jseval fielddestino="subtotal0" actxml="false" suma="true">( ( precio_venta + 0 ) - ( ( ( precio_venta + 0 ) )  * (porcentaje_desc0 + 0 ) / 100 ))</jseval>
      <jseval fielddestino="subtotal1" actxml="false" suma="true">(( subtotal0 + 0 ) - (( subtotal0 + 0 )  * ( porcentaje_desc1 + 0 ) / 100 ))</jseval>
    </field>

    <field id="aviso_desc" local="true" noshow="true">
      <helper type="parameter" id="SIS::02::aviso_desc">
        <label>Aviso limite de descuento</label>
        <defaultValue>15</defaultValue>
      </helper>
    </field>

    <field id="alerta_desc" clasefila="true" noshow="true">
      <label>Alerta</label>
      <if exp="'porcentaje_desc0' &gt; 'aviso_desc'">
        <true>'resaltadoRojo'</true>
        <false>''</false>
      </if>
    </field>

    <field id="subtotal0" local="true" deshabilitado="true" noshow="true" modpos="nobr">
      <label>SubTotal</label>
      <valor default="true">0.00</valor>
      <tipo>decimal</tipo>
          <if exp="true">
            <true>( ( precio_venta + 0 ) - (( ( precio_venta + 0 ))  * ( porcentaje_desc0 + 0 ) / 100 ))</true>
            <false>0</false>
          </if>
      <jseval fielddestino="neto_detalle" actxml="false" suma="true">subtotal0 * cantidad_detalle</jseval>
    </field>

    <field id="separa123" local="true" modpos="nobr" deshabilitado="true" colstyle="display:none;">
      <size>1</size>
    </field>

    <field id="porcentaje_desc1"   deshabilitado="false" noZero="true" >
      <label modpos="nobr">% 2</label>
      <valor default="true">0.00</valor>
      <tipo>decimal</tipo>
      <size>5</size>
      <jseval fielddestino="subtotal1" actxml="false" suma="true">(( subtotal0 + 0 ) - (( subtotal0 + 0 )  * ( porcentaje_desc1 + 0 ) / 100 ))</jseval>
    </field>


    <field id="subtotal1" local="true" deshabilitado="true" noshow="true" >
      <label>SubTotal1</label>
      <tipo>decimal</tipo>
      <valor default="true">0.00</valor>
            <if exp="true">
                <true>(( subtotal0 + 0 ) - (( subtotal0 + 0 )  * ( porcentaje_desc1 + 0 ) / 100 ))</true>
                <false>0</false>
            </if>                    
      <jseval fielddestino="neto_detalle" actxml="false" suma="true">subtotal1 * cantidad_detalle</jseval>
    </field>

    <field id="separa234" local="true" modpos="nobr" deshabilitado="true" colstyle="display:none;">
      <size>1</size>
    </field>

    <field id="neto_detalle" suma="true" deshabilitado="true" modpos="nobr">
      <label>Neto</label>
      <valor default="true">0.00</valor>
      <tipo>decimal</tipo>
            <if exp="true">
                <true>round(subtotal1 * cantidad_detalle, 2)</true>
                <false>0</false>
            </if>               
      <jseval fielddestino="iva_detalle" actxml="false">( ( neto_detalle + 0) * ( alicuota_iva + 0) / 100 )</jseval>
      <jseval fielddestino="subtotal_movimiento" total="true">neto_detalle</jseval> 
      <jseval fielddestino="neto_movimiento" total="true">neto_detalle</jseval>
      <size>10</size>
    </field>



    <field id="alicuota_iva" esClave="true" colstyle="display:none;" local="true" required="true">
      <label modpos="nobr">Alic</label>
      <valor default="true">0.00</valor>
      <tipo>decimal</tipo>
      <helper type="combo" xml="genalicuotas_qry.xml" dir="/ayudas" empty="true">
        <field id="ctbcuenta_iva_id" local="true">
          <expression having="false"> (CASE WHEN '[__imputacion_concepto__]' = 1 THEN cuenta_haber_id ELSE cuenta_debito_id END)</expression>
          <detalle>ctbcuenta_iva_id</detalle>
        </field>
      </helper>
      <jseval fielddestino="iva_detalle" actxml="false"> ( (neto_detalle + 0)  * (alicuota_iva + 0) / 100 )</jseval>
    </field>
    
    <field id="alicuota_iva_local" local="true" noshow="true">
      <actualiza>
        <field id="alicuota_iva" destino="alicuota" />
      </actualiza>
    </field>

    <field id="iva_detalle" suma="true"   deshabilitado="true" sincelda="true">
      <label   modpos="nobr"  Formstyle="display: none;">Iva</label>
      <tipo>numeric</tipo>
      <valor default="true">0.00</valor>
            <if exp="true">
                <true>round(( (neto_detalle + 0)  * (alicuota_iva + 0) / 100 ), 2 )</true>
                <false>0</false>
            </if>          
      <jseval fielddestino="importe_IVA" total="true">iva_detalle</jseval> 
      <jseval fielddestino="mi_importe_iva" total="true">iva_detalle</jseval>    
      <jseval fielddestino="total_detalle" actxml="false">(neto_detalle +  ((iva_detalle + 0)) )</jseval> 
    </field>

    <field id="importe_iva" noshow="true">
            <if exp="true">
                <true>iva_detalle</true>
                <false>0</false>
            </if>          
    </field>

    <field id="separa789" local="true" modpos="nobr"  deshabilitado="true" colstyle="display:none;" >
      <size>1</size>
    </field>

    <field id="total_detalle" suma="true" deshabilitado="true">
      <label modpos="nobr">Total</label>
      <valor default="true">0.00</valor>
      <tipo>decimal</tipo> 
            <if exp="true">
                <true>round((neto_detalle + 0) +  ((iva_detalle + 0)), 2 )</true>
                <false>0</false>
            </if>               
      <jseval fielddestino="importe_movimiento" total="true">total_detalle</jseval> 
      <detalle>importe_movimiento</detalle>
    </field>

    <field id="id_regdetalle"   autoinc="true"     noshow="true" esClave="true"/>

    <field id="id_pedidosregdetalle" esClave="true" noshow="true">
      <label>Notas de Pedidos</label>
    </field>

    <field id="NOTAS" deshabilitado="true" noshow="true">
      <label>Notas</label>
    </field>
    
  </fieldGroup>

    <field id="graba_ctb" local="true" noshow="true">
        <valor eval="true"><![CDATA[ strpos($_SESSION['properties']['modulos'],'contabilidad') != false ? '1' : '0' ]]>
        </valor>
    </field>


    <field id="stkconcepto_id" local="true" noshow="true">
      <expresion>(SELECT option_value FROM HTXOPTIONS where option_name = 'ID_STKREMITOS')</expresion>
      <detalle>stkconcepto_id</detalle>
    </field>
                                       
    <field id="grabastk" local="true" noshow="true" valauto="true">
        <valor>true</valor>
    </field>

    <field id="emite_det_remito" local="true" noshow="true" >
        <label>emite</label>                     
        <if exp="true">
      <true>'emiteremito'</true>
      <false>''</false>
        </if>
    </field>
    
    <field id="NOEmite_det_remito" local="true" noshow="true" >
      <label>no emite</label>
        <if exp="'emiteremito' == 'false'">
      <true>'true'</true>
      <false>'false'</false>
        </if>
    </field>
                                                       
  <fieldGroup noshow="true"  local="true"  _style="display: none;">

      <!-- CONTABLE -->
      
    <field id="imputacion_concepto" />
    
    <field id="ctbcuenta_stk_id"/>
    
    <fieldGroup style="padding:2px 2px 2px 2px;">

        <if>return (strpos($_SESSION['properties']['modulos'],'contabilidad') !== false);</if>

          <field id="testctb" local="true" noshow="false" colstyle="color:red;text-decoration:blink;" Formstyle="display:none;">
             <if exp="'ctbcuenta_stk_id' == ''">
                 <true>'Falta Cuenta CTB de Articulo'</true>
                <false>''</false>
             </if>
          </field>

    </fieldGroup>

    <field id="ctbcuenta_stk_doh">
      <if exp="imputacion_concepto == 0">
          <true>'1'</true>
          <false>'0'</false>
      </if>
    </field>
                                         
    <field id="ctbcuenta_iva_id">
    </field>                       

    <field id="ctbcuenta_iva_doh">
      <if exp="imputacion_concepto == 0">
          <true>'1'</true>
          <false>'0'</false>
      </if>
    </field>
    
          <!-- Otros Datos  -->
    <field id="orden" deshabilitado="true" oculto="true">
      <label>Orden</label>
      <size>35</size>
    </field>

  </fieldGroup>

  <fieldGroup local="true" noshow="true">
  
    <field id="wcontrolstk" deshabilitado="true" >
      <label>sssss</label>
      <valor default="true">0</valor>
    </field>

    <field id="stkunidad_id"/>
    <field id="stksector_id"/>
    <field id="stkfamilia_id"/>
    <field id="stkrubro_id"/>
    <field id="precio_costo"/>
    <field id="referencia">
      <valor>'SALIDA POR VENTA'</valor>
    </field>
    
   
    <field id="stkdeposito_id" _deshabilitado="true" >
      <detalle>stkdeposito_id</detalle>
      <label>dep</label>
    </field>

  </fieldGroup>

    <importar xml="mos_remitos_art_qry.xml" label="Remitos" title="Seleccione" reemplazar="true" >
    <field id="fecha_movimiento">fecha_movimiento</field>
    <field id="regcuenta_id">regcuenta_id</field>
    <field id="id_stklista">id_stklista</field>
    <field id="regmovim_id">id_pedidos</field>
    <field id="subsistemav_id" >subsistemav_id</field>
    <field id="pedido_regmovim">pedido_regmovim</field>
    <field id="imp_wcontrolstk">imp_wcontrolstk</field>
     
  </importar>

       MOVIMIENTOS DE STOCK

      <field id="stkact" local="true" noshow="true"></field>
  
    </table>
  </form>
</histrix>
