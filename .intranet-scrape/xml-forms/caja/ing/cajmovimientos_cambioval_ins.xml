<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="insert">
    <title/>
    <obs/>
    <form>
        <table id="CAJ_MOVIMIENTOS">
            
            <field id="cajconcepto_id"          id_temp="cajconceptorel_id" />
            <field id="cajpuesto_id"     	    id_temp="cajpuestodestino_id" />
            <field id="nro_movimiento">
                <valor>(select numero from CAJ_NUMERADORES where cajconcepto_id = '[__cajconceptorel_id__]')</valor>
                <tipo>integer</tipo>
            </field>
            <field id="fecha_movimiento"        id_temp="fecha_movimiento">
                <tipo>date</tipo>
            </field>
            <field id="hora_movimiento">
                <valor>NOW()</valor>
                <tipo>integer</tipo>
            </field>
            <field id="referencia_movimiento"   id_temp="referencia_movimiento">
          	  <tipo>varchar</tipo>
      		</field>
            <field id="importe_movimiento"      id_temp="importe_moneda">
                <tipo>custom_numeric</tipo>
            </field>
            <field id="cajregistro_id">
              <valor>(select id_cajregistro from CAJ_REGISTROS where cajpuesto_id = '[__cajpuestodestino_id__]' and fecha_registro = STR_TO_DATE('[__fecha_movimiento__]','%d/%m/%Y'))</valor>             
              <tipo>integer</tipo>
            </field>
            <field id="usuario_id"  id_temp="usuario_id" />            
            
        </table>
    </form>
</histrix>