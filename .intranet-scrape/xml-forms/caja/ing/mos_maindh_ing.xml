<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="fichaing" inserta="false" borra="false" modifica="false" imprime="false" tooltip="false" confirma="CONFIRMAR" transaccional="true" preFetch="false" preloadData="false" processFirst="true">
    <title /> Carga de Notas de Pedidos
    <obs></obs>
    <confirmacion><![CDATA[¿Confirma el Ingreso?  ]]></confirmacion> 

    <form >
        <table id="REG_MOVIMIENTOS" label="Nota de Pedido">

		<validation>
			<condition><![CDATA['regcuenta_ivaletra' == '']]></condition>
			<message>Debe Ingresar una Cuenta</message>
		</validation>

		<validation>
			<condition><![CDATA[regconcepto_id + 0 == 0]]></condition>
			<message>Tipo de Comprobante no válido</message>
		</validation>

		<validation>
			<condition><![CDATA[puesto_movimiento + 0 == 0]]></condition>
			<message>Punto de Venta no válido</message>
		</validation>

		<validation>
			<condition><![CDATA[nro_movimiento + 0 == 0]]></condition>
			<message>Numero de Movimiento no válido</message>
		</validation>
		
		<validation>
			<condition><![CDATA[micanpro + 0 == 0]]></condition>
			<message>Debe ingresar un articulo</message>
		</validation>

		<validation>
			<condition><![CDATA[ ((bonificaciones_movimiento + 0 != 0) &amp;&amp; bonificaciones_movimiento &gt; control_dtogral) ]]></condition>
			<message>Bonificacion General Exedida</message>
		</validation>


        <!-- GRABACION DE CUENTA CORRIENTE -->

		<movimientos>
			<relacion id="mos_regmovimientos_ins.xml"/>
			<relacion id="mos_actualizo_numerador_ca.xml"/> 
		</movimientos>

            <cierraproceso id="cajmovimientos_ing.xml" _condition="(imputa_pago==1)">
                <paring destino="imputacion_concepto">imputacion_concepto</paring>
                <paring destino="moneda_id">moneda_id</paring>
                <paring destino="cajpuesto_id">cajpuesto_id</paring>
                <paring destino="cajconcepto_id">cajconcepto_id</paring>
                <paring destino="cajregistro_id">cajregistro_id</paring>
                <paring destino="importe_movimiento">importe_movimiento</paring>
                <paring destino="fecha_movimiento">fecha_movimiento</paring>
                <paring destino="referencia_movimiento">referencia_movimiento</paring>
                <paring destino="nro_movimiento">nro_movimiento</paring>
                <paring destino="ctbcuenta_reg_id">ctbcuenta_id</paring>
                <paring destino="ctbcuenta_reg_doh">ctbcuenta_reg_doh</paring>
                <paring destino="para_cct">para_cct</paring>
                <paring destino="saldo_a_cct">saldo_a_cct</paring>
                <paring destino="limite_credito">limite_credito</paring>
            </cierraproceso>

	    <field id="para_cct" local="true" noshow="true">
		    <valor>1</valor>
	    </field>
	    
	    <field id="saldo_a_cct" local="true" noshow="true">
		    <valor>1</valor>
	    </field>


		<field id="id_regmovim" oculto="true">
			<condicion operador="=">-1</condicion>
		</field>


        <fieldGroup id="DEBUG" local="true" noshow="true">
                <field id="cajpuesto_id" />
                <field id="cajconcepto_id" />
                <field id="stkconcepto_id" />
                <field id="cajregistro_id" />
                <field id="imputacion_concepto" />
                <field id="subsistema_id" />
                <field id="moneda_id">
                    <valor>1</valor>
                </field>
                <field id="ctbcuenta_reg_id" />
                <field id="ctbcuenta_reg_doh">
                    <if exp="'imputacion_concepto' == '0'">
                        <true>0</true>
                        <false>1</false>
                    </if>
                </field>
        		<field id="subsistemavendedor_id" /> 
		        <field id="subsistematransporte_id" /> 
        	<field id="tiposervicio_afip">
		    <valor>1</valor>
		</field>
            </fieldGroup>


		<fieldGroup>

			<field id="regcuenta_id" local="true" noshow="true">
				<label>Cuenta</label>
				<helper type="external" xml="regcuenta_relacionescmb.xml" dir="/ayudas" _empty="true" >
				</helper>				
				<size>6</size> 
				<detalle>regcuenta_id</detalle>
				<actualiza>
					<field id="codigo_detalle" destino="regcuenta_id" xml="pedidosarticulo_grid.xml" />
					<field id="regcuentarelacion_id" destino="regcuenta_id" />
					<field id="domicilio_movimiento" destino="regcuenta_id"   />
				</actualiza>
			</field>


			<field id="nro_cuenta" local="true" required="true" min="1">
				<label>Cod</label>
				<helper type="external" xml="regcuenta_relacionescmb_nro.xml" dir="/ayudas" _empty="true" >
				 
				 
	              <field id="login" local="true" noshow="true">
    	            <label>login</label>
                    <valor eval="true">$_SESSION['idUser']</valor>
        		  </field>
				  // FILTRO LOS CLIENTES DEL VENDEDOR QUE USA EL PROGRAMA
				  <field id="usuario_vendedor" noshow="true">
					    <eval> if ($_SESSION['administrator'] != 1) return true; </eval>
						<expresion having="false">ifnull((select usuario_id from REG_CUENTA_RELACIONES RCR join REG_CUENTA_USERS RCU on RCU.regcuenta_id = RCR.regcuentarelacionada_id where RCR.regcuenta_id = REG_CUENTA.id_regcuenta and RCR.subsistemarelacionada_id = '[__subsistemavendedor_id__]' order by fecha_vigencia DESC limit 1), 0 )</expresion>
          	        	<condicion operador="=">[__login__]</condicion>
				  </field>   

				</helper>				
				<size>6</size> 
			</field>

			<field id="regcuenta_nombre" local="true" deshabilitado="true" sincelda="true">
				<label modpos="nobr" />
				<size>25</size>
			</field>

			<field id="regcuenta_ivaletra" local="true" deshabilitado="true" sincelda="true">
				<label modpos="nobr" style="font-size: large; text-align:center;" ></label>
			
				<actualiza>
				    <field id="puesto_movimiento" destino="letra" />
				    <field id="nro_movimiento" destino="letra" />
				    <field id="impresion" destino="letra" />
				    <field id="fiscal" destino="letra" />
				</actualiza>
				<size>1</size>
				<detalle>letra_movimimento</detalle>
			</field>
				
			
			<field id="regconcepto_id" deshabilitado="true" local="true">
				<label modpos="nobr"  style="font-size: large; text-align: right;" ></label>
				<helper type="combo" id="REG_CONCEPTOS">
					<field id="id_concepto" />
					<field id="descripcion_concepto"/>
					<field id="subsistema_id" />
				</helper>
				<actualiza>
					<field id="puesto_movimiento" destino="regconcepto_id" />
					<field id="nro_movimiento" destino="regconcepto_id" />
					<field id="impresion" destino="letra" />
					<field id="fiscal"            destino="regconcepto_id" />
				</actualiza>
				<detalle>concepto_id</detalle>
			</field>
			
			<field id="puesto_movimiento" _deshabilitado="true" _sincelda="true" >
				<label modpos="nobr" style="font-size: large;"></label>
				<helper type="combo" xml="npv_x_puesto_qry.xml" />
				<valor>1</valor>
				<actualiza>
					<field id="nro_movimiento" destino="puesto" />
					<field id="impresion" destino="puesto" />
					<field id="fiscal"            destino="puesto" />
				</actualiza>
				<size>4</size>
				<detalle>puesto_movimiento</detalle>
			</field>
			<field id="nro_movimiento" _deshabilitado="true" sincelda="true" deshabilitado="true">
				<label modpos="nobr" style="font-size: large;" />
                <parametro id="numerador_param.xml" retorna="numero">
                    <field id="letra"  oculto="true" esClave="true">
                        <condicion operador="=" valorde="regcuenta_ivaletra"></condicion>
                    </field>
                    <field id="puesto"  oculto="true" esClave="true">
                        <condicion operador="=" valorde="puesto_movimiento"></condicion>
                    </field>
                    <field id="numero">
<!--                        <complete>numero + 1</complete> -->
                    </field>
                </parametro>
				<formato>%08d</formato>
				<size>8</size>
				<detalle>nro_movimiento</detalle>
			</field>


            <field id="espacio" local="true" deshabilitado="true" colspan="2"/>

			<field id="fecha_movimiento" deshabilitado="true">
				<label modpos="nobr">Fecha</label>
				<valor>today</valor>
				<actualiza>
					<field id="fecha_vigencia" destino="regcuentarelacionada_id" />
					<field id="regcuenta_id" destino="fecha_movimiento" />
				</actualiza>
			</field>

			<field id="fpv_movimiento" sincelda="true">
				<label modpos="nobr">Fecha Ent.</label>
				<tipo>date</tipo>
				<valor>today</valor>
			</field>			
			

			<field id="impresion" local="true" noshow="true" deshabilitado="true">
			       <setvar>xmlImpresion</setvar> 
			      <label>Programa de Impresion</label>
			      <parametro id="numerador_param.xml" retorna="impresion" />
			</field> 

			<field id="regcuenta_ivaid" local="true" noshow="true">
				<label>id_Iva</label>
			</field>
		  
			<field id="regcuenta_direccion" local="true" deshabilitado="true">
				<label>Direccion</label>
				<size>25</size>
			</field>

			<field id="regcuenta_localidad" local="true" deshabilitado="true">
				<label modpos="nobr">Localidad</label>
				<size>20</size>
			</field>

			<field id="regcuenta_provincia" local="true" deshabilitado="true">
				<label>Provincia</label>
			</field>




			<field id="regcuenta_iva" local="true" deshabilitado="true">
				<label modpos="nobr">Iva</label>
			</field>

			<field id="regcuenta_cuit" local="true" deshabilitado="true" sincelda="true">
				<label modpos="nobr">CUIT</label>
			</field>

		    <field id="login" local="true" noshow="true">
			   <valor eval="true">$_SESSION['idUser']</valor>
	        </field>

			<field id="regcuentavendedor_id" deshabilitado="true">
				<label >Vendedor</label>
				<helper type="combo" xml="regcuenta_simple_qry.xml" dir="/ayudas" _empty="true">
					<field id="id_regcuenta" />
					<field id="baja_cuenta">
						<condicion operador="=">'0000-00-00'</condicion> 
					</field>
					<field id="subsistema_id" >
						<condicion operador="=" valorde="subsistemavendedor_id"/>
					</field>
				</helper>
			</field>     

			

			<field id="wstklista_id"  local="true"  deshabilitado="true">
				<label  modpos="nobr">Lista de Precios </label>
				<help>Lista de Precios</help>
				<helper type="combo"  xml="stklista_qry.xml" dir="/ayudas" _empty="true">
					<field id="max_desc1" >
							<expresion>porcentaje_desc</expresion>
					</field>					
					<field id="max_desc2" >
							<expresion>porcentaje_desc1</expresion>
					</field>
				</helper>
				<actualiza>
				    <field id="control_dtogral" destino="stklista_id" />
					<field id="codigo_detalle" destino="wstklista_id" xml="mos_maindh_grid.xml" />
				</actualiza>
			</field>      

			<field id="max_desc1" local="true" noshow="true" />

			<field id="max_desc2" local="true" noshow="true" />

			<field id="regforma_id" sincelda="true" deshabilitado="true">
				<label modpos="nobr">Condicion de Venta</label>
				<helper type="combo" xml="regforma_qry.xml" dir="/ayudas" _empty="true" />
			</field>		

			<field id="regcuentatransporte_id" colspan="5">
				<label >Transporte</label>
				<helper type="combo" xml="regcuenta_simple_qry.xml" dir="/ayudas" empty="true">
					<field id="id_regcuenta" />
					<field id="baja_cuenta">
						<condicion operador="=">'0000-00-00'</condicion> 
					</field>
					<field id="subsistema_id" >
						<condicion operador="=" valorde="subsistematransporte_id"/>
					</field>
				</helper>
			</field>      
                            

			<field id="limite_credito" local="true" deshabilitado="true" sincelda="true">
        	    <label modpos="nobr" style="color:blue">Limite</label>
	            <formato>%15.2f</formato>
	            <tipo>numeric</tipo>
        	</field>

 			<field id="cons_pendiente" local="true" deshabilitado="true" sincelda="true">
                <label modpos="nobr"  style="color:blue">Pendiente</label>
                <tipo>numeric</tipo>
            	<formato>%15.2f</formato>
        	</field> 

			<field id="diferencia" local="true"    deshabilitado="true" sincelda="true">
            	<label modpos="nobr"  style="color:blue">Diferencia</label>
            	<tipo>numeric</tipo>
        	</field>

        	<field id="regforma_id" _sincelda="true">
                <label  _modpos="nobr"  >Condicion de Venta</label>
                <helper type="combo" xml="regforma_qry.xml" dir="/ayudas">            	
                </helper>
            </field>
			
			<!--
			<field id="referencia_movimiento"  >
				<label colspan="4">Observaciones</label>
				<size>80</size>
			</field>      
			-->
			
        </fieldGroup>
        			
		<!-- DETALLE DEL COMPROBANTE  -->
		<fieldGroup>			
			<field id="detalle" local="true" colspan="10">
			<label modpos="force" />
				<helper type="object" xml="mos_maindh_grid.xml" />
			</field>
			
		</fieldGroup>
					<!-- FIN -->
		<fieldGroup>

			<field id="separator1" local="true" deshabilitado="true">
				<label colspan="2"/>
			</field>
				
			<field id="subtotal_movimiento" local="true" deshabilitado="true">
				<label modpos="nobr" _style="font-size: medium; text-align: right;">Sub Total</label>
				<tipo>decimal</tipo>		
				<valor default="true">0.00</valor>
			    <if exp="true">
				    <true>neto_movimiento + 0 - ((neto_movimiento + 0) * (bonificaciones_movimiento + 0) / 100)</true>
				    <false>0</false>
				</if>
				<jseval campodestino="importe_movimiento">(subtotal_movimiento + 0) + (importe_iva + 0) + (importe_exento + 0) )</jseval>  
			</field>

			<field id="Descu" local="true">
                <label></label>
				<helper xml="stk_descuentosvolumen_qry.xml" dir="/stock/listas/" type="link" width="400px" height="300px">
				  <parameter source="wstklista_id" target="stklista_id" />                                          
				</helper>
				
				<valor>Desc.Grales</valor>
				<tipo>varchar</tipo>
			</field>		

			<field id="bonificaciones_movimiento" _noshow="true" _sincelda="true">
				<label  modpos="nobr" _style="font-size: medium; text-align: right;">Descuento Gral %</label>
                <jseval campodestino="neto_movimiento">subtotal_movimiento + 0 - ((subtotal_movimiento + 0) * (bonificaciones_movimiento + 0) / 100)</jseval>
                <jseval campodestino="importe_bon" actxml="false">((subtotal_movimiento + 0) * (bonificaciones_movimiento + 0) / 100)</jseval>
                <jseval campodestino="importe_IVA">mi_importe_iva + 0 - ((mi_importe_iva + 0) * (bonificaciones_movimiento + 0) / 100)</jseval>
                <jseval campodestino="importe_movimiento">neto_movimiento  + (importe_IVA + 0 ) + (importe_exento + 0) </jseval>

				<tipo>decimal</tipo>		
			</field>
			<field id="importe_bon" _noshow="true" deshabilitado="true" sincelda="true">
		         <label modpos="nobr">Importe Descuento</label>
		         <tipo>decimal</tipo>
			</field>

			<field id="separator3" local="true" deshabilitado="true">
				<label colspan="2"/>
			</field>


			<field id="neto_movimiento" deshabilitado="true" >
				<label modpos="nobr" _style="font-size: medium; text-align: right;">Neto</label>
				<tipo>decimal</tipo>		
			</field>

			<field id="separator4" local="true" deshabilitado="true">
				<label colspan="2"/>
			</field>
			<field id="importe_IVA" deshabilitado="true">
				<label modpos="nobr" _style="font-size: medium; text-align: right;">IVA</label>
				<tipo>decimal</tipo>		
			</field>
			<field id="separator5" local="true" deshabilitado="true">
				<label colspan="2"/>
			</field>	  			  
			<field id="importe_exento" deshabilitado="true">
				<label modpos="nobr" _style="font-size: medium; text-align: right;">Exento</label>
				<valor default="true">0.00</valor>
				<tipo>decimal</tipo>		
			</field>
			<field id="separator6" local="true" deshabilitado="true">
				<label colspan="2"/>
			</field>  
			<field id="importe_movimiento" deshabilitado="true">
				<label modpos="nobr" _style="font-size: xx-large; text-align: right;">Total</label>
				<tipo>decimal</tipo>		
				<valor>0</valor>
				<size>20</size>
			    <if exp="true">
				    <true>(subtotal_movimiento + 0) + (importe_IVA + 0) + (importe_exento + 0) </true>
				    <false>0</false>
				</if>
			</field>			
			
			
			<field id="separator7" local="true" deshabilitado="true">
				<label colspan="2"/>
			</field>

			<field id="micanpro" local="true" deshabilitado="true">
			  <label modpos="nobr">Cant. de Productos</label>
			  <actualiza>
				<field id="control_dtogral" destino="cantidad" />
			  </actualiza>
			</field>
			
            <field id="mi_importe_iva" local="true" deshabilitado="true" noshow="true">
                <label>Se almacena el importe original por si tiene descuentos globales para poder recalcularlos y tomar este como base de calculo</label>
            </field>


			<field id="control_dtogral" local="true" deshabilitado="true">
			  <label>Ctrl</label>
			  <helper type="combo" id="STK_DESCUENTOSVOLUMEN">
				<field id="limite">
				  <expresion>round(porcentaje_descuento0)</expresion>
				</field>
				<field id="porcentaje_descuento0">
				  <expresion>round(porcentaje_descuento0)</expresion>
				</field>
				<field id="desde_cantidad">
				  <condicion operador="&lt;=">'[__cantidad__]' AND hasta_cantidad &gt;= '[__cantidad__]'</condicion>
				</field>
				<field id="stklista_id" />
				<field id="cantidad" local="true" />
				<parameter source="wstklista_id" target="stklista_id" />
				<parameter source="micanpro"    target="cantidad" />
			  </helper>
			  <tipo>int</tipo>
			</field>

		</fieldGroup> 
            <field id="fiscal" local="true" noshow="true">
                <label>Fiscal</label>
                <parametro id="numerador_fiscal.xml" retorna="fiscal" />
                <actualiza>
                    <field id="grillafiscal" destino="fiscal" />
                </actualiza>

            </field>
            <field id="grillafiscal" colspan="4" local="true" noshow="true">
                <helper type="object" xml="mos_fiscal_grid.xml" />
            </field>
        </table>               
    </form>
</histrix>

