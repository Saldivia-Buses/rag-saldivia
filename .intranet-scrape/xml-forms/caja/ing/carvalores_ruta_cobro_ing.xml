<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="ing" subtipo="vertical" preloadData="false" imprime="false" exportasuma="true" 
  llenoreferente="true" 
  resume="true"
  confirma="CONFIRMAR">
  <title>Ingreso de Valores</title>
  <obs/>
  <form >
    <table id="CAR_VALORES" label="Carga de Valores">

      <movimientos>
        <relacion id="carvalores_ins.xml"/>
        <relacion id="carmovimientos_ins.xml"/>
      </movimientos>
      <field id="id_regmovim" local="true" esClave="true" noshow="true" valauto="true">
        <detalle>id_regmovim</detalle>
      </field>


      <field id="id_carvalor" autoinc="true" esClave="true" noshow="true"/>
<!--        <condicion operador="=">-1</condicion> 
      </field>-->


      <field id="cajformapago_id" local="true" esClave="true" noshow="true">
        <detalle>cajformapago_id</detalle>
      </field>

      <fieldGroup id="parametros_ingreso" local="true" noshow="true">
        <field id="importe_movimiento"/>
        <field id="imputacion_concepto"/>
        <field id="fecha_movimiento"/>
        <field id="referencia_movimiento"/>	   
      </fieldGroup>

      <!--
       <validation>
            <condition><![CDATA[carbanco_id + 0 == '0']]></condition>
            <message>Debe Ingresar una Cuenta Bancaria</message>
        </validation>

       <validation>
            <condition><![CDATA[carplaza_id + 0 == '0']]></condition>
            <message>Debe Ingresar una Cuenta Bancaria</message>
        </validation>

       <validation>
            <condition><![CDATA[nro_valor + 0 == '0']]></condition>
            <message>Debe Ingresar un Numero de Valor</message>
        </validation>

       <validation>
            <condition><![CDATA[importe_valor + 0 == '0']]></condition>
            <message>Debe Ingresar un Importe de Valor</message>
        </validation>
      -->
      
      <!-- Banco / Sucursal / Plaza -->

      <field id="carbanco_id" valauto="000" esClave="true">
        <label>Banco</label>
        <helper type="external" xml="carbanco_qry.xml" dir="/ayudas" />
        <size>3</size>
      </field>
      
      <field id="nombre_banco" deshabilitado="true" tabla="CAR_BANCOS" sincelda="true">
        <label modpos="nobr"/>
        <size>60</size>
      </field>

      <field id="sucursal_banco" >
        <label>Sucursal</label>
        <size>3</size>
      </field>

      <field id="carplaza_id" >
        <label modpos="nobr">Plaza</label>
        <helper type="external" xml="carplaza_qry.xml" dir="/ayudas" />
        <size>4</size>
      </field>

      <field id="nombre_plaza" deshabilitado="true" tabla="CAR_PLAZAS" sincelda="true">
        <label modpos="nobr"/>
        <size>30</size>
      </field>

      <field id="nro_valor">
        <label>Nº Valor</label>
      </field>

      <field id="cuenta_valor">
        <label modpos="nobr">Nº Cuenta</label>
      </field>

      <field id="fecha_valor">
        <label>Fecha de Emision</label>
        <valor>today</valor>
      </field>

      <field id="acreditacion_valor">
        <label modpos="nobr">Fecha de Acreditación</label>
        <valor>today</valor>
      </field>

      <field id="moneda_id">
        <helper type="combo" xml="monedas_qry.xml" dir="/ayudas" />
        <label>Moneda</label>
      </field>

      <field id="importe_valor" suma="true">
        <label modpos="nobr">Importe</label>
        <detalle>pago_valor</detalle>
      </field>

      <field id="titular_valor">
        <label colspan="3">Titular</label>
        <size>70</size>
      </field>

      <field id="cuit_valor">
        <label _modpos="nobr">CUIT</label>
        <size>13</size>
      </field>
	<field id="tipo_movimiento" local="true"  valauto="true" noshow="true">
		<expresion>[__imputacion_concepto__]</expresion>
        </field>

    </table>

    <join>
      <table id="CAR_BANCOS">
        <field id="id_carbanco">
          <condicion operador="=">CAR_VALORES.carbanco_id</condicion>
        </field>
      </table>
    </join>

    <join>
      <table id="CAR_PLAZAS">
        <field id="id_carplaza">
          <condicion operador="=">CAR_VALORES.carplaza_id</condicion>
        </field>
      </table>
    </join>
  </form>
</histrix>
