<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="insert" >
    <title/>
    <obs/>
    <form>
        <table id="CAJ_MOVIMIENTOS" idCampoCond="total_imputado">
            <field id="cajregistro_id"          id_padre="cajregistro_id"/>
            <field id="cajconcepto_id"      	id_padre="cajconcepto_id"/>
            <field id="cajpuesto_id"     		id_padre="cajpuesto_id"/>
            <field id="nro_movimiento"          id_padre="nro_movimiento"/>
            <field id="fecha_movimiento"        id_padre="fecha_movimiento">
                <tipo>date</tipo>
            </field>
            <field id="hora_movimiento">
                <valor>NOW()</valor>
                <tipo>integer</tipo>
            </field>
            <field id="referencia_movimiento"   id_padre="referencia_movimiento">
          	  <tipo>varchar</tipo>
      		</field>
            <field id="importe_movimiento"      id_temp="total_imputado">
                <tipo>custom_numeric</tipo>
            </field>
        </table>
    </form>
</histrix>
