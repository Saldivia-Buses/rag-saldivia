<histrix tipo="fichaing" inserta="false" borra="false" modifica="false" imprime="false" log="false" transaccional="true" tooltip="false" confirma="GRABAR">
    <title>Pago</title>
    <obs/>
    <form >

        <table id="REG_MOVIMIENTOS" label="Recibo">



            <validation>
                <condition><![CDATA['nro_movimiento' + 0 == 0]]>
                </condition>         
                <message>Debe Ingresar un Nro de Recibo</message>
            </validation>

            <validation>
                <condition><![CDATA[importe_movimiento + 0 == 0]]>
                </condition>
                <message>Debe Imputar un Comprobante</message>
            </validation>

            <validation>
                <condition><![CDATA[importe_anticipo + 0 < 0]]>
                </condition>
                <message>El anticipo no puede ser un numero negativo</message>
            </validation>
