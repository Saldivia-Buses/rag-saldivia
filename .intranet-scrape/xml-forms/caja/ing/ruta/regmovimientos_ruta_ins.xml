<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="insert" _sqlhardcoded="true">
    <title/>
    <obs/>
    <form>
        <table id="REG_MOVIMIENTOS" idCampoCond="total_imputado">
            <field id="subsistema_id"      	id_temp="subsistema_id"/>
            <field id="regcuenta_id"     	id_temp="regcuenta_id" />
            <field id="concepto_id"      	id_padre="regconcepto_id"/>

            <field id="fecha_movimiento"     	id_padre="fecha_movimiento"/>
            <field id="letra_movimiento"     	id_padre="regcuenta_ivaletra"/>


            <field id="cajconcepto_id"     	id_padre="cajconcepto_id" local="true"/>
            
            <field id="puesto_movimiento"     	id_padre="puesto_movimiento"/>
<!--            <field id="nro_movimiento" 	     	id_padre="nro_movimiento"/> -->
            <field id="nro_movimiento" >
            	<valor>ifnull(( select numero from CAJ_NUMERADORES RN where cajconcepto_id = [__cajconcepto_id__] ), 0)</valor>
                </field>
            
            <field id="reg_fecha" 	        id_padre="fecha_movimiento"/>
            <field id="vencimiento_movimiento" 	id_padre="vencimiento_movimiento"/>
            <!--
            <field id="neto_movimiento"         id_temp="neto_movimiento"/>
            <field id="importe_iva"           	id_temp="importe_iva"/>
            <field id="importe_exento" 	     	id_temp="importe_exento"/>
            <field id="alicuota_iva" 	     	id_temp="alicuota_iva"/>
                -->
            <field id="importe_movimiento"     	id_temp="total_imputado"/>
            <field id="referencia_movimiento"   id_padre="referencia_movimiento">
          	  <tipo>varchar</tipo>
          	</field>

            <field id="cajmovimiento_id" 	lastId="cajmovimientos_ruta_ins.xml"/>
        </table>
    </form>
</histrix>	
