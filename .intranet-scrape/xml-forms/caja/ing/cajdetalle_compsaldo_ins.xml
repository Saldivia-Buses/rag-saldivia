<?xml version="1.0" encoding="UTF-8"?>
<!--
	Esta grabación tiene como objetivo grabar la partida contable
	referida a la cuenta corriente dentro del asiento de caja
-->
<histrix tipo="insert" >
    <title/>
    <obs/>
    <form >
        <table id="CAJ_DETALLES" idCampoCond="imputado">
            <field id="cajmovimiento_id" lastId="cajmovimientos_ins.xml"/>
            <field id="cuenta_id"       id_temp="ctbcuenta_reg_id" required="true"/>
            <field id="doh"             id_temp="ctbcuenta_reg_doh">
                <tipo>varchar</tipo>
            </field>
            <field id="importe_detalle" id_temp="imputado" required="true"/>
        </table>
    </form>
</histrix>
