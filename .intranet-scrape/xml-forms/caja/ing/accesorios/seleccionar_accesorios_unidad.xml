<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="ing" path="fotos/accesorios" llenoreferente="true">
    <title>Accesorios por coche</title>
    <obs/>
    <form >
        <table id="ACCESORIOS_COCHE" label="Accesorios Estandar"  idCampoCond="imputar">
            <field id="id_accesorio" noshow="true" esClave="true" autoinc="true">
            </field>
            <field id="cotizacion_id" oculto="true" >
            </field>

            <field id="nrofab" _noshow="true" tabla="PEDCOTIZ">
		<label>Nro. Fabricación</label>
                <expression having="false">nrocha</expression>
            </field>

            <field id="nro_cuenta2" oculto="true" tabla="PEDCOTIZ">
		    <expression having="false">PEDCOTIZ.ctacod</expression>
            </field>

            <field id="fecha" noshow="true">
                <label>fecha</label>
                <tipo>date</tipo>
                <valor>today</valor>
            </field>
            <field id="artcod" deshabilitado="true" >
                <label>Cod.</label>
                <valor default="true">0</valor>
                <detalle>codigo_detalle</detalle>
            </field>

            <field id="artdes" autocompletar="true" >

                <label>Accesorios</label>
                <size>70</size>
                <detalle>descripcion_detalle</detalle>
                
            </field>
            <field id="fotopath" local="true" noshow="true">
                <if exp="true">
                    <true>'artcod/'</true>
                    <false>''</false>
                </if>
                <tipo>varchar</tipo>
            </field>
	    <field id="alicuota_iva" noshow="true">
		<expression>select alicuota from GEN_IVA_ALICUOTAS where artiva = iva_id limit 1</expression>
		<detalle>alicuota_iva</detalle>
	    </field>
                       <!--
            <field id="foto" path="fotopath" download="true">
                <expression>select ARTICULO_FOTO.foto from ARTICULO_FOTO where ARTICULO_FOTO.idArticulo = STKINSUM.artcod limit 1</expression>
                <label>Imagen</label>
                <tipo >file</tipo>
                <size>40</size>
            </field>
                           -->
            <field id="cantidad" noZero="true" noEmpty="true">
                <label>Cant</label>
                <tipo>integer</tipo>
		    <detalle>cantidad_detalle</detalle>
            </field>
            <field id="precio_unitario"  >
                <label>P.Unit</label>
                <tipo>numeric</tipo>
                <detalle>precio_venta</detalle>
		<size>20</size>
            </field>

<!--
            <field id="precio_adicional"  suma="true">
                <label>Sub Total </label>

                <tipo>numeric</tipo>
            </field>  -->
            <field id="total" suma="true" >
                <label>Sub Total </label>

                <expression>case when cantidad != 0 then cantidad * precio_unitario else precio_adicional end</expression>
                <detalle>subtotal0</detalle>

                <tipo>numeric</tipo>
            </field>
            <field id="imputar" local="true" refresh="true" >
                <label>Selec</label>
                <help>Seleccion</help>
                <tipo>check</tipo>
                <valor default="true">1</valor>
            </field>
			<field id="estado" noshow="true">
				<label>Estado</label>
				<condicion operador="=">1</condicion>
			</field>
        </table>
        <join tipo="left">
            <table id="PEDCOTIZ">
                <field id="id">
                    <condicion operador="=">ficha_id</condicion>
                </field>
            </table>
        </join>
        
        <join tipo="left">
            <table id="STKINSUM">
                <field id="artcod">
                    <condicion operador="=">ACCESORIOS_COCHE.artcod</condicion>
                </field>
                <field id="siscod">
                    <condicion operador="=">'02'</condicion>
                </field>

            </table>
        </join>
    </form>
</histrix>
