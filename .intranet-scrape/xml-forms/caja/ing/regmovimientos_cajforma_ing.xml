<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="fichaing" inserta="false" borra="false" modifica="false" imprime="false" log="false" transaccional="true" tooltip="false" confirma="GRABAR">
    <title />
    <obs />
    <form>
        <table id="REG_MOVIMIENTOS" label="Depositos">

            <validation>
                <condition><![CDATA[regcuenta_id + 0 == '0']]>
                </condition>
                <message>Debe Ingresar una Cuenta</message>
            </validation>

            <validation>
                <condition><![CDATA[importe_movimiento == 0]]>
                </condition>
                <message>Debe Ingresar un Importe de Movimiento</message>
            </validation>

            <validation>
                <condition><![CDATA[cajformapagorel_id == 0]]>
                </condition>
                <message>Falta forma de cobro-pago para asociar a la operacion</message>
            </validation>

            <cierraproceso id="cajmovimientos_ing.xml">
                <paring destino="moneda_id">moneda_id</paring>
                <paring destino="cajpuesto_id">cajpuesto_id</paring>
                <paring destino="cajconcepto_id">cajconcepto_id</paring>
                <paring destino="cajregistro_id">cajregistro_id</paring>
                <paring destino="importe_movimiento">importe_movimiento</paring>
                <paring destino="fecha_movimiento">fecha_movimiento</paring>
                <paring destino="referencia_movimiento">referencia_movimiento</paring>
                <paring destino="nro_movimiento">nro_movimiento</paring>
                <paring destino="ctbcuenta_reg_id">ctbcuenta_reg_id</paring>
                <paring destino="ctbcuenta_reg_doh">ctbcuenta_reg_doh</paring>	
                <paring destino="imputacion_concepto">imputacion_concepto</paring>
            </cierraproceso>
            
            
            <field id="descripcion_concepto" style="background-color:#000;color:#fff;padding-top:5px;padding-bottom:5px;text-align:center;" deshabilitado="true" colspan="12" noshow="true">  
                <attribute id="noshow">oculta_titulos</attribute>
              <expression sql="true">
                SELECT descripcion_concepto FROM CAJ_CONCEPTOS WHERE id_cajconcepto = [__cajconcepto_id__]
              </expression> 
              <size>40</size>
            </field>
            
            <field id="oculta_titulos" local="true" noshow="true">
              <helper type="parameter" id="SIS::02::oculta_titulos">
                  <label>Oculta titulos identificadores en programas de caja</label>
                  <defaultValue>false</defaultValue>
              </helper>
            </field>


            <field id="titulo" local="true" deshabilitado="true" noshow="true">
          	  <if exp="imputacion_concepto == 0">
          	  <true>'Extracciones'</true>
          	  <false>'Depositos'</false>
          	  </if>
          	  <setvar>titulo</setvar>
            </field>
      
            <movimientos>
                <relacion id="regmovimientos_ins.xml"/>
                <relacion id="regdetalles_ins.xml"/> 
				
				<!-- Compensa el ingreso/egreso de plata en la cuenta -->
				<relacion id="cajvaloresrel_ins.xml"/>
				<relacion id="cajmovimientos_ant_upd.xml"/>
				
                <relacion id="impresion_caja.xml"/> 
                <relacion id="actualizo_cajnumerador.xml"/> 
            </movimientos>
		
            <field id="id_regmovim" noshow="true">
                <condicion operador="=">-1</condicion>
            </field>
		 
            <fieldGroup id="DEBUG" local="true" noshow="true">
                <field id="cajpuesto_id" />
                <field id="cajconcepto_id" />
                <field id="fecha_movimiento" />
                <field id="subsistema_id" />
                <field id="regconcepto_id" />
                <field id="imputacion_concepto" />
                <field id="imprime_concepto" />
                <field id="cajregistro_id" />
                <field id="ctbcuenta_id" />
                <field id="ctbcuenta_reg_doh"  >
                    <if exp="imputacion_concepto == 0">
                        <true>1</true>
                        <false>0</false>
                    </if>
                </field>
                <field id="tipoimpre_concepto" />
            </fieldGroup>
			      
            <field id="moneda_id" local="true" noshow="true">
                <label>Moneda</label>
                <helper type="combo" id="CAJ_PUESTO_MONEDAS">
                    <field id="moneda_id" />
                    <field id="moneda_id2">
                        <expression>moneda_id</expression>
                    </field>
                    <field id="cajpuesto_id">
                        <condicion operador="=" valorde="cajpuesto_id"></condicion>
                    </field>
                </helper>
            </field>

            <field id="regcuenta_id" local="true">
                <label>Ingresa en Cuenta</label>
                <helper type="combo" xml="regcuenta_cmb.xml" dir="/ayudas" empty="true">
                    <field id="moneda_id">
                        <condicion operador="=" valorde="moneda_id"></condicion>
                    </field>
                    <field id="baja_cuenta">
                        <condicion operador="=">0000-00-00</condicion>
                    </field>
                    <field id="ctbcuenta_reg_id" noshow="true">
                        <expression>ifnull((SELECT cuenta_id FROM REG_CUENTA_IMPUTACION
                                                WHERE REG_CUENTA_IMPUTACION.regcuenta_id = REG_CUENTA.id_regcuenta
                                                  AND REG_CUENTA_IMPUTACION.doh = (CASE WHEN '0' = 1 THEN 1 ELSE 0 END) LIMIT 1) , GEN_SUBSISTEMAS.cuenta_haber_id)</expression>
                        <label>Haber</label>
                        <detalle>ctbcuenta_reg_id</detalle>
                    </field>
                </helper>
                <size>6</size>        
            </field>

            <field id="ctbcuenta_reg_id" local="true" noshow="true" />

            <field id="regcuenta_nombre" local="true" deshabilitado="true" sincelda="true">
                <label modpos="nobr"></label>
            </field>

            <field id="nro_movimiento" deshabilitado="true">
                <label>Nº Comprobante</label>	
                <parametro id="cajnumerador_param.xml" retorna="numero">
                    <field id="numero">
                       <!-- <complete>numero + 1</complete> -->
                    </field>
                </parametro>
                <format>%08d</format>
                <size>8</size>
                <detalle>nro_movimiento</detalle>
            </field>
            
            <field id="vencimiento_movimiento">
                <label>Fecha de Acreditacion</label>
                <valor>today</valor>
            </field>

            <field id="referencia_movimiento" maxlength="144">
                <label>Referencia</label>
                <tipo>varchar</tipo>
                <size>144</size>
            </field>

            <field id="importe_movimiento">
                <size>10</size>
                <label>Importe</label>
                <tipo>custom_numeric</tipo>
            </field>

			
			<!-- Forma de Cobro/Pago de caja donde compensará el ingreso (deposito) o egreso (extraccion) de fondos de la cuenta -->

			<field id="cajformapagorel_id" local="true" noshow="true">
				<helper type="combo" id="CAJ_FORMAS_PAGO">
					<field id="id_cajformapago" />
					<field id="descripcion_forma" />
					<field id="subsistema_id">
						<expression having="false">subsistema_forma_id</expression>
					</field>
					<field id="imputacion_concepto" local="true"/>
					<field id="tipo_forma">
						<condicion operador="=">IF('[__imputacion_concepto__]' = '0', 1, 0)</condicion>
					</field>
				</helper>
			</field>
			
			<field id="pago_valor_rel" local="true" noshow="true">
				<if exp="true">
					<true>importe_movimiento</true>
					<false>0</false>
				</if>
			</field>
			
			<field id="importe_total" local="true" noshow="true">
				<valor>0</valor>
			</field>
			
			<field id="graba_anticipo" local="true" noshow="true">
			    <if exp="'subsistema_id' == '04'">
				<true>1</true>
				<false>0</false>
			    </if>
			</field>
			
			<!-- fin -->
			
            <field id="muestracheck" local="true" noshow="true">
                <if exp="tipoimpre_concepto != 2">
                    <true>'display:none;'</true>
                    <false>''</false>
                </if>
            </field>

            <field id="CHKimprime" local="true" noshow="true">
                <attribute id="style">muestracheck</attribute>
                <label style="font-size: medium; align: right;" _modpos="nobr">Imprime Comprobante</label>
                <tipo>check</tipo>
            </field>

            <field id="impresion" local="true" noshow="true" deshabilitado="true">
                <label>Programa de Impresion</label>
                <if exp="CHKimprime=='1' || tipoimpre_concepto=='1'">
                    <true>'imprime_concepto'</true>
                    <false>''</false>
                </if> 
            </field>
        </table>

    </form>
</histrix>  
