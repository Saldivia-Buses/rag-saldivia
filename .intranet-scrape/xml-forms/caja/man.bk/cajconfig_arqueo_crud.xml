<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="ing" deleteRow="false" transacional="true" tooltip="false" inserta="false" modifica="false" confirma="APLICAR" forceReload="true" showCantidad="false"  dataTables_info="false">
	<title>Formas de Cobro/Pago</title>
	 <obs></obs>
		<form>
		    <table id="CAJ_FORMAS_PAGO" label="Formas de Cobro/Pago para arqueo">

				<movimientos>
					<relacion id="cajconfig_arqueo_del.xml"/>
					<relacion id="cajconfig_arqueo_ins.xml"/>
				</movimientos>

				<field id="id_cajformapago" noshow="true" esClave="true"/>

				<!-- TABLA DE VINCULACION -->
				<field id="id_cajpuestoarqueo" tabla="CAJ_PUESTO_ARQUEOS" noshow="true" />
				<field id="cajpuesto_id"  local="true" esClave="true"     noshow="true" />
				<field id="cajformapago_id"    tabla="CAJ_PUESTO_ARQUEOS" noshow="true" />
				<!-- FIN -->
				<!-- Determina La Grabacion de los Registros Habilitados -->
				<field id="habilitado" _refresh="true" deshabilitado="false">
				    <expression>case when CAJ_PUESTO_ARQUEOS.cajformapago_id then 1 else 0 end</expression>
				    <tipo>check</tipo>
				</field>
				<field id="descripcion_forma" deshabilitado="true" >
					<label>Nombre</label>    
				</field>

				<field id="tipo_forma" deshabilitado="true">
					<helper type="combo">
						<option value="0">Cobro</option>
						<option value="1">Pago</option>
					</helper>
				</field>


<!--
				<field id="anterior" noshow="true">
				    <expression>case when CAJ_PUESTO_ARQUEOS.cajformapago_id then 1 else 0 end</expression>
				</field>
    -->
				<!-- Determina La Grabacion de los Registros Previamente Habilitados al Ingreso del Formulario -->
<!--				<field id="borrado" noshow="true" local="true">
				    <if exp="'habilitado' != 'anterior'">
						<true>1</true>
						<false>0</false>
				    </if>
				</field>
    -->
    <!--
				<group>
				    <field id="id_cajformapago" tabla="CAJ_FORMAS_PAGO" />
				</group>
        -->
				<order>
					<field id="tipo_forma" />
				</order>

		    </table>

		    <join tipo="left">
				<table id="CAJ_PUESTO_ARQUEOS">
				    <field id="cajformapago_id">
						<condicion operador="=">id_cajformapago</condicion>
				    </field>
					<field id="cajpuesto_id">
						<condicion operador="=">'[__cajpuesto_id__]'</condicion>
					</field>
				</table>
		    </join>
		    
		</form>
</histrix>    

