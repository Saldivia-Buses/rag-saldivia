<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="grid" procesa="true" imprime="false" deleteRow="false" transacional="true" tooltip="false" inserta="false" modifica="false" confirma="APLICAR" forceReload="true" showCantidad="false" dataTable_info="false">
    <title>Puntos de Venta por Puesto</title>
    <obs></obs>
    <form>
        <table id="REG_NUMERADORES" label="P.V. para el Puesto">
            <movimientos>
                <relacion id="cajconfig_npv_del.xml"/>
                <relacion id="cajconfig_npv_ins.xml"/>
            </movimientos>
				
            <field id="id_regnumerador" noshow="true" esClave="true" />
				
				<!-- TABLA DE VINCULACION -->
            <field id="id_cajpuestonpv" tabla="CAJ_PUESTO_NPV"   noshow="true" />
            <field id="cajpuesto_id" local="true" esClave="true" noshow="true" />
            <field id="regnumerador_id" tabla="CAJ_PUESTO_NPV"   noshow="true" />
				<!-- FIN -->
                <!-- Determina La Grabacion de los Registros Habilitados -->                
            <field id="habilitado" refresh="true" deshabilitado="false">
                <expression>case when !isnull(regnumerador_id) then 1 else 0 end</expression>
                <tipo>check</tipo>
            </field>
				
            <field id="puesto" >
                <label>P.Venta</label>
                <format>%04d</format>
            </field>
				
            <field id="descripcion">
                <label>Tipo Comprobante</label>
                <expression>CONCAT(REG_CONCEPTOS.descripcion_concepto,' ',letra)</expression>
            </field>
				

<!--
            <field id="anterior" noshow="true">
                <expression>case when regnumerador_id then 1 else 0 end</expression>
            </field>

            <field id="borrado" noshow="true" local="true">
                <if exp="'habilitado' != 'anterior'">
                    <true>1</true>
                    <false>0</false>
                </if>
            </field> -->
            <order>
        	<field id="puesto" />
            </order>
        </table>
        <join tipo="left">
            <table id="CAJ_PUESTO_NPV">
                <field id="regnumerador_id">
                    <condicion operador="=">id_regnumerador</condicion>
                </field>
                <field id="cajpuesto_id">
                    <condicion operador="=">'[__cajpuesto_id__]'</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="REG_CONCEPTOS">
                <field id="id_concepto">
                    <condicion operador="=">regconcepto_id</condicion>
                </field>
                <field id="subsistema_id">
                    <condicion operador="=">'02'</condicion>
                </field>
            </table>
        </join>
		    
    </form>
</histrix>
