<?xml version="1.0" encoding="UTF-8"?>
	<histrix	tipo="fichaing" inserta="false" borra="false" modifica="false" imprime="false" tooltip="false"
				confirma="ANULAR COMPROBANTE" _form="false" transaccional="true" preFetch="true" preloadData="true"
				procesa="false">

    <title>Anulacion de Comprobantes</title>
    <obs/>
    
    <eventos>
      <event id="procesar">close</event>
    </eventos>
    
    <form>

	<table id="REG_MOVIMIENTOS">
		

		<validation optional="true">
			<condition><![CDATA[id_regmovim != 0]]></condition>
			<message>Se va a anular el comprobante, desea continuar?</message>
		</validation>

		<validation>
			<condition><![CDATA[puedeborrar == 0]]></condition>
			<message>El comprobante esta imputado a otro, primero desimpute desde cta cte.</message>
		</validation>

		<validation>
			<condition><![CDATA[nromovimiento == 0]]></condition>
			<message>El numero de comprobante no puede ser cero. Ingrese primeramente el numero de comprobante en Mod.</message>
		</validation>


		<validation>
			<condition><![CDATA[numero_cae != 0]]></condition>
			<message>El comprobante fue autorizado por AFIP, no se puede anular</message>
		</validation>


		<!-- Proceso de anulacion -->      

		<movimientos>
			<relacion id="anula_ctbmovimientos.xml" />
            <relacion id="anula_stkmovimientosreg.xml" />
			<relacion id="anula_regdetalles.xml" />
			<relacion id="anula_regmovimientos.xml" />
		</movimientos>
		
		<field id="id_regmovim" esClave="true" noshow="true" />

		<field id="puedeborrar" noshow="true">
			<expression> case when (select count(*) from REG_IMPUTACIONES where regmovim0_id = REG_MOVIMIENTOS.id_regmovim ) &gt; 0 then 0 else 1 end</expression>
		</field>

		<field id="procesa" local="true" noshow="true">
		    <setvar>procesa</setvar>
		    <if exp="'param_procesa' == '0'">
			<true>'false'</true>
			<false>'true'</false>
		    </if>
		</field>

		<!-- Si se envía valor 0 a esta variable, no aparece el botón "Anular", por defecto SI aparece -->

		<field id="param_procesa" local="true" noshow="true" />

		<!-- Comienzo -->
 
 <fieldGroup style="padding:2px 2px 2px 2px;"  deshabilitado="true">

		<field id="datos" local="true" style="font-size:16px;">
			<label>DATOS</label>
		</field>        

		<field id="nombre_cuenta">
			<expression>CASE REG_MOVIMIENTOS.nombre_movimiento WHEN '' THEN REG_CUENTA.nombre_cuenta ELSE REG_MOVIMIENTOS.nombre_movimiento END</expression>
			<label>Cuenta</label>
			<size>45</size>
		</field>

		<field id="cuit_cuenta" tabla="REG_CUENTA" modpos="nobr">
			<label>CUIT</label>
		</field>

		<field id="cod_direccion" tabla="REG_CUENTA" modpos="nobr" >
			<label>Dirección</label>
			<size>30</size>
		</field>

		<field id="subsistema_id" noshow="true" />

		<field id="descripcion_concepto" tabla="REG_CONCEPTOS" >
			<label>Comprobante</label>
		</field>

		<field id="fecha_movimiento" modpos="nobr">
			<label>Fecha</label>
			<tipo>date</tipo>
		</field>

		<field id="nro_movimiento" modpos="nobr" >
			<label>Numero</label>
			<expression>CONCAT(REG_MOVIMIENTOS.letra_movimiento,' ', LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,'0'),'-', LPAD(REG_MOVIMIENTOS.nro_movimiento ,8,'0'))</expression>
		    <size>40</size>    
		    <tipo>varchar</tipo>
		</field>

		<field id="nromovimiento" >
			<label>NRO</label>
			<expression>(REG_MOVIMIENTOS.nro_movimiento)</expression>
		</field>

		<field id="localidad_id" tabla="REG_CUENTA" >
			<label>Localidad</label>
			<expression>SELECT CONCAT(id_localidad,' ', nombre_localidad) FROM GEN_LOCALIDADES where id_localidad = REG_CUENTA.localidad_id limit 1</expression>
			<size>30</size>
		</field>

		<field id="provincia_id" tabla="REG_CUENTA" modpos="nobr" >
			<label>Provincia</label>
			<expression>SELECT nombre_provincia FROM GEN_PROVINCIAS where id_provincia = REG_CUENTA.provincia_id limit 1</expression>
			<size>20</size>
		</field>

		<field id="vencimiento_movimiento" deshabilitado="true">
			<label  modpos="nobr">Vencimiento</label>
		</field>

		<field id="detdalles" local="true">
			<label colspan="15">Detalle</label>
			<helper type="object" xml="factura_detalle_qry.xml" dir="/caja/qry">
				<parameter source="id_regmovim" target="regmovim_id" operator="="/>	
				<parameter source="subsistema_id" target="subsistema_id" operator="="/>	
			</helper>
		</field>

		<field id="articulos" local="true">
			<label colspan="15">Movimientos</label>
			<helper type="object" xml="factura_articulos_qry.xml" dir="/caja/qry">
				<parameter source="id_regmovim" target="regmovimiento_id" operator="="/>
			</helper>
		</field>

		<!-- OCULTA EL CAMPO OTROS DETALLES SOLO DISPONIBLE PARA INSUMAS 1:oculto 0:muestra	-->

		<field id="muestraod" local="true" noshow="true">
              <helper type="parameter" id="SIS::01::oculta_imputaciones">
                <label>Oculta otros detalles</label>
                <defaultValue>1</defaultValue>
              </helper>
        </field>

		<field id="otrosdetalles" local="true">
			<attribute id="oculto">muestraod</attribute>
			<label colspan="15">Otros Detalles</label>
			<helper type="object" xml="factura_detalle_qry_new.xml" dir="/caja/qry">
				<parameter source="id_regmovim" target="regmovim_id" operator="="/>	
			</helper>
		</field>

		<!-- OCULTA EL CAMPO OTROS DETALLES SOLO DISPONIBLE PARA INSUMAS -->

        <!-- Importes -->
		
		<field id="valores" local="true" style="font-size:16px;">
			<label>VALORES</label>
		</field>        

		<field id="neto_movimiento" >
			<label>Neto</label>
			<tipo>numeric</tipo>
		</field>

		<field id="total_iva" modpos="nobr">
			<label>IVA</label>
			<expression>SUM(REG_DETALLES.iva_detalle)</expression>
            <size>10</size>
			<tipo>numeric</tipo>
		</field>

		<field id="importe_exento" modpos="nobr">
			<label>Exento</label>
			<tipo>numeric</tipo>
		</field>           

        <field id="importe_percepcion" >
            <label>Percepcion Gan</label>
            <tipo>numeric</tipo>
        </field>

        <field id="importe_ibr" modpos="nobr">
            <label>Percepcion IIBB</label>
            <tipo>numeric</tipo>
        </field>

		<field id="fecha_cae" deshabilitado="true">
			<label modpos="nobr">Fecha CAI:</label>
		</field>

		<field id="importe_movimiento" >
			<label>Total</label>
			<tipo>numeric</tipo>
		</field>

		<field id="numero_cae" modpos="nobr">
			<label>NRO CAE</label>
			<!-- <expression> case when (REG_MOVIMIENTOS.numero_cae) &gt; 0 then 0 else 1 end</expression> -->
		</field>


	</fieldGroup>

		<group>
			<field id="id_regmovim" />
		</group>

    </table>

	<join tipo="left">
		<table id="REG_CONCEPTOS">
		    <field id="id_concepto">
			<condicion operador="=">concepto_id</condicion>
		    </field>
		</table>
	</join>

	<join tipo="left">
		<table id="REG_CUENTA">
			<field id="id_regcuenta">
				<condicion operador="=">regcuenta_id</condicion>
			</field>
		</table>
	</join>

	<join tipo="left">
		<table id="REG_DETALLES">
			<field id="regmovim_id">
				<condicion operador="=">id_regmovim</condicion>
			</field>
		</table>
	</join>
  </form>
</histrix>
