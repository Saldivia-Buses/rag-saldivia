        <help>Fecha</help>
      </field>
      <field id="fechafin">
        <label>Hasta</label>
        <help>Hasta Fecha</help>
        <tipo>date</tipo>
      </field> 
      <field id="horas">
        <label>Horas</label>
        <help>Horas</help>
        <tipo>varchar</tipo> 
