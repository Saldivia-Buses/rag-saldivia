            <field id="movnpv" _deshabilitado="true" _sincelda="true" style="width:4em;white-space:nowrap;">
                <label modpos="nobr">Número</label>
                <format>%04d</format>
		<size>4</size>
                <valor>1</valor>
            </field>
            <field id="movnro" ctbregnro="1" deshabilitado="false" sincelda="true" style="width:8em;">
                <label modpos="nobr" >- </label>
                <expression sql="true">select max(movnro) + 1 from CCTMOVIM where siscod = '03'</expression>
                <!--<parametro id="numeradorfac.xml" retorna="num">
                    <field id="siscod" oculto="true" noselect="true">
                        <condicion operador="=">'03'</condicion>
                        <tipo>varchar</tipo>
                        <valor>'03'</valor>
