                <tipo>varchar</tipo>

            </field> -->
            <field id="domicilio" deshabilitado="true" >
                <label _colspan="2" modpos="nobr" >Domicilio:</label>
                <help></help>
                <tipo>varchar</tipo>
                <size>30</size>
            </field>
            <field id="movfec" >
                <label modpos="nobr">Fecha</label>
                <help>Fecha de Emisión </help>
                <valor>today</valor>
                <detalle>movfec</detalle>
                <tipo>date</tipo>
            </field>

            <field id="cta2" required="false" _autocompletar="true" _searchRecord="false">
                <label _colspan="3" >Nombre 2</label>
   <!--             <ayuda_ex id="CCTCUENT" condes="true" _xml="HLPcctcuent_conta_cot.xml" dir="/help_local">
                    <field id="ctacod2" noshow="true">
                	<expression>ctacod</expression>
                    </field>

                    <field id="ctanom2">
                        <expression having="false">ctanom</expression>
                        <tipo>varchar</tipo>
                    </field>
                    <field id="siscod" oculto="true" >
                        <condicion operador="=">'02'</condicion>
                    </field>
                    <order>
                        <field id="ctanom"></field>
                    </order>
                </ayuda_ex>
-->
                <size>40</size>
            </field>
            
            <field id="cta_nom2" deshabilitado="true" noshow="true">
                <label  modpos="nobr" ></label>
                <help></help>
                <tipo>varchar</tipo>
            </field>
            <field id="doccod" deshabilitado="true"  noshow="true">
                <label modpos="nobr">Doc</label>
            </field>
            <field id="ctanro" deshabilitado="true">
                <label modpos="nobr">Cuit</label>
            </field>
            <field id="movlet" deshabilitado="true" _sincelda="true" style="width:2em" noshow="true">
                <label modpos="nobr" ></label>
                <valor>X</valor>

            </field>

            <field id="concod" >
                <label _modpos="nobr" _colspan="3">Tipo</label>
                <help>Tipo Comprobante </help>
                <tabla_ex id="CCTCONCE">
                    <field id="concod"></field>
                    <field id="condes"></field>
                    <field id="siscod">
                        <condicion operador="=">'02'</condicion>
                    </field>
                    <field id="conimp">
                        <condicion operador="=">1</condicion>
                    </field>
                    <order>
                        <field id="concod"></field>
                    </order>
                </tabla_ex>
                <valor>1</valor>
                <detalle>concod</detalle>
            </field>

