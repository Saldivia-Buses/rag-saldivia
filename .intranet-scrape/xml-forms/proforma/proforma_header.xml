                    <field id="concod" oculto="true" noselect="true">
                        <condicion operador="=" >1</condicion>
                    </field>
                    <field id="num">
                        <expression>max(movnro) + 1</expression>
                    </field>
                </parametro> -->
                <format>%08d</format>
                <detalle>movnro</detalle>
                <detalle>carrec</detalle>
                <detalle>cajnro</detalle>
                <detalle>movinc</detalle>

            </field>


            <field id="ctacte" deshabilitado="true" noshow="true">
                <detalle>ctacte</detalle>
            </field>


