<?xml version="1.0" encoding="UTF-8"?>
<histrix llenoTemporal="false" tipo="cabecera"   transaccional="true"  >
    <title>Punto de Venta</title>
    <obs/>
    <form>
        <table id="CCTMOVIM" label="Emision de Facturas Proforma" _styleTbody="height:150px;overflow-x:hidden;">
            <field id="siscod" local="true" noshow="true" >
                <valor>03</valor>
            </field>
            <field id="ctacod" required="true"  deshabilitado="true">
                <label >Cliente:</label>
                <help>Código de Cliente</help>
                <tipo>integer</tipo>
                <detalle>ctacod</detalle>
                <size>3</size>

            </field>
               <field id="ctanom" required="true" autocompletar="true" searchRecord="false">
               <label _colspan="2" >Nombre 1</label>
               <ayuda_ex id="CCTCUENT" _condes="true" xml="HLPcctcuent_conta_cot.xml" dir="/help_local">
                   <field id="ctacod" noshow="true" >
                       <detalle>ctacod</detalle>
                   </field>

                   <field id="ctanom2">
                       <expression having="false">CCTCUENT.ctanom</expression>
                       <tipo>varchar</tipo>
                   </field>
                   <field id="siscod" oculto="true" >
                       <condicion operador="=">'02'</condicion>
                   </field>
                   <field id="ctatel" class="informal" noshow="true">
                       <detalle>ctatel</detalle>
                   </field>
                    <field id="Dmicilio" noshow="true">
                        <expression>CONCAT(ctadir, ' ', ctaloc)</expression>
                        <label>Domicilio</label>
                        <detalle>domicilio</detalle>
                    </field>
                    <field id="ivacod" noshow="true">
                        <detalle>ivacod</detalle>
                    </field>
                    <field id="ivacod2" noshow="true">
                        <expression>(case when ivacod = 1 or ivacod = 2 then 'A' else 'B' end)</expression>
                        <detalle>movlet</detalle>
                    </field>
                    <field id="doccod" noshow="true">
                        <detalle>doccod</detalle>
                    </field>
                    <field id="ctanro" noshow="true">
                        <detalle>ctanro</detalle>
                    </field>


                   <clave>ctanom</clave>
                   <descripcion>ctanom</descripcion>
                   <order>
                       <field id="ctanom"></field>
                   </order>
               </ayuda_ex>

               <size>40</size>
           </field>

