<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="consulta">
    <title>Cuenta Corriente</title>
    <obs></obs>
    <form detalle="proforma_update_ing.xml" >
        <table id="CCTMOVIM" label="Movimientos">

            <field id="siscod" oculto="true">
                <label>Cod.</label>
                <help> </help>
                <condicion operador="=">03</condicion>
                <valor>'03'</valor>
            </field>

            <field id="movnro" tipoOrden="DESC">
                <label modpos="nobr">Número</label>
                <help> Número Comprobante</help>
                <format>%12d</format>
                <detalle>movnro</detalle>
                <detalle>nrofac</detalle>
                <detalle>carrec</detalle>
                <detalle>cajnro</detalle>
                <detalle>movinc</detalle>
            </field>

            <field id="movfec">
                <label>Fecha </label>
            </field>
            
            <field id="nrofab" noZero="true">
                <label>Unidad</label>
            </field>            

            <field id="ctacod">
                <label>Nombre</label>
                <help>Código de Cuenta </help>
                <tabla_ex id="CCTCUENT">
                    <field id="ctacod"/>
                    <field id="ctafan"/>
                    <field id="siscod">
                        <condicion operador="=">'02'</condicion>
                    </field>
                </tabla_ex>
<!--		        <condicion operador="=">20</condicion> 
-->
                <detalle>ctacod</detalle>
            </field>
            <field id="movref__1">
                <label>Referencia</label>
                <tipo>varchar</tipo>
            </field>
            <field id="movnpv" noshow="true">
                <label>P.V.</label>
                <help> Punto Venta</help>
                <format>%04d</format>
                <detalle>movnpv</detalle>
                <detalle>nropue</detalle>

					  
            </field>
		<!-- <field id="comprobante" local="true">
			 <label>Numero</label>
			<expression>CONCAT(LPAD(movnpv,4,0),' - ',LPAD(movnro,6,0))</expression>
		</field>-->
            <field id="concod" noshow="true">
                <label>concep</label>

                <detalle>concod</detalle>
            </field>
            <field id="movlet" noshow="true">
                <detalle>movlet</detalle>
            </field>

		
<!--                  <field id="concepto">
		      <expression>condes</expression>
                      <label>Cod.Concepto</label>
                      <help> </help>
		      <tipo>string</tipo>
                  </field> -->

    <!--          <field id="movvto">
                      <label>Venc. </label>
                      <help> </help>
                  </field>
-->
            <field id="movimp" >
                <label>Importe</label>
                <help> </help>
                <tipo>numeric</tipo>
            </field>

            <field id="nrofab" >
                <label>Unidad</label>
            </field>
		  
            <order>
                <field id="movnro"></field>
            </order>

<!--
		  <filters>
			<field id="movfec"  >
			    <operador>>=</operador>
			    <label>Desde Fecha</label>
			    <valor>today</valor>

			</field>  
			<field id="movfec" >
			    <operador>&lt;=</operador>
			    <label>Hasta Fecha</label>
			    <valor>today</valor>

			</field>
		  </filters>
-->
        </table>
        <join tipo="left">
            <table id="CCTCUENT">
                <field id="ctacod">
                    <condicion operador="=">CCTMOVIM.ctacod</condicion>
                </field>
                <field id="siscod">
                    <condicion operador="=">'02'</condicion>
                </field>
            </table>

        </join>
        <join tipo="left">
            <table id="CCTCONCE">
                <field id="siscod" oculto="true">
                    <label>cctcuent.siscod</label>
                    <condicion operador="=">CCTMOVIM.siscod</condicion>
                </field>

                <field id="concod" oculto="true">
                    <condicion operador="=">CCTMOVIM.concod</condicion>
                </field>

                <field id="condes" oculto="true">
                </field>
            </table>
        </join>
              
    </form>
</histrix>
