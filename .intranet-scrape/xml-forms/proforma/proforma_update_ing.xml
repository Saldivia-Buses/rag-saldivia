                    <true>ROUND(((subtot_final * artali) / 100), 2)</true>
                    <false>iva</false>
                </if>
                <tipo>numeric</tipo>
            </field>

            <field id="precio_final" local="true" noshow="true">
                <label>Precio</label>
                <if exp="true">
                    <true>ROUND((subtot_final / artcan), 2)</true>
                    <false></false>
                </if>
                <tipo>numeric</tipo>
            </field>
-->

        </table>	
    </form>
</histrix>