            <field id="nrofab" deshabilitado="true" sincelda="true">
                <label posx="19" posY="95" >Referencia: </label>
                <tipo>varchar</tipo>
                <expression>case when CCTMOVIM.nrofab != '' then 
                                 CONCAT((select CONCAT(' U',CH.nrocha,' Nro: ', RIGHT(CH.chasis, 6), ' ', MC.desabv, ' Cliente: ', (case when PED.ctacod != '' then (select LEFT(CCTCUENT.ctafan, 17) from CCTCUENT where CCTCUENT.ctacod = PED.ctacod and siscod = '02') else (select LEFT(CCTCUENT.ctafan, 17) from CCTCUENT where CCTCUENT.ctacod = T.ctacod and siscod = '02') end))                                    
                                 from CHASIS CH
                                 join MODCHASIS MC on MC.marcod = CH.marcod and MC.modcha = CH.modcod
                                 left join PEDCOTIZ PED on PED.nrocha = CH.nrocha
                                 join TURNOSPRODUCCION T on T.nrofab = CH.nrocha
 
                                 where CCTMOVIM.nrofab = CH.nrocha limit 1
                                 ), ' ', movref__1)  else movref__1 end</expression>
            </field>

      


