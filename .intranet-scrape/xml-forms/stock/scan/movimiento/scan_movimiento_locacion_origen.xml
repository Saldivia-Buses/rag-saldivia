          </field>

          <field id="stkarticulo_id" local="true" oculto="true"/>

          <field id="fija">
            <expression>ifnull((select 0 from STK_ARTICULOS where id_stkarticulo = '[__stkarticulo_id__]'  and id_stklocacion = stklocacion_fija_id ), 1)</expression>
            <tipo>integer</tipo>
<!--             <detalle>fija</detalle>
 -->          </field>

          <field id="codigo_locacion" noshow="true" />

          <field id="stock" _bloqueafila="true">
            <expression having="false">(select stock_actual from STK_ARTICULO_LOCACION  WHERE stkarticulo_id = '[__stkarticulo_id__]' and id_stklocacion = stklocacion_id limit 1)</expression>
            <condicion operador="!=">0 </condicion>
            <detalle>stock</detalle>
          </field>

          <field id="stkdeposito_origen_id">
            <expression>stkdeposito_id</expression>
            <detalle>stkdeposito_origen_id</detalle>
          </field>

          <field id="computable">
            <expression having="false">(select suma_total from STK_DEPOSITOS where id_stkdeposito = stkdeposito_id)</expression>
            <condicion operador="=">1</condicion>
          </field>

          <order>
            <field id="fija" />
            <field id="codigo_locacion" />
          </order> 


  </table>
  </form>
