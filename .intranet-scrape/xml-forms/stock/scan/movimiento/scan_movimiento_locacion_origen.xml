<?xml version="1.0" encoding="UTF-8"?>
<histrix imprime="false" inserta="false" modifica="false" tipo="consulta" transaccional="true">
  <title>Scan</title>
  <obs/>
  <form>
    <table id="STK_LOCACION" label="Scan">
          
          <field id="id_stklocacion"/>

          <field id="codigo_locacion2">
            <expression>concat(ifnull(
              (select ' (Fija)' from STK_ARTICULOS where id_stkarticulo = '[__stkarticulo_id__]'  and id_stklocacion = stklocacion_fija_id )
              , '-'
              ),
               codigo_locacion,  
              ' stock: ', 
                   ifnull( 
              (select stock_actual from STK_ARTICULO_LOCACION  WHERE stkarticulo_id = '[__stkarticulo_id__]' and id_stklocacion = stklocacion_id limit 1), '0')
              , ' ',
              (select date_format(max(fecha_movimiento), '%d/%m/%y') from STK_MOVIMIENTOS M 
              where M.stkarticulo_id = '[__stkarticulo_id__]' and 
                   M.stkdeposito_id = STK_LOCACION.stkdeposito_id 
                And M.stklocacion_id = STK_LOCACION.id_stklocacion)
               )</expression>
