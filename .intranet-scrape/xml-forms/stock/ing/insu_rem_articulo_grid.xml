			<label modpos="nobr">cantidad</label>
			<tipo>decimal</tipo>
			<valor dafault="true">1.00</valor>
			<jseval fielddestino="neto_detalle" _actxml="false" suma="true">subtotal1 * cantidad_detalle</jseval>
			<jseval fielddestino="cantidad_valida" total="true">cantidad_detalle</jseval>	
		</field>
	</fieldGroup>

      <!-- PRECIOS -->
	<fieldGroup _colstyle="display: none;" _style="display: none;">
		<field id="precio_venta"  _deshabilitado="true">
			<label modpos="nobr">Precio</label>
			<valor default="true">0.00</valor>
			<tipo>decimal</tipo>   
			<jseval fielddestino="subtotal0" _actxml="false" suma="true">((precio_venta + 0 ) - ((precio_venta + 0 )  * (porcentaje_desc0 + 0 ) / 100 ))</jseval>
			<jseval fielddestino="subtotal1" _actxml="false" suma="true">((subtotal0 + 0 ) - ((subtotal0 + 0 )  * (porcentaje_desc1 + 0 ) / 100 ))</jseval>
			<jseval fielddestino="neto_detalle" _actxml="false" suma="true">subtotal1 * cantidad_detalle</jseval>
		</field>
		<field id="porcentaje_desc0" deshabilitado="true" noshow="true">
			<label >% 1</label>
			<valor default="true">0.00</valor>
			<tipo>decimal</tipo>
			<jseval fielddestino="subtotal0" _actxml="false" suma="true">((precio_venta + 0 ) - ((precio_venta + 0 )  * (porcentaje_desc0 + 0 ) / 100 ))</jseval>
			<jseval fielddestino="subtotal1" _actxml="false" suma="true">((subtotal0 + 0 ) - ((subtotal0 + 0 )  * (porcentaje_desc1 + 0 ) / 100 ))</jseval>
		</field>
		<field id="subtotal0" local="true" deshabilitado="true" noshow="true">
			<label modpos="nobr"   >SubTotal</label>
			<valor default="true">0.00</valor>
			<tipo>decimal</tipo>
		    	<if exp="true">
		            <true>((precio_venta + 0 ) - ((precio_venta + 0 )  * (porcentaje_desc0 + 0 ) / 100 ))</true>
		            <false>0</false>
		        </if>
			<jseval fielddestino="neto_detalle" _actxml="false" suma="true">subtotal0 * cantidad_detalle</jseval>
		</field>
		<field id="porcentaje_desc1"   deshabilitado="true" noshow="true">
			<label modpos="nobr">% 2</label>
			<tipo>decimal</tipo>
			<valor default="true">0.00</valor>
			<jseval fielddestino="subtotal1" _actxml="false" suma="true">((subtotal0 + 0 ) - ((subtotal0 + 0 )  * (porcentaje_desc1 + 0 ) / 100 ))</jseval>
		</field>
		<field id="subtotal1" local="true" deshabilitado="true" noshow="true" >
			<label modpos="nobr" >SubTotal1</label>
			<tipo>decimal</tipo>
			<valor default="true">0.00</valor>
		        <if exp="true">
		            <true>((subtotal0 + 0 ) - ((subtotal0 + 0 )  * (porcentaje_desc1 + 0 ) / 100 ))</true>
		            <false>0</false>
		        </if>                		
			<jseval fielddestino="neto_detalle" _actxml="false" suma="true">subtotal1 * cantidad_detalle</jseval>
		</field>
		<field id="neto_detalle" suma="true" deshabilitado="true" >
			<label modpos="nobr">Neto</label>
			<valor default="true">0.00</valor>
			<tipo>decimal</tipo>
		        <if exp="true">
		            <true>round(subtotal1 * cantidad_detalle, 2)</true>
		            <false>0</false>
