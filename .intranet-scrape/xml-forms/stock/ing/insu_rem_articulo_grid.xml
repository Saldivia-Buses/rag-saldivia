			<jseval fielddestino="neto_movimiento" total="true">neto_detalle</jseval>
		</field>
		<field id="alicuota_iva"  noshow="true" >
			<label >Alicuota</label>
			<valor default="true">0.00</valor>
			<tipo>decimal</tipo>
			<helper type="combo" xml="genalicuotas_qry.xml" dir="/ayudas" _empty="true"/>
			<jseval fielddestino="iva_detalle"> ( (neto_detalle + 0)  * (alicuota_iva + 0) / 100 )</jseval>
		</field>
		<field id="iva_detalle" suma="true" deshabilitado="true" noshow="true">
			<label modpos="nobr"  		_colstyle="display: none;">Imp.IVA</label>
			<tipo>decimal</tipo>
			<valor default="true">0.00</valor>
		        <if exp="true">
		            <true>round(( (neto_detalle + 0)  * (alicuota_iva + 0) / 100 ), 2 )</true>
		            <false>0</false>
		        </if>          
			<jseval fielddestino="importe_iva" total="true">iva_detalle</jseval> 
			<jseval fielddestino="total_detalle" _actxml="false">(neto_detalle +  ((iva_detalle + 0)) )</jseval> 
			<jseval fielddestino="mi_importe_iva" total="true">iva_detalle</jseval>    
		</field>
		<field id="total_detalle" suma="true" deshabilitado="true">
			<label _modpos="nobr">Total</label>
