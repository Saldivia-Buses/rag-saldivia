		-->


      <!-- Otros Datos  -->
		<field id="orden" deshabilitado="true" oculto="true">
			<label>Orden</label>
			<size>35</size>
		</field>
	</fieldGroup>
	<fieldGroup local="true" noshow="true">
		<field id="wcontrolstk" deshabilitado="true" _noshow="true" >
			<label modpos="nobr" colspan="3">sssss</label>
			<valor default="true">0</valor>
		</field>

		<field id="stkunidad_id"/>
		<field id="stksector_id"/>
		<field id="stkfamilia_id"/>
		<field id="stkrubro_id"/>
		<field id="precio_costo"/>
		<field id="referencia">
			<valor>'SALIDA POR VENTA'</valor>
		</field>
