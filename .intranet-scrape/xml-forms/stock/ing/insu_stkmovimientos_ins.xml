<?xml version="1.0" encoding="UTF-8" ?>
    <histrix tipo="insert">
	<title>Ingreso Movimiento</title>
	 <obs></obs>
		<form >
		    <table id="STK_MOVIMIENTOS"  		>

			<field id="regdetalle_id"  lastId="insu_regdetalles_ins.xml">
			<!-- 
	<valor>(SELECT AUTO_INCREMENT -1 FROM information_schema.TABLES WHERE TABLE_SCHEMA = 'insumas' AND TABLE_NAME = 'REG_DETALLES')</valor>	
-->
			</field>

			<field id="stkarticulo_id"         	id_temp="codigo_detalle"/>
			<field id="stkconcepto_id" 	    	_id_temp="stkconcepto_id">
				<valor>(SELECT option_value FROM HTXOPTIONS where option_name = 'ID_STKREMITOS')</valor>
			</field>
			<field id="regcuenta_id"           	id_padre="regcuenta_id"/>
			<field id="fecha_movimiento" 	   	id_padre="fecha_movimiento"/>
			<field id="alta_movimiento" 	   	id_padre="fecha_movimiento"/>
			<field id="puesto_movimiento" 	   	id_padre="puesto_movimiento"/>
			<field id="numero_movimiento" 	   	id_padre="nro_movimiento"/>
			<field id="orden_movimiento" 	   	id_temp="_ORDEN"/>
			<field id="cantidad" 	       		id_temp="cantidad_detalle"/>
			<field id="precio_costo"       		id_temp="precio_costo"/>
			<field id="precio_venta" 	   		id_temp="precio_venta"/>
			<field id="precio_total"       		id_temp="total_detalle"/>
			<field id="referencia" 	       		_id_temp="descripcion_detalle">
				<valor>'Remitido'</valor>
			</field>

			<field id="unidad_id" 	       		id_temp="stkunidad_id"/>

			<field id="stkdeposito_id" 	   		id_padre="stkdeposito_id" /> 
			
			<field id="stkfamilia_id" 	   		id_temp="stkfamilia_id"/>
			<field id="stkrubro_id" 	   		id_temp="stkrubro_id"/>

		    </table>
		</form>
    </histrix>	


