<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="grid" subtipo="vertical" procesa="false" deleteRow="false">
  <title>Ingreso de Inventario</title>
  <obs/>
  <form>
    <table id="STK_INVENTARIO_DETALLES" label="Ingreso de Inventario">
      
      <movimientos>
        <relacion id="stkinventariodet_insumas_upd.xml"/>
      </movimientos>
      
  <fieldGroup noshow="true">
	    <field id="unidad_id" tabla="STK_ARTICULOS"/>
	    <field id="precio_lista" tabla="STK_ARTICULOS"/>
	    <field id="precio_venta" tabla="STK_ARTICULOS"/>
	    <field id="precio_promedio" tabla="STK_ARTICULOS"/>
        <field id="id_stkinventariodet" />
        <field id="stkinventario_id">
	        <condicion operador="=">0</condicion>
	    </field>
  </fieldGroup>

  <fieldGroup style="text-align:center;padding:2px 2px 2px 2px;">

	      <field id="stkarticulo_id" esClave="true" >
	        <label>Codigo</label>
	        <helper type="external" xml="stkarticulo_stockactual_deposito_qry.xml" dir="/ayudas">
	          <field id="wstklista_id" local="true">
	            <valor>1</valor>
	          </field>
	        </helper>
	        <size>12</size>
	      </field>
	      
	      <field id="nombre_articulo" tabla="STK_ARTICULOS" deshabilitado="true">
	        <label modpos="nobr">Descripcion</label>
	        <size>60</size>
	      </field>
	      
	      <field id="stock" deshabilitado="true">
	        <label modpos="nobr">Teorico</label>
	      </field>

		<field id="alerta_desc" clasefila="true" noshow="true" local="true">
			<label>Alerta</label>
			<expression>if( genmoneda_origen_id = 2, 'resaltado', '')</expression>
		</field>

	    <!-- PARAMETROS EN DOLARES -->

			<field id="genmoneda_origen_id" deshabilitado="true" tabla="STK_ARTICULOS" noshow="true">
				<label>Moneda</label>
			</field>

			<field id="cotizacion_dolar" local="true" tabla="STK_ARTICULOS" noshow="true">
				<label>Cotizacion</label>
			</field>

		<!-- FIN PARAMETROS EN DOLARES -->

		
		<!-- PRECIOS CONJUNTOS -->

	      <field id="precio_costo" editable="true" tabla="STK_ARTICULOS">
	        <label modpos="nobr">Precio conjunto</label>
	        <expression>if( genmoneda_origen_id=2, round(precio_costo * '[__cotizacion_dolar__]' ,2) , round(precio_costo,2) )</expression>
	        <tipo>numeric</tipo>
	      </field>



	      <!-- PRECIOS SEPARADOS:
	      <field id="precio_costo" local="true" editable="true" >
	        <label modpos="nobr">Precio Ar$</label>
	        <expression>round(precio_costo,2)</expression>
	        <tipo>numeric</tipo>
	      </field>

	      <field id="precio_costo2" editable="true" local="true">
	        <label modpos="nobr">Precio u$s</label>
			<expression>if( genmoneda_origen_id=2, round(precio_costo * '[__cotizacion_dolar__]' ,2), '' )</expression>
	        <tipo>numeric</tipo>
	      </field> -->

	      
	      <field id="stock_real1" editable="true" style="width:120px; height:20px; text-align:right;">
	        <label>Recuento 1</label>
	        <jseval fielddestino="diferencia">(stock_real1 + 0 == 0)?(diferencia + 0):(stock_real1) - (stock + 0)</jseval>
	        <jseval fielddestino="monto">((precio_costo + 0) * (diferencia + 0)).toFixed(2)</jseval>
	        <tipo>integer</tipo>
	      </field>
	      
	      <field id="stock_real2" editable="true" style="width:120px; height:20px; text-align:right;">
	        <label>Recuento 2</label>
	        <jseval fielddestino="diferencia">(stock_real2 + 0 == 0)?(diferencia + 0):(stock_real2) - (stock + 0)</jseval>
	        <jseval fielddestino="monto">((precio_costo + 0) * (diferencia + 0)).toFixed(2)</jseval>
	        <tipo>integer</tipo>
	      </field>
	      
	      <field id="stock_real3" editable="true" style="width:120px; height:20px; text-align:right;">
	        <label>Recuento 3</label>
	        <jseval fielddestino="diferencia">(stock_real3 + 0 == 0)?(diferencia + 0):(stock_real3) - (stock + 0)</jseval>
	        <jseval fielddestino="monto">((precio_costo + 0) * (diferencia + 0)).toFixed(2)</jseval>
	        <tipo>integer</tipo>
	      </field>
	      
	      <field id="diferencia" deshabilitado="true" noZero="true" editable="true" style="width:80px; height:20px; text-align:center;">
	        <label modpos="nobr">Diferencia</label>
	        <tipo>integer</tipo>
	        <if exp="(stock_real3 + 0) != 0">
	          <true>(stock_real3 + 0) - (stock + 0)</true>
	          <false>((stock_real2 + 0) != 0) ? (stock_real2 + 0) - (stock + 0) : (stock_real1 + 0) - (stock + 0)</false>
	        </if>
	      </field>
	      
	      <field id="ajuste" editable="true" modpos="nobr" style="width:30px; height:20px; text-align:center;">
	        <label>Ajuste</label>
	        <tipo>check</tipo>
	      </field>

	      <field id="monto" deshabilitado="true" editable="true">
	        <label>Monto</label>
	        <if exp="true">
	          <true>(precio_costo + 0) * (diferencia + 0)</true>
	          <false>(precio_costo + 0) * (diferencia + 0)</false>
	        </if>
	      </field>

	      <field id="observaciones" editable="true">
	        <label>Obs</label>
	        <size>90</size>
	      </field>

    
	</fieldGroup>

    
      <order>
        <field id="nombre_articulo" />
      </order>
    
    </table>
    
    <join tipo="left">
      <table id="STK_ARTICULOS">
        <field id="id_stkarticulo">
          <condicion operador="=">STK_INVENTARIO_DETALLES.stkarticulo_id</condicion>
        </field>
      </table>
    </join>

  </form>
</histrix>