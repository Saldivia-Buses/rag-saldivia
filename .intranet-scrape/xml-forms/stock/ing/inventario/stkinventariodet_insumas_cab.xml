<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="fichaing" inserta="false" modifica="false">
  <title>Ingreso de Inventario</title>
  <obs/>
  <form>
    <table id="STK_INVENTARIOS" label="Ingreso de Inventario">
      
      <validation>
        <condition><![CDATA[ 'stkdeposito_id' == 0 ]]> </condition>
        <message>Debe Ingresar un Depósito</message>
      </validation>
      
      <movimientos>
        <relacion id="stkinventario_insumas_upd.xml" />
      </movimientos>

      <fieldGroup noshow="true">

            <field id="id_stkinventario" noshow="true">
              <actualiza>
                <field id="stkinventariodetalles" destino="stkinventario_id" />
              </actualiza>
            </field>

            <field id="impresion" local="true" >
              <helper type="parameter" id="XML_IMP_CTRL_INVENTARIO" >
                <label>XML de Impresión</label>
                <defaultValue>/stock/qry/imp_stkinventario_insumas_qry.xml</defaultValue>
              </helper>
            </field>

            <field id="opname" local="true" print="false">
              <valor>ID_CTRL_INVENTARIO</valor>
            </field>

            <field id="usuario_id" print="false">
              <valor eval="true">$_SESSION['idUser']</valor>
            </field>

      </fieldGroup>

      <fieldGroup style="padding:2px 2px 2px 2px;">
        
        <field id="nro_inventario" >
          <label>Nº Conteo</label>
          <helper type="external" xml="stkinventario_qry.xml" dir="/ayudas" empty="true">
            <field id="cerrado" oculto="true">
              <condicion operador="=">0</condicion>
            </field>
          </helper>
        </field>

        <field id="cotizacion_dolar" modpos="nobr">
          <label>Cotizacion u$s</label>
          <valor default="true">1</valor>
              <actualiza>
                 <field id="stkinventariodetalles" destino="cotizacion_dolar" />
              </actualiza>
        </field>
        
        <field id="fecha_inventario" deshabilitado="true">
          <label modpos="nobr">Fecha Inv</label>
          <tipo>date</tipo>
        </field>
        
        <field id="stkdeposito_id" deshabilitado="true" modpos="nobr">
          <label>Depósito</label>
          <helper type="combo" xml="stkdeposito_qry.xml" dir="/ayudas" empty="true"/>
          <actualiza>
            <field id="stkarticulo_id" destino="stkdeposito_id" xml="stkinventariodet_insumas_ing.xml" />
          </actualiza>
        </field>
        
        <field id="cerrado" style="font-size:20px;width:20px;height:20px;" >
          <label modpos="nobr">Cerrar</label>
          <tipo>check</tipo>
        </field>

        <field id="separador" deshabilitado="true" editable="false" style="height:10px;"/>

        <field id="stkinventariodetalles" local="true">
          <helper type="object" xml="stkinventariodet_insumas_ing.xml" ></helper>
          <label  colspan="10"/>
        </field>

      </fieldGroup>

    </table>

  </form>
</histrix>