<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="fichaing" inserta="false" modifica="false" imprime="false" reloadForm="false">
  <title>Recepcion de Materiales</title>
  <obs></obs>
  <form>
    <table id="STK_MOVIMIENTOS" label="Recepción de Compras">

      <movimientos>
            <relacion id="avisouser_norecepcionado.xml"/>
      </movimientos>

      <fieldGroup noshow="true">

        	<field id="puesto_movimiento" deshabilitado="true" local="true" >
                <label>puesto</label>
                <valor>1</valor>
            </field>

        	<field id="stktransaccion_id"  deshabilitado="true" >
                <label>Transaccion ID</label>
            </field>

            <field id="de" local="true" >
            	<label>de</label>
              	<valor eval="true">$_SESSION['usuario']</valor>
            </field>

            <field id="para" local="true" >
            	<label>para</label>
	            <helper type="parameter" id="SIS::RH::usuario_administrador_stock">
                  <label>Usuario reponsable de stock</label>
                  <defaultValue></defaultValue>
	            </helper>
            </field>

      </fieldGroup>

      <fieldGroup style="font-size:medium;padding:2px 2px 2px 2px;vertical-align:middle;">

            <field id="numero_movimiento" deshabilitado="true" local="true" >
                <label>Nro Movimiento</label>
            </field>

            <field id="fecha_movimiento"  deshabilitado="true" >
                <label>Fecha origen</label>
                <tipo>date</tipo>
            </field>

            <field id="fecha" local="true" modpos="nobr" deshabilitado="true" >
                <label>Fecha Destino</label>
                <valor>today</valor>
                <tipo>date</tipo>
            </field>

            <field id="deposito_origen" deshabilitado="true" local="true">
      				<label>Origen</label>
      				<helper type="combo" xml="stkdeposito_qry.xml" dir="/ayudas" empty="true" />
            </field>

            <field id="deposito_destino" local="true" deshabilitado="true" modpos="nobr">
		          <label>Destino</label>
		          <helper type="combo" xml="stkdeposito_qry.xml" dir="/ayudas" empty="true" />
            </field>

            <field id="separator_5" local="true" style="background-color: #c9c9c9; height: 1px;font-size:2px;" colspan="9" deshabilitado="true" />

      </fieldGroup>

      <fieldGroup style="padding:2px 2px 2px 2px;vertical-align:middle;">

            <field id="concepto_devolucion" local="true" required="true">
                <label>Concepto Devolucion</label>
                <helper type="combo" id="STK_CONCEPTOS">
                  <field id="id_stkconcepto" />
                  <field id="nombre_concepto" />
                  <field id="tipo_concepto">
                    <condicion operador="=">0</condicion>
                  </field>
                </helper>
                <valor default="true">10</valor>
            </field>

            <field id="separator_2" local="true" style="padding:5px 0px 0px 0px;" colspan="6" deshabilitado="true" />

      </fieldGroup>

      <fieldGroup>

            <field id="detalle" showObjTabla="true" local="true" colspan="6">
              <helper type="object" xml="stktransfer_recepciontb.xml">
                <parameter source="numero_movimiento" target="numero_movimiento" />
                <parameter source="fecha_movimiento" target="fecha_movimiento" />
                <parameter source="stktransaccion_id" target="stktransaccion_id" />
              </helper>
              <label >Recepción</label>
            </field>

        </fieldGroup>

    </table>

    <join>
      <tabla id="STK_CONCEPTOS">
        <field id="id_stkconcepto">
           <condicion operador="=">stkconcepto_id</condicion>
        </field>
        <field id="tipo_concepto">
            <condicion operador="=">1</condicion>
        </field>
      </tabla>
    </join>

    <join>
      <tabla id="STK_DEPOSITOS">
        <field id="id_stkdeposito">
          <condicion operador="=">stkdeposito_id</condicion>
        </field>
      </tabla>
    </join>

  </form>
</histrix>