<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="cabecera" _llenoTemporal="true" >
  <title>Ingreso Movimientos Stock</title>
  <obs/>
  <form>
    <table id="STK_MOVIMIENTOS" label="Deposito en Efectivo">

      <field id="puesto_movimiento" sincelda="true" deshabilitado="true">
          <label _modpos="nobr">Comprobante</label>
          <size>4</size>
        	<formato>%04d</formato>
          <detalle>puesto_movimiento</detalle>
      </field>

      <field id="numero_movimiento" sincelda="true" deshabilitado="true">
          <label modpos="nobr">-</label>
          <parametro id="numerador_param.xml" retorna="numero">
              <field id="numero">
                  <complete>numero + 1</complete>
              </field>
          </parametro>
          <formato>%08d</formato> 
          <size>8</size>
          <detalle>numero_movimiento</detalle>
      </field>

      <field id="regcuenta_id" _noshow="true">
          <label colspan="5">Cuenta</label>
          <helper type="external" xml="regcuenta_solamente_qry.xml" dir="/ayudas" empty="true">
              <field id="subsistema_id" noshow="true">
                  <condicion operador="=">'01'</condicion>
              </field>
          </helper>
          <detalle>regcuenta_id</detalle>
      </field>

      <field id="nombre" local="true" deshabilitado="true" sincelda="true">
          <label modpos="nobr"  />
          <size>35</size>
      </field>

      <field id="fecha_movimiento" deshabilitado="false">
          <label>Fecha</label>
          <help>Fecha movimiento</help>
        	<valor>today</valor>
        	<tipo>date</tipo>
          <detalle>fecha_movimiento</detalle>
      </field>

      <field id="stkconcepto_id" modpos="nobr">
          <label >Concepto</label>
          <help>Código de concepto</help>
          <helper type="combo" xml="stkconcepto_qry.xml" dir="/ayudas" />
          <detalle>stkconcepto_id</detalle>
      </field>
        

        




      <field id="stkdeposito_id" modpos="nobr">
          <label>Deposito</label>
          <helper type="combo" xml="stkdeposito_qry.xml" dir="/ayudas" />
          <detalle>stkdeposito_id</detalle>
      </field>

      <field id="referencia" maxlength="60">
          <label modpos="nobr" colspan="5">Referencia</label>
          <help>Referencia del movimiento</help>
          <size>40</size>
      </field>


      <field id="impresion" local="true" noshow="true" deshabilitado="true">
          <parametro id="numerador_param.xml" retorna="impresion"></parametro>
      </field>

      
    </table>

  </form>
</histrix>
