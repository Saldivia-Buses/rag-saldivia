<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="grid" borra="false" inserta="false" deleteRow="false" procesa="true" _paginar="250" _imprime="false" preloadData="false">
  <title>Ingreso pedido interno</title>
  <obs/>
  <form>
    <table id="STK_ARTICULOS" _id="STK_ARTICULO_PEDIDOINT" label="Ingreso pedido interno">

      <movimientos>
        <relacion id="stkpedidoint_ins.xml"/>
      </movimientos>


      <filters>

        <field id="fecha_pedido" deshabilitado="true">
          <label>Pedido para la Fecha</label>
          <operador>&lt;=</operador>
          <valor>today</valor>
          <tipo>date</tipo>
        </field>

        <field id="separador" modpos="nobr" deshabilitado="true" editable="false" />

        <field id="stkdeposito_id" deshabilitado="false" modpos="nobr">
          <label>Deposito</label>
          <operador>=</operador>
        </field>

        <field id="separador" modpos="nobr" deshabilitado="true" editable="false" />

        <field id="stkrubro_id" modpos="nobr">
          <operador>=</operador>
          <label>Rubro</label>
        </field>

        <field id="separador" modpos="nobr" deshabilitado="true" editable="false" />

        <field id="codigo_barra">
          <operador>=</operador>
          <label modpos="nobr">Codigo de barra</label>
        </field>

        <field id="separador" modpos="nobr" deshabilitado="true" editable="false" />

        <field id="id_stkarticulo">
          <operador>=</operador>
          <label modpos="nobr">Codigo Art</label>

        </field>

      </filters>


      <field id="separador" local="true" deshabilitado="true" noshow="true">
          <size>1</size>
      </field>
     
<fieldGroup colstyle="text-align:center;">

      <field id="id_stkarticulo" >
         <helper type="external" xml="stkarticulo_qry.xml" dir="/ayudas" empty="true" >
                    <field id="id_stkarticulo"></field>
                    <field id="baja_articulo" noshow="true">
                         <condicion operador="!=">1</condicion>
                    </field>
          </helper>
      </field>

      <field id="codigo_barra" _tabla="STK_ARTICULOS">
        <label>Codigo de Barra</label>
      </field>

      <field id="stkrubro_id" _tabla="STK_ARTICULOS">
        <label>Rubro</label>
        <helper type="combo" xml="stkrubro_qry.xml" dir="/ayudas" empty="true"/>
      </field>

      <field id="nombre_articulo" _tabla="STK_ARTICULOS" >
        <label>Articulo</label>
      </field>

      <field id="cantidad" deshabilitado="false" editable="true" refresh="true">
        <expresion having="false">STK_ARTICULO_PEDIDOINT.cantidad</expresion>
        <label>Pedir</label>
        <tipo>check</tipo>
      </field>

  </fieldGroup>




      <field id="stkfamilia_id" _tabla="STK_ARTICULOS" noshow="true">
        <helper type="combo" xml="stkfamilia_qry.xml" dir="/ayudas" empty="true"/>
      </field>

      <field id="fecha_pedido" local="true" noshow="true">
        <tipo>date</tipo>
        <valor>today</valor>
        <!--expresion having="false">STK_ARTICULO_PEDIDOINT.fecha_pedido</expresion -->
      </field>

      <field id="stkdeposito_id" noshow="true" local="true">
        <helper type="combo" xml="stkdeposito_qry.xml" dir="/ayudas"/>
      </field>



      <field id="valorant" noshow="true">
        <expresion having="false">IFNULL(STK_ARTICULO_PEDIDOINT.cantidad,0)</expresion>
        <label>valorant</label>
        <tipo>check</tipo>
      </field>

      <field id="pide" local="true" noshow="true">
        <if exp=" (cantidad + 0 != valorant + 0) ">
          <true>'true'</true>
          <false>'false'</false>
        </if>
      </field>


      <field id="baja_articulo" noshow="true">
        <condicion operador="!=">1</condicion>
      </field>


      <order>
        <field id="nombre_articulo" tabla="STK_ARTICULOS"/>
      </order>
    </table>

    <join tipo="left">
      <table id="STK_ARTICULO_PEDIDOINT">
        <field id="stkarticulo_id">
          <condicion operador="=">STK_ARTICULOS.id_stkarticulo</condicion>
        </field>
        <field id="stkdeposito_id">
          <condicion operador="=">'[__stkdeposito_id__]'</condicion>
        </field>
      </table>
    </join>
   
         <!--
    <join tipo="left">
	<table id="STK_DEPOSITOS">
	    <field id="id_stkdeposito">
		<condicion operador="=">STK_ARTICULO_PEDIDOINT.stkdeposito_id</condicion>
	    </field>
	</table>
    </join>
      -->
  </form>
</histrix>
