<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="fichaing" inserta="false" borra="false" modifica="false" imprime="false" tooltip="false" confirma="CONFIRMAR REMITO"  transaccional="true">
    <title>Emisión de remitos</title>
    <obs></obs>
    <form >
        <table id="REG_MOVIMIENTOS" label="Emisión de remitos">
		<validation>
			<condition><![CDATA['regcuenta_ivaletra' == '']]></condition>
			<message>Debe Ingresar una Cuenta</message>
		</validation>

		<validation>
			<condition><![CDATA[regconcepto_id + 0 == 0]]></condition>
			<message>Tipo de Comprobante no válido</message>
		</validation>

		<validation>
			<condition><![CDATA[nro_movimiento + 0 == 0]]></condition>
			<message>Numero de Movimiento no válido</message>
		</validation>

            <!-- GRABACION DE CUENTA CORRIENTE -->

		<movimientos>
			<relacion id="insu_regmovimientos_ins.xml"/>
		</movimientos>

		<field id="id_regmovim" oculto="true">
			<condicion operador="=">-1</condicion>
		</field>
        
		<fieldGroup id="DEBUG" local="true" noshow="true">
			<field id="cajpuesto_id" />
			<field id="imputacion_concepto" />
			<field id="moneda_id">
			    <valor>1</valor>
			</field>
			  
			<field id="ctbcuenta_id">
			    <actualiza>
				<field id="ctbcuenta_reg_id"/>
			    </actualiza>
			</field>

			<field id="ctbcuenta_reg_id" />
				<field id="ctbcuenta_reg_doh">
					<if exp="true">
					<true>imputacion_concepto</true>
					<false>0</false>
					</if>
				</field>
				<field id="vencimiento_movimiento" >
					<label modpos="nobr">Fecha de Vencimiento</label>
					<tipo>date</tipo>
				</field>
		</fieldGroup>
		<fieldGroup> 
			<field id="subsistema_id" local="true" valauto="true" noshow="true"/>
			<field id="nro_cuenta" local="true">
				<label>Cod</label>
				<helper type="external" xml="regcuenta_relacionescmb_nro.xml" dir="/ayudas" _empty="true" >
				</helper>				
				<size>6</size> 
			</field>

			<field id="regcuenta_id" local="true" noshow="true">
				<label>Cuenta</label>
				<helper type="external" xml="regcuenta_relacionescmb.xml" dir="/ayudas" _empty="true" >
				</helper>				
				<size>6</size> 
				<detalle>regcuenta_id</detalle>
				<detalle>regcuenta_id_fac</detalle>
				<actualiza>
<!--					<field id="codigo_detalle" 		destino="regcuenta_id" xml="insu_rem_articulo_grid.xml" /> -->
			                <field id="facturas"        		destino="regcuenta_id_fac"   />
					<field id="regcuentarelacion_id" 	destino="regcuenta_id" />
					<field id="domicilio_movimiento" 	destino="regcuenta_id"   />
				</actualiza>
				<jseval campodestino="regcuenta_id">regcuenta_id</jseval>
			</field>
<!--			<field id="regcuenta_ivaletra" local="true" deshabilitado="true">
				<label modpos="nobr" style="font-size: large;" ></label>
				<actualiza>
				    <field id="puesto_movimiento" destino="letra" />
				    <field id="nro_movimiento" destino="letra" />
				    <field id="impresion" destino="letra" />
				</actualiza>
				<size>1</size>
				<detalle>letra_movimimento</detalle>
			</field> -->

			<field id="concepto_id" local="true" valauto="true" noshow="true">

			</field>


			<field id="regconcepto_id" deshabilitado="true" local="true" copia="concepto_id">

				<label modpos="nobr" colspan="2" style="font-size: large;" >Comprobante</label>
				<helper type="combo" id="REG_CONCEPTOS">
					<field id="id_concepto" />
					<field id="descripcion_concepto"/>
					<field id="subsistema_id">
						<condicion operador="=">[__subsistema_id__]</condicion> 
					</field>	
					<field id="informa_calculo">
						<condicion operador="=">1</condicion>
					</field>
				</helper>
				<actualiza>
					<field id="puesto_movimiento" destino="regconcepto_id" />
					<field id="nro_movimiento" destino="regconcepto_id" />
					<field id="impresion" destino="letra" />
				</actualiza>
				<detalle>concepto_id</detalle>
			</field>
            <field id="stkdeposito_id" local="true" _noshow="true" _sincelda="true" >
                <label modpos="nobr">Deposito</label>

                <helper type="combo" xml="stkdeposito_qry.xml" refresh="true" dir="/ayudas">
                </helper>
<!--
                <actualiza>
                    <field id="stkdeposito_id" _destino="stkdeposito_id" />
                    <field id="codigo_detalle" destino="stkdeposito_id" xml="mos_articulo_grid.xml" />
                </actualiza>
                -->
                <valor>2</valor>
                <detalle>stkdeposito_id</detalle>
            </field>

			
			<field id="regcuenta_nombre" local="true" deshabilitado="true">
				<label colspan="2">Razón Social</label>
				<size>25</size>
			</field>
			<field id="letra" deshabilitado="true" noshow="true">
				<label modpos="nobr" />
				<valor>X</valor>
			</field>
			<field id="puesto_movimiento" _deshabilitado="true">
				<label modpos="nobr">Punto de Venta</label>
				<helper type="combo" id="REG_NUMERADORES" empty="true">
					<field id="puesto" />
					<field id="nombre_puesto">
						<expression>LPAD(puesto,4,'0')</expression>
					</field>
					<field id="letra">
						<condicion operador="=">'X'</condicion>
					</field>
					<field id="regconcepto_id" oculto="true"/>
					<order>
						<field id="puesto" />
					</order>
				</helper>
				<valor>1</valor>
				<actualiza>
					<field id="nro_movimiento" destino="puesto" />
					<field id="impresion" destino="puesto" />
				</actualiza>
				<size>4</size>
				<detalle>puesto_movimiento</detalle>
			</field>
                <field id="nro_movimiento" local="true" _noshow="true" sincelda="true" deshabilitado="true">
                    <label modpos="nobr" style="font-size: large;" >Nro Rem</label>
                    <format>%08d</format>
                    <size>8</size>
                    <parametro id="numerador_paramrem.xml" retorna="numero">

	                    <field id="regconcepto_id"  oculto="true" esClave="true">
                            <condicion>47</condicion>

        	            </field>
	                    <field id="letra2"  local="true" oculto="true" />
	                    <field id="puesto"  oculto="true" esClave="true">
    	                	    <condicion operador="=" valorde="puesto_movimiento"></condicion>
        	            </field>


                        <field id="numero">
                            <complete>numero + 1</complete>
                        </field>
                    </parametro>
                    <detalle>nro_movimiento</detalle>
                </field>          
			
			<field id="impresion" local="true" noshow="true" deshabilitado="true">
			      <setvar>xmlImpresion</setvar>
			      <label>Programa de Impresion</label>
			      <parametro id="numerador_param.xml" retorna="impresion" />
			</field>
			<field id="regcuenta_direccion" local="true" deshabilitado="true">
				<label colspan="2">Direccion</label>
				<size>25</size>
			</field>
			<field id="fecha_movimiento" >
				<label modpos="nobr">Fecha</label>
				<valor>today</valor>
				<actualiza>
					<field id="fecha_vigencia" destino="regcuentarelacionada_id" />
					<field id="regcuenta_id" destino="fecha_movimiento" />
				</actualiza>
			</field>
			<field id="regcuenta_localidad" local="true" deshabilitado="true">
				<label colspan="2">Localidad</label>
				<size>25</size>
			</field>
			<field id="regcuenta_iva" local="true" deshabilitado="true">
				<label modpos="nobr">Iva</label>
			</field>
			<field id="regcuenta_provincia" local="true" deshabilitado="true">
				<label colspan="2">Provincia</label>
			</field>
			<field id="regcuenta_cuit" local="true" deshabilitado="true">
				<label modpos="nobr" colspan="5">CUIT</label>
			</field>
			<field id="regcuenta_ivaid" local="true" noshow="true">
				<label>id_Iva</label>
			</field>
			<field id="subsistemavendedor_id" local="true" valauto="true" noshow="true"/>
			<field id="subSistematransporte_id" local="true"  valauto="true" noshow="true" />
