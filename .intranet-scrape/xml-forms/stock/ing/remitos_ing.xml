			<field id="factura_regmovim" local="true" noshow="true" />
		<!--
			<field id="regcuentatransporte_id" >
				<label colspan="4" modpos="nobr">Transporte</label>
				<helper type="combo" xml="regcuenta_simple_qry.xml" dir="/ayudas" empty="true">
					<field id="id_regcuenta" />
