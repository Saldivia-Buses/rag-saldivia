			<field id="wstklista_id"  local="true"  _deshabilitado="true">
				<label  modpos="nobr">Lista de Precios </label>
				<help>Lista de Precios</help>
				<helper type="combo"  xml="stklista_qry.xml" dir="/ayudas" empty="true"/>
				<actualiza>
					<field id="codigo_detalle" destino="wstklista_id" xml="insu_rem_articulo_grid.xml"/>
				</actualiza>
			</field>      

			<field id="regforma_id" _sincelda="true">
				<label _modpos="nobr">Condicion de Venta</label>
				<helper type="combo" xml="regforma_qry.xml" dir="/ayudas" _empty="true" />
			</field>		
			<field id="Controlstk" local="true">
				<label  colspan="1" >Controla Stock</label>
				<helper type="combo" >
				    <option value="0">Si</option>
				    <option value="1">No</option>
				</helper>
				<actualiza>
				    <field id="facturas" destino="wcontrolstk"  />  	//ENVIA AL COMBO DE PEDIDOS PARA TRAER LOS PEDIDOS CON O SIN STOCK
				    <field id="codigo_detalle" destino="wcontrolstk" xml="insu_rem_articulo_grid.xml" />  //Envia a Articulo filtrar el F2
