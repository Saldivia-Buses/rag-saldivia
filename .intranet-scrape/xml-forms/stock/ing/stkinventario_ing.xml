<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="grid" subtipo="vertical" deleteRow="false" tooltip="false" log="false" preloadData="false" inserta="false" 
	procesa="true" paginar="50">

  <title>Ingreso de Inventario</title>
  <obs/>
  <form>
    <table id="STK_ARTICULOS" label="Ingreso de Inventario" idCampoCond="grabar">

      <movimientos>
        <relacion id="stkinventario_ins.xml"/>
        <!-- <relacion id="stkinventario_close.xml"/> -->
        <relacion id="act_numerador_inginv.xml"/>
      </movimientos>

      <filters>
            
            <field id="stkconcepto_id" >
                <label>Concepto</label>
            </field>
            
            <field id="separador" modpos="nobr" deshabilitado="true" editable="false" />

            <field id="stkdeposito_id" modpos="nobr" >
                <label>Deposito</label>
            </field>
            
            <field id="separador" modpos="nobr" deshabilitado="true" editable="false" />

            <field id="stkrubro_id" modpos="nobr">
                <label>Rubro</label>
            </field>

		<field id="id_stkarticulo"   >
		    <label>Cod. Articulo</label>
		    <operador>=</operador>
		</field>

            <field id="separador" modpos="nobr" deshabilitado="true" editable="false" />
            
            <field id="fecha_movimiento" modpos="nobr">
                <label>Fecha</label>
                <valor>today</valor>
            </field>

    </filters>


	<fieldGroup style="text-align:center;vertical-align:middle; padding:2px 2px 2px 2px;">

		<field id="id_stkarticulo"  noshow="true" />

		<field id="codigo_barra">
		    <label>Cod. Articulo</label>
		    <expression>id_stkarticulo</expression>
		</field>

		<field id="nombre_articulo">
		    <label>Descripcion</label>
		</field>

		<field id="stkconcepto_id" local="true" >
			<label>Concepto</label>
			<helper type="combo" xml="stkconcepto_qry.xml" dir="/ayudas">
				<field id="tipo_concepto">
					<condicion operador="=">0</condicion>
				</field>
				<field id="omite_concepto">
					<expression>id_stkconcepto</expression>
					<condicion operador="=">id_stkconcepto and id_stkconcepto NOT IN (select option_value from HTXOPTIONS where option_name = 'FIELD::stkconcepto_omitirhelper')</condicion>
				</field>
			</helper>
		</field>

		<field id="stock" local="true" suma="true">
			<label>stock</label>
			<expression>SELECT SUM(CASE WHEN STK_CONCEPTOS.tipo_concepto = 0 THEN cantidad ELSE -(cantidad) END) 
		            FROM STK_MOVIMIENTOS 
		           INNER JOIN STK_CONCEPTOS ON STK_CONCEPTOS.id_stkconcepto = STK_MOVIMIENTOS.stkconcepto_id 
		           WHERE STK_MOVIMIENTOS.stkarticulo_id = STK_ARTICULOS.id_stkarticulo
		             and STK_MOVIMIENTOS.stkdeposito_id = '[__stkdeposito_id__]'
			</expression>
		</field>

		<field id="cantidadstk" local="true" editable="true" suma="true">
			<label>Stock Real</label>
		</field>

	</fieldGroup>


	<fieldGroup noshow="true">

        <field id="base" local="true">
		    	<valor eval="true">$_SESSION['db']</valor>
		</field>


		<field id="fecha_movimiento" local="true">
	        <label>fecha</label>
	        <tipo>date</tipo>
		</field>

        <field id="user_id" local="true" >
            <helper type="combo" xml="usuarios_qry.xml" dir="/ayudas"  />
            <label>Usuario</label>
            <valor eval="true">$_SESSION['idUser']</valor>
        </field>

		<field id="alta_movimiento" local="true">
	        <label>fecha</label>
	        <tipo>date</tipo>
	        <valor>today</valor>
		</field>

		<field id="separador" local="true" deshabilitado="true" >
			<size>1</size>
		</field>

		<field id="_ORDEN" local="true" >
	        <label>#</label>
		</field>

		<field id="referencia" local="true">
        	<label>referencia</label>
	        <tipo>varchar</tipo>
	        <valor>'INGRESO DE STOCK INICIAL'</valor>
        </field>

        <!-- <field id="stkarticulo_id">
			<expression>STK_ARTICULOS.id_stkarticulo</expression>
		</field> -->

		<field id="stkrubro_id" >
			<label>rubro</label>
			<helper type="combo" xml="stkrubro_qry.xml" dir="/ayudas" empty="true" />
		</field>

		<field id="stkfamilia_id" 	/>
		<field id="stksector_id" 	/>
		<field id="unidad_id"  		/>
		<field id="precio_costo"	/>
		<field id="precio_lista" 	/>
		<field id="precio_venta"	/>
		<field id="precio_promedio" />

		<field id="stkdeposito_id" local="true" >
			<label>stkdeposito</label>
			<helper type="combo" xml="stkdeposito_qry.xml" dir="/ayudas" />
		</field>



		<field id="baja_articulo">
			<condicion operador="!=">1</condicion>
		</field>

		<field id="grabar" local="true" >
			<if exp="(cantidadstk + 0) != 0">
				<true>'true'</true>
				<false>'false'</false>
			</if>
		</field>

		<field id="imprimereport" local="true" >
			<if exp="true">
				<true>(_ORDEN == 0)? 1 : 0</true>
				<false>0</false>
			</if>
		</field>

	</fieldGroup>

	<fieldGroup noshow="true">

		<field id="stktransaccion_id" local="true">
            <label>TRANSACCION</label>
            <valor eval="true">date('U')</valor>
        </field>   

        <field id="regcuenta_id" local="true">
		  <label>regcuenta</label>
		  <tipo>integer</tipo>
		  <valor>999999</valor>
		</field>  

		<!-- ESTOS CAMPOS SON PARA ACTUALIZAR EL NUMERADOR PORQUE NO ME DEJA GRABAR EL NUEVO NUMERO DESDE LA BD -->

		<field id="stknumconc" local="true" >
			<valor>99</valor>
		</field>

		<field id="subsistema_id" local="true">
              <label>subsistema_id</label>
              <valor>40</valor>
        </field>  

		<field id="numero_movimiento"  deshabilitado="true" local="true">
				<label>Numero</label>
				<expression sql="true">(SELECT numero FROM STK_NUMERADORES where stkconcepto_id = '99' and subsistema_id= [__subsistema_id__] and puesto = [__stkdeposito_id__])</expression>
		</field>

		<field id="numero_upd"  deshabilitado="true" local="true">
				<label>Numero</label>
				<expression sql="true">(SELECT numero + 1 FROM STK_NUMERADORES where stkconcepto_id = '99' and subsistema_id= [__subsistema_id__] and puesto = [__stkdeposito_id__])  </expression>
		</field>

	</fieldGroup>


		<order>
			<field id="nombre_articulo" />
		</order>

    </table>


  </form>
</histrix>