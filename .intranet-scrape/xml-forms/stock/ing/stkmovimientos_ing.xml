<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="ing" llenoTemporal="false"  subtipo="vertical" imprime="false" xmlImpresion="/stock/qry/imp_inventario_qry.xml">
  <title>Ingreso Movimientos Stock</title>
  <obs/>
  <form>
    <table id="STK_MOVIMIENTOS" label="Ingreso de movimientos">

    <movimientos cabecera="stkmovimientos_cab.xml">
	     <relacion id="stkmovimiento_ins.xml" /> 
        <!--        <relacion id="stkmovimiento_close.xml"/> -->
    </movimientos>
     
      <field id="id_stkmovimiento" deshabilitado="true" noshow="true" autoInc="true">
          <label>Codigo</label>
          <help>Codigo de movimiento</help>
      </field>

      <field id="_ORDEN" local="true" _noshow="true">
          <label Formstyle="display:none;">#</label>
      </field>

      <field id="stkarticulo_id" _tabla="STK_ARTICULOS" style="text-align:center;">
          <label>Codigo de Articulo</label>
          <helper type="external" xml="stkarticulo_qry.xml" dir="/ayudas">
            <!-- <field id="wstklista_id" local="true">
              <valor>1</valor>
            </field> -->
            <field id="baja_articulo" noshow="true">
                <condicion operador="!=">1</condicion>
            </field>
          </helper>
          <size>15</size>
      </field>              

      <field id="separador1" local="true" deshabilitado="true" modpos="nobr" colstyle="display:none;">
          <size>1</size>
      </field>

      <field id="nombre_articulo" local="true" deshabilitado="true"  modpos="nobr" _colspan="5">
          <label></label>
          <size>60</size>
      </field>    
      

      <field id="separador2" local="true" deshabilitado="true" modpos="nobr" colstyle="display:none;">
          <size>1</size>
      </field>


      <field id="cantidad" modpos="nobr" >
          <label>Cantidad</label>
          <tipo>decimal</tipo>
      </field>

      <field id="separador3" local="true" deshabilitado="true" modpos="nobr" colstyle="display:none;">
          <size>1</size>
      </field>

      <field id="stock" modpos="nobr" style="font-weight:bold;">
                <label >Stock</label>
                <expresion>SELECT sum( STK_MOVIMIENTOS.cantidad * (CASE WHEN STK_CONCEPTOS.tipo_concepto = 1 THEN -1 ELSE 1 END ))
                             FROM STK_MOVIMIENTOS 
                        LEFT JOIN STK_CONCEPTOS ON STK_CONCEPTOS.id_stkconcepto = STK_MOVIMIENTOS.stkconcepto_id
                            WHERE STK_MOVIMIENTOS.stkarticulo_id = STK_ARTICULOS.id_stkarticulo
                </expresion>
                <tipo>numeric</tipo>
      </field>

      <field id="separador4" local="true" deshabilitado="true" modpos="nobr" colstyle="display:none;">
          <size>1</size>
      </field>


      <field id="stkunidad_id" local="true" deshabilitado="true" >
          <label modpos="nobr">Unidad</label>
          <size>60</size>
          <helper type="combo" xml="unidad_qry.xml" dir="/ayudas" empty="true"/>
          <actualiza>
              <field id="unidad_id" />
          </actualiza>
      </field>

      <field id="unidad_id" noshow="true" />



<!--
      <field id="fecha_movimiento">
