      <field id="numero_movimiento" sincelda="true">
        <label modpos="nobr">-</label>
      </field>
        
         
        

      <field id="regcuenta_id" _noshow="true">
        <label>Cuenta</label>
        <helper type="external" xml="regcuenta_solamente_qry.xml" dir="/ayudas" empty="true">
            <field id="subsistema_id" noshow="true">
                <condicion operador="=">'01'</condicion>
            </field>
        </helper>
        <detalle>regcuenta_id</detalle>
      </field>

      <field id="nombre" local="true" deshabilitado="true" sincelda="true">
        <label modpos="nobr" />
        <size>35</size>
      </field>

      <field id="stkdeposito_id">
        <label>Deposito</label>
        <helper type="combo" xml="stkdeposito_qry.xml" dir="/ayudas" />
      </field>
      <field id="stksector_id" noshow="true" />
      <field id="stkfamilia_id" noshow="true" />
      <field id="stkrubro_id" noshow="true" />


      <field id="cantidad_compra" local="true">
        <label>Cantidad</label>
        <jseval campodestino="cantidad">cantidad_compra * stkvalor_uso</jseval>
      </field>

      <field id="stkunidad_compra_id" local="true" deshabilitado="true" sincelda="true">
        <label modpos="nobr"/>
        <helper type="combo" xml="unidad_qry.xml" dir="/ayudas" empty="true" />
      </field>
        
       <field id="stkvalor_compra" local="true" noshow="true"> </field>

       <field id="stkvalor_uso" local="true" noshow="true"> </field>

    -->

