<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="ing" preloadData="false" procesa="false" llenoreferente="true" llenotemporal="true" tooltip="false" showCantidad="false" updateTotals="true" subtipo="vertical">
  <title>Detalle</title>
  <obs/>
  <consulta>
    <table id="REG_DETALLES" label="movimientos">
	<movimientos>
		<relacion id="insu_regdetalles_ins.xml"/>
		<relacion id="insu_stkmovimientos_ins.xml"/> 
		<relacion id="regimputaciondetallesrem_ins.xml"/>  
	</movimientos>
	<fieldGroup>
		<field id="codigo_detalle" deshabilitado="false">
			<label>Cod.</label>
			<helper type="external" xml="stkarticulo_mos.xml" dir="/ayudas">
			      <field id="regcuenta_id"   local="true" noshow="true"/> 
			      <field id="wstklista_id" 	 local="true" noshow="true" />
				<field id="wcontrolstk"  local="true" noshow="true">
					<valor>1</valor>
					<detalle>wcontrolstk</detalle>
				</field>
			</helper>
			<size>15</size>
		</field>
		<field id="descripcion_detalle" deshabilitado="true">
			<label modpos="nobr">Descripción</label>
			<size>35</size>
		</field>
		<field id="cantidad_detalle">
			<label modpos="nobr">cantidad</label>
			<tipo>numeric</tipo>
			<valor dafault="true">1.00</valor>

			<jseval fielddestino="neto_detalle" _actxml="false" suma="true">subtotal1 * cantidad_detalle</jseval>	
		</field>
	</fieldGroup>

