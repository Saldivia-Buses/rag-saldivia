		<field id="id_facregdetalle" local="true" esClave="true" noshow="true">
			<label>id</label>
		</field>

		<field id="COMPROBANTES" deshabilitado="true" >
			<label colstyle="text-align:center;">Comprobantes</label>
			<tipo>varchar</tipo>
		</field>
	</fieldGroup>
      <!-- CONTABLE -->
	<fieldGroup>
	<field id="Stkconcepto_id" local="true" deshabilitado="true" noshow="true" >
		<helper type="combo" xml="stkconcepto_qry.xml" dir="/ayudas">
			<field id="id_stkconcepto">
			<condicion operador="=">(SELECT option_value FROM HTXOPTIONS where option_name = 'ID_STKREMITOS')
			</condicion>
			</field>
		</helper>
		<label>tt</label>
	</field>
	
	<field id="id_regdetalle" noshow="true" esClave="true"/>
		<field id="orden" deshabilitado="true" oculto="true">
			<label>Orden</label>
			<size>35</size>
		</field>
			<field id="cuenta_id" local="true" noshow="true">
			<label modpos="nobr">haber</label>
		</field>
		<field id="doh" local="true" noshow="true">
			<if exp="'debe' != 1">
				<true>'1'</true>
				<false>'0'</false>
			</if>
		</field>
	</fieldGroup>

        <importar xml="beve_pedidos_qry.xml" label="Importar" title="Seleccione" >
		<field id="fecha_movimiento">fecha_movimiento</field>
<!--		<field id="regcuenta_id">regcuenta_id</field> -->
		<field id="regcuenta_id_fac">regcuenta_id_fac</field>
		<field id="id_stklista">id_stklista</field>
		<field id="subsistemav_id" >subsistemav_id</field>
		<field id="pedido_regmovim">pedido_regmovim</field>
		<field id="imp_wcontrolstk">imp_wcontrolstk</field>

		 
	</importar>
    
    </table>
  </consulta>
</histrix>
