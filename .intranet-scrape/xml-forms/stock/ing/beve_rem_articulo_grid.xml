			<label >Alicuota</label>
			<valor default="true">0.00</valor>
			<tipo>decimal</tipo>
			<helper type="combo" xml="genalicuotas_qry.xml" dir="/ayudas" _empty="true"/>
			<jseval fielddestino="iva_detalle"> ( (neto_detalle + 0)  * (alicuota_iva + 0) / 100 )</jseval>
		</field>
