<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" preloadData="false" width="40%">
  <title>Cta Ctes</title>
  <obs/>
  <form detalle="remito_anul.xml">
    <table id="REG_MOVIMIENTOS" label="Cta Cte Proveedores">
      <filters>
        <field id="fecha_movimiento">
          <label>Desde</label>
          <operador>&gt;=</operador>
          <valor>today</valor>
        </field>
        <field id="fecha_movimiento">
          <label>Hasta</label>
          <operador>&lt;=</operador>
          <valor>today</valor>
        </field>
        <field id="nro_cuenta" colstyle="display: none;">
          <label>Cuenta</label>
          <operador>=</operador>
        </field>
        <field id="nombre" deshabilitado="true">
          <label modpos="nobr"/>
          <size>70</size>
        </field>
        <field id="nro_movimiento">
          <label>Nro. Movimiento</label>
          <operador>=</operador>
        </field>
        <!--
        <field id="tipo" deshabilitado="false">
          <operador>=</operador>
          <label>Tipo</label>
          <valor>2</valor>
        </field>
-->
      </filters>
      <!-- CONSULTA -->
      <field id="id_regmovim" _noshow="true" esClave="true">
        <detalle>id_regmovim</detalle>
      </field>
      <field id="concepto_id">
        <helper type="combo" xml="regconcepto_qry.xml" dir="/ayudas" empty="true"/>
        <label>Concepto</label>
        <condicion operador="=">47</condicion>
      </field>
      <field id="movimiento">
        <expression>CONCAT(REG_MOVIMIENTOS.letra_movimiento,' ',LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,'0'),'-',LPAD(REG_MOVIMIENTOS.nro_movimiento  ,8,'0'))
	  </expression>
        <label>Nro.Mov.</label>
      </field>
      <field id="nro_movimiento" colstyle="display:none;"/>
      <field id="nro_cuenta" noshow="true" tabla="REG_CUENTA">
        <helper type="external" xml="regcuenta_solamente_nro_qry.xml" dir="/ayudas" empty="true"/>
      </field>
      <field id="regcuenta_id" noshow="true">
      </field>
      <field id="nombre" local="true" noshow="true"/>
      <field id="referencia_movimiento">
        <label>Referencia</label>
      </field>
      <field id="fecha_movimiento">
        <label>Fecha</label>
        <tipo>date</tipo>
      </field>
      <field id="subsistema_id" oculto="true">
        <detalle>subsistema_id</detalle>
      </field>
      <field id="importe_movimiento" suma="true">
        <label>Importe</label>
        <tipo>numeric</tipo>
      </field>
      <field id="saldo_movimiento" suma="true">
        <label>Pendiente</label>
        <tipo>numeric</tipo>
      </field>
      <order>
      </order>
    </table>
    <join>
      <table id="REG_CUENTA">
        <field id="id_regcuenta">
          <condicion operador="=">regcuenta_id</condicion>
        </field>
      </table>
    </join>
  </form>
</histrix>
