<?xml version="1.0" encoding="UTF-8" ?>
<!-- 
*******************************************************************************
Tipo:  CRUD
Tarea: Detalle de Listas de Precios de Productos
Autor: d!ego2k
Fecha: 21/12/2011
*******************************************************************************
-->
<histrix tipo="abm-mini" subtipo="vertical" paginar="100" tooltip="false">
    <title>Detalle de Listas de Precios de Productos</title>
    <obs/>
    <form>
        <table id="STK_LISTADETALLE" label="Listas de Precios">

            <filters>
                <field id="nombre_articulo" deshabilitado="false">
                    <label>Nombre Articulo</label>
                    <operador>like</operador>
                </field>                                
                
                <field id="stkarticulo_id" grupo="Avanzado">
                    <label>Codigo</label>
                    <operador>like</operador>
                </field>

                <field id="stkrubro_id" tabla="STK_ARTICULOS" grupo="Avanzado">
                    <label>Rubro</label>
                    <operador>=</operador>
                </field>
                <field id="stkfamilia_id" tabla="STK_ARTICULOS" grupo="Avanzado">
                    <label>Familia</label>
                    <operador>=</operador>
                </field>
                <field id="stkmarca_id" tabla="STK_ARTICULOS" grupo="Avanzado">
                    <label>Marca</label>
                    <operador>=</operador>
                </field>

            </filters>
			<field id="baja_articulo" oculto="true" tabla="STK_ARTICULOS">
				<condicion operador="!=">1</condicion>
			</field>
        
            <field id="id_stklistadetalle" autoinc="true" esClave="true" noshow="true" />

            <field id="stkarticulo_id" _esClave="true">
                <label>Articulo</label>
                <helper type="external" xml="stkarticulo_qry.xml" dir="/ayudas">
                    <field id="id_stkarticulo"/>
                    <order>
                        <field id="nombre_articulo"/>
                    </order>
                </helper>
            </field>

            <field id="nombre_articulo" deshabilitado="true">
                <label>Desc</label>
                <expression having="false">nombre_articulo</expression>   
                <size>70</size>
            </field>

            <field id="stklista_id" oculto="true">
                <label>Codigo Lista</label>
                <operador>=</operador>
            </field>

            <field id="stkrubro_id" oculto="true" tabla="STK_ARTICULOS">
                <label>Rubro</label>
                <helper type="combo" xml="stkrubro_qry.xml" dir="/ayudas" empty="true"/>
            </field>
            
            <field id="stkfamilia_id" oculto="true" tabla="STK_ARTICULOS">
                <label>Familia</label>
                <helper type="combo" xml="stkfamilia_qry.xml" dir="/ayudas" empty="true"/>
            </field>

            <field id="stkmarca_id" oculto="true" tabla="STK_ARTICULOS">
                <label>Marca</label>
                <helper type="combo" xml="stkmarca_qry.xml" dir="/ayudas" empty="true"/>
            </field>
            
            <field id="stklistadetalle_costo" deshabilitado="true">
                <label>Precio Costo</label>
                <help>Precio Costo</help>     
                <tipo>numeric</tipo>
                <expression>STK_ARTICULOS.precio_costo</expression>
            </field>
            
            <field id="stklistadetalle_precioventa">
                <label >Precio Venta</label>
                <help>Precio de Venta</help>
                <tipo>decimal</tipo>
            </field>

            <field id="dto_porcentaje">
                <label >Descuento (%)</label>
                <tipo>decimal</tipo>
            </field>


            <field id="dto_fechadesde" >
                <label>Fecha desde Desc</label>
                <tipo>date</tipo>
                <valor>today</valor>
            </field>

            <field id="dto_fechahasta" modpos="nobr">
                <label colspan="2">Fecha hasta Desc</label>
                <tipo>date</tipo>
            </field>



            <order>
                <field id="nombre_articulo" tabla="STK_ARTICULOS" />
            </order>

        </table>
        
        <join>
            <table id="STK_LISTAS">
                <field id="id_stklista">
                    <condicion operador="=">STK_LISTADETALLE.stklista_id</condicion>
                </field>
            </table>
        </join>
        <join>
            <table id="STK_ARTICULOS">
                <field id="id_stkarticulo">
                    <condicion operador="=">STK_LISTADETALLE.stkarticulo_id</condicion>
                </field>
            </table>
        </join>
		
	
    </form>

</histrix>

