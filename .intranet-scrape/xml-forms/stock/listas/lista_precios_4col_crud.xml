<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="grid" borra="false" inserta="false" deleteRow="false" procesa="true" log="false" preloadData="false" editable="true" path="fotos/articulos">
	<title>Lista de precios general</title>
	<obs></obs>
	<form>
		<table id="STK_ARTICULOS" styleTbody="height:500px;overflow-x:hidden;">
			<title>Lista de precios general</title>

			<movimientos>
			    <!-- <relacion id="lista_precios_replace_0.xml"/> -->
			    <relacion id="lista_precios_replace_1.xml"/>
			    <relacion id="lista_precios_replace_2.xml"/>
			    <relacion id="lista_precios_replace_3.xml"/>
			    <relacion id="lista_precios_replace_4.xml"/>
			</movimientos>
			
			
			<filters>
				<field id="stkrubro_id">
					<label modpos="nobr">Rubro</label>
				</field>
				<field id="prov" deshabilitado="false">
					<label modpos="nobr">Proveedor</label>
				</field>

				<field id="id_stkarticulo">
					<label>Cod.</label>
				</field>

				<field id="nombre_articulo" fullSearch="true">
					<label modpos="nobr">Articulo</label>
					<help>Descripcion de Articulo</help>
					<operador>like</operador>
				</field>
			</filters>

			<fieldGroup>

			<field id="id_stkarticulo" PDFcolor="000000" esClave="true"
				style="font-weight:bold;">
				<ayuda_ex id="STK_ARTICULOS">
					<field id="id_stkarticulo">
						<label>Cod</label>
					</field>
					<field id="nombre_articulo">
						<label>Nombre</label>
						<detalle>nombre_articulo</detalle>
					</field>
					<field id="subsistema_id" oculto="true">
						<condicion operador="=">'01'</condicion>
					</field>
				</ayuda_ex>
				<label>Cod.</label>
				<detalle>id_stkarticulo</detalle>
			</field>


			<field id="stkrubro_id" noshow="true">
				<label modpos="nobr">Rubro</label>
				<helper type="combo" xml="stkrubro_qry.xml" dir="/ayudas"
					empty="true" />
			</field>

			<field id="nombre_articulo" _autocompletar="false" fullSearch="true">
				<label>Articulo</label>
				<help>Descripcion de Articulo.</help>
			</field>

			<field id="baja_articulo" oculto="true">
				<condicion operador="!=">1</condicion>
			</field>

            <field id="prov" noshow="true">
                <label>prov</label>
                <expression>(select P.regcuenta_id from STK_ARTICULO_PROVEEDOR P where P.stkarticulo_id = STK_ARTICULOS.id_stkarticulo limit 1)</expression>
                <tabla_ex id="REG_CUENTA" vacio="true">
                    <field id="id_regcuenta" />
                    <field id="nombre_cuenta" />
                    <field id="subsistema_id" oculto="true">
                        <condicion operador="=">'01'</condicion>
                    </field>
                </tabla_ex>
                <tipo>varchar</tipo>
            </field>

            </fieldGroup>

                 <fieldGroup noshow="true">

                        <field id="_ORDEN" local="true" />
                        
                        <field id="color" local="true" clasefila="true">
                           <if exp="( _ORDEN % 2) == 0">
                             <true>''</true>
                             <false>'resaltadoVioleta'</false>
                           </if>
                        </field>
                       <field id="precio_ant1" >
                        	<expression>max(case when stklista_id = 1 then stklistadetalle_precioventa end)</expression>
                        </field>
                        <field id="precio_ant2" >
                        	<expression>max(case when stklista_id = 2 then stklistadetalle_precioventa end)</expression>
                        </field>
                        <field id="precio_ant3" >
                        	<expression>max(case when stklista_id = 3 then stklistadetalle_precioventa end)</expression>
                        </field>
                        <field id="precio_ant4" >
                        	<expression>max(case when stklista_id = 4 then stklistadetalle_precioventa end)</expression>
                        </field>
                </fieldGroup>

                <fieldGroup>
                        <field id="mon">
                    	    <label>Moneda</label>
                    	    <expression>abreviatura_moneda</expression>
                        </field>

                        <field id="precio_Costo_new" _editable="true" _deshabilitado="false">
                            <expression>STK_ARTICULOS.precio_costo</expression>
                            <label>Precio Costo</label>
                            <tipo>numeric</tipo>
                        </field>
                        
                        
                        <field id="precio1" noZero="true" editable="true" deshabilitado="false">
                        	<expression>max(case when stklista_id = 1 then stklistadetalle_precioventa end)</expression>
                    	    <label>Lista 1</label>     
                    	    <tipo>numeric</tipo>
                        </field>
                        <field id="precio2" noZero="true" editable="true" deshabilitado="false">
                        	<expression>max(case when stklista_id = 2 then stklistadetalle_precioventa end)</expression>   
                    	    <label>Lista 2</label>     
                    	    <tipo>numeric</tipo>
                        </field>
                        <field id="precio3" noZero="true" editable="true" deshabilitado="false">
                        	<expression>max(case when stklista_id = 3 then stklistadetalle_precioventa end)</expression>
                    	    <label>Lista 3</label>     
                    	    <tipo>numeric</tipo>
                        </field>
                        <field id="precio4" noZero="true" editable="true" deshabilitado="false">
                        	<expression>max(case when stklista_id = 4 then stklistadetalle_precioventa end)</expression>
                    	    <label>Lista 4</label>     
                    	    <tipo>numeric</tipo>
                        </field>
                        <field id="newcost" local="true" noshow="true">
                            <if exp="(precio_Costo_new + 0) != (precio_costo + 0)">
                              <true>'true'</true>
                              <false>'false'</false>
                            </if>
                        </field>                       
                        <field id="newprice1" local="true" noshow="true">
      						<if exp="(precio1 + 0) != (precio_ant1  + 0)">
	                    		<true>'true'</true>
	                    		<false>'false'</false>
                    	    </if>
                    	</field>
                        <field id="newprice2" local="true" noshow="true">
      						<if exp="(precio2 + 0 ) != (precio_ant2 + 0)">
	                    		<true>'true'</true>
	                    		<false>'false'</false>
                    	    </if>
                    	</field>                        
                    	<field id="newprice3" local="true" noshow="true">
      						<if exp="(precio3 + 0) != (precio_ant3  + 0)">
	                    		<true>'true'</true>
	                    		<false>'false'</false>
                    	    </if>
                    	</field>
                    	<field id="newprice4" local="true" noshow="true">
      						<if exp="(precio4 + 0) != (precio_ant4  + 0)">
	                    		<true>'true'</true>
	                    		<false>'false'</false>
                    	    </if>
                    	</field> <!--
                        <field id="newprice" local="true" noshow="true">
      						<if exp="(precio1 + 0) != (precio_ant1  + 0) || (precio2  + 0 ) != (precio_ant2 + 0) || (precio3 + 0) != (precio_ant3  + 0) || (precio4 + 0) != ( precio_ant4 + 0 )">
	                    		<true>'true'</true>
	                    		<false>'false'</false>
                    	    </if>
                    	</field>-->

                </fieldGroup>                            
			<group>
				<field id="id_stkarticulo" />
			</group>

			<order>
				<field id="nombre_articulo" />
			</order>

		</table>
		<join tipo="left">
			<table id="GEN_MONEDAS">
				<field id="id_moneda">
					<condicion operador="=">genmoneda_venta_id</condicion>
				</field>
			</table>

		</join>

		<join tipo="left">
			<table id="STK_LISTADETALLE">
				<field id="stkarticulo_id">
					<condicion operador="=">STK_ARTICULOS.id_stkarticulo</condicion>
				</field>
			</table>

		</join>
	</form>
</histrix>
