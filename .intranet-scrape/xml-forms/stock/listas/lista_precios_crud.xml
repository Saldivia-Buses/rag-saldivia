<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="grid" borra="false" inserta="false" deleteRow="false" procesa="true" log="false" preloadData="false" editable="true" path="fotos/articulos" >
	<title>Lista de precios general</title>
	<obs></obs>
	<form>
		<table id="STK_ARTICULOS" styleTbody="height:500px;overflow-x:hidden;">
			<title>Lista de precios general</title>

			<movimientos>
			    <!-- <relacion id="lista_precios_replace_0.xml"/> -->
			    <relacion id="lista_precios_replace_1.xml"/>
			    <relacion id="lista_precios_replace_2.xml"/>
			    <relacion id="lista_precios_replace_3.xml"/>
			    <!--
			    <relacion id="lista_precios_replace_4.xml"/>
			    -->
			</movimientos>


			<filters>
				<field id="stkrubro_id">
					<label modpos="nobr">Rubro</label>
				</field>
				
			<field id="separador" deshabilitado="true" noshow="true" local="true" modpos="nobr"/>

				<field id="stkmarca_id">
					<label modpos="nobr">Marca</label>
				</field>

			<field id="separador" deshabilitado="true" noshow="true" local="true" modpos="nobr"/>

				<field id="stkfamilia_id">
					<label modpos="nobr">Familia</label>
				</field>

			<field id="separador" deshabilitado="true" noshow="true" local="true" modpos="nobr"/>

				<field id="prov" deshabilitado="false">
					<label modpos="nobr">Proveedor</label>
				</field>

				<field id="id_stkarticulo">
					<label>Cod.</label>
					<operador>like</operador>
				</field>

			<field id="separador" deshabilitado="true" noshow="true" local="true" modpos="nobr"/>
				
				<field id="nombre_articulo" colspan="5">
					<label modpos="nobr">Articulo</label>
					<help>Descripcion de Articulo</help>
					<operador>like</operador>
				</field>				

			<field id="separador" deshabilitado="true" noshow="true" local="true" modpos="nobr"/>

				<field id="con_stock" deshabilitado="false" modpos="nobr">
                	<label>Solo con stock</label>
            	</field>

			</filters>

			<field id="separador" deshabilitado="true" noshow="true" local="true">
				<size>1</size>
			</field>

			<fieldGroup colstyle="text-align:center;">

			<field id="id_stkarticulo" PDFcolor="000000" esClave="true"	style="font-weight:bold;">
				<helper type="external" xml="stkarticulo_qry.xml" dir="/ayudas">
					<field id="id_stkarticulo">
						<label>Cod</label>
					</field>
					<field id="nombre_articulo">
						<label>Nombre</label>
						<detalle>nombre_articulo</detalle>
					</field>
				</helper>
				<label>Cod.</label>
				<detalle>id_stkarticulo</detalle>
			</field>


			<field id="stkrubro_id" noshow="true" multiple="true">
				<label modpos="nobr">Rubro</label>
				<helper type="combo" xml="stkrubro_qry.xml" dir="/ayudas" empty="true" />
			</field>

            <field id="stkfamilia_id" noshow="true" multiple="true" >
                <label modpos="nobr">Familia</label>
                <helper type="combo" xml="stkfamilia_qry.xml" dir="/ayudas" empty="true"/>
            </field>

			<field id="stkmarca_id" _noshow="true" tabla="STK_ARTICULOS"  multiple="true">
				<label>Marca</label>
				<helper type="combo" xml="stkmarca_qry.xml" dir="/ayudas" empty="true" />
			</field>

			<field id="nombre_articulo" _autocompletar="false" fullSearch="true">
				<label>Articulo</label>
				<help>Descripcion de Articulo</help>
				<size>99</size>
			</field>

			<field id="baja_articulo" oculto="true">
				<condicion operador="!=">1</condicion>
			</field>

            <field id="prov" noshow="true" multiple="true">
                <label>prov</label>
                <expresion>(select P.regcuenta_id from STK_ARTICULO_PROVEEDOR P where P.stkarticulo_id = STK_ARTICULOS.id_stkarticulo limit 1)</expresion>
                <tabla_ex id="REG_CUENTA" vacio="true">
                    <field id="id_regcuenta" />
                    <field id="nombre_cuenta" />
                    <field id="subsistema_id" oculto="true">
                        <condicion operador="=">'01'</condicion>
                    </field>
                    <order>
                    <field id="nombre_cuenta" />
                    </order>
                </tabla_ex>
                <tipo>varchar</tipo>
            </field>
          
          	<field id="totalstk" noZero="true">
                <label>Stock Actual</label>
                <expresion having="false">select sum(case when tipo_concepto = 0 then 1 else -1 end * ifnull(STK_MOVIMIENTOS.cantidad,0) ) from STK_MOVIMIENTOS  LEFT JOIN    STK_CONCEPTOS ON (STK_CONCEPTOS.id_stkconcepto = STK_MOVIMIENTOS.stkconcepto_id) where stkarticulo_id = id_stkarticulo</expresion>
                <tipo>numeric</tipo>
	        </field>
	        
	        <field id="con_stock" noshow="true" local="true">
	          <tipo>check</tipo>
	        </field>

	        <field id="test_stock" noshow="true">
	            <expression>select (CASE WHEN '[__con_stock__]' = '0' THEN 1 ELSE ( CASE WHEN sum(case when tipo_concepto = 0 then 1 else -1 end * ifnull(STK_MOVIMIENTOS.cantidad,0) ) != 0 THEN 1 ELSE 0 END) END) from STK_MOVIMIENTOS  LEFT JOIN    STK_CONCEPTOS ON (STK_CONCEPTOS.id_stkconcepto = STK_MOVIMIENTOS.stkconcepto_id) where stkarticulo_id = id_stkarticulo</expression>
	            <condicion operador="=">1</condicion>
	        </field> 	
           
			
            </fieldGroup>

                 <fieldGroup noshow="true">

                        <field id="_ORDEN" local="true" />
                        
                        <field id="color" local="true" clasefila="true">
                           <if exp="( _ORDEN % 2) == 0">
                             <true>''</true>
                             <false>'resaltadoVioleta'</false>
                           </if>
                        </field>
                       <field id="precio_ant1" >
                        	<expresion>max(case when STK_LISTADETALLE.stklista_id = 1 then stklistadetalle_precioventa end)</expresion>
                        </field>
                        <field id="precio_ant2" >
                        	<expresion>max(case when STK_LISTADETALLE.stklista_id = 2 then stklistadetalle_precioventa end)</expresion>
                        </field>
                        <field id="precio_ant3" >
                        	<expresion>max(case when STK_LISTADETALLE.stklista_id = 3 then stklistadetalle_precioventa end)</expresion>
                        </field>
                        <!--
                        <field id="precio_ant4" >
                        	<expresion>max(case when stklista_id = 4 then stklistadetalle_precioventa end)</expresion>
                        </field>
                        -->
                </fieldGroup>

                <fieldGroup>
                        <field id="precio_Costo_new" _editable="true" _deshabilitado="false">
                            <expresion>STK_ARTICULOS.precio_costo</expresion>
                            <label>Precio Costo</label>
                            <tipo>numeric</tipo>
                        </field>
                        
                        
                        <field id="precio1" noZero="true" editable="true" deshabilitado="false">
                        	<expresion>max(case when STK_LISTADETALLE.stklista_id = 1 then stklistadetalle_precioventa end)</expresion>
                    	    <label>Lista 1</label>     
                    	    <tipo>numeric</tipo>
                        </field>
                        <field id="precio2" noZero="true" editable="true" deshabilitado="false">
                        	<expresion>max(case when STK_LISTADETALLE.stklista_id = 2 then stklistadetalle_precioventa end)</expresion>   
                    	    <label>Lista 2</label>     
                    	    <tipo>numeric</tipo>
                        </field>
                        <field id="precio3" noZero="true" editable="true" deshabilitado="false">
                        	<expresion>max(case when STK_LISTADETALLE.stklista_id = 3 then stklistadetalle_precioventa end)</expresion>
                    	    <label>Lista M</label>     
                    	    <tipo>numeric</tipo>
                        </field>
                        <!--
                        <field id="precio4" noZero="true" editable="true" deshabilitado="false">
                        	<expresion>max(case when stklista_id = 4 then stklistadetalle_precioventa end)</expresion>
                    	    <label>Lista 4</label>     
                    	    <tipo>numeric</tipo>
                        </field>
						-->
                        <field id="newcost" local="true" noshow="true">
                            <if exp="(precio_Costo_new + 0) != (precio_costo + 0)">
                              <true>'true'</true>
                              <false>'false'</false>
                            </if>
                        </field>
                        
                        <field id="newprice1" local="true" noshow="true">
      						<if exp="(precio1 + 0) != (precio_ant1  + 0)">
	                    		<true>'true'</true>
	                    		<false>'false'</false>
                    	    </if>
                    	</field>
                        <field id="newprice2" local="true" noshow="true">
      						<if exp="(precio2 + 0 ) != (precio_ant2 + 0)">
	                    		<true>'true'</true>
	                    		<false>'false'</false>
                    	    </if>
                    	</field>                        
                    	<field id="newprice3" local="true" noshow="true">
      						<if exp="(precio3 + 0) != (precio_ant3  + 0)">
	                    		<true>'true'</true>
	                    		<false>'false'</false>
                    	    </if>
                    	</field><!--
                    	<field id="newprice4" local="true" noshow="true">
      						<if exp="(precio4 + 0) != (precio_ant4  + 0)">
	                    		<true>'true'</true>
	                    		<false>'false'</false>
                    	    </if>
                    	</field>-->
                </fieldGroup>                            
			<group>
				<field id="id_stkarticulo" />
			</group>

			<order>
				<field id="nombre_articulo" />
			</order>

		</table>
		<join tipo="left">
			<table id="STK_LISTADETALLE">
				<field id="stkarticulo_id">
					<condicion operador="=">STK_ARTICULOS.id_stkarticulo</condicion>
				</field>
			</table>
		</join>		
<!--
		<join tipo="left">
		    <table id="STK_MOVIMIENTOS">
				<field id="stkarticulo_id">
					<condicion operador="=">STK_ARTICULOS.id_stkarticulo</condicion>
				</field>
		    </table>
		</join>
		
	    <join tipo="left">
	      <table id="STK_CONCEPTOS">
	        <field id="id_stkconcepto">
	          <condicion operador="=">STK_MOVIMIENTOS.stkconcepto_id</condicion>
	        </field>
	      </table>
	    </join>
	    -->
	</form>
</histrix>
