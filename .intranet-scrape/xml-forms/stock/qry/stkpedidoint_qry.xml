<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" borra="no" inserta="no" _paginar="250" _imprime="false" _preloadData="false">
  <title>Consulta Pedido Interno</title>
  <obs/>
  <form>
    <table id="STK_ARTICULOS" label="Consulta pedido interno">

      <field id="id_stkarticulo" noshow="true" />
      
       <field id="fecha_pedido" tabla="STK_ARTICULO_PEDIDOINT" _local="true" _noshow="true">
        <tipo>date</tipo>
        <valor>today</valor>
        <label>Fecha pedido</label>
       </field>
                                     
       <field id="stkdeposito_id" _noshow="true" tabla="STK_ARTICULO_PEDIDOINT" _local="true">
        <label>Deposito</label>
        <helper type="combo" xml="stkdeposito_qry.xml" dir="/ayudas" empty="true"/>
       </field>

       
      <field id="stkfamilia_id" noshow="true">
        <helper type="combo" xml="stkfamilia_qry.xml" dir="/ayudas" empty="true"/>
      </field>
      <field id="stkrubro_id">
        <label>Rubro</label>
        <helper type="combo" xml="stkrubro_qry.xml" dir="/ayudas" empty="true"/>
      </field>
      
       <field id="codigo_barra">
        <label>Codigo de Barra</label>
        <helper type="external" xml="stkarticulo_pos.xml" dir="/ayudas">
          <field id="wstklista_id" local="true">
            <valor>1</valor>
          </field>
        </helper>
      </field>

      <field id="nombre_articulo">
        <label>Articulo</label>
      </field>
      
      
       
       <field id="cantidad" tabla="STK_ARTICULO_PEDIDOINT"  noshow="true">
            
             <label>Pedido</label>
                                                                               <!--
             <expresion>case when STK_ARTICULO_PEDIDOINT.cantidad = 1 then 'Si' else 'No' end</expresion>
               -->
             <condicion operador="=">1</condicion>
            
       </field>
               
                              <!--
                       
      
      <field id="permiso" local="true" noshow="true">
        <valor eval="true">$_SESSION['administrator']</valor>
      </field>
                              -->
       

      <filters>
        <field id="fecha_pedido" deshabilitado="false">
    	    <label>Fecha</label>
    	    <operador>=</operador>
            <valor>today</valor>
            <tipo>date</tipo>
        </field>
        
        <field id="stkdeposito_id" deshabilitado="false">
          <label>Deposito</label>
          <operador>=</operador>
        </field>
        
        <field id="stkrubro_id">
           <operador>=</operador>
           <label>Rubro</label>
       </field>
       
       <field id="codigo_barra">
           <operador>=</operador>
           <label modpos="nobr">Codigo de barra</label>
       </field>
                                                                
                                                     
      </filters>
        <!--
      <group>
        <field id="id_stkarticulo" />
      </group>
         -->
      <order>
        <field id="fecha_pedido" tabla="STK_ARTICULO_PEDIDOINT"/>
      </order>
      
    </table>
           
    <join tipo="left">
          <table id="STK_ARTICULO_PEDIDOINT">
            <field id="stkarticulo_id">
                 <condicion operador="=">STK_ARTICULOS.id_stkarticulo</condicion>
            </field>
            <!--
            <field id="stkdeposito_id">
        	<condicion operador="=">'[__stkdeposito_id__]'</condicion>
    	    </field>   
    	         	    
    	    <field id="fecha_pedido">
    		<condicion operador="=">'[__fecha_pedido__]'</condicion>
    	    </field>
    	         -->
    	  
          </table>
    </join>
                                              
    
  </form>
</histrix>
