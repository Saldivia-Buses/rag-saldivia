<?xml version="1.0" encoding="ISO-8859-1"?>
<histrix tipo="consulta" borra="no" inserta="no" paginar="250" imprime="false" preloadData="false">
	<title>Ventas Articulos</title>
	<obs></obs>
	<form  >
		<table id="REG_MOVIMIENTOS">
			<title>Ventas por Articulos</title>
			<field id="cajmovimiento_id" noshow="true">
				<condicion operador="=">null</condicion>
			</field>

			<field id="fecha_movimiento" noshow="true">
                 	<label>fecha</label>   	 
             		</field>

			<field id="nombre_rubro" tabla="STK_RUBROS" noshow="true">
			<label>rubro</label>
				<helper type="combo" xml="stkrubro_qry.xml" dir="/ayudas" empty="true">
				</helper>
             		</field>

			<field id="nombre_subrubro" tabla="STK_SUBRUBROS" noshow="true" >
			<label>subrubro</label>
				<helper type="combo" xml="stksubrubro_qry.xml" dir="/ayudas"  empty="true">
				</helper>
             		</field>

			<field id="nombre_articulo" tabla="STK_ARTICULOS">
				<label>Articulo</label>
			</field>

			<field id="concepto" tabla="REG_CONCEPTOS">
				<label>Cant.Comprob.</label>
				<expresion>count(REG_MOVIMIENTOS.concepto_id)</expresion>
				<tipo>numeric</tipo> 
			</field>

			<field id="cantidad_articulos" suma="true" total="true">
				<label>Cantidad de articulos</label>
				<expresion>sum(case when tipo_concepto = 0 then 1 else -1  end * cantidad_detalle)</expresion>
				<tipo>numeric</tipo> 
			</field>

			
			<field id="total" local="true" suma="true" total="true">
				<label>Total Ventas</label>
				<expresion>sum(case when tipo_concepto = 0 then 1 else -1  end * importe_movimiento)</expresion>
				<tipo>numeric</tipo> 
			</field>
		        <group>
		                <field id="nombre_articulo" tabla="STK_ARTICULOS"></field>
       		        </group>

			<filters>
		               <field id="fecha_movimiento">
		                 <label>Desde</label>
		         	 <operador>&gt;=</operador>
		               </field>
  
		               <field id="fecha_movimiento">
		          	 <label>Hasta</label>
		          	 <operador>&lt;=</operador>
		          	 <valor>today</valor>  <!-- le asigna la fecha actual-->
		               </field>

			       <field id="nombre_rubro">
		          	 <label>rubro</label>
		          	 <operador>=</operador>
		     				
				</field>
  				 <field id="nombre_subrubro">
		          	 <label>subrubro</label>
		          	 <operador>=</operador>
		     				
				</field>

                        </filters>
		</table>
		<join >
			<table id="REG_CONCEPTOS">
				<field id="id_concepto" >
				<condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
				</field>
			</table>
		</join>
		
		<join >
			<table id="REG_DETALLES">
			<field id="regmovim_id" >
				<condicion operador="=">REG_MOVIMIENTOS.id_regmovim</condicion>
			</field>
			</table>
		</join>
        	<join >
			<table id="STK_ARTICULOS">
			<field id="id_stkarticulo" >
				<condicion operador="=">REG_DETALLES.codigo_detalle</condicion>
			</field>
			</table>
		</join>
		<join tipo="LEFT">
			<table id="STK_RUBROS">
			<field id="id_stkrubro" >
				<condicion operador="=">STK_ARTICULOS.stkrubro_id</condicion>
			</field>
			</table>
		</join>
	        <join tipo="LEFT" >
			<table id="STK_SUBRUBROS">
			<field id="id_stksubrubro" >
				<condicion operador="=">STK_ARTICULOS.stksubrubro_id</condicion>
			</field>
			</table>
		</join>
	
	</form>
</histrix>
