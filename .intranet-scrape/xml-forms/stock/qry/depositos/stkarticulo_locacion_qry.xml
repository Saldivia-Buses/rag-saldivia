      <condicion operador="=">stklocacion_id</condicion>
    </field> -->

    <field id="stock_actual" >
      <label>Stock Actual</label>
      <condicion operador="&gt;">0 OR STK_ARTICULOS.stklocacion_fija_id = stklocacion_id</condicion>
    
      <!-- <expression having="false">select stock_actual from STK_ARTICULO_LOCACION join STK_ARTICULOS on stkarticulo_id = id_stkarticulo where stklocacion_id = id_stklocacion and stock_actual &gt; 0 or stklocacion_fija_id = id_stklocacion</expression>  
      <condicion operador="&gt;">0</condicion> -->

     </field>

