    <field id="fotopath" local="true" noshow="true">
      <if exp="true">
        <true>'stkarticulo_id/'</true>
        <false>''</false>
      </if>
      <tipo>varchar</tipo>
    </field>

    <field id="foto" path="fotopath" _open="true" print="false" download="false" _viewer="true" watermark="stkarticulo_id">
        <expression>select ARTICULO_FOTO.foto from ARTICULO_FOTO where ARTICULO_FOTO.idArticulo = stkarticulo_id and ARTICULO_FOTO.foto != '' order by revision desc limit 1</expression> 
        <label>Imagen</label>
        <tipo Type="Image">file</tipo>
        <size>40</size> 
    </field>


<!--
    <field id="standardpack_id">
      <label>Standard Pack</label>
