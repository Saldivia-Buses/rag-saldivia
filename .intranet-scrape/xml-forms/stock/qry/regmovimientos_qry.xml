<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" >
  <title>Comprobantes emitidos</title>
  <obs/>
  <form  detalle="regdetalles_qry.xml"  >
    <table id="REG_MOVIMIENTOS" label="Comprobantes emitidos">
      <filters>

        <field id="fecha_movimiento">
    	    <label>Desde</label>
	        <operador>&gt;=</operador>
	        <valor>today</valor>

        </field>
  
        <field id="fecha_movimiento">
    	    <label>Hasta</label>
	        <operador>&lt;=</operador>
	        <valor>today</valor>
        </field>

	<field id="nro_cuenta" colstyle="display: none;" >
		    <label>Cuenta</label>
        </field>

    
      </filters>
      
      <!-- CONSULTA -->
      <field id="nro_cuenta" noshow="true" tabla="REG_CUENTA">
		<helper type="external" xml="regcuenta_solamente_nro_qry.xml" dir="/ayudas" empty="true" />
      </field>
      
      <field id="regcuenta_id" noshow="true">
		<detalle>regcuenta_id</detalle>
      </field>
     
      <field id="fecha_movimiento" _tabla="REG_MOVIMIENTOS" noshow="true">
        <tipo>date</tipo>
      </field>

      <field id="tipo" local="true" noshow="true">
        <helper type="combo">
          <option value="1">Pendientes</option>
          <option value="2">Debe-Haber</option>
        </helper>
        <detalle>pendiente</detalle>
	 <detalle>tipo</detalle>
      </field>
      
      <field id="subsistema_id" oculto="true">
        <detalle>subsistema_id</detalle>
      </field>
            
       <field id="nombre_cuenta" tabla="REG_CUENTA">
        <label>Nombre Cuenta</label>
      </field>
      
      

      <field id="color" local="true" clasefila="true" noshow="true">
        <label>color</label>
        <if exp="saldo &lt; 0">
          <true>'resaltadoRojo'</true>
          <false>''</false>
        </if>
      </field>
      
      <field id="fecha_mov1" noshow="true">
        <expression>min(REG_MOVIMIENTOS.fecha_movimiento)</expression>
        <detalle>desde</detalle>
      </field>
      
      <field id="fecha_mov2" noshow="true">
        <expression>max(REG_MOVIMIENTOS.fecha_movimiento)</expression>
        <detalle>hasta</detalle>
      </field>
      
        <field id="concepto_id" _tabla="REG_MOVIMIENTOS" noshow="true">
        
          <condicion operador="=">
	    (select id_concepto from REG_CONCEPTOS WHERE informa_calculo = 1 
			    and id_concepto = REG_MOVIMIENTOS.concepto_id limit 1)
<!--		AND subsistema_id = REG_MOVIMIENTOS.subsistema_id -->
	</condicion>
          
        </field>
      


      <group>
        <field id="regcuenta_id"/>
      </group>
      <order>
        <field id="nombre_cuenta"/>
      </order>

    </table>

    <join>
      <table id="REG_CUENTA">
        <field id="subsistema_id">
          <condicion operador="=">REG_MOVIMIENTOS.subsistema_id</condicion>
        </field>
        <field id="id_regcuenta">
          <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
        </field>
      </table>
    </join>
    <join>
      <table id="REG_CONCEPTOS">
        <field id="subsistema_id">
          <condicion operador="=">REG_MOVIMIENTOS.subsistema_id</condicion>
        </field>
        <field id="id_concepto">
          <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
        </field>
        <field id="informa_calculo">
          <condicion operador="=">1</condicion>
        </field>
      </table>
    </join>
    <!--
    <join tipo="left">
      <table id="REG_IMPUTACIONES">
        <field id="regmovim0_id">
          <condicion operador="=">REG_MOVIMIENTOS.id_regmovim</condicion>
        </field>
      </table>
    </join>
    -->
  </form>
</histrix>
