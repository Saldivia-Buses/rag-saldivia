<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta">
  <title>Movimientos</title>
  <obs/>
  <form  detalle="regimputaciones_qry.xml" inline="true" _hasDetail="has2imp">
 
	<table id="REG_MOVIMIENTOS" label="Resumen Cta Cte">
 
		<field id="subsistema_id" valauto="true" noshow="true">
			<preparam operador="=">true</preparam>
			<tipo>varchar</tipo>
		</field>
		
		<field id="concepto_id" noshow="true" />

		<field id="tipo" valauto="true" local="true"  oculto="true" />
		<field id="regcuenta_id"  valauto="true" oculto="true">
		</field>
		<field id="desde" valauto="true" noshow="true" local="true">
			<preparam campo="fecha_movimiento" operador="&lt;">true</preparam>
		</field>
		<field id="hasta"         valauto="true" noshow="true" local="true" ></field>
		<field id="id_regmovim" noshow="true">
			<detalle>regmovim_id</detalle>
		</field>
		<field id="nombre" _local="true" print="false" noshow="true">
			<expression>REG_CUENTA.nombre_cuenta</expression>
			<setvar>nombre_div</setvar>
		</field>
		<field id="fecha_movimiento" table="REG_MOVIMIENTOS">
			<label>Fecha</label>
			<help>Fecha movimiento</help>
			<condicion operador="&gt;=">'[__desde__]' and REG_MOVIMIENTOS.fecha_movimiento &lt;= '[__hasta__]' </condicion>
			<tipo>varchar</tipo>
		</field>
		<field id="abreviacion_concepto" tabla="REG_CONCEPTOS">
			<label>Comp</label>
		</field>
		<field id="imprime_concepto1" _noshow="true">
			<label>imprim_con</label>  
			<expression>case when isnull(CAJ_CONCEPTOS.imprime_concepto) then REG_NUMERADORES.ejecuta else CAJ_CONCEPTOS.imprime_concepto end</expression>
		</field>
		<field id="nro_movimiento"  >
			<label>Numero</label>
			<expression>
		CONCAT(REG_MOVIMIENTOS.letra_movimiento,' ',LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,'0'),'-',LPAD(REG_MOVIMIENTOS.nro_movimiento  ,8,'0'))
			</expression>
		  	<helper type="link" dir="/caja/qry">
				<parameter source="id_cajmovimiento" target="id_cajmovimiento" />
				<parameter source="id_regmovim" target="id_regmovim" />
		  	</helper>
		  	<attribute id="linkint">imprime_concepto1</attribute>
		</field>
		<!--
		<field id="anular" local="true">
		    <label>Anulacion</label>
		    <valor>'Anulacion'</valor>
		    <helper xml="anulacion.xml"  dir="">
			<parameter source="id_regmovimiento" id="" />
		    </helper>
		</field>
    FALTA EL PROGRAMA DE ANULAR REMITOS
      <field id="xml_llamar" local="true" _noshow="true">
        <if exp="cajmovimiento_id + 0 != 0">
          <true>'recibo_qry.xml'</true>
          <false>''</false>
        </if>
      </field>

      <field id="eliminacion" tdWidth="20" linkdir="/caja/qry" local="true" print="false" linkdes="Detalle del Comprobante">
        <attribute id="linkint">xml_llamar</attribute>
        <label>Detalle</label>
        <if exp="'xml_llamar' != ''">
          <true>'&gt;&gt;'</true>
          <false>''</false>
        </if>
    
        <paring destino="id_regmovimheader">id_regmovim</paring>
        <paring destino="id_cajmovmiento">cajmovimiento_id</paring>
      </field>
-->		
		<field id="imputacion_concepto" tabla="REG_CONCEPTOS" noshow="true" />
		<field id="valor_declarado" suma="true" noZero="true">
			<label>Valor Declarado</label> 
			<tipo>numeric</tipo>
		</field>
		<order>
			<field id="fecha_movimiento" tabla="REG_MOVIMIENTOS" />
			<field id="imputacion_concepto"/>
		</order>
		<group>
			<field id="id_regmovim" tabla="REG_MOVIMIENTOS"/>
		</group>
	</table>
    
	<join>
		<table id="REG_CONCEPTOS">
			<field id="id_concepto">
				<!-- <condicion operador="=">
				(SELECT id_concepto FROM REG_CONCEPTOS WHERE informa_calculo = 1 and subsistema_id = REG_MOVIMIENTOS.subsistema_id LIMIT 1)
				</condicion> -->
				<condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
           </field>
           <field id="informa_calculo">
	           <condicion operador="=">1</condicion>
           </field>
           <field id="subsistema_id">
               <condicion operador="=">REG_MOVIMIENTOS.subsistema_id</condicion>
			</field>
		</table>
	</join>
	<join tipo="left">
		<table id="CAJ_CONCEPTOS">
			<field id="regconcepto_id">
				<condicion operador="=">REG_CONCEPTOS.id_concepto</condicion>
			</field>
		</table>
	</join>
	<join tipo="left">
		<table id="REG_CUENTA">
			<field id="id_regcuenta">
				<condicion operador="=">regcuenta_id</condicion>
			</field>
		</table>
	</join>
	<join tipo="left">
		<table id="REG_NUMERADORES">
			<field id="regconcepto_id">
				<condicion operador="=">REG_CONCEPTOS.id_concepto</condicion>
			</field>
		</table>
	</join>

	<join tipo="left">
		<table id="REG_IMPUTACIONES">
			<field id="regmovim_id">
				<condicion operador="=">REG_MOVIMIENTOS.id_regmovim</condicion> 
			</field>
			<field id="subsistema0_id">
				<condicion operador="=">'REG_MOVIMIENTOS.subsistema_id'</condicion> 
			</field>
		</table>
	</join>
  </form>
</histrix>
