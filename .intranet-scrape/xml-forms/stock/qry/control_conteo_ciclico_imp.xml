<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="ficha" sololectura="true" autoprint="true" PDFfontSize="9" PDFpageSize="A4">
  <title>Planilla de Conteo Cíclico</title>
  <obs></obs>
  <form>
    <pdf PDForientacion="P">
        <code><![CDATA[

			$pdf->SetDrawColor(0);
			$pdf->SetXY(10,10);

			$tp = 05;
			$ap = $pdf->anchoPagina - 2;
			$mp = ($ap / 2);
			$lp = $pdf->largoPagina;

			// Codigo articulo
			$pdf->Rect(005, 040, $ap, 020, 0.1);

        ]]></code>
    </pdf>

	<table id="STK_ARTICULOS"  label="Conteo cíclico">
		
