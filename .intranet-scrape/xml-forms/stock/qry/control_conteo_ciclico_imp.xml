				<parameter source="id_stkarticulo" target="stkarticulo_id" />
		    </helper>
		</field>

		<field id="fecha_conteo" local="true">
			<label posx="5" posy="+10">Fecha conteo:_________________________</label> 
		</field>

		<field id="firma_contador" local="true">
			<label posx="5" posy="+8">Firma Contador:________________________</label> 
