      REEMPLAZAR POR STK_HIST_COSTOS


            <field id="cosT">
                <label>Costo.</label>
                <expression having="false">select INSPR.costo_articulo from STK_HIST_COSTOS as INSPR where INSPR.ultima_fecha= max(STK_HIST_COSTOS.ultima_fecha) and INSPR.stkarticulo_id = STK_HIST_COSTOS.stkarticulo_id limit 1</expression>
                <tipo>numeric</tipo>
            </field>
            
            <field id="prov">
                <label>prov</label>
                <expression>(select P.regcuenta_id from STK_ARTICULO_PROVEEDOR P where P.stkarticulo_id = STK_ARTICULOS.id_stkarticulo limit 1)</expression>
                <!--
                <expression>(select INSPR.regcuenta_id from STK_HIST_COSTOS as INSPR where INSPR.stkarticulo_id = STK_ARTICULOS.id_stkarticulo order by ultima_fecha DESC limit 1)</expression>
                -->
                <tabla_ex id="REG_CUENTA" _xml="REG_CUENTA.xml" vacio="true">
                    <field id="id_regcuenta">
                    </field>
                    <field id="nombre_cuenta">
                    </field>
                    <field id="subsistema_id" oculto="true">
                        <condicion operador="=">'01'</condicion>
                    </field>
                </tabla_ex>
                <tipo>varchar</tipo>
            </field>

            <field id="costo">
                <label>Costo</label>
                <expression>round(case when ((select STK_HIST_COSTOS.costo_articulo from STK_HIST_COSTOS where STK_HIST_COSTOS.stkarticulo_id = STK_ARTICULOS.id_stkarticulo order by ultima_fecha DESC limit 1) * STK_ARTICULOS.valor_compra / STK_ARTICULOS.valor_uso) &gt; 0  then ((select STK_HIST_COSTOS.costo_articulo from STK_HIST_COSTOS where STK_HIST_COSTOS.stkarticulo_id = STK_ARTICULOS.id_stkarticulo  order by ultima_fecha DESC limit 1) * STK_ARTICULOS.valor_compra / STK_ARTICULOS.valor_uso) else STK_ARTICULOS.precio_costo end, 2)</expression>
                <tipo>decimal</tipo>
            </field>
            


            <field id="ultima_fecha" _tabla="STK_HIST_COSTOS" tipoOrden="DESC">
                <expression>(select INSPR.ultima_fecha from STK_HIST_COSTOS as INSPR where INSPR.stkarticulo_id = STK_ARTICULOS.id_stkarticulo  order by ultima_fecha DESC limit 1)</expression>
                <label>ult.compra</label>
                <tipo>date</tipo>
            </field>
            <field id="fec2ult" tabla="STK_HIST_COSTOS" _noshow="true">
                <expresion _sql="true"><![CDATA[ select max(STKINS.ultima_fecha) from STK_HIST_COSTOS as STKINS where STKINS.stkarticulo_id = STK_ARTICULOS.id_stkarticulo and (select INSPR.ultima_fecha from STK_HIST_COSTOS as INSPR where INSPR.stkarticulo_id = STK_ARTICULOS.id_stkarticulo  order by ultima_fecha DESC limit 1) > STKINS.ultima_fecha order by ultima_fecha DESC limit 1 ]]>
                </expresion>
                <label>compra Ant</label>
                <tipo>date</tipo>
            </field>
      
               <!--
            <field id="cos2to" noshow="true">
                <label>Costo Ant</label>
                <expression sql="true"><![CDATA[ select round(STKINS.costo_articulo * 0[__valor_compra__] / 0[__valor_uso__], 2) from STK_HIST_COSTOS as STKINS where STKINS.stkarticulo_id ='[__id_stkarticulo__]' and '[__ultima_fecha__]' > STKINS.ultima_fecha order by ultima_fecha DESC limit 1 ]]>
                </expression>
            </field>

            <field id="inc" local="true">
                <label>% Inc.</label>
                <if exp="0cos2to &lt; 0costo &amp;&amp; 0cos2to != 0">
                    <true>round((0costo - 0cos2to) / 0cos2to * 100, 2)</true>
                    <false>0</false>
                </if>
                <tipo>decimal</tipo>

            </field>
            <field id="hilite"  clasefila="true" local="true" noshow="true">
                <if exp="inc + 0 > 1">
                    <true>'resaltado'</true>
                    <false>(inc + 0 &lt;= 1 &amp;&amp; 0inc &gt; 0)?'resaltadoVioleta':''</false>
                </if>
                <tipo>varchar</tipo>
            </field>
-->

