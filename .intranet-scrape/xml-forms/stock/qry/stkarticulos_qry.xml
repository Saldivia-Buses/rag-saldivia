            <field id="stock" >
                <label style="font-weight:bold;">Stock</label>
                <expression >SELECT sum( STK_MOVIMIENTOS.cantidad * (CASE WHEN STK_CONCEPTOS.tipo_concepto = 1 THEN -1 ELSE 1 END ))
      FROM STK_MOVIMIENTOS LEFT JOIN STK_CONCEPTOS ON STK_CONCEPTOS.id_stkconcepto = STK_MOVIMIENTOS.stkconcepto_id
      WHERE STK_MOVIMIENTOS.stkarticulo_id = STK_ARTICULOS.id_stkarticulo
                </expression>
                <tipo>numeric</tipo>
            </field>
            <field id="cuentadebe_id" print="false">
