<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" path="fotos/articulos" preloadData="false" paginar="250" >
   <title>Articulos Por Rubro</title>
   <obs/>
   <form>
	<table id="STK_ARTICULOS">

		<filters>
			
			<field id="id_stkarticulo">
			    <label>Codigo</label>
			    <operador>like</operador>
			</field>
			
			<field id="nombre_art" deshabilitado="true" colspan="8">
			    <label modpos="nobr">Articulo</label>
			    <size>80</size>
			</field>
			
			<field id="stkfamilia_id">
				<label>Familia</label>
				<operador>=</operador>
			</field>
			
			<field id="stkrubro_id">
				<label modpos="nobr">Rubro</label>
				<operador>=</operador>
			</field>
			
			<field id="stksubrubro_id">
				<label modpos="nobr">SubRubro</label>
				<operador>=</operador>
			</field>
			
			<field id="stkmarca_id">
				<label modpos="nobr">Marca</label>
				<operador>=</operador>
			</field>

		</filters>

			<field id="stkfamilia_id" multiple="true">
				<label>Familia</label>
				<helper type="combo" xml="stkfamilia_qry.xml" dir="/ayudas" empty="true"/>
			</field>

			<field id="stksubrubro_id" multiple="true">
				<label>SubRubro</label>
				<helper type="combo" xml="stksubrubro_qry.xml" dir="/ayudas" empty="true"/>
			</field>


			<field id="stkrubro_id" multiple="true" colstyle="text-align:center;">
				<label>Rubro</label>
				<helper type="combo" xml="stkrubro_qry.xml" dir="/ayudas" empty="true" />
			</field>

			<field id="nombre_familia" noshow="true" tabla="STK_FAMILIAS" />
			<field id="nombre_rubro" noshow="true" tabla="STK_RUBROS" />
			<field id="nombre_subrubro" noshow="true" tabla="STK_SUBRUBROS" />

			<field id="id_stkarticulo" colstyle="text-align:center;">
				<label>Codigo</label>
				<helper type="external" id="STK_ARTICULOS" empty="true">
					<field id="id_stkarticulo" />
					<field id="nombre_art">
						<label>Nombre</label>
						<detalle>nombre_art</detalle>
						<expression>STK_ARTICULOS.nombre_articulo</expression>
					</field>
					<field id="descripcion">
						<label>Descripcion</label>
						<expression>STK_ARTICULOS.referencia</expression>
					</field>
				</helper>
			</field>

			<field id="nombre_art" local="true" noshow="true" colspan="8">
			    <size>80</size>
			</field>

			<field id="nombre_articulo" >
				<label>Nombre Articulo</label>
				<expression>IF(referencia != '', referencia, nombre_articulo)</expression>
			</field>

			<field id="stkmarca_id" multiple="true" colstyle="text-align:center;">
				<label>Marca</label>
				<helper type="combo" xml="stkmarca_qry.xml" dir="/ayudas" empty="true"/>
			</field>

			<field id="stkarticulo_foto" xmlField="image" path="id_stkarticulo">
				<label>Foto</label>
				<tipo Type="Image">file</tipo>
				<size>80</size>
			</field>

			<order>
				<field id="nombre_articulo" />
				<field id="nombre_familia" />
				<field id="nombre_rubro" />
				<field id="nombre_subrubro" />
			</order>


	</table>

		<join tipo="left">
		    <table id="STK_FAMILIAS">
				<field id="id_stkfamilia">
				    <condicion operador="=">STK_ARTICULOS.stkfamilia_id</condicion>
				</field>
		    </table>
		</join>

		<join tipo="left">
		    <table id="STK_RUBROS">
				<field id="id_stkrubro">
				    <condicion operador="=">STK_ARTICULOS.stkrubro_id</condicion>
				</field>
		    </table>
		</join>

		<join tipo="left">
		    <table id="STK_SUBRUBROS">
				<field id="id_stksubrubro">
				    <condicion operador="=">STK_ARTICULOS.stksubrubro_id</condicion>
				</field>
		    </table>
		</join>


   </form>
</histrix>
