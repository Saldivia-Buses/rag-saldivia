<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" _preloadData="false">
  <title>Ficha Kardex</title>
  <obs/>
  <form>
    <table id="STK_MOVIMIENTOS" label="movimientos">

		<field id="id_stkmovimiento" esClave="true" noshow="true"/>

        <field id="stkarticulo_id" noshow="true" >
        </field>

       <field id="stkarticulo_id"  >
        <label>Código Barra</label>
        <helper type="external" xml="stkarticulo_pos.xml" dir="/ayudas">
          <field id="wstklista_id" local="true">
            <valor>1</valor>
          </field>
        </helper>                
    </field>
      <field id="descripcion_detalle" local="true" _tabla="STK_ARTICULOS" noshow="true">
        <label modpos="nobr">Nombre</label>
        <help>Referencia del movimiento</help>
      </field>
      <field id="stkdeposito_id">
        <label>Depósito</label>
        <helper type="combo" xml="stkdeposito_qry.xml" dir="/ayudas" empty="true" />
      </field>

            <field id="stklocacion_id" >
	    <helper type="link" xml="fichakardex_modif_art.xml" >
		<parameter source="id_stkmovimiento" target="id_stkmovimiento" />
	    </helper>
          <helper _empty="true" id="STK_LOCACION" type="combo" empty="true">
            <field id="id_stklocacion"/>
            <field id="codigo_locacion">
              <detalle>codigo_locacion</detalle>
            </field>
            <field id="stkdeposito_id">
              <detalle>stkdeposito_id</detalle>
            </field>
	    <order>
                <field id="codigo_locacion" />

	    </order>
          </helper>

                <label>Depósito Origen</label>
            </field>


      <field id="comprobante" >
        <label>Comprobante</label>
        <expresion>CONCAT((LPAD(ifnull(puesto_movimiento,0),4,0)),'-',(LPAD(numero_movimiento,8,0)))</expresion>
      </field>
      
      <field id="referencia" >
        <label>Referencia</label>
      </field>

      <field id="fecha_movimiento">
        <label>Fecha</label>
        <help>Fecha movimiento</help>
        <tipo>date</tipo>
      </field>
      <field id="vencimiento_art">
        <label>Vencimiento</label>
        <tipo>date</tipo>
      </field>

      <field id="stkconcepto_id">
        <helper type="combo" xml="stkconcepto_qry.xml" dir="/ayudas" empty="true">
        </helper>
        <label>Concepto</label>
        <help>Código de concepto</help>
        <detalle>concepto_id</detalle>
      </field>

      <field id="ingresos" local="true" noZero="true">
        <label modpos="nobr">Ingresos</label>
        <expresion>CASE WHEN STK_CONCEPTOS.tipo_concepto = 0 THEN cantidad ELSE 0 END</expresion>
        <tipo>numeric</tipo>
      </field>
      <field id="egresos" local="true" noZero="true">
        <label modpos="nobr">Egresos</label>
        <expresion>CASE WHEN STK_CONCEPTOS.tipo_concepto = 1 THEN cantidad ELSE 0 END</expresion>
        <tipo>numeric</tipo>
      </field>
      <field id="cantidad" local="true" suma="true" acumula="true">
        <expresion>CASE WHEN STK_CONCEPTOS.tipo_concepto = 0 THEN STK_MOVIMIENTOS.cantidad ELSE -(STK_MOVIMIENTOS.cantidad) END</expresion>
        <label>Stock</label>
        <tipo>numeric</tipo>
      </field>

       <field id="usuario" >
        <label>Usuario</label>
        <expression>CONCAT(ifnull(HTXUSERS.nombre, ''),' ', ifnull(HTXUSERS.apellido, ''))</expression>
      </field>

      <field id="tipo_concepto" clasefila="true" noshow="true">
        <expresion>CASE WHEN STK_CONCEPTOS.tipo_concepto = 0 THEN 'resaltado' else '' END</expresion>
      </field>
      
      <order>
        <field id="fecha_movimiento"/>
        <field id="id_stkmovimiento"/>
      </order>
      
    </table>
    <join tipo="left">
      <table id="STK_ARTICULOS">
        <field id="id_stkarticulo">
          <condicion operador="=">STK_MOVIMIENTOS.stkarticulo_id</condicion>
        </field>
      </table>
    </join>
    <join tipo="inner">
      <table id="STK_CONCEPTOS">
        <field id="id_stkconcepto">
          <condicion operador="=">STK_MOVIMIENTOS.stkconcepto_id</condicion>
        </field>
      </table>
    </join>

    <join tipo="left">
      <table id="HTXUSERS">
        <field id="Id_usuario">
          <condicion operador="=">STK_MOVIMIENTOS.user_id</condicion>
        </field>
      </table>
    </join>
  </form>
</histrix>
