<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="ficha" preFetch="true" borra="false" imprime="false" cancel="false">
  <title>Cambiar Estado</title>
  <obs></obs>
  <eventos>
    <event id="update">close</event>
    <event id="update">refresh</event>
  </eventos>

  <form>
    <table id="STK_INVENTARIOS" label="Inventario">
      <field id="id_stkinventario" noshow="true" esClave="true"></field>
      <field id="nro_inventario" deshabilitado="true">
        <label>Nº</label>
      </field>
      <field id="fecha_inventario" deshabilitado="true">
        <label>Fecha</label>
        <tipo>date</tipo>
      </field>
      <field id="stkdeposito_id" deshabilitado="true">
        <label>Depósito</label>
        <helper type="combo" xml="stkdeposito_qry.xml" dir="/ayudas" empty="true"/>
      </field>
      <field id="cerrado" style="font-size:20px;width:20px;height:20px;">
        <label>Estado</label>
        <helper type="combo">
          <option value="0">Abierto</option>
          <option value="1">Cerrado</option>
        </helper>
        <tipo>radio</tipo>
      </field>
    </table>
  </form>
</histrix>