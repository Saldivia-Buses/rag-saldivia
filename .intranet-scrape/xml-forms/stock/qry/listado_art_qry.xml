<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" borra="no" inserta="no" paginar="250"
	path="fotos/articulos" _preloadData="false">
	<title>Insumos</title>
	<obs></obs>
	<form>
		<table id="STK_ARTICULOS" label="Listado de Articulos" styleTbody="height:500px;overflow-x:hidden;">
			<title>Listado de Articulos</title>
			<filters>
				<field id="stkrubro_id">
					<label modpos="nobr">Rubro</label>
				</field>
				<field id="prov" deshabilitado="false">
					<label >Proveedor</label>
				</field>

				<field id="id_stkarticulo">
					<label>Cod.</label>
				</field>

				<field id="nombre_articulo" fullSearch="true">
					<label modpos="nobr">Articulo</label>
					<help>Descripcion de Articulo</help>
					<operador>like</operador>
				</field>
				<field id="stkdeposito_id">
					<label >Depósito</label>
				</field>
				
            <field id="genmoneda_venta_id" fieldgroup="avanzado">
                <label >Moneda Venta</label>
                <helper type="combo" xml="moneda_qry.xml" dir="/ayudas" empty="true" />
            </field> 
				

			</filters>
		          <field id="stkdeposito_id" local="true">
		        	<helper type="combo" id="STK_DEPOSITOS" empty="true">
		        	  <field id="id_stkdeposito" />
		        	  <field id="nombre_deposito" />
		        	</helper>
		        	<label >Depósito</label>

		      	  </field>


			<field id="id_stkarticulo" PDFcolor="000000" esClave="true"
				style="font-weight:bold;">
				<ayuda_ex id="STK_ARTICULOS">
					<field id="id_stkarticulo">
						<label>Cod</label>
					</field>
					<field id="nombre_articulo">
						<label>Nombre</label>
						<detalle>nombre_articulo</detalle>
					</field>
					<field id="subsistema_id" oculto="true">
						<condicion operador="=">'01'</condicion>
					</field>
				</ayuda_ex>
				<label>Cod.</label>
				<detalle>id_stkarticulo</detalle>
			</field>


			<field id="stkrubro_id" noshow="true">
				<label modpos="nobr">Rubro</label>
				<helper type="combo" xml="stkrubro_qry.xml" dir="/ayudas"
					empty="true" />
			</field>

			<field id="nombre_articulo" _autocompletar="false" fullSearch="true">
				<label>Articulo</label>
				<help>Descripcion de Articulo.</help>
			</field>

			<field id="baja_articulo" oculto="true">
				<condicion operador="!=">1</condicion>
			</field>

            <field id="prov">
                <label>prov</label>
                <expression having="false">(select P.regcuenta_id from STK_ARTICULO_PROVEEDOR P where P.stkarticulo_id = STK_ARTICULOS.id_stkarticulo limit 1)</expression>
                <tabla_ex id="REG_CUENTA" _xml="REG_CUENTA.xml" vacio="true">
                    <field id="id_regcuenta">
                    </field>
                    <field id="nombre_cuenta">
                    </field>
                    <field id="subsistema_id" oculto="true">
                        <condicion operador="=">'01'</condicion>
                    </field>
                </tabla_ex>
                <tipo>varchar</tipo>
            </field>

			<field id="actual" local="true" noZero="true">
				<label>Stock Actual</label>
				<helper type="link" xml="stock_deposito_1.xml">
					<parameter source="id_stkarticulo" target="stkarticulo_id" />
				</helper>
				<attribute id="colstyle">colorlabel</attribute>
				<expression>(case when '[__stkdeposito_id__]' = '' then (Select sum(cantidad_stock) FROM STK_STOCKACTUAL STK1 WHERE STK1.stkarticulo_id = STK_ARTICULOS.id_stkarticulo) else
					    (Select sum(cantidad_stock) FROM STK_STOCKACTUAL STK1 WHERE STK1.stkarticulo_id = STK_ARTICULOS.id_stkarticulo and STK1.stkdeposito_id = '[__stkdeposito_id__]') end)
				</expression>
    <!--
				<expression>Select sum(CASE WHEN STK2.tipo_concepto = 0 THEN 1 ELSE
					-1 END * STK1.cantidad) FROM STK_MOVIMIENTOS STK1 left JOIN
					STK_CONCEPTOS STK2 on ( STK2.id_stkconcepto = STK1.stkconcepto_id )
					where STK1.stkarticulo_id = STK_ARTICULOS.id_stkarticulo
				</expression>
				-->
				<tipo>numeric</tipo>
			</field>
                                                <!--
			<field id="Pedido" local="true">
				<label>Pedido</label>
				<helper type="link" xml="detalle_pedido.xml">
					<parameter source="id_stkarticulo" target="id_stkarticulo" />
				</helper>
				<attribute id="colstyle">colorlabel</attribute>
				<expression>sum( case when REG_CONCEPTOS.id_concepto = option_value
					then REG_DETALLES.cantidad_detalle else 0 end )</expression>
				<tipo>numeric</tipo>
			</field>

			<field id="facturado" local="true">
				<label>Facturado</label>
				<expression>select sum(ifnull(RD1.cantidad_detalle,0) ) from
					REG_DETALLES RD1
					JOIN REG_IMPUTACIONESDETALLES on
					REG_IMPUTACIONESDETALLES.regdetallefac_id = RD1.id_regdetalle
					where REG_IMPUTACIONESDETALLES.regdetalleped_id =
					REG_DETALLES.id_regdetalle
				</expression>
				<tipo>numeric</tipo>
			</field>
			<field id="pendiente" local="true">
				<label>Pendiente</label>
				<if exp="true">
					<true>Pedido - facturado</true>
					<false>0</false>
				</if>
				<tipo>numeric</tipo>
			</field>
			-->
			<field id="ultima" >
				<label>Ultima Venta</label>
				
								<expression>Select max(fecha_movimiento) FROM STK_MOVIMIENTOS STK1 left JOIN
					STK_CONCEPTOS STK2 on ( STK2.id_stkconcepto = STK1.stkconcepto_id )
					where STK1.stkarticulo_id = STK_ARTICULOS.id_stkarticulo
				</expression>
				<tipo>date</tipo>
			</field>
            <field id="genmoneda_venta_id"  _sincelda="true">
                <label >Moneda Venta</label>
                <helper type="combo" xml="moneda_qry.xml" dir="/ayudas" empty="true" />
            </field> 
			
			<group>
			
				<field id="id_stkarticulo" />
			</group>

			<order>
				<field id="nombre_articulo" />
			</order>

		</table>
                                         <!--
		<join tipo="left">
			<table id="REG_DETALLES">
				<field id="codigo_detalle">
					<condicion operador="=">STK_ARTICULOS.id_stkarticulo
					</condicion>
				</field>
			</table>
		</join>
		<join tipo="left">
			<table id="REG_MOVIMIENTOS">
				<field id="id_regmovim">
					<condicion operador="=">REG_DETALLES.regmovim_id</condicion>
				</field>
			</table>
		</join> 

		<join tipo="left">
			<table id="REG_CONCEPTOS">
				<field id="id_concepto">
					<condicion operador="=">REG_MOVIMIENTOS.concepto_id
					</condicion>
				</field>
			</table>
		</join>
		<join tipo="left">
			<table id="HTXOPTIONS">
				<field id="option_value">
					<condicion operador="=">REG_CONCEPTOS.id_concepto and
						option_name = 'ID_NOTA_PEDIDOS'</condicion>
				</field>
			</table>
		</join>
                                             -->
	</form>
</histrix>
