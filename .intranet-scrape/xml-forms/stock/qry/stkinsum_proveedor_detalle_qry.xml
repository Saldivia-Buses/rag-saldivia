<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta">
    <title>Artículos por proveedor</title>
    <obs></obs>
    <form>
        <table id="STK_ARTICULO_PROVEEDOR">
            
            <field id="id_stkarticuloproveedor" _noshow="true">
                <label>Cod.</label>
                <operador>=</operador>
            </field>

            <field id="regcuenta_id" noshow="true">
                <label>Proveedor</label>
            </field>

            <field id="nombre_articulo" tabla="STK_ARTICULOS" deshabilitado="true">
                <label>Descripcion</label>
                <size>50</size>
            </field>

        </table>

        <join tipo="left">
            <table id="STK_ARTICULOS">
                <field id="id_stkarticulo">
                    <condicion operador="=">STK_ARTICULO_PROVEEDOR.stkarticulo_id</condicion>
                </field>
            </table>
        </join>

    </form>
</histrix>