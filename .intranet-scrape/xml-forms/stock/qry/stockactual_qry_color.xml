<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" borra="no" inserta="no" paginar="250" _imprime="false" preloadData="false">
  <title>Stock Actualizado</title>
  <obs/>
  <form>
    <table id="STK_STOCKACTUAL" label="Stock Actualizado">

     <filters>
        <field id="stkfamilia_id">
          <operador>=</operador>
          <label modpos="nobr">Familia</label>
        </field>
        <field id="stkrubro_id">
          <operador>=</operador>
          <label modpos="nobr">Rubro</label>
        </field>
        <field id="id_stkarticulo" tabla="STK_ARTICULOS" noshow="true">
            <operador>=</operador>
            <label>Codigo de Articulo</label>
        </field>
        <field id="prov" deshabilitado="false">
		    <label>Proveedor</label>
	    </field>
        <field id="codigo_barra" tabla="STK_ARTICULOS">
          <operador>=</operador>
          <label modpos="nobr">Codigo de barra</label>
        </field>
        <field id="stkdeposito_id">
    	    <helper type="combo" id="STK_DEPOSITOS" empty="true">
    	        <field id="id_stkdeposito" />
    	        <field id="nombre_deposito" />
    	    </helper>
    	    <label modpos="nobr">Depósito</label>
            <operador>=</operador>
  	    </field>
  	    
  	    <field id="colores">
  	            <valor>Colores</valor>
  	            <label />
  	    </field>
      </filters>      
      
      <field id="colores" local="true" noshow="true" editable="false">
          <helper type="link" xml="stkcolores_crud.xml" dir="/stock/man/" modal="true" width="320px" height="200px" title="Referencia Colores" />
	      <valor>Colores</valor>
      </field>
      
      <fieldGroup>
            <field id="prov" noshow="true">
                <label>prov</label>
                <expresion having="false">(select P.regcuenta_id from STK_ARTICULO_PROVEEDOR P where P.stkarticulo_id = STK_ARTICULOS.id_stkarticulo limit 1)</expresion>
                <tabla_ex id="REG_CUENTA" _xml="REG_CUENTA.xml" vacio="true">
                    <field id="id_regcuenta">
                    </field>
                    <field id="nombre_cuenta">
                    </field>
                    <field id="subsistema_id" oculto="true">
                        <condicion operador="=">'01'</condicion>
                    </field>
                </tabla_ex>
                <tipo>varchar</tipo>
            </field>

      <field id="id_stkarticulo" tabla="STK_ARTICULOS" _noshow="true" esClave="true">
        <label>Codigo de Articulo</label>
        <helper type="external" xml="stkarticulo_qry.xml" dir="/ayudas">
          <field id="wstklista_id" local="true">
            <valor>1</valor>
          </field>
        </helper>

      </field>
      <field id="codigo_barra" tabla="STK_ARTICULOS">
        <label>Codigo de Barra</label>
        <helper type="external" xml="stkarticulo_pos.xml" dir="/ayudas">
          <field id="wstklista_id" local="true">
            <valor>1</valor>
          </field>
        </helper>
      </field>
      <field id="stkfamilia_id" noshow="true" tabla="STK_ARTICULOS">
        <label>Familia</label>
        <helper type="combo" xml="stkfamilia_qry.xml" dir="/ayudas" empty="true"/>
      </field>
      <field id="stkrubro_id" tabla="STK_ARTICULOS">
        <label>Rubro</label>
        <helper type="combo" xml="stkrubro_qry.xml" dir="/ayudas" empty="true"/>
      </field>
      <field id="stkdeposito_id">
    	<helper type="combo" id="STK_DEPOSITOS" empty="true">
    	  <field id="id_stkdeposito" />
    	  <field id="nombre_deposito" />
    	</helper>
    	<label modpos="nobr">Depósito</label>
  	  </field>


      <field id="nombre_articulo" tabla="STK_ARTICULOS">
        <label>Articulo</label>
      </field>
    </fieldGroup>

    <fieldGroup noshow="true">
      <field id="cantidad_stock">
        <expresion>@CS := (cantidad_stock * 1)</expresion>
      </field>   
      <field id="enordendecompra">
        <expresion>@OC := IFNULL((SELECT SUM(cantidad_compra) FROM CPS_DETALLE WHERE stkarticulo_id = STK_STOCKACTUAL.stkarticulo_id and recibido_compra != cantidad_compra),0)</expresion>
      </field>
      <field id="ennotapedido">
        <expresion>@NP := (ifnull(
        (SELECT sum(ifnull(RD1.cantidad_detalle,0) ) FROM REG_MOVIMIENTOS RM1
        JOIN REG_DETALLES RD1 ON RM1.id_regmovim = RD1.regmovim_id
          WHERE RD1.codigo_detalle = STK_STOCKACTUAL.stkarticulo_id and RM1.subsistema_id = '02' and RM1.concepto_id = 18),0) - 
          ifnull(
          (select sum(cantidad_imputada) from REG_MOVIMIENTOS RM2
        JOIN REG_DETALLES RD2 ON RM2.id_regmovim = RD2.regmovim_id  
        JOIN REG_IMPUTACIONESDETALLES RI2 on RI2.regdetalleped_id = RD2.id_regdetalle
        where RM2.id_regmovim = RM2.id_regmovim and
        RD2.codigo_detalle = STK_STOCKACTUAL.stkarticulo_id and RM2.subsistema_id = '02' and RM2.concepto_id = 18), 0))
        </expresion>
      </field>
      <field id="realreal">
        <expresion>@RR := (@CS + @OC - @NP)</expresion>
      </field>
    </fieldGroup>
    
    
    <fieldGroup local="true" tdWidth="100px">
      <field id="ver_cantidad_stock">
        <label>Real</label>
        <tipo>varchar</tipo>
        <attribute id="style">pinta_cantidad_stock</attribute>
        <valor> </valor>
      </field>
      <field id="ver_enordendecompra">
        <label>Entrante (OC)</label>
        <tipo>varchar</tipo>
        <attribute id="style">pinta_enordendecompra</attribute>
        <valor> </valor>
      </field>
      <field id="ver_ennotapedido">
        <label>Comprometido (NP)</label>
        <tipo>varchar</tipo>
        <attribute id="style">pinta_ennotapedido</attribute>
        <valor> </valor>
      </field>
      <field id="ver_realreal">
        <label>Disponible</label>
        <tipo>varchar</tipo>
        <attribute id="style">pinta_realreal</attribute>
        <valor> </valor>
      </field>
    </fieldGroup>

    <fieldGroup noshow="true">
      <field id="pinta_cantidad_stock">
        <expresion>CONCAT('background-color: ',(SELECT color FROM STK_COLORES WHERE valor_desde &lt;= cantidad_stock AND valor_hasta &gt;= cantidad_stock))</expresion>
      </field>
      <field id="pinta_enordendecompra">
        <expresion>CONCAT('background-color: ',(SELECT color FROM STK_COLORES WHERE valor_desde &lt;= @OC AND valor_hasta &gt;= @OC))</expresion>
      </field>
      <field id="pinta_ennotapedido">
        <expresion>CONCAT('background-color: ',(SELECT color FROM STK_COLORES WHERE valor_desde &lt;= @NP AND valor_hasta &gt;= @NP))</expresion>
      </field>
      <field id="pinta_realreal">
        <expresion>CONCAT('background-color: ',(SELECT color FROM STK_COLORES WHERE valor_desde &lt;= @RR AND valor_hasta &gt;= @RR))</expresion>
      </field>
    </fieldGroup>

    <field id="baja_articulo" tabla="STK_ARTICULOS" noshow="true">
      <condicion operador="=">0 and STK_ARTICULOS.no_listar = 0</condicion>
    </field>

      <group>
        <field id="nombre_articulo" tabla="STK_ARTICULOS"/>
      </group>
      
    </table>

    <join>
      <table id="STK_ARTICULOS">
        <field id="id_stkarticulo">
          <condicion operador="=">STK_STOCKACTUAL.stkarticulo_id</condicion>
        </field>
      </table>
    </join>

    <join tipo="LEFT">
      <table id="STK_RUBROS">
        <field id="id_stkrubro">
          <condicion operador="=">STK_ARTICULOS.stkrubro_id</condicion>
        </field>
      </table>
    </join>
    
  </form>
</histrix>
