<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" paginar="200">
  <title>Consulta general</title>
  <obs/>
  <form>
    <table id="STK_MOVIMIENTOS" label="Consulta general">
      <!-- preconsultas>
        <xmlfile id="stockgeneralcps_pre.xml"/>
      </preconsultas -->

      <filters>

          <field id="id_stkarticulo" tabla="STK_ARTICULOS" >
            <label>Codigo Articulo</label>
            <operador>=</operador>
          </field>

          <field id="codigo_barra" >
            <operador>=</operador>
            <label modpos="nobr">Codigo de Barra</label>
            <help>Articulo a buscar</help>
          </field>

          <field id="nombre_articulo" tabla="STK_ARTICULOS" deshabilitado="true"/>


          <field id="stkconcepto_id">
            <operador>=</operador>
            <label>Concepto</label>
            <help>Concepto elegido</help>
          </field>

          <field id="regcuentavendedor_id">
            <operador>=</operador>
            <label modpos="nobr">Vendedor</label>
          </field>


          <field id="puesto_movimiento">
            <operador>=</operador>
            <label modpos="nobr">P.Venta</label>
          </field>

          

          <field id="stkfamilia_id">
            <operador>=</operador>
            <label>Familia</label>
          </field>

          
          

          <field id="stkrubro_id">
            <operador>=</operador>
            <label modpos="nobr">Rubro</label>
          </field>

          <field id="stksubrubro_id">
            <operador>=</operador>
            <label modpos="nobr">Sub Rubro</label>
          </field>

          <field id="stkdeposito_id">
            <operador>=</operador>
            <label modpos="nobr">Deposito</label>
          </field>

          <field id="fecha_mov1" deshabilitado="false">
            <valor>today</valor>
            <operador>&gt;=</operador>
            <label>Desde Fecha</label>
            <help>Fecha movimiento</help>
          </field>

          <field id="fecha_mov2" deshabilitado="false">
            <valor>today</valor>
            <operador>&lt;=</operador>
            <label modpos="nobr">Hasta Fecha</label>
            <help>Fecha movimiento</help>
          </field>

      </filters>

      <fieldGroup >

            <field id="id_stkmovimiento" _noshow="true" />

            <field id="id_stkarticulo" tabla="STK_ARTICULOS" >
              <label>Codigo Articulo</label>
              <helper type="external" xml="stkarticulo_qry.xml" dir="/ayudas">
                <field id="wstklista_id" local="true">
                  <valor>1</valor>
                </field>
              </helper>
              <apreparam campo="id_stkarticulo" operador="=">true</apreparam>
            </field>

            <field id="codigo_barra"  tabla="STK_ARTICULOS">
              <label>Codigo Barra</label>
              <helper type="external" xml="stkarticulo_pos.xml" dir="/ayudas">
                <field id="wstklista_id" local="true">
                  <valor>1</valor>
                </field>
              </helper>
            </field>

            <field id="nombre_articulo" tabla="STK_ARTICULOS">
              <label modpos="nobr">Nombre</label>
              <help>Referencia del movimiento</help>
            </field>

            <field id="stkconcepto_id" noshow="true">
              <helper type="combo" xml="stkconcepto_qry.xml" dir="/ayudas" empty="true"></helper>
              <label>Concepto</label>
              <help>Código de concepto</help>
              <detalle>concepto_id</detalle>
            </field>

            <field id="nombre_concepto" tabla="STK_CONCEPTOS" print="false">
              <label>Concepto</label>
              <help>Codigo de concepto</help>
            </field>

            <field id="entrada" local="true" suma="true" noZero="true">
              <label>Entrada</label>
              <expression>
                CASE WHEN STK_CONCEPTOS.tipo_concepto = 0 THEN cantidad ELSE 0 END
              </expression>
              <tipo>numeric</tipo>
            </field>

            <field id="salida" local="true" suma="true" noZero="true">
              <label>Salida</label>
              <expression>
                CASE WHEN STK_CONCEPTOS.tipo_concepto = 1 THEN cantidad ELSE 0 END
              </expression>
              <tipo>numeric</tipo>
            </field>

            <field id="precio_total" suma="true" noZero="true">
              <label>Importe</label>
              <tipo>numeric</tipo>
            </field>

            <field id="stkdeposito_id">
              <label>Deposito</label>
              <helper type="combo" xml="stkdeposito_qry.xml" dir="/ayudas" empty="true"></helper>
            </field>

            <field id="stkfamilia_id" noshow="true" tabla="STK_ARTICULOS">
              <label>Familia</label>
              <helper type="combo" xml="stkfamilia_qry.xml" dir="/ayudas" empty="true"></helper>
              <apreparam campo="stkfamilia_id" operador="=">true</apreparam>
            </field>

            <field id="stkrubro_id" noshow="true" tabla="STK_ARTICULOS">
              <label>Rubro</label>
              <helper type="combo" xml="stkrubro_qry.xml" dir="/ayudas" empty="true"></helper>
              <actualiza>
                <field destino="stkrubro_id" id="stksubrubro_id"/>
              </actualiza>
              <apreparam campo="stkrubro_id" operador="=">true</apreparam>
            </field>

            <field id="stksubrubro_id" tabla="STK_ARTICULOS">
              <label modpos="nobr">SubRubro</label>
              <helper type="combo" xml="stksubrubro_qry.xml" dir="/ayudas" empty="true" />
              <apreparam campo="subrubro_id" operador="=">true</apreparam>
            </field>

            <field id="fecha_movimiento">
              <label>Fecha</label>
              <help>Fecha movimiento</help>
              <tipo>date</tipo>
            </field>




            <field id="referencia">
              <label>referencia</label>
              <help>Referencia del movimiento</help>
            </field>


            <field id="puesto_movimiento" noshow="true">
              <label>P.Venta</label>
              <helper type="combo" id="REG_NUMERADORES" empty="true">
                <field id="puesto" />
                <field id="nombre_puesto">
                  <expression>LPAD(puesto,4,'0')</expression>
                </field>
                
              </helper>
                  
            </field>

            <field id="comprobante" local="true" deshabilitado="true">
              <label>Comprobante</label>
              <expression>
                CONCAT((LPAD(STK_MOVIMIENTOS.puesto_movimiento,4,0)),'-',(LPAD(STK_MOVIMIENTOS.numero_movimiento,8,0)))
              </expression>
            </field>

            

            <field id="nombre_cuenta" tabla="REG_CUENTA">
              <label modpos="nobr">Cuenta</label>
            </field>

            <field id="regcuentavendedor_id" tabla="REG_MOVIMIENTOS"  colspan="3">
              <label>Vendedor</label>
              <helper type="combo" xml="regcuenta_simple_qry.xml" dir="/ayudas" empty="true">
                <field id="id_regcuenta" esClave="true" oculto="true" />
                <field id="subsistema_id" oculto="true">
                  <condicion operador="=">22</condicion>
                </field>
                <order>
                  <field id="nombre_cuenta" />
                </order>
              </helper>
            </field> 



            <field id="fecha_mov1" noshow="true">
              <expression having="false">STK_MOVIMIENTOS.fecha_movimiento</expression>
              <help>Fecha movimiento</help>
              <apreparam campo="fecha_movimiento" operador="&gt;=">true</apreparam>
              <tipo>date</tipo>
            </field>

            <field id="fecha_mov2" noshow="true">
              <expression having="false">STK_MOVIMIENTOS.fecha_movimiento</expression>
              <help>Fecha movimiento</help>
              <apreparam campo="fecha_movimiento" operador="&lt;=">true</apreparam>
              <tipo>date</tipo>
            </field>

            <field id="color" local="true" clasefila="true" noshow="true"/>

            <field id="recibido_compra" local="true" noshow="true"></field>

      </fieldGroup>


      <group>
        <field id="id_stkmovimiento"/>
      </group>

    </table>

    <join tipo="left">
      <table id="STK_CONCEPTOS">
        <field id="id_stkconcepto">
          <condicion operador="=">STK_MOVIMIENTOS.stkconcepto_id</condicion>
        </field>
      </table>
    </join>
    
    <join tipo="left">
      <table id="STK_ARTICULOS">
        <field id="id_stkarticulo">
          <condicion operador="=">STK_MOVIMIENTOS.stkarticulo_id</condicion>
        </field>
      </table>
    </join>
    
    <join tipo="left">
      <table id="REG_CUENTA">
        <field id="id_regcuenta">
          <condicion operador="=">STK_MOVIMIENTOS.regcuenta_id</condicion>
        </field>
      </table>
    </join>

    <join tipo="left">
      <table id="REG_DETALLES">
        <field id=" id_regdetalle">
          <condicion operador="=">STK_MOVIMIENTOS.regdetalle_id</condicion>
        </field>
      </table>
    </join>

    <join tipo="left">
      <table id="REG_MOVIMIENTOS">
        <field id="id_regmovim">
          <condicion operador="=">REG_DETALLES.regmovim_id</condicion>
        </field>
      </table>
    </join>

  </form>
</histrix>
