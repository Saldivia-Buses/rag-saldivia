<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="chart" >
	<title>Dias de Entrega</title>
	<obs/>
	<form  >
		<table id="GEN_CALENDAR">
			<grafico id="DiasEntrega" >
				<ancho>400</ancho>
				<tipo>L</tipo>
				<etiquetas>mes</etiquetas>
				<serie>dias_entrega</serie>
				<title>Entrega</title>
			</grafico>
			<filters>
				<field id="fecha">
					<operador>&gt;=</operador>
					<label>Desde Fecha</label>
					<help>Fecha movimiento</help>
					<valor eval="true">date('01/01/Y')</valor>
				</field>
				<field id="fecha">
					<operador>&lt;=</operador>
					<label _modpos="nobr">Hasta Fecha</label>
					<help>Fecha movimiento</help>
					<valor>today</valor>
				</field>
			</filters>
			<field id="mes" oculto="true">
				<expression>month(GEN_CALENDAR.fecha)</expression>
				<label>Mes</label>
				<options>
					<option valor="1">Ene</option>
					<option valor="2">Feb</option>
					<option valor="3">Mar</option>
					<option valor="4">Abr</option>
					<option valor="5">May</option>
					<option valor="6">Jun</option>
					<option valor="7">Jul</option>
					<option valor="8">Ago</option>
					<option valor="9">Sep</option>
					<option valor="10">Oct</option>
					<option valor="11">Nov</option>
					<option valor="12">Dic</option>
				</options>
				<tipo>varchar</tipo>
			</field>
			<field id="fecha" oculto="true">
				<tipo>date</tipo>
			</field>
			<field id="year" oculto="true">
				<expression>year(GEN_CALENDAR.fecha)</expression>
			</field>

			<field id="dias_entrega" local="true">
				<label>Dias de entrega</label>
				<expression><![CDATA[
					ROUND((SELECT  
					SUM(datediff( ifnull(conciliado , now()) , REG_MOVIMIENTOS.fecha_movimiento)) 
					FROM REG_MOVIMIENTOS 
					where REG_MOVIMIENTOS.regestado_id IN (10, 11)
					and ( ( REG_MOVIMIENTOS.fecha_movimiento >= GEN_CALENDAR.fecha and REG_MOVIMIENTOS.fecha_movimiento <= LAST_DAY(GEN_CALENDAR.fecha) ) ) 
					and ( ( REG_MOVIMIENTOS.concepto_id = 47) )) 
					/
					(SELECT COUNT(*)
					FROM REG_MOVIMIENTOS
					where REG_MOVIMIENTOS.regestado_id IN (10, 11)
					and ( ( REG_MOVIMIENTOS.fecha_movimiento >= GEN_CALENDAR.fecha and REG_MOVIMIENTOS.fecha_movimiento <= LAST_DAY(GEN_CALENDAR.fecha)) ) 
					and ( ( REG_MOVIMIENTOS.concepto_id = 47) )), 2)
				]]>
				</expression>
				<tipo>numeric</tipo>
			</field>

			<group>
				<field id="year" />
				<field id="mes" />
			</group>
		</table>
	</form>
</histrix>