		<!--
	            <field id="variacion_costo" noshow="true">
		            <label>% Variación Cotiz.</label>
		            <expression>round(  (costo_proveedor - @costo_ant) / @costo_ant * 100,2)</expression>
		            <tipo>decimal</tipo>
	            </field>

	            <field id="variacion_costo_fin">
		            <label>% Var Cotiz. Final</label>
		            <expression>round( ( @costofinal_local_desc - @costofinal_ant) / @costofinal_ant * 100,2)</expression>
		            <tipo>decimal</tipo>
	            </field>

	            <field id="fecha">
	                <label>Modificado</label>
	                <expression>ultimo_cambio</expression>
	                <tipo>date</tipo>
	            </field>
		    -->
	            <field id="ultimo_cambio" deshabilitado="true" valauto="true" colstyle="display:none;" modpos="nobr">
	                <label>Hora de Cambio</label>
	                <valor eval="true">date('Y-m-d H:i:s')</valor>
	                <size>40</size>
	            </field>

	            <field id="dias_vigencia" colstyle="display:none;">
	                <label>Vigencia (dias)</label>
	                <help>Dias de Vigencia</help>
	            </field>
<!--
	            <field id="vencim" colstyle="display:none;" modpos="nobr">
	                <label>Vencimiento</label>
	                <expression>case when dias_vigencia != 0 then DATE_ADD(ultimo_cambio,INTERVAL dias_vigencia DAY) end</expression>
	                <tipo>date</tipo>
	            </field>
-->
	            <field id="observaciones" _colstyle="display:none;">
	                <label>Observaciones</label>
	                <size>100</size>
	            </field>

	            <field id="t_pieza" noshow="true" tabla="STK_ARTICULOS">
	                <label>t_pieza</label>
	            </field>

	            <field id="tipo_pieza" noshow="true">
	                <expression>t_pieza</expression>
	                <options>
	                    <option valor=""></option>
	                    <option valor="1">Si</option>
	                    <option valor="0">No</option>
	                </options>
	            </field>

                <field id="fabricacion_propia" noshow="true" tabla="STK_ARTICULOS">
                    <options>
                        <option valor=""></option>
                        <option valor="1">Si</option>
                        <option valor="0">No</option>
                    </options>
                </field>

	            <field id="colores" noshow="true" clasefila="true">
	                <expression>case when dias_vigencia != 0 and DATE_ADD(ultimo_cambio,INTERVAL dias_vigencia DAY) &lt; now() or (costo_proveedor = 0) then 'error' end</expression>
	            </field>

		    <field id="grabar" noshow="false" local="true">
			<label>grabar</label>
			<tipo>check</tipo>
			<valor>1</valor>
		    </field>
	        </fieldGroup>
        
        </table>

        <join>
            <table id="STK_ARTICULOS">
                <field id="id_stkarticulo">
                    <condicion operador="=">stkarticulo_id</condicion>
                </field>
                <field id="subsistema_id">
                    <condicion operador="=">'01'</condicion>
                </field>
                <field id="baja_articulo">
                    <condicion operador="=">0</condicion>
                </field>                
            </table>
        </join>

        <join tipo="left">
            <table id="REG_CUENTA">
                <field id="id_regcuenta">
                    <condicion operador="=">STK_COSTO_REPOSICION.regcuenta_id and STK_COSTO_REPOSICION.regcuenta_id != 0 </condicion>
                </field>
            </table>
        </join>
        
        <join tipo="left">
            <table id="CTBCUENT">
                <field id="ctbcod" >
                    <condicion operador="=">STK_ARTICULOS.cuentadebe_id</condicion>
                </field>
            </table>
        </join> 

    </form>
</histrix>  