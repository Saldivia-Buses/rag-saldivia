<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="list" path="fotos/articulos">
    <title>Fotos por Artículo</title>
    <obs></obs>
    <form >
        <table id="STK_ARTICULO_FOTO" label="Articulo Fotos">
            <field id="id_foto" autoinc="true" noshow="true">
            </field>

            <field id="stkarticulo_id" oculto="true">
                <label>Articulo</label>
                <help>Codigo de Articulo</help>
                <tipo>varchar</tipo>
            </field>
            <field  id="foto"  path="stkarticulo_id" >
                <label>Foto</label>
                <help>Foto del Articulo</help>
                <size>70</size>
                <tipo >file</tipo>
            </field>
        </table>
    </form>
</histrix>