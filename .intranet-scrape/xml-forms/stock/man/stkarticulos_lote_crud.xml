<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="crud" paginar="100" borra="false" preloadData="true">
    <title>Ingreso de Artículos por lote</title>
    <obs></obs>
    <form>
        <table id="STK_ARTICULOS" label="Ingreso de Artículos por lote">
            <filters>
                <field id="id_stkarticulo">
                    <label>Codigo</label>
                    <operador>=</operador>
                </field>
            </filters>

            <field id="id_stkarticulo">
                <label>Codigo</label>
                <help>Codigo de Articulo</help>
            </field>

            <field id="nombre_articulo" >
                <label modpos="nobr" colspan="4">Descripcion</label>
                <help>Descripcion de Articulo</help>
            </field>
            <field id="codigo_barra">
                <label>Cod Barras</label>
                <help>Codigo de Barras</help>
            </field>
            <field id="cantidad_pack">
                <label modpos="nobr">Cant. x Caja</label>
                <help>Cantidad por caja</help>
            </field>
            <field id="stkrubro_id" deshabilitado="true">
                <attribute id="deshabilitado">deshabilita_rubro</attribute>
                <label>Rubro</label>
                <helper type="combo" xml="stkrubro_qry.xml" dir="/ayudas" empty="true" ></helper>
                <actualiza>
                    <field id="stksubrubro_id" destino="stkrubro_id" />
                </actualiza>
            </field>
            <field id="nombre_subrubro" Formstyle="display:none;">
                <label modpos="nobr">Sub-Rubro</label>
                <expression>STK_SUBRUBROS.nombre_subrubro</expression>
            </field>
            <field id="stksubrubro_id" colstyle="display:none;">
                <label modpos="nobr">SubRubro</label>
                <helper type="combo" xml="stksubrubro_qry.xml" dir="/ayudas" empty="true" >
                    <field id="stkrubro_id" oculto="true">
                        <condicion operador="=">-1</condicion>
                    </field>
                </helper>
            </field>
            <field id="stkfamilia_id" required="true" noZero="true">
                <label modpos="nobr">Familia</label>
                <helper type="combo" xml="stkfamilia_qry.xml" dir="/ayudas" empty="true" />
            </field>
            <field id="stkmarca_id" noZero="true">
                <label modpos="nobr">Marca</label>
                <helper type="combo" xml="stkmarca_qry.xml" dir="/ayudas" empty="true" />
            </field>

            <fieldGroup noshow="true">
                <field id="no_listar" valauto="true">
                    <valor default="true">0</valor>
                </field>
                <field id="trazable" valauto="true">
                    <valor default="true">0</valor>
                </field>
                <field id="recLote" valauto="true">
                    <valor default="true">0</valor>
                </field>
                <field id="genmoneda_origen_id" valauto="true">
                    <valor default="true">1</valor>
                </field>
                <field id="gravado" valauto="true">
                    <valor default="true">0</valor>
                </field>
                <field id="ivaregimen_id" valauto="true">
                    <valor default="true">1</valor>
                </field>
                <field id="genmoneda_venta_id" valauto="true">
                    <valor default="true">1</valor>
                </field>
                <field id="valor_compra" valauto="true">
                    <valor default="true">1</valor>
                </field>
                <field id="valor_uso" valauto="true">
                    <valor default="true">1</valor>
                </field>
                <field id="baja_articulo" valauto="true">
                    <condicion operador="!=">1</condicion>
                    <valor default="true">0</valor>
                </field>
                <field id="deshabilita_rubro" local="true" valauto="true">
                    <helper type="parameter" id="SIS::STK_deshabilita_rubro::">
                        <label>Deshabilita Rubro</label>
                        <defaultValue>true</defaultValue>
                    </helper>
                </field>
            </fieldGroup>
            <field id="precios_listas" local="true" noshow="true">
                <label>Precios</label>
                <helper type="object" xml="stkarticulos_lote_precios_crud.xml">
                    <parameter source="id_stkarticulo" target="stkarticulo_id" />
                </helper>
            </field>
            <order>
                <field id="nombre_articulo" tabla="STK_ARTICULOS" />
            </order>
        </table>

        <join tipo="left">
            <table id="STK_SUBRUBROS">
                <field id="id_stksubrubro">
                    <condicion operador="=">STK_ARTICULOS.stksubrubro_id</condicion>
                </field>
            </table>
        </join>

    </form>
</histrix>