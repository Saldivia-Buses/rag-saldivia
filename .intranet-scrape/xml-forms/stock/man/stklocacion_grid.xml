<?xml version="1.0" encoding="UTF8"?>
<histrix tipo="list" borra="false" grid="90%">
  <titulo>Locación</titulo>
  <obs/>
  <form>
    <table id="STK_LOCACION">
      <title>Depósitos</title>
      <field id="id_stklocacion" noshow="true" autoinc="true" />

      <field id="stkdeposito_id" oculto="true" />
      
      <field id="codigo_locacion">
        <label>Código Locación</label>
      </field>
<!--
	<field id="movil" >
	    <label>Es Movil(carro)</label>
	    <tipo>check</tipo>
	</field>
-->

      <field id="articulos" _style="width:200px; text-align:left;padding-left:25%;">
        <label>Artículos</label>
        <attribute id="linkdes">nombre_locacion</attribute>
        <helper xml="stkarticulo_locacion_crud.xml" type="link" width="90%">
          <parameter source="id_stklocacion" target="stklocacion_id" />
        </helper>
        <expression having="false">(select group_concat(concat( stkarticulo_id, ':   ' , stock_actual) separator '&lt;br&gt;') from STK_ARTICULO_LOCACION  join STK_ARTICULOS on stkarticulo_id = id_stkarticulo where stklocacion_id = id_stklocacion and ( stock_actual &gt; 0 or  stklocacion_fija_id = id_stklocacion) )</expression>
        <!-- <expression>(case when (select count(*) from STK_ARTICULO_LOCACION WHERE stklocacion_id = id_stklocacion and (stock_actual &gt; 0 )) > 3 
                         then concat((select count(*) from STK_ARTICULO_LOCACION WHERE stklocacion_id = id_stklocacion and stock_actual &gt; 0) , ' Artículos')
                        else ifnull((select group_concat(concat( stkarticulo_id, ':   ' , stock_actual) separator '&lt;br&gt;') from STK_ARTICULO_LOCACION where stklocacion_id = id_stklocacion and stock_actual &gt; 0),0) end)</expression> codigo luis-->
        <!--<condicion operador="&gt;">0 or ((SELECT count(*) from STK_ARTICULOS where stklocacion_fija_id = id_stklocacion) != 0)</condicion>  -->
        <condicion operador="&gt;">''</condicion> 
      </field>

    	<order>
          <field id="codigo_locacion" />
    	</order>
    </table>
  </form>
</histrix>
