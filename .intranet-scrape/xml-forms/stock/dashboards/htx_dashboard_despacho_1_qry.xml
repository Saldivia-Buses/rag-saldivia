<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta">
  <title>Dashboard</title>
  <form>
    <table id="HTX_DASHBOARD">
    <filters>
	<field id="DESPACHADO">
	    <label>Despachado</label>
	</field>
    </filters>
	<field id="DESPACHADO" local="true" noshow="true">
	    <helper type="combo" id="REG_CATEGORIAS" empty="true">
		<field id="id_regcategoria" />
		<field id="nombre_categoria" />
		<field id="subsistema_id">
		    <condicion operador="=">'TR'</condicion>
		</field>
	    </helper>
	    <label>Despachado</label>
	</field>
      <fieldGroup>
        <field id="id_dash" autoinc="true" noshow="true">
		    </field>
        <field id="group_dash" noshow="true">
        </field>
        <field id="subgroup_dash" noshow="true">
        </field>

        <field id="enable_dash" noshow="true">
          <condicion operador="=">1</condicion>
        </field>
        <field id="title_dash" style="font-size:1.5em;">
          <label>Título</label>
        </field>
        <field id="unit_dash">
          <label>Unidad</label>
          <helper type="combo">
          <option value="1">%</option>
          <option value="2">$</option>
          <option value="3">Unid. diaria</option>
          <option value="4">Dias</option>
        </helper> 
        </field>
        <field id="objective_dash" style="font-size:1.5em;">
          <label>Objetivo</label>
        </field>
        <field id="formula_dash" noshow="true">
          <label>Formula</label>
          <size>200</size>
        </field>
        <field id="flag_dash" noshow="true">
    	  <label>Flag</label>
    	</field>
        <field id="ID_FACTURAS" noshow="true">
          <expression>(select option_value from HTXOPTIONS where option_name ='ID_FACTURAS')</expression>
        </field>
        <field id="orden_dash" noshow="true" />
      </fieldGroup>
      <fieldGroup repeat="12">
        <field id="fecha_ini" local="true" noshow="true">
          <label>Fecha_ini</label>
          <if exp="true">
            <true>date('Y-'.str_pad(__repeat__,2,'0', STR_PAD_LEFT).'-01')</true>
            <false>0</false>
          </if>
          <tipo>date</tipo>
        </field>
        <field id="fecha_fin" local="true" noshow="true">
          <label>Fecha_fin</label>
          <if exp="true">
            <true>date('Y-m-t', strtotime(date('Y-'.str_pad(__repeat__,2,'0', STR_PAD_LEFT).'-01')))</true>
            <false>0</false>
          </if>
          <tipo>date</tipo>
        </field>
        <field id="For" local="true" noshow="true">
          <if exp="true">
            <true>'formula_dash'</true>
            <false>0</false>
          </if>
          <size>200</size>   
        </field>             <!--
                         
        <field id="attr" _noshow="true" local="true">
    		<expression sql="true">SELECT 
    		CASE [__flag_dash__] 
    		WHEN 0 THEN ''
    		WHEN 1 THEN 
    			CASE WHEN 
    			    (((([__For___repeat____])-[__objective_dash__])/[__objective_dash__])*100) &gt; 10 THEN 'background-color:green;'
    			ELSE
    			    CASE WHEN
        			(((([__For___repeat____])-[__objective_dash__])/[__objective_dash__])*100) &lt; -10 THEN 'background-color:red;'
        		    ELSE 'Y'
    				END
        	        END
    			WHEN 2 THEN
        	        
        	        CASE WHEN 
			    (((([__For___repeat____])-[__objective_dash__])/[__objective_dash__])*100) &gt; 10 THEN 'background-color:red;'
    			ELSE
    			    CASE WHEN
        		        (((([__For___repeat____])-[__objective_dash__])/[__objective_dash__])*100) &lt; -10 THEN 'background-color:green;'
        		    ELSE 'background-color:yellow;'
        		    END
        		END                            
        	
        	END
        	
        	</expression>
    		<label>attr</label>
    	</field>        --> 
    	
    	<field id="ver" noZero="true">
          <label>Mes</label>
          <expression sql="true">[__For___repeat____]</expression>
          <tipo>numeric</tipo>
        </field>
        
      </fieldGroup>
      <order>
        <field id="orden_dash"/>
        <field id="group_dash"/>
        <field id="subgroup_dash"/>
      </order>
    </table>
  </form>
</histrix>
