<?xml version="1.0" encoding="ISO-8859-1"?>
<histrix tipo="consulta" _limit="50">
	<title>Rubros</title>
	<obs></obs>
	<form >
		<table id="REG_CUENTA" label="Rubros por Proveedor">
		    <field id="id_regcuenta" noshow="true"/>
		    <field id="subsistema_id" noshow="true"/>
		    <field id="nro_cuenta" norepeat="true">
			<label>Cod</label>
		    </field>
		    <field id="nombre_cuenta" norepeat="true">
			<label>Nombre</label>
		    </field>

		    <field id="stksubrubro_id" tabla="STK_ARTICULOS" noshow="true">
			<condicion operador="!=">''</condicion>
		    </field>

		    <field id="nombre_rub">
			<expression>CONCAT(STK_RUBROS.id_stkrubro,'-',STK_RUBROS.nombre_rubro)</expression>
			<label>Rubro</label>
		    </field>
	    
		    <field id="nombre_sub">
			<expression>CONCAT(STK_SUBRUBROS.id_stksubrubro,'-',STK_SUBRUBROS.nombre_subrubro)</expression>
			<label>Sub Rubro</label>
		    </field>

		    <field id="baja_cuenta" noshow="true">
			<condicion operador="=">'0000-00-00'</condicion>
		    </field>

		    <group>
			<field id="id_regcuenta" />
			<field id="stksubrubro_id" />
		    </group>

		    <order>
			<field id="nombre_cuenta" />
			<field id="nro_cuenta" />
			<field id="nombre_sub" tabla="STK_SUBRUBROS" />
		    </order>
		</table>
		<join tipo="left">
		    <table id="STKINMOV">
			<field id="movcod">
			    <condicion operador="=">1</condicion>
			</field>
			<field id="siscod">
			    <condicion operador="=">REG_CUENTA.subsistema_id</condicion>
			</field>
			<field id="ctacod">
			    <condicion operador="=">REG_CUENTA.nro_cuenta</condicion>
			</field>
		    </table>
		</join>
		<join tipo="left">
		    <table id="STK_ARTICULOS">
			<field id="id_stkarticulo">
			    <condicion operador="=">STKINMOV.artcod</condicion>
			</field>
			<field id="subsistema_id">
			    <condicion operador="=">STKINMOV.siscod</condicion>
			</field>
		    </table>
		</join>
		<join tipo="left">
		    <table id="STK_RUBROS">
			<field id="id_stkrubro">
			    <condicion operador="=">STK_ARTICULOS.stkrubro_id</condicion>
			</field>
		    </table>
		</join>
		<join tipo="left">
		    <table id="STK_SUBRUBROS">
			<field id="id_stksubrubro">
			    <condicion operador="=">STK_ARTICULOS.stksubrubro_id</condicion>
			</field>
		    </table>
		</join>
	</form>
</histrix>
