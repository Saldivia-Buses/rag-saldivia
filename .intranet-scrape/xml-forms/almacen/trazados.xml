<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" PDForientacion="L">
	<title>Insumos Trazados</title>
	<obs/>
	<form >
		<table id="STKINMOV" label="ENTRADA SALIDA STOCK">
			<field id="nrocha">
				<label>Num.Fabric</label>
				<tipo>integer</tipo>
				<help>Nro de Fabricacion</help>
				<preparam operador="=">true</preparam>
			</field>
			
			<field id="movfec">
				<label>Fecha Salida</label>
				<help>Fecha Salida</help>
			</field>

			
			<field id="siscod" oculto="true">
				<label>Codigo Sistema.. </label>
				<help>
				</help>
				<condicion operador="=">'01' and LENGTH(barcode) > 7</condicion>
				
			</field>
			<!--
			<field id="movref">
				<label>Referencia . </label>
				<help>
				</help>
				<format>%10s</format>
			</field>
			-->
			<field id="artcod">
				<label>Articulo</label>
				<help>Codigo de Articulo. </help>
			</field>
			<field id="artdes" tabla="STKINSUM">
				<label>Descripcion</label>
				<tipo>varchar</tipo>
			</field>
			<field id="opecod" oculto="true">
			</field>

			<field id="barcode">
				<label>Número de Serie</label>
				<help>Número de Serie</help>
				<helper type="link" xml="herramientas_ficha.xml">
				    <parameter source="barcode" target="id_herramienta" />
				    <parameter source="artcod" target="artcod" />
				    <parameter source="2" target="grucod" />
				</helper>
			</field>
			<field id="ctacod" noshow="true"  tabla="CCTCUENT">  
			</field>
			
			<field id="ctafan" tabla="CCTCUENT"> 
				<label>Prov</label>
				<tipo>varchar</tipo>
			</field>
<!--			<field id="nrofac" tabla="FACDETAL">
			    <label>Factura</label>
			    <help>Factura</help>
			</field>					
			-->
							
			<field id="ocpnro" tabla="HERRAMIENTAS" linkint="cpsencab_cabreimp.xml" linkdes="O.Compra" linkdir="/compras">
			    <paring destino="ocpnro" operador="=">ocpnro</paring>
			    <paring destino="ctacod" operador="=">ctacod</paring>
			    
			    
				<label>O.Compra</label>
			</field> <!--
			<field id="ocpfec" tabla="HERRAMIENTAS">
				<label>Fec O.C.</label>
				<tipo>date</tipo>
			</field>			-->			
			<field id="remito" > 
				<expression>case when HERRAMIENTAS.remnro = 0 then (select FACREMIT.remnro from FACREMIT where FACREMIT.ocpnro = HERRAMIENTAS.ocpnro and FACREMIT.ocpfec = HERRAMIENTAS.ocpfec limit 1) else HERRAMIENTAS.remnro end </expression>
				<label>Remito</label>
				<tipo>integer</tipo>
			</field>						
			<field id="nrofac" _tabla="FACDETAL">
				<expression sql="true">select FACDETAL.nrofac from FACDETAL where FACDETAL.remnro = ([__remito__] + 0) limit 1 </expression>
				<tipo>integer</tipo>
			    <label>Factura</label>
			    <help>Factura</help>
			</field>					
			
			<field id="remfec" tabla="HERRAMIENTAS">
				<label>Fec Rem</label>
				<tipo>date</tipo>
			</field>								
			<filters>
				<field id="artcod" deshabilitado="false">
					<ayuda_ex id="STKINSUM">
						<clave>artcod</clave>
						<descripcion>artdes</descripcion>
					</ayuda_ex>
					
					<label>Cod.</label>
					<operador  modificador="left">=</operador>					
				</field>			
				<field id="artdes" >
					<label>Articulo</label>
					<help>Descripcion de Articulo</help>
					<operador>like</operador>
				</field>					
				<field id="nrocha" >
					<operador>=</operador>
					<label>Nro de Fabricacion</label>
					<valor>0</valor>
					
				</field>				

			</filters>

			<group>
		        <field id="nrocha" ></field>
		        <field id="artcod" tabla="STKINMOV"></field> 
		        <field id="opecod" tabla="STKINMOV"></field> 
		        <field id="barcode" ></field> 
		     </group> 

			<order>
				<field id="artdes"/>
			</order>
		</table>
		
		<join tipo="left">
			<table id="STKINSUM">
				<field id="siscod" oculto="true">
					<condicion operador="=">'01'</condicion>
					
				</field>
				<field id="artcod" oculto="true">
					<condicion operador="=">STKINMOV.artcod</condicion>
				</field>
			</table>
		</join>

		<join tipo="left">
			<table id="HERRAMIENTAS">
				<field id="artcod" >
					<condicion operador="=">STKINMOV.artcod</condicion>
					
				</field>
				<field id="grucod" >
					<condicion operador="=">2</condicion>
				</field>
				
				<field id="id_herramienta" >
					<condicion operador="=">STKINMOV.barcode</condicion>
				</field>
			</table>
		</join>
		<join tipo="left">
			<table id="CCTCUENT">
				<field id="ctacod" >
					<condicion operador="=">HERRAMIENTAS.ctacod</condicion>
				</field>
				<field id="siscod" >
					<condicion operador="=">'01'</condicion>
				</field>
				
			</table>
		</join>		
<!--		<join tipo="left">
			<table id="FACDETAL">
			    <field id="remnro" >
				    <condicion operador="=">(case when HERRAMIENTAS.remnro = 0 then (select FACREMIT.remnro from FACREMIT where FACREMIT.ocpnro = HERRAMIENTAS.ocpnro and FACREMIT.ocpfec = HERRAMIENTAS.ocpfec limit 1) else HERRAMIENTAS.remnro end)</condicion>
				    
			    </field>
			</table>
		</join> -->
	</form>
</histrix>
