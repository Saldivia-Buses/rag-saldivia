<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="abm-mini">
	<title>HORARIOS de Ingreso/Egreso</title>
	<obs></obs>
	<form >
		<table id="HORARIOHIST" >
			<title>Horarios</title>
			<field id="desdeFecha">
				<label>Desde Fecha</label>
				<help>Fecha de Vigencia</help>
			</field>
			<field id="horario" oculto="true">
				<label>cod de ingreo</label>
				<help>Descripcion Horario</help>
			</field>
			<field id="ingreso">
				<label>Ingreso</label>
				<help>Hora de Ingreso</help>
			</field>
			<field id="egreso">
				<label>Egreso</label>
				<help>Hora de Egreso</help>
			</field>
			<field id="ingresoPremio">
				<label>Ingreso Premio</label>
				<help>Hora de Ingreso</help>
			</field>
			<field id="egresoPremio">
				<label>EgresoPremio</label>
				<help>Hora de Egreso</help>
			</field>
			
			
			<field id="dia">
				<label>Dia</label>
				<help>Día de la Semana</help>
                <options>
                 <option valor="1">Domingo</option>
                 <option valor="2">Lunes</option>
                 <option valor="3">Martes</option>
                 <option valor="4">Miércoles</option>
                 <option valor="5">Jueves</option>
                 <option valor="6">Viernes</option>
                 <option valor="7">Sábado</option>
                </options>
			</field>
			<field id="extras50">
				<label>Max. Extras 50%</label>
				<help>Cantidad máxima de horas extras al 50%</help>
			</field>

			<order>
                <field id="desdeFecha"></field>
                <field id="dia"></field>

			</order>
		</table>
	</form>	   
</histrix> 