		</table>
		<join tipo="left">
			<table id="CCTCUENT">
				<field id="siscod" oculto="true">
					<condicion operador="=">'01'</condicion>
				</field>				
				<field id="ctacod" >
					<condicion operador="=">RETIVA.ctacod</condicion>
				</field>
			</table>
		
		</join>
		<join tipo="left">
			<table id="CCTMOVIM">
				<field id="siscod" oculto="true">
					<condicion operador="=">'01'</condicion>
				</field>				
				<field id="ctacod" >
					<condicion operador="=">RETIVA.ctacod</condicion>
				</field>
				<field id="movnro">
					<condicion operador="=">RETIVA.movnro</condicion>
				</field>
				<field id="movfec">
					<condicion operador="=">RETIVA.ivafec</condicion>
				</field>
			</table>
		
		</join>
	</form>	   
</histrix> 
