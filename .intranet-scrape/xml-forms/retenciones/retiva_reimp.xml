<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="ficha" sololectura="true" autoprint="true" preFetch="true" path="/fotos/firmas/">
	<title>Retencion de iva</title>
	<obs></obs>
	<form >
		<table id="RETIVA" label="Retencion de iva">
			<field id="ivanro" deshabilitado="true">
				<label posx="5" posy="+4" >Constancia de Retencion Nro</label>
				<help>Numero de la retencion</help>
				<format>%08d</format>
			</field>		
			<field id="ivafec" deshabilitado="true">
				<label posx="100" posy="0" >Fecha</label>
				<help>Fecha de la Retencion</help>
			</field>	
			<field id="lin1" local="true">
			    <label posx="5" posy="+2" size="200">Datos del Agente de Retencion</label>
1			</field>
			<field id="agente" local="true">
			    <label posx="5" posy="+2" size="30">Nombre Agente</label>
			    <expression>select paralf from FSMPARAM where FSMPARAM.parcla = 'empnom' limit 1</expression>
			</field>
			<field id="agentecuit" local="true">
			    <label posx="5" posy="+2" size="30">C.U.I.T.:</label>
			    <expression>select paralf from FSMPARAM where FSMPARAM.parcla = 'cuiemp' limit 1</expression>
			</field>
			<field id="agentedomi" local="true">
			    <label posx="5" posy="+2" size="30">Domicilio:</label>
			    <expression>select group_concat(paralf, ' ') from FSMPARAM where FSMPARAM.parcla in ('empdir', 'emploc', 'emppro')</expression>
			</field>

			<field id="lin2" local="true">
			    <label posx="5" posy="+4" size="200">Datos del Sujeto Retenido</label>
			</field>

<!--		
			<field id="nroag" local="true" deshabilitado="true">
				<label posx="13" posy="27" >Ag.Ret.IIBB Nro</label>
				<valor>'450-002395-0'</valor>
				<tipo>varchar</tipo>
			</field>	-->
			<field id="ctacod" deshabilitado="true" noshow="true" print="false">
				<label  >Cuenta</label>
				<help>Codigo de Cuenta</help>
			</field>
			<field id="ctanom" tabla="CCTCUENT" deshabilitado="true">
				<label colspan="2"   posx="5" posy="+2" size="30">Nombre</label>
				<help>Nombre</help>
			</field>
			
			<field id="ctanro" tabla="CCTCUENT">
				<label colspan="2" posx="5" posy="+2" size="30">C.U.I.T. Nro</label>
				<help>Numero Doc</help>
			</field> 


			<field id="ctadir" tabla="CCTCUENT">
				<label colspan="2" posx="5" posy="+2" size="30">Direccion</label>
				<help>Direccion</help>
			</field>
			<field id="ctaloc" tabla="CCTCUENT">
				<label colspan="2" posx="5" posy="+2" size="30">Localidad</label>
				<help>Localidad</help>
			</field>


			<field id="lin3" local="true">
			    <label posx="5" posy="+4" size="200">Datos de la Retencion</label>
			</field>
			<field id="imp" local="true">
			    <label posx="5" posy="+2" size="30">Impuesto</label>
			    <valor>Retencion de iva</valor>
			</field>
			<field id="cativa" _local="true">
			    <label posx="5" posy="+2" size="30">Regimen</label>
<!-- 			    <valor>217</valor>
 -->			</field>	
			<field id="num">
			    <label posx="5" posy="+2" size="30">Comprobante</label>
			    <expression>concat('OP 0001-', LPAD( RETIVA.movnro,8, '0'))</expression>
			</field>
			<field id="movimp" tabla="CCTMOVIM">
				<label posx="5" posy="+2" size="30">Monto Comprobante</label>
				<tipo>decimal</tipo>
			</field>			
			<field id="ivatot" >
				<label posx="5" posy="+2" size="30">Importe Retencion</label>
				<help>Importe de la Operacion</help>
				<tipo >decimal</tipo>
			</field>		

<field id="firma1" _local="true" >
    <expression>'firma831.jpg'</expression>
    <label posx="80" posy="+2" PDFnoborder="true" PDFsize="15"></label>
<tipo>file</tipo>
    <size>50</size>
</field>

