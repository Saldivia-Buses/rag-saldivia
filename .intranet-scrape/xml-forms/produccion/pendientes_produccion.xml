                    <true>'tipvtn'</true>
                    <false>'#FBEC5D '</false>
                </if>
            </field>
            <field id="vtnpuerta" tabla="PEDCOTIZ" color="true" transparent="true">
                <label size="23" posx="110" posy="0" PDFsize="10">Pta Ascenso</label>
                <help></help>

                <options>
                    <option valor="">#FBEC5D </option>
                    <option valor="0">#FBEC5D </option>
                    <option valor="1">Fija</option>
                    <option valor="2">Movil</option>


                </options>

            </field>
            <field id="luneta" tabla="PEDCOTIZ"  color="true" transparent="true">
                <label size="23" posx="160" posy="0" PDFsize="10" >Luneta</label>
                <options>
                    <option valor="">#FBEC5D </option>
                    <option valor="0">#FBEC5D </option>
                    <option valor="1">Con Vidrio</option>
                    <option valor="2">Ciega</option>
                    <option valor="3">#FBEC5D</option>
                </options>
            </field>
            <field id="calefn" tabla="PEDCOTIZ" color="true" transparent="true">
                <label size="24" posx="5" posy="+1" PDFsize="10">Calef</label>
                <help></help>
                <options>
                    <option valor="">#FBEC5D </option>
                    <option valor="0">No</option>
                    <option valor="1">Si</option>
                </options>

            </field>
            <field id="tipcal" tabla="PEDCOTIZ" color="true" transparent="true">
                <tabla_ex id="TIPCALEF">
                    <field id="tipcal">
                        <label>Codigo</label>
                    </field>
                    <field id="descal">
                        <label>Calefacción</label>
