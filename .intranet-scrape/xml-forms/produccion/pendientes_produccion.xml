        <table id="TURNOSPRODUCCION" label="Programa de Produccion"  showCantidad="false" >
            <filters>

                <field id="sale2" deshabilitado="false">
                    <label>Desde</label>
                    <help>Fecha de Ingreso a Línea</help>
                    <operador>&gt;=</operador>
                    <!-- <valor eval="true">date("d/m/Y", mktime(0, 0, 0, date("m") , date("d")-5, date("Y")))</valor> -->
                    <valor eval="true">date("d/m/Y", mktime(0, 0, 0, date("m") , date("d")-10, date("Y"))) </valor>


                </field>
            </filters>
            <field id="siscli" local="true" oculto="true" >
                <valor>'02'</valor>
            </field>

            <field id="prueba" oculto="true" local="true" >
                <expression>PEDCOTIZ.id</expression>
                <label>id ficha</label>
                <paring destino="ficha_id">prueba</paring>
            </field>

            <field esClave="true" id="fechaing" PDFanchofijo="true" oculto="true">
                <label >Entra</label>
                <help>Fecha de Ingreso a Linea</help>
                <!--	<format>d/m</format> -->

            </field>
            <field id="offset" noshow="true" deshabilitado="true">
                <expression>
                    select count(*) from TURNOSPRODUCCION as TUR where
                    TUR.fechaing &gt;= TURNOSPRODUCCION.fechaing and
                TUR.fechaing &lt;= now()</expression>
                <tipo>integer</tipo>
            </field>
            <field id="sale2" esClave="true" oculto="true">
                <label modpos="nobr" >Terminado</label>

                <expression> select TUR.fechaing from TURNOSPRODUCCION as TUR where
                TUR.fechaing &gt; TURNOSPRODUCCION.fechaing order by TUR.fechaing ASC limit 15, 1</expression>
                <tipo>date</tipo>
                <condicion operador=">=" >now()</condicion>

            </field>
