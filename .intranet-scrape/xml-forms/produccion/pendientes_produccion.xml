            <field deshabilitado="true" id="ctacod" tabla="PEDCOTIZ" linkint="cctconta_consulta.xml" linkdes="Ver medios de Contacto">
                <!--				<expression>PEDCOTIZ.ctacod</expression> -->
                <expression>case when PEDCOTIZ.ctacod != '' then PEDCOTIZ.ctacod else TURNOSPRODUCCION.ctacod end</expression>

                <label >Cliente</label>
                <help>Código de Cuenta</help>
                <tabla_ex condes="true" id="CCTCUENT">
                    <field id="ctacod"/>
                    <field id="ctafan">
                        <expression>LEFT(ctafan,5)</expression>
                    </field>
                    <field id="siscod" oculto="true">
                        <condicion operador="=">'02'</condicion>
                    </field>
                </tabla_ex>
                <paring destino="ctacod">ctacod</paring>
                <paring destino="siscod">siscli</paring>
                <size>25</size>

            </field>

            <field id="tieneFicha" noshow="true">
                <expression>case when PEDCOTIZ.estado_ficha = 1
                and PEDCOTIZ.pedfec != '0000-00-00'
                and PEDCOTIZ.nrocha != 0
                and PEDCOTIZ.ctacod != 0 
                and CHASIS.marcod != 0 
                and CHASIS.modcod != 0 
                and PEDCOTIZ.nrocar != 0 
                and PEDCOTIZ.homologacion_id != '' 
                and (select valor_atributo from PRODUCTO_ATRIB_VALORES where producto_id = id and prdatributo_id = 35) != 0 
                and PEDCOTIZ.tipserv != 0 
                and (select valor_atributo from PRODUCTO_ATRIB_VALORES where producto_id = id and prdatributo_id = 13) != 0 
                and (select valor_atributo from PRODUCTO_ATRIB_VALORES where producto_id = id and prdatributo_id = 14) != 0 
              then 'ficha_producto1_qry.xml' else '' end
              </expression>
            </field>
            

            <field id="nrofab" linkint="fichaventas.xml" linkdes="Ver Ficha de Ventas" >
                <attribute id="linkint">tieneFicha</attribute>
                <label modpos="nobr" style="text-align:center;color:#444;font-weight:bold;">Nro.</label>
                <help>Número de Fabricación</help>
                <ayuda_ex id="CHASIS">
                    <field id="nrocha"/>
                    <field id="chades"/>
                </ayuda_ex>
                <detalle>nrofab</detalle>
            </field>
            <field id="fic" local="true" noshow="true" print="false">
                <valor>'fichaventas_abm.xml'</valor>
                <tip>varchar</tip>
            </field>
            <field id="moddes" tabla="MODCHASIS" color="true" transparent="true">
                <label colspan="6" size="23" posx="110" posy="0" PDFsize="10">Nro Chasis</label>
                <help></help>
                <size>40</size>
                <if exp="'chasis' != ' '">
                    <true>chasis</true>
                    <false>'#FBEC5D '</false>
                </if>
            </field>
            <field deshabilitado="true" id="moddes" local="true" color="true" transparent="true">
                <expression>case when MODCHASIS.moddes != '' then MODCHASIS.moddes else '#FBEC5D' end</expression>
                <label >Mod</label>
                <help/>
                <tipo>varchar</tipo>

            </field>

            <field id="nrocar" color="true" transparent="true" _tabla="PEDCOTIZ">
                <label size="24" posx="5" posy="+1" PDFsize="10">Mod.</label>
                <helper type="combo" id="CARROCERIA">
                    <field id="nrocar"/>
                    <field id="modcar">
                        <expression>RIGHT(modcar,4)</expression>
                    </field>
                </helper>
                <if exp="'nrocar' != 0">
                    <true>nrocar</true>
                    <false>'#FBEC5D '</false>
                </if>
            </field>

            <field id="momentos" local="true" deshabilitado="true" print="false" color="true" transparent="true" noshow="true">
                <label Formstyle="display:none;">Posiciones</label>
                <tabla_ex id="MOMENTO" xml="momento_posiciones.xml" >
                </tabla_ex>
                <if exp="true">
                    <true>offset</true>
                    <false>0</false>
                </if>

                <tipo>varchar</tipo>
            </field>

            <field deshabilitado="true" id="asientos" noZero="true">
                <label>Asi</label>
                <tipo>integer</tipo>
                <expression>HOMOLOGMOD.asientos+1</expression>
                <if exp="asientos != 0">
                    <true>'[__asientos__]'</true>
                    <false>'#FBEC5D'</false>
                </if>
            </field>

            <field id="marasi">
                <expression>atributoUnidad(id, 'marasi')</expression>
                <attribute id="style">faltante</attribute>
                <label>Asientos</label>
                <helper type="combo" id="MARCAASI">
                    <field id="marasi"/>
                    <field id="asides">
                        <expression>LEFT(asides, 4)</expression>
                    </field>
                    <field id="siscod" oculto="true">
                        <condicion operador="=">03</condicion>
                    </field>
                </helper>
               <if exp="marasi + 0 != 0">
                    <true>'[__asientos__]'</true>
                    <false>'#FBEC5D'</false>
                </if>
                <tipo>varchar</tipo>
            </field>

            <field id="tipasi" tabla="PEDCOTIZ" color="true" transparent="true">
                <helper type="combo" xml="tipoasiento.xml">
                    <field id="tipasi"/>
                    <field id="asides">/
                        <expression>SUBSTRING(asides,1,4)</expression>
                    </field>
                    <field id="siscod" oculto="true">
                        <condicion operador="=">03</condicion>
                    </field>
                </helper>
                <label size="24" posx="110" posy="0" PDFsize="10">Tipo As.</label>
                <expression>case when tipasi != 0 then asides else '#FBEC5D ' end</expression>
                <!-- <if exp="'tipasi' != 0">
                    <true>'[__tipasi__]'</true>
                    <false>'#FBEC5D '</false>
                </if> -->
                <tipo>varchar</tipo>
            </field>

            <field id="bagno" deshabilitado="true" noZero="true">
                <label>B</label>
                <expression>atributoUnidad(id, 'bagno')</expression>
                <options>
                    <option valor="0">#FBEC5D</option>
                    <option valor="1">  </option>
                    <option valor="2">BB</option>
                    <option valor="3">#FBEC5D</option>
                </options>
                <tipo>varchar</tipo>
            </field>

            <field id="miniba" deshabilitado="true" color="true" transparent="true">
                <label>Bar.</label>
                <expression>atributoUnidad(id, 'minibar')</expression>
                <options>
                    <option valor="">#FBEC5D </option>
                    <option valor="0">#FBEC5D </option>
                    <option valor="1">No</option>
                    <option valor="2">Si</option>
                </options>
                <tipo>varchar</tipo>
            </field>

            <field id="cucheta">
                <expression>atributoUnidad(id, 'cucheta')</expression>
                <label modpos="nobr">Cuch</label>
                <helper type="combo" xml="prd_helper_propiedades.xml" dir="/produccion" emtpy="true">
                    <field id="campoficha_id">
