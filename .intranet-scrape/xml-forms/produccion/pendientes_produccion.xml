                                <expression>case when PEDCOTIZ.previd = 0 then 'NO' when PEDCOTIZ.previd = 1 then 'prep' when PEDCOTIZ.previd = 2 then (select left(PROVAUDIOVID.nombre, 5) from PROVAUDIOVID where PROVAUDIOVID.idprov = PEDCOTIZ.prvtv  ) end </expression>
                                <tipo>varchar</tipo>
                        </field>
                        <field id="hi" deshabilitado="true" clasefila="true" noshow="true">
