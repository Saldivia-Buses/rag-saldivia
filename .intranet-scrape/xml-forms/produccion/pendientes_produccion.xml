        </table>
        <join tipo="left">
            <table id="PEDCOTIZ">
                <field id="nrocha">
                    <condicion operador="=">TURNOSPRODUCCION.nrofab</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="CHASIS">
                <field id="nrocha">
                    <condicion operador="=">PEDCOTIZ.nrocha</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="MARCAASI">
                <field id="marasi">
                    <condicion operador="=">PEDCOTIZ.marasi</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="MARCAAIR">
                <field id="marair">
                    <condicion operador="=">PEDCOTIZ.marair</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="TIPOCARTEL">
                <field id="idCartel">
                    <condicion operador="=">PEDCOTIZ.tipcartel</condicion>
                </field>
            </table>
        </join>

        <join tipo="left">
            <table id="HOMOLOGMOD">
                <field id="id_homologacion">
                    <condicion operador="=">PEDCOTIZ.homologacion_id</condicion>
                </field>
            </table>
        </join>

        <join tipo="left">
            <table id="POSICAIR">
                <field id="posair">
                    <condicion operador="=">PEDCOTIZ.posair</condicion>
                </field>
            </table>
        </join>

        <join tipo="left">
            <table id="CONCESIONARIO">
                <field id="idconces">
                    <condicion operador="=">(case when CHASIS.conces != '' then CHASIS.conces else TURNOSPRODUCCION.idconces end)</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="MODCHASIS">
                <field id="modcha">
                    <condicion operador="=">CHASIS.modcod</condicion>
                </field>
                <field id="marcod">
                    <condicion operador="=">CHASIS.marcod</condicion>
                </field>
            </table>
        </join>
    </form>
</histrix>
