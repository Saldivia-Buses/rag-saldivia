            <field id="panaNom" tabla="PEDCOTIZ" color="true" transparent="true">
                <expression> CASE WHEN PEDCOTIZ.fotoPana != ' ' THEN (SUBSTRING(REPLACE((TRIM(TRAILING '.jpg' from PEDCOTIZ.fotoPana)),(LEFT(PEDCOTIZ.fotoPana,(LOCATE('/',PEDCOTIZ.fotoPana)))), ' '),1,8))ELSE '#FBEC5D' END</expression>
                <label colspan="8" size="24" posx="5" posy="+1" PDFsize="10">Asiento</label>


            </field>
            <field id="pana" tabla="PEDCOTIZ" color="true" transparent="true">

                <label>Pana</label>
                <expression>CASE WHEN trim(PEDCOTIZ.pana) = ''  THEN '#FBEC5D'
                    ELSE  (CASE WHEN  PEDCOTIZ.pana not like 'S/%' THEN LEFT(PEDCOTIZ.pana,18)  ELSE  '#FBEC5D' END)
                END</expression>
                <!--
                                <if exp="'pana' != ''">
                                        <true>substr('pana', 0,4)."..."</true>
                                        <false>'#FBEC5D '</false>
                                </if>-->
                <tipo>varchar</tipo>
            </field>
            <field id="ninterno" color="true" transparent="true">
                <expression>CASE WHEN isnull(PEDCOTIZ.ninterno) THEN  '#FBEC5D' ELSE (CASE WHEN  PEDCOTIZ.ninterno like 'S/%' THEN '#FBEC5D' ELSE  PEDCOTIZ.ninterno END)END</expression>

                <label>Int</label>
                <help></help>
                <!--<if exp="'ninterno' != ''">
                                        <true>'ninterno'</true>
                                        <false>'#FBEC5D'</false>
                                </if>-->
                <tipo>varchar</tipo>
            </field>


