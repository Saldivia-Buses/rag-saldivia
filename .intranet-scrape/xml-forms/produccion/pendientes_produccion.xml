                    </field>
                </tabla_ex>
                <tipo>varchar</tipo>
            </field>

            <field id="vtnmov" tabla="PEDCOTIZ" color="true" transparent="true">
                <label size="24" posx="5" posy="+1" PDFsize="10">Movil x lado</label>
                <help></help>
                <if exp="'vtnmov' != ''">
                    <true>'vtnmov'</true>
                    <false>'#FBEC5D '</false>
                </if>
                <helper type="combo" xml="prd_helper_propiedades.xml" dir="/produccion" emtpy="true">
                    <field id="campoficha_id">
                        <condicion operador="=">'cant_ventanas'</condicion>
                    </field>
                </helper>
            </field>
            
            <field id="tipvtn" tabla="PEDCOTIZ" color="true" transparent="true">
