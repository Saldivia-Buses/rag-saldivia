            <field id="accesorios"  linkint="cotiz_accesorios_coche_foto_cons2.xml" linkdir="/cotizacion" _linkint="accesorios_coche_qry.xml" deshabilitado="true" style="width:auto;" linkdes="Adicionales" noZero="true" print="false">
                   <expression>select sum(ifnull(precio_unitario,0) * cantidad) from ACCESORIOS_COCHE AS ACC where (estado != 2 and estado != 3) and ACC.ficha_id = PEDCOTIZ.id</expression>
                <label modpos="nobr" Formstyle="display:none;" style="color:#444;font-weight:bold;" print="false">Adicionales</label>
                <paring destino="ficha_id">PEDid</paring>
                <paring destino="showprecios">1</paring>
            </field>
      
      <field id="emails" _showTablaObj="true" local="true" print="false">
        <helper type="link" xml="contaemail_qry.xml" dir="/email">
          <parameter target="subject" source="subj2" operator="like"/>
        </helper>
        <label Formstyle="display:none;">Mail</label>
        <help></help>
        <expression sql="true"><![CDATA[select CONCAT(RIGHT(fecha, 2), '/', SUBSTRING(fecha, 6, 2)) from HTXMAIL where match(subject, body) against('[__subj__]' IN BOOLEAN MODE) limit 1]]></expression>
      </field>  
      <field id="cantPend" local="true" print="false" >
        <label Formstyle="display:none;">Pend.</label>
        <expression>CASE WHEN (SELECT COUNT(*) FROM ACCESORIOS_COCHE ac WHERE estado = 0 and precio_unitario != 0 and ac.ficha_id = PEDCOTIZ.id) THEN CONCAT((SELECT COUNT(*) FROM ACCESORIOS_COCHE ac WHERE estado = 0 and precio_unitario != 0 and ac.ficha_id = PEDCOTIZ.id), '/', (SELECT COUNT(*) FROM ACCESORIOS_COCHE ac WHERE ac.ficha_id = PEDCOTIZ.id and precio_unitario != 0)) END</expression>
      </field>  
