            <field id="PEDid"  noshow="true">
                <expression>PEDCOTIZ.id</expression>
            </field>

            <field id="siscli" local="true" oculto="true">
                <valor>'02'</valor>
            </field>
      
            <field id="nroturno"  esclave="true" deshabilitado="true" noshow="true" autoinc="true">
                <label modpos="nobr" Formstyle="display:none;">Turno</label>
                <help>Turno</help>
            </field>
            
      <field id="subj" noshow="true" print="false">
              <expression><![CDATA[case when nrofab != 0 then concat('+accesorios+Unidad: +', nrofab) else 'SINMAIL--------' end]]></expression>
          </field>
      <field id="subj2" noshow="true" print="false">
              <expression><![CDATA[concat('Accesorios Unidad: ', nrofab)]]></expression>
          </field>
            <field id="cliente"  tabla="PEDCOTIZ" deshabilitado="true" noshow="true" >
                <expression>case when PEDCOTIZ.ctacod != '' then PEDCOTIZ.ctacod else
                    TURNOSPRODUCCION.ctacod end
                </expression>
            </field>

