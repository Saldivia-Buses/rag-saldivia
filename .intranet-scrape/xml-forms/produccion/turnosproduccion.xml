            <field id="colorFec"  noshow="true">
                <expression>case when PEDCOTIZ.ingresoLinea != '0000-00-00' then 'color:green;font-size:11px;' else '' end</expression>
                <tipo>varchar</tipo>
            </field>

            <field id="linea_id" _noshow="true" valauto="true" required="true">
                <label modpos="nobr">Linea</label>
                <helper type="combo" id="PROD_LINEAS" _empty="true">
                    <field id="id_linea" />
                    <field id="nombre_linea" />
                    <field id="vigente_linea" oculto="true">
                        <condicion operador="=">1</condicion>
                    </field>
                </helper>

                <preparam campo="linea_id" operador="=">true</preparam>
<!--                <valor>1</valor> -->
<!--                <condicion operador="=">1</condicion> -->
            
            </field>
            <field id="semana">
                <label modpos="nobr" Formstyle="display:none;">Sem</label>
                <expression>WEEKOFYEAR(case when PEDCOTIZ.ingresoLinea != '0000-00-00' then PEDCOTIZ.ingresoLinea else fechaing  end)</expression>
            </field>
            <field id="fechaing"  esClave="true" colstyle="display:none;">
                <label modpos="nobr" colspan="2">Ingresa</label>
                <help>Fecha de Ingreso a Linea</help>
            </field>
            <field esClave="true" id="fecha2" _PDFanchofijo="true" Formstyle="display:none;" colstyle="display:none;" >
            <!--    <attribute id="colstyle">colorFec</attribute>-->
                <expression>case when PEDCOTIZ.ingresoLinea != '0000-00-00' then PEDCOTIZ.ingresoLinea else '' end</expression>
                <label modpos="nobr">Entra</label>
                <tipo>date</tipo>
                <help>Fecha de Ingreso a Linea</help>
                <!--  <format>d/m</format> -->
            </field>
      
		  <field id="ingresaEntra" local="true">
			<expression>CONCAT(DATE_FORMAT(fechaing, '%d/%m/%y'), '  -  ', IFNULL(DATE_FORMAT(case when PEDCOTIZ.ingresoLinea != '0000-00-00' then PEDCOTIZ.ingresoLinea else '' end, '%d/%m/%y'), ''))</expression>
            <label _modpos="nobr" style="width:auto;">Fecha Ingreso / Entró</label>
		  </field>
    
            <field id="hora_movimiento" deshabilitado="false" colstyle="display:none;">
                <label _modpos="nobr">Hora Mov</label>
              <tipo>time</tipo>
              <valor>00:00:00</valor>
            </field>
            <field id="hora" deshabilitado="false">
                <expression>LEFT(TURNOSPRODUCCION.hora_movimiento, 5)</expression>
                <label Formstyle="display:none;" modpos="nobr">Hora Mov</label>
                <tipo>time</tipo>
            </field>

            <field id="sale2" esClave="true"  deshabilitado="true" noshow="true" >
                <label _modpos="nobr"   _colspan="2">Sale</label>
                <expression having="false">DATE_ADD((case when ingresoLinea != '0000-00-00' then ingresoLinea else fechaing end), INTERVAL 60 DAY)</expression>
                <!--<expression>CASE WHEN PEDCOTIZ.ingresoLinea != '0000-00-00' THEN DATE_ADD(PEDCOTIZ.ingresoLinea, INTERVAL 45 DAY) ELSE DATE_ADD(TURNOSPRODUCCION.fechaing, INTERVAL 45 DAY) END</expression>
               <expression having="true"> select TUR.fechaing from TURNOSPRODUCCION as TUR where
          TUR.fechaing &gt; TURNOSPRODUCCION.fechaing order by TUR.fechaing ASC limit 0[__cant__], 1
                </expression>  -->
                <tipo>date</tipo>

                <preparam campo="sale2" operador="&lt;">true</preparam>

            </field>
<!--
comentado parametro para ganar velocidad
            <field id="cant" local="true" deshabilitado="true" noshow="true">
                <parametro id="fsmparam_parent.xml" retorna="parent">
                    <field id="parcla">
                        <condicion operador="=" >'posic'</condicion>
                    </field>
                </parametro>
                <tipo>integer</tipo>
            </field>
            -->
            <field id="chasis_entrada" noshow="true">
                <expression>CONCAT('Fecha de entrada del Chasis: ', date_format(CHASIS.entrada, '%d/%m/%Y'))</expression>
                <tipo>date</tipo>
            </field>
            
      
          
            <field id="terminacion"  deshabilitado="true" noshow="true">
                <expression>CASE WHEN PEDCOTIZ.terminacion != '0000-00-00' THEN PEDCOTIZ.terminacion ELSE '' END</expression>
                <label modpos="nobr" Formstyle="display:none" >PreEntrega</label> 
            </field>

      <field id="offset" noshow="true" deshabilitado="true">
                <expression> select count(*) from TURNOSPRODUCCION as TUR where
                  TUR.linea_id = TURNOSPRODUCCION.linea_id and
                    TUR.fechaing &gt;= TURNOSPRODUCCION.fechaing and TUR.fechaing
                    &lt;= date(now())
                </expression>
                <tipo>integer</tipo>
            </field>
            <field id="ingresoLinea" noshow="true" tabla="PEDCOTIZ">
            </field>

            <field id="Ingresos" noshow="true">
                <expression>(select count(*) from PEDCOTIZ P join TURNOSPRODUCCION T on T.nrofab = P.nrocha  where P.ingresoLinea &gt;= PEDCOTIZ.ingresoLinea and T.linea_id = TURNOSPRODUCCION.linea_id)</expression>
            </field>



      <field id="salePreent" local="true">
        <expression>CONCAT(DATE_FORMAT(DATE_ADD((case when ingresoLinea != '0000-00-00' then ingresoLinea else fechaing end), INTERVAL 60 DAY), '%d/%m/%y'), '  -  ', IFNULL(DATE_FORMAT(CASE WHEN PEDCOTIZ.terminacion != '0000-00-00' THEN PEDCOTIZ.terminacion ELSE '' END, '%d/%m/%y'), ' '))</expression>
        <label>Fecha Sale   /   PreEntrega</label>
      </field>
       <field id="momentos" local="true" deshabilitado="true">
                <label style="display:none;" colstyle="display:none;" _modpos="nobr" >Posición</label>
                <tabla_ex id="MOMENTO" xml="momento_posiciones.xml">
                </tabla_ex>
                <if exp="true">
                    <true>offset</true>
                    <false>0</false>
                </if>

                <tipo>varchar</tipo>
            </field>

            <field id="ubicacion" print="false">
                <label _modpos="nobr">observaciones</label>
                <help>observaciones</help>
                <size>30</size>
            </field>

            <field id="notas" print="false">
                <label >Notas</label>
                <help>Notas</help>
            </field>

            <field id="terminacionFinal" print="false" noshow="true" tabla="PEDCOTIZ">
                <label>Aviso Entrega</label>
<!--                <expression>case when PEDCOTIZ.terminacionFinal = '0000-00-00' then '' else PEDCOTIZ.terminacionFinal end</expression>  -->
                <tipo>date</tipo>
                <condicion operador="=">'0000-00-00' or isnull(terminacionFinal) or terminacionFinal &gt; STR_TO_DATE('[__afecha__]', '%d/%m/%Y')</condicion>
            </field>

            <field id="Entrega" noshow="true" print="false">
                <label>Retiró</label>
                <expression>select entrega from ENTREGASCOCHES where ENTREGASCOCHES.nrofab = TURNOSPRODUCCION.nrofab  and ENTREGASCOCHES.entrega IS NOT NULL  limit 1</expression>
                <tipo>date</tipo>
            </field>         

            <field id="colorEnt" noshow="true" local="true">
                <if exp="'Entrega' != ''">
                    <true>'color:green;'</true>
                    <false>''</false>
                </if>
            </field>
            
            <field id="posent" local="true" print="false" getStyle="colorEnt">     
                <label modpos="nobr" Formstyle="display:none;">Aviso/Retiró</label>
                <if exp="'Entrega' != '' and nrofab != 0">
                    <true>'Entrega'</true>
                    <false>'terminacionFinal'</false>
                </if>
                <tipo>date</tipo>
            </field>
   
        <field deshabilitado="true" id="marcod" tabla="CHASIS" _noZero="true">
                <expression>CHASIS.marcod</expression>
                <label modpos="nobr" Formstyle="display:none;">Ch.</label>
                <help/>
                <tabla_ex id="MARCHASIS">
                    <field id="marcod">
                    </field>
                    <field id="desabv">
                    </field>

                    <field id="siscod" oculto="true">
                        <condicion operador="=">03</condicion>
                    </field>
                </tabla_ex>
                <tipo>integer</tipo>
            </field>
 
            <field deshabilitado="true" id="moddes" tabla="MODCHASIS">

                <expression>case when MODCHASIS.desabv != '' then MODCHASIS.desabv else
                    TURNOSPRODUCCION.modeloChasis end
                </expression>

                <label modpos="nobr" Formstyle="display:none;">Mod</label>
                <help/>
                <tipo>varchar</tipo>
            </field>
            <field id="fechaActualiza" valauto="true" deshabilitado="true" noshow="true">
                <label modpos="nobr" _colstyle="display:none">Fecha Act.</label>
                <valor>today</valor>
                <tipo>date</tipo>
            </field>

            <field deshabilitado="true" id="chasis" tabla="CHASIS"  linkint="chasis_cons.xml" linkdes="Ver Datos del Chasis">
                <expression><![CDATA[CONCAT( SUBSTRING(CHASIS.chasis, -8, 2),'<b>', RIGHT(CHASIS.chasis, 6), '</b>')]]></expression>
                <label Formstyle="display:none;">Ch N</label>
                <help>Numero de Serie del chasis</help>
                <paring destino="nrocha">nrofab</paring>
                <attribute id="tooltip">chasis_entrada</attribute>        

            </field>
            <field id="admin" local="true" noshow="true">
                <valor>1</valor>
            </field>
            
            <field id="tieneFicha" noshow="true">
                <expression>case when PEDCOTIZ.estado_ficha = 1 then 'ficha_producto1_qry.xml' else '' end</expression>
            </field>

            <field id="ficha_id" noshow="true">
                <expression>PEDCOTIZ.id</expression>
            </field>
            <field id="nrofab"  deshabilitado="false" noZero="true" linkint="ficha_producto1_qry.xml" linkdir="/producto" linkdes="Ficha Producto">
                <label _modpos="nobr" style="color:#444;font-weight:bold;">Nro.</label>
                <help>Numero de Fabricacion</help>
                <helper type="external" id="CHASIS">
            	    <field id="nrocha" />
            	    <field id="chades" />
            	</helper>
            <attribute id="linkint">tieneFicha</attribute>
                <paring destino="nrofab">nrofab</paring>
                <paring destino="producto_id">ficha_id</paring>
                <paring destino="id">ficha_id</paring>
                <detalle>nrocha</detalle>
            </field>
