                <expression>case when PEDCOTIZ.homologacion_id != '' then (atributoUnidad(id, 'marair')) else TURNOSPRODUCCION.marair end</expression>
                <label>A/A</label>
                <tabla_ex id="MARCAAIR" vacio="true" indexvacio="0" valorvacio="NO">
                    <field id="marair" />                     
                    <field id="desair">
                        <expression>LEFT(desair, 4)</expression>
                    </field>                    
                    <field id="siscod" oculto="true">
                        <condicion operador="=">03</condicion>
                    </field>
                </tabla_ex>
                <tipo>varchar</tipo>
            </field>

            <!-- <field id="pedido" noshow="true">
                <expression>@pedido:=(SELECT SUM(round(movcps ,  2)) from CPSENCAB left JOIN CPSMOVIM on 
                    ( CPSMOVIM.siscod = CPSENCAB.siscod ) and 
