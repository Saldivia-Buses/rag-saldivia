            <field id="marasi">
                <expression>case when PEDCOTIZ.homologacion_id != '' then (atributoUnidad(id, 'marasi')) else TURNOSPRODUCCION.marasi end</expression>
                <attribute id="style">faltante</attribute>
                <label >Asientos</label>
                <help/>
                <tabla_ex id="MARCAASI">
                    <field id="marasi">
                    </field>
                    <field id="asides">
                        <expression>LEFT(asides, 4)</expression>
                    </field>
                    <field id="siscod" oculto="true">
                        <condicion operador="=">03</condicion>
                    </field>
                </tabla_ex>
            </field>

            <field id="hi" deshabilitado="true" clasefila="true" noshow="true">
                <expression>case when TURNOSPRODUCCION.fechaActualiza = DATE(NOW()) then 'resaltado' else '' end</expression>
                <tipo>varchar</tipo>
            </field>

            <field id="reasignado" noshow="true">
                <expression having="false">case when @max_fec &gt; terminacion or ultima_modificacion &gt; terminacion then 1 else 0 end</expression>
            <preparam operador="=">true</preparam>
                <helper type="combo" _empty="true">
                    <option value="">Todos</option>
                    <option value="0">No</option>
                    <option value="1">Si</option>
                </helper>

            </field>
    	    <field id="esconces" noshow="true">
		<expression having="false">PEDCOTIZ.ctacod</expression>
		<condicion operador="=">CONCESIONARIO.ctacod</condicion>
    	    </field>

            <field id="concliente" noshow="true" required="false">
		
                <expression having="false">(case when (CONCESIONARIO.ctacod = TURNOSPRODUCCION.ctacod or CONCESIONARIO.ctacod = PEDCOTIZ.ctacod) then 2 when (PEDCOTIZ.ctacod != 0 OR TURNOSPRODUCCION.ctacod != 0) then 1 ELSE 2 end)</expression>

                <helper type="combo" empty="true">
                    <option value=""></option>
                    <option value="1">Con Cliente</option>
                    <option value="2">Sin Cliente</option>
                </helper>
            <preparam operador="=">true</preparam>

            </field>
	    <field id="facturado" noshow="true">
		<expression>(select count(*) from REG_MOVIMIENTOS where REG_MOVIMIENTOS.nrofab  = PEDCOTIZ.nrocha and REG_MOVIMIENTOS.fecha_movimiento &lt;= STR_TO_DATE('[__afecha__]', '%d/%m/%Y') and REG_MOVIMIENTOS.subsistema_id = '02')</expression>
		<condicion operador="=">0</condicion>
	    </field>
            
        <field id="conAviso" noshow="true" deshabilitado="false" required="false">
              <expression having="false">(case when terminacionFinal != '0000-00-00' then 1 else -1 end)</expression>
            <helper type="combo" empty="true">
                <option value=""></option>
                <option value="-1">Sin Aviso</option>
                <option value="1">Con Aviso</option>
            </helper>
	    
            <preparam operador="=">true</preparam>

        </field>


            <order>
                <!--<field id="terminado"/>-->

                <field id="conces"/>

                <field id="fechaing"/>
                <!--<field id="hora_movimiento"/>-->
            </order>
        </table>
        <join tipo="left">
            <table id="PEDCOTIZ">
                <field id="nrocha">
                    <condicion operador="=">TURNOSPRODUCCION.nrofab and PEDCOTIZ.nrocha != 0</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="CCTCUENT">
                <field id="ctacod">
                    <condicion operador="=">(case when PEDCOTIZ.ctacod != 0 then PEDCOTIZ.ctacod else TURNOSPRODUCCION.ctacod end)</condicion>
                </field>
                <field id="siscod">
                    <condicion operador="=">'02'</condicion>
                </field>
                
                
            </table>
        </join>
      <join tipo="left">
            <table id="HOMOLOGMOD">
                <field id="id_homologacion">
                    <condicion operador="=">PEDCOTIZ.homologacion_id</condicion>
                </field>
            </table>
        </join>
    <join tipo="left">
       <table id="CARROCERIA">
          <field id="nrocar">
                 <condicion operador="=">HOMOLOGMOD.nrocar</condicion>
          </field>
        </table>
    </join>

        <join tipo="left">
            <table id="CHASIS">
                <field id="nrocha">
                    <condicion operador="=">TURNOSPRODUCCION.nrofab and CHASIS.nrocha != 0</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="MODCHASIS">
                <field id="modcha">
                    <condicion operador="=">CHASIS.modcod</condicion>
                </field>
                <field id="marcod">
                    <condicion operador="=">CHASIS.marcod</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="CONCESIONARIO">
                <field id="idconces">
                    <condicion operador="=">(case when CHASIS.conces != '' then CHASIS.conces else TURNOSPRODUCCION.idconces end)</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="EURO_TIPO">
                <field id="id_euro">
                    <condicion operador="=">MODCHASIS.euro_id</condicion>
                </field>
            </table>
        </join>
        
    </form>
</histrix>
