    <field id="fechaultcoche" noshow="true">
      <expression>@fultcoche:= (SELECT P.pedfec FROM PEDCOTIZ P where P.ctacod = PEDCOTIZ.ctacod group by P.pedfec order by P.pedfec DESC limit 1)</expression>
    </field>

    <field id="noesprimerizo" noshow="true"><!-- Si tiene Fichas de venta con fecha menor a la fecha del último coche - 30 días, no es primerizo -->
      <expression>CASE WHEN (SELECT 0 FROM PEDCOTIZ P where P.pedfec &lt; DATE_SUB(@fultcoche, INTERVAL 30 DAY) and P.ctacod = PEDCOTIZ.ctacod group by P.ctacod) = 0 THEN 0 ELSE 1 END</expression>
    </field>

    <field id="esconcesionario" noshow="true">
      <expression>CASE WHEN (SELECT 1 FROM CONCESIONARIO WHERE ctacod = PEDCOTIZ.ctacod limit 1) = 1 THEN 1 ELSE 0 END</expression>
      <label>Es Conc</label>
    </field>

    <field id="tienepedcotiz" noshow="true">
      <expression>CASE WHEN (SELECT 1 FROM PEDCOTIZ P where P.ctacod = PEDCOTIZ.ctacod group by P.ctacod) = 1 THEN 1 ELSE 0 END</expression>
    </field>
          
    <field id="ot1" local="true" noshow="true">
        <expression>
          CASE WHEN (CASE WHEN (SELECT 0 FROM PEDCOTIZ P where P.pedfec &lt; DATE_SUB(@fultcoche, INTERVAL 30 DAY) and P.ctacod = PEDCOTIZ.ctacod group by P.ctacod) = 0 THEN 0 ELSE 1 END) = 1 and
                (CASE WHEN (SELECT 1 FROM CONCESIONARIO WHERE ctacod = PEDCOTIZ.ctacod limit 1) = 1 THEN 1 ELSE 0 END) = 0 and
                (CASE WHEN (SELECT 1 FROM PEDCOTIZ P where P.ctacod = PEDCOTIZ.ctacod group by P.ctacod) = 1 THEN 1 ELSE 0 END) = 1
            THEN 'color:red;font-weight:bold;font-size:16px;' ELSE '' END
        </expression>
    </field>
    
