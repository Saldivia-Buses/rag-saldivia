<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" paginar="100" path="/fotos/coches">
	<title>PROGRAMA DE PRODUCCION</title>
	<obs/>
	<form >
		<table id="TURNOSPRODUCCION" label="Programa de Produccion"  showCantidad="false" styleTbody="height:500px; overflow-x:hidden;">
			<filters>
<!--				<field  id="fechasal">
					<label>Desde</label>
					<help>Fecha de Ingreso a Linea</help>
					<operador>>=</operador>
					<valor eval="true">date("d/m/Y", mktime(0, 0, 0, date("m")  , date("d")-5, date("Y")))</valor>
				</field> -->
				<field id="sale2" deshabilitado="false">
					<label>Desde</label>
					<help>Fecha de Ingreso a Linea</help>
					<operador>&gt;=</operador>
					<valor eval="true">date("d/m/Y", mktime(0, 0, 0, date("m") ,
						date("d")-5, date("Y")))</valor>
					
				</field>				
			</filters>
			<field id="siscli" local="true" oculto="true" >
				<valor>'02'</valor>
			</field>
			<field esclave="true" id="fechaing" PDFanchofijo="true">
				<label >Entra</label>
				<help>Fecha de Ingreso a Linea</help>
				<!--	<format>d/m</format> -->

			</field>
			<field id="sale2" esClave="true">
				<label modpos="nobr" >Sale</label>
				
				<expression> select TUR.fechaing from TURNOSPRODUCCION as TUR where
					TUR.fechaing &gt; TURNOSPRODUCCION.fechaing order by TUR.fechaing ASC limit 15, 1</expression>
				<tipo>date</tipo>
			</field>		
			<!--			
			<field id="fechasal" esclave="true" >
				<label modpos="nobr">Sale</label>
				<help>Fecha de Salida de Linea</help>
			</field> -->
			<field deshabilitado="true" id="moddes" tabla="MODCHASIS">

				<expression>case when MODCHASIS.moddes != '' then MODCHASIS.moddes else TURNOSPRODUCCION.modeloChasis end</expression>
				
				<label >Mod</label>
				<help/>
				<tipo>varchar</tipo>
			</field>
			
<!--			<field deshabilitado="true" id="chasis" tabla="CHASIS">
				<expression>RIGHT(CHASIS.chasis, 6)</expression>
				<label>Chasis</label>
				<help>Numero de Serie del chasis</help>
			</field>
-->
			<field id="nrofab" linkint="fichaventas.xml" linkdes="Ver Ficha de Ventas">
				<label modpos="nobr" style="color:#444;font-weight:bold;">Nro.</label>
				<help>Numero de Fabricacion</help>
				<ayuda_ex id="CHASIS">
					<field id="nrocha"/>
					<field id="chades"/>
				</ayuda_ex>
				<!--<format><![CDATA[<b>%d</b>]]></format>
-->
				<paring destino="nrocha">nrofab</paring>
			</field>
			<field deshabilitado="true" id="ctaconces" tabla="CHASIS" noshow="true">
				<expression>case when CONCESIONARIO.ctacod >= 0 then CONCESIONARIO.ctacod else 0 end</expression>				
				<tipo>integer</tipo>

			</field>
			
			
			<field deshabilitado="true" id="conces" tabla="CHASIS" linkint="cctconta_consulta.xml" linkdes="Ver medios de Contacto">
<!--				<expression>CHASIS.conces</expression> -->
				<expression>case when CHASIS.conces != '' then CHASIS.conces else TURNOSPRODUCCION.idconces end</expression>				
			-	<tabla_ex vacio="true" xml="concesionario.xml"/> 
				<label>Conces</label>
				<help>Concesionario</help>
				<tipo>integer</tipo>
				<paring destino="ctacod">ctaconces</paring>				
				<paring destino="siscod">siscli</paring>					
			</field>
			<field deshabilitado="true" id="ctacod" tabla="PEDCOTIZ" linkint="cctconta_consulta.xml" linkdes="Ver medios de Contacto">
<!--				<expression>PEDCOTIZ.ctacod</expression> -->
				<expression>case when PEDCOTIZ.ctacod != '' then PEDCOTIZ.ctacod else TURNOSPRODUCCION.ctacod end</expression>
				
				<label >Cliente</label>
				<help>Codigo de Cuenta</help>
				<tabla_ex condes="true" id="CCTCUENT">
					<field id="ctacod"/>
					<field id="ctafan">
						<expression>LEFT(ctafan, 17)</expression> 
					</field>
					<field id="siscod" oculto="true">
						<condicion operador="=">'02'</condicion>
					</field>
				</tabla_ex>
				<tipo>varchar</tipo>
				<paring destino="ctacod">ctacod</paring>				
				<paring destino="siscod">siscli</paring>				
			</field>

            <field id="bagno" deshabilitado="true" noZero="true">
                <label>B</label>
                <expression>atributoUnidad(id, 'bagno')</expression>
                <options>
                    <option valor="0"></option>
                    <option valor="1">  </option>
                    <option valor="2">BB</option>
                    <option valor="3">S/D</option>
                </options>
                <tipo>varchar</tipo>
            </field>

            <field id="corpath" local="true" noshow="true">
                <if exp="true">
                    <true>'nrofab/corte'</true>
                    <false>''</false>
                </if>
                <tipo>varchar</tipo>
            </field>

          	<field id="cortePint"  path="corpath" open="true" print="false">
	       		<expression>atributoUnidad(id, 'cortepint')</expression>
                <label>Corte</label>
                <tipo>file</tipo>
                <size>50</size>
            </field>
			<field id="trabajos" obj="trabajos_coche_cons.xml" showObjTabla="true"  showValor="true" linkint="trabajos_coche.xml" linkdes="Trabajo Adicionales" local="true" >
				<label style="color:#444; ">Trabajos Adicionales</label>
				<paring destino="nrofab" operador="=">nrofab</paring>
				<valor>'Editar trabajos'</valor>
				<tipo>varchar</tipo>
			</field>			
			<order>
				<field id="fechaing"/>
			</order>
		</table>
		<join tipo="left">
			<table id="PEDCOTIZ">
				<field id="nrocha">
					<condicion operador="=">TURNOSPRODUCCION.nrofab</condicion>
				</field>
			</table>
		</join>
		<join tipo="left">
			<table id="CHASIS">
				<field id="nrocha">
					<condicion operador="=">TURNOSPRODUCCION.nrofab</condicion>
				</field>
			</table>
		</join>
		<join tipo="left">
			<table id="MODCHASIS">
				<field id="modcha">
					<condicion operador="=">CHASIS.modcod</condicion>
				</field>
				<field id="marcod">
					<condicion operador="=">CHASIS.marcod</condicion>
				</field>
			</table>
		</join>
		<join tipo="left">
			<table id="CONCESIONARIO">
				<field id="idconces">
					<condicion operador="=">(case when CHASIS.conces != '' then CHASIS.conces else TURNOSPRODUCCION.idconces end)</condicion>
				</field>
			</table>
		</join>
		
	</form>
</histrix>
