<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta">
	<title>Trabajos Adicionales por coche</title>
	<obs/>
	<form >
		<table id="TRABAJOS_COCHE">
			<title>Trabajos</title>
			<filters>
				<field id="fechaTrabajo">
					<label>Desde</label>
					<operador>&gt;=</operador>
					<valor eval="true">date('d/m/Y', mktime(0, 0, 0, 1 , 1, date("Y") -  1 ))</valor>
				</field>
				<field id="fechaTrabajo">
					<label>Hasta</label>
					<operador>&lt;=</operador>
					<valor eval="true">date('d/m/Y', mktime(0, 0, 0, 12 , 31, date("Y") -  1 ))</valor>
				</field>
			</filters>
			<field id="idTrabajo" tabla="TRABAJOS_COCHE" noshow="true">
				<label>Codigo</label>
				<help>codigo de Trabajo</help>
			</field>
			<field id="nombre" tabla="TRABAJO" >
				<label>Trabajo</label>
			</field>
			<field id="fechaTrabajo">
				<label>Fecha</label>
				<help>Fecha de realización del trabajo</help>
				<tipo>date</tipo>
			</field>
			
			<field id="fechaPago" noshow="true">
				<label>Pago</label>
				<help>Fecha de Pago del trabajo</help>
			</field>			

			<field id="importe">
				<expression>SUM(importe)</expression>
				<label>Importe</label>
				<help>Importe del trabajo</help>
			</field>			
			<group>
				<field id="idTrabajo" tabla="TRABAJOS_COCHE"/>
			</group>
		</table>
		<join tipo="left">
			<table id="TRABAJO">
				<field id="idTrabajo">
					<condicion operador="=">TRABAJOS_COCHE.idTrabajo</condicion>
				</field>
			</table>
		</join>
	</form>
</histrix>
