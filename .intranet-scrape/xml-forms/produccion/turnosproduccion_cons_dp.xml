            <field id="hi" deshabilitado="true" clasefila="true" noshow="true">
                <expression>case when TURNOSPRODUCCION.fechaActualiza = DATE(NOW()) then 'resaltado' else '' end</expression>
                <tipo>varchar</tipo>
            </field>

            <field id="enlinea" noshow="true">
                <expression having="false">ifnull((select 1 from PROD_PATH_REGISTRO join PROD_PRODUCT_PATH ON id_productpath = productpath_id JOIN POSICIONESFAB PF on PF.id_posicionfab = PROD_PRODUCT_PATH.posicionfab_id where nrofab_id = nrofab and hora_salida = '0000-00-00 00:00:00:00' limit 1), 0)</expression>
                <preparam operador="=">true</preparam>
                <helper type="combo" _empty="true">
                    <option value="">Todos</option>
                    <option value="0">No</option>
                    <option value="1">Si</option>
                </helper>
            </field>

            <field id="enlalinea" noshow="true">
                <expression having="false">ifnull((select 1 from PROD_PATH_REGISTRO join PROD_PRODUCT_PATH ON id_productpath = productpath_id JOIN POSICIONESFAB PF on PF.id_posicionfab = PROD_PRODUCT_PATH.posicionfab_id where nrofab_id = nrofab and hora_salida = '0000-00-00 00:00:00:00' limit 1), 0)</expression>
                <condicion operador="=">1 or PEDCOTIZ.terminacionFinal = '0000-00-00' or isnull(PEDCOTIZ.terminacionFinal) or terminacionFinal &gt; STR_TO_DATE('[__afecha__]', '%d/%m/%Y')</condicion> 
            </field>

            <field id="reasignado" noshow="true">
                <expression having="false">case when @max_fec &gt; terminacion or ultima_modificacion &gt; terminacion then 1 else 0 end</expression>
                <preparam operador="=">true</preparam>
                <helper type="combo" _empty="true">
                    <option value="">Todos</option>
                    <option value="0">No</option>
                    <option value="1">Si</option>
                </helper>
            </field>

            <field id="concliente" noshow="true" required="false">
