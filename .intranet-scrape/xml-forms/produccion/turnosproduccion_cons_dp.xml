<histrix tipo="consulta" _autoupdate="240" path="/fotos/coches" _limit="1">
    <title>PROGRAMA DE PRODUCCION</title>
    <obs/>
    <form  detalle="detalleUnidad.xml" inline="true">
        <table id="TURNOSPRODUCCION" label="Programa de Produccion"  _showCantidad="false" _styleTbody="height:500px; overflow-x:hidden;">

            <preconsultas>
                <xmlfile id="turnosproduccion_pre.xml"/>
            </preconsultas>
        
            <filters>
                <field id="linea_id" deshabilitado="false">
                    <label>Línea</label>
                    <operador>=</operador>
		            <valor>7</valor> 
                </field>

                <field id="afecha">
                    <label>Fecha</label>
                    <tipo>date</tipo>
                    <valor>today</valor>
                </field>
<!--
                <field id="sale2" deshabilitado="false">
                    <label>Desde</label>
                    <help>Fecha de Ingreso a Linea</help>
                    <operador>&gt;=</operador>
                    <valor eval="true">date("d/m/Y", mktime(0, 0, 0, date("m"), date("d")-50, date("Y")))
                    </valor>
                </field>
                <field id="terminacion" deshabilitado="false">
                    <label modpos="nobr">Desde terminado</label>
                    <help>Fecha de Ingreso a Linea</help>
                <operador>&gt;=</operador>
                </field>
                <field id="terminacion" deshabilitado="false">
                    <label modpos="nobr">Hasta terminado</label>
                    <help>Fecha de Ingreso a Linea</help>
                <operador>&lt;=</operador>
                </field>
-->
                <field id="conAviso" deshabilitado="false">
                    <label modpos="nobr">Aviso Entrega</label>
                    <operador>=</operador>
                </field>

                <field id="enlinea" deshabilitado="false">
                    <label modpos="nobr">En Línea</label>
                    <operador>=</operador>
                </field>

                <field id="reasignado" deshabilitado="false">
                    <label modpos="nobr">Reasignado</label>
                    <operador>=</operador>
                </field>

                <field id="concliente" deshabilitado="false">
                    <label modpos="nobr">Con Cliente</label>
                    <operador>=</operador>
                </field>

            </filters>
            
            <field id="afecha" local="true" noshow="true">
                <label>Fecha</label>
                <tipo>date</tipo>
                <valor>today</valor>
                <preparam campo="afecha" _operador="=">true</preparam>
            </field>

            <field id="siscli" local="true" oculto="true" >
                <valor>'02'</valor>
            </field>
<!--
            <field id="idCotiz" oculto="true">
                <detalle>idCotiz</detalle>
            </field> 
        -->
            <field id="cliente" tabla="PEDCOTIZ" deshabilitado="true" noshow="true" >
                <expression>case when PEDCOTIZ.ctacod != '' then PEDCOTIZ.ctacod else TURNOSPRODUCCION.ctacod end</expression>
            </field>

            <field id="semana">
                <label>Sem</label>
                <expression>WEEKOFYEAR(case when PEDCOTIZ.ingresoLinea != '0000-00-00' then PEDCOTIZ.ingresoLinea else fechaing  end)</expression>
            </field>
            
            <field id="colorFec"  oculto="true">
                <expression>case when PEDCOTIZ.ingresoLinea != '0000-00-00' then 'color:green;font-size:12px;' else 'color:red;font-size:11px;' end</expression>
                <tipo>varchar</tipo>
            </field>

            <field id="linea_id" noshow="true">
                <helper type="combo" id="PROD_LINEAS" _empty="true">
                    <field id="id_linea" />
                    <field id="nombre_linea" />
                    <field id="vigente_linea" oculto="true">
                        <condicion operador="=">1</condicion>
                    </field>
                </helper>
                <tipo>numeric</tipo>
                <preparam campo="linea_1" _operador="=">true</preparam>
            </field>
           
            <field id="fechaing" _PDFanchofijo="true" oculto="true">
                <expression>fechaing</expression>
                <tipo>date</tipo>
<!--                <format>d/m</format> -->
<!--                <condicion operador="&lt;">CASE WHEN linea_id = 1 THEN ADDDATE(CURDATE(),INTERVAL 90 DAY) ELSE ADDDATE(CURDATE(),INTERVAL 1000 DAY) END</condicion> -->
            </field>

            <field id="homologacion_id" _PDFanchofijo="true" oculto="true" noshow="true" tabla="PEDCOTIZ">
                <expression>homologacion_id</expression>
            </field>
          
            <field id="hora_movimiento" _PDFanchofijo="true" oculto="true" />

            <field id="fff" noshow="true">
                <expression>IF( IFNULL(PEDCOTIZ.ingresoLinea,'0000-00-00') = '0000-00-00','fecha_ingreso_linea_ficha.xml', '')</expression>
                 <tipo>varchar</tipo>
            </field>
                    
            <field id="fechaing2"  esClave="true" _PDFanchofijo="true">
                <expression>CONCAT(DATE_FORMAT(fechaing, '%d/%m'), IFNULL(DATE_FORMAT(case when PEDCOTIZ.ingresoLinea != '0000-00-00' then PEDCOTIZ.ingresoLinea else '' end, ' - %d/%m'), ''))</expression>
                <label>Entra</label>
                <help>Fecha de Turno vs Ingreso a Línea</help>
                <attribute id="style">colorFec</attribute>
                <attribute id="linkint">fff</attribute>
                <paring destino="nrocha">nrofab</paring>
                <!--<expression having="false">(case when PEDCOTIZ.ingresoLinea != '0000-00-00' then CONCAT(PEDCOTIZ.ingresoLinea, ' - ',fechaing) else fechaing end)</expression>-->
            </field>
                              
            <field id="controlcalidad" local="true"  obj="controlcalidad/controlcalidad_coche_Horiz_cons.xml" showObjTabla="true"  print="false">
                <paring destino="nrofab_id" operador="=">nrofab</paring>
<!--                <paring destino="linea_id" operador="=">linea_id</paring>  -->
                <paring destino="homologacion_id" operador="=">homologacion_id</paring> 
                <tipo>varchar</tipo>
                <label>Controles de Calidad</label>
            </field>
          
            <field id="fechaTerminacion" local="true" >
                <label modpos="nobr">Terminado</label>
                <attribute id="style">colorFecTer</attribute>
                <expression>(case when PEDCOTIZ.terminacion != '0000-00-00' then PEDCOTIZ.terminacion else (DATE_ADD((case when ingresoLinea != '0000-00-00' then ingresoLinea else fechaing end), INTERVAL 60 DAY)) end)</expression>
                <help>Fecha de Salida de Linea (o fecha tentativa de salida"</help>
                <tipo>date</tipo>
                <format>d/m</format>
            </field>

            <field id="terminacion" tabla="PEDCOTIZ" noshow="true">
                <label modpos="nobr">Terminacion</label>
                <tipo>date</tipo>            
<!--		<condicion operaror="=">'0000-00-00' or isnull(terminacion)</condicion> -->
            </field>

            <field id="posent" local="true" print="false" ignoreOption="true" getStyle="colorEnt">
                <label modpos="nobr" Formstyle="display:none;">Notas</label>
<!--                <tabla_ex id="MOMENTO" xml="momento_posiciones.xml" /> -->
                <if exp="'Entrega' != '' and nrofab != 0">
                    <true>date(  'd/m/Y', strtotime ( 'Entrega')) </true>
                    <false>'ubicacion'</false>
                </if>
            </field>
            <field id="controlar" style="font-size:9px">
                <helper xml="prod_control_movim_avisoprod_qry.xml" type="link" title="control" dir="controlcalidad/" modal="true">
                    <parameter source="nrofab" target="nrofab_id"/>
<!--                    <parameter source="controlcausal_id" target="controlcausal_id"/> -->
                    <parameter source="1" target="aviso_produccion"/>
                    
                    
                    <parameter source="homologacion_id" target="homologacion_id"/>
                </helper>                
                <expression>(select group_concat(nombre_control) from PROD_CONTROL_MOVIM PC join PROD_CONTROLES on prodcontrol_id = id_prodcontrol where PC.nrofab_id = nrofab and PC.no_aplica = 0 and PC.conforme = 1 and aviso_produccion = 1 limit 1)</expression>
            </field>

            <field id="filtmail" noshow="true">
                <expression>CONCAT('+"Entrega Unidad" +', PEDCOTIZ.nrocha)</expression>
            </field>

            <field id="filtmail_param" noshow="true">
                <expression>CONCAT('Entrega Unidad ', PEDCOTIZ.nrocha)</expression>
            </field>

            <field id="terminacionFinal" tabla="PEDCOTIZ">
                <label>Aviso Entrega</label>
                <tipo>date</tipo>
                <helper type="link" xml="email_subj_qry.xml" dir="/email">
                    <parameter target="subject" source="filtmail_param" operator="like"/>
                </helper>
                <label>Correos</label>
                <help></help>
                <condicion operador="=">'0000-00-00' or isnull(terminacionFinal) or terminacionFinal &gt; STR_TO_DATE('[__afecha__]', '%d/%m/%Y')</condicion>
            </field> 

            <field id="Ingresos" noshow="true">
                <expression>(select count(*) from PEDCOTIZ PING join TURNOSPRODUCCION T on T.nrofab = PING.nrocha  where PING.ingresoLinea &gt;= PEDCOTIZ.ingresoLinea and T.linea_id = TURNOSPRODUCCION.linea_id)</expression>
            </field>
                                  
            <field id="corpath" local="true" noshow="true">
                <if exp="true">
                    <true>'nrofab/corte'</true>
                    <false>''</false>
                </if>
                <tipo>varchar</tipo>
            </field>
            
            <field id="offset" noshow="true" deshabilitado="true">
                <expression>select count(*) from TURNOSPRODUCCION as TUR where 
                    TUR.linea_id = TURNOSPRODUCCION.linea_id and 
                    TUR.fechaing &gt;= TURNOSPRODUCCION.fechaing and 
                    TUR.fechaing &lt;= now()
                </expression>
                <tipo>integer</tipo>
            </field>
            
            <field id="colorFecTer"  oculto="true">
                <expression>case when PEDCOTIZ.terminacion != '0000-00-00' then 'color:green; font-size:11px;font-weight:bold;' else 'color:#B32600; font-weight:bold;' end</expression>
                <tipo>varchar</tipo>
            </field>
           
            <field id="sale2" _esClave="true" noshow="true">
                <label modpos="nobr" >terminado</label>
                <expression having="false">DATE_ADD((case when ingresoLinea != '0000-00-00' then ingresoLinea else fechaing end), INTERVAL 60 DAY)</expression>
                <tipo>date</tipo>
                <preparam campo="sale2" operador="&lt;">true</preparam>
            </field>
        
            <field id="chasis_entrada" noshow="true">
                <expression>CONCAT('Fecha de entrada del Chasis: ', date_format(CHASIS.entrada, '%d/%m/%Y'))</expression>
                <tipo>date</tipo>
            </field>
            
            <field id="log" local="true" linkint="turnos_log_msg_cons.xml"  linkdir="produccion/" linkdes="Historial" print="false" >
                <label getStyle="maxfec"  Formstyle="display:none;">Ult.Modif</label>
                <attribute id="tooltip">obser2</attribute>
                <if exp="'max_fec' == 'today'">
                  <true>'HOY'</true>
                  <false>('max_fec'=='ayer')?'Ayer': (('max_fec' != '')?date('d/m', strtotime('max_fec')):'')</false>
                </if>                
                <!--
                <expression>case when @maxrev = DATE(NOW()) then 'HOY'
                    when @maxrev = DATE_SUB(curdate(), INTERVAL 1 DAY) then 'Ayer'
                    else date_format(@maxrev, '%d/%m') end
                </expression> -->
                <paring destino="num"    >nrofab</paring>     
            </field>

            <field id="publicada" local="true" noshow="true">
                <label getStyle="maxfec"></label>
                <expression><![CDATA[ (SELECT fecha FROM `HTXLOG` WHERE campo = 'Estado' AND HTXLOG.obs LIKE concat('%N.Fab.: ',nrofab,'%')  AND xmlprog = 'Fichaventas_abm.xml'  AND tipo = 'UPDATE' LIMIT 1)]]></expression>
<!--                <expression><![CDATA[ max( (SELECT fecha FROM `HTXLOG` WHERE campo = 'Estado' AND HTXLOG.obs LIKE concat('%N.Fab.: ',nrofab,'%')  AND xmlprog = 'Fichaventas_abm.xml'  AND tipo = 'UPDATE' LIMIT 1), 
					 (SELECT fecha FROM `HTXLOG` WHERE campo = 'Estado' AND HTXLOG.obs LIKE concat('%N.Fab.: ',nrofab,'%')  AND xmlprog = 'producto_estado_ficha_update.xml'  AND tipo = 'UPDATE' LIMIT 1))	
]]></expression>
-->
            </field>
<!--
            <field id="reasignacion" local="true" noshow="true">
                <label getStyle="maxfec" colstyle="color:red"></label>
                <expression><![CDATA[SELECT 'REASIG' FROM `HTXLOG` WHERE campo = 'Cliente' AND obs LIKE concat('%N.Fab.: ',nrofab,'%') AND (xmlprog = 'Fichaventas_abm.xml' or xmlprog = 'producto_estado_ficha_update.xml') AND tipo = 'UPDATE' AND fecha > '[__publicada__]' AND nrofab != 0 LIMIT 1]]></expression>
            </field>
-->
            <field id="muestra" noshow="true" local="true">
                <valor>0</valor>
            </field>

            <field id="controlcausal_id" noshow="true" local="true">
                <valor>7</valor>
            </field>

            <field id="cant_propiedad_cliente" noshow="true">
                <expression>@cant_prop_cli:=(select count(*) from PROD_CONTROL_MOVIM PCM where PCM.nrofab_id = nrofab and PCM.controlcausal_id = 7 and PCM.no_conforme = 1 and PCM.controlado = 0)</expression>
            </field>

            <field id="propiedad_cliente">
                <label>Prop Cli</label>    
                <helper xml="prod_control_movim_qry.xml" type="link" title="control" dir="controlcalidad/" modal="true">
                    <parameter source="nrofab" target="nrofab_id"/>
                    <parameter source="controlcausal_id" target="controlcausal_id"/>
                    <parameter source="muestra" target="muestra"/>
                    <parameter source="homologacion_id" target="homologacion_id"/>
                </helper>
                <expression>case when @cant_prop_cli != 0 then CONCAT(@cant_prop_cli, ' Prop.Cli') else '' end</expression>
            </field>

            <field id="cant_trabajos_cnrt" noshow="true">
                <expression>@cant_trabajos_cnrt:=(SELECT COUNT(*) FROM PROD_TRABAJOS_CNRT where nrofab_id = nrofab)</expression>
            </field>

            <field id="tiene_trabajos_cnrt" noshow="true">
                <expression>case when @cant_trabajos_cnrt != 0 and HOMOLOGMOD.dispos = '' then 'background-color: #F5A9A9;' else 
                    (case when @cant_trabajos_cnrt != 0 and HOMOLOGMOD.dispos != '' then 'background-color: #00ff00;' else '' end) 
                    end</expression>
            </field>            

            <field id="cnrt" print="false" noshow="true">
                <label Formstyle="display:none;" colstyle="color:red;font-weight:bold; text-align:center">CNRT</label>
                <expression>CASE WHEN (PEDCOTIZ.nrocha = '' or PEDCOTIZ.nrocha IS NULL) THEN ''
                ELSE (case when (HOMOLOGMOD.expte = '' or HOMOLOGMOD.dispos = '' or HOMOLOGMOD.plano = '' or PEDCOTIZ.homologacion_id = '' or PEDCOTIZ.homologacion_id IS NULL) then 'NO' ELSE '' end) END</expression>
            </field>

            <field id="trabajos_cnrt" local="true" colstyle="color:red;font-weight:bold; text-align:center;" Formstyle="display:none;">    
                <label>CNRT</label>    
                <helper xml="prod_trabajos_cnrt.xml" dir="fabricacion/" type="link" modal="true">
                    <parameter source="nrofab" target="nrofab_id"/>
                </helper>
                <expression>case when @cant_trabajos_cnrt != 0 then (CONCAT(IFNULL((select CONCAT(DATE_FORMAT(TC.fecha_inspeccion_cnrt, '%d/%m'), ' ') FROM PROD_TRABAJOS_CNRT TC where TC.nrofab_id = nrofab and TC.fecha_inspeccion_cnrt != '0000-00-00' order by TC.fecha_inspeccion_cnrt ASC limit 1), ''), 'CNRT')) else '' end</expression>
                <attribute id="linkdes">nrofab</attribute>
                <attribute id="style">tiene_trabajos_cnrt</attribute>
                <if exp="'trabajos_cnrt' != '' and nrofab != 0">
                    <true>'trabajos_cnrt'</true>
                    <false>'cnrt'</false>
                </if>
            </field>

