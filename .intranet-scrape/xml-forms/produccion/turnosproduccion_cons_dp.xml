                <label Formstyle="display:none;">Posición</label>
                <tabla_ex id="MOMENTO" xml="momento_posiciones.xml" >
                </tabla_ex>
                <if exp="true">
                    <true>offset</true>
                    <false>0</false>
                </if>
                <tipo>varchar</tipo>
            </field>-->

            <field id="Entrega" noshow="true" print="false">
                <label>PreEntrega</label>
                <expression>select entrega from ENTREGASCOCHES where ENTREGASCOCHES.nrofab = TURNOSPRODUCCION.nrofab  and ENTREGASCOCHES.entrega IS NOT NULL  limit 1</expression>
                <tipo>date</tipo>
