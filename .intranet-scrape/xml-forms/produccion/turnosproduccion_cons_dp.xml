            <field deshabilitado="true" id="chasis" tabla="CHASIS" linkint="chasis_cons.xml" linkdes="Ver Datos del Chasis">
                <expression><![CDATA[CONCAT( SUBSTRING(CHASIS.chasis, -8, 2),'<b>', RIGHT(CHASIS.chasis, 6), '</b>')]]></expression>
                <label>Chasis</label>
                <tipo>editor</tipo>
                <help>Número de Serie del chasis</help>
                <paring destino="nrocha">nrofab</paring>
     <!--             <attribute id="tooltip">chasis_entrada</attribute>-->        
            </field>

            <field id="tieneFicha" noshow="true">
                <expression>case when PEDCOTIZ.estado_ficha = 1 then 'ficha_producto1_qry.xml' else '' end</expression>
            </field>
            
            <field deshabilitado="true" id="conces" tabla="CHASIS" linkint="cctconta_consulta.xml" linkdes="Ver medios de Contacto">
<!--                <expression>case when CHASIS.conces != '' then CHASIS.conces else TURNOSPRODUCCION.idconces end</expression>
                <tabla_ex vacio="true" xml="concesionario.xml"/> -->
                <expression>CONCESIONARIO.nombre</expression>
                <label>Conc</label>
                <help>Concesionario</help>
                <paring destino="ctacod">ctaconces</paring>
                <paring destino="siscod">siscli</paring>
            </field>

            <field id="linkmodchasis" noshow="true">
                <expression>(select 'modchasis_cambios_qry.xml' from MODCHASIS_CAMBIOS MC where MC.modelo_id = MODCHASIS.id_modelo and MC.fecha_cambio &lt;= CHASIS.entrada and MC.notifica = 1)</expression>
            </field>

            <field id="colorchasis" noshow="true" local="true">
                <if exp="'linkmodchasis' != '' ">
                    <true>'color:red; font-size:small'</true>
                    <false>''</false>
                </if>
            </field>

            <field id="id_modelo" tabla="MODCHASIS" oculto="true" />
              
            <field deshabilitado="true" id="moddes" tabla="MODCHASIS" _style="max-width:2em; max-height:3em:text-overflow: ellipsis;">
                <expression>left(concat((case when MODCHASIS.desabv != '' then MODCHASIS.desabv else TURNOSPRODUCCION.modeloChasis end),' ' ,(select ifnull(group_concat(MC.texto_notificacion), '') from MODCHASIS_CAMBIOS MC where MC.modelo_id = MODCHASIS.id_modelo and MC.fecha_cambio &lt;= CHASIS.entrada and MC.notifica = 1) ), 20) </expression>
                <label >Mod</label>
                <tipo>varchar</tipo>
                <attribute id="linkint">linkmodchasis</attribute>
                <attribute id="style">colorchasis</attribute>
                <helper xml="" type="link" title="Cambios" dir="/produccion/man/">
                    <parameter source="id_modelo" target="modelo_id" />
                </helper>
            </field>
<!--             <field deshabilitado="true" id="abrev_euro" tabla="EURO_TIPO" noshow="true">
                <label >Eu</label>
                <tipo>varchar</tipo>
            </field> -->

            <field id="ficha_id" noshow="true">
                <expression>PEDCOTIZ.id</expression>
            </field>

            <field id="nrofab"  noZero="true">
                <attribute id="linkint">tieneFicha</attribute>
                <expression>nrofab</expression>
                <label modpos="nobr" style="text-align:center;color:#444;font-size:14px;">Fab</label>
                <help>Número de Fabricación</help>
                <paring destino="nrocha">nrofab</paring>
                <detalle>nrocha</detalle>
                <helper type="link" xml="ficha_producto1_qry.xml" dir="/producto" modal="true" title="Ficha Técnica">
                    <parameter source="ficha_id" target="producto_id"/>
                    <parameter source="nrofab" target="nrofab"/>
                </helper>
            </field>
            
            <field id="max_fec" noshow="true">
              <expression>@maxrev:=(select DATE(max(timestamp_atributo)) from PRODUCTO_ATRIB_VALORES where producto_id = id)</expression>
<!--    <expression>@maxrev:=(SELECT fecha FROM `HTXLOG` WHERE (obs LIKE concat('% N.Fab.: ',nrofab,'%') or obs LIKE concat('% Coche: ', nrofab,'%')) AND (xmlprog ='fichaventas_abm.xml' or xmlprog = 'accesorios_coche.xml' or xmlprog = 'accesorios_coche_precio.xml' or xmlprog = 'producto_atributos_valores.xml' or xmlprog = 'producto_estado_ficha_update.xml') ORDER BY fecha DESC LIMIT 1)</expression> 
 -->        </field>

            <field id="today" noshow="true" print="false">
                <expression>DATE(NOW())</expression>
            </field>

            <field id="ayer"  noshow="true" print="false">
                <expression>DATE_SUB(curdate(), INTERVAL 1 DAY)</expression>
            </field>
            
            <field id="maxfec" local="true" noshow="true" print="false">
                <label>1</label>
                <if exp="'max_fec' == 'today'">
                    <true>'font-size:17px;color:red;font-weight:bold;text-decoration: blink;'</true>
                    <false>('max_fec'=='ayer')?'font-size:17px;color:blue;font-weight:bold;':'font-size:11px;color:green;font-weight:bold;'</false>
                </if>
                <tipo>varchar</tipo>
            </field>

            <field id="nroF" noshow="true">
                <expression>CONCAT(nrofab,',')</expression>
            </field>
            
