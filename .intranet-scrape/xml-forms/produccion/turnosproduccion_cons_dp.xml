    	    <field id="control_lcm" style="font-size:11px;color:green;font-weight:bold;">
        		<expression>(SELECT date(hora_control) FROM PROD_CONTROL_MOVIM WHERE prodcontrol_id = 504 and nrofab_id = TURNOSPRODUCCION.nrofab LIMIT 1)</expression>
        		<label>Ctrl LCM</label>
        		<tipo>date</tipo>
        		<format>d/m</format>
