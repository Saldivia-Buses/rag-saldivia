            <field id="offset" noshow="true" deshabilitado="true">
                <expression>
                    select count(*) from TURNOSPRODUCCION as TUR where
                    TUR.fechaing &gt;= TURNOSPRODUCCION.fechaing and
                    TUR.fechaing &lt;= now()
                </expression>
                <tipo>integer</tipo>
            </field>
            <field id="cant" local="true" deshabilitado="true" noshow="true" print="false">
