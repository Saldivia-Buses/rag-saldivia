            <field id="max_fec" noshow="true">
<!--    <expression>@maxrev:=GREATEST((SELECT MAX(fecha) from HTXLOG  where ( HTXLOG.xmlprog = 'Fichaventas_abm.xml' or xmlprog = 'accesorios_coche.xml' ) and ( HTXLOG.obs like concat('%N.Fab.: ',nrofab,'%') )  or ( HTXLOG.obs like concat('% Coche: ',nrofab,'%')) ) , (select max(ACC.fecha) from PEDCOTIZ AS PED1 left join ACCESORIOS_COCHE as ACC on ACC.ficha_id = PED1.id where PED1.id = PEDCOTIZ.id ))</expression> -->
    <expression>@maxrev:=GREATEST(PEDCOTIZ.revfec , (select max(ACC.fecha) from PEDCOTIZ AS PED1 left join ACCESORIOS_COCHE as ACC on ACC.ficha_id = PED1.id where PED1.id = PEDCOTIZ.id ))</expression>
            </field>

            <field id="maxfec" local="true" noshow="true" print="false">
                <label>1</label>
                <expression>case when @maxrev = DATE(NOW()) then 'animation: blink 1s steps(5, start) infinite; -webkit-animation: blink 1s steps(5, start) infinite;font-size:16px;color:red;font-weight:bold;text-decoration: blink;'
                    when @maxrev = DATE_SUB(curdate(), INTERVAL 1 DAY)  then 'font-size:16px;color:blue;font-weight:bold;'

                    else 'font-size:16px;color:green;font-weight:bold;'
                end</expression>
                <tipo>varchar</tipo>
            </field>
            <field id="log" local="true" linkint="turnos_log_terminal_cons.xml"  linkdes="Historial" print="false">
                <label getStyle="maxfec"  Formstyle="display:none;">Modificado</label>
                <!--                <expression>PEDCOTIZ.revfec</expression> -->
                <expression>case when @maxrev = DATE(NOW()) then 'HOY'
                    when @maxrev = DATE_SUB(curdate(), INTERVAL 1 DAY) then 'Ayer'
                else date_format(@maxrev, '%d/%m') end</expression>

                <paring destino="obs"     operador="like">nroF</paring>
                <paring destino="num"    >nroF</paring>


            </field>
