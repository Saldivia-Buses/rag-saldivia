	    <field id="title" noshow="true">
		<expression>concat(nrofab, ' ',(select ctafan from CCTCUENT where siscod = '02' and CCTCUENT.ctacod = (case when PEDCOTIZ.ctacod != '' then PEDCOTIZ.ctacod else TURNOSPRODUCCION.ctacod end )),' - ',
CARROCERIA.modcar,' ',MARCHASIS.mardes, ' ',MODCHASIS.desabv, ' ',
case when CARROCERIA.doble_piso = 1 then (CONCAT(HOMOLOGMOD.asientos, '+', HOMOLOGMOD.asientos_plantabaja)) else (HOMOLOGMOD.asientos + HOMOLOGMOD.acompañante) end,' Asientos ',
(CASE WHEN HOMOLOGMOD.banbar = 1 THEN 'BB' ELSE ' ' END) ,'- Largo: ', largo, trim(referencia) )</expression>
	    </field>

