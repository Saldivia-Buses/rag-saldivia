                        <condicion operador="=" >'posic'</condicion>
                    </field>
                </parametro>
                <tipo>integer</tipo>
            </field>

            <field id="colorFecTer"  oculto="true">
                <expression>case when PEDCOTIZ.terminacion != '0000-00-00' then 'color:green; font-size:11px;font-weight:bold;' else 'color:#B32600; font-weight:bold;' end</expression>
                <tipo>varchar</tipo>
            </field>

            <field id="fechaing2" _PDFanchofijo="true" oculto="true">
                <expression>fechaing</expression>
            </field>          


            <field id="fechaTerminacion" local="true" >
                <label modpos="nobr">Terminacio</label>
                <attribute id="style">colorFecTer</attribute>

                <expression>(case when PEDCOTIZ.terminacion != '0000-00-00' then PEDCOTIZ.terminacion else (select TUR.fechaing from TURNOSPRODUCCION as TUR where
                TUR.fechaing &gt; TURNOSPRODUCCION.fechaing order by TUR.fechaing ASC limit [__cant__], 1) end)</expression>
                <help>Fecha de Salida de Linea</help>
                <tipo>date</tipo>

            </field>

            <field id="sale2" esClave="true" noshow="true">
                <label modpos="nobr" >terminado</label>
                <expression having="false">DATE_ADD((case when ingresoLinea != '0000-00-00' then ingresoLinea else fechaing end), INTERVAL 30 DAY)</expression>
                <tipo>date</tipo>
                <preparam campo="sale2" operador="&lt;">true</preparam>
            </field>
 
            <field id="fechaTerminacion" local="true" noshow="true">
                <label modpos="nobr">Pre Ent</label>
                <attribute id="style">colorFecTer</attribute>

                <expression>(case when PEDCOTIZ.terminacion != '0000-00-00' then PEDCOTIZ.terminacion else (DATE_ADD((case when ingresoLinea != '0000-00-00' then ingresoLinea else fechaing end), INTERVAL 45 DAY)) end)</expression>
                <help>Fecha de Salida de Linea</help>
                <tipo>date</tipo>
                <format>d/m</format>

            </field>
            <field deshabilitado="true" id="desabv" tabla="MODCHASIS">
