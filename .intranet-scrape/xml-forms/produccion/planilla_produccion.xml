      <field id="carpeta_planos" local="true" linkint="prod_carpeta_planos_qry.xml" linkdir="fabricacion" _linkdes="Carpeta Planos" linkWidth="95%" linkHeight="95%">
          <label modpos="nobr">PL STD</label>
          <paring destino="homologacion">homologacion_id</paring>
          <paring destino="nrocar">nrocar</paring>
          <paring destino="modelo_lcm">modelo_lcm_id</paring>
          <paring destino="nrofab">nrofab</paring>
          <paring destino="producto_id" >ficha_id</paring>
          <expression>select (case when HOMOLOGMOD.nrocar != '' then CONCAT(count(*), ' std') else '' end) FROM PRD_CARPETA_PLANOS where PRD_CARPETA_PLANOS.homologacion_id = HOMOLOGMOD.id_homologacion or PRD_CARPETA_PLANOS.nrocar_id = HOMOLOGMOD.nrocar or PRD_CARPETA_PLANOS.modelo_lcm_id = HOMOLOGMOD.modelo_lcm_id</expression>
          <attribute id="linkdes">nrofab</attribute>
      </field>

      <field id="planos_especiales" local="true" linkint="prd_planos_qry.xml" linkdir="produccion" _linkdes="Carpeta Planos" linkWidth="95%" linkHeight="95%">
        <label modpos="nobr">PL ESP</label>
        <paring destino="nrofab">nrofab</paring>
        <expression>select (case when HOMOLOGMOD.nrocar != '' then CONCAT(count(*), ' esp') else '' end) FROM PRD_PLANOS where PEDCOTIZ.nrocha = PRD_PLANOS.nrofab and PRD_PLANOS.carpetaplanos_id = 0</expression>
        <attribute id="linkdes">nrofab</attribute>
      </field>

      <field id="fotos_produccion" showValor="true" linkint="homol_fotos_prod_producto_qry.xml" linkdir="fabricacion" _linkdes="Carpeta Planos" linkWidth="95%" linkHeight="95%">
        <label>Fotos Produ</label>
        <paring destino="homologacion_id" operador="=">id_homologacion</paring>
        <paring destino="producto_id" operador="=">ficha_id</paring>
        <expression><![CDATA[SELECT CONCAT(IFNULL(count(*), 0), ' Fotos') FROM HOMOLOG_FOTOS_PROD HAV
                                JOIN PRODUCTO_ATRIB_VALORES PAV ON PAV.prdatributo_id = HAV.prdatributo_id 
                                                               AND PAV.valor_atributo = 1
                                WHERE HAV.homologacion_id = HOMOLOGMOD.id_homologacion
                                  AND PAV.producto_id = PEDCOTIZ.id ]]></expression>
        <valor>'Fotos Produc'</valor>
        <tipo>varchar</tipo>
        <attribute id="linkdes">nrofab</attribute>
      </field>
      
    <field id="pl2" local="true" showObjTabla="true">
    <label>Planos</label>
    <helper type="object" xml="pedidoint_qry.xml">
  <parameter source="nrofab" target="nrofab" />
  </helper>
    </field>

            <field id="momentos" local="true" deshabilitado="true" print="false" noshow="true" >
                <label Formstyle="display:none;"  style="font-size:16px;">Posición</label>

                <tabla_ex id="MOMENTO" xml="momento_posiciones.xml" >
                </tabla_ex>
                <if exp="true">
                    <true>offset</true>
                    <false>0</false>
                </if>

                <tipo>varchar</tipo>
            </field>
            <field id="Entrega" noshow="true" print="false">
                <label>PreEntrega</label>
                <expression>select entrega from ENTREGASCOCHES where ENTREGASCOCHES.nrofab = TURNOSPRODUCCION.nrofab  and ENTREGASCOCHES.entrega IS NOT NULL  limit 1</expression>
                <tipo>date</tipo>

            </field>

            <field id="ubicacion" noshow="true">
                <label >Ubicacion</label>
                <help>Ubicacion</help>
            </field>
            <field id="colorEnt" noshow="true" local="true">
                <if exp="'Entrega' != ''">
                    <true>'color:green;font-weight:bold;font-size:16px'</true>
                    <false>('ubicacion' != '')?'color:blue;font-weight:bold;font-size:16px;':''</false>
                </if>
            </field>
            <field id="CANTposic" noshow="true">
                <expression>select count(*) from POSICIONESFAB</expression>
            </field>
