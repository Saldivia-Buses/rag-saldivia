            <field id="Entregado" _noshow="true" print="false" deshabilitado="false">
                <label colstyle="display:none;">Entregado</label>
                <expression>select count(*) from ENTREGASCOCHES where ENTREGASCOCHES.nrofab = TURNOSPRODUCCION.nrofab  and ENTREGASCOCHES.entrega IS NOT NULL  limit 1</expression>
                <tipo>integer</tipo>
                <options>
                    <option valor="0">No</option>
                    <option valor="1">SI</option>
                </options>
            </field>
                 
            <field  id="conces" tabla="CHASIS">
                <expression>CONCESIONARIO.nombre</expression>
                <tabla_ex vacio="true" xml="concesionario.xml"/>
                <label>Conc</label>
                <help>Concesionario</help>
            </field>

            <field deshabilitado="true" id="nrocar" tabla="HOMOLOGMOD">

                <expression>case when HOMOLOGMOD.nrocar != '' then HOMOLOGMOD.nrocar else TURNOSPRODUCCION.nrocar end</expression>

                <label  style="font-size:16px;">Mod.</label>
                <help/>
                <tabla_ex id="CARROCERIA">
                    <field id="nrocar">
                    </field>
                    <field id="desabv">
                    </field>

                    <field id="siscod" oculto="true">
                        <condicion operador="=">03</condicion>
                    </field>
                </tabla_ex>
                <tipo>varchar</tipo>
            </field>

            <field id="asientos" deshabilitado="true" noZero="true">
                <label style="font-size:16px; text-align:center;">Asi</label>
                <tipo>integer</tipo>
                <expression>case when CARROCERIA.doble_piso = 1 then (CONCAT(HOMOLOGMOD.asientos, '+', HOMOLOGMOD.asientos_plantabaja)) else (HOMOLOGMOD.asientos + HOMOLOGMOD.acompañante) end</expression>
            </field>
            
            <field id="bagno" deshabilitado="true" noZero="true">
                <label style="font-size:16px;">B</label>
                <expression>atributoUnidad(id, 'bagno')</expression>
                <options>
                    <option valor="0"></option>
                    <option valor="1">BB</option>
                    </options>
                <tipo>varchar</tipo>
            </field>

            <field id="cucheta">
                <expression>atributoUnidad(id, 'cucheta')</expression>
                <label style="font-size:16px;">Cuch</label>
                <helper type="combo" xml="prd_helper_propiedades.xml" dir="/produccion" emtpy="true">
                    <field id="campoficha_id">
                        <condicion operador="=">'cucheta'</condicion>
                    </field>
                </helper>
            </field>

            <field id="aire" noZero="true">
            <expression>atributoUnidad(id, 'marair')</expression>
                <label style="font-size:16px;">A/A</label>
                <tabla_ex id="MARCAAIR" vacio="true" indexvacio="0" valorvacio="NO">
                    <field id="marair" />                     
                    <field id="desair">
                        <expression>LEFT(desair, 4)</expression>
                    </field>                    
                    <field id="siscod" oculto="true">
                        <condicion operador="=">03</condicion>
                    </field>
                </tabla_ex>
                <tipo>varchar</tipo>
            </field>


            <field id="asiento" noshow="true">
                <expression>@asiento:=(SELECT (SUM(ROUND(pencps, 2))) from CPSENCAB left JOIN CPSMOVIM on
                    ( CPSMOVIM.siscod = CPSENCAB.siscod ) and
                    CPSMOVIM.ocpnro = CPSENCAB.ocpnro and CPSMOVIM.siscod = ''
                    where
                    CPSMOVIM.nrocha = TURNOSPRODUCCION.nrofab   and
                    CPSENCAB.ctacod = (select MARCAASI.ctacod
                from  MARCAASI where marasi = atributoUnidad(id, 'marasi') ))</expression>
               
            </field>


            <field id="faltante" noshow="true">
                <expression>(CASE WHEN @asiento > 1 THEN 'color:red;font-size:16px;'
                    when @asiento = 0 THEN 'color:green;font-size:16px;'
                    when @asiento &lt;= 1 THEN 'color:orange;font-size:16px;'
                    ELSE
                'color:grey;font-size:16px;' END)</expression>
            </field>


            <field id="marasi">
                <expression> atributoUnidad(id, 'marasi')</expression>
                <attribute id="style">faltante</attribute>
                <label >Asientos</label>
                <help/>
                <tabla_ex id="MARCAASI">
                    <field id="marasi">
                    </field>
                    <field id="asides">
                        <expression>LEFT(asides, 4)</expression>
                    </field>
                    <field id="siscod" oculto="true">
                        <condicion operador="=">03</condicion>
                    </field>
                </tabla_ex>
            </field>

      <field id="cnrt">
            <label style="color:red;font-weight:bold; text-align:center">CNRT</label>
            <expression>CASE WHEN (PEDCOTIZ.nrocha = '' or PEDCOTIZ.nrocha IS NULL) THEN ''
                    ELSE (case when (HOMOLOGMOD.expte = '' or HOMOLOGMOD.dispos = '' or HOMOLOGMOD.plano = '' or PEDCOTIZ.homologacion_id = '' or PEDCOTIZ.homologacion_id IS NULL) then 'NO' ELSE '' end) END</expression>
      </field>

            <field id="hi" deshabilitado="true" clasefila="true" noshow="true">
                <expression>case when TURNOSPRODUCCION.fechaActualiza = DATE(NOW()) then 'resaltado' else '' end</expression>

                <tipo>varchar</tipo>
            </field>
    
            <order>
                <field id="fechaing2"/>
            </order>
          
         
          
        </table>
        <join tipo="left">
            <table id="PEDCOTIZ">
                <field id="nrocha">
                    <condicion operador="=">TURNOSPRODUCCION.nrofab and PEDCOTIZ.nrocha != 0 and estado_ficha != 0</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="HOMOLOGMOD">
                <field id="id_homologacion">
                    <condicion operador="=">PEDCOTIZ.homologacion_id</condicion>
                </field>
            </table>
        </join>        
    <join tipo="left">
               <table id="CARROCERIA">
          <field id="nrocar">
                 <condicion operador="=">HOMOLOGMOD.nrocar</condicion>
          </field>
        </table>
    </join>
    <join tipo="left">
      <table id="MARCHASIS">
        <field id="marcod">
          <condicion operador="=">HOMOLOGMOD.marcod</condicion>
        </field>
      </table>
    </join>

        <join tipo="left">
            <table id="CHASIS">
                <field id="nrocha">
                    <condicion operador="=">TURNOSPRODUCCION.nrofab and CHASIS.nrocha != 0</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="MODCHASIS">
                <field id="modcha">
                    <condicion operador="=">CHASIS.modcod</condicion>
                </field>
                <field id="marcod">
                    <condicion operador="=">CHASIS.marcod</condicion>
                </field>
            </table>
        </join>
        
        <join tipo="left">
            <table id="CONCESIONARIO">
                <field id="idconces">
                    <condicion operador="=">(case when CHASIS.conces != '' then CHASIS.conces else TURNOSPRODUCCION.idconces end)</condicion>
                </field>
            </table>
        </join>
                         
    </form>
</histrix>
