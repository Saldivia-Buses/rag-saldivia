<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="abm" width="40">
  <title>Solicitud de Reserva</title>
  <obs/>
  <form>
    <table id="PROD_RESERVA">
      <title>Solicitud de Reserva</title>
      <field id="id_reserva" esClave="true" autoinc="true" noshow="true">
			</field>
      <field id="numero_reserva">
        <label>Numero</label>
        <help>Numero de Solicitud</help>
      </field>
      <field id="fecha_reserva">
        <label modpos="nobr">Fecha</label>
        <help>Fecha de Solicitud</help>
        <valor>today</valor>
      </field>
      <field id="ctacod_id">
        <label  colspan="4" >Cliente</label>
        <help>Codigo de Cuenta</help>
        <tabla_ex condes="true" id="CCTCUENT" vacio="true">
          <field id="ctacod"/>
          <field id="ctafan2">
            <expresion>CCTCUENT.ctanom</expresion>
          </field>
          <field id="siscod" oculto="true">
            <condicion operador="=">'02'</condicion>
          </field>
          <field id="baja" oculto="true">
            <condicion operador="=">0</condicion>
          </field>
          <order>
            <field id="ctanom"/>
          </order>
        </tabla_ex>
        <actualiza>
          <field destino="ctacod_id" id="cctlinea_id"/>
        </actualiza>
      </field>
      <!--
            <field id="ctafan" tabla="CCTCUENT" noshow="true">
                <label>ctafan</label>
            </field>
-->
      <field id="cctlinea_id">
        <label colspan="4">Linea </label>
        <helper type="combo" xml="cct_cliente_linea.xml" dir="/clientes_local" empty="true"/>
      </field>

      <field id="homologacion_id" _deshabilitado="true">
        <label colspan="4">Homologacion</label>
        <helper type="combo" xml="combo_homologacion_modelo.xml" dir="/fabricacion" empty="true">
                </helper>
      </field>
      <field id="cantidad_coches">
        <label colspan="4">Cantidad de Coches</label>
      </field>
      <field id="observacion_reserva">
        <label>Observaciones</label>
        <help>Observaciones</help>
      </field>
    </table>
  </form>
</histrix>
