      <tabla_ex xml="posiciones.xml" vacio="true"/>
      <label  modpos="nobr">Pos</label>
      <help>Posicion en la linea</help>

      </field> -->

            
            <field id="colorEnt" noshow="true" local="true">
                <if exp="'Entrega' != ''">
                    <true>'color:green;font-weight:bold;'</true>
                    <false>('ubicacion' != '')?'color:bluoe;font-weight:bold;':''</false>
                </if>
            </field>
            <field id="CANTposic" noshow="true">
                <expression>select count(*) from POSICIONESFAB</expression>
            </field>

            <field id="modeloChasis">
                <label modpos="nobr" colstyle="display:none;">Mod.Chasis</label>
                <help>Modelo del Chasis</help>
                <size>8</size>
            </field>
            <field id="bagno" colstyle="display:none;">
                <label modpos="nobr">BB </label>
                <helper type="combo">
                    <option value="0"></option>
                    <option value="1">No</option>
                    <option value="2">Si</option>
                    <option value="3">S/D</option>
                </helper>
                <tipo>varchar</tipo>
            </field>
            <field id="cucheta" colstyle="display:none;">
                <label modpos="nobr" >Cucheta</label>
                <helper type="combo">
                    <option value="0"></option>
                    <option value="1">No</option>
                    <option value="2">Si</option>
                    <option value="3">S/D</option>
                </helper>
            </field>
            <field id="marair" _deshabilitado="true" colstyle="display:none;">
                <label  modpos="nobr">Marca A/A</label>
                <helper type="combo" id="MARCAAIR" empty="true">
                    <field id="marair">

                    </field>
                    <field id="desair">
                        <expression>LEFT(desair, 3)</expression>
                    </field>

                    <field id="siscod" oculto="true">
