      </field>
        -->
			<field id="ubicacion">
                <label colstyle="display:none;" modpos="nobr">Ubicacion</label>
                <help>Ubicacion</help>
                <size>8</size>
            </field>

            <field id="terminacion"  deshabilitado="true" noshow="true">
                <expression>CASE WHEN PEDCOTIZ.terminacion != '0000-00-00' THEN PEDCOTIZ.terminacion ELSE '' END</expression>
                <label modpos="nobr" Formstyle="display:none" >PreEntrega</label>
               
            </field>
			<field id="offset" noshow="true" deshabilitado="true">
                <expression> select count(*) from TURNOSPRODUCCION as TUR where
            	    TUR.linea_id = TURNOSPRODUCCION.linea_id and
                    TUR.fechaing &gt;= TURNOSPRODUCCION.fechaing and TUR.fechaing
                    &lt;= now()
                </expression>
                <tipo>integer</tipo>
            </field>
			<field id="salePreent" local="true">
				<expression>CONCAT(DATE_FORMAT(DATE_ADD((case when ingresoLinea != '0000-00-00' then ingresoLinea else fechaing end), INTERVAL 45 DAY), '%d/%m/%y'), 'n', IFNULL(DATE_FORMAT(CASE WHEN PEDCOTIZ.terminacion != '0000-00-00' THEN PEDCOTIZ.terminacion ELSE '' END, '%d/%m/%y'), ''))</expression>
				<label style="width:auto;">Sale PreEntrega</label>
			</field>
			 <field id="momentos" local="true" deshabilitado="true">
                <label style="display:none;" colstyle="display:none;" modpos="nobr" >Posición</label>
                <tabla_ex id="MOMENTO" xml="momento_posiciones.xml">
                </tabla_ex>
                <if exp="true">
                    <true>offset</true>
                    <false>0</false>
                </if>

                <tipo>varchar</tipo>
            </field>
			<field id="Entrega" _noshow="true" print="false">
                <label  style="display:none;"  colstyle="display:none;" modpos="nobr">Entrega</label>
                <expression>select entrega from ENTREGASCOCHES where ENTREGASCOCHES.nrofab = TURNOSPRODUCCION.nrofab  and ENTREGASCOCHES.entrega IS NOT NULL  limit 1</expression>
                <tipo>date</tipo>
            </field>

            <field id="posent" local="true" print="false" ignoreOption="true" getStyle="colorEnt" deshabilitado="true">

                <label modpos="nobr" Formstyle="display:none;">Posic/Entr.</label>
                <!-- <atributte id="style">colorEnt</atributte> -->
                <tabla_ex id="MOMENTO" xml="momento_posiciones.xml" />

                <if exp="'Entrega' != '' and nrofab != 0">
                    <true>date(  'd/m/Y', strtotime ( 'Entrega'))</true>
                    <false>('ubicacion' != '')?'ubicacion': ((momentos &lt;= CANTposic)?'momentos':'')</false>
                </if>
            </field>

            <field deshabilitado="true" id="marcod" tabla="CHASIS">
                <expression>CHASIS.marcod</expression>
                <label modpos="nobr" Formstyle="display:none;">Ch.</label>
                <help/>
                <tabla_ex id="MARCHASIS">
                    <field id="marcod">
                    </field>
                    <field id="desabv">
                    </field>

                    <field id="siscod" oculto="true">
                        <condicion operador="=">03</condicion>
                    </field>
                </tabla_ex>
                <tipo>integer</tipo>
            </field>

            <field deshabilitado="true" id="moddes" tabla="MODCHASIS">

                <expression>case when MODCHASIS.moddes != '' then MODCHASIS.moddes else
                    TURNOSPRODUCCION.modeloChasis end
                </expression>

                <label modpos="nobr" Formstyle="display:none;">Mod</label>
                <help/>
                <tipo>varchar</tipo>
            </field>
            <field id="fechaActualiza" valauto="true" deshabilitado="true" noshow="true">
                <label modpos="nobr" _colstyle="display:none">Fecha Act.</label>
                <valor>today</valor>
                <tipo>date</tipo>
            </field>

            <field deshabilitado="true" id="chasis" tabla="CHASIS"  linkint="chasis_cons.xml" linkdes="Ver Datos del Chasis">
                <expression><![CDATA[CONCAT( SUBSTRING(CHASIS.chasis, -8, 2),'<b>', RIGHT(CHASIS.chasis, 6), '</b>')]]></expression>
                <label Formstyle="display:none;">Ch N</label>
                <help>Numero de Serie del chasis</help>
                <paring destino="nrocha">nrofab</paring>
                <attribute id="tooltip">chasis_entrada</attribute>        

            </field>
            <field id="admin" local="true" noshow="true">
                <valor>1</valor>
            </field>
            <field id="tieneFicha" noshow="true">
                <expression>case when PEDCOTIZ.nrocha != 0 and PEDCOTIZ.estado_ficha = 1 then 'ficha_producto1_qry.xml' else '' end</expression>
            </field>

            <field id="ficha_id" noshow="true">
                <expression>PEDCOTIZ.id</expression>
            </field>
            <field id="nrofab"  deshabilitado="false" noZero="true" linkint="ficha_producto1_qry.xml" linkdir="/producto" linkdes="Ficha Producto">
                <label _modpos="nobr" style="color:#444;font-weight:bold;">Nro.</label>
                <help>Numero de Fabricacion</help>
                <helper type="external" id="CHASIS">
                    <field id="nrocha" />
                    <field id="chades" />
                </helper>
                <paring destino="nrofab">nrofab</paring>
                <paring destino="producto_id">ficha_id</paring>
                <paring destino="id">ficha_id</paring>
                <detalle>nrocha</detalle>
            <attribute id="linkint">tieneFicha</attribute>
            </field>
            
            <field id="accesorios"  linkint="cotiz_accesorios_coche_foto_cons2.xml" linkdir="/cotizacion" _linkint="accesorios_coche_qry.xml" deshabilitado="true"
		    style="width:auto;"
                   linkdes="Adicionales"
                   noZero="true" >
                   <expression>select sum(ifnull(precio_unitario,0) * cantidad) from ACCESORIOS_COCHE AS ACC where estado != 2  and ACC.ficha_id = PEDCOTIZ.id</expression>
                <label modpos="nobr" Formstyle="display:none;" style="color:#444;font-weight:bold;">Adicionales</label>
                <paring destino="ficha_id">PEDid</paring>
                <paring destino="showprecios">1</paring>
            </field>
	    
			<field id="emails" _showTablaObj="true" local="true">
				<helper type="link" xml="contaemail_qry.xml" dir="/email">
					<parameter target="subject" source="subj" operator="like"/>
				</helper>
				<label >Mail</label>
				<help></help>
				<expression><![CDATA[select CONCAT(RIGHT(fecha, 2), '/', SUBSTRING(fecha, 6, 2)) from HTXMAIL where subject like concat('%',@subj,'%') limit 1]]></expression>
			</field>	
			<field id="cantPend" local="true" >
				<label>Pend.</label>
				<expression>CASE WHEN (SELECT COUNT(*) FROM ACCESORIOS_COCHE ac WHERE estado = 0 and precio_unitario != 0 and ac.ficha_id = PEDCOTIZ.id) THEN CONCAT((SELECT COUNT(*) FROM ACCESORIOS_COCHE ac WHERE estado = 0 and precio_unitario != 0 and ac.ficha_id = PEDCOTIZ.id), '/', (SELECT COUNT(*) FROM ACCESORIOS_COCHE ac WHERE ac.ficha_id = PEDCOTIZ.id and precio_unitario != 0)) END</expression>
			</field>	
