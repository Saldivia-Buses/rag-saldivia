      <expression>(select count(*) from STKINMOV where STKINMOV.nrocha=nrofab and STKINMOV.siscod = '01' and STKINMOV.nrocha != 0)</expression>
      <label >Comp.</label>
      <help>Completado</help>
      <tipo>grafico</tipo>
      </field> -->

            <field id="idconces" _noshow="true">
                <tabla_ex vacio="true" xml="concesionario.xml"/>
                <label modpos="nobr" colstyle="display:none;">Concesionario</label>
                <help>Concesionario</help>
                <tipo>varchar</tipo>
                <valor>0</valor>
            </field>
            <field id="idconces2" noshow="true" _colstyle="display:none;" >
                <tabla_ex vacio="true" xml="concesionario.xml"/>
                <expression having="false">(case when !isnull(CHASIS.conces) then CHASIS.conces else TURNOSPRODUCCION.idconces end )</expression>
<!--                <preparam campo="idconces2" operador="=">true</preparam> -->

            </field>

            <field id="ctacod" deshabilitado="true" _noshow="true" _forceUpdate="true" _style="display:none;">
                <label modpos="nobr">cta</label>
                <help>Codigo de Cuenta</help>
            </field>
            
            <field id="ctanom" autocompletar="true" deshabilitado="false">
                <label modpos="nobr" colstyle="display:none;" >Cliente </label>
                <expression>select ctafan from CCTCUENT where CCTCUENT.siscod = '02' and
                    CCTCUENT.ctacod = (case when PEDCOTIZ.ctacod != '' then PEDCOTIZ.ctacod else
                    TURNOSPRODUCCION.ctacod end) limit 1
                </expression>  
                <ayuda_ex condes="true" id="CCTCUENT" vacio="true" >

                    <field id="ctacod" noshow="true" >
                    <detalle>ctacod</detalle>
                    </field>

                    <field id="ctafan">
                    </field>

                    <field id="siscod" oculto="true">
                        <condicion operador="=">'02'</condicion>
                    </field><!--
                    <field id="catcod" oculto="true">
                        <condicion operador="=">1</condicion>
                    </field>-->
                    <field id="baja" oculto="true">
                        <condicion operador="=">0</condicion>
                    </field>


                    <order>
                        <field id="ctafan"></field>
                    </order>
                </ayuda_ex>
            </field>

            <field id="nrocar">
                <label modpos="nobr" colstyle="display:none;">Carroc.</label>
                <help>Modelo de Carroceria</help>
                <tabla_ex id="CARROCERIA">
                    <field id="nrocar">
                    </field>
                    <field id="desabv">
                    </field>

                    <field id="siscod" oculto="true">
                        <condicion operador="=">03</condicion>
                    </field>
                    <order><field id="desabv"/></order>
                </tabla_ex>
            </field>
            <field id="cantasi">
                <label modpos="nobr" colstyle="display:none;">Asientos</label>
                <help/>
                <size>2</size>
            </field>
           

            
