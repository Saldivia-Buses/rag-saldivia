            <field deshabilitado="true" id="ctacon2" tabla="CHASIS" noshow="true">
                <expression>case when CONCESIONARIO.ctacod >= 0 then
                    CONCESIONARIO.ctacod else 0 end
                </expression>
                <tipo>integer</tipo>
            </field>

            <field deshabilitado="true" id="conces" tabla="CONCESIONARIO"
                   linkint="cctconta_consulta.xml" linkdes="Ver medios de Contacto">
                <expression>CONCESIONARIO.nombre</expression>
                <!-- <expression>case when CHASIS.conces != '' then CHASIS.conces else
          TURNOSPRODUCCION.idconces end</expression>
        <tabla_ex vacio="true" xml="concesionario.xml"/> -->
                <label Formstyle="display:none;">Conces</label>
                <help>Concesionario</help>
                <tipo>varchar</tipo>
                <paring destino="ctacod">ctacon2</paring>
                <paring destino="siscod">siscli</paring>
            </field>
            <field deshabilitado="true" id="ctacod2" tabla="PEDCOTIZ"
                   linkint="cctconta_consulta.xml" linkdes="Ver medios de Contacto">
                <expression>case when PEDCOTIZ.ctacod != '' then PEDCOTIZ.ctacod else
                    TURNOSPRODUCCION.ctacod end
                </expression>
                <label modpos="nobr" Formstyle="display:none;">Cliente</label>
                <help>Codigo de Cuenta</help>omologacion y deberia 
                <tabla_ex condes="true" id="CCTCUENT">
                    <field id="ctacod2">
                	<expression>ctacod</expression>
                    </field>
                    <field id="ctafan">
                        <expression>LEFT(ctafan, 22)</expression>
                    </field>
                    <field id="siscod" oculto="true">
                        <condicion operador="=">'02'</condicion>
                    </field>
                </tabla_ex>
                <tipo>varchar</tipo>
                <paring destino="ctacod">ctacod2</paring>
                <paring destino="siscod">siscli</paring>

            </field>
            <field deshabilitado="true" id="otros" local="true" linkint="fichas_x_cliente.xml" linkdes="Total de Coches" print="false">
                <!-- xxx      <expression>select count(*) from PEDCOTIZ as PED where PED.ctacod = PEDCOTIZ.ctacod</expression> -->
                <expression>(case when !isnull(PEDCOTIZ.ctacod) then
                    (select count(*) from VUNIDADES as PED where PED.ctacod = PEDCOTIZ.ctacod)
                else (select count(*) from VUNIDADES as PED where PED.ctacod = TURNOSPRODUCCION.ctacod) end) </expression>

                <label Formstyle="display:none;">Ot.</label>
                <help>Codigo de Cuenta</help>
                <paring destino="ctacod">cliente</paring>
                <tipo>varchar</tipo>
            </field>
            <field id="ninterno" _tabla="PEDCOTIZ" print="false" deshabilitado="true">
                <expression>PEDCOTIZ.ninterno</expression>
                <label Formstyle="display:none;" >Int.</label>
                <help></help>
            </field>
            <field deshabilitado="true" id="nrocar2" tabla="PEDCOTIZ">
                <expression>case when PEDCOTIZ.nrocar != '' then PEDCOTIZ.nrocar else
                    TURNOSPRODUCCION.nrocar end
                </expression>

                <label modpos="nobr" Formstyle="display:none;">Mod.</label>
                <help/>
                <tabla_ex id="CARROCERIA">
                    <field id="nrocar">
                    </field>
                    <field id="desabv">
                    </field>

                    <field id="siscod" oculto="true">
                        <condicion operador="=">03</condicion>
                    </field>
                </tabla_ex>
                <tipo>varchar</tipo>
            </field>
            <field deshabilitado="true" id="cantasi2" tabla="PEDCOTIZ">

                <expression>case when PEDCOTIZ.cantasi != '' then PEDCOTIZ.cantasi else
                    TURNOSPRODUCCION.cantasi end
                </expression>

                <label modpos="nobr" Formstyle="display:none;">Asi</label>
                <help/>
                <tipo>integer</tipo>
            </field>
            <field deshabilitado="true" id="marcod" tabla="CHASIS">
                <expression>CHASIS.marcod</expression>
                <label modpos="nobr" Formstyle="display:none;">Ch.</label>
                <help/>
                <tabla_ex id="MARCHASIS">
                    <field id="marcod">
                    </field>
                    <field id="desabv">
                    </field>

                    <field id="siscod" oculto="true">
                        <condicion operador="=">03</condicion>
                    </field>
                </tabla_ex>
                <tipo>integer</tipo>
            </field>


            <field id="bagno2" deshabilitado="true" >
                <label modpos="nobr" Formstyle="display:none;">BB</label>
                <expression>CASE WHEN PEDCOTIZ.bagno != 0 THEN PEDCOTIZ.bagno ELSE TURNOSPRODUCCION.bagno END</expression>
                <helper type="combo">
                    <option value="0"></option>
                    <option value="1">No</option>
                    <option value="2">Si</option>
                    <option value="3">S/D</option>
                </helper>
                <tipo>varchar</tipo>
            </field>



            <field id="cucheta2">
                <expression>CASE WHEN PEDCOTIZ.cucheta != 0 THEN PEDCOTIZ.cucheta ELSE TURNOSPRODUCCION.cucheta END</expression>
                <label modpos="nobr" Formstyle="display:none;">Cuch</label>
                <helper type="combo">
                    <option value="0"></option>
                    <option value="1">No</option>
                    <option value="2">Si</option>
                    <option value="3">S/D</option>
                </helper>
            </field>



            <field id="marair2" _deshabilitado="true" >
				<expression>CASE WHEN PEDCOTIZ.marair != 0 THEN PEDCOTIZ.marair ELSE TURNOSPRODUCCION.marair END</expression>
                <label modpos="nobr"  Formstyle="display:none;">A/A</label>
                <helper type="combo" id="MARCAAIR" empty="true">
                    <field id="marair">
                    </field>
                    <field id="desair">
                        <expression>LEFT(desair, 3)</expression>
                    </field>

                    <field id="siscod" oculto="true">
                        <condicion operador="=">03</condicion>
                    </field>
                </helper>
                <tipo>varchar</tipo>
            </field>

            <field id="marasi">
                <expression>LEFT(MARCAASI.asides, 4)</expression>
                <label modpos="nobr" Formstyle="display:none;">Marca</label>
                <help/>
            </field>
	    <field id="cnrt">
		<label Formstyle="display:none;" colstyle="color:red;font-weight:bold; text-align:center">CNRT</label>
		<expression>CASE WHEN (PEDCOTIZ.nrocha = '' or PEDCOTIZ.nrocha IS NULL) THEN ''
                    ELSE (case when (HOMOLOGMOD.expte = '' or HOMOLOGMOD.dispos = '' or HOMOLOGMOD.plano = '' or PEDCOTIZ.homologacion_id = '' or PEDCOTIZ.homologacion_id IS NULL) then 'NO' ELSE '' end) END</expression>
	    </field>
		
	
        <field id="hi" deshabilitado="true" clasefila="true" noshow="true">
            <expression>case when TURNOSPRODUCCION.fechaActualiza = DATE(NOW())
                then 'resaltado' else '' end
            </expression>
            <tipo>varchar</tipo>
        </field>

		
            <order>
                <field id="fechaing"/>
            </order>
        </table>
        <join tipo="left">
            <table id="PEDCOTIZ">
                <field id="nrocha">
                    <condicion operador="=">TURNOSPRODUCCION.nrofab</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="HOMOLOGMOD">
                <field id="id_homologacion">
                    <condicion operador="=">PEDCOTIZ.homologacion_id</condicion>
                </field>

            </table>
        </join>
        <join tipo="left">
            <table id="CHASIS">
                <field id="nrocha">
                    <condicion operador="=">TURNOSPRODUCCION.nrofab</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="MODCHASIS">
                <field id="modcha">
                    <condicion operador="=">CHASIS.modcod</condicion>
                </field>
                <field id="marcod">
                    <condicion operador="=">CHASIS.marcod</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="MARCAASI">
                <field id="marasi">
                    <condicion operador="=">PEDCOTIZ.marasi</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="CONCESIONARIO">
                <field id="idconces">
                    <condicion operador="=">(case when CHASIS.conces != '' then  CHASIS.conces else TURNOSPRODUCCION.idconces
                        end)
                    </condicion>
                </field>
            </table>
        </join>
    </form>
</histrix>
