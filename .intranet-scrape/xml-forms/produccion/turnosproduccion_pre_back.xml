<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta"  path="/fotos/coches">

    <title>PROGRAMA DE PRODUCCION</title>
    <obs/>
    <form >
        <table id="TURNOSPRODUCCION" label="Programa de Produccion"  showCantidad="false" _styleTbody="height:500px; overflow-x:hidden;">
            <field id="siscli" local="true" oculto="true" >
                <valor>'02'</valor>
            </field>

            <field  id="nroturno" autoinc="true" noshow="true"  esclave="true" print="false">
                <label>Turno</label>
                <help>Turno</help>
            </field>

            <field id="linea_id" _noshow="true">
            </field>

	    <field id="id_modelo" deshabilitado="false" tabla="MODCHASIS" noshow="true" required="false">
                </field>

            <field id="controlcalidad" local="true"  obj="controlcalidad/controlcalidad_coche_Horiz_cons.xml" showObjTabla="true"  print="false">
                <paring destino="nrofab" operador="=">nrofab</paring>
                <paring destino="homologacion_id" operador="=">homologacion_id</paring>
                <tipo>varchar</tipo>
            </field>


           <field id="corpath" local="true" noshow="true">
                <if exp="true">
                    <true>'nrofab/corte'</true>
                    <false>''</false>
                </if>
                <tipo>varchar</tipo>
            </field>
            <field id="cortePint" path="corpath" open="true" print="false">
<!--                <expression>select valor_atributo from PRODUCTO_ATRIB_VALORES where producto_id = PEDCOTIZ.id and prdatributo_id = 7</expression>-->
            <expression><![CDATA[SELECT PRODUCTO_ATRIB_VALORES.valor_atributo FROM PRODUCTO_ATRIB_VALORES
                                    WHERE PRODUCTO_ATRIB_VALORES.producto_id = PEDCOTIZ.id
                                      AND PRODUCTO_ATRIB_VALORES.prdatributo_id = 7]]></expression>

                <label>Corte</label>
                <tipo>file</tipo>
                <size>50</size>
            </field>

        	<field id="posicionreal" style="color:blue;">
        	    <expression>coalesce((select nombre from PROD_PATH_REGISTRO join PROD_PRODUCT_PATH ON id_productpath = productpath_id JOIN POSICIONESFAB PF on PF.id_posicionfab = PROD_PRODUCT_PATH.posicionfab_id where nrofab_id = nrofab and hora_salida = '0000-00-00 00:00:00:00' limit 1), 
			    (select concat('salido de ', descripcion) from PROD_PATH_REGISTRO PPR JOIN PROD_PRODUCT_PATH PPP ON PPP.id_productpath = PPR.productpath_id JOIN POSICIONESFAB PF  ON PF.id_posicionfab  = PPP.posicionfab_id
JOIN MOMENTO  ON MOMENTO.idMomento = PF.idMomento WHERE PPR.nrofab_id = PEDCOTIZ.nrocha and hora_salida != '0000-00-00 00:00:00' and PEDCOTIZ.terminacionFinal = '0000-00-00' order by hora_salida desc limit 1))</expression>
        	</field>

            <field id="colorFec"  oculto="true">
                <expression>case when PEDCOTIZ.ingresoLinea != '0000-00-00' then 'color:green;font-size:12px;' else '' end</expression>
                <tipo>varchar</tipo>
            </field>
			<field id="cliente"  tabla="PEDCOTIZ" deshabilitado="true" noshow="true" >
                <expression>case when PEDCOTIZ.ctacod != '' then PEDCOTIZ.ctacod else
                    TURNOSPRODUCCION.ctacod end
                </expression>
            </field>
            <field id="semana">
                <label modpos="nobr" Formstyle="display:none;">Sem</label>
                <expression>WEEKOFYEAR(case when PEDCOTIZ.ingresoLinea != '0000-00-00' then PEDCOTIZ.ingresoLinea else fechaing  end)</expression>
            </field>

	    <field id="fechaing" oculto="true">
                <expression>fechaing</expression>
                <tipo>date</tipo>
                <format>d/m</format>
<!--                 <condicion operador="&lt;">CASE WHEN linea_id = 1 THEN ADDDATE(CURDATE(),INTERVAL 60 DAY) ELSE ADDDATE(CURDATE(),INTERVAL 1000 DAY) END</condicion>
 -->	    </field>

            <field id="homologacion_id" _PDFanchofijo="true" oculto="true" noshow="true" tabla="PEDCOTIZ">
                <expression>homologacion_id</expression>
            </field>

            <field id="fechaing2"  esClave="true" _PDFanchofijo="true">
                <attribute id="style">colorFec</attribute>
                <expression>CONCAT(DATE_FORMAT(fechaing, '%d/%m'), IFNULL(DATE_FORMAT(case when PEDCOTIZ.ingresoLinea != '0000-00-00' then PEDCOTIZ.ingresoLinea else '' end, ' - %d/%m'), ''))</expression>
                <label >Entra</label>
                <help>Fecha de Ingreso a Linea</help>
                <!--<expression having="false">(case when PEDCOTIZ.ingresoLinea != '0000-00-00' then CONCAT(PEDCOTIZ.ingresoLinea, ' - ',fechaing) else fechaing end)</expression>
                <tipo>date</tipo>
                <format>d/m</format> -->
            </field>

            <field id="offset" noshow="true" >
                <expression>
                    select count(*) from TURNOSPRODUCCION as TUR where
                    TUR.fechaing &gt;= TURNOSPRODUCCION.fechaing and
                    TUR.fechaing &lt;= now()
                </expression>
                <tipo>integer</tipo>
            </field>

            <field id="colorFecTer"  oculto="true">

                <expression>case when PEDCOTIZ.terminacion != '0000-00-00' then 'color:green; font-size:11px;font-weight:bold;' else 'color:#B32600; font-weight:bold;' end</expression>

                <tipo>varchar</tipo>

            </field>


            <field id="sale2" esClave="true" noshow="true">
                <attribute id="style">colorFecTer</attribute>
                <label modpos="nobr" >Sale</label>
                <expression having="false">DATE_ADD((case when ingresoLinea != '0000-00-00' then ingresoLinea else fechaing end), INTERVAL 60 DAY)</expression>
                <tipo>date</tipo>
            </field>

            <field id="fechaTerminacion" local="true" >
                <label modpos="nobr">Terminacion</label>
                <attribute id="style">colorFecTer</attribute>
                <expression>(case when PEDCOTIZ.terminacion != '0000-00-00' then PEDCOTIZ.terminacion else (DATE_ADD((case when ingresoLinea != '0000-00-00' then ingresoLinea else fechaing end), INTERVAL 45 DAY)) end)</expression>

                <!--
                                <expression>(case when PEDCOTIZ.terminacion != '0000-00-00' then PEDCOTIZ.terminacion else (select TUR.fechaing from TURNOSPRODUCCION as TUR where
                                        TUR.fechaing &gt; TURNOSPRODUCCION.fechaing order by TUR.fechaing ASC limit [__cant__], 1) end)</expression>
                                -->

                <help>Fecha de Salida de Linea</help>

                <tipo>date</tipo>

                <format>d/m</format>



            </field>




            <!--<field id="ing" _having="false">
                <expression>year(fechaing)</expression>
                <condicion operador="&gt;=">2008</condicion>
            </field> -->
            <field id="Yaent" noshow="true" print="false">
                <label  Formstyle="display:none;" modpos="nobr">Entrega</label>
                <expression having="false" >year(fechaing)</expression>
                <condicion operador="&gt;=">2008</condicion>

            </field>
            <field  id="moddes" tabla="MODCHASIS">
                <!--				<expression>MODCHASIS.moddes</expression> -->
                <expression>case when MODCHASIS.desabv != '' then MODCHASIS.desabv else TURNOSPRODUCCION.modeloChasis end</expression>


                <label >Mod</label>
                <help/>
                <tipo>varchar</tipo>
            </field>

        <field id="muestra" noshow="true" local="true">
            <valor>0</valor>
        </field>

        <field id="controlcausal_id" noshow="true" local="true">
            <valor>7</valor>
        </field>

        <field id="cant_propiedad_cliente" noshow="true">
            <expression>@cant_prop_cli:=(select count(*) from PROD_CONTROL_MOVIM PCM where PCM.nrofab_id = nrofab and PCM.controlcausal_id = 7 and PCM.no_conforme = 1 and PCM.controlado = 0)</expression>
        </field>

        <field id="propiedad_cliente">
            <label>Prop Cli</label>    
            <helper xml="prod_control_movim_qry.xml" type="link" title="control" dir="controlcalidad/" modal="true">
                <parameter source="nrofab" target="nrofab_id"/>
                <parameter source="controlcausal_id" target="controlcausal_id"/>
                <parameter source="muestra" target="muestra"/>
                <parameter source="homologacion_id" target="homologacion_id"/>
            </helper>
                <expression>case when @cant_prop_cli != 0 then CONCAT(@cant_prop_cli, ' Prop.Cli') else '' end</expression>
        </field>

        <field id="cant_trabajos_cnrt" noshow="true">
            <expression>@cant_trabajos_cnrt:=(SELECT COUNT(*) FROM PROD_TRABAJOS_CNRT where nrofab_id = nrofab)</expression>
        </field>

        <field id="tiene_trabajos_cnrt" noshow="true">
            <expression>case when @cant_trabajos_cnrt != 0 and HOMOLOGMOD.dispos = '' then 'background-color: #F5A9A9;' else 
                (case when @cant_trabajos_cnrt != 0 and HOMOLOGMOD.dispos != '' then 'background-color: #00ff00;' else '' end) 
                end</expression>
        </field>            

        <field id="cnrt" print="false" noshow="true">
            <label Formstyle="display:none;" colstyle="color:red;font-weight:bold; text-align:center">CNRT</label>
            <expression>CASE WHEN (PEDCOTIZ.nrocha = '' or PEDCOTIZ.nrocha IS NULL) THEN ''
                ELSE (case when (HOMOLOGMOD.expte = '' or HOMOLOGMOD.dispos = '' or HOMOLOGMOD.plano = '' or PEDCOTIZ.homologacion_id = '' or PEDCOTIZ.homologacion_id IS NULL) then 'NO' ELSE '' end) END</expression>
        </field>

        <field id="trabajos_cnrt" local="true" colstyle="color:red;font-weight:bold; text-align:center;" Formstyle="display:none;">    
            <label>Prot</label>    
            <helper xml="prod_trabajos_cnrt.xml" dir="fabricacion/" type="link" modal="true">
                <parameter source="nrofab" target="nrofab_id"/>
            </helper>
            <expression>case when @cant_trabajos_cnrt != 0 then (CONCAT(IFNULL((select CONCAT(DATE_FORMAT(TC.fecha_inspeccion_cnrt, '%d/%m'), ' ') FROM PROD_TRABAJOS_CNRT TC where TC.nrofab_id = nrofab and TC.fecha_inspeccion_cnrt != '0000-00-00' order by TC.fecha_inspeccion_cnrt ASC limit 1), ''), 'CNRT')) else '' end</expression>
            <attribute id="linkdes">nrofab</attribute>
            <attribute id="style">tiene_trabajos_cnrt</attribute>
            <if exp="'trabajos_cnrt' != '' and nrofab != 0">
                <true>'trabajos_cnrt'</true>
                <false>'cnrt'</false>
            </if>
        </field>
                
	    <field id="control_lcm" style="font-size:11px;color:green;font-weight:bold;">
		<expression>(SELECT date(hora_control) FROM PROD_CONTROL_MOVIM WHERE prodcontrol_id = 504 and nrofab_id = TURNOSPRODUCCION.nrofab LIMIT 1)</expression>
		<label>Ctrl LCM</label>
		<tipo>date</tipo>
		<format>d/m</format>
	    </field>

            <field  id="chasis" tabla="CHASIS" linkint="chasis_cons.xml" linkdes="Ver Datos del Chasis">

                <expression><![CDATA[   CONCAT( SUBSTRING(CHASIS.chasis, -8, 2),'<b>', RIGHT(CHASIS.chasis, 6), '</b>')]]></expression>

                <label>Chasis</label>

                <help>Numero de Serie del chasis</help>

                <paring destino="nrocha">nrofab</paring>



            </field>


        <field id="tieneFicha" noshow="true">
            <expression>case when PEDCOTIZ.estado_ficha = 1 then 'ficha_producto1_qry.xml' else '' end</expression>
        </field>

	    <field id="ficha_id" noshow="true">
		<expression>PEDCOTIZ.id</expression>
	    </field>

            <field id="nrofab" >
                <attribute id="linkint">tieneFicha</attribute>

        	<expression>nrofab</expression>
                <label modpos="nobr" style="text-align:center;color:#444;font-size:14px;">Fv</label>
                <help>Numero de Fabricacion</help>
                <paring destino="nrocha">nrofab</paring>
                <detalle>nrocha</detalle>
                <helper type="link" xml="ficha_producto1_qry.xml" dir="/producto" modal="true" title="Ficha Producto">
			<parameter source="ficha_id" target="producto_id"/>
			<parameter source="nrofab" target="nrofab"/>
	        </helper>

            </field>


            <!--
            <field id="nrofab" linkint="fichaventas.xml" linkdes="Ver Ficha de Ventas">
                <label modpos="nobr" style="color:#444;font-weight:bold;">Nro.</label>
                <help>Numero de Fabricacion</help>
                <ayuda_ex id="CHASIS">
                    <field id="nrocha"/>
                    <field id="chades"/>
                </ayuda_ex>
                <paring destino="nrocha">nrofab</paring>

            </field>
-->			

            <field id="fic" local="true" noshow="true" >

                <valor>'fichaventas_abm.xml'</valor>

                <tip>varchar</tip>

            </field>

            <field id="maxfec" l_ocal="true" noshow="true">

                <label>1</label>

                <expression>case when PEDCOTIZ.revfec = DATE(NOW()) then 'color:red;font-weight:bold;' end</expression>

                <tipo>varchar</tipo>

            </field>
            
            <field id="max_fec" noshow="true">
              <expression>@maxrev:=(select DATE(max(timestamp_atributo)) from PRODUCTO_ATRIB_VALORES where producto_id = id)</expression>
            </field>

<!--             <field id="max_fec" noshow="true">
              <expression>  GREATEST( PEDCOTIZ.revfec ,
                    (select max(ACC.fecha) from PEDCOTIZ AS PED1 left join ACCESORIOS_COCHE as ACC on ACC.ficha_id = PED1.id where PED1.id = PEDCOTIZ.id ))</expression>                
            </field> -->
			<field id="nroF" noshow="true">
                <expression>CONCAT(nrofab,',')</expression>
            </field>

            <field id="ayer" noshow="true">
                <expression>DATE_SUB(curdate(), INTERVAL 1 DAY)</expression>
            </field>

            <field id="today" noshow="true">
                <expression>DATE(now())</expression>
            </field>


            <field id="log" local="true" linkint="turnos_log_msg_cons.xml"  linkdir="produccion/" linkdes="Historial" print="false" >
                <label getStyle="maxfec"  Formstyle="display:none;">Ult.Modif</label>
                <attribute id="tooltip">obser2</attribute> 
                <if exp="'max_fec' == 'today'">
            	    <true>'HOY'</true>
            	    <false>('max_fec'=='ayer')?'Ayer': (('max_fec' != '')?date('d/m', strtotime('max_fec')):'')</false>
                </if>                
                <!--
                <expression>case when @maxrev = DATE(NOW()) then 'HOY' 
                    when @maxrev = DATE_SUB(curdate(), INTERVAL 1 DAY) then 'Ayer' 
                    else date_format(@maxrev, '%d/%m') end
                </expression> -->
                <paring destino="num"    >nroF</paring>
                
            </field>
            -->

            <!--

            <field id="log" local="true" linkint="turnos_log_msg_cons.xml" linkdes="Historial" print="false">
                <label getStyle="maxfec"  Formstyle="display:none;">Ult.Modif</label>
                <expression>case when PEDCOTIZ.revfec = DATE(NOW()) then 'HOY'
                          when PEDCOTIZ.revfec = DATE(NOW()) - 1 then 'Ayer'
                  else date_format(PEDCOTIZ.revfec, '%d/%m') end</expression>

                <tipo>date</tipo>
                <paring destino="xmlprog" operador="="   >fic</paring>
                <paring destino="obs"     operador="like">nrofab</paring>

            </field>
            -->


            <field id="momentos" local="true"  print="false" noshow="true" >

                <label Formstyle="display:none;">Posición</label>
                <tabla_ex id="MOMENTO" xml="momento_posiciones.xml" >
                </tabla_ex>
                <if exp="true">
                    <true>offset</true>
                    <false>0</false>
                </if>
                <tipo>varchar</tipo>
            </field>

            <field id="Entrega" noshow="true" print="false">
                <label>Entrega</label>
                <expression having="false">(select entrega  from ENTREGASCOCHES where ENTREGASCOCHES.nrofab = TURNOSPRODUCCION.nrofab  and ENTREGASCOCHES.entrega IS NOT NULL  limit 1)</expression>
                <tipo>date</tipo>
            </field>

	    <field id="hayentrega">
                <expression having="false">(select count(*)  from ENTREGASCOCHES where ENTREGASCOCHES.nrofab = TURNOSPRODUCCION.nrofab  and ENTREGASCOCHES.entrega IS NOT NULL  limit 1)</expression>
		<condicion operador="=">0</condicion>
	    </field>

            <field id="ubicacion" noshow="true">
                <label >Ubicacion</label>
                <help>Ubicacion</help>
            </field>

            <field id="colorEnt" noshow="true" local="true">
                <if exp="'Entrega' != ''">
                    <true>'color:green;font-weight:bold;'</true>
                    <false>('ubicacion' != '')?'color:blue;font-weight:bold;':''</false>
                </if>
            </field>

            <field id="CANTposic" noshow="true">

                <expression>select count(*) from POSICIONESFAB</expression>

            </field>



            <field id="posent" local="true" print="false" ignoreOption="true" getStyle="colorEnt">

                <label modpos="nobr" Formstyle="display:none;">Posic/Entr.</label>
                <!-- <atributte id="style">colorEnt</atributte> -->
                <tabla_ex id="MOMENTO" xml="momento_posiciones.xml" />

                <if exp="'Entrega' != '' and nrofab != 0">
                    <true>date(  'd/m/Y', strtotime ( 'Entrega'))</true>
                    <false>('ubicacion' != '')?'ubicacion': ((momentos &lt;= CANTposic)?'momentos':'')</false>
                </if>
            </field>

            <field id="terminacionFinal" tabla="PEDCOTIZ" noshow="true">
                <label>Aviso Entrega</label>
                <tipo>date</tipo>
            </field>

            <field id="Entregado" _noshow="true" print="false" deshabilitado="false">
                <label colstyle="display:none;">Entregado</label>
		<!--
                <expression>select count(*) from ENTREGASCOCHES where ENTREGASCOCHES.nrofab = TURNOSPRODUCCION.nrofab  and ENTREGASCOCHES.entrega IS NOT NULL  limit 1</expression>
		-->
                <expression having="false">(case when TURNOSPRODUCCION.movnro > 0  then 1
					       when (select count(*) from ENTREGASCOCHES where ENTREGASCOCHES.nrofab = TURNOSPRODUCCION.nrofab  and ENTREGASCOCHES.entrega IS NOT NULL  limit 1) + (select count(*) from CCTMOVIM where CCTMOVIM.siscod = '02' and CCTMOVIM.nrofab = TURNOSPRODUCCION.nrofab and CCTMOVIM.nrofab != 0 limit 1) > 1 then 1 
            				       else 0 end)</expression>

                <tipo>integer</tipo>
                <options>
                    <option valor="0">No</option>
                    <option valor="1">SI</option>
                </options>
                <condicion operador="=">0</condicion>
            </field>

            <field  id="ctaconces" tabla="CHASIS" noshow="true">
                <expression>case when CONCESIONARIO.ctacod >= 0 then CONCESIONARIO.ctacod else 0 end</expression>
                <tipo>integer</tipo>
            </field>

            <field  id="conces" tabla="CHASIS" linkint="cctconta_consulta.xml" linkdes="Ver medios de Contacto">
                <!-- <expression>case when CHASIS.conces != '' then CHASIS.conces else TURNOSPRODUCCION.idconces end</expression> -->
                <expression>CONCESIONARIO.nombre</expression>

                <tabla_ex vacio="true" xml="concesionario.xml"/>
                <label>Conc</label>
                <help>Concesionario</help>

                <paring destino="ctacod">ctaconces</paring>
                <paring destino="siscod">siscli</paring>
                <tipo>button</tipo>
            </field>
            <field id="ctacod" noshow="true">
                <expression>case when PEDCOTIZ.ctacod != '' then PEDCOTIZ.ctacod else TURNOSPRODUCCION.ctacod end</expression>
            </field>

        <field id="muestra_ft" noshow="true" local="true">
            <valor>1</valor>
        </field>

        <field id="obs" linkint="accesorios_coche_qry.xml" linkdir="/produccion/man/">
            <label>Adic.</label>
            <expression>case when (select count(*) from ACCESORIOS_COCHE AS ACC where ACC.nrofab = TURNOSPRODUCCION.nrofab and TURNOSPRODUCCION.nrofab != 0) = 0 then '' else 'Adic' end</expression>
            <paring destino="muestra_ft">muestra_ft</paring>
            <paring destino="nrofab">nrofab</paring>
            <attribute id="linkdes">nrofab</attribute>
        </field>

            <field  id="ctafan" tabla="PEDCOTIZ" linkint="cctconta_consulta.xml" linkdes="Ver medios de Contacto">
                <expression>LEFT(ctafan, 17)</expression>
                <label >Cliente</label>
                <help>Codigo de Cuenta</help>
                <paring destino="ctacod">ctacod</paring>
                <paring destino="siscod">siscli</paring>
            </field>
			
			<field deshabilitado="true" id="otros" local="true" linkint="fichas_x_cliente.xml" linkdes="Total de Coches" print="false">
                <!-- xxx      <expression>select count(*) from PEDCOTIZ as PED where PED.ctacod = PEDCOTIZ.ctacod</expression> -->
                <expression>(case when !isnull(PEDCOTIZ.ctacod) then
                    (select count(*) from VUNIDADES as PED where PED.ctacod = PEDCOTIZ.ctacod)
                else (select count(*) from VUNIDADES as PED where PED.ctacod = TURNOSPRODUCCION.ctacod) end) </expression>

                <label getStyle="ot1" Formstyle="display:none;">Ot.</label>
                <help>Codigo de Cuenta</help>
                <paring destino="ctacod">cliente</paring>
                <tipo>varchar</tipo>
            </field>
	
			<field id="fechaultcoche" noshow="true">
				<expression>@fultcoche:= (SELECT P.pedfec FROM PEDCOTIZ P where P.ctacod = PEDCOTIZ.ctacod group by P.pedfec order by P.pedfec DESC limit 1)</expression>
			</field>

			<field id="noesprimerizo" noshow="true"><!-- Si tiene Fichas de venta con fecha menor a la fecha del último coche - 30 días, no es primerizo -->
				<expression>CASE WHEN (SELECT 0 FROM PEDCOTIZ P where P.pedfec &lt; DATE_SUB(@fultcoche, INTERVAL 30 DAY) and P.ctacod = PEDCOTIZ.ctacod group by P.ctacod) = 0 THEN 0 ELSE 1 END</expression>
			</field>

			<field id="esconcesionario" noshow="true">
				<expression>CASE WHEN (SELECT 1 FROM CONCESIONARIO WHERE ctacod = PEDCOTIZ.ctacod limit 1) = 1 THEN 1 ELSE 0 END</expression>
				<label>Es Conc</label>
			</field>

			<field id="tienepedcotiz" noshow="true">
				<expression>CASE WHEN (SELECT 1 FROM PEDCOTIZ P where P.ctacod = PEDCOTIZ.ctacod group by P.ctacod) = 1 THEN 1 ELSE 0 END</expression>
			</field>
				  
			<field id="ot1" local="true" noshow="true">
					<expression>
						CASE WHEN (CASE WHEN (SELECT 0 FROM PEDCOTIZ P where P.pedfec &lt; DATE_SUB(@fultcoche, INTERVAL 30 DAY) and P.ctacod = PEDCOTIZ.ctacod group by P.ctacod) = 0 THEN 0 ELSE 1 END) = 1 and
									(CASE WHEN (SELECT 1 FROM CONCESIONARIO WHERE ctacod = PEDCOTIZ.ctacod limit 1) = 1 THEN 1 ELSE 0 END) = 0 and
									(CASE WHEN (SELECT 1 FROM PEDCOTIZ P where P.ctacod = PEDCOTIZ.ctacod group by P.ctacod) = 1 THEN 1 ELSE 0 END) = 1
							THEN 'color:red;font-weight:bold;font-size:16px;' ELSE '' END
					</expression>
			</field>

        <field id="modelo_lcm_id" tabla="HOMOLOGMOD" noshow="true" />
        <field id="id_homologacion" tabla="HOMOLOGMOD" noshow="true" />

      <field id="carpeta_planos" local="true" linkint="prod_carpeta_planos_qry.xml" linkdir="fabricacion" _linkdes="Carpeta Planos" linkWidth="95%" linkHeight="95%">
          <label modpos="nobr">PL STD</label>
          <paring destino="homologacion">homologacion_id</paring>
          <paring destino="nrocar">nrocar</paring>
          <paring destino="modelo_lcm">modelo_lcm_id</paring>
          <paring destino="nrofab">nrofab</paring>
          <paring destino="producto_id" >ficha_id</paring>
          <expression>select (case when HOMOLOGMOD.nrocar != '' then CONCAT(count(*), ' std') else '' end) FROM PRD_CARPETA_PLANOS where PRD_CARPETA_PLANOS.homologacion_id = HOMOLOGMOD.id_homologacion or PRD_CARPETA_PLANOS.nrocar_id = HOMOLOGMOD.nrocar or PRD_CARPETA_PLANOS.modelo_lcm_id = HOMOLOGMOD.modelo_lcm_id</expression>
          <attribute id="linkdes">nrofab</attribute>
      </field>

      <field id="planos_especiales" local="true" linkint="prd_planos_qry.xml" linkdir="produccion" _linkdes="Carpeta Planos" linkWidth="95%" linkHeight="95%">
        <label modpos="nobr">PL ESP</label>
        <paring destino="nrofab">nrofab</paring>
        <expression>select (case when HOMOLOGMOD.nrocar != '' then CONCAT(count(*), ' esp') else '' end) FROM PRD_PLANOS where PEDCOTIZ.nrocha = PRD_PLANOS.nrofab and PRD_PLANOS.carpetaplanos_id = 0</expression>
        <attribute id="linkdes">nrofab</attribute>
      </field>

      <field id="fotos_produccion" showValor="true" linkint="homol_fotos_prod_producto_qry.xml" linkdir="fabricacion" _linkdes="Carpeta Planos" linkWidth="95%" linkHeight="95%">
        <label>Fotos Produ</label>
        <paring destino="homologacion_id" operador="=">id_homologacion</paring>
        <paring destino="producto_id" operador="=">ficha_id</paring>
        <expression><![CDATA[SELECT CONCAT(IFNULL(count(*), 0), ' Fotos') FROM HOMOLOG_FOTOS_PROD HAV
                                JOIN PRODUCTO_ATRIB_VALORES PAV ON PAV.prdatributo_id = HAV.prdatributo_id 
                                                               AND PAV.valor_atributo = 1
                                WHERE HAV.homologacion_id = HOMOLOGMOD.id_homologacion
                                  AND PAV.producto_id = PEDCOTIZ.id ]]></expression>
        <valor>'Fotos Produc'</valor>
        <tipo>varchar</tipo>
        <attribute id="linkdes">nrofab</attribute>
      </field>

            <field id="nrocar" tabla="HOMOLOGMOD">
                <expression>case when HOMOLOGMOD.nrocar != '' then HOMOLOGMOD.nrocar else TURNOSPRODUCCION.nrocar end</expression>
                
                <label >Mod.</label>
                <help/>
                <tabla_ex id="CARROCERIA">
                    <field id="nrocar">
                    </field>
                    <field id="desabv">
                    </field>
                    
                    <field id="siscod" oculto="true">
                        <condicion operador="=">03</condicion>
                    </field>
                </tabla_ex>
                <tipo>varchar</tipo>
            </field>

            <field id="asientos" deshabilitado="true" noZero="true" style="text-align:center;">
                <label>Asi</label>
                <tipo>integer</tipo>
                <expression>case when PEDCOTIZ.homologacion_id != '' then 
                (case when CARROCERIA.doble_piso = 1 then (CONCAT(HOMOLOGMOD.asientos, '+', HOMOLOGMOD.asientos_plantabaja)) else (HOMOLOGMOD.asientos + HOMOLOGMOD.acompañante) end)
                else TURNOSPRODUCCION.cantasi end</expression>
            </field>

            <field id="bagno" deshabilitado="true" noZero="true">
                <label>B</label>
                <expression>atributoUnidad(id, 'bagno')</expression>
                <options>
                    <option valor="0">''</option>
                    <option valor="1">BB</option>
                </options>
                <tipo>varchar</tipo>
            </field>

            <field id="cucheta">
                <expression>case when PEDCOTIZ.homologacion_id != '' then (atributoUnidad(id, 'cucheta')) else TURNOSPRODUCCION.cucheta end</expression>
                <label modpos="nobr">Cuch</label>
                <options>
                    <option valor="0"> </option>
                    <option valor="1">Cuch</option>
                </options>
            </field>

            <field id="aire">
                <expression>case when PEDCOTIZ.homologacion_id != '' then (atributoUnidad(id, 'marair')) else TURNOSPRODUCCION.marair end</expression>
                <label>A/A</label>
                <tabla_ex id="MARCAAIR" vacio="true" indexvacio="0" valorvacio="NO">
                    <field id="marair">
                    </field>
                    <field id="desair">
                        <expression>LEFT(desair, 4)</expression>
                    </field>
                    <field id="siscod" oculto="true">
                        <condicion operador="=">03</condicion>
                    </field>
                </tabla_ex>
                <tipo>varchar</tipo>
            </field>

            <field id="marasi">
                <expression>case when PEDCOTIZ.homologacion_id != '' then (atributoUnidad(id, 'marasi')) else TURNOSPRODUCCION.marasi end</expression>
                <attribute id="style">faltante</attribute>
                <label >Marca</label>
                <help/>
                <tabla_ex id="MARCAASI" _xml="marcaasi.xml">
                    <field id="marasi">
                    </field>
                    <field id="asides">
                        <expression>LEFT(asides, 4)</expression>
                    </field>
                    <field id="siscod" oculto="true">
                        <condicion operador="=">03</condicion>
                    </field>
                </tabla_ex>
            </field>

            <field id="usuario" local="true" oculto="true">
            <label modpos="nobr">Usuario</label>
            <valor eval="true">$_SESSION['usuario']</valor>
            </field>

            <field id="usuario_critico" noshow="true">
                <expression>case when '[__usuario__]' = 'javier' or '[__usuario__]' = 'hector' or '[__usuario__]' = 'adrian' or '[__usuario__]' = 'adm1' or '[__usuario__]' = 'martinm' then 'false' else 'true' end</expression>
            </field>

            <field id="controlcalidadsuper" local="true">
            <helper xml="controles_linea_supervisor.xml" dir="controlcalidad/" type="link">
                <parameter source="nrofab" target="nrofab_id"/>
                <parameter source="homologacion_id" target="homologacion_id"/>
            </helper>
            <expression>'Ingreso y Controles Crítico'</expression>
            <attribute id="oculto">usuario_critico</attribute>
            </field>

            <field id="hi"  clasefila="true" noshow="true">
                <expression>'grisado2'</expression>
                <tipo>varchar</tipo>
            </field>
            <field id="hi2"  clasefila="true" noshow="true">
                <expression>CASE WHEN (SELECT 1 FROM CONCESIONARIO WHERE ctacod = PEDCOTIZ.ctacod limit 1) = 1 THEN 'resaltadoVioleta' ELSE '' END</expression>
                <tipo>varchar</tipo>
            </field>
            <field id="enlinea" noshow="true" required="false">
                <expression having="false">ifnull((select 1 from PROD_PATH_REGISTRO join PROD_PRODUCT_PATH ON id_productpath = productpath_id JOIN POSICIONESFAB PF on PF.id_posicionfab = PROD_PRODUCT_PATH.posicionfab_id where nrofab_id = nrofab and hora_salida = '0000-00-00 00:00:00:00' limit 1), 0)</expression>
            </field>
            <field id="reasignado" noshow="true"  required="false">
                <expression having="false">case when @max_fec &gt; terminacion or ultima_modificacion &gt; terminacion then 1 else 0 end</expression>

            </field>

            <field id="concliente" noshow="true"  required="false">
                <expression>case when (CONCESIONARIO.ctacod = TURNOSPRODUCCION.ctacod or CONCESIONARIO.ctacod = PEDCOTIZ.ctacod) then 2 when (PEDCOTIZ.ctacod != 0 OR TURNOSPRODUCCION.ctacod != 0) then 1 ELSE 2 end</expression>

            </field>

        <field id="conAviso" noshow="true" deshabilitado="false" required="false">
              <expression having="false">(case when terminacionFinal != '0000-00-00' then 1 else -1 end)</expression>
        </field>
            
            <order>
                <field id="Sale"/>
            </order>
        </table>
        <join tipo="left">
            <table id="PEDCOTIZ">
                <field id="nrocha">
                    <condicion operador="=">TURNOSPRODUCCION.nrofab and PEDCOTIZ.nrocha != 0</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="CCTCUENT">
                <field id="ctacod">
                    <condicion operador="=">(case when PEDCOTIZ.ctacod != 0 then PEDCOTIZ.ctacod else TURNOSPRODUCCION.ctacod end)</condicion>
                </field>
                <field id="siscod">
                    <condicion operador="=">'02'</condicion>
                </field>


            </table>
        </join>

        <join tipo="left">
            <table id="CHASIS">
                <field id="nrocha">
                    <condicion operador="=">TURNOSPRODUCCION.nrofab and CHASIS.nrocha != 0</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="HOMOLOGMOD">
                <field id="id_homologacion">
                    <condicion operador="=">PEDCOTIZ.homologacion_id</condicion>
                </field>

            </table>
        </join>
    <join tipo="left">
        <table id="CARROCERIA">
          <field id="nrocar">
                 <condicion operador="=">HOMOLOGMOD.nrocar</condicion>
          </field>
        </table>
    </join>
        <join tipo="left">
            <table id="MODCHASIS">
                <field id="modcha">
                    <condicion operador="=">CHASIS.modcod</condicion>
                </field>
                <field id="marcod">
                    <condicion operador="=">CHASIS.marcod</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="CONCESIONARIO">
                <field id="idconces">
                    <condicion operador="=">(case when CHASIS.conces != '' then CHASIS.conces else TURNOSPRODUCCION.idconces end)</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="EURO_TIPO">
                <field id="id_euro">
                    <condicion operador="=">MODCHASIS.euro_id</condicion>
                </field>
            </table>
        </join>
    </form>
</histrix>

