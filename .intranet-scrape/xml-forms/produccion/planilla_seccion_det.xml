<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" autoupdate="240" sqlhardcoded="true" style="height:100%;" limit="[__limits__]" path="/fotos/coches">
	<title>ENTREGAS POR SECCION</title>
	<obs/>
	<form >
		<table id="TURNOSPRODUCCION" label="ENTREGAS POR SECCION"  showCantidad="false" >
		    <fieldGroup thstyle="font-size:21px;">
			<field id="puestos" local="true" noshow="true"></field>
			<field id="mes"  local="true" noshow="true" />
			<field id="year" local="true" noshow="true" />
			<field id="coches" local="true" noshow="true"/>
			<field id="limits" local="true" noshow="true">
				<setvar>limit</setvar>
			</field>

			<field id="linea_id" noshow="true"></field>
			<field id="idMomento" local="true" noshow="true"></field>
			
			
			<field id="_ORDEN" local="true" noshow="true">
				<label colstyle="font-weight:bold;font-size:21px;color:red;">Orden</label>
				<tipo>integer</tipo>
			</field>

			<field id="ord" local="true" noZero="true">
				<label colstyle="font-weight:bold;font-size:21px;color:red;">Ord.</label>
				<if exp="_ORDEN > (coches - 15)">
					<true>''</true>
					<false>_ORDEN</false>
				</if>

				<tipo>integer</tipo>
			</field>

			<field id="colores" local="true" clasefila="true" noshow="true" deshabilitado="true">
				<label>Col</label>
				<if exp="_ORDEN > (coches - 15)">
				  <true>'resaltado'</true>
				 <false>(_ORDEN % 2 != 0)?'grisado2':''</false>
				</if>
				
			</field>
			
			<field id="numorden" local="true" noshow="true" noZero="false">
			<label>order</label>
			    <if exp="true">
				<true>_ORDEN - 1 </true>
				<false>0</false>
			    </if>
			</field>
			

	                <field id="fechaing2" _PDFanchofijo="true" oculto="true">
		          <expression>fechaing</expression>
	                </field>                  

			<field id="primercoche" noshow="true">
			    <expression having="false">(select  T.fechaing  from TURNOSPRODUCCION as T
				    left join PEDCOTIZ as P on P.nrocha = T.nrofab
				    where (P.terminacion = '0000-00-00' or ( month(P.terminacion) = [__mes__] and year(P.terminacion) = [__year__] )) and
				    T.linea_id = [__linea_id__] and
				    year(T.fechaing ) >= [__year__] - 1
				    order by (T.fechaing ) limit 1)</expression>
				    <condicion operador="&lt;=">fechaing</condicion>
			</field>

                                                            
			<field id="fechaSalida" esClave="true"	>
				<label modpos="nobr" colstyle="font-weight:bold;font-size:28px;">Sale</label>
		            <expression sql="true">select fechaing  from TURNOSPRODUCCION as T left join PEDCOTIZ on PEDCOTIZ.nrocha = T.nrofab where 
			        T.linea_id = [__linea_id__] and 
			        fechaing >= '[__year__]-[__mes__]-01' order by fechaing  limit [__numorden__] , 1</expression>
			        <tipo>date</tipo>
			        <format>d/m</format>
			</field> 
            		<!--<field id="hora_movimiento">
            		    <label colstyle="font-weight:bold;font-size:28px;color:#888;">Hora</label>
		            <expression sql="true">select CONCAT( TIME_FORMAT(hora_movimiento, '%H'), 'Hs')  from TURNOSPRODUCCION as T left join PEDCOTIZ on PEDCOTIZ.nrocha = T.nrofab where 
			        T.linea_id = [__linea_id__] and
			        fechaing >= '[__year__]-[__mes__]-01' 
			        order by fechaing  limit [__numorden__] , 1</expression>
            		    <tipo>varchar</tipo>
            		</field>-->

            <field id="ingreso_sector">
                <label colstyle="font-weight:bold;font-size:18px;color:#888;">Ing.</label>
                <expression>select concat(date_format(fecha_control, '%d/%m') ,' ' ,TIME_FORMAT(hora_control,'%H:%i'))from PROD_CONTROLES join PROD_CONTROL_MOVIM on id_prodcontrol = prodcontrol_id where nrofab_id = nrofab and orden_control = 1 and seccion_id = idMomento</expression>
            </field>


            <field id="ficha_id" noshow="true">
                <expression>PEDCOTIZ.id</expression>
            </field>

            <field id="controles_criticos" local="true" _noZero="true">
                <label colstyle="color:red;width:2em;font-weight:bold;font-size:18px;text-align:center;">Criti.</label>
                <expression>CASE WHEN (SELECT count(hora_control) FROM PROD_CONTROLES join PROD_CONTROL_MOVIM on id_prodcontrol = prodcontrol_id where nrofab_id = nrofab and seccion_id = idMomento and critico = 1 and habilitado = 0) != (SELECT count(critico) FROM PROD_CONTROLES where seccion_id = idMomento and critico = 1 and habilitado = 0) and (select count(hora_control)from PROD_CONTROLES join PROD_CONTROL_MOVIM on id_prodcontrol = prodcontrol_id where nrofab_id = nrofab and orden_control = 1 and seccion_id = idMomento and habilitado = 0) = 1 THEN 'Críticos Pendient.' else '' end</expression>
                <!--<attribute id="style">controles_criticos</attribute>-->
            </field>

			<field id="liberacion">
			    <label colstyle="font-weight:bold;font-size:18px;color:#888;">Libe.</label>
			    <expression>select concat(date_format(fecha_control, '%d/%m') ,' ' ,TIME_FORMAT(hora_control,'%H:%i'))from PROD_CONTROLES join PROD_CONTROL_MOVIM on id_prodcontrol = prodcontrol_id where nrofab_id = nrofab and orden_control = 999 and seccion_id = idMomento</expression>
			</field>


			<field id="controles" local="true" noZero="true">
			    <label colstyle="width:2em;font-weight:bold;font-size:18px;text-align:center;">Pend.</label>
			    <helper xml="prod_control_movim_qry.xml" type="link" title="Controles de Calidad" dir="controlcalidad/" modal="true">
				<parameter source="nrofab" target="nrofab_id"/>
				<parameter source="idMomento" target="seccion_id"/>
				<parameter source="orden_noconforme" target="orden_noconforme" />
			    </helper>
			    <expression>SELECT sum(CASE WHEN no_conforme = 1 and controlado = 0 THEN 1 else 0 END) FROM PROD_CONTROLES join PROD_CONTROL_MOVIM on id_prodcontrol = prodcontrol_id where nrofab_id = nrofab and seccion_id = idMomento</expression>
			</field>

			<field id="orden_noconforme" local="true" noshow="true">
			    <valor>1</valor>
			</field>

            <field id="tieneFicha" noshow="true">
                <expression>case when PEDCOTIZ.estado_ficha = 1
                and PEDCOTIZ.pedfec != '0000-00-00'
                and PEDCOTIZ.nrocha != 0
                and PEDCOTIZ.ctacod != 0 
                and CHASIS.marcod != 0 
                and CHASIS.modcod != 0 
                and PEDCOTIZ.nrocar != 0 
                and PEDCOTIZ.homologacion_id != '' 
                and (select valor_atributo from PRODUCTO_ATRIB_VALORES where producto_id = id and prdatributo_id = 35) != 0 
                and PEDCOTIZ.tipserv != 0 
                and (select valor_atributo from PRODUCTO_ATRIB_VALORES where producto_id = id and prdatributo_id = 13) != 0 
                and (select valor_atributo from PRODUCTO_ATRIB_VALORES where producto_id = id and prdatributo_id = 14) != 0 
              then 'ficha_producto1_qry.xml' else '' end
              </expression>
            </field>

	    <field id="title" noshow="true">
		<expression>concat(nrofab, ' ',(select ctafan from CCTCUENT where siscod = '02' and CCTCUENT.ctacod = (case when PEDCOTIZ.ctacod != '' then PEDCOTIZ.ctacod else TURNOSPRODUCCION.ctacod end )),' - ',
CARROCERIA.modcar,' ',MARCHASIS.mardes, ' ',MODCHASIS.moddes, ' ',HOMOLOGMOD.asientos + acompañante,' Asientos ',(CASE WHEN banbar = 1 THEN 'BB' ELSE ' ' END) ,'- Largo: ', largo, trim(referencia) )</expression>
	    </field>

        <field deshabilitado="true" id="chasis" tabla="CHASIS" linkint="chasis_cons.xml" linkdes="Ver Datos del Chasis">
            <expression><![CDATA[CONCAT( SUBSTRING(CHASIS.chasis, -8, 2),'<b>', RIGHT(CHASIS.chasis, 6), '</b>')]]></expression>
            <label colstyle="font-weight:bold;font-size:16px;">Chasis</label>
            <tipo>editor</tipo>
            <help>Numero de Serie del chasis</help>
            <paring destino="nrocha">nrofab</paring>
            <attribute id="tooltip">chasis_entrada</attribute>        
        </field>

            <field id="nrofab" tabla="TURNOSPRODUCCION">
                <attribute id="linkint">tieneFicha</attribute>
                <attribute id="linkdes">title</attribute>
        		<helper xml="ficha_producto1_qry" dir="/producto" type="link" modal="true" width="98%" title="Ficha Producto">
        			<parameter source="nrofab" target="nrofab" />
        			<parameter source="producto_id" target="producto_id" />
        			<parameter source="ficha_id" target="id" />
        			<parameter source="ficha_id" target="producto_id" />
        			<parameter source="nrofab" target="nrofab" />
        		</helper>
				<label colstyle="font-weight:bold;font-size:22px;">Nro.</label>
                <help>Numero de Fabricacion</help>
            </field>

			<field id="siscli" local="true" oculto="true" >
				<valor>'02'</valor>
			</field>
			
                <field deshabilitado="true" id="ctacod" tabla="PEDCOTIZ" >
                <expression>case when PEDCOTIZ.ctacod != '' then PEDCOTIZ.ctacod else TURNOSPRODUCCION.ctacod end</expression>
                <label colstyle="font-weight:bold;font-size:26px;color:#888;" >Cliente</label>
                <help>Codigo de Cuenta</help>
                <tabla_ex id="CCTCUENT">
                    <field id="ctacod"/>
                    <field id="ctafan">
                        <expression>LEFT(ctafan, 17)</expression>
                    </field>
                    <field id="siscod" oculto="true">
                        <condicion operador="=">'02'</condicion>
                    </field>
                </tabla_ex>
                <paring destino="ctacod">ctacod</paring>
                <paring destino="siscod">siscli</paring>
            </field>

            <field id="corpath" local="true" noshow="true">
                <if exp="true">
                    <true>'nrofab/corte'</true>
                    <false>''</false>
                </if>
                <tipo>varchar</tipo>
            </field>
        
        <field id="cortePint"  path="corpath" open="true" print="false" colstyle="width:auto;font-size:28px;" height="50">
           <expression>atributoUnidad(id, 'cortepint')</expression>
           <label>Corte</label>
           <tipo>file</tipo>
           <size>93</size>
        </field>

        <field id="max_fec" noshow="true">
          <expression>@maxrev:=(select DATE(max(timestamp_atributo)) from PRODUCTO_ATRIB_VALORES where producto_id = id)</expression>
        </field>

<!--             <field id="max_fec" noshow="true">
              <expression>  GREATEST( PEDCOTIZ.revfec ,
                    (select max(ACC.fecha) from PEDCOTIZ AS PED1 left join ACCESORIOS_COCHE as ACC on ACC.ficha_id = PED1.id where PED1.id = PEDCOTIZ.id ))</expression>                
            </field> -->

            <field id="maxfec" local="true" noshow="true" print="false">
                <label>1</label>
                <expression>case when @maxrev = DATE(NOW()) then 'font-size:34px;color:red;;font-weight:bold;text-decoration:blink;animation: blink 1s steps(5, start) infinite; -webkit-animation: blink 1s steps(5, start) infinite;' 
                    when @maxrev = DATE_SUB(curdate(), INTERVAL 1 DAY)  then 'font-size:34px;color:blue;font-weight:bold;text-decoration:blink;width:auto;'
                    
                	    else 'font-size:23px;color:green;font-weight:bold;width:auto;'
                                    end</expression>
                <tipo>varchar</tipo>
            </field>
            
              
            <field id="log" local="true" linkint="turnos_log_terminal_cons.xml" linkdir="menu" linkdes="Historial" print="false" >
                <label getStyle="maxfec"  >Ult.Modif</label>
                <attribute id="tooltip">obser2</attribute> 
                <expression>case when @maxrev = DATE(NOW()) then 'HOY' 
                          when @maxrev = DATE_SUB(curdate(), INTERVAL 1 DAY) then 'Ayer' 
                  else date_format(@maxrev, '%d/%m') end</expression>
        
                <paring destino="obs"     operador="like">nrofab</paring>
                <paring destino="num"    >nrofab</paring>
            </field>
            <field deshabilitado="true" id="moddes" tabla="MODCHASIS">
                <expression>case when MODCHASIS.moddes != '' then MODCHASIS.desabv else TURNOSPRODUCCION.modeloChasis end</expression>

                <label colstyle="font-weight:bold;font-size:28px;">Modelo</label>
                <help/>
                <tipo>varchar</tipo>
            </field>
			<field deshabilitado="true" id="ctaconces" tabla="CHASIS" noshow="true">
				<expression>case when CONCESIONARIO.ctacod >= 0 then CONCESIONARIO.ctacod else 0 end</expression>
				<tipo>integer</tipo>

			</field>

			<field esClave="true" id="fechaing" PDFanchofijo="true" noshow="true" tipoOrden="DESC"> 
				<label >Entra</label>
				<help>Fecha de Ingreso a Linea</help>


			</field>
			
            <field deshabilitado="true" id="nrocar" tabla="PEDCOTIZ">
                <expression>case when PEDCOTIZ.nrocar != '' then PEDCOTIZ.nrocar else TURNOSPRODUCCION.nrocar end</expression>
                <label colstyle="font-weight:bold;font-size:28px;color:#888;">Mod.</label>
                <help/>
                <tabla_ex id="CARROCERIA">
                    <field id="nrocar">
                    </field>
                    <field id="desabv">
                    </field>

                    <field id="siscod" oculto="true">
                        <condicion operador="=">03</condicion>
                    </field>
                </tabla_ex>
                <tipo>varchar</tipo>
            </field>


            <field deshabilitado="true" id="asientos" noZero="true">
                <label colstyle="font-weight:bold;font-size:28px;">Asi</label>
                <tipo>integer</tipo>
                <expression>HOMOLOGMOD.asientos+1</expression>
            </field>
            
            <field id="bagno" deshabilitado="true" noZero="true">
                <label colstyle="font-weight:bold;font-size:28px;">B</label>
                <expression>atributoUnidad(id, 'bagno')</expression>
                <options>
                    <option valor="0"></option>
                    <option valor="1">  </option>
                    <option valor="2">BB</option>
                    <option valor="3">S/D</option>
                </options>
                <tipo>varchar</tipo>
            </field>
 
	       <field id="miniba" deshabilitado="true" noshow="true">
                <label  colstyle="font-weight:bold;font-size:28px;"></label>
                <expression>atributoUnidad(id, 'minibar')</expression>
            </field>


            <field id="aire"  noZero="true">
            <expression>atributoUnidad(id, 'marair')</expression>
                <label colstyle="font-weight:bold;font-size:28px;">A/A</label>
                <tabla_ex id="MARCAAIR" vacio="true" indexvacio="0" valorvacio="NO">
                    <field id="marair">
                      
                    </field>
                    <field id="desair">
                        <expression>LEFT(desair, 4)</expression>
                    </field>
                    
                    <field id="siscod" oculto="true">
                        <condicion operador="=">03</condicion>
                    </field>
                </tabla_ex>
                <tipo>varchar</tipo>
            </field>


            <field id="asientos" noshow="true">
                <expression>@asiento:=(SELECT (SUM(ROUND(pencps, 2))) from CPSENCAB left JOIN CPSMOVIM on
                    ( CPSMOVIM.siscod = CPSENCAB.siscod ) and
                    CPSMOVIM.ocpnro = CPSENCAB.ocpnro and CPSMOVIM.siscod = ''
                    where
                    CPSMOVIM.nrocha = TURNOSPRODUCCION.nrofab   and
                    CPSENCAB.ctacod = (select MARCAASI.ctacod
					from  MARCAASI where marasi = atributoUnidad(id, 'marasi') ))</expression>
            </field>


            <field id="faltante" noshow="true">
                <expression>(CASE WHEN @asiento > 1 THEN 'color:red;font-size:28px;'
                    when @asiento = 0 THEN 'color:green;font-size:28px;'
                    when @asiento &lt;= 1 THEN 'color:orange;font-size:28px;'
                    ELSE
                'color:grey;font-size:28px; ' END)</expression>
            </field>

            <field id="marasi">
                <expression> atributoUnidad(id, 'marasi')</expression>
                <attribute id="style">faltante</attribute>
                <label >Asientos</label>
                <help/>
                <tabla_ex id="MARCAASI">
                    <field id="marasi">
                    </field>
                    <field id="asides">
                        <expression>LEFT(asides, 4)</expression>
                    </field>
                    <field id="siscod" oculto="true">
                        <condicion operador="=">03</condicion>
                    </field>
                </tabla_ex>
            </field>


        <field id="video" deshabilitado="true" _noshow="true">
            <label colstyle="font-weight:bold;font-size:28px;">Video</label>
            <expression>CASE WHEN (select count(ACCESORIOS_COCHE.artcod) FROM ACCESORIOS_COCHE WHERE ACCESORIOS_COCHE.nrofab = TURNOSPRODUCCION.nrofab and (ACCESORIOS_COCHE.artcod = '052' or ACCESORIOS_COCHE.artcod = '053' or ACCESORIOS_COCHE.artcod = '054')) > 0 THEN 'SI' else '' END</expression>
            <tipo>varchar</tipo>
        </field>

        <field id="chapita" deshabilitado="true" local="true" linkint="chapita.xml" linkdes="Imprimir Chapita" Formstyle="display:none;" >
                <expression>'Chapa Ident.'</expression>
                <label>Chapa Identif</label>
                <tipo>varchar</tipo>
                <valor>"Chapa Identif"</valor>
                <paring destino="nrofab" operador="=">nrofab</paring>
                <paring destino="nrovin" >nrovin</paring>
        </field>

            <field id="pl2" local="true" showObjTabla="true">
	           <label>Planos</label>

	           <helper type="object" _type="link" xml="pedidoint_terminal_qry.xml" _modal="true">
		          <parameter source="nrofab" target="nrofab" operator="=" />
		       </helper>
               <!--
               <valor>'Ver'</valor>
                -->
             <size>20</size>
        
        </field>
	     <field id="pl3" local="true" showObjTabla="true">
    	      <label>Planos2</label>
		<helper type="object" xml="prd_planos_qry.xml">
		<parameter source="nrofab" target="nrofab" />
		<parameter source="idMomento" target="seccion_id" />
		</helper>
        
      <size>20</size>
	    </field>
	    
	    
            <field id="hi" deshabilitado="true" clasefila="true" noshow="true">
                <expression>case when TURNOSPRODUCCION.fechaActualiza = DATE(NOW()) then 'resaltado' else '' end</expression>

                <tipo>varchar</tipo>
            </field>

            </fieldGroup>
			         
			<order>
				<field id="fechaing2"/>
			</order>
		</table>
		<join tipo="left">
			<table id="PEDCOTIZ">
				<field id="nrocha">
					<condicion operador="=">TURNOSPRODUCCION.nrofab</condicion>
				</field>
			</table>
		</join>
		<join tipo="left">
			<table id="CHASIS">
				<field id="nrocha">
					<condicion operador="=">TURNOSPRODUCCION.nrofab</condicion>
				</field>
			</table>
		</join>
        <join tipo="left">
            <table id="HOMOLOGMOD">
                <field id="id_homologacion">
                    <condicion operador="=">PEDCOTIZ.homologacion_id</condicion>
                </field>
            </table>
        </join>        

    <join tipo="left">
               <table id="CARROCERIA">
          <field id="nrocar">
                 <condicion operador="=">HOMOLOGMOD.nrocar</condicion>
          </field>
        </table>
    </join>
    <join tipo="left">
      <table id="MARCHASIS">
        <field id="marcod">
          <condicion operador="=">HOMOLOGMOD.marcod</condicion>
        </field>
      </table>
    </join>
	<join tipo="left">
			<table id="MODCHASIS">
				<field id="modcha">
					<condicion operador="=">CHASIS.modcod</condicion>
				</field>
				<field id="marcod">
					<condicion operador="=">CHASIS.marcod</condicion>
				</field>
			</table>
	</join>
	<join tipo="left">
			<table id="CONCESIONARIO">
				<field id="idconces">
					<condicion operador="=">(case when CHASIS.conces != '' then CHASIS.conces else TURNOSPRODUCCION.idconces end)</condicion>
				</field>
			</table>
	</join>
	</form>
</histrix>
