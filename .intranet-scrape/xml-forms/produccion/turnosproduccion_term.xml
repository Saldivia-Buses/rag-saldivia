    <form  _detalle="detalleUnidad.xml" _inline="true">
        <table id="TURNOSPRODUCCION" label="Programa de Produccion">
            <filters>
                <field id="sale2" deshabilitado="true" noshow="true">
                    <label>Desde</label>
                    <help>Fecha de Ingreso a Linea</help>
                    <operador>&gt;=</operador>
                    <valor eval="true">date("d/m/Y", mktime(0, 0, 0, date("m"), date("d")-10, date("Y")))
                    </valor>
                </field>
            </filters>
            
            <field id="siscli" local="true" oculto="true" >
                <valor>'02'</valor>
            </field>

            <field id="seccion_id" noshow="true" local="true">
            </field>


	    <field id="fecha_salida_sec" noshow="true">
		<label>Sal.Secc</label>
		<expression>(select count(*) from PROD_CONTROLES join PROD_CONTROL_MOVIM on id_prodcontrol = prodcontrol_id 
		    where nrofab_id = PEDCOTIZ.nrocha and 
			  fecha_control &lt; DATE_FORMAT(NOW() ,'%Y-%m-01') and
			  orden_control = 999 and seccion_id = '[__seccion_id__]')</expression>
		<condicion operador="=">0</condicion>
	    </field>

        <field id="mes" local="true" noshow="true" incdec="true" min="1" max="12">
            <label>Mes</label>
            <tipo>integer</tipo>
            <size>2</size>
            <valor eval="true">date('m')</valor>
            <operador>=</operador>
        </field>

        <field id="year" local="true" noshow="true" incdec="true" min="1900" max="3000">
            <label modpos="nobr">año</label>
            <tipo>integer</tipo>
            <size>4</size>
            <valor eval="true">date('Y')</valor>
            <operador>=</operador>
        </field>

            <field id="_ORDEN" local="true" noshow="true">
                <label colstyle="font-weight:bold;font-size:21px;color:red;">Orden</label>
                <tipo>integer</tipo>
            </field>

        <field id="coches" noshow="true">
            <expression>select count(*) + 15 from TURNOSPRODUCCION left join PEDCOTIZ on PEDCOTIZ.nrocha = TURNOSPRODUCCION.nrofab where 
                    TURNOSPRODUCCION.linea_id = linea_id and
                    month(TURNOSPRODUCCION.fechaing) = '[__mes__]' and 
                    year(TURNOSPRODUCCION.fechaing) =  '[__year__]'</expression>
        </field>
	    <field id="count" suma="true" acumula="true" local="true" >
                <label colstyle="font-weight:bold;font-size:21px;color:red;">Ord.</label>
		<valor>1</valor>
	    </field>
<!--
            <field id="ord" local="true" noZero="true">
                <label colstyle="font-weight:bold;font-size:21px;color:red;">Ord.</label>
                <if exp="_ORDEN > (coches - 15)">
                    <true>''</true>
                    <false>_ORDEN</false>
                </if>

                <tipo>integer</tipo>
            </field>
    -->        
            <field id="numorden" local="true" noshow="true" noZero="false">
            <label>order</label>
                <if exp="true">
                <true>_ORDEN + 1 - 1 </true><!-- ARREGLAR _ORDEN (En HTX II arranca desde 0 y en HTX I desde 1 )-->
                <false>0</false>
                </if>
            </field>

            <field id="colores" local="true" clasefila="true" noshow="true" deshabilitado="true">
                <label>Col</label>
                <if exp="_ORDEN > (coches - 15)">
                  <true>'resaltado'</true>
                 <false>(_ORDEN % 2 != 0)?'grisado2':''</false>
                </if>
            </field>            

    <fieldGroup colstyle="font-weight:bold;font-size:21px">
        <if>return $_SESSION['idUser'] == '136';</if>
 
        <field id="chapa" >
        <label>Chaperia</label>
        <expression>select T.fechaing FROM TURNOSPRODUCCION T WHERE T.nroturno = idturno_ingreso_seccion(TURNOSPRODUCCION.nrofab, 3) limit 1</expression>
        <tipo>date</tipo>
        <format>d/m</format>
        </field>
        <field id="hrchapa" noshow="true">
        <label colstyle="font-size:19px;color:#888;">Hr.Ch.</label>
        <expression>select CONCAT( TIME_FORMAT(T.hora_movimiento, '%H'), 'Hs') FROM TURNOSPRODUCCION T WHERE T.nroturno = idturno_ingreso_seccion(TURNOSPRODUCCION.nrofab, 3) limit 1</expression>
        <tipo>time</tipo>

        </field>
        <field id="Term" >
        <label>Terminacion</label>
        <expression>select T.fechaing FROM TURNOSPRODUCCION T WHERE T.nroturno = idturno_ingreso_seccion(TURNOSPRODUCCION.nrofab, 5) limit 1</expression>
        <tipo>date</tipo>
        <format>d/m</format>
        </field>
        <field id="hrTerm" noshow="true">
        <label colstyle="font-size:19px;color:#888;">Hr.T.</label>
        <expression>select CONCAT( TIME_FORMAT(T.hora_movimiento, '%H'), 'Hs')  FROM TURNOSPRODUCCION T WHERE T.nroturno = idturno_ingreso_seccion(TURNOSPRODUCCION.nrofab, 5) limit 1</expression>
        <tipo>time</tipo>

        </field>

    </fieldGroup>

<!--         <if>return $_SESSION['idUser'] != '136';</if>
 -->
            <field id="fechaSalida" esClave="true"  >
                <label modpos="nobr" colstyle="font-weight:bold;font-size:28px;">Sale</label>
                    <expression sql="true">select fechaing  from TURNOSPRODUCCION as T left join PEDCOTIZ on PEDCOTIZ.nrocha = T.nrofab where 
                    T.linea_id = [__linea_id__] and 
                    fechaing >= '[__year__]-[__mes__]-01' order by fechaing  limit [__numorden__] , 1</expression>
                    <tipo>date</tipo>
                    <format>d/m</format>
            </field> 
            
            <field id="ingreso_sector">
                <label colstyle="font-weight:bold;font-size:18px;color:#888;">Ing.</label>
                <expression>select concat(date_format(fecha_control, '%d/%m') ,' ' ,TIME_FORMAT(hora_control,'%H:%i'))from PROD_CONTROLES join PROD_CONTROL_MOVIM on id_prodcontrol = prodcontrol_id where nrofab_id = nrofab and orden_control = 1 and seccion_id = '[__seccion_id__]'</expression>
            </field>

            <field id="controles_criticos" local="true" _noZero="true">
                <label colstyle="color:red;width:2em;font-weight:bold;font-size:18px;text-align:center;">Criti.</label>
                <expression>CASE WHEN (SELECT count(hora_control) FROM PROD_CONTROLES join PROD_CONTROL_MOVIM on id_prodcontrol = prodcontrol_id where nrofab_id = nrofab and seccion_id = '[__seccion_id__]' and critico = 1 and habilitado = 0) != (SELECT count(critico) FROM PROD_CONTROLES where seccion_id = '[__seccion_id__]' and critico = 1 and habilitado = 0) and (select count(hora_control)from PROD_CONTROLES join PROD_CONTROL_MOVIM on id_prodcontrol = prodcontrol_id where nrofab_id = nrofab and orden_control = 1 and seccion_id = '[__seccion_id__]' and habilitado = 0) = 1 THEN 'Críticos Pendient.' else '' end</expression>
                <!--<attribute id="style">controles_criticos</attribute>-->
            </field>

            <field id="liberacion">
                <label colstyle="font-weight:bold;font-size:18px;color:#888;">Libe.</label>
                <expression>select concat(date_format(fecha_control, '%d/%m') ,' ' ,TIME_FORMAT(hora_control,'%H:%i'))from PROD_CONTROLES join PROD_CONTROL_MOVIM on id_prodcontrol = prodcontrol_id where nrofab_id = nrofab and orden_control = 999 and seccion_id = '[__seccion_id__]'</expression>
            </field>

            <field id="orden_noconforme" local="true" noshow="true">
                <valor>1</valor>
            </field>

            <field id="controles" local="true" noZero="true">
                <label colstyle="width:2em;font-weight:bold;font-size:18px;text-align:center;">Pend.</label>
                <helper xml="prod_control_movim_qry.xml" type="link" title="Controles de Calidad" dir="controlcalidad/" modal="true">
                <parameter source="nrofab" target="nrofab_id"/>
                <parameter source="seccion_id" target="seccion_id"/>
                <parameter source="orden_noconforme" target="orden_noconforme" />
                </helper>
                <expression>SELECT sum(CASE WHEN no_conforme = 1 and controlado = 0 THEN 1 else 0 END) FROM PROD_CONTROLES join PROD_CONTROL_MOVIM on id_prodcontrol = prodcontrol_id where nrofab_id = nrofab and seccion_id = '[__seccion_id__]'</expression>
            </field>

            <field id="cliente" tabla="PEDCOTIZ" deshabilitado="true" noshow="true" >
                <expression>case when PEDCOTIZ.ctacod != '' then PEDCOTIZ.ctacod else TURNOSPRODUCCION.ctacod end</expression>
            </field>

            <field id="semana" noshow="true">
                <label>Sem</label>
                <expression>WEEKOFYEAR(case when PEDCOTIZ.ingresoLinea != '0000-00-00' then PEDCOTIZ.ingresoLinea else fechaing  end)</expression>
            </field>
            
            <field id="colorFec"  oculto="true">
                <expression>case when PEDCOTIZ.ingresoLinea != '0000-00-00' then 'color:green;font-size:11px;' else '' end</expression>
                <tipo>varchar</tipo>
            </field>

            <field id="linea_id" noshow="true">
                <helper type="combo" id="PROD_LINEAS" empty="true">
                    <field id="id_linea" />
                    <field id="nombre_linea" />
                </helper>
                <tipo>numeric</tipo>
                <valor>1</valor>
            </field>
           
            <field id="fechaing" _PDFanchofijo="true" oculto="true">
                <expression>fechaing</expression>
            </field>

            <field id="homologacion_id" _PDFanchofijo="true" oculto="true" noshow="true" tabla="PEDCOTIZ">
                <expression>homologacion_id</expression>
            </field>
          
            <field id="hora_movimiento" _PDFanchofijo="true" oculto="true" />
                    
            <field id="fechaing2"  esClave="true" _PDFanchofijo="true" noshow="true">
                <attribute id="style">colorFec</attribute>
                <expression having="false">(case when PEDCOTIZ.ingresoLinea != '0000-00-00' then PEDCOTIZ.ingresoLinea else fechaing end)</expression>
                <label >Entra</label>
                <tipo>date</tipo>
                <help>Fecha de Ingreso a Linea</help>
                <format>d/m</format> 
                <condicion operador="&lt;">CASE WHEN linea_id = 1 THEN ADDDATE(CURDATE(),INTERVAL 60 DAY) ELSE ADDDATE(CURDATE(),INTERVAL 1000 DAY) END</condicion>
            </field>
                              

            <!--<field id="controlcalidad" local="true"  obj="controlcalidad/controlcalidad_coche_Horiz_cons.xml" showObjTabla="true"  print="false">
                <paring destino="nrofab_id" operador="=">nrofab</paring>
                <paring destino="linea_id" operador="=">linea_id</paring>
                <paring destino="homologacion_id" operador="=">homologacion_id</paring> 
                <tipo>varchar</tipo>
                <label>Controles de Calidad</label>
            </field>-->
          
        

            <field id="terminacion" tabla="PEDCOTIZ" noshow="true">
                <label modpos="nobr">Terminacion</label>
                <tipo>date</tipo>            
            </field>

         
            <field id="posent" local="true" print="false" ignoreOption="true" getStyle="colorEnt" noshow="true">
                
                <label modpos="nobr" Formstyle="display:none;">Posic/Entr.</label>
                <tabla_ex id="MOMENTO" xml="momento_posiciones.xml" />
                <if exp="'Entrega' != '' and nrofab != 0">
                    <true>date(  'd/m/Y', strtotime ( 'Entrega')) </true>
                    <false>'ubicacion'</false>
                </if>
            </field>
              <field id="filtmail" noshow="true">
                <expression>CONCAT('+"Entrega Unidad" +', PEDCOTIZ.nrocha)</expression>
              </field>
            <field id="filtmail_param" noshow="true">
                <expression>CONCAT('Entrega Unidad ', PEDCOTIZ.nrocha)</expression>
            </field>

            <field id="Ingresos" noshow="true">
                <expression>(select count(*) from PEDCOTIZ P join TURNOSPRODUCCION T on T.nrofab = P.nrocha  where P.ingresoLinea &gt;= PEDCOTIZ.ingresoLinea and T.linea_id = TURNOSPRODUCCION.linea_id)</expression>
            </field>
                                  
            <field id="corpath" local="true" noshow="true">
                <if exp="true">
                    <true>'nrofab/corte'</true>
                    <false>''</false>
                </if>
                <tipo>varchar</tipo>
            </field>

            
            <field id="offset" noshow="true" deshabilitado="true">
                <expression>
                    select count(*) from TURNOSPRODUCCION as TUR where 
                    TUR.linea_id = TURNOSPRODUCCION.linea_id and 
                    TUR.fechaing &gt;= TURNOSPRODUCCION.fechaing and 
                    TUR.fechaing &lt;= now()
                </expression>
                <tipo>integer</tipo>
            </field>
            
            <field id="colorFecTer"  oculto="true">
                <expression>case when PEDCOTIZ.terminacion != '0000-00-00' then 'color:green; font-size:11px;font-weight:bold;' else 'color:#B32600; font-weight:bold;' end</expression>
                <tipo>varchar</tipo>
            </field>
           
          
          
            <field id="sale2" _esClave="true" noshow="true">
                <label modpos="nobr" >terminado</label>
                <expression having="false">DATE_ADD((case when ingresoLinea != '0000-00-00' then ingresoLinea else fechaing end), INTERVAL 60 DAY)</expression>
                <tipo>date</tipo>
                <preparam campo="sale2" operador="&lt;">true</preparam>
            </field>
        
            <field id="chasis_entrada" noshow="true">
                <expression>CONCAT('Fecha de entrada del Chasis: ', date_format(CHASIS.entrada, '%d/%m/%Y'))</expression>
                <tipo>date</tipo>
            </field>
            
          <field id="log" local="true" linkint="turnos_log_msg_cons.xml"  linkdir="" linkdes="Historial" print="false">
                <label getStyle="maxfec"  Formstyle="display:none;">Ult.Modif</label>
                <attribute id="tooltip">obser2</attribute>
                <attribute id="style">maxfec</attribute>
                <if exp="'max_fec' == 'today'">
                  <true>'HOY'</true>
                  <false>('max_fec'=='ayer')?'Ayer': (('max_fec' != '')?date('d/m', strtotime('max_fec')):'')</false>
                </if>                
                <paring destino="num"    >nroF</paring>
            </field>

          <field id="publicada" local="true" noshow="true">
                <label getStyle="maxfec"></label>
                <expression><![CDATA[SELECT fecha FROM `HTXLOG` WHERE campo = 'Estado' AND HTXLOG.obs LIKE concat('%N.Fab.: ',nrofab,'%')  AND (xmlprog = 'Fichaventas_abm.xml' or xmlprog = 'producto_estado_ficha_update.xml') AND tipo = 'UPDATE' LIMIT 1]]></expression>
            </field>

          <field id="reasignacion" local="true">
                <label getStyle="maxfec" colstyle="color:red"></label>
                <expression><![CDATA[SELECT 'REASIG' FROM `HTXLOG` WHERE campo = 'Cliente' AND obs LIKE concat('%N.Fab.: ',nrofab,'%') AND (xmlprog = 'Fichaventas_abm.xml' or xmlprog = 'producto_estado_ficha_update.xml') AND tipo = 'UPDATE' AND fecha > '[__publicada__]' AND nrofab != 0 LIMIT 1]]></expression>
            </field>

        <field id="tiene_trabajos_cnrt" noshow="true">
            <expression>case when 
                (SELECT COUNT(*) FROM PROD_TRABAJOS_CNRT where nrofab_id = nrofab) != 0 and HOMOLOGMOD.dispos = '' then 'background-color: #F5A9A9;' else 
                (case when (SELECT COUNT(*) FROM PROD_TRABAJOS_CNRT where nrofab_id = nrofab) != 0 and HOMOLOGMOD.dispos != '' then 'background-color: #00ff00;' else '' end) 
                end</expression>
        </field>            

        <field id="cnrt" print="false" noshow="true">
            <label Formstyle="display:none;" colstyle="color:red;font-weight:bold; text-align:center">CNRT</label>
            <expression>CASE WHEN (PEDCOTIZ.nrocha = '' or PEDCOTIZ.nrocha IS NULL) THEN ''
                ELSE (case when (HOMOLOGMOD.expte = '' or HOMOLOGMOD.dispos = '' or HOMOLOGMOD.plano = '' or PEDCOTIZ.homologacion_id = '' or PEDCOTIZ.homologacion_id IS NULL) then '' ELSE '' end) END</expression>
        </field>

        <field id="trabajos_cnrt" local="true" colstyle="color:red;font-weight:bold; text-align:center; font-size:24px !important;color:red;" Formstyle="display:none;">    
            <label></label>    
            <helper xml="prod_trabajos_cnrt.xml" dir="fabricacion/" type="link" modal="true" width="90%">
                <parameter source="nrofab" target="nrofab_id"/>
            </helper>
            <expression>case when (SELECT COUNT(*) FROM PROD_TRABAJOS_CNRT where nrofab_id = nrofab) != 0 then 'CNRT' else '' end</expression>
            <attribute id="linkdes">nrofab</attribute>
            <attribute id="style">tiene_trabajos_cnrt</attribute>
            <if exp="'trabajos_cnrt' != '' and nrofab != 0">
                <true>'trabajos_cnrt'</true>
                <false>'cnrt'</false>
            </if>
        </field>

            <field id="nroF" noshow="true">
                <expression>CONCAT(nrofab,',')</expression>
            </field>

            <field id="tieneFicha" noshow="true">
                <expression>case when PEDCOTIZ.estado_ficha = 1 then 'ficha_producto1_qry.xml' else '' end</expression>
            </field>

          <field deshabilitado="true" id="moddes" tabla="MODCHASIS">
                <expression>case when MODCHASIS.desabv != '' then MODCHASIS.desabv else TURNOSPRODUCCION.modeloChasis end</expression>
                <label colstyle="font-weight:bold;font-size:28px; color:#888">Mod</label>
                <tipo>varchar</tipo>
            </field>

            <field deshabilitado="true" id="abrev_euro" tabla="EURO_TIPO">
                <label colstyle="font-weight:bold;font-size:28px; color:#888">Eu</label>
                <tipo>varchar</tipo>
            </field>
        
        <field deshabilitado="true" id="chasis" tabla="CHASIS" linkint="chasis_cons.xml" linkdes="Ver Datos del Chasis">
            <expression><![CDATA[CONCAT( SUBSTRING(CHASIS.chasis, -8, 2),'<b>', RIGHT(CHASIS.chasis, 6), '</b>')]]></expression>
            <label colstyle="font-weight:bold;font-size:16px;">Chasis</label>
            <tipo>editor</tipo>
            <help>Numero de Serie del chasis</help>
            <paring destino="nrocha">nrofab</paring>
            <attribute id="tooltip">chasis_entrada</attribute>        
        </field>

      <field id="ficha_id" noshow="true">
    <expression>PEDCOTIZ.id</expression>
      </field>

            <field id="nrofab" tabla="TURNOSPRODUCCION">
                <attribute id="linkint">tieneFicha</attribute>
                <attribute id="linkdes">title</attribute>
                <helper xml="ficha_producto1_qry" dir="/producto" type="link" modal="true" width="98%" title="Ficha Producto">
                    <parameter source="nrofab" target="nrofab" />
                    <parameter source="producto_id" target="producto_id" />
                    <parameter source="ficha_id" target="id" />
                    <parameter source="ficha_id" target="producto_id" />
                    <parameter source="nrofab" target="nrofab" />
                </helper>
                <label colstyle="font-weight:bold;font-size:28px;">Nro.</label>
                <help>Numero de Fabricacion</help>
            </field>
                       
            <field id="max_fec" noshow="true">
              <expression>@maxrev:=(select DATE(max(timestamp_atributo)) from PRODUCTO_ATRIB_VALORES where producto_id = id)</expression>
            </field>

<!--             <field id="max_fec" noshow="true">
              <expression>  GREATEST( PEDCOTIZ.revfec ,
                    (select max(ACC.fecha) from PEDCOTIZ AS PED1 left join ACCESORIOS_COCHE as ACC on ACC.ficha_id = PED1.id where PED1.id = PEDCOTIZ.id ))</expression>                
            </field> -->

            <field id="today" noshow="true" print="false">
          <expression>DATE(NOW())</expression>
            </field>
            <field id="ayer"  noshow="true" print="false">
          <expression>DATE_SUB(curdate(), INTERVAL 1 DAY)</expression>
            </field>
            
            <field id="maxfec" local="true" noshow="true" print="false">
                <label>1</label>
                <expression>case when @maxrev = DATE(NOW()) then 'font-size:34px !important;color:red;;font-weight:bold;text-decoration:blink;animation: blink 1s steps(5, start) infinite; -webkit-animation: blink 1s steps(5, start) infinite;' 
                    when @maxrev = DATE_SUB(curdate(), INTERVAL 1 DAY)  then 'font-size:34px !important;color:blue;font-weight:bold;text-decoration:blink;width:auto;'
                    
                        else 'font-size:23px !important;color:green;font-weight:bold;width:auto;'
                                    end</expression>
                <tipo>varchar</tipo>
            </field>


            <field id="colorEnt" noshow="true" local="true">
                <if exp="'Entrega' != ''">
                    <true>'color:green;font-weight:bold;'</true>
                    <false>('ubicacion' != '')?'color:blue;font-weight:bold;':''</false>
                </if>
            </field>
        
          <field deshabilitado="true" id="ctafan" tabla="PEDCOTIZ">
                <expression>LEFT(ctafan, 17)</expression>
                <label colstyle="font-weight:bold;font-size:28px; color:#888">Cliente</label>
                <help>Codigo de Cuenta</help>
            </field>
            

    
        <field id="cortePint"  path="corpath" print="false" tabla="PEDCOTIZ" open="true" colstyle="width:auto;font-size:28px;" height="50">
                <expression>select valor_atributo from PRODUCTO_ATRIB_VALORES where producto_id = id and prdatributo_id = 7</expression>
                <label>Corte</label>
                <tipo>file</tipo>
                <size>93</size>
        </field>
            

	<field id="posicionreal" style="color:blue;">
        <label colstyle="font-weight:bold;font-size:28px;">sector</label>
	    <expression>select nombre from PROD_PATH_REGISTRO join PROD_PRODUCT_PATH ON id_productpath = productpath_id JOIN POSICIONESFAB PF on PF.id_posicionfab = PROD_PRODUCT_PATH.posicionfab_id where nrofab_id = nrofab and hora_salida = '0000-00-00 00:00:00:00' limit 1</expression>
	</field>
  

            
            <field deshabilitado="true" id="ctaconces"  noshow="true">
                <expression>case when CONCESIONARIO.ctacod >= 0 then CONCESIONARIO.ctacod else 0 end</expression>
                <tipo>integer</tipo>
                
            </field>
            
            
            <field id="ctacod" noshow="true">
                <expression>case when PEDCOTIZ.ctacod != '' then PEDCOTIZ.ctacod else TURNOSPRODUCCION.ctacod end</expression>
            </field>
        
            <field deshabilitado="true" id="nrocar" tabla="HOMOLOGMOD">
                <expression>case when HOMOLOGMOD.nrocar != '' then HOMOLOGMOD.nrocar else TURNOSPRODUCCION.nrocar end</expression>
                
                <label colstyle="font-weight:bold;font-size:28px;">Mod.</label>
                <help/>
                <tabla_ex id="CARROCERIA">
                    <field id="nrocar">
                    </field>
                    <field id="desabv">
                    </field>
                    
                    <field id="siscod" oculto="true">
                        <condicion operador="=">03</condicion>
                    </field>
                </tabla_ex>
                <tipo>varchar</tipo>
            </field>
            <field id="asientos" deshabilitado="true" noZero="true">
                <label colstyle="font-weight:bold; font-size:28px; color:#888; text-align:center;">Asi</label>
                <tipo>integer</tipo>
                <expression>case when CARROCERIA.doble_piso = 1 then (CONCAT(HOMOLOGMOD.asientos, '+', HOMOLOGMOD.asientos_plantabaja)) else (HOMOLOGMOD.asientos + HOMOLOGMOD.acompañante) end</expression>
            </field>
            
            <field id="bagno" deshabilitado="true" noZero="true">
                <label colstyle="font-weight:bold;font-size:28px;color:#888">B</label>
                <expression>atributoUnidad(id, 'bagno')</expression>
                <options>
                    <option valor="0">No</option>
                    <option valor="1">Si</option>
                </options>
                <tipo>varchar</tipo>
            </field>

            <field id="aire" noZero="true">
            <expression>atributoUnidad(id, 'marair')</expression>
                <label colstyle="font-weight:bold;font-size:28px;">A/A</label>
                <tabla_ex id="MARCAAIR" vacio="true" indexvacio="0" valorvacio="NO">
                    <field id="marair" />                     
                    <field id="desair">
                        <expression>LEFT(desair, 4)</expression>
                    </field>                    
                    <field id="siscod" oculto="true">
                        <condicion operador="=">03</condicion>
                    </field>
                </tabla_ex>
                <tipo>varchar</tipo>
            </field>

            <field id="marasi">
                <expression> atributoUnidad(id, 'marasi')</expression>
                <attribute id="style">faltante</attribute>
                <label colstyle="font-weight:bold;font-size:28px;">Asientos</label>
                <help/>
                <tabla_ex id="MARCAASI">
                    <field id="marasi">
                    </field>
                    <field id="asides">
                        <expression>LEFT(asides, 4)</expression>
                    </field>
                    <field id="siscod" oculto="true">
                        <condicion operador="=">03</condicion>
                    </field>
                </tabla_ex>
            </field>

        <field id="video" deshabilitado="true" _noshow="true">
            <label colstyle="font-weight:bold;font-size:28px;">Video</label>
            <expression>CASE WHEN (select count(ACCESORIOS_COCHE.artcod) FROM ACCESORIOS_COCHE WHERE ACCESORIOS_COCHE.nrofab = TURNOSPRODUCCION.nrofab and (ACCESORIOS_COCHE.artcod = '052' or ACCESORIOS_COCHE.artcod = '053' or ACCESORIOS_COCHE.artcod = '054')) > 0 THEN 'SI' else '' END</expression>
            <tipo>varchar</tipo>
        </field>

        <field id="chapita" deshabilitado="true" local="true" linkint="chapita.xml" linkdes="Imprimir Chapita" Formstyle="display:none;" >
                <expression>'Chapa Ident.'</expression>
                <label colstyle="font-weight:bold;font-size:20px;">Chapa Identif</label>
                <tipo>varchar</tipo>
                <valor>"Chapa Identif"</valor>
                <paring destino="nrocha" operador="=">nrofab</paring>
                <paring destino="nrovin" >nrovin</paring>
        </field>

   <field id="pl2" local="true" showObjTabla="true">
    <label colstyle="font-weight:bold;font-size:18px;">Planos</label>
    <helper type="object" xml="pedidoint_qry.xml">
  <parameter source="nrofab" target="nrofab" />
  </helper>
    </field>
    
    <field id="modelo_lcm_id" tabla="HOMOLOGMOD" noshow="true" />
    <field id="id_homologacion" tabla="HOMOLOGMOD" noshow="true" />

      <field id="carpeta_planos" local="true" linkint="prod_carpeta_planos_qry.xml" linkdir="fabricacion" _linkdes="Carpeta Planos" linkWidth="95%" linkHeight="95%">
          <label modpos="nobr" colstyle="font-weight:bold;font-size:20px;">PL STD</label>
          <paring destino="homologacion">homologacion_id</paring>
          <paring destino="nrocar">nrocar</paring>
          <paring destino="modelo_lcm">modelo_lcm_id</paring>
          <paring destino="nrofab">nrofab</paring>
          <paring destino="producto_id" >ficha_id</paring>
          <paring destino="seccion_id">seccion_id</paring>
          <expression>select (case when HOMOLOGMOD.nrocar != '' then CONCAT(count(*), ' std') else '' end) FROM PRD_CARPETA_PLANOS where (PRD_CARPETA_PLANOS.homologacion_id = HOMOLOGMOD.id_homologacion or PRD_CARPETA_PLANOS.nrocar_id = HOMOLOGMOD.nrocar or PRD_CARPETA_PLANOS.modelo_lcm_id = HOMOLOGMOD.modelo_lcm_id) and PRD_CARPETA_PLANOS.seccion_id = '[__seccion_id__]'</expression>
          <attribute id="linkdes">nrofab</attribute>
      </field>

      <field id="planos_especiales" local="true" linkint="prd_planos_qry.xml" linkdir="produccion" _linkdes="Carpeta Planos" linkWidth="95%" linkHeight="95%">
        <label modpos="nobr" colstyle="font-weight:bold;font-size:20px;">PL ESP</label>
        <paring destino="nrofab">nrofab</paring>
        <expression>select (case when HOMOLOGMOD.nrocar != '' then CONCAT(count(*), ' esp') else '' end) FROM PRD_PLANOS where PEDCOTIZ.nrocha = PRD_PLANOS.nrofab and PRD_PLANOS.carpetaplanos_id = 0</expression>
        <attribute id="linkdes">nrofab</attribute>
      </field>

      <field id="fotos_produccion" showValor="true" linkint="homol_fotos_prod_producto_qry.xml" linkdir="fabricacion" _linkdes="Carpeta Planos" linkWidth="95%" linkHeight="85%">
        <label modpos="nobr" colstyle="font-weight:bold;font-size:20px;">Fotos Produ</label>
        <paring destino="homologacion_id" operador="=">id_homologacion</paring>
        <paring destino="producto_id" operador="=">ficha_id</paring>
        <expression><![CDATA[SELECT CONCAT(IFNULL(count(*), 0), ' Fotos') FROM HOMOLOG_FOTOS_PROD HAV
                                JOIN PRODUCTO_ATRIB_VALORES PAV ON PAV.prdatributo_id = HAV.prdatributo_id 
                                                               AND PAV.valor_atributo = 1
                                WHERE HAV.homologacion_id = HOMOLOGMOD.id_homologacion
                                  AND PAV.producto_id = PEDCOTIZ.id ]]></expression>
        <valor>'Fotos Produc'</valor>
        <tipo>varchar</tipo>
        <attribute id="linkdes">nrofab</attribute>
      </field>

            <field id="hi" deshabilitado="true" clasefila="true" noshow="true">
                <expression>case when TURNOSPRODUCCION.fechaActualiza = DATE(NOW()) then 'resaltado' else '' end</expression>
                <tipo>varchar</tipo>
            </field>


            <order>
                <!--<field id="terminado"/>-->
                <field id="fechaing"/>
                <!--<field id="hora_movimiento"/>-->
            </order>
        </table>
        <join tipo="left">
            <table id="PEDCOTIZ">
                <field id="nrocha">
                    <condicion operador="=">TURNOSPRODUCCION.nrofab and PEDCOTIZ.nrocha != 0</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="CCTCUENT">
                <field id="ctacod">
                    <condicion operador="=">(case when PEDCOTIZ.ctacod != 0 then PEDCOTIZ.ctacod else TURNOSPRODUCCION.ctacod end)</condicion>
                </field>
                <field id="siscod">
                    <condicion operador="=">'02'</condicion>
                </field>
                
                
            </table>
        </join>
      <join tipo="left">
            <table id="HOMOLOGMOD">
                <field id="id_homologacion">
                    <condicion operador="=">PEDCOTIZ.homologacion_id</condicion>
                </field>

            </table>
        </join>
    <join tipo="left">
               <table id="CARROCERIA">
          <field id="nrocar">
                 <condicion operador="=">HOMOLOGMOD.nrocar</condicion>
          </field>
        </table>
    </join>
        
        
        <join tipo="left">
            <table id="CHASIS">
                <field id="nrocha">
                    <condicion operador="=">TURNOSPRODUCCION.nrofab and CHASIS.nrocha != 0</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="MODCHASIS">
                <field id="modcha">
                    <condicion operador="=">CHASIS.modcod</condicion>
                </field>
                <field id="marcod">
                    <condicion operador="=">CHASIS.marcod</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="CONCESIONARIO">
                <field id="idconces">
                    <condicion operador="=">(case when CHASIS.conces != '' then CHASIS.conces else TURNOSPRODUCCION.idconces end)</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="EURO_TIPO">
                <field id="id_euro">
                    <condicion operador="=">MODCHASIS.euro_id</condicion>
                </field>
            </table>
        </join>
        
    </form>
</histrix>
