<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" paginar="100" width="50">
    <title>CONSULTA DE FICHA DE VENTAS</title>
    <form  detalle="prd_planos.xml">
        <table id="PEDCOTIZ" label="Ficha de Ventas">
            <field id="id" noshow="true">
                <detalle>ficha_id</detalle>
                <detalle>id</detalle>
            </field>
            <field id="nrocha" esClave="true" tipoOrden="DESC">
                <label>Nro Fab</label>
                <help>Número de Fabricación</help>
                <detalle>nrofab</detalle>
            </field>
            <field id="ctacod">
                <label PDFsize="12" posx="6" posy="+1" size="23">Cliente</label>
                <help>Cçodigo de Cuenta</help>
                <tabla_ex condes="true" id="CCTCUENT">
                    <field id="ctacod"/>
                    <field id="ctafan"/>
                    <field id="siscod" oculto="true">
                        <condicion operador="=">'02'</condicion>
                    </field>
                </tabla_ex>
            </field>

           <field id="homologacion_id" tabla="PEDCOTIZ">
                <label>Homol</label>
                <helper type="combo" xml="combo_homologacion_modelo.xml" dir="/fabricacion" empty="true">
                </helper>
                <detalle>homologacion_id</detalle>
            </field>

           <field id="nrocar" tabla="HOMOLOGMOD">
                <label size="23" posx="110" posy="0" PDFsize="10">Mod.</label>
                <tabla_ex id="CARROCERIA">
                    <field id="nrocar">
                    </field>
                    <field id="desabv">
                    </field>  
                    <field id="siscod" oculto="true">
                        <condicion operador="=">03</condicion>
                    </field>
                </tabla_ex>
            </field>

            <field deshabilitado="true" id="asientos" noZero="true">
                <label>Asi</label>
                <tipo>integer</tipo>
                <expression>(HOMOLOGMOD.asientos + acompañante)</expression>
            </field>
			
            <field id="marcod" tabla="CHASIS" noshow="true">
                <label PDFsize="10" posx="6" posy="+2" size="23">Chasis Marca</label>
                <help/>
                <tabla_ex xml="marchasis.xml">
                    <field id="siscod" oculto="true">
                        <condicion operador="=">'03'</condicion>
                    </field>
                </tabla_ex>
                <tipo>integer</tipo>
            </field>
            <field id="desabv" tabla="MODCHASIS" >
                <label size="23" posx="60" posy="0" modpos="nobr" PDFsize="10">Chasis</label>
                <help></help>
                <tipo>varchar</tipo>
            </field>

            <field id="modelo_lcm_id" tabla="HOMOLOGMOD" noshow="true" />

            <field id="asigna_planos" local="true" linkint="prod_asignar_planos_unidad.xml" linkdir="fabricacion" _linkdes="Carpeta Planos" linkWidth="95%" linkHeight="95%">
                  <label modpos="nobr">Carpeta</label>
                  <paring destino="homologacion">homologacion_id</paring>
                  <paring destino="nrocar">nrocar</paring>
                  <paring destino="modelo_lcm">modelo_lcm_id</paring>
                  <paring destino="nrofab">nrocha</paring>
                  <expression>'>>>>'</expression>
                  <attribute id="linkdes">nrocha</attribute>
            </field>

            <field id="revfec"  deshabilitado="true">
                <label style="color:red;">Última Modif.</label>
                <help>Fecha de Pedido</help>
            </field>

            <order>
                <field id="nrocha" tabla="PEDCOTIZ"/>
            </order>
        </table>
      <join tipo="left">
            <table id="HOMOLOGMOD">
                <field id="id_homologacion">
                    <condicion operador="=">PEDCOTIZ.homologacion_id</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="CHASIS">
                <field id="nrocha">
                    <condicion operador="=">PEDCOTIZ.nrocha</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="MODCHASIS">
                <field clave="true" id="modcha">
                    <condicion operador="=">CHASIS.modcod</condicion>

                </field>
                <field id="marcod">
                    <condicion operador="=">CHASIS.marcod</condicion>
                </field>
            </table>
        </join>
    </form>
</histrix>
