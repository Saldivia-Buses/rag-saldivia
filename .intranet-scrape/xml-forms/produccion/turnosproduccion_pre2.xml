                <expression>select REG_MOVIMIENTOS.nro_movimiento from REG_MOVIMIENTOS where REG_MOVIMIENTOS.subsistema_id = '02' and REG_MOVIMIENTOS.nrofab = TURNOSPRODUCCION.nrofab and REG_MOVIMIENTOS.nrofab != 0 limit 1 </expression>
                <!-- <paring destino="ctacod">cliente</paring> -->
