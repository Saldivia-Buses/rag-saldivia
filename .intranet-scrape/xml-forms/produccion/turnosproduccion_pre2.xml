                    <true>offset</true>
                    <false>0</false>
                </if>

                <tipo>varchar</tipo>
            </field>

	    <field id="hayentrega">
                <expression having="false">(select count(*)  from ENTREGASCOCHES where ENTREGASCOCHES.nrofab = PEDCOTIZ.nrocha  and ENTREGASCOCHES.entrega IS NOT NULL  limit 1)</expression>
		<condicion operador="=">0</condicion>
	    </field>
