                <parameter source="nrofab" target="nrofab_id"/>
            </helper>
            <expression>case when (SELECT COUNT(*) FROM PROD_TRABAJOS_CNRT where nrofab_id = nrofab) != 0 then 'CNRT' else '' end</expression>
            <attribute id="linkdes">nrofab</attribute>
            <attribute id="style">tiene_trabajos_cnrt</attribute>
        </field>

        <field id="tiene_trabajos_cnrt" noshow="true">
            <expression>case when 
                (SELECT COUNT(*) FROM PROD_TRABAJOS_CNRT where nrofab_id = nrofab) != 0 and HOMOLOGMOD.dispos = '' then 'background-color: #F5A9A9;' else 
                (case when (SELECT COUNT(*) FROM PROD_TRABAJOS_CNRT where nrofab_id = nrofab) != 0 and HOMOLOGMOD.dispos != '' then 'background-color: #00ff00;' else '' end) 
                end</expression>
        </field>            

        <field id="cnrt" print="false" noshow="true">
            <label Formstyle="display:none;" colstyle="color:red;font-weight:bold; text-align:center">CNRT</label>
            <expression>CASE WHEN (PEDCOTIZ.nrocha = '' or PEDCOTIZ.nrocha IS NULL) THEN ''
                ELSE (case when (HOMOLOGMOD.expte = '' or HOMOLOGMOD.dispos = '' or HOMOLOGMOD.plano = '' or PEDCOTIZ.homologacion_id = '' or PEDCOTIZ.homologacion_id IS NULL) then 'NO' ELSE '' end) END</expression>
        </field>

        <field id="trabajos_cnrt" local="true" colstyle="color:red;font-weight:bold; text-align:center;" Formstyle="display:none;">    
            <label>Proto</label>    
            <helper xml="prod_trabajos_cnrt.xml" dir="fabricacion/" type="link" modal="true">
                <parameter source="nrofab" target="nrofab_id"/>
            </helper>
            <expression>case when (SELECT COUNT(*) FROM PROD_TRABAJOS_CNRT where nrofab_id = nrofab) != 0 then 'CNRT' else '' end</expression>
            <attribute id="linkdes">nrofab</attribute>
            <attribute id="style">tiene_trabajos_cnrt</attribute>
            <if exp="'trabajos_cnrt' != '' and nrofab != 0">
                <true>'trabajos_cnrt'</true>
