            <field id="afecha" local="true" >
                <label>Fecha</label>
                <tipo>date</tipo>
                <valor>today</valor>
            </field>

            <field id="PEDid"  noshow="true">
                <expression>PEDCOTIZ.id</expression>
            </field>

            <field id="siscli" local="true" oculto="true" >
                <valor>'02'</valor>
            </field>
            <field  id="nroturno" autoinc="true" noshow="true"  esclave="true" print="false">
                <label>Turno</label>
                <help>Turno</help>
            </field>

      <field id="subj" noshow="true" print="false">
              <expression><![CDATA[concat('+accesorios+Unidad: +', nrofab)]]></expression>
          </field>
            
      <field id="subj2" noshow="true" print="false">
              <expression><![CDATA[concat('ccesorios Unidad: ', nrofab)]]></expression>
          </field>
            
			<field id="cliente"  tabla="PEDCOTIZ" deshabilitado="true" noshow="true" >
                <expression>case when PEDCOTIZ.ctacod != '' then PEDCOTIZ.ctacod else TURNOSPRODUCCION.ctacod end</expression>
            </field>

            <field id="semana">
                <label modpos="nobr" Formstyle="display:none;">Sem</label>
                <expression>WEEKOFYEAR(case when PEDCOTIZ.ingresoLinea != '0000-00-00' then PEDCOTIZ.ingresoLinea else fechaing  end)</expression>
            </field>
            <field id="linea_id" colstyle="display:none;">
                <helper type="combo" xml="lineas.xml" >
                    <!-- 
                    <field id="id_linea" />
                    <field id="nombre_linea" />
                    <order>
                        <field id="id_linea" table="PROD_LINEAS" />
                    </order>
                -->
                </helper>
                <label>Linea</label>
            </field>


            <field id="colorFec"  oculto="true">
                <expression>case when PEDCOTIZ.ingresoLinea != '0000-00-00' then 'color:green;font-size:11px;' else '' end</expression>
                <tipo>varchar</tipo>
            </field>

            <field esClave="true" id="fecha2" _PDFanchofijo="true" _Formstyle="display:none;">
                <attribute id="colstyle">colorFec</attribute>
                <!--   <expression>fechaing</expression>  -->
                <expression>case when PEDCOTIZ.ingresoLinea != '0000-00-00' then PEDCOTIZ.ingresoLinea else '' end</expression>
                <label modpos="nobr">Entra</label>
                <tipo>date</tipo>
                <help>Fecha de Ingreso a Linea</help>
                <!--  <format>d/m</format> -->

            </field>
			
			<field id="ingresaEntra" local="true">
<!--			<expression>CONCAT(DATE_FORMAT(fechaing, '%d/%m/%y'), '\n', IFNULL(DATE_FORMAT(case when PEDCOTIZ.ingresoLinea != '0000-00-00' then PEDCOTIZ.ingresoLinea else '' end, '%d/%m/%y'), ''))</expression>
 -->
			<expression>CONCAT(DATE_FORMAT(fechaing, '%d/%m/%y'), '  -  ', IFNULL(DATE_FORMAT(case when PEDCOTIZ.ingresoLinea != '0000-00-00' then PEDCOTIZ.ingresoLinea else '' end, '%d/%m/%y'), ''))</expression>

				<label modpos="nobr" style="width:auto;">Ingresa Entra</label>
			</field>

            <field id="offset" noshow="true" deshabilitado="true">
                <expression>
                    select count(*) from TURNOSPRODUCCION as TUR where
                    TUR.fechaing &gt;= TURNOSPRODUCCION.fechaing and
                TUR.fechaing &lt;= date(now())</expression>
                <tipo>integer</tipo>
            </field>
            <!--
            <field id="cant" local="true" deshabilitado="true" noshow="true">
                <parametro id="fsmparam_parent.xml" retorna="parent">
                    <field id="parcla">
                        <condicion operador="=" >'posic'</condicion>
                    </field>
                </parametro>
                <tipo>integer</tipo>
            </field>
	    
   -->
	    <field id="hora_movimiento" deshabilitado="false" colstyle="display:none;" _required="true" esClave="true">
                <label modpos="nobr">Hora Mov.</label>
                <tipo>time</tipo>
            </field>
            <field id="hora" deshabilitado="false">
                <expression>LEFT(TURNOSPRODUCCION.hora_movimiento, 5)</expression>
                <label Formstyle="display:none;" modpos="nobr">Hora Mov</label>
                <tipo>time</tipo>
            </field>
            <field id="sale2" esClave="true" colstyle="dislpay:none;">
                <label modpos="nobr" >Sale</label>
                <!--	<expression>DATE_ADD(fechaing, INTERVAL 45 DAY)</expression>-->

                <expression having="false">DATE_ADD((case when ingresoLinea != '0000-00-00' then ingresoLinea else fechaing end), INTERVAL 60 DAY)</expression>

                <tipo>date</tipo>
            </field>
            <field id="terminacion" deshabilitado="true">
                <expression>PEDCOTIZ.terminacion</expression>
                <label modpos="nobr" >Terminacion</label> <!--IFNULL(DATE_FORMAT(PEDCOTIZ.terminacion, '%d/%m/%y'), '')-->
                <tipo>date</tipo>
            </field>

	    <field id="salePreent" local="true">
		<expression>CONCAT(DATE_FORMAT(DATE_ADD((case when ingresoLinea != '0000-00-00' then ingresoLinea else fechaing end), INTERVAL 60 DAY), '%d/%m/%y'), ' - ', IFNULL(DATE_FORMAT(CASE WHEN PEDCOTIZ.terminacion != '0000-00-00' THEN PEDCOTIZ.terminacion ELSE '' END, '%d/%m/%y'), ''))</expression>
	    </field>
            <field id="Yaent" noshow="true" print="false">
                <label  Formstyle="display:none;" modpos="nobr">Entrega</label>
                <expression>year(fechaing)</expression>
                <condicion operador="&gt;=">2008</condicion>

            </field>

            <field deshabilitado="true" id="moddes" tabla="MODCHASIS">
                <!--				<expression>MODCHASIS.moddes</expression> -->
                <expression>case when MODCHASIS.desabv != '' then MODCHASIS.desabv else TURNOSPRODUCCION.modeloChasis end</expression>

                <label >Mod</label>
                <help/>
                <tipo>varchar</tipo>
            </field>
            <field deshabilitado="true" id="chasis" tabla="CHASIS" linkint="chasis_cons.xml" linkdes="Ver Datos del Chasis">
                <expression><![CDATA[CONCAT( SUBSTRING(CHASIS.chasis, -8, 2),'<b>', RIGHT(CHASIS.chasis, 6), '</b>')]]></expression>
                <label>Chasis</label>
                <help>Numero de Serie del chasis</help>
                <paring destino="nrocha">nrofab</paring>

            </field>

            <field id="tieneFicha" noshow="true">
                <expression>case when PEDCOTIZ.estado_ficha = 1 then 'ficha_producto1_qry.xml' else '' end</expression>
            </field>

            <field id="ficha_id" noshow="true">
                <expression>PEDCOTIZ.id</expression>
            </field>
            <field id="nrofab"  deshabilitado="false" noZero="true" linkint="ficha_producto1_qry.xml" linkdir="/producto" linkdes="Ficha Producto">
                <label _modpos="nobr" style="color:#444;font-weight:bold;">Nro.</label>
                <help>Numero de Fabricacion</help>
                <helper type="external" id="CHASIS">
                    <field id="nrocha" />
                    <field id="chades" />
                </helper>
            <attribute id="linkint">tieneFicha</attribute>
                <paring destino="nrofab">nrofab</paring>
                <paring destino="producto_id">ficha_id</paring>
                <paring destino="id">ficha_id</paring>
                <detalle>nrocha</detalle>
            </field>
            <field id="posicionreal" style="color:blue;">
                <expression>select nombre from PROD_PATH_REGISTRO join PROD_PRODUCT_PATH ON id_productpath = productpath_id JOIN POSICIONESFAB PF on PF.id_posicionfab = PROD_PRODUCT_PATH.posicionfab_id where nrofab_id = nrofab and
                hora_salida = '0000-00-00 00:00:00:00' limit 1</expression>
            </field>            
            <field id="accesorios"  linkint="cotiz_accesorios_coche_foto_cons2.xml" linkdir="/cotizacion" _linkint="accesorios_coche_qry.xml" deshabilitado="true"
		    style="width:auto;"
                   linkdes="Adicionales">
                   <expression>select sum(ifnull(precio_unitario,0) * cantidad) from ACCESORIOS_COCHE AS ACC where estado != 2  and ACC.ficha_id = PEDCOTIZ.id</expression>
                <label modpos="nobr" style="color:#444;font-weight:bold;">Acc</label>
                <paring destino="ficha_id">PEDid</paring>
                <paring destino="showprecios">1</paring>
            </field>

      <field id="emails" _showTablaObj="true" local="true">
        <helper type="link" xml="contaemail_qry.xml" dir="/email">
          <parameter target="subject" source="subj2" operator="like"/>
        </helper>
        <label >Mail</label>
        <help></help>
        <expression sql="true"><![CDATA[select CONCAT(RIGHT(fecha, 2), '/', SUBSTRING(fecha, 6, 2)) from HTXMAIL where match(subject) against('[__subj__]' IN BOOLEAN MODE) limit 1]]></expression>
      </field>  

<!--			<field id="emails" _showTablaObj="true" local="true">
				<helper type="link" xml="contaemail_qry.xml" dir="/email">
					<parameter target="subject" source="subj" operator="like"/>
				</helper>
				<label >Mail</label>
				<help></help>
				<expression><![CDATA[select CONCAT(RIGHT(fecha, 2), '/', SUBSTRING(fecha, 6, 2)) from HTXMAIL where subject like concat('%',@subj,'%') limit 1]]></expression>
				
			</field>		

  -->
			<field id="cantPend" local="true" >
				<label>Pend.</label>
				<expression>CASE WHEN (SELECT COUNT(*) FROM ACCESORIOS_COCHE ac WHERE estado = 0 and precio_unitario != 0 and ac.ficha_id = PEDCOTIZ.id) THEN CONCAT((SELECT COUNT(*) FROM ACCESORIOS_COCHE ac WHERE estado = 0 and precio_unitario != 0 and ac.ficha_id = PEDCOTIZ.id), '/', (SELECT COUNT(*) FROM ACCESORIOS_COCHE ac WHERE ac.ficha_id = PEDCOTIZ.id and precio_unitario != 0)) END</expression>
			</field>
