<?xml version="1.0" encoding="ISO-8859-1" ?>
<histrix tipo="consulta" _imprime="false">
  <title>ARTICULOS POR SECTOR</title>
  <obs></obs>
  <form >
    <table id="STK_ARTICULO_PROCESO" label="Rubros" >
      
      <field id="proceso_id"  oculto="true">
        <label>Cod.</label>
      </field>

      <field id="homologacion_id" oculto="true">
        <label>Homol</label>
      </field>

      <field id="nombre_proceso" local="true" noshow="true" print="false">
        <setvar>titulo_div</setvar>
        <setvar>tituloAbm</setvar>
      </field>

      <field id="stkarticulo_id" esClave="true">
        <label>Art.</label>
                <help>Codigo de Articulo</help>
                <!-- <ayuda_ex id="STKINSUM" xml="HLPstkinsum.xml" dir="/ayudas" > -->
					<ayuda_ex id="STKINSUM" xml="HLPstkinsum.xml" dir="/ayudas_local" >
                    <field id="artcod" >
                        <label>Cod.</label>
                    </field>
                    <field id="artdes">
                        <label>Insumo</label>
                        <detalle>artdes</detalle>
                    </field>
	    </ayuda_ex>    
     </field>
      <field id="artdes">
        <expression>artdes</expression>
        <label>Descripcion</label>
      </field>
      <field id="cantidad" required="true">
        <label>Cant.</label>
        <jseval>cantidad != 0</jseval>
      </field>
      
                        <field id="artuni" deshabilitado="true" tabla="STKINSUM">
                <label modpos="nobr" >Unidad</label>
                <help>Unidad de Stock</help>
                <tabla_ex id="FSMUNIDS">
                    <field id="unicod" clave="true"></field>
                    <field id="uninom"></field>
                </tabla_ex>
                <tipo>integer</tipo>
            </field>
    </table>
    <join tipo="left">
      	<table id="STKINSUM">
      	    <field id="artcod">
      		    <condicion operador="=">stkarticulo_id</condicion>
      	    </field>
            <field id="siscod">
              <condicion operador="=">'01'</condicion>
            </field>
      	</table>
    </join>
  </form>     
</histrix>
