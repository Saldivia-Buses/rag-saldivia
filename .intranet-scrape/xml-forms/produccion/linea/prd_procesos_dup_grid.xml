<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="grid" ancho="60%" deleteRow="false">
  <title>Procesos de Produccion</title>
  <obs/>
  <form >
    <table id="PROD_PROCESOS">
      <movimientos >
        <relacion id="prod_procesos_dup_ins.xml"></relacion>
      </movimientos>

        <field id="id_proceso" noshow="true">
          <label>id</label>
        </field>

      <field id="nombre_proceso">
        <label>Proceso</label>
        <help>nombre del proceso</help>
        <size>150</size>
      </field>

      <field id="descripcion_proceso">
        <label>Descripcion</label>
        <help>Descripción del proceso</help>
        <size>300</size>
      </field>

        <field id="homologacion_id"  noshow="true" esClave="true" >
          <label>Modelo</label>
          <condicion operador="=">-1</condicion>
        </field>

      <field id="procesopadre_id" noshow="true">
      </field>

        <field id="max_id" noshow="true">
          <expression>SELECT MAX(pp.id_proceso) + 1 FROM PROD_PROCESOS pp</expression>
        </field>

        <field id="primer_id" noshow="true">
          <expression>SELECT MIN(pp.id_proceso) FROM PROD_PROCESOS pp WHERE pp.homologacion_id = PROD_PROCESOS.homologacion_id</expression>
        </field>

        <field id="new_proceso_id" local="true" noshow="true">
          <if exp="true">
            <true>max_id - primer_id + id_proceso</true>
            <false>max_id - primer_id + id_proceso</false>
          </if>
        </field>

        <field id="new_procesopadre_id" local="true" noshow="true">
          <if exp="procesopadre_id == 0">
            <true>0</true>
            <false>max_id - primer_id + procesopadre_id</false>
          </if>
        </field>

        <field id="new_homologacion_id"  local="true" noshow="true">
          <label>Homologacion Nueva</label>
        </field>

      <order>
        <field id="id_proceso" />
      </order>
    </table>
  </form>
</histrix>
