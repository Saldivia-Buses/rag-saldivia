<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<histrix tipo="card" grid="30%,300px">
  <title>Posiciones</title>
  <obs/>
  <form  >
    <table id="MOMENTO" >
      <title>Secciones de Fabricación</title>

      <field id="idMomento"  noshow="true">
	    <label>id</label>
      </field>
      <field id="reportar" noshow="true">
        <label>reportar</label>
        <expresion>(select count(*) from PROD_ESTADOSLINEA where seccion_id = idMomento and fecha_salida = '0000-00-00')</expresion>
        <condicion operador="!=">0</condicion>
      </field>  
      <field id="descripcion" noshow="true">
      </field>
      
      <field id="titulo" style="font-weight:bold;font-size:20px;" local="true">
        <if exp="true">
    	    <true>'descripcion - (reportar)'</true>
    	    <false>''</false>
        </if>
        <help>descripcion</help> 
      </field>
      <field id="coches" local="true" showObjTabla="true">
        <helper type="object" xml="coches_seccion_cons.xml">
    	    <parameter source="idMomento" target="seccion_id"/>
        </helper>
      </field>      
    </table>
  </form>
</histrix>
