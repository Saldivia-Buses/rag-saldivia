<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="ing" imprime="false" subtipo="vertical" log="false" path="fotos/articulos" detailDir="/articulos">
    <title>ARTICULOS POR SECTOR</title>
    <obs></obs>
    <eventos>
        <event id="procesar">close</event>
<!--         <event id="procesar">refresh</event>
 -->    </eventos>
    <form detalle="stkpieza_qry.xml" inline="true" hasDetail="tienehijos">
        <table id="STK_ARTICULO_PROCESO" label="Rubros">

<!--             <importar xml="stkinsum_select.xml" label="Cargar Materiales" titulo="Seleccionar Materiales"></importar>  -->

		<movimientos>
			<relacion id="materiales_proceso_ins.xml" />
			<!--<relacion id="materiales_proceso_upd.xml" />-->
			<relacion id="materiales_proceso_del.xml" />
		</movimientos>

		<field id="id_artproceso" noshow="true" esClave="false" />

		<field id="proceso_id" oculto="true" esClave="false">
			<label>Cod.</label>
		</field>

		<field id="fecha" local="true" noshow="true">
			<label>Fecha</label>
			<valor>today</valor>
			<tipo>date</tipo>
			<detalle>fecha</detalle>
		</field>

		<field id="homologacion_id" oculto="true">
			<label>Homol</label>
		</field>

		<field id="stkarticulo_id" esClave="true" colspan="4">
			<label>Art.</label>
			<help>Codigo de Articulo</help>
			<ayuda_ex id="STKINSUM" xml="HLPstkinsum.xml" dir="/ayudas_local" >
				<field id="artcod">
					<label>Cod.</label>
				</field>
				<field id="artdes">
					<label>Insumo</label>
					<detalle>artdes</detalle>
				</field>
				<field id="valuso">
					<detalle>valuso</detalle>
				</field>
				<field id="valcps">
					<detalle>valcps</detalle>
				</field>
				<field id="artuni">
					<label>unidad</label>
					<detalle>artuni</detalle>
				</field>
				<field id="unicps">
					<detalle>unicps</detalle>
				</field>
			</ayuda_ex>
			<detalle>idPadre</detalle>
			<size>12</size>
		</field>

		<field id="artdes">
			<expression>artdes</expression>
			<label modpos="nobr">Descripcion</label>
			<size>50</size>
		</field>

		<field id="conversion" local="true" preventLoop="true" deshabilitado="true">
			<label modpos="nobr">Conv</label>
			<if exp="valCps == valUso">
				<true>cantidad</true>
				<false>(valCps == 1)?(cantidad / valUso):(cantidad * valCps)</false>
			</if>
			<tipo>decimal</tipo>
		</field>

		<field id="unicps" tabla="STKINSUM" deshabilitado="true">
			<label modpos="nobr">Compra</label>
			<help>Unidad de Compra</help>
			<tabla_ex id="FSMUNIDS">
				<field id="unicod"></field>
				<field id="uninom"></field>
			</tabla_ex>
		</field>
		
		<field id="cantidad" tabla="STK_ARTICULO_PROCESO">
			<label modpos="nobr">Cantidad</label>
			<tipo>float</tipo>
		</field>

		<field id="artuni" deshabilitado="true" tabla="STKINSUM">
			<label modpos="nobr">Uso</label>
			<help>Unidad de Stock</help>
			<tabla_ex id="FSMUNIDS">
				<field id="unicod" clave="true"></field>
				<field id="uninom"></field>
			</tabla_ex>
			<tipo>integer</tipo>
		</field>

        <field id="fecha" local="true" noshow="true">
            <label>Fecha</label>
            <valor>today</valor>
            <tipo>date</tipo>
            <detalle>fecha</detalle>
        </field>

<!--         <field id="costo_final_func_cdesc" style="font-weigth:bold;color:red;">
            <label>Costo c/Desc</label>
            <expression>ifnull(getCostConDtoFunc(STK_ARTICULO_PROCESO.stkarticulo_id, ifnull(STK_COSTO_REPOSICION.moneda_id, 1), STR_TO_DATE('[__fecha__]', '%d/%m/%Y')  ), 0) 
* (case when (select count(*) from STKPIEZA where IdPadre = STK_ARTICULO_PROCESO.stkarticulo_id) then 1 else (valcps / valuso) end)</expression>            
            <tipo>numeric</tipo>
        </field>

        <field id="parcialRCD"  suma="true" local="true">
            <label>Total</label>
            <if exp="true">
                <true>(costo_final_func_cdesc + 0) * cantidad</true>
                <false></false>
            </if>
            <tipo>numeric</tipo>
        </field>
 -->        
		<field id="artcod" tabla="STKINSUM" noshow="true" />

      <field id="fecult" tabla="STKINSUM" tipoOrden="DESC" Formstyle="display:none;">
		<expression>ultima_compra</expression>
        <label>ult.compra</label>
        <tipo>date</tipo>
      </field>                                         

		<field id="valCps">
			<expression>valcps</expression>
			<label modpos="nobr">Cps</label>
		</field>

		<field id="valUso">
			<expression>valuso</expression>
			<label modpos="nobr">Uso</label>
		</field>

		<field id="tienehijos" noshow="true">
			<expression>ifnull((select 1 from STKPIEZA s where s.idPadre = STK_ARTICULO_PROCESO.stkarticulo_id limit 1), 0)</expression>
		</field>

		<field id="fotopath" local="true" noshow="true">
			<if exp="true">
				<true>'stkarticulo_id/'</true>
				<false>''</false>
			</if>
			<tipo>varchar</tipo>
		</field>

		<field id="foto" path="fotopath" download="true" Formstyle="display:none;" deshabilitado="true">
			<expression>select ARTICULO_FOTO.foto from ARTICULO_FOTO where ARTICULO_FOTO.idArticulo = STKINSUM.artcod order by revision desc limit 1</expression>
			<label>Imagen</label>
			<tipo>file</tipo>
			<size>100</size>
		</field>

		<field id="borrarchk" local="true" _editable="true" refresh="true" Formstyle="display:none;">
			<label _Formstyle="display:none;">Borrar</label>
			<tipo>check</tipo>
		</field>

		<field id="deleteCond" local="true" noshow="true">
			<label>cond del</label>
			<if exp="'borrarchk' == 1">
				<true>'true'</true>
				<false>'false'</false>
			</if>
		</field>

		<field id="insertCond" local="true" noshow="true">
			<label>cond ins</label>
			<if exp="'borrarchk' == 0">
				<true>1</true>
				<false>0</false>
			</if>
		</field>

		<group>
			<field id="stkarticulo_id" />
		</group>

	</table>

	<join tipo="left">
		<table id="STKINSUM">
			<field id="artcod">
				<condicion operador="=">STK_ARTICULO_PROCESO.stkarticulo_id</condicion>
			</field>
			<field id="siscod">
				<condicion operador="=">'01'</condicion>
			</field>
		</table>
	</join>

	<join tipo="left">
		<table id="STKPIEZA">
			<field id="idPadre">
				<condicion operador="=">STKINSUM.artcod</condicion>
			</field>
		</table>
	</join>

	<join tipo="left">
		<table id="STKINSPR">
			<field id="siscod">
				<condicion operador="=">STKINSUM.siscod</condicion>
			</field>
			<field id="artcod">
				<condicion operador="=">STKINSUM.artcod</condicion>
			</field>
		</table>
	</join>

<!-- 	<join tipo="left">
		<table id="STK_COSTO_REPOSICION">
			<field id="stkarticulo_id">
				<condicion operador="=">STKINSUM.artcod</condicion>
			</field>
		</table>
	</join>
 -->
  </form>
</histrix>
