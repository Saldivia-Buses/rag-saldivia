		  <join tipo="left">
		    <tabla id="CCTCUENT">
			<campo id="siscod" oculto="true">
			    <condicion operador="=">01</condicion>
			</campo>
			<campo id="ctacod" oculto="true">
			    <condicion operador="=">IVAIMPORTES.ctacod</condicion>
			</campo>
		    </tabla>
		  </join>
		<join tipo="left">
			<tabla id="CCTCONCE">
				<campo id="siscod" oculto="true">
					<condicion operador="=">01</condicion>
				</campo>
				<campo id="concod" oculto="true">
					<condicion operador="=">IVAIMPORTES.codcom</condicion>
				</campo>
			</tabla>
		</join>						   
	    
		  
