			<campo id="debe" suma="true">
				<expresion>sum(totcom * (case when CCTCONCE.contip = 1 then 1 else 0 end))</expresion>
				<label>debe</label>
			</campo>
			<campo id="haber" suma="true">
				<expresion>sum(totcom * (case when CCTCONCE.contip = 2 then 1 else 0 end))</expresion>
				<label>haber</label>
			</campo>
			<campo id="dif" local="true">
				<label>diferencia</label>
				<if exp="true">
					<verdadero>debe - haber</verdadero>
					<falso>0</falso>
				</if>
			</campo>
			<filtros>
			    <campo id="feciva">
				<label>Desde Fecha</label>
				<operador>&gt;=</operador>
				<valor>today</valor>
			    </campo>
		    	    <campo id="feciva">
				<operador>&lt;=</operador>
				<label>Hasta Fecha</label>
				<valor>today</valor>
			    </campo>
			</filtros>
    		    <group>
<!--    		        <campo id="IVAIMPORTES.siscod"></campo>
    		        <campo id="IVAIMPORTES.siscod"></campo>-->
