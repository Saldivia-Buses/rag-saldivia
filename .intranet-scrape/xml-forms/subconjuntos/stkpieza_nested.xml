<?xml version="1.0" encoding="ISO-8859-1" ?>
<histrix tipo="consulta" path="fotos/articulos">
    <title>FORMACION DE PRODUCTO</title>
    <obs></obs>
    <form detalle="stkpieza_nested.xml" hasDetail="cantHijos" inline="true">
        <table id="STKPIEZA" label="Piezas">
    	    <fieldGroup>
        	<field id="id_pieza" esClave="true" autoinc="true" noshow="true" />
        	<field id="idPadre" arbol="padre" esClave="true" required="false" >
                	<label colstyle="display:none;" >padre</label>
	            <help>Nombre del Articulo al que pertenece </help>
    	            <ayuda_ex id="STKINSUM" xml="HLPstkinsum.xml" dir="/help_local">
    		        <field id="artcod">
            	            <label>Cod.</label>
                        </field>
	                <field id="artdes">
        	            <label>Insumo</label>
            	            <detalle>artdes</detalle>
                	</field>
                        <field id="siscod" oculto="true">
	                    <condicion operador="=">'01'</condicion>
    	                </field>
        	        <clave>artcod</clave>
            	        <descripcion>artdes</descripcion>
                    </ayuda_ex>
	        </field>
            
                <field id="articulo_hijo" arbol="hijo" esClave="true" >
	            <label>Codigo de Pieza</label>
    	            <help>Codigo del Articulo</help>
    		    <ayuda_ex id="STKINSUM" xml="HLPstkinsum.xml" dir="/help_local">
	                <field id="artcod">
    	                    <label>Cod.</label>
        	        </field>
                        <field id="artdes">
	                    <label>Insumo</label>
    	                <detalle>artdes</detalle>
    	                </field>
                        <field id="siscod" oculto="true">
	                    <condicion operador="=">'01'</condicion>
    	                </field>
        	        <clave>artcod</clave>
            	        <descripcion>artdes</descripcion>
                    </ayuda_ex>
                <detalle>idPadre</detalle>
	        </field>
        	<field id="artdes"  tabla="STKINSUM">
            	    <expression>artdes</expression>
        	    <label modpos="nobr">Articulo </label>
            	    <tipo>varchar</tipo>
            	    <size>50</size>
        	</field>
        	<field id="cantidad">
            	    <label>Cantidad</label>
        	</field>
	        <field id="valcps" noshow="true" tabla="STKINSUM">
    	        </field>
                <field id="valuso" noshow="true" tabla="STKINSUM">
	        </field>
	        <field id="uninom" tabla="FSMUNIDS" deshabilitado="true">
	    	    <expression>FSMUNIDS.uninom</expression>
		    <label>Unidad</label>
	    	    <tipo>char</tipo>
	        </field> 
	        <field id="costo_automatico" deshabilitado="true" >
            	    <tipo>decimal</tipo>
                    <label>Unitario</label>
	        </field>
        	<field id="total" deshabilitado="true" suma="true">
            	    <label>Costo</label>
		    <expression>round(cantidad * costo_automatico, 2)</expression>
            	    <tipo>decimal</tipo>
                </field>

    	    </fieldGroup>
    	    <fieldGroup tdWitdh="10">

        	<field id="FOTOPATH" local="true" noshow="true">
            	    <if exp="true">
                	<true>'articulo_hijo/'</true>
                        <false>''</false>
	            </if>
    		    <tipo>varchar</tipo>
                </field>
                <field id="cantHijos" noshow="true">
	            <expression>select count(*) from STKPIEZA as PIEZA where PIEZA.idPadre = STKPIEZA.articulo_hijo</expression>
    	        </field>
		<field id="fecult"  tipoOrden="DESC">
			<expression>(select STKINSPR.fecult from STKINSPR where STKINSPR.artcod = STKPIEZA.articulo_hijo and STKINSPR.siscod='01' order by fecult DESC limit 1) </expression>
			<label modpos="nobr" Formstyle="display:none;">ult.compra</label>
			<tipo>date</tipo>
		</field>			
		<field id="ultsalida" >
			<label Formstyle="display:none;">Ultima Salida</label>
			<expression>select max(STK.movfec) from STKINMOV as STK where STK.artcod = STKPIEZA.articulo_hijo and STK.siscod = '01' and STK.movcod = 10</expression>
			<tipo>date</tipo>
		</field>
		<field id="ctacod"  >
			<expression>(select ctacod from STKINSPR where STKINSPR.artcod =  STKPIEZA.articulo_hijo and STKINSPR.siscod='01' order by fecult DESC limit 1) </expression>
			<label colspan="4" modpos="nobr" Formstyle="display:none;">Proveedor</label>
			<tipo>integer</tipo>
			<tabla_ex id="CCTCUENT">
				<field id="ctacod" />
				<field id="ctafan" />					
				<field id="siscod" oculto="true">
					<condicion operador="=">'01'</condicion>
				</field>
			</tabla_ex>
		</field>
        	<field id="foto" path="FOTOPATH" Formstyle="display:none;">
            	    <expression>select ARTICULO_FOTO.foto from ARTICULO_FOTO where ARTICULO_FOTO.idArticulo = STKINSUM.artcod order by revision desc limit 1</expression>
            	    <label>Imagen</label>
            	    <tipo >file</tipo>
            	    <size>40</size>
        	</field>
	        <field id="ctbcod" print="false" tabla="CTBCUENT" style="text-align:center;" Formstyle="display:none;">
	            <label>Nro Cta</label>
	            <tipo>varchar</tipo>
		</field>
		<field id="ctbnom" tabla="CTBCUENT" print="false">
	            <expression>ctbnom</expression>
	            <label>CtaCtb</label>
	            <tipo>varchar</tipo>
	        </field>
	</fieldGroup>    
	<order>
	    <field id="ctbcod" tabla="CTBCUENT"/>
	</order>



        </table>
        <join tipo="left">
            <table id="STKINSUM">
                <field id="siscod" >
                    <condicion operador="=">'01'</condicion>
                </field>
                <field id="artcod">
                    <condicion operador="=">STKPIEZA.articulo_hijo</condicion>
                </field>

            </table>
        </join>
    <join tipo="left">
    
      <table id="CTBCUENT">
<!--        <field id="siscod" >
          <condicion operador="=">'10'</condicion>
        </field>
    -->    
        <field id="ctbcod" >
          <condicion operador="=">STKINSUM.artctb</condicion>
        </field>
    
      </table>
    </join>        
        
    <join tipo="left">
    
      <table id="FSMUNIDS">
        <field id="unicod" >
          <condicion operador="=">STKINSUM.artuni</condicion>
        </field>
    
      </table>
    </join>    

    </form>
</histrix>

