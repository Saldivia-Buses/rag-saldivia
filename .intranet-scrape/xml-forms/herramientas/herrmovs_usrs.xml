<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="abm" preloadData="false">
  <title>Movimiento de Herramientas por USUARIO</title>
  <obs></obs>
  <form >
    <table id="HERRMOVS" label="MOVIMIENTOS">
      <filters>
        <field id="usuario">
        <label>Código</label>
          <operador>=</operador>
         <!-- <valor>0</valor>-->
        </field>
        <field id="nombre" local="true" deshabilitado="true">
        <label>Nombre</label>
          <operador>=</operador>
        </field>        
      </filters>
      
      <field id="id_herr">
        <label>Cod.</label>
        <expression>id_herramienta</expression>
        <tipo>varchar</tipo>
        <format>(%s)</format>
        <help>Cod. de Herramienta</help>
      </field>
      <field id="id_herramienta">
        <label>Herramienta</label>
        <help>Herramienta </help>
        <helper type="combo" id="MANT_EQUIPOS" empty="true">
		  <field id="numero_serie" />
          <field id="nombre_equipo">
            <expression>concat( nombre_equipo,' - ', numero_serie)</expression> 
          </field>
          <field id="tipoequipo_id">
            <condicion operador="=">3</condicion>
          </field>

          <order>
            <field id="nombre_equipo"></field>
          </order>
        </helper>
        
      </field>

      
            <field id="movher">
        <label>Movimiento </label>
        <help>Tipo de Movimiento de la Herramienta. </help>
        <tabla_ex id="CONCHERR">
          <field id="movher"></field>
          <field id="movnom"></field>
        </tabla_ex>
        
      </field>
            
      <field id="movfec">
        <label>Fecha Movimiento </label>
        <help>Fecha de Movimiento de la Herramienta. </help>
      </field>
      
      <field id="usuario" _noshow="true" autocompletar="true" oculto="true">
        <label>Usuario </label>
        <help>Usuario </help>
           	<ayuda_ex id="FSMOPERA" xml="HLPpersonal_ope.xml" dir="/help_local">
		      <!-- campos a agregar al contenedor Filtro-->
		        <field id="opecod">
		          <detalle>usuario</detalle>
		        </field>
		        <field id="nombres">
		            <expression>CONCAT(apellido,', ', Nombre)</expression>
		            <detalle>nombre</detalle>
		        </field>
        	</ayuda_ex>        
        <valor default="true">0</valor>
      </field>

	<field id="nombre" local="true" noshow="true" deshabilitado="true" noselect="true">
		<label>Nombre</label>
	</field>
      <order>
        <field id="movfec"></field>
      </order>
      
    </table>
    
  </form>
</histrix>
