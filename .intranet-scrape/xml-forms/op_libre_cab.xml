                  </field>					  -->
			<field id="concod" oculto="true">
				<label modpos="nobr">concod</label>
				<help/>
				<valor>4</valor>
			</field>
			<field id="movcta" oculto="true" ctbtipo="1">
				<label modpos="nobr">movcta</label>
				<help/>
				<valor>1</valor>
			</field>
			<field id="zoncod" oculto="true" >
				<label modpos="nobr">zoncod</label>
				<valor>0</valor>
			</field>

			<field deshabilitado="true" id="movnpv">
				<label modpos="nobr">Orden de Pago</label>
				<help>Comprobante</help>
				<format>%04d</format>
				<detalle>movnpv</detalle>				
			</field>
			<field id="siscaj" oculto="true">
				<label>siscaj</label>
				<parametro id="fsmparam_paralf.xml" retorna="paralf">
					<field id="parcla">
						<condicion operador="=">'siscaj'</condicion>
					</field>
				</parametro>
			</field>
			<field deshabilitado="true" id="movnroOP" local="true" ctbregnro="1">
				<label modpos="nobr">Numero</label>
				<help>Numero</help>
				<parametro id="cajparam_parent.xml" retorna="parent">
<!--					<field id="siscod" oculto="true">
						<condicion operador="=" valorde="siscaj"/>
							<tipo>varchar</tipo>
							<valor>'05'</valor>
					</field> -->
					<field id="parcla" oculto="true">
						<condicion operador="=">'nropag'</condicion>
					</field>
					<field id="parent">
						<complete>parent + 1</complete>
					</field>					
				</parametro>
				<tipo>integer</tipo>
				<format>%012d</format>
				<detalle>movnro</detalle>
				<detalle>cajnro</detalle>
				<detalle>carpag</detalle>
				<detalle>nrocom</detalle>
				<detalle>carrec</detalle>
				<detalle>referencia</detalle>

			</field>
			<field id="fpago" local="true" obj="op_libre_cajmovim_ing.xml">
				<label  colspan="4">forma de pago</label>
			</field>
			<field id="movref__1" ctbreferencia="1">
				<label modpos="nobr" colspan="3">Ref</label>
			</field>


			<field id="opecla" local="true" oculto="true">
				<label>Usuario</label>
				<valor eval="true">$_SESSION['usuario']</valor>
			</field>
