<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="cabecera" >
	<title>Orden de pago</title>
	<obs/>
	<form >
		<table id="CCTMOVIM" label="ORDEN DE PAGO">
			<field id="siscod" oculto="true">
				<label>Cod.</label>
				<help/>
				<valor>'01'</valor>
				<condicion operador="=">'01'</condicion>
			</field>

			<field id="sisctb"  oculto="true">
				<label>sisctb</label>
				<parametro id="fsmparam_paralf.xml" retorna="paralf">
					<field id="parcla">
						<condicion operador="=" >'sisctb'</condicion>
					</field>
				</parametro>
			</field>			
			<field id="ctbpro"   oculto="true" >
				<label>ctbdeu</label>
				<parametro id="ctbparam_paralf.xml" retorna="paralf">
					<field id="siscod" oculto="true">
						<condicion operador="=" valorde="sisctb"></condicion>
					</field>
					<field id="parcla">
						<condicion operador="=">'ctbpro'</condicion>
					</field>
				</parametro>
			</field>				
			<field id="movfec" ctbfecha="1">
				<label modpos="nobr">Fecha</label>
				<help/>
				<valor>today</valor>
				<detalle>cajfec</detalle>
				<detalle>movfec</detalle>				
			</field>
			<!--
                  <field id="ctadir" tabla="CCTCUENT">
