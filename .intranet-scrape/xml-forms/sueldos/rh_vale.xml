<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="ficha" sololectura="true" autoprint="true" PDFsincabecera="true" >
    <title>VALE</title>
    <obs/>
    <form>

       <pdf>
          <code><![CDATA[
            if ($lineCounter == 5){
                $pdf->AliasNbPages();
                $pdf->AddPage();
                $lineCounter=1;
                $pdf->SetXY(0,0);
                $pdf->maxY=0;
            }
            //else echo $lineCounter.'_';
            $pdf->SetDrawColor(0, 0, 0);
            $pdf->Line(150,$pdf->getY(),150,$pdf->getY() + 50);
            $pdf->RoundedRect(124,$pdf->getY() + 1,20,5, 2);
            $pdf->RoundedRect(5,$pdf->getY(),$pdf->anchoPagina ,50, 5);


            /*
            $pdf->RoundedRect(5,160,$pdf->anchoPagina,42, 5);
            $pdf->Line(5,167,$pdf->anchoPagina+5,167);
            $pdf->Line(5,174,$pdf->anchoPagina+5,174);

            $pdf->Line(5,181,$pdf->anchoPagina+5,181);
            $pdf->Line(5,188,$pdf->anchoPagina+5,188);
            $pdf->Line(5,195,$pdf->anchoPagina+5,195);
            $pdf->Line(($pdf->anchoPagina / 2)+5,160,($pdf->anchoPagina / 2)+5,202);
            */
          ]]></code>
      </pdf>

        <table id="RH_MOVIMIENTOS" >


            <campo id="fecha" >
                <label posx="120" posy="+1" PDFnolabel="true">Fecha</label>
                <valor>today</valor>
                <tipo>date</tipo>
            </campo>
            <campo id="id_movimiento" oculto="true">
            </campo>
            <campo id="legajo" print="false">
                <label posx="5" posy="0" PDFlabel="false">Leg.</label>
                <tipo>integer</tipo>
                <condicion operador="!=">0</condicion>
            </campo>
            <campo id="murabito" local="true">
                <label posx="5" posy="+9">Recibí de: Murabito María Carmen</label>
            </campo>
            <campo id="recibi" local="true">
                <expression>importe</expression>
                <label posx="5" posy="+1" >La suma de Pesos </label>
                <tipo aletras="true">decimal</tipo>
            </campo>
            <campo id="concepto" >
                <expression>nombre_concepto</expression>
                <label posx="5" posy="+1" >En concepto de </label>
            </campo>
            <campo id="concepto2" >
                <expression>nombre_concepto</expression>
                <label posx="150" posy="0" >Conc:</label>
            </campo>
            <campo id="quincena" >
                <expression>(case when DAYOFMONTH(fecha) > 15 then '2da Quincena del mes de ' else '1ra Quincena del mes de ' end)</expression>
                <label posx="5" posy="+1" >Correspondiente a la </label>
            </campo>
            <campo id="mes">
                <expression>MONTH(fecha)</expression>
                <label posx="75" posy="0" ></label>
                <options>
                    <option valor="1">Enero</option>
                    <option valor="2">Febrero</option>
                    <option valor="3">Marzo</option>
                    <option valor="4">Abril</option>
                    <option valor="5">Mayo</option>
                    <option valor="6">Junio</option>
                    <option valor="7">Julio</option>
                    <option valor="8">Agosto</option>
                    <option valor="9">Septiembre</option>
                    <option valor="10">Octubre</option>
                    <option valor="11">Noviembre</option>
                    <option valor="12">Diciembre</option>

                </options>
            </campo>
            <campo id="year">
                <label posx="90" posy="0"></label>
                <expression>CONCAT(' de ', YEAR(fecha), '.')</expression>
            </campo>




            <campo id="suma" >
                <expression>importe</expression>

                <label posx="150" posy="+12" size="12">Total</label>
                <tipo >decimal</tipo>

            </campo>
            <campo id="sum2" >
                <expression>importe</expression>

                <label posx="5" posy="0" size="12">Total: </label>
                <tipo >decimal</tipo>

            </campo>

            <campo id="nom">
                <expression>concat(PERSONAL.apellido, ', ', PERSONAL.nombre)</expression>
                <label posx="70" posy="0">Firma</label>
                <tipo>varchar</tipo>
            </campo>
        </table>
        <join tipo="left">
            <table id="PERSONAL">
                <campo id="legajo">
                    <condicion operador="=">RH_MOVIMIENTOS.legajo</condicion>
                </campo>
            </table>
        </join>
        <join tipo="left">
            <table id="RH_CONCEPTOS">
                <campo id="id_concepto">
                    <condicion operador="=">RH_MOVIMIENTOS.concepto_id</condicion>
                </campo>
            </table>
        </join>

    </form>
</histrix>
