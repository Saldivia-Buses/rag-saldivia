      <field id="comunes">
        <label>Hs.Com</label>
        <expression sql="true"><![CDATA[ 
                    select  SEC_TO_TIME(sum(FF.comun)) from 
               (select TIME_TO_SEC(TIMEDIFF(case when max(F1.hora) > JORNADA.salida  then JORNADA.salida else max(F1.hora) end, 
                                            case when min(F1.hora) < JORNADA.entrada then JORNADA.entrada else (min(F1.hora)) end )) as "Horas", 
                         (case when TIME_TO_SEC(JORNADA.comunes) > (TIME_TO_SEC(TIMEDIFF(case when max(F1.hora) > JORNADA.salida  then JORNADA.salida else max(F1.hora) end, 
                                            case when min(F1.hora) < JORNADA.entrada then JORNADA.entrada else (min(F1.hora)) end ))) then (TIME_TO_SEC(TIMEDIFF(case when max(F1.hora) > JORNADA.salida  then JORNADA.salida else max(F1.hora) end, 
                                            case when min(F1.hora) < JORNADA.entrada then JORNADA.entrada else (min(F1.hora)) end ))) else TIME_TO_SEC(JORNADA.comunes) end) as "comun"        
                                from FICHADAS as F1 left JOIN JORNADA on JORNADA.idJornada = [__idJornada__] and
                                                                 JORNADA.dia = DAYOFWEEK(F1.fecha)
        
                                                where F1.tarjeta = [__tarjeta__] and               
                                                              F1.fecha  >= '[__desde__]' and 
                                                  F1.fecha  <= '[__hasta__]' GROUP BY F1.fecha ) as FF  ]]></expression>
        <tipo>time</tipo>
      </field>          
      <field id="extras">
        <label>Hs.Ext</label>
        <expression sql="true"><![CDATA[ 
                    select  SEC_TO_TIME(sum(FF.comun)) from 
               (select TIME_TO_SEC(TIMEDIFF(case when max(F1.hora) > JORNADA.salida  then JORNADA.salida else max(F1.hora) end, 
                                            case when min(F1.hora) < JORNADA.entrada then JORNADA.entrada else (min(F1.hora)) end )) as "Horas", 
                         (case when TIME_TO_SEC(JORNADA.comunes) <= (TIME_TO_SEC(TIMEDIFF(case when max(F1.hora) > JORNADA.salida  then JORNADA.salida else max(F1.hora) end, 
                                            case when min(F1.hora) < JORNADA.entrada then JORNADA.entrada else (min(F1.hora)) end ))) then 
                         (-1) * ( TIME_TO_SEC(JORNADA.comunes) - TIME_TO_SEC(TIMEDIFF(case when max(F1.hora) > JORNADA.salida  then JORNADA.salida else max(F1.hora) end, 
                                            case when min(F1.hora) < JORNADA.entrada then JORNADA.entrada else (min(F1.hora)) end )) ) else (0) 
                         end) as "comun"        
                                from FICHADAS as F1 left JOIN JORNADA on JORNADA.idJornada = [__idJornada__] and
                                                                 JORNADA.dia = DAYOFWEEK(F1.fecha)
        
                                                where F1.tarjeta = [__tarjeta__] and               
                                                              F1.fecha  >= '[__desde__]' and 
                                                  F1.fecha  <= '[__hasta__]' GROUP BY F1.fecha ) as FF  ]]></expression>
        <tipo>time</tipo>
      </field>        
        
      <field id="Enfermedad">
        <label>Enfer.</label>
        <expression sql="true"><![CDATA[ 
        select 
          SEC_TO_TIME(sum((select sum(TIME_TO_SEC(JORNADA.comunes)) as "fechas" FROM GEN_CALENDAR 
               left JOIN JORNADA on JORNADA.idJornada = [__idJornada__] and 
                                      JORNADA.dia = DAYOFWEEK(GEN_CALENDAR.fecha)
               where 
                                        GEN_CALENDAR.fecha >= '[__desde__]' and 
                                        GEN_CALENDAR.fecha <= '[__hasta__]' and
                                        GEN_CALENDAR.fecha >= FRANCOS_PER.fechainicio and
                                        GEN_CALENDAR.fecha <= FRANCOS_PER.fechafin        
        
        
             ))) as lic  from 
           FRANCOS_PER where FRANCOS_PER.legajo = [__legajo__] 

             limit 1
        ]]></expression>
        <tipo>time</tipo>
      </field>
      <field id="fecha">
        <label>Fecha</label>
      </field>
      
      <field id="Hora" >
        <label>Hora</label>
        <tipo>varchar</tipo>
      </field> 
      <field id="Hora1">
        <expression>min(hora)</expression>
        <label>Hora Ent</label>
        <tipo>varchar</tipo>
      </field>

      <field id="Hora2">
        <expression>max(hora)</expression>
        <label>Hora Sal</label>
        <tipo>varchar</tipo>
      </field>
      <field id="Horas">
        <expression>TIMEDIFF(max(hora), min(hora))</expression>
        <label>Horas Trabajadas</label>
        <tipo>varchar</tipo>
        
      </field>
      
      <field id="reloj">
        <label>Reloj</label>
      </field>
      <field id="codigo">
        <label>Codigo</label>
      </field> -->
      <order>
        <field id="apellido"></field>
      </order>
      <group>
        <field id="legajo" />
        
      </group> 
    </table>

    
    <join tipo="left">      
      <table id="CATPERSONAL">
        <field id="idSindicato">
          <condicion operador="=">PERSONAL.idSindicato</condicion>
        </field>
        <field id="idCateg">
          <condicion operador="=">PERSONAL.idCateg</condicion>
        </field>
      </table>
    </join>
    <join tipo="left">      
      <table id="FAMILIA">
        <field id="idPersona">
          <condicion operador="=">PERSONAL.idPersona</condicion>
        </field>
      </table>
    </join>
  </form>
</histrix>
