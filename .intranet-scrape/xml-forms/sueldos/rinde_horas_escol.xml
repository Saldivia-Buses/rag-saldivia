<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" class="consultaing2" barraDrag="false">
  <title>Rendicion de Horas</title>
  <obs/>
  <form >
    
      <table id="PERSONAL" label="Rendición de Horas" >

      <filters>

        <field id="IdSindicato" >
          <label>Sindicato</label>
          <operador>=</operador>
        </field>

        <field id="desde" local="true">
          <label>Desde</label>
          <tipo>date</tipo>
          <valor>today</valor>
          <operador>&gt;=</operador>
        </field>            

        <field id="hasta" local="true">
          <label>Hasta</label>
          <tipo>date</tipo>
          <valor>today</valor>
          <operador>&lt;=</operador>
        </field>            
        
      </filters>

      <field id="desde" local="true"  noshow="true">
        <label>Desde</label>
        <tipo>date</tipo>
      </field>            
      <field id="hasta" local="true"  noshow="true">
        <label>Hasta</label>
        <tipo>date</tipo>
      </field>            

      <field id="fechaEgreso" oculto="true">
        <label>Egreso</label>
        <tipo>date</tipo>
        <condicion operador="=">'0000-00-00'</condicion>
      </field>            
              
      <field id="IdSindicato">
        <label>Sindicato</label>
        <help>Código de Sindicato</help>
          <helper type="combo" id="SINDICATO">
            <field id="IdSindicato"></field>
            <field id="Nombre"></field>
            <order>
                <field id="IdSindicato"></field>
            </order>
          </helper>
        <detalle>IdSindicato</detalle>  
      </field>

      <field id="nom">
        <expression>concat(PERSONAL.apellido, ', ', PERSONAL.nombre)</expression>
        <label>Apellido</label>
        <tipo>varchar</tipo>
      </field>            
<!--      <field id="nombre">
        <label>Nombre</label>
        <tipo>varchar</tipo>
      </field> -->
      <field id="tarjeta" noshow="true">
        <label>Tarjeta</label>
      </field>        
      <field id="idJornada" noshow="true">
        <label>Jornada</label>
      <!--  <tabla_ex id="JORNADAS">
          <field id="idJornada"></field>
          <field id="nombre"></field>
          
        </tabla_ex> -->
      </field>          
      <field id="legajo">
        <label>Legajo</label>
        <tipo>integer</tipo>
      </field>
      <field id="fecing">
        <label>Ingreso</label>
        <tipo>date</tipo>
      </field>
      <field id="CUIL">
        <label>CUIL</label>
        <tipo>integer</tipo>
      </field>
      <field id="descripcion" _tabla="CATPERSONAL">
        <label>Categ.</label>
        <expression><![CDATA[(select descripcion from CATEGHISTORIA 
                                     left join CATPERSONAL 
                                     on CATPERSONAL.IdSindicato = CATEGHISTORIA.idSindicato 
                                     and CATPERSONAL.IdCateg = CATEGHISTORIA.IdCateg 
                                     where CATEGHISTORIA.IdPersona = PERSONAL.IdPersona 
and  CATEGHISTORIA.fechaDesde <= CONCAT(RIGHT(REPLACE('[__hasta__]', '/', ''), 4), SUBSTRING(REPLACE('[__hasta__]', '/', ''), 3, 2), LEFT(REPLACE('[__hasta__]', '/', ''), 2)) 
order by CATEGHISTORIA.fechaDesde desc limit 1)]]>
              </expression>
        <tipo>varchar</tipo>
        
      </field>

      <field id="tipoliq" >
      <!--    <expression>select tipoliq FROM CONCEPCONV inner join CONVENIOS on CONVENIOS.idSindicato= CONCEPCONV.IdSindicato  where CONCEPCONV.IdSindicato = PERSONAL.IdSindicato and CONCEPCONV.IdCateg = PERSONAL.IdCateg and CONVENIOS.fechaHasta >= CURDATE() limit 1</expression> -->
        <expression>select tipoliq FROM CONCEPCONV inner join CONVENIOS on CONVENIOS.idSindicato= CONCEPCONV.IdSindicato  where CONCEPCONV.IdSindicato = PERSONAL.IdSindicato and CONCEPCONV.IdCateg = PERSONAL.IdCateg limit 1</expression>
            
        <tabla_ex id="CONCEPLIQU">
          <field id="tipoLiq"/>
          <field id="Nombre"/>
        </tabla_ex> 
        <label>Tipo Liq.</label>
        <tipo>varchar</tipo>
      </field>
      
<!--       <field id="asignacion" tabla="FAMILIA">
        <expression>sum(asignacion)</expression>
        <label>Asig.</label>
        <tipo>integer</tipo>
      </field>-->
      <field id="ayudaescolar" tabla="FAMILIA">
        <expression>sum(ayudaescolar)</expression>
        <label>Escol.</label>
        <tipo>integer</tipo>
      </field>
      <field id="val">
          <label>importe</label>
          <expression>select importe FROM CONCEPCONV inner join CONVENIOS on CONVENIOS.idSindicato= CONCEPCONV.IdSindicato  where CONCEPCONV.IdSindicato = PERSONAL.IdSindicato and CONCEPCONV.IdCateg = PERSONAL.IdCateg  limit 1</expression>
      </field>
