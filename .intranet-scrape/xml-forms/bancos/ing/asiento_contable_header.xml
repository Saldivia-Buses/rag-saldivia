<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="fichaing" class="consultaancha" marginTabs="true" inserta="false" modifica="false" tooltip="false" importTempTable="TEMPTABLENAME" llenoTemporal="TEMPTABLENAME"
updateTempTable="false">
  <title>Asiento Contable</title>
  <obs/>
  <form>
    <table id="CTB_MOVIMIENTOS" label="Minuta">
      
      <movimientos>
            <relacion id="ctbmovimiento_ins.xml"/> 
      </movimientos>

      <!--
      <validation>
        <condition><![CDATA[diferencia + 0 != 0]]></condition>
        <message>Asiento Desbalanceado</message>
      </validation>
      -->
      
      <field id="nro_minuta" noshow="true" />

      <field id="fecha_movimiento" deshabilitado="true">
        <label modpos="nobr" colspan="4">Fecha</label>
      </field>

	  <field id="ejercicio_id" _noshow="true" local="true" _deshabilitado="true">
        <helper type="combo" xml="ctbejercicio_qry.xml" dir="/ayudas">	  	
        	<field id="cerrado">
        		<condicion operador="!=">1</condicion>
       		</field>
        </helper>
        <label colspan="4">Ejercicio</label>
        <detalle>ejercicio_id</detalle>
      </field>

      <field id="concepto_id">
        <helper type="combo" xml="ctbconcepto_qry.xml" dir="/ayudas" />
        <label colspan="4">Concepto</label>
        <help>Código de concepto</help>
        <detalle>concepto_id</detalle>
      </field>

      <field id="referencia" valauto="true">
        <label>Referencia</label>
      </field>

      <field id="fecha_modificacion" noshow="true">
        <expresion>NOW()</expresion>
      </field>

      <field id="usuario_modificacion" noshow="true">
        <valor eval="true">$_SESSION['usuario']</valor>
      </field>
      
      <field id="detalle" local="true">
        <label colspan="4"/>
        <helper type="object" xml="asiento_contable_crud.xml" />
      </field>
      
      <field id="difasiento" deshabilitado="true" local="true">
          <label style="font-size: 16px; color: red;">Diferencia</label>
          <!--
          _validar="true" 
          <if exp="difasiento + 0 == 0">
            <true>1</true>
            <false>0</false>
          </if>
          <valor>0</valor>
          -->
      </field>


    </table>
  </form>
</histrix>
