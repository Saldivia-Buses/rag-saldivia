<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="ing"  imprime="false" procesa="false" showCantidad="false" tooltip="false" llenoTemporal="TEMPTABLENAME" importTempTable="TEMPTABLENAME" exportasuma="true" llenareferente="true">
  <title>Movimientos</title>
  <obs/>
  <form>
    <table id="CTB_DETALLES" label="cabecera" idCampoCond="grabar">

      <movimientos>
        <relacion id="ctbdetalle_ins.xml"/>
      </movimientos>

      <field id="grabar" local="true" noshow="true">
        <if exp="debe != 0 || haber != 0">
          <true>1</true>
          <false>0</false>
        </if>
      </field>

      <field id="cuenta_id">
        <label modpos="nobr">Cuenta</label>
        <helper type="combo" xml="cuentas_habilitadas_qry.xml" dir="/ayudas" />
      </field>
     
      <field id="debe" suma="true" noZero="true" local="true" retroalimenta="true">
        <label modpos="nobr">Debe</label>
        <tipo>numeric</tipo>
      </field>

      <field id="haber" suma="true" noZero="true" local="true" retroalimenta="true">
        <label modpos="nobr">Haber</label>
        <tipo>numeric</tipo>
      </field>



      <field id="doh" local="true" _noshow="true">
        <if exp="debe + 0 &gt; 0 ">
          <true>'0'</true>
          <false>'1'</false>
        </if>
      </field>

      <field id="importe" noshow="true">
        <if exp="debe + 0 &gt; 0 ">
          <true>debe</true>
          <false>haber</false>
        </if>
      </field>

      <field id="_ORDEN" local="true" esClave="true" deshabilitado="true" noshow="true">
        <label>Orden</label>
      </field>

	  <!-- Campos de Validación -->
	  
      <field id="valid" validRow="true" noshow="true">
        <if exp="debe + haber">
          <true>1</true>
          <false>0</false>
        </if>
      </field>
      
      <field id="balancea" _noshow="true" deshabilitado="true" local="true" suma="true" acumula="true">
      	<label colstyle="display:none;" Formstyle="display:none;">balancea</label>
        <if exp="true">
          <true>debe - haber</true>
          <false>0</false>
        </if>
        <tipo>numeric</tipo>
        <jseval campodestino="difasiento" total="true">balancea</jseval>
        <detalle>difasiento</detalle>
      </field>
      
    </table>
  </form>
</histrix>
