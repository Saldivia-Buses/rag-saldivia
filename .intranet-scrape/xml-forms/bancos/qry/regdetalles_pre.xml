<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta">
    <title>Movimientos</title>
    <obs/>
    <form>
        <table id="REG_MOVIMIENTOS" label="Resumen Cta Cte">

            <field id="id_regmovim"    noshow="true" />

            <field id="subsistema_id"  noshow="true" />

            <field id="regcuenta_id"   noshow="true" />

            <field id="cajmovimiento_id" noshow="true" />

            <field id="nombre" local="true" print="false" noshow="true">
                <expresion>''</expresion>
            </field>

            <field id="desde" noshow="true" local="true" />

            <field id="hasta" noshow="true" local="true" />

            <field id="arrastrasaldo" noshow="true" local="true" validRow="true">
                <condicion operador="=">1</condicion>
            </field>

            <field id="tipofecha" noshow="true" local="true"/>

            <field id="fecha_preconsulta">
                <expresion>fecha_movimiento</expresion>
            </field>

            <field id="filfec" having="false" noshow="true">
                <label>filtrofecha</label>
                <expresion>1</expresion>
                <condicion operador="=">1 AND
                        (('[__tipofecha__]' = '0' AND REG_MOVIMIENTOS.fecha_movimiento &lt; '[__desde__]' ) OR
                         ('[__tipofecha__]' = '1' AND REG_MOVIMIENTOS.conciliado &lt; '[__desde__]') AND IFNULL(REG_MOVIMIENTOS.conciliado, '0000-00-00') != '0000-00-00' OR
                         ('[__tipofecha__]' = '2' AND REG_MOVIMIENTOS.vencimiento_movimiento &lt; '[__desde__]'))</condicion>
            </field>

            <field id="abreviacion_concepto" tabla="REG_CONCEPTOS">
                <label>Comp</label>
                <expresion>''</expresion>
            </field>

            <field id="comprobante">
                <label>Comprobante</label>
                <expresion>'SALDO ANTERIOR'</expresion>
            </field>

            <field id="vencimiento_movimiento">
                <label>Acreditacion</label>
                <expresion>''</expresion>
            </field>

            <field id="cuota_movimiento">
                <label>Cuotas</label>
                <expresion>''</expresion>
            </field>

            <field id="imputacion_concepto" tabla="REG_CONCEPTOS" noshow="true" />

            <field id="importe_movimiento" noshow="true" />

            <field id="debe" suma="true" noZero="true">
                <label>debe</label>
                <expresion>SUM(CASE WHEN REG_CONCEPTOS.imputacion_concepto = 0 THEN REG_MOVIMIENTOS.importe_movimiento ELSE 0 END)</expresion>
                <tipo>custom_numeric</tipo>
            </field>

            <field id="haber" suma="true" noZero="true">
                <label>Haber</label>
                <expresion>SUM(CASE WHEN REG_CONCEPTOS.imputacion_concepto = 1 THEN REG_MOVIMIENTOS.importe_movimiento ELSE 0 END)</expresion>
                <tipo>custom_numeric</tipo>
            </field>

            <field id="saldo" local="true" suma="true" acumula="true">
                <label>saldo</label>
                <expresion>SUM(CASE WHEN REG_CONCEPTOS.imputacion_concepto = 0 THEN REG_MOVIMIENTOS.importe_movimiento ELSE (REG_MOVIMIENTOS.importe_movimiento * -1) END)</expresion>
                <tipo>custom_numeric</tipo>
            </field>

            <order>
                <field id="fecha_movimiento" noshow="true"/>
                <field id="vencimiento_movimiento" noshow="true"/>
            </order>

        </table>

        <join>
            <table id="REG_CONCEPTOS">
                <field id="id_concepto">
                    <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
                </field>
                <field id="subsistema_id">
                    <condicion operador="=">REG_MOVIMIENTOS.subsistema_id</condicion>
                </field>
            </table>
        </join>

        <join>
            <table id="REG_CUENTA">
                <field id="id_regcuenta">
                    <condicion operador="=">regcuenta_id</condicion>
                </field>
            </table>
        </join>

    </form>
</histrix>