<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta">
	<form >
	<title>CONSULTA DE FICHA DE VENTAS</title>
	<!-- <form  detalle="fichaventas.xml"> -->
		<table id="PEDCOTIZ" label="Ficha de Ventas">
			
			<field id="nrocha" esClave="true" tipoOrden="DESC" linkint="fichaventas.xml" linkdes="Ver Ficha de Ventas">
				<label>Nro Fab</label>
				<help>Numero de Fabricacion</help>

				<paring destino="nrocha">nrocha</paring>
			</field>
			<field id="ctacod">
				<label PDFsize="12" posx="6" posy="+1" size="23">Cliente</label>
				<help>Codigo de Cuenta</help>
				<tabla_ex condes="true" id="CCTCUENT">
					<field id="ctacod"/>
					<field id="ctafan"/>
					<field id="siscod" oculto="true">
						<condicion operador="=">'02'</condicion>
					</field>
				</tabla_ex>
			</field>
			<field id="nrocar">
				<label size="23" posx="110" posy="0" PDFsize="10">Carroceria</label>
				<help></help>
				<tabla_ex xml="carroceria.xml">
					<field id="siscod" oculto="true">
						<condicion operador="=">'03'</condicion>
					</field>
				</tabla_ex>
			</field>			
			<field id="marcod" tabla="CHASIS">
				<label PDFsize="10" posx="6" posy="+2" size="23">Chasis Marca</label>
				<help/>
				<tabla_ex xml="marchasis.xml">
					<field id="siscod" oculto="true">
						<condicion operador="=">'03'</condicion>
					</field>				
				</tabla_ex>
				<tipo>integer</tipo>
			</field>
			<field id="moddes" tabla="MODCHASIS" >
				<label size="23" posx="60" posy="0" modpos="nobr" PDFsize="10">Modelo</label>
				<help></help>
				<tipo>varchar</tipo>
			</field>			
			<field id="revfec"  deshabilitado="true">
				<label style="color:red;font-size:16px;">Ultima Modificación</label>
				<help>Fecha de Pedido</help>
			</field>				
			<field id="obsesp"></field> 
			<!--			
			<field id="modcod" tabla="CHASIS">
				<label PDFsize="10" modpos="nobr" posx="60" posy="0" size="23">Modelo</label>
				<help/>
				<tabla_ex id="MODCHASIS">
					<field clave="true" id="modcha">
						<label>Modelo</label>
						<help>Codigo del Modelo de Chasis</help>
					</field>
					<field id="moddes">
						<label>Descripcion</label>
						<help>Descripcion del Modelo</help>
					</field>
					<field id="marcod">
						<label>Marca Chasis</label>
					</field>
				</tabla_ex>
			</field> -->
		<!--	<field id="pedfec">
				<label>fecha</label>
				<help>fecha</help>
			</field> -->
			<!-- <field id="chasis">
                      <label>Nro.Chasis </label>
                      <help>Nro de serie del Chasis </help>
                  </field>
 -->
			<order>
				<field id="nrocha" tabla="PEDCOTIZ"/>
			</order>
		</table>
		<join tipo="left">
			<table id="CHASIS">
				<field id="nrocha">
					<condicion operador="=">PEDCOTIZ.nrocha</condicion>
				</field>
			</table>
		</join>
		<join tipo="left">
			<table id="MODCHASIS">
					<field clave="true" id="modcha">
						<condicion operador="=">CHASIS.modcod</condicion>

					</field>
					<field id="marcod">
						<condicion operador="=">CHASIS.marcod</condicion>
					</field>			
			</table>
		</join>			
	</form>
</histrix>
