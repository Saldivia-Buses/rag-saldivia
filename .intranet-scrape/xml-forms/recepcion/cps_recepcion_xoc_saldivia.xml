<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="fichaing" inserta="false" modifica="false" imprime="false" _transaccional="true" log="false">
	<title>Recepcion de Compras</title>
	<obs></obs>
	<form >

		<table id="CPSENCAB" label="Recepción de Compras" >

			<movimientos>
				<relacion id="cps_movimientos_recepcion.xml" />       
				<relacion id="cpsencab_rec_ingmov2.xml"></relacion>
			</movimientos>

			<validation>
				<condition >
					<![CDATA[remnro + 0 == 0]]>
				</condition>
				<message>Numero de Remito en cero</message>
			</validation>

			<field id="ocpnro"  _deshabilitado="true">
				<ayuda_ex id="CPSENCAB">
					<field id="ocpnro" />

					<field id="ocprnro2">
						<expression>ocpnro</expression>
					</field>

					<field id="ctacod">
						<label>Prov</label>
						<detalle>ctacod</detalle>
					</field>
					<field id="ocpfec">
						<expression>date_format(ocpfec, "%d/%m/%Y")</expression>
						<label>Fecha</label>
						<detalle>ocpfec</detalle>
						<detalle>movfec</detalle>
						<tipo>date</tipo>
					</field><!--
					<field id="remnro" noshow="true">
						<expression>
							SELECT remnro FROM FACREMIT WHERE ctacod = CPSENCAB.ctacod ORDER BY remfec DESC, remnro DESC LIMIT 1
						</expression>
						<detalle>remnro</detalle>
						<label>NRem</label>
					</field>
					<field id="remnpv" noshow="true">
						<expression>
							SELECT remnpv FROM FACREMIT WHERE ctacod = CPSENCAB.ctacod ORDER BY remfec DESC, remnro DESC LIMIT 1
						</expression>
						<detalle>remnpv</detalle>
						<label>Nnpv</label>
					</field>      -->                   
					<field id="remfec" noshow="true">
						<expression>
							SELECT date_format(remfec, "%d/%m/%Y") FROM FACREMIT WHERE ctacod = CPSENCAB.ctacod ORDER BY remfec DESC LIMIT 1
						</expression>
						<detalle>remfec</detalle>
						<label>RemFec</label>
					</field>
					<field id="ocpest" noshow="true">
						<detalle>ocpest</detalle>
					</field>
					<field id="ocpobs" noshow="true">
						<detalle>ocpobs</detalle>
					</field>
					<field id="paramoc" noshow="true">
					    <expression>case when ocpest = 0 or ocpest = 2 or ocpest = 4 then 0 else ocpnro end</expression>
					    <detalle>paramoc</detalle>
					</field>
				</ayuda_ex>
				<label _modpos="nobr">O.Compra</label>
				<help>Numero de Orden de Compra</help>
			</field>

			<field id="ocpfec"  deshabilitado="true">
				<label modpos="nobr">Fecha O.C.</label>
				<help>Fecha O.C.</help>
			</field>

			<field id="ocpest" deshabilitado="true" sincelda="true">
				<label modpos="nobr">Estado O.C.</label>
		        <options>
		          <option valor=""></option>
		          <option valor="0">No Autorizada</option>
		          <option valor="1">Pendiente</option>
		          <option valor="2">Cumplida</option>
		          <option valor="3">Parcial</option>
		          <option valor="4">Anulada</option>
		        </options>
			</field>

                        <field id="paramoc" local="true" noshow="true">
                            <actualiza>
                                <field id="materiales" destino="ocpnro" />
                            </actualiza>
                        </field>

			<field id="ctacod" _oculto="true" public="true">
				<label>Proveedor</label>
				<ayuda_ex id="CCTCUENT" _xml="HLPcctcuent.xml">
					<field id="ctacod">
						<label>Nro</label>
					</field>
					<field id="nombre">
						<expression>ctanom</expression>
						<label>Nombre</label>
						<detalle>ctanom</detalle>
						<tipo>varchar</tipo>
					</field>
					<field id="siscod" oculto="true">
						<label>siscod</label>
						<condicion operador="=">'01'</condicion>
					</field>
					<clave>ctacod</clave>
					<descripcion>nombre</descripcion>
				</ayuda_ex>
				<help>Codigo de Cuenta</help>
			</field>

			<field id="ctanom" local="true" deshabilitado="true" _sincelda="true">
				<label modpos="nobr" colspan="8"></label>
				<help>Nombre del proveedor</help>
				<size>30</size>
			</field>

			<field id="dos" local="true" oculto="true">
				<valor>2</valor>
			</field>
			<field id="remfec" local="true">
				<label >Fecha Remito</label>
				<help>Fecha de Remito</help>
				<valor>today</valor>
				<tipo>date</tipo>
			</field>
			<field id="remnpv" local="true" required="true">
				<label modpos="nobr">Remito</label>
				<help>Punto de Venta</help>
				<!--<format>%04d</format>-->
<!--				<valor default="true">0</valor>-->
			</field>
			<field id="remnro" min="1" local="true" sincelda="true" required="true">
				<label modpos="nobr">-</label>
				<help>Numero de Remito</help>
				<detalle>movnro</detalle>
				<!--<format>%010d</format>-->
<!--				<valor default="true">0</valor> -->
			</field>
			<field id="movfec__1" local="true">
				<label>Fecha Recepcion</label>
				<help>Fecha de Recepcion</help>
				<tipo>date</tipo>
				<valor>today</valor>
			</field>
			<field id="ocpobs" sincelda="true" deshabilitado="true">
				<label modpos="nobr" />
				<size>100</size>
			</field>
			<field id="forzarCump" local="true" _refresh="true">
				<label modpos="nobr">Marcar Como Cumplida</label>
				<valor>0</valor>
				<tipo>check</tipo>
			</field>
   <!--
			<field id="pedidos" local="true"  showObjTabla="true">
				<helper type="object" xml="cpsmovim_pedidos_noTabs.xml">
					<parameter source="ocpnro" target="ocpnro" />
				</helper>
                <label _colspan="4">Pedidos  </label>
            </field>
-->        

			<field id="materiales" showObjTabla="true" local="true">
				<helper type="object" xml="cps_detalle_grid_xoc_rec.xml">
<!--						<parameter source="ocpnro" target="ocpnro" />
						<parameter source="ctacod" target="ctacod" />				-->						
				</helper>
				<label colspan="6">recepción</label>
			</field>

			<field id="cerrar" local="true" noshow="true">
				<label>Cerrar</label>
				<valor>1</valor>
			</field>

			<field id="cumplida" local="true" noshow="true" editable="true" >
				<if exp="cerrar == 0 || 'forzarCump' == '1'">
					<true>1</true>
					<false>0</false>
				</if>
			</field>

		</table>

	</form>
</histrix>