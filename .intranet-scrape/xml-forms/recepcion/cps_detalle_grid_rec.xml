        <field id="marcar" local="true" editable="true" style="color:green;">
            <tipo>check</tipo>
<!--	    <attribute id="deshabilitado">habilita_inspec</attribute> -->
        
            <jseval campodestino="ingresan">(( marcar == 1)? pencps : 0 )</jseval>
            <jseval campodestino="pencps" >pen_cpsori - (ingresan + 0)</jseval>  
        
            <jseval campodestino="cierre">(mov_pen2 + (ingresan + 0) &gt;= movcps)?0:1</jseval>

            <jseval campodestino="emitir">(( (ingresan + 0) != 0  )? 1 : 0 )</jseval>

            <jseval campodestino="Unidades" actxml="false">(valcps == 1)?((ingresan + 0) * valuso):((ingresan + 0) / ((valcps == 0)?1:valcps))</jseval>
            <jseval campodestino="coddem" actxml="false">(((straFecha( $(\'[name=movfec__1]\').val() ) - straFecha(\'ped\') ) / (1000 * 60 * 60 * 24)) &gt;= 15)? 110 : ((((straFecha( $(\'[name=movfec__1]\').val() ) - straFecha(\'ped\') ) / (1000 * 60 * 60 * 24)) &gt;= 3)? 110 : certificados ) </jseval>
        
        </field>


            
        <field id="ingresan" local="true" preventLoop="true" editable="true" style="color:red; border:1px solid #bbb; padding:2px;" _suma="true">
            <label modpos="nobr" default="true">Ingresan</label>
	    <attribute id="deshabilitado">habilita_inspec</attribute>
            <help>Cantidad ingresada</help>
            <jseval campodestino="Unidades" actxml="false">(valcps == 1)?((ingresan + 0) * valuso):((ingresan + 0) / ((valcps == 0)?1:valcps))</jseval>
            <jseval campodestino="coddem" actxml="false">(((straFecha( $(\'[name=movfec__1]\').val() ) - straFecha(\'ped\') ) / (1000 * 60 * 60 * 24)) &gt;= 15)? 110 : ((((straFecha( $(\'[name=movfec__1]\').val() ) - straFecha(\'ped\') ) / (1000 * 60 * 60 * 24)) &gt;= 3)? 110 :  certificados ) </jseval> 

            <jseval campodestino="cierre">(mov_pen2 + (ingresan + 0) &gt;= movcps)?0:1</jseval>

            <jseval campodestino="pencps" actxml="false">pen_cpsori - (ingresan + 0)</jseval>
            
            <jseval campodestino="emitir">(( (ingresan + 0) != 0)? 1 : 0 )</jseval>
            
            
                    <tipo>custom_numeric</tipo>
            
            </field>



       <!-- tengo que agregar este campo para que el calculo no se haga sobre si mismo todo el tiempo -->
            
            <field id="pencps" deshabilitado="true" editable="true" tabla="CPSMOVIM" style="width:4em;text-align:center;">
