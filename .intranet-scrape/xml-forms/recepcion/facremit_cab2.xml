<?xml version="1.0" encoding="ISO-8859-1"?>
<histrix tipo="cabecera" _graba="true">
	<title>REMITO</title>
	<obs></obs>
	<form >
		
		<table id="FACREMIT" label="REMITO" _graba="true">

			<field id="ctacod" _oculto="true">
				<label>Proveedor</label>
				<ayuda_ex id="CCTCUENT" _xml="HLPcctcuent.xml" dir="/help_local">
					<field id="ctacod">
						<label>Nro</label>
					</field>
					<field id="nombre">
						<expression>ctanom</expression>
						<label>Nombre</label>						
						<detalle>ctanom</detalle>	
						<tipo>varchar</tipo>					
					</field>
					<field id="siscod" oculto="true">
						<label>siscod</label>
						<condicion operador="=">'01'</condicion>
					</field>					
					<clave>ctacod</clave>
					<descripcion>nombre</descripcion>
					
				</ayuda_ex>		

								
				<help>Codigo de Cuenta</help>
			</field>
			
			<field id="ctanom" local="true" deshabilitado="true" sincelda="true">
				<label modpos="nobr"></label>
				<help>Nombre del proveedor</help>
			</field>
			<field id="ocpnro"  deshabilitado="true">
				<label modpos="nobr">O.Compra</label>
				<help>Numero de Orden de Compra</help>
			</field>
			
			<field id="ocpfec"  deshabilitado="true">
				<label modpos="nobr">Fecha O.C</label>
				<help>Fecha O.C.</help>
			</field>
			<!--
			<field id="dos" local="true" oculto="true">
				<valor>2</valor>
			</field>
			-->				
			<field id="remfec">
				<label >Fecha Remito</label>
				<help>Fecha de Remito</help>
<!--				<valor>today</valor>-->
			</field>			
			<field id="remnpv">
				<label modpos="nobr">Npv</label>
				<help>Punto de Venta</help>
				<format>%04d</format>
			</field>
			<field id="remnro" min="1">
				<label modpos="nobr">Numero</label>
				<help>Numero de Remito</help>
				<detalle>movnro</detalle>
				<format>%010d</format> 
			</field>
			<field id="movfec__1">
				<label>Fecha Recepcion</label>
				<help>Fecha de Recepcion</help>
				<tipo>date</tipo>
				<valor>today</valor>				
			</field>
			<!--		
			<field id="forzarCump" local="true" _refresh="true">
				<label modpos="nobr">Marcar Como Cumplida</label>

				<tipo>check</tipo>              	 
			</field>		
		-->
		</table>

	</form>
</histrix>
