<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" PDForientacion="L" preloadData="false">
  <title>ORDENES DE COMPRA</title>
  <obs></obs>
  <form  _detalle="cpsmovim.xml" _inline="true">
    <table id="OCPRECIB" label="ORDENES DE COMPRA">
      <field id="siscod" oculto="true">
        <label>Codigo Sistema</label>
        <help></help>
        <detalle>siscod</detalle>
      </field>
      <field id="ocpnro2" tipoOrden="DESC" noshow="true">
        <expression>OCPRECIB.ocpnro</expression>
      </field>
      
      <field id="ocpnro" linkint="cpsencab_cabreimp.xml"  linkdir="/compras" linkdes="Orden de Compra">
        <paring destino="ocpnro">ocpnro</paring>
        <label>O.Compra</label>
        <help>Numero de Orden de Compra. </help>
        <detalle>ocpnro</detalle>
      </field>
      <field id="nrocha" tabla="CPSMOVIM">
        <label>Nro</label>
        <tipo>integer</tipo>
      </field>
      
      <field id="ocpfec">
        <label _modpos="nobr">Emisión</label>
        <help>Fecha de Emisión</help>
        <detalle>ocpfec</detalle>
        <detalle>movfec</detalle>
      </field>
      
      <field id="ctacod">
        <label>Proveedor</label>
        <help>Codigo de Cuenta PROVEEDOR. </help>
        <ayuda_ex id="CCTCUENT">
          
          <field id="ctacod" clave="true" muestra="false"></field>
          <field id="ctafan"></field>
          <field id="siscod" oculto="true">
            <condicion operador="=">'01'</condicion>
          </field>
          <field id="baja">
            <condicion operador="!=">1</condicion>
          </field>
          <order>
            <field id="ctanom"></field>
          </order>
        </ayuda_ex>
        <tipo>integer</tipo>
        </field>
        
      <field id="ctanom" tabla="CCTCUENT">
      <tipo>varchar</tipo>
        <label>Nombre</label>
      </field>

              
      <field id="codest">
        <label _modpos="nobr">Estado</label>
        <help>Estado Actual</help>
       <tabla_ex id="ESTADOBS">
                    <field id="codest" clave="true"></field>
                    <field id="nomest"></field>
                </tabla_ex>
	<condicion operador="=">3</condicion>
      </field>

      <field id="artcod" deshabilitado="true"  esClave="true">
        <label>Art.</label>
        <help>Codigo de Articulo</help>
        <tipo>varchar</tipo>
      </field>
      
   
      <field id="observacion">
        <label modpos="nobr">Observaciones</label>
        <tipo>varchar</tipo>
      </field>
      
      <field id="fecreq" tabla="CPSMOVIM">
        <label _modpos="nobr">Requerido</label>
        <tipo>date</tipo>
      </field>      
      <field id="movcps" deshabilitado="true" tabla="CPSMOVIM">
        <label>Pedido</label>
        <help>Pedido (expresado en la unidad de compra)</help>
        
      </field>
    
      <field id="movcps" deshabilitado="true" tabla="CPSMOVIM">
        <expression>round(movcps, 2)</expression>
        <label>Ped.cps</label>
        <help>Pedido (expresado en la unidad de compra)</help>
        <tipo>decimal</tipo>
        

      </field>
      <field id="mov_pen2" deshabilitado="true" >
        <expression>round(movcps - pencps ,  2)</expression>
        <label>Rec</label>
        <help>Recibido (expresado en la unidad de compra)</help>
        <tipo>decimal</tipo>
      </field>
      <field id="pencps" tabla="CPSMOVIM">
        <label>Pend.cps</label>
        <help>Pendiente (expresado en la unidad de compra)</help>
        <!--<expression>ROUND(pencps, 2)</expression>-->
        <!--<condicion operador="&gt;">0</condicion> -->
        <tipo>decimal</tipo>
        
      </field>
      <field id="artuni_exp3" deshabilitado="true">
        <expression>STKINSUM.unicps</expression>
        <label>U.Cps</label>
        <help>Unidad de Compra</help>
        <tabla_ex id="FSMUNIDS">

          <field id="unicod" clave="true"></field>
          <field id="uniabv"></field>
        </tabla_ex>
        <tipo>varchar</tipo>
      </field>            
      <field id="baja" tabla="CCTCUENT" noshow="true">
            <condicion operador="=">0</condicion>
          </field>
              
     
      <order>
        <field id="ocpnro2"/>        
      </order>
      
      <filters>
        
               <field id="ctacod">
         <operador>=</operador>
         <label>Proveedor</label>
        
          </field>
        
        <field id="ocpfec">
          <operador>&gt;=</operador>
          <label>Desde Fecha</label>
            <valor eval="true">date("d/m/Y", mktime(0, 0, 0, date("m")-1 ,
            date("d"), date("Y")))
                    </valor>
        </field>
        <field id="ocpfec">
          <operador>&lt;=</operador>
          <label modpos="nobr">Hasta Fecha</label>
          <valor>today</valor>
        </field>
            
       
     
        
      </filters>
      
    </table>
    <join tipo="left">
      <table id="CCTCUENT">
        <field id="siscod" oculto="true">
          <condicion operador="=">'01'</condicion>
        </field>
        <field id="ctacod" oculto="true">
          <condicion operador="=">OCPRECIB.ctacod</condicion>
        </field>
        

        
      </table>
    </join>
    
    <join tipo="left">
      <table id="CPSMOVIM">
        <field id="siscod" oculto="true">
          <condicion operador="=">OCPRECIB.siscod</condicion>
        </field>
        <field id="ocpnro" oculto="true">
          <condicion operador="=">OCPRECIB.ocpnro</condicion>
        </field>
        <field id="movfec" oculto="true">
          <condicion operador="=">OCPRECIB.ocpfec</condicion>
        </field>
     
        
      </table>
    </join>
     <join tipo="left">
      <table id="CPSENCAB">
        <field id="siscod" oculto="true">
          <condicion operador="=">OCPRECIB.siscod</condicion>
        </field>
        <field id="ocpnro" oculto="true">
          <condicion operador="=">OCPRECIB.ocpnro</condicion>
        </field>
        <field id="ocpfec" oculto="true">
          <condicion operador="=">OCPRECIB.ocpfec</condicion>
        </field>
        
      </table>
    </join>
    <join tipo="left">
      <table id="STKINSUM">
        <field id="siscod" oculto="true">
          <label>STKINSUM.siscod</label>
          <condicion operador="=">'01'</condicion>
        </field>
        <field id="artcod" oculto="true">
          <condicion operador="=">OCPRECIB.artcod</condicion>
        </field>
        <field id="artuni" oculto="true">
        </field>
        <field id="unicps" oculto="true">
        </field>
      </table>
    </join>
  </form>
</histrix>
