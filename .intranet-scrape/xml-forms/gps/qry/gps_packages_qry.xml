                 GPS.gps_in1="inactivo"</expression>
      </field>
      -->
      <!-- SELECT (SUM(TIME_TO_SEC((gps_time)))) / 3600,gps_in1,gps_date FROM `GPS_TACOEXTEND`  where  (gps_date="2012-10-27") AND (gps_in1="inactivo")-->

    

      <field id="gps_point">
        <label>point</label>
        <expression>concat( replace(gps_latitude,',','.'),',', replace(gps_longitude,',','.'))</expression>
        <tipo>geoPoint</tipo>
      </field>
      
      
      <field id="device_id" _noshow="true">
        <label>Tipo</label> 
        <helper type="combo" id="gps_equipos" empty="true">           
          <field id="device_id" />
          <field id="Cliente" />        
        </helper>      
      </field>
      
      <order>
        <field id="id_package"></field>
      </order>
    </table>
  </form>
</histrix>  
