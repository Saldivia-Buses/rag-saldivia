<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="consulta" limit="700" preloadData="false">
  <title>GPS PACKAGES</title>
  <obs></obs>
  <form>
    <table id="GPS_TACOEXTEND" label="Paquetes">
     
      
      
      <filters>
        <field id="gps_date">
          <label>Desde</label>
          <valor>today</valor>
          <operador>&gt;=</operador>
        </field>
        
        
        <field id="gps_time" deshabilitado="false">
          <label>HDesde</label>
          <operador>&gt;=</operador>
          <valor eval="true">date('H:i:s', time() - 180 * 60)</valor>
        </field>

        
        
        <field id="gps_date">
          <label>Hasta</label>
          <valor>today</valor>
          <operador>&lt;=</operador>
        </field>
        
                                
        <field id="gps_time" deshabilitado="false">
          <label>HHasta</label>
          <operador>&lt;=</operador>
          <valor eval="true">date('H:i:s')</valor>
        </field>
        
          <field id="device_id" deshabilitado="false">
          <label>Equipo</label>
          <operador>=</operador>
          
        </field>
        </filters>   
 
      
      <field id="id_package" autoinc="true" _noshow="true" tipoOrden="DESC">
        <label>id</label>
      </field> 
      
      <field id="device_id">
      <label>Equipo</label>
      
      </field>
      
       <field id="device_id" _noshow="true">
        <label>Tipo</label> 
        <helper type="combo" id="gps_equipos" empty="true">           
          <field id="device_id" />
          <field id="Cliente" />        
        </helper>      
      </field>

      
      
       
      <field id="gps_date" >
        <label>----Fecha----</label>
        <tipo>date</tipo>
        <condicion operador="=">date(now())</condicion>

      </field> 
      
     
      <field id="gps_time" suma="false">
        <label>---Hora---</label>
        <tipo>time</tipo>
      </field> 
      
      <field id="gps_in1">
        <label>Contacto</label>
        <help>Ignicion</help>
      </field>

      
      <field id="gps_baterybus">
        <label>Bat Bus</label>
        <help>Bateria</help>
      </field> 



      
      <field id="gps_latitude">
        <label>Latitud</label>
        <help>Latitud del gps</help>
      </field>
      <field id="gps_longitude">
        <label>Longitud</label>
        <help>Longitud del gps</help>
        <condicion operador="!=">0</condicion>
      </field>
      
      
      <field id="gps_odometert">
        <label>Kms total</label>
        <help>Odometro total</help>
      </field>
      
      
       <field id="gps_odometerp">
        <label>Kms Hoy</label>
        <help>Odometro parcial</help>
      </field>
 <!--
      
      <field id="gps_direction" _noshow="true">
        <label>Direccion</label>
        <help>Direccion</help>
      </field>
     
    
      <field id="gps_directionhumans">
        <label>Direccion</label>
        <help>Direccion para humanos</help>
      </field>
    --> 
      
     
      <field id="gps_speed">
        <label>Km/h</label>
        <help>Velocidad</help>
      </field>
      
<!--      
       <field id="gps_volt_serial">
        <label>Sensor Combustible - SERIAL</label>
        <help>Voltaje de Combusitble....</help>
      </field>
      <field id="gpsalt_analogo">
        <label>Altura Combust - Analogo</label>
        <help>Altura de Combusitble....</help>
      </field>  
      -->
  
    <!--   <field id="gps_alt_serial_dec">
        <label>Altura Combust - SERIAL</label>
        <expression>ROUND (gps_alt_serial_dec,1)+25</expression>
        <help>Voltaje de Combusitble....</help>
      </field>
   --> 
      
      <field id="gps_volt_serial_dec">
        <label>volt SERIE</label>
        <expression>ROUND (gps_volt_serial_dec,3)</expression>
        <help>Voltaje de Combusitble....</help>
      </field>

           <field id="gps_valores_validos">
         <!--<condicion operador="=">1</condicion>
  -->
        <label>Valid</label>
      </field> 


      <field id="masrepetido">
        <label>Mas Repe</label>
      </field>  
      
        <field id="masrepetidos2">
        <label>2do Repe</label>
      </field>  
      
      <field id="PromValidos" local="true">
         <label>Prom</label>
        <expression>ROUND(((masrepetido+masrepetidos2)/2),3) </expression>   
       </field>
      
      <field id="AltValida" local="true">
         <label>LITROS</label>
        <expression>ROUND((((masrepetido+masrepetidos2)/2) *127.8 +26),1)</expression>   
       </field>
      
      
      <field id="in1" local="true">
        <label>T.comb</label>
        <expression>ROUND (((((gps_in0-9.9) * -10))-3),1)</expression>
     <!--   <expression>ROUND(((( ((gps_in0 - ((gps_baterybus - 12.2)*(gps_in0/gps_baterybus))  )-9.9))* -10) -2.5) ,1) </expression> -->
      </field>
    
     <!-- 
      <field id="gps_temzona" local="true">
        <expression>ROUND ((gps_temzona -273),1) </expression>
        <label>T.Zona</label>
        </field>  
     --> 
     
      
      <field id="gps_point">
        <label>point</label>
        <expression>concat( replace(gps_latitude,',','.'),',', replace(gps_longitude,',','.'))</expression>
        <tipo>geoPoint</tipo>
      </field>
      <group>
        <field id="gps_date" />    
        <field id="gps_time" /> 
            
      </group> 
      <order>
        <field id="id_package"></field>
      </order>
    </table>
  </form>
</histrix>  
