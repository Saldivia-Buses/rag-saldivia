<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="consulta">
  <title>Minutas</title>
  <obs></obs>
  <form detalle="detalle_asiento.xml" inline="true">
    <table id="CTB_DETALLES" label="Minutas">

      <filters>
        <field id="ejercicio_id">
          <label>Ejercicio</label>
          <operador>=</operador>
        </field>
        <field id="concepto_id">
          <label modpos="nobr">Concepto</label>
          <operador>=</operador>
        </field>
        <field id="fecha_movimiento">
          <label>Desde</label>
          <valor>today</valor>
          <tipo>date</tipo>
          <operador>&gt;=</operador>
        </field>
        <field id="fecha_movimiento">
          <label modpos="nobr">Hasta</label>
          <valor>today</valor>
          <tipo>date</tipo>
          <operador>&lt;=</operador>
        </field>
        <field id="nro_minuta">
          <label>Desde Minuta</label>
          <operador>&gt;=</operador>
        </field>
        <field id="nro_minuta">
          <label modpos="nobr">Hasta Minuta</label>
          <operador>&lt;=</operador>
        </field>
        <field id="nro_movimiento" tabla="REG_MOVIMIENTOS">
          <label>Comprobante</label>
          <operador>like</operador>
        </field>
        <field id="desbalanceadas">
          <label modpos="nobr">Desbalanceadas</label>
          <valor>1</valor>
        </field>
      </filters>

      <field id="id_detalle" noshow="true" />    

      <field id="fecha_movimiento" tabla="CTB_MOVIMIENTOS">
        <label>Fecha</label>
        <tipo>date</tipo>
      </field>

      <field id="nro_minuta" tabla="CTB_MOVIMIENTOS">
        <label>Nro. Minuta</label>
      </field>
     
      <field id="concepto_id" noshow="true" tabla="CTB_MOVIMIENTOS">
        <helper type="combo" dir="/ayudas" xml="ctbconcepto_qry.xml" empty="true"></helper>
        <label>Concepto</label>
      </field>
    
      <field id="regmovim_id" noshow="true" tabla="CTB_MOVIMIENTOS" />

      <field id="ejercicio_id" noshow="true" tabla="CTB_MOVIMIENTOS">
        <helper type="combo" xml="ctbejercicios_crud.xml" dir="/contabilidad/man/">
          <field id="activo" tipoOrden="DESC"/>
          <field id="fecha_mov1">
            <expresion>DATE_FORMAT(comienza, '%d/%m/%Y')</expresion>
            <tipo>date</tipo>
            <detalle>ejercicio_id</detalle>
          </field>
          <field id="fecha_mov2">
            <expresion>DATE_FORMAT(finaliza, '%d/%m/%Y')</expresion>
            <tipo>date</tipo>
          </field>
          <field id="finaliza"></field>
        </helper>
        <label>Ejercicio</label>
        <!--<detalle>ejercicio_id</detalle>-->
      </field>

      <field id="nombre_concepto" tabla="CTB_CONCEPTOS">
        <label>Concepto</label>
      </field>

      <field id="nombre_cuenta">
        <expression>CASE REG_MOVIMIENTOS.nombre_movimiento WHEN '' THEN concat(REG_CUENTA.nombre_cuenta,'(',REG_CUENTA.nro_cuenta,')') ELSE REG_MOVIMIENTOS.nombre_movimiento END</expression>
        <label>Nombre</label>
      </field>

      <field id="nro_movimiento" tabla="REG_MOVIMIENTOS" noshow="true" />
      
      <field id="comprobante_cta">
        <helper type="link" xml="regmovimiento_muestra_ficha.xml" dir="/caja/proc">
          <parameter source="regmovim_id" target="id_regmovim" />
        </helper>
        <expression>CONCAT(REG_CONCEPTOS.abreviacion_concepto, ' ', REG_MOVIMIENTOS.letra_movimiento, ' ', LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,0), '-', LPAD(nro_movimiento, 8, 0))</expression>
        <label>Comprobante</label>
      </field>

      <field id="debe">
        <label>Debe</label>
        <expression>sum(case when doh = 0 then importe else 0 end)</expression>
      </field>

      <field id="haber">
        <label>Haber</label>
        <expression>sum(case when doh = 1 then importe else 0 end)</expression>
      </field>

      <field id="diferencia" suma="true">
        <label>Diferencia</label>
        <expresion>sum( round(importe, 2) * (case when doh = 1 then 1 else -1 end))</expresion>
      </field>

      <field id="desbalanceadas" local="true" noshow="true">
        <lable>Desbalanceadas</lable>
        <tipo>check</tipo>
      </field>

      <field id="filtro" noshow="true">
        <expresion>(case when [__desbalanceadas__] = 1 AND (sum(case when doh = 0 then importe else (importe * -1) end)) = 0 THEN 0 ELSE 1 END)</expresion>
        <condicion operador="=">1</condicion>
      </field>

      <field id="movimiento_id" noshow="true">
        <detalle>movimiento_id</detalle>
      </field>

      <order>
        <field id="nro_minuta" />
      </order>

      <group>
        <field id="movimiento_id" />
      </group>

    </table>

    <join>
      <table id="CTB_MOVIMIENTOS">
        <field id="id_movimiento">
          <condicion operador="=">CTB_DETALLES.movimiento_id</condicion>
        </field>
      </table>
    </join>

    <join>
      <table id="CTB_CONCEPTOS">
        <field id="id_concepto">
          <condicion operador="=">CTB_MOVIMIENTOS.concepto_id</condicion>
        </field>
      </table>
    </join>

    <join tipo="left">
      <table id="REG_MOVIMIENTOS">
        <field id="id_regmovim">
          <condicion operador="=">CTB_MOVIMIENTOS.regmovim_id</condicion>
        </field>
      </table>
    </join>

    <join tipo="left">
      <table id="REG_CONCEPTOS">
        <field id="id_concepto">
          <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
        </field>
      </table>
    </join>
    
    <join tipo="left">
      <table id="REG_CUENTA">
        <field id="id_regcuenta">
          <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
        </field>
      </table>
    </join>

  </form>
</histrix>  
