<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="consulta" PDForientacion="L" noTabs="true" export="true" tableHeight="40em" imprime="true" _serverSide="true">
  <title>Movimientos</title>
  <obs></obs>
  <form>
    <table id="CTB_MOVIMIENTOS" label="movimientos">

        <field id="fecha_movimiento">
            <label>Fecha</label>
            <condicion operador="&gt;=">'[__fecha_minima__]' and CTB_MOVIMIENTOS.fecha_movimiento &lt;= '[__fecha_maxima__]'</condicion>
        </field>

        <field id="nro_minuta" style="width:5em;">
            <helper type="link" xml="minuta_detalle_qry.xml">
                <parameter target="movimiento_id" source="id_movimiento" />
                <parameter target="ejercicio_id"  source="ejercicio_id" />
                <parameter target="actual"        source="cuenta_id" />
                <parameter target="idmov"         source="id_detalle" />
            </helper>
            <label>Nro minuta</label>
            <help>Numero de la minuta</help>
        </field>

        <field id="regmovim_id" noshow="true" />

      <field id="nro_cuenta" tabla="REG_CUENTA">
        <label>Nro.Cuenta</label>
      </field>

      <field id="nom_cta">
        <expression>CASE REG_MOVIMIENTOS.nombre_movimiento WHEN '' THEN REG_CUENTA.nombre_cuenta ELSE REG_MOVIMIENTOS.nombre_movimiento END</expression>
        <label>Nombre</label>
      </field>

      <field id="comprobante_cta">
        <helper type="link" xml="regmovimiento_muestra_ficha.xml" dir="/caja/proc" >
          <parameter source="regmovim_id" target="id_regmovim" />
        </helper>
        <expression>CONCAT(REG_CONCEPTOS.abreviacion_concepto, ' ', REG_MOVIMIENTOS.letra_movimiento, ' ', LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,0), '-', LPAD(nro_movimiento, 8, 0) )</expression>
        <label>Comprobante</label>
      </field>

      <field id="id_detalle" tabla="CTB_DETALLES" noshow="true" />

      <field id="cuenta_id" tabla="CTB_DETALLES" print="false" noshow="true">
        <label>Nro.Cuenta</label>
      </field>

      <field id="nombre_cuenta" local="true" noshow="true" print="false">
	<label>Cta.Cble.</label>
      </field>

      <field id="cta_cble" noshow="true">
	<label>Cta.Cble.</label>
	<expression>concat(CTB_DETALLES.cuenta_id,' - ','[__nombre_cuenta__]')</expression>
      </field>

      <field id="id_movimiento" noshow="true" >
        <label>Codigo</label>
        <help>Código de movimiento</help>
      </field>

      <field id="concepto_id" noshow="true">
        <label>Concepto</label>
        <help>Código de concepto</help>
      </field>

      <field id="mes" noshow="true" _break="true"  local="true">
        <label></label>
        <help>Fecha movimiento</help>
        <expresion> month(CTB_MOVIMIENTOS.fecha_movimiento)</expresion>
      </field>

      <field id="referencia" >
        <label>Referencia</label>
        <help>Referencia del movimiento</help>
      </field>

      <field id="debe" suma="true" noZero="true"  local="true"> 
        <expresion>case when doh = 0 then importe else 0 end</expresion>
        <label>Debe</label> 
        <tipo>numeric</tipo> 
      </field>

      <field id="haber" suma="true" noZero="true"  local="true" > 
        <expresion>case when doh = 1 then importe else 0 end</expresion>
        <label>Haber</label>
        <tipo>numeric</tipo> 
      </field>

      <field id="diferencia" suma="true"  local="true"> 
        <expresion>round(importe, 2) * (case when doh = 0 then 1 else -1 end)</expresion>
        <label>Diferencia</label>
        <tipo>numeric</tipo> 
      </field>

      <field id="acumulado" suma="true" acumula="true" local="true">
        <label>Acumulado</label>
        <if exp="true">
            <true>debe - haber</true>
            <false>0</false>
        </if>
        <tipo>numeric</tipo>
      </field>

      <field id="ejercicio_id" noshow="true">
        <label>Ejercicio</label>
        <detalle>ejercicio_id</detalle>
      </field>

      <field id="fecha_minima" noshow="true" local="true" />

      <field id="fecha_maxima" noshow="true" local="true" />

      <order>
        <field id="fecha_movimiento" tabla="CTB_MOVIMIENTOS"></field>
      </order>
    </table>
    <join tipo="inner">
      <table id="CTB_CONCEPTOS">
        <field id="id_concepto">
          <condicion operador="=">concepto_id</condicion>
        </field>
      </table>
    </join>
    <join tipo="left">
      <table id="CTB_DETALLES">
        <field id="movimiento_id">
          <condicion operador="=">id_movimiento</condicion>
        </field>
      </table>
    </join>
     <join tipo="left">
      <table id="REG_MOVIMIENTOS">
        <field id="id_regmovim">
          <condicion operador="=">CTB_MOVIMIENTOS.regmovim_id</condicion>
        </field>
      </table>
    </join>
    <join tipo="left">
      <table id="REG_CONCEPTOS">
        <field id="id_concepto">
          <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
        </field>
      </table>
    </join>
    <join tipo="left">
      <table id="REG_CUENTA">
        <field id="id_regcuenta">
          <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
        </field>
      </table>
    </join>
  </form>
</histrix>  
