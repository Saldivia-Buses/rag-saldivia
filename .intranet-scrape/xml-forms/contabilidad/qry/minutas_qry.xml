<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta">
  <title>Movimientos</title>
  <obs/>
  <consulta detalle="minuta_detalle_qry.xml" inline="true">
    <table id="CTB_MOVIMIENTOS" label="movimientos">
      <filtros>
	        <field id="ejercicio_id">
	          <label>Ejercicio</label>
	          <help>Ejercicio contable</help>
	          <operador>=</operador>
	        </field>
	        <field id="concepto_id">
	          <operador>=</operador>
	          <label modpos="nobr">Tipo de concepto</label>
	          <help>Concepto elegido</help>
	        </field>
	        <field id="fecha_mov1" deshabilitado="false">
	          <valor>today</valor>
	          <operador>&gt;=</operador>
	          <label>Desde Fecha</label>
	          <help>Fecha movimiento</help>
	        </field>
	        <field id="fecha_mov2" deshabilitado="false">
	          <valor>today</valor>
	          <operador>&lt;=</operador>
	          <label modpos="nobr">hasta Fecha</label>
	          <help>Fecha movimiento</help>
	        </field>
	        <field id="nro_minuta1" deshabilitado="false">
	          <valor/>
	          <operador>&gt;=</operador>
	          <label>Desde minuta</label>
	          <help>Ingrese desde que minuta buscar</help>
	        </field>
	        <field id="nro_minuta2" deshabilitado="false">
	          <valor/>
	          <operador>&lt;=</operador>
	          <label modpos="nobr">hasta minuta</label>
	          <help>Ingrese hasta que minuta buscar</help>
	        </field>
	        <field id="nro_movimiento" tabla="REG_MOVIMIENTOS">
	    	    <label>Comprobante</label>
	    	    <operador>=</operador>
	    	    <help>Ingrese comprobante a buscar</help>
	    	</field>
	    	<field id="solo_diferencia">
	           <label modpos="nobr">Solo c/Diferencia</label>
	   	   </field>
      </filtros>

      <field id="nro_minuta" noshow="false">
        <label>Numero minuta</label>
        <help>Numero de la minuta</help>
        <size>4</size>
      </field>
    
      <field id="id_movimiento" _noshow="true">
        <label>Codigo</label>
        <help>Código de movimiento</help>
        <detalle>movimiento_id</detalle>
      </field>
    
      <field id="nro_movimiento" noshow="true" tabla="REG_MOVIMIENTOS" />
    
      <field id="concepto_id" noshow="true">
        <helper type="combo" dir="/ayudas" xml="ctbconcepto_qry.xml" empty="true"></helper>
        <label>Concepto</label>
        <help>Código de concepto</help>
        <!--<detalle>concepto_id</detalle>
      -->
   	 </field>
    
    <field id="regmovim_id" noshow="true" />
    
    <field id="nro_cuenta" tabla="REG_CUENTA">
      <label>Nro.Cuenta</label>
    </field>
    
    <field id="nom_cta">
      <expression>CASE REG_MOVIMIENTOS.nombre_movimiento WHEN '' THEN REG_CUENTA.nombre_cuenta ELSE REG_MOVIMIENTOS.nombre_movimiento END</expression>
      <label>Nombre</label>
    </field>
    
    <field id="comprobante_cta">
      <helper type="link" xml="regmovimiento_muestra_ficha.xml" dir="/caja/proc" >
        <parameter source="regmovim_id" target="id_regmovim" />
      </helper>
      <expression>
        CONCAT(REG_CONCEPTOS.abreviacion_concepto, ' ', REG_MOVIMIENTOS.letra_movimiento, ' ', LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,0), '-', LPAD(nro_movimiento, 8, 0) )
      </expression>
      <label>Comprobante</label>
    </field>
    
    <field id="fecha_movimiento" tabla="CTB_MOVIMIENTOS">
      <label>Fecha</label>
      <help>Fecha movimiento</help>
    </field>
    
    <field id="referencia">
      <label>referencia</label>
      <help>Referencia del movimiento</help>
    </field>
    
    <field id="debe" suma="true">
      <expresion>sum(case when doh = 0 then importe else 0 end)</expresion>
      <label>Debe</label>
      <tipo>numeric</tipo>
    </field>
    
    <field id="haber" suma="true">
      <expresion>sum(case when doh = 1 then importe else 0 end)</expresion>
      <label>Haber</label>
      <tipo>numeric</tipo>
    </field>
    
    <field id="diferencia" suma="true">
      <expresion>sum( round(importe, 2) * (case when doh = 1 then 1 else -1 end))</expresion>
      <label>Diferencia</label>
      <tipo>numeric</tipo>
    </field>

    <field id="resaltado" clasefila="true" noshow="true">
      <label>res</label>
      <expresion>case when abs(sum( round(importe, 2) * (case when doh = 1 then 1 else -1 end))) != 0 then 'resaltado' else '' end</expresion>
    </field>

	<field id="solo_diferencia" local="true" noshow="true">
       <tipo>check</tipo>
    </field>

    <field id="filt_diferencia" noshow="true">
		<expression>CASE WHEN ('[__solo_diferencia__]' = '1' and (case when abs(sum( round(importe, 2) * (case when doh = 1 then 1 else -1 end))) != 0 then 1 else 0 end) = 1) or ('[__solo_diferencia__]' = '0') THEN 1 ELSE 0 END</expression>
		<condicion operador="=">1</condicion>
    </field>

    <field id="ejercicio_id" noshow="true">
      <helper type="combo" xml="ctbejercicios_crud.xml" dir="/contabilidad/man/">
        <field id="activo" tipoOrden="DESC"/>
        <field id="fecha_mov1">
          <expresion>DATE_FORMAT(comienza, '%d/%m/%Y')</expresion>
          <tipo>date</tipo>
          <detalle>ejercicio_id</detalle>
        </field>
        <field id="fecha_mov2">
          <expresion>DATE_FORMAT(finaliza, '%d/%m/%Y')</expresion>
          <tipo>date</tipo>
        </field>
        <field id="finaliza"></field>
      </helper>
      <label>Ejercicio</label>
      <help>Ejercicio contable</help>
      <detalle>ejercicio_id</detalle>
    </field>
    <field id="nombre_concepto" tabla="CTB_CONCEPTOS" colstyle="Display:none;" print="false">
      <label>Concepto</label>
      <help>Codigo de concepto</help>
    </field>
    <field id="nro_minuta2" noshow="true">
      <expresion having="false">nro_minuta</expresion>
      <help>numero de minuta</help>
    </field>
    <field id="nro_minuta1" noshow="true">
      <expresion having="false">nro_minuta</expresion>
      <help>numero de minuta</help>
    </field>
    <field id="fecha_mov1" noshow="true">
      <expresion having="false">CTB_MOVIMIENTOS.fecha_movimiento</expresion>
      <help>Fecha movimiento</help>
      <tipo>date</tipo>
    </field>
    <field id="fecha_mov2" noshow="true">
      <expresion having="false">CTB_MOVIMIENTOS.fecha_movimiento</expresion>
      <help>Fecha movimiento</help>
      <tipo>date</tipo>
    </field>
    <order>
      <field id="fecha_movimiento" tabla="CTB_MOVIMIENTOS"/>
    </order>
    <group>
      <field id="id_movimiento"/>
    </group>
  </table>
  <join>
    <table id="CTB_CONCEPTOS">
      <field id="id_concepto">
        <condicion operador="=">concepto_id</condicion>
      </field>
    </table>
  </join>
  <join>
    <table id="CTB_DETALLES">
      <field id="movimiento_id">
        <condicion operador="=">id_movimiento</condicion>
      </field>
    </table>
  </join>
  <join tipo="left">
    <table id="REG_MOVIMIENTOS">
      <field id="id_regmovim">
        <condicion operador="=">CTB_MOVIMIENTOS.regmovim_id</condicion>
      </field>
    </table>
  </join>
  <join tipo="left">
    <table id="REG_CONCEPTOS">
      <field id="id_concepto">
        <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
      </field>
    </table>
  </join>
  <join tipo="left">
    <table id="REG_CUENTA">
      <field id="id_regcuenta">
        <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
      </field>
    </table>
  </join>
</consulta>
</histrix>