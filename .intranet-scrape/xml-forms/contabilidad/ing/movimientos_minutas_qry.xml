<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="consulta" >
  <title>Movimientos</title>
  <obs></obs>
  <consulta >
    <table id="CTB_MOVIMIENTOS" label="movimientos">

      <filtros>
        <field id="ejercicio_id">
          <label>Ejercicio</label>
          <help>Ejercicio contable</help>
          <operador>=</operador>
        </field>
        <field id="fecha_movimiento">
          <valor>today</valor>
          <operador>=</operador>
          <label>Fecha</label>
          <help>Fecha movimiento</help>
        </field>
        <field id="nro_minuta">
          <label>Nº minuta</label>
          <operador>=</operador>
          <help>Ingrese hasta que minuta buscar</help>
        </field>
        <field id="referencia">
          <label>referencia</label>
          <operador>like</operador>
          <size>20</size>
        </field>

        <field id="concepto_id">
          <operador>=</operador>
          <label>Tipo de concepto</label>
          <help>Concepto elegido</help>
        </field>

      </filtros>

      <field id="nro_minuta" noshow="false">
        <label>Nro minuta</label>
        <help>Numero de la minuta</help>
        <condicion operador="=">nro_minuta</condicion>
      </field>
      <field id="id_movimiento" noshow="true" >
        <label>Codigo</label>
        <help>Código de movimiento</help>
      </field>
      <field id="concepto_id" noshow="true" >
        <helper type="combo" dir="/ayudas" xml="ctbconcepto_qry.xml"></helper>
        <label>Concepto</label>
        <help>Código de concepto</help>
        <condicion operador="!=">0</condicion>
      </field>
      <field id="fecha_movimiento">
        <label>Fecha</label>
      </field>
      <field id="referencia">
        <label>referencia</label>
        <size>20</size>
      </field>
      <field id="comienza" tabla="CTB_EJERCICIOS" noshow="true" />
      <field id="finaliza" tabla="CTB_EJERCICIOS" noshow="true" />

      <field id="debe" >
        <expresion>sum(case when doh = 0 then importe else 0 end)</expresion>
        <label>Debe</label>
        <tipo>numeric</tipo>
      </field>
      <field id="haber" >
        <expresion>sum(case when doh = 1 then importe else 0 end)</expresion>
        <label>Haber</label>
        <tipo>numeric</tipo>
      </field>
      <field id="diferencia" >
        <expresion>
          sum( round(importe, 2) * (case when doh = 1 then 1 else -1 end))
        </expresion>
        <label>Diferencia</label>
        <tipo>numeric</tipo>
      </field>

      <field id="anulacion" local="true">
        <helper type="link" xml="movimientos_minutas_anul.xml" _width="600" _height="150" modal="true">
          <parameter source="id_movimiento" target="id_movimiento" />
        </helper>
        <label>Anular</label>
        <valor>&gt;&gt;</valor>
      </field>
      <field id="resaltado" clasefila="true" noshow="true">
        <label>res</label>
        <expresion>
          case when abs(sum( round(importe, 2) * (case when doh = 1 then 1 else -1 end))) != 0 then 'resaltado' else '' end
        </expresion>
      </field>
      <field id="ejercicio_id" noshow="true">
        <helper type="combo" xml="ctbejercicios_crud.xml" dir="/contabilidad/man/">
          <field id="activo" tipoOrden="DESC"/>
        </helper>
        <condicion operador="=">ejercicio_id</condicion>
        <label>Ejercicio</label>
        <help>Ejercicio contable</help>
      </field>
      <group>
        <field id="id_movimiento"></field>
      </group>
    </table>
    <join tipo="left">
      <table id="CTB_CONCEPTOS">
        <field id="id_concepto">
          <condicion operador="=">concepto_id</condicion>
        </field>
      </table>
    </join>
    <join tipo="left">
      <table id="CTB_DETALLES">
        <field id="movimiento_id">
          <condicion operador="=">id_movimiento</condicion>
        </field>
      </table>
    </join>
    <join tipo="left">
      <table id="CTB_EJERCICIOS">
        <field id="id_ejercicio">
          <condicion operador="=">ejercicio_id</condicion>
        </field>
      </table>
    </join>
  </consulta>
</histrix>