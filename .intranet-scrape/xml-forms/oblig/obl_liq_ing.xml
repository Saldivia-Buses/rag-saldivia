<?xml version="1.0" encoding="UTF-8"?>
<abm graboasiento="true" muestraasiento="false" llenoTemporal="false" tipo="ing" subtipo="vertical" importadatos="remitos_cons.xml" imprime="false">
	<titulo>INGRESO DE FACTURAS</titulo>
	<confirmacion><![CDATA[¿Desea Ingresar el comprobante?  ]]></confirmacion>
	<consulta>

		<tabla id="OBL" label="Ingreso de Facturas">
			<!-- Este ingreso va a incorporar un boton IMPORTAR
				llamado con los parametros mencionados en los campos
			-->
			<!-- accesskey="I" -->

			<!-- <importar xml="remitos_cons.xml"  label="Importar desde Remitos" titulo="Seleccione Remito" dir="/remitos">
				<campo id="ctacod"></campo>
			</importar>-->

			<movimientos cabecera="obl_liq_cab.xml">
				<relacion id="factura_oblmovim_ingmov.xml"/>
		<!-- 	<relacion id="factura_cctmovim_ctdo_ingmov.xml"/>
				<relacion id="factura_cajmovim_ingmov.xml"/>

				<relacion id="factura_ivacompras_ingmov.xml"/>
				<relacion id="factura_ivaimportes_ingmov.xml"/>
				<relacion id="factura_pergan_ivaimportes_ingmov.xml"/>
				<relacion id="factura_periva_ivaimportes_ingmov.xml"/>
				<relacion id="factura_pering_ivaimportes_ingmov.xml"/>

				<relacion id="factura_facdetal_ingmov.xml"/>
				<relacion id="factura_stkinmov_ingmov.xml"/>-->

				<!--					<relacion id="factura_rni_ivaimportes_ingmov.xml"></relacion> -->
			</movimientos>
			<campo id="siscod" oculto="true"  >
				<label >siscod</label>
				<valor>'01'</valor>
				<tipo>varchar</tipo>
			</campo>
			<campo id="movnro" oculto="true" >
				<label >remnro</label>
				<tipo>integer</tipo>
			</campo>

			<campo id="artuni" oculto="true">
				<label>artuni</label>
			</campo>
			<campo id="artcan" oculto="true">
				<label >artcan</label>
				<tipo>numeric</tipo>
			</campo>
			<campo id="artnet" oculto="true">
				<label >artnet</label>
				<tipo>numeric</tipo>
			</campo>
			<campo id="movp2" oculto="true">
				<label >movp2</label>
				<tipo>numeric</tipo>
			</campo>


			<campo id="ctb_comp" local="true" ctbcuenta="1">
				<label colspan="1">Cuenta Ctb</label>
				<tabla_ex id="CTBCUENT" vacio="true">
					<campo id="ctbcod"></campo>

					<campo id="ctbnom">
						<detalle>ctbnom</detalle>
					</campo>
					<campo id="ctbhab">
						<condicion operador="=">1</condicion>
					</campo>
				    <!--
					<campo id="siscod">
						<condicion operador="=">'10'</condicion>
					</campo>
					-->
					<orden>
						<campo id="ctbnom"></campo>
					</orden>
				</tabla_ex>
				<tipo>varchar</tipo>

			    <IF exp="trim('ctb_comp') == ''">
					<verdadero>'ctb_prov'</verdadero>
					<falso>'ctb_comp'</falso>
				</IF>
			</campo>

<!--			<campo id="ctbnom" local="true" deshabilitado="true">
				<label modpos="nobr" >Contable</label>
				<tipo>varchar</tipo>
			</campo>
			-->
			<campo id="neto" suma="true" oculto="true">
				<label modpos="nobr" >Neto Gravado</label>
				<tipo>numeric</tipo>
				<jseval campodestino="iva">neto * alicuota / 100</jseval>

			</campo>
			<campo id="nogravado" suma="true" oculto="true">
				<label modpos="nobr">No Gravado</label>
				<tipo>numeric</tipo>
			</campo>
			<campo id="exento" suma="true">
				<label modpos="nobr">Importe</label>
				<tipo>numeric</tipo>
			</campo>

			<campo id="alicuota" local="true" oculto="true">
				<label>Alicuota</label>
				<opciones>
					<opcion valor="21">21.00 %</opcion>
					<opcion valor="27.00">27.00 %</opcion>
					<opcion valor="10.50">10.50 %</opcion>
				</opciones>
				<tipo>decimal</tipo>
				<valor>21</valor>
				<jseval campodestino="iva">neto * alicuota / 100</jseval>

			</campo>


			<campo  id="iva" ctbimporte="3" suma="true" local="true" oculto="true">
				<label modpos="nobr">I.V.A.</label>
				<IF exp="iva == 0" operador="=">
					<verdadero>round(neto,2 ) * alicuota / 100</verdadero>
					<falso>iva</falso>
				</IF>
				<tipo>numeric</tipo>
			</campo>
			<campo id="perciv" ctbimporte="4" oculto="true">
				<label modpos="nobr">Per.I.V.A.</label>
				<tipo>numeric</tipo>
			</campo>
			<campo id="pergan" ctbimporte="6" oculto="true">
				<label modpos="nobr">Per. Ganancias</label>
				<tipo>numeric</tipo>
			</campo>
			<campo id="pering" ctbimporte="5" oculto="true">
				<label >Per.Ing.Brutos</label>
				<tipo>numeric</tipo>
			</campo>
			<campo id="total" copia="saldo" deshabilitado="true"  local="true" suma="true" ctbimporte="2">
				<label modpos="nobr" Formstyle="font-size:18px;color:red;">Total</label>
				<IF exp="conimp == 2" operador="=">
					<verdadero> neto + nogravado + iva +  exento +  perciv + pergan + pering </verdadero>
					<falso>neto + nogravado + iva +  exento +  perciv + pergan + pering</falso>
				</IF>
				<tipo>numeric</tipo>
			</campo>
			<campo id="multi" deshabilitado="true"  local="true" noshow="true">
				<label modpos="nobr">multi</label>
				<IF exp="conimp == 2" operador="=">
					<verdadero>1</verdadero>
					<falso>-1</falso>
				</IF>
				<tipo>integer</tipo>
			</campo>
			<campo id="saldo" suma="true" deshabilitado="true">
				<label modpos="nobr" Formstyle="font-size:18px;color:red;">Saldo</label>
				<tipo>numeric</tipo>

				<IF exp="(saldo) == 0" operador="=">
					<verdadero>multi * (total * fpago)</verdadero>
					<falso>multi *(total * fpago) </falso>
				</IF>
			</campo>
			<campo id="impcod" local="true" noshow="true">
			<label modpos="nobr"></label>
				<IF exp="true" operador="=">
					<verdadero>(alicuota == 21.00 ? 1: (alicuota == 27.00 ? 3 : 2))</verdadero>
					<falso>0</falso>
				</IF>
				<tipo>numeric</tipo>
			</campo>
			<campo id="grabo_pergan" local="true" noshow="true">
				<IF exp="(pergan != 0)" operador="=">
					<verdadero>'true'</verdadero>
					<falso>'false'</falso>
				</IF>
				<tipo>varchar</tipo>
			</campo>
			<campo id="f_p" local="true" noshow="true">
				<IF exp="(fpago == 0)" operador="=">
					<verdadero>'true'</verdadero>
					<falso>'false'</falso>
				</IF>
				<tipo>varchar</tipo>
			</campo>
			<campo id="artcod" noshow="true">
				<label >artcod</label>
				<tipo>varchar</tipo>
			</campo>

			<campo id="grdet" local="true"  noshow="true">
				<IF exp="('artcod'	 != '')" operador="=">
					<verdadero>'true'</verdadero>
					<falso>'false'</falso>
				</IF>
				<tipo>varchar</tipo>
			</campo>
			<campo id="grabo_periv" local="true" noshow="true">
				<IF exp="(perciv != 0)" operador="=">
					<verdadero>'true'</verdadero>
					<falso>'false'</falso>
				</IF>
				<tipo>varchar</tipo>
			</campo>
			<campo id="grabo_per_ing" local="true" noshow="true">
				<IF exp="(pering != 0)" operador="=">
					<verdadero>'true'</verdadero>
					<falso>'false'</falso>
				</IF>
				<tipo>varchar</tipo>
			</campo>
<!--			<campo id="imputiv" local="true" ctbtipo="3" noshow="true">
				<valor>1</valor>
			</campo>
			<campo id="imputpiv" local="true" ctbtipo="4" noshow="true">
				<valor>1</valor>
			</campo>
			<campo id="imputpib" local="true" ctbtipo="5" noshow="true">
				<valor>1</valor>
			</campo>
			<campo id="imputpga" local="true" ctbtipo="6" noshow="true">
				<valor>1</valor>
			</campo>
			<campo id="imputnetos" local="true" ctbtipo="1" noshow="true">
				<valor>1</valor>
			</campo>
			-->

			<campo deshabilitado="true" id="netos" ctbimporte="1" noshow="true">
				<IF exp="true" operador="=">
					<verdadero>neto + nogravado + exento</verdadero>
					<falso>0</falso>
				</IF>
				<tipo>numeric</tipo>
			</campo>
			<campo deshabilitado="true" id="ref" ctbreferencia="1" >
				<IF exp="true" operador="=">
					<verdadero>'concod - movnpv-movnro - ctanom'</verdadero>
					<falso>0</falso>
				</IF>
				<tipo>varchar</tipo>
			</campo>
		</tabla>
	</consulta>
</abm>
