<?xml version="1.0" encoding="ISO-8859-1" ?>
   <abm tipo="consulta">
       <titulo>Cuenta Corriente de Obligaciones</titulo>
        <obs></obs>
				<consulta detalle="imputaciones.xml">
					<tabla id="OBLMOVIM" label="Movimientos Obligaciones" styleTbody="height:500px;">

						<campo id="siscod">
							<label>Cod.</label>
							<help>
							</help>
						</campo>
						<filtro_ex>
							<label>Cuenta</label>
							<tabla_ex id="OBLCUENT">
								<campo id="ctacod"></campo>
								<campo id="ctanom"></campo>
								<campo id="siscod"></campo>
								<campo id="baja">
									<condicion operador="=">0</condicion>
								</campo>

								<orden>
									<campo id="ctanom"></campo>
								</orden>

								<filtra>ctacod</filtra>
							</tabla_ex>
						</filtro_ex> -
						<campo id="ctacod">
							<label>Cod.</label>
							<help>Codigo de Cuenta </help>
							<detalle>ctacod</detalle>
						</campo>
						<campo id="concod" noshow="true">
							<label>concod</label>
							<detalle>concod</detalle>
						</campo>
						<campo id="movnpv">
							<label>P.V.</label>
							<help> Punto Venta</help>
							<formato>%04d</formato>
							<detalle>movnpv</detalle>
						</campo>
						<campo id="movnro" >
							<label>Numero</label>
							<help> Numero Comprobante</help>
							<formato>%12d</formato>
							<detalle>movnro</detalle>


						</campo>

						<campo id="concepto">
							<expresion>condes</expresion>
							<label>Cod.Concepto</label>
							<help>
							</help>
							<tipo>string</tipo>
							<!--		      <tabla_ex id="CCTCONCE">

							<campo id="concod"></campo>
							<campo id="condes"></campo>
							</tabla_ex>
							-->
						</campo>

						<campo id="movfec">
							<label>Fecha </label>
							<help>
							</help>
						</campo>

						<!--          <campo id="movvto">
						<label>Venc. </label>
						<help> </help>
						</campo>
						-->
						<campo id="Debe" suma="true">
							<expresion>movimp * (case when conimp = 1 then 1 else 0 end)</expresion>
							<label>Debe</label>
							<help>
							</help>
						</campo>

						<campo id="Haber" suma="true" link_int="oblmovim_comp.xml" linkdes="Ver Recibo">
							<expresion>movimp * (case when conimp = 2 then 1 else 0 end)</expresion>
							<label>Haber</label>
							<help>
							</help>
						<!-- <paring destino="siscod">siscod</paring>							-->
							<paring destino="movnro">movnro</paring>
							<paring destino="carrec">movnro</paring>
							<paring destino="cajnro">movnro</paring>
							<paring destino="movinc">movnro</paring>
							<paring destino="movnpv">movnpv</paring>
							<paring destino="ctacod">ctacod</paring>
							<paring destino="movfec">movfec</paring>
							<paring destino="cajfec">movfec</paring>
						</campo>

						<campo id="movsal" suma="true">
							<label>Saldo</label>
							<help></help>
							<tipo>numeric</tipo>
						</campo>
						<filtros>
							<campo id="movfec">
								<operador>>=</operador>
								<label>Desde Fecha</label>
								<valor>today</valor>

							</campo>
							<campo id="movfec">
								<operador>&lt;=</operador>
								<label>Hasta Fecha</label>
								<valor>today</valor>

							</campo>
						</filtros>
						<orden>
							<campo id="movfec"></campo>
						</orden>
					</tabla>

					<join tipo="left">
						<tabla id="OBLCONCE">
							<campo id="siscod" oculto="true">
								<label>cctcuent.siscod</label>
								<condicion operador="=">
									OBLMOVIM.siscod</condicion>
							</campo>

							<campo id="concod" oculto="true">
								<condicion operador="=">
									OBLMOVIM.concod</condicion>
							</campo>

							<campo id="condes" oculto="true">
							</campo>

						</tabla>
					</join>
				</consulta>
        </abm>