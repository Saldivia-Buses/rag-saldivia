<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="consulta" subtipo="vertical" width="50" paginar="100">
<title>Productos</title>
<obs></obs>
<form detalle="producto_atributos_valores.xml">
    <table id="PRODUCTOS">
        <title>Productos</title>
	<filters>
        <field id="descripcion_producto" >
            <label>Producto</label>
            <help>Nro Unidad</help>
    	    <operador>=</operador>
        </field>
	    
	</filters>
        <field id="id_producto" autoinc="true" noshow="true" tipoOrden="DESC">
            <label>producto</label>
            <detalle>producto_id</detalle>
        </field>

        <field id="id" tabla="PEDCOTIZ" noshow="true" />

        <field id="nrocha" tabla="PEDCOTIZ" esClave="true" deshabilitado="true">
    	    <label>FV</label>
    	    <detalle>nrofab</detalle>
            <attribute id="linkdes">nrocha</attribute>
            <helper type="link" xml="ficha_venta_qry.xml" dir="/ventas" modal="true" title="Ficha Producto">
            <parameter source="id_producto" target="producto_id"/>
            <parameter source="id_producto" target="id"/>
            <parameter source="nrocha" target="nrofab"/>
            </helper>        
        </field>
        <field id="ctacod" tabla="PEDCOTIZ">
        <label>Cliente</label>
        <help>Código de Cuenta</help>
        <tabla_ex condes="true" id="CCTCUENT">
          <field id="ctacod"/>
          <field id="ctafan2">
              <expression>CCTCUENT.ctafan</expression>
          </field>
         <field id="ctafan" />
          <field id="siscod" oculto="true">
            <condicion operador="=">'02'</condicion>
          </field>
          <field id="baja" oculto="true">
            <condicion operador="=">0</condicion>
          </field>
        </tabla_ex>
      </field>        

      <field id="homologacion_id" tabla="PEDCOTIZ">
    	    <label Formstyle="display:none;">Homol</label>
            <helper type="combo" xml="combo_homologacion_modelo.xml" dir="/fabricacion" empty="true">
            </helper>
            <detalle>homologacion_id</detalle>
        </field>

        <field id="acces" local="true" style="text-align:center;">
            <label>Accesorios</label>
            <helper type="link" xml="accesorios_coche_precio.xml" dir="/produccion/man/" title="Editar Adicionales">
                <parameter source="nrocha" target="nrofab"/>
                <parameter source="id" target="ficha_id"/>
            </helper>
            <attribute id="linkdes">nrocha</attribute>
            <valor>Acces.</valor>
        </field>

        <field id="nrochaFT" tabla="PEDCOTIZ" esClave="true" deshabilitado="true">
          <label>FT</label>
          <expression>PEDCOTIZ.nrocha</expression>
            <attribute id="linkdes">nrocha</attribute>
            <helper type="link" xml="ficha_producto1_qry.xml" dir="/producto" modal="true" title="Ficha Producto">
            <parameter source="id_producto" target="producto_id"/>
            <parameter source="id_producto" target="id"/>
            <parameter source="nrocha" target="nrofab"/>
            </helper>        
        </field>

        <field id="estado_ficha" tabla="PEDCOTIZ">
            <label>Estado</label>
            <options>
              <option valor="0">Borrador</option>
              <option valor="1">Publicada</option>
              <option valor="2">Comercial</option>
            </options>       
        </field>

        <field id="edita_cabecera" local="true" style="text-align:center;">
            <label>Editar Encabez.</label>
            <valor>Encabe.</valor>
            <attribute id="linkdes">nrocha</attribute>
            <helper type="link" xml="producto_estado_ficha_update.xml" dir="/producto/ing" title="Editar cabecera de ficha">
                <parameter source="id_producto" target="id"/>
                <parameter source="nrocha" target="nrocha"/>
            </helper>          
        </field>

      <field id="cotizar" local="true"  linkmodal="true">
        <label Formstyle="display:none;">Cotizar</label>
        <helper type="link" xml="cotizar_coche_acc_ing.xml" dir="/cotizacion" >
          <parameter source="nrocha" target="nrofab_id"/>
          <parameter source="nrocha" target="nrofab"/>
          <parameter source="ctacod" target="ctacod"/>
          <parameter source="id_producto" target="ficha_id"/>
        </helper>
       <expression>select sum(precio_adicional) from ACCESORIOS_COCHE AS ACC where estado != 2 and precio_unitario != 0 and ACC.ficha_id = PEDCOTIZ.id and ACC.cotizacion_id = 0 limit 1</expression>
      </field>

    <field id="ultima"   _linkmodal="true" showObjTabla="true" local="true">
        <label style="display:none;">Cotiz.</label>
        <helper type="object" xml="cotizaciones_btn.xml" dir="/cotizacion" >
          <parameter source="id_producto" target="ficha_id"/>
        </helper>
    </field> 
  
    <field id="cantPend" local="true" Formstyle="display:none;">
      <label>Pend.</label>
      <expression>CASE WHEN (SELECT COUNT(*) FROM ACCESORIOS_COCHE ac WHERE estado = 0 and precio_unitario != 0 and ac.ficha_id = PEDCOTIZ.id) THEN CONCAT((SELECT COUNT(*) FROM ACCESORIOS_COCHE ac WHERE estado = 0 and precio_unitario != 0 and ac.ficha_id = PEDCOTIZ.id), '/', (SELECT COUNT(*) FROM ACCESORIOS_COCHE ac WHERE ac.ficha_id = PEDCOTIZ.id and precio_unitario != 0)) END</expression>
    </field>

    <field id="descripcion_producto" noshow="true">
        <label>Desc</label>
        <help>Descripción Producto</help>
        <size>30</size>
    </field>

    <field id="borra_producto" local="true" style="text-align:center;">
        <label>Bor.</label>
        <expression><![CDATA['<img src="../img/cancel.png" />']]></expression>
        <attribute id="linkdes">nrocha</attribute>
        <helper type="link" xml="producto_borrar_ficha_ing.xml" dir="/producto/ing" title="Editar cabecera de ficha" width="600px" height="200px">
            <parameter source="id" target="id" />
        </helper>
    </field>

	<order>
	    <field id="id_producto"/>
	</order>
    </table>
    <join tipo="left">
	<table id="PEDCOTIZ">
	    <field id="id">
		<condicion operador="=">id_producto</condicion>
	    </field>
	</table>
    </join>
</form>	   
</histrix>