            <label>Cant.Atributos</label>
            <help>Cantidad de atributos cargados es la seccion</help>
    	    <expresion>((select count(*) from PRODUCTO_ATRIB_VALORES join PRODUCTO_ATRIBUTOS on id_prdatributo = prdatributo_id where prdseccion_id = id_prdseccion and producto_id = '[__producto_id__]' and valor_atributo != 0 and valor_atributo != 'NULL' and PRODUCTO_ATRIBUTOS.print_value = 1) 
    	             + (select count(*) from ACCESORIOS_COCHE where prdseccion_id = id_prdseccion and ficha_id = producto_id))</expresion>
    	             <condicion operador="!=">0</condicion>
        </field> -->

        <field id="valores" local="true" showObjTabla="true" >
    <!--	    <attribute id="Etiqueta">nombre_seccion</attribute> -->
    	    <label posx="5" posy="+1"></label>
    	    <helper xml="producto_atributos_valores_qry.xml" type="object">
            <parameter source="producto_id" target="producto_id" />
            <parameter source="cotizacion_id" target="cotizacion_id" />
    		<parameter source="id_prdseccion" target="prdseccion_id" />
    	    </helper>
        </field>


        <field id="Panas" local="true" showObjTabla="true" >
    	    <label posx="5" posy="+0.5"></label>
    	    <helper xml="producto_panas.xml" type="object" dir="/">
            <parameter source="cotizacion_id" target="cotizacion_id" />
    		<parameter source="producto_id" target="producto_id" />
    		<parameter source="id_prdseccion" target="prdseccion_id" /> 
    	    </helper>
        </field>
      
        <field id="muestra_ft" noshow="true" local="true">
            <valor>1</valor>
        </field>

        <field id="obs" local="true" showObjTabla="true" >
    	    <label posx="5" posy="+0.5"></label>
    	    <helper xml="accesorios_coche_qry.xml" type="object" dir="/produccion/man/">
            <parameter source="cotizacion_id" target="cotizacion_id" />
    		<parameter source="producto_id" target="ficha_id" />
    		<parameter source="id_prdseccion" target="prdseccion_id" />
            <parameter source="muestra_ft" target="muestra_ft" /> 
    	    </helper>
        </field>
	
        <order>
            
            <field id="orden_seccion" />
            <field id="nombre_seccion" />

        </order>
    </table>
</form>	   
</histrix>