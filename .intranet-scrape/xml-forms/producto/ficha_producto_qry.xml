<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="card" subtipo="vertical" _imprime="false" _autoprint="true"  grid="98%,10"   inserta="false" 
 path="fotos/coches" 

>
<title>Sección</title>
<obs></obs>
<form >
    <table id="PRODUCTO_SECCION">
        <title>Ficha de Producto</title>

    <field id="producto_id" local="true" noshow="true">
        <detalle>producto_id</detalle>
        <label>Unidad</label>
    </field>

    <field id="cotizacion_id" local="true" noshow="true">
        <detalle>cotizacion_id</detalle>
        <label>Cotiz</label>
    </field>

    <field id="activa_seccion" noshow="true">
        <condicion operador="=">0</condicion>
    </field>

        <field id="id_prdseccion" autoinc="true" noshow="true">
            <label>Código</label>
            <detalle>prdseccion_id</detalle>
        </field>
        <field id="orden_seccion" noshow="true">
            <label>Orden</label>
            <help>Orden de impresión</help>
        </field>
        <field id="nrofab" noshow="true" local="true" />
                                          
        <field id="nombre_seccion"  style="font-weight:bold;" lblsize="90"  PDFbold="true" PDFsize="15"   PDFcolor="ffffff" PDFbackgroundColor="555555">
            <label >Secciones</label>
            <help>Nombre de la Sección</help>
        </field>

