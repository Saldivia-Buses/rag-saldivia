<?xml version="1.0" encoding="UTF-8"?>
<histrix  tipo="grid"  deleteRow="false" imprime="false" procesa="true" inserta="false">
	<title>Atributos</title>
	<obs/>
	<form>
		<table id="PRODUCTO_ATRIBUTO_HOMOLOGACION">
			<movimientos>
		    	<relacion id="producto_homolog_atributo_del.xml" />
				<relacion id="producto_homolog_atributo_ins.xml" />
		    </movimientos>
			<titulo>Controles</titulo>
			<filters auto="true">

			<field id="homologacion_id">
				<label modpos="nobr">Homolog.Origen</label>
				<operador>=</operador>
			</field>

			<field id="prdseccion_id">
				<label _modpos="nobr">Sección</label>
				<operador>=</operador>
			</field>

			</filters>

			<field id="prdatributo_id" noshow="true">
				<label>Ctrl</label>
				<detalle>id_prdatributo</detalle>
			</field>

			<field id="nombre_ayudas" noshow="true">
                <expression>CONCAT(nombre_atributo, ' - ', descrip_cotizacion)</expression>
            </field>

			<field id="id_prdatributo" noshow="true">
				<label>ProdControl</label>
				<expression>PRODUCTO_ATRIBUTO_HOMOLOGACION.prdatributo_id</expression>
			</field>

			<field id="graba_homologacion" noshow="true" local="true">
				<label>Homologacion</label>
			</field>

			<field id="id_homologacion" noshow="true" local="true">
			    <if exp="true">
				<true>graba_homologacion</true>
				<false>'0'</false>
			    </if>
			</field>

        <field id="homologacion_id" noshow="true" _local="true">
          <label>Descripcion</label>
          <helper type="combo" xml="combo_homologacion_modelo.xml" dir="/fabricacion">
          	      <field id="baja" noshow="true">
        			<condicion operador="=">0</condicion>
      			  </field>
          </helper>

       </field>

		  <field id="controlo" editable="true" deshabilitado="false" local="true">
		  		<label>Controla</label>
		  		<tipo>check</tipo>
		  		<valor>1</valor>
		  </field>

	      <field id="homologacion_id_destino" local="true" _noshow="true">
	      	<label>Hom.Dest</label>
	      </field>

			<field id="orden_atributo" tabla="PRODUCTO_ATRIBUTOS" noshow="true">
				<label>Orden</label>
				<size>3</size>
			</field>

			<field id="prdseccion_id" tabla="PRODUCTO_ATRIBUTOS">
				<label>Sección</label>
					<helper id="PRODUCTO_SECCION" type="combo" empty="true">
                    <field id="id_prdseccion" />
                    <field id="nombre_seccion" />
					<field id="activa_seccion" oculto="true">
                		<condicion operador="=">0</condicion>
                	</field>
					</helper>
			</field>

			<field id="nombre_atributo" tabla="PRODUCTO_ATRIBUTOS">
				<label>nombre</label>
				<size>30</size>
			</field>

			<order>
				<field id="prdseccion_id" tabla="PRODUCTO_ATRIBUTOS"/>
				<field id="orden_atributo" tabla="PRODUCTO_ATRIBUTOS"/>
			</order>
		</table>
		<join tipo="left">
		    <table id="PRODUCTO_ATRIBUTOS">
			<field id="id_prdatributo">
			    <condicion operador="=">PRODUCTO_ATRIBUTO_HOMOLOGACION.prdatributo_id</condicion>	
			</field>
		    </table>
		</join>
	</form>
</histrix>
