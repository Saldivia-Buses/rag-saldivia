<?xml version="1.0" encoding="utf-8"?>
<histrix tipo="fichaing" preFetch="true" inserta="false" imprime="false" modifica="false" confirma="Eliminar Ficha" cancel="false">
    <title>Eliminar Ficha Completa</title>
    <obs></obs>
    <eventos>
        <event id="procesar">close</event>
        <event id="procesar">reload</event>
    </eventos>
    <form>
        <table id="PEDCOTIZ" label="Eliminar Ficha Completa">

            <movimientos>
                <relacion id="producto_borrar_ficha_pedcotiz_del.xml" />
                <relacion id="producto_borrar_ficha_productos_del.xml" />
                <relacion id="producto_borrar_ficha_accesorios_coche_del.xml" />
            </movimientos>

            <field id="id" deshabilitado="true" noshow="true" valauto="true">
                <label>id</label>
                <help>id de Unidad.</help>
            </field>

            <field id="nrocha" deshabilitado="true" esClave="true">
                <label>N.Fab.</label>
            </field>

            <field id="estado_ficha_venta" deshabilitado="true">
                <label>Estado</label>
                <help>Estado Ficha de Venta</help>
                <expression>CASE WHEN PEDCOTIZ.estado_ficha = 0 THEN 'Borrador'
                                 WHEN PEDCOTIZ.estado_ficha = 1 THEN 'Publicada'
                                 WHEN PEDCOTIZ.estado_ficha = 2 THEN 'Comercial' ELSE '' END</expression>
            </field>

            <field id="ctafan" tabla="CCTCUENT" deshabilitado="true">
                <label>Cliente</label>
            </field>

            <field id="homologacion_id" deshabilitado="true">
                <label>Homologación</label>
                <helper type="combo" xml="combo_homologacion_modelo.xml" dir="/fabricacion" empty="true">
                    <field id="baja" oculto="true">
                        <condicion operador="=">0</condicion>
                    </field>
                </helper>
            </field>

            <field id="mensaje_alerta" local="true" style="font-size: 15px; color: red;" deshabilitado="true">
                <label>#</label>
                <valor>Está a punto de eliminar la ficha de venta detallada</valor>
                <size>40</size>
            </field>

       </table>

        <join>
            <table id="CCTCUENT">
                <field id="ctacod">
                    <condicion operador="=">PEDCOTIZ.ctacod</condicion>
                </field>
                <field id="siscod">
                    <condicion operador="=">'02'</condicion>
                </field>
            </table>
        </join>

    </form>
</histrix>