<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="grid" subtipo="vertical" paginar="100" inserta="false" modifica="false" borra="false" deleteRow="false" preloadData="false" procesa="true" transaccional="true">
    <title>Productos</title>
    <obs></obs>
    <form>
        <table id="PRODUCTOS">

            <filters>
                <field id="descripcion_producto">
                    <label>Ficha Base</label>
                    <help>Nro Unidad</help>
                    <operador>=</operador>
                </field>
            </filters>

            <movimientos>
                <relacion id="productos_duplicar_ins.xml" />
            </movimientos>

            <field id="id_producto" autoinc="true" noshow="true" tipoOrden="DESC" />

            <field id="id" tabla="PEDCOTIZ" noshow="true" />

            <field id="login" local="true" noshow="true">
                <valor eval="true">$_SESSION['login']</valor>
            </field>

            <field id="nrocha" tabla="PEDCOTIZ" esClave="true" deshabilitado="true">
           	    <label>Nro</label>
    	        <detalle>nrofab</detalle>
                <attribute id="linkdes">nrocha</attribute>
                <helper type="link" xml="ficha_venta_qry.xml" dir="/ventas" modal="true" title="Ficha Producto">
                    <parameter source="id_producto" target="producto_id"/>
                    <parameter source="id_producto" target="id"/>
                    <parameter source="nrocha" target="nrofab"/>
                </helper>        
            </field>

            <field id="ctacod" tabla="PEDCOTIZ">
                <label>Cliente</label>
                <help>Codigo de Cuenta</help>
                <tabla_ex condes="true" id="CCTCUENT">
                    <field id="ctacod" />
                    <field id="ctafan2">
                        <expression>CCTCUENT.ctafan</expression>
                    </field>
                    <field id="siscod" oculto="true">
                        <condicion operador="=">'02'</condicion>
                    </field>
                    <field id="baja" oculto="true">
                        <condicion operador="=">0</condicion>
                    </field>
                </tabla_ex>
            </field>        

            <field id="descripcion_producto" noshow="true" required="true">
                <size>30</size>
            </field>

            <field id="homologacion">
                <label>Homologacion</label>
                <expression>PEDCOTIZ.homologacion_id</expression>
                <helper type="combo" xml="combo_homologacion_modelo.xml" dir="/fabricacion" /> 
            </field>

            <field id="deshabilitado_producto" noshow="true">
                <expression><![CDATA[
                    SELECT IF(COUNT(*) > 0, 'false', 'true') FROM CHASIS  
                        JOIN HOMOLOGMOD ON HOMOLOGMOD.modcha = CHASIS.modcod
                                       AND HOMOLOGMOD.marcod = CHASIS.marcod                                    
                        WHERE HOMOLOGMOD.id_homologacion = PEDCOTIZ.homologacion_id
                          AND CHASIS.nrocha NOT IN (SELECT PC.nrocha FROM PEDCOTIZ PC WHERE PC.nrocha IS NOT NULL) ]]></expression>
            </field>

            <field id="descripcion_producto_nuevo" local="true" editable="true" deshabilitado="false">
                <label>Nueva Ficha</label>
                <helper type="combo" xml="combo_chasis_sin_ficha.xml">
                    <field id="homologacion_id" oculto="true" local="true" />
                </helper>
                <attribute id="deshabilitado">deshabilitado_producto</attribute>
            </field>

            <field id="marco" local="true" deshabilitado="false">
                <label>Duplicar</label>
                <tipo>check</tipo>
                <attribute id="deshabilitado">deshabilitado_producto</attribute>
            </field>

            <field id="homologacion_id" tabla="PEDCOTIZ" editable="true" noshow="true">
               <label>Homol</label>                
                <actualiza>
                    <field id="descripcion_producto_nuevo" destino="homologacion_id" />
                </actualiza>
            </field>

	       <order>
	           <field id="id_producto" />
	       </order>

        </table>

        <join tipo="left">
	        <table id="PEDCOTIZ">
	            <field id="id">
		            <condicion operador="=">id_producto</condicion>
	            </field>
	        </table>
        </join>

    </form>	   
</histrix>