<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta">
  <title>IVA COMPRAS</title>
  <obs/>
  <form >
    <table id="IVACOMPRAS" label="IVA COMPRAS" styleTbody="height:300px;overflow-x:hidden;">
      <field id="fecreg" oculto="true">
        <label>Registrado</label>
        <help></help>
      </field>
      <field id="feciva">
        <label>Fecha</label>
        <help></help>
      </field>
      <!--                  <field id="comcod">
        <label>Cod.Comp.D.G.I.. </label>
        <help>TIPO DE COMPROBANTE SEGUN D.G.I. (RG 3419 - ANEXO VI ). </help>
        </field>
        -->
      <field id="abreviacion_concepto" tabla="REG_CONCEPTOS">
        <label>Conc</label>
        <tipo>varchar</tipo>
      </field>
      <field id="codlet">
        <label>L</label>
        <help></help>
      </field>
      <field id="nronpv">
        <label>Npv</label>
        <help></help>
        <format>%04d</format>
      </field>
<!--        <field id="regmin" tabla="CCTMOVIM" linkint="ctbregis2.xml">
          <label>regmin</label>
          <tipo>integer</tipo>
          <valor>0</valor>
          <paring destino="regmin">regmin</paring>
          <paring destino="regfec">fecreg</paring>          
        </field>    
      <field id="asi"  >
        <expression>select sum(CTBREGIS.regimp) / 2 from CTBREGIS where CTBREGIS.regfec = IVACOMPRAS.fecreg and CTBREGIS.regmin = CCTMOVIM.regmin and CTBREGIS.siscod = '10' </expression>
        <label>Asiento</label>
        <tipo>numeric</tipo>
      </field>    -->  

      <field id="nrocom" linkint="facdetal.xml" linkdes="Ver detalle del Comprobante">
        <label>Numero</label>
        <help></help>
        <format>%010d</format>
        <paring destino="nrofac">nrocom</paring>
        <paring destino="nropue">nronpv</paring>
        <paring destino="ctacod">ctacod</paring>
        <paring destino="regfec">feciva</paring>        
      </field>
      <!--
        <field id="npvnro">
          <expression>CONCAT({ fn CONVERT( IVACOMPRAS.nronpv, SQL_CHAR) } , { fn CONVERT( IVACOMPRAS.nrocom, SQL_CHAR) })</expression>
          <label>Comprobante</label>
          <tipo>varchar</tipo>
        </field>
        -->
      <field id="ctacod" oculto="true">
        <label>Cuenta</label>
        <help></help>
      </field>
      <field id="ctanom">
        <label>Proveedor</label>
        <expression>SUBSTRING(IVACOMPRAS.ctanom,1,20)</expression>
        <help></help>
      </field>
      <!--      <field id="tipdoc">
          <label>Doc</label>
          <help>Codigo de Documento</help>
            <tabla_ex id="FSMDOCUM">
              <field id="doccod"></field>
              <field id="docnom"></field>
            </tabla_ex>          
          
        </field>
        -->
      <field id="cuit_cuenta">
        <label>CUIT</label>
        <expression>CASE WHEN IVACOMPRAS.nrodoc = '' THEN REPLACE(REG_CUENTA.cuit_cuenta, '-', '') ELSE IVACOMPRAS.nrodoc END</expression>
      </field>
      <!--        <field id="ivacod">
          <label>Categoria I.V.A. </label>
          <help>
          </help>
          <tabla_ex id="FSMCTIVA">
            <field id="ivacod"></field>
            <field id="ivanom"></field>
          </tabla_ex>
        </field>-->
