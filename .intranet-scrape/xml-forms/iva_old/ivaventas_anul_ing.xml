<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="ing" inserta="false" modifica="false" preloadData="false">
	<title>IVA VENTAS</title>
	<obs></obs>
	<form>
		<table id="IVAVENTAS" label="IVA VENTAS">
			<movimientos _cabecera="ivaventas_anul_cab.xml">
				<relacion id="ivaventas_ingmov.xml"></relacion>
			</movimientos>
			<filters>
				<field id="feciva">
					<label>Fecha</label>
					<valor>today</valor>
				</field>
				<field id="fecreg">
					<label modpos="nobr">Fecha Registracion</label>
					<help>Fecha de Registracion</help>
					<valor>today</valor>
				</field>
				<field id="ctacod" deshabilitado="true" >
					<label>Cuenta</label>
					<help>Código de Cuenta</help>
					<valor>0</valor>
				</field>
				<field id="ctanom" _deshabilitado="true">
					<label modpos="nobr">Clente</label>
					<help>Nombre</help>
					<valor>ANULADO</valor>
					<size>40</size>
				</field>
				<field id="codcom">
					<label modpos="nobr">Conc</label>
					<help>Concepto</help>
				</field>
				<field id="codlet" >
					<label>Letra</label>
					<help>Letra del Comprobante</help>
				</field>

				<field id="nronpv" >
					<label modpos="nobr">Npv</label>
					<help>Punto de Venta</help>
					<format>%04d</format>
				</field>
	
				<field id="nrodesde">
					<label modpos="nobr">Nro Desde</label>
				</field>
				<field id="nrohasta">
					<label modpos="nobr">Nro Hasta</label>
				</field>

				<!--
				<field id="regmin" tabla="CCTMOVIM" noshow="true">
