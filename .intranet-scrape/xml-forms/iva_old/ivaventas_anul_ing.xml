				<tipo>integer</tipo>
				<valor>0</valor>
				<help>Minuta</help>
			</field>
			-->
			<field id="nrodoc" deshabilitado="true" >
				<label modpos="nobr">CUIT</label>
				<help>Número de CUIT</help>
				<valor>00-00000000-0</valor>
			</field>

			<!--				<field id="gravado" suma="true">
			<expression>impgra * (case when conimp = 1 then 1 else -1 end)</expression>
			<label>Gravado</label>
		</field>
		<field id="impcod" tabla="IVAIMPORTES">
			<label>Impuesto</label>
			<tabla_ex id="IVAIMPUESTOS">
				<field id="impcod"></field>
				<field id="impnom"></field>
			</tabla_ex>
			<tipo>varchar</tipo>
		</field>

		<field id="Importe"  suma="true">
			<expression>impimp * (case when conimp = 1 then 1 else -1 end)</expression>
			<label>Importe</label>
		</field>
		<field id="execom" norepeat="true" suma="true">
			<label>Exento</label>
		</field>

		<field id="NOG" norepeat="true" suma="true">
			<label>No Grav.</label>
			<expression>nogcom * (case when conimp = 1 then 1 else -1 end)</expression>

		</field>
		-->
		<field id="totcom" deshabilitado="true">
			<label >Total</label>
			<valor>0</valor>
		</field>
	</filters>

	<field id="_ORDEN" local="true" noshow="true"/>
	<field id="feciva" local="true">
		<label>Fecha</label>
		<help>Fecha del Comprobante</help>
		<valor>today</valor>
	</field>
	<field id="fecreg" local="true">
		<label modpos="nobr">Fecha Registracion</label>
		<help>Fecha de Registracion</help>
		<valor>today</valor>
	</field>
	<field id="ctacod" local="true" deshabilitado="true" >
		<label>Cuenta</label>
		<help>Código de Cuenta</help>
		<valor>0</valor>
	</field>
	<field id="ctanom" local="true" _deshabilitado="true">
		<label modpos="nobr">Clente</label>
		<help>Nombre</help>
		<valor>ANULADO</valor>
		<size>40</size>
	</field>
	<field id="codcom" local="true">
		<tabla_ex id="CCTCONCE">
			<field id="concod"></field>
			<field id="condes"></field>
			<field id="siscod">
				<condicion operador="=">02</condicion>
			</field>
		</tabla_ex>
		<label modpos="nobr">Conc</label>
		<help>Concepto</help>
	</field>
	<field id="codlet" local="true">
		<label>Letra</label>
		<help>Letra del Comprobante</help>
	</field>

	<field id="nronpv" sincelda="true" local="true">
		<label modpos="nobr">Npv</label>
		<help>Punto de Venta</help>
		<format>%04d</format>
	</field>
	<field id="nrocom" sincelda="true" local="true" validRow="true">
		<label modpos="nobr">Numero</label>
		<help>Número de comprobante</help>
		<if exp="_ORDEN &gt;= (nrodesde + 0)  &amp;&amp; _ORDEN &lt;= (nrohasta + 0)">
			<true>_ORDEN</true>
			<false>0</false>
		</if>
	</field>

	<field id="nrodesde" local="true" noshow="true">
		<label modpos="nobr">Nro Desde</label>
	</field>
	<field id="nrohasta" local="true" noshow="true">
		<label modpos="nobr">Nro Hasta</label>
	</field>

