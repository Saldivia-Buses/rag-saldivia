<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta">
    <title>REGINFO_CV_COMPRAS_CBTE</title>
    <obs/>
    <form>
    	<table id="IVACOMPRAS" label="REGINFO_CV_COMPRAS_CBTE">
			
			<fieldGroup id="DEBUG" noshow="true" local="true" print="false" export="false">
				<field id="anio" />

				<field id="mes" />

				<field id="fecha_desde">
					<tipo>date</tipo>
				</field>

				<field id="fecha_hasta">
					<tipo>date</tipo>
				</field>

				<field id="archivo" />

				<field id="titulo">
					<setvar>titulo</setvar>
					<expression>CONCAT('[__anio__]', '[__mes__]','_[__archivo__]')</expression>
				</field>
			</fieldGroup>

			<fieldGroup id="tests" export="false" noshow="true">
				<field id="regmovim_id" noshow="false">
<label>id</label>
</field>
				<field id="_ORDEN" local="true" noshow="false" style="color:blue;font-weight:bold;" />

				<field id="iva_detalle" suma="true">
				    <expression>IF(IVACOMPRAS.ivacod = 6, LPAD(round(IVACOMPRAS.totcom * 100, 0), 15, '0'), LPAD(round(SUM(IVAIMPORTES.impimp - (impimp * (case when IVAIMPORTES.impcod &gt; 3 then 1 else 0 end))) * 100, 0), 15, '0'))</expression>
				    <!--<expression>LPAD(round(SUM(IVAIMPORTES.impimp - (impimp * (case when IVAIMPORTES.impcod &gt; 3 then 1 else 0 end))) * 100, 0), 15, '0')</expression>-->
				    <label>Imp. Liq.</label>
				    <tipo>integer</tipo>
				    <!--<condicion operador="!=">0</condicion>-->
				</field>

				<field id="style_cuit">
					<expression>IF(LPAD(REPLACE(CCTCUENT.ctanro, '-', ''), 20, 0) = 0 and (CASE WHEN IVACOMPRAS.codcom = 7 THEN '99' ELSE FSMDOCUM.codafip END) != '99', 'background-color:red;', '')</expression>
				</field>				
			</fieldGroup>

			<fieldGroup id="table_fields" export="false" noshow="true">

				<field id="fecreg">
					<condicion operador="&gt;=">STR_TO_DATE('[__fecha_desde__]', '%d/%m/%Y') AND IVACOMPRAS.fecreg &lt;= STR_TO_DATE('[__fecha_hasta__]', '%d/%m/%Y')</condicion>
				</field>

				<field id="pto_vta_bco" local="true">
					<label>Pto.Vta Banco</label>
				</field>

				<field id="ctacod" _noshow="false">
					<label>Cta</label>
				</field>
			</fieldGroup>

			<fieldGroup id="exportables">
				<field id="fecha_comp">
					<label>Fecha comp.</label>
					<expression>REPLACE(IVACOMPRAS.feciva, '-', '')</expression>
				</field>

				<field id="regconcepto_afip" >
					<label>Tipo comp.</label>
					<expression>LPAD((CASE WHEN IVACOMPRAS.codcom in (1, 36) and CCTMOVIM.movlet = 'A' THEN 1
 										   WHEN IVACOMPRAS.codcom = 2 and CCTMOVIM.movlet = 'A' THEN 2
 										   WHEN IVACOMPRAS.codcom = 3 and CCTMOVIM.movlet = 'A' THEN 3
										   WHEN IVACOMPRAS.codcom = 4 and CCTMOVIM.movlet = 'A' THEN 4
										   WHEN IVACOMPRAS.codcom in (1, 36) and CCTMOVIM.movlet = 'B' THEN 6
										   WHEN IVACOMPRAS.codcom = 2 and CCTMOVIM.movlet = 'B' THEN 7
										   WHEN IVACOMPRAS.codcom = 3 and CCTMOVIM.movlet = 'B' THEN 8
										   WHEN IVACOMPRAS.codcom = 4 and CCTMOVIM.movlet = 'B' THEN 9
										   WHEN IVACOMPRAS.codcom in (1, 36) and CCTMOVIM.movlet = 'C' THEN 11
										   WHEN IVACOMPRAS.codcom = 2 and CCTMOVIM.movlet = 'C' THEN 12
										   WHEN IVACOMPRAS.codcom = 3 and CCTMOVIM.movlet = 'C' THEN 13
  										   WHEN IVACOMPRAS.codcom = 7 THEN 83 END), 3, 0)</expression>
				</field>

				<field id="puesto_movimiento">
					<label>P.Vta.</label>
					<expression>LPAD(CCTMOVIM.movnpv, 5, 0)</expression>
				</field>

				<field id="nro_movimiento">
					<label>Nro Comprobant</label>
					<expression>LPAD(CCTMOVIM.movnro, 20, 0)</expression>
				</field>

				<field id="despacho_importacion">
					<label>Despacho Imp.</label>
					<expression>'                '</expression>
				</field>

				<field id="tipo_documento_id">
					<label>Cod documento</label>
					<expression>CASE WHEN IVACOMPRAS.codcom = 7 THEN '99' ELSE FSMDOCUM.codafip END</expression>
				</field>

				<field id="cuit_cuenta">
					<label>CUIT</label>
					<expression>LPAD(REPLACE(REPLACE(CCTCUENT.ctanro , '-', ''), '/', ''), 20, 0)</expression>
					<tipo>integer</tipo>
				</field>

				<field id="nombre_cuenta">
					<expression>RPAD(REPLACE(IF(IVACOMPRAS.ctanom != '',IVACOMPRAS.ctanom,CCTCUENT.ctanom),'Ñ', 'N'), 30, ' ')</expression>
					<label>Razon Social</label>
				</field>

				<field id="importe_movimiento">
					<expression>LPAD(round(IVACOMPRAS.totcom * 100, 0), 15, '0')</expression>
					<label>Total</label>
					<tipo>integer</tipo>
				</field>

				<field id="importe_nogravado">
					<label>No Grav</label>
					<expression>CASE WHEN CCTMOVIM.movlet IN ('B', 'C') THEN '000000000000000' ELSE LPAD(round(IVACOMPRAS.nogcom * 100, 0), 15, '0') END</expression>
					<tipo>integer</tipo>
				</field>

				<field id="importe_exento">
					<expression>CASE WHEN CCTMOVIM.movlet IN ('B', 'C') THEN '000000000000000' ELSE LPAD(round(IVACOMPRAS.execom * 100, 0), 15, '0') END</expression>
					<label>Exento</label>
					<tipo>integer</tipo>
				</field>

				<field id="percepciones_o_imp_val_agr">
					<expression>'000000000000000'</expression>
				</field>

				<field id="percepciones_o_imp_nac">
					<expression>'000000000000000'</expression>
				</field>

				<field id="importe_percepcion">
					<label>Percepcion</label>
					<expression>ifnull((LPAD(ROUND(sum(impimp * (case when IVAIMPORTES.impcod &gt; 3 then 1 else 0 end))*100, 0), 15, '0')),'000000000000000')</expression>
					<tipo>integer</tipo>
				</field>

				<field id="percepcion_imp_munic">
					<expression>'000000000000000'</expression>
				</field>

				<field id="impuestos_int">
					<expression>'000000000000000'</expression>
				</field>

				<field id="codigo_moneda">
					<label>Moneda</label>
					<expression>'PES'</expression>
				</field>

				<field id="tipo_cambio">
					<label>Tipo Cambio</label>
					<expression>'0001000000'</expression>
				</field>

				<field id="cantidad_alic">
					<label>Cant. alicuota</label>
					<expression>CASE WHEN CCTMOVIM.movlet IN ('B', 'C') THEN 0 ELSE (SELECT count(distinct(IVAIMPORTES.impali))
														FROM IVAIMPORTES 
														WHERE IVAIMPORTES.tipoiva = 1 
														  AND IVAIMPORTES.codcom = IVACOMPRAS.codcom 
														  AND IVAIMPORTES.nronpv = IVACOMPRAS.nronpv 
														  AND IVAIMPORTES.nrocom = IVACOMPRAS.nrocom 
														  AND IVAIMPORTES.ctacod = IVACOMPRAS.ctacod
														  AND IVAIMPORTES.feciva = IVACOMPRAS.fecreg
														  ) END</expression>
					<tipo>integer</tipo><!--AND IVAIMPORTES.impimp != 0--><!-- count(distinct(IVAIMPORTES.impali)) -->
				</field>

				<field id="codigo_operacion">
					<expression>CASE WHEN IVAIMPORTES.impimp = 0 THEN 'E' ELSE '0' END</expression>
				</field>

				<field id="cred_fisc_comp">
					<label>Credito Fiscal Comp</label>
					<expression>LPAD(round(sum(impimp *  (case when IVAIMPORTES.impcod = 1 then 1 else 0 end)) * 100, 0), 15, '0')</expression>
<!--					<expression>'000000000000000'</expression> -->
				</field>

				<field id="otros_tributos">
					<label>Otros Tributos</label>
					<expression>'000000000000000'</expression>
				</field>

				<field id="cuit_emisor">
					<label>Cuit Emisor</label>
					<expression>'00000000000'</expression>
				</field>

				<field id="denom_emisor">
					<label>Denom. Emisor</label>
					<expression>'                              '</expression>
				</field>

				<field id="iva_comision">
					<expression>'000000000000000'</expression>
				</field>

				<field id="fecha_vencimiento">
					<expression>REPLACE(CCTMOVIM.movvto, '-', '')</expression>
				</field>
			</fieldGroup>

	    <order>
		<field id="regmovim_id" />
	    </order>
            <group>
                <field id="id_ivacompra" tabla="IVACOMPRAS" />
            </group>

		</table>

        <join tipo="left">
            <table id="IVAIMPORTES">
                <field id="ctacod" oculto="true">
                    <condicion operador="=">IVACOMPRAS.ctacod</condicion>
                </field>
                <field id="codcom" oculto="true">
                    <condicion operador="=">IVACOMPRAS.codcom</condicion>
                </field>
                <field id="nrocom" oculto="true">
                    <condicion operador="=">IVACOMPRAS.nrocom</condicion>
                </field>
                <field id="nronpv" oculto="true">
                    <condicion operador="=">IVACOMPRAS.nronpv</condicion>
                </field>
                <field id="tipoiva" oculto="true">
                    <condicion operador="=">1</condicion>
                </field>   
                <field id="feciva" oculto="true">
                    <condicion operador="=">IVACOMPRAS.fecreg</condicion>
                </field>                
            </table>
        </join> 

        <join tipo="left">
            <table id="CCTMOVIM">
                <field id="id_regmovim">
                    <condicion operador="=">IVACOMPRAS.regmovim_id</condicion>
                </field>
            </table>
        </join>

        <join tipo="left">
            <table id="CCTCONCE">
                <field id="siscod">
			    	<condicion operador="=">'01'</condicion>
			    </field>
			    <field id="concod">
		      		<condicion operador="=">IVACOMPRAS.codcom</condicion>
		    	</field>
		  	</table>
		</join>

		<join tipo="left">
  			<table id="CCTCUENT">
    			<field id="siscod">
      				<condicion operador="=">'01'</condicion>
    			</field>
    			<field id="ctacod">
      				<condicion operador="=">IVACOMPRAS.ctacod</condicion>
    			</field>
  			</table>
		</join>

		<join tipo="left">
			<table id="FSMDOCUM">
		    	<field id="doccod">
		      		<condicion operador="=">CCTCUENT.doccod</condicion>
		    	</field>
		  	</table>
		</join>
		
	</form>
</histrix>