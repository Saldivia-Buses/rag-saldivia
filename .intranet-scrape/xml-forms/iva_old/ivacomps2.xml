      <field id="tipo_concepto">
        <label>Tipo Comp.</label>
        <expression>LPAD(REG_CONCEPTOS.tipo_concepto, 2, 0)</expression>
      </field>
      <field id="nronpv">
        <label>P.Vta.</label>
        <help></help>
        <expression>LPAD(IVACOMPRAS.nronpv, 4, 0)</expression>
      </field>
      <field id="nrocom">
        <label>Nro.Comp.</label>
        <expression>LPAD(IVACOMPRAS.nrocom, 20, 0)</expression>
      </field>
      
      <field id="feciva">
        <label>Fec.Comp.</label>
        <expression>REPLACE(IVACOMPRAS.feciva, '-', '')</expression>
      </field>
      <field id="nrodoc">
        <label>Cuit Inf.</label>
        <expression><![CDATA[CASE WHEN CHAR_LENGTH(REPLACE(REG_CUENTA.cuit_cuenta, '-', '')) = 11 THEN REG_CUENTA.cuit_cuenta ELSE REPLACE(nrodoc, '-', '') END]]></expression>
      </field>
      <field id="ctanom">
        <expression>RPAD(REPLACE(IVACOMPRAS.ctanom, 'Ñ', 'N'), 25, ' ')</expression>
        <label>Informado</label>
        <help></help>
        <size>25</size>
      </field>
      <field id="impLiq" _oculto="true" suma="true">
        <expression>LPAD(REPLACE(sum(impimp * (case when REG_CONCEPTOS.imputacion_concepto = 0 then -1 else 1 end) * (case when IVAIMPORTES.impcod = 1 then 1 else 0 end)) + sum(impimp * (case when REG_CONCEPTOS.imputacion_concepto = 0 then -1 else 1 end) * (case when IVAIMPORTES.impcod = 2 then 1 else 0 end)) + sum(impimp * (case when REG_CONCEPTOS.imputacion_concepto = 0 then -1 else 1 end) * (case when IVAIMPORTES.impcod = 3 then 1 else 0 end)), '.', ''), 12, 0)</expression>
        <label>Imp.Liquidado</label>
      </field>
      <field id="cuitVend">
        <label>Cuit Vend.</label>
        <expression>LPAD(0, 11, 0)</expression>
      </field>
      <field id="denomVend">
        <label>Vend.</label>
        <expression>LPAD(' ', 25, ' ')</expression>
      </field>
      <field id="ivaCom">
        <label>IVA Com.</label>
        <expression>LPAD(0, 12, 0)</expression>
      </field>


                      <field id="Total" oculto="true">
        <expression having="true">sum(impimp * (case when REG_CONCEPTOS.imputacion_concepto = 0 then -1 else 1 end) * (case when IVAIMPORTES.impcod = 1 then 1 else 0 end)) + sum(impimp * (case when REG_CONCEPTOS.imputacion_concepto = 0 then -1 else 1 end) * (case when IVAIMPORTES.impcod = 2 then 1 else 0 end)) + sum(impimp * (case when REG_CONCEPTOS.imputacion_concepto = 0 then -1 else 1 end) * (case when IVAIMPORTES.impcod = 3 then 1 else 0 end))</expression>
        <label>Liquidado</label>
        <condicion operador="&gt;">0</condicion>
      </field>
      
          


