      <order>
        
		<field id="IVACOMPRAS.feciva" />
		<field id="IVACOMPRAS.nronpv" />
		<field id="IVACOMPRAS.nrocom" />
      
      </order>      <filters>
        <field id="fecreg">
          <operador>>=</operador>
          <label>Desde Fecha</label>
          <valor>today</valor>
        </field>
        <field id="fecreg">
          <operador>&lt;=</operador>
          <label>Hasta Fecha</label>
          <valor>today</valor>
        </field>
      </filters>
    </table>
		<join tipo="left">
			<table id="REG_CUENTA">
				<field id="subsistema_id">
					<condicion operador="=">'01'</condicion>
				</field>
				<field id="nro_cuenta">
					<condicion operador="=">IVACOMPRAS.ctacod</condicion>
				</field>
			</table>
		</join>		

		<join tipo="left">

			<table id="REG_MOVIMIENTOS">
				<field id="subsistema_id" oculto="true">
					<condicion operador="=">'01'</condicion>
				</field>				
				<field id="concod" >
					<condicion operador="=">IVACOMPRAS.codcom</condicion>
				</field>
				<field id="regcuenta_id" >
					<condicion operador="=">REG_CUENTA.id_regcuenta</condicion>
				</field>
				<field id="nro_movimiento" >
					<condicion operador="=">IVACOMPRAS.nrocom</condicion>
				</field>
				<field id="puesto_movimiento" >
					<condicion operador="=">IVACOMPRAS.nronpv</condicion>
				</field>
			    <field id="fecha_movimiento" >
					<condicion operador="=">IVACOMPRAS.feciva</condicion>
				</field>				

			</table>
		</join>			


		<join tipo="left">
			<table id="REG_CONCEPTOS">
				<field id="subsistema_id" oculto="true">
					<condicion operador="=">'01'</condicion>
				</field>
				<field id="cod_concepto">
					<condicion operador="=">IVACOMPRAS.codcom</condicion>
				</field>
			</table>
		</join>
    
		<join tipo="right ">
		  <table id="IVAIMPORTES">
		    <field id="tipoiva" oculto="true">
		      <condicion operador="=">1</condicion>
		    </field>
		    <field id="codcom">
		      <condicion operador="=">IVACOMPRAS.codcom</condicion>
		    </field>
		    <field id="codlet">
		      <condicion operador="=">IVACOMPRAS.codlet</condicion>
		    </field>
		    <field id="nronpv">
		      <condicion operador="=">IVACOMPRAS.nronpv</condicion>
		    </field>
		    <field id="nrocom">
		      <condicion operador="=">IVACOMPRAS.nrocom</condicion>
		    </field>
		    <field id="ctacod">
		      <condicion operador="=">IVACOMPRAS.ctacod</condicion>
		    </field>
	            <field id="feciva" >
	              <condicion operador="=">IVACOMPRAS.fecreg</condicion>
	    	    </field>
		    
		  </table>
		</join>
  

