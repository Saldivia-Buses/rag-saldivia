<?xml version="1.0" encoding="ISO-8859-1" ?>
   <histrix tipo="ing" llenoTemporal="false" imprime="false" inserta="false">
       <title>Cuenta Corriente</title>
        <obs></obs>
				<consulta>
					<table id="CCTMOVIM" label="Movimientos">
						<importar xml="imputacion_rc_cctmovim_select.xml"  label="Seleccionar Facturas" titulo="Seleccione Facturas">
							<field id="ctacod">ctacod</field>
						</importar>					
						<movimientos cabecera="imputacion_rc_cab.xml">
							<relacion id="imputacion_rc_cctmovim_update_ingmov.xml"></relacion>  						
							<relacion id="imputacion_rc_cctimput_ingmov.xml"></relacion>  						
						</movimientos> 						
						<field id="siscod" oculto="true">
							<label>Cod.</label>
							<help>
							</help>
						</field>
						<field id="sisprv" noshow="true" local="true">
							<label>prv</label>
							<valor>05</valor>
						</field>						
						<field id="ctacod" noshow="true">
							<label>Cod.</label>
							<help>Codigo de Cuenta </help>

						</field>
						<!--		        <condicion operador="=">20</condicion> 
							-->
						<field id="movnpv" deshabilitado="true">
							<label>P.V.</label>
							<help> Punto Venta</help>
							<formato>%04d</formato>
						</field>
						<field id="movnro" deshabilitado="true">
							<label>Numero</label>
							<help> Numero Comprobante</help>
							<formato>%12d</formato>
							
						</field>
						<field id="concod" noshow="true" deshabilitado="true">
							<label>concod</label>
						</field>						
						<field id="concepto" deshabilitado="true">
							<expresion>condes</expresion>
							<label>Cod.Concepto</label>
							<help>
							</help>
							<tipo>string</tipo>
		<!--		      <tabla_ex id="CCTCONCE">
							
							<field id="concod"></field>
							<field id="condes"></field>
							</tabla_ex>
							-->
						</field>
						<field id="movfec" deshabilitado="true">
							<label>Fecha </label>
							<help></help>
						</field>
						<!--          <field id="movvto">
						<label>Venc. </label>
						<help> </help>
						</field>
						-->
						<field id="movimp" deshabilitado="true">
							<label>Importe</label>
							<help>
							</help>
						</field>
						<field id="movsal" suma="true">
							<label>Imputado</label>
							<help>Imputado</help>
							<condicion operador="!=">0</condicion>
						</field>
						<field id="salant" local="true" noshow="true">
							<label>salant</label>
							<help></help>
						</field>
						<field id="newsaldo" local="true" deshabilitado="true">
							<label>Saldo</label>
							<if exp="(salant + movsalCAB) &gt;= 0" operador="=">
								<true>salant - abs(movsalCAB)</true>
								<false>salant - movsal</false>
							</if>
							<tipo>numeric</tipo>
						</field>	
						<order>
							<field id="movfec"></field>
						</order>
					</table>
					
					<join tipo="left">
						<table id="CCTCONCE">
							<field id="siscod" oculto="true">
								<label>cctcuent.siscod</label>
								<condicion operador="=">
									CCTMOVIM.siscod</condicion>
							</field>
							
							<field id="concod" oculto="true">
								<condicion operador="=">
									CCTMOVIM.concod</condicion>
							</field>
							
							<field id="condes" oculto="true">
							</field>
							
						</table>
					</join>
				</consulta>
        </histrix>