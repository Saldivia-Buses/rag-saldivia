			<field deshabilitado="true" id="nrocar" tabla="PEDCOTIZ">
<!--				<expression>PEDCOTIZ.nrocar</expression> -->
				<expression>case when PEDCOTIZ.nrocar != '' then PEDCOTIZ.nrocar else TURNOSPRODUCCION.nrocar end</expression>

				<label >Mod.</label>
				<help/>
				<tabla_ex id="CARROCERIA">
					<field id="nrocar">
					</field>
					<field id="desabv">
					</field>

					<field id="siscod">
						<condicion operador="=">03</condicion>
					</field>
				</tabla_ex>
				<tipo>varchar</tipo>
			</field>

			<field deshabilitado="true" id="cantasi" tabla="PEDCOTIZ">
<!--				<expression>PEDCOTIZ.cantasi</expression> -->
				<expression>case when PEDCOTIZ.cantasi != '' then PEDCOTIZ.cantasi else TURNOSPRODUCCION.cantasi end</expression>

				<label >A</label>
				<help/>
				<tipo>integer</tipo>
			</field>
