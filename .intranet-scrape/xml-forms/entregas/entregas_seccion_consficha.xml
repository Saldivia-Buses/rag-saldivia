<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" _autoupdate="120" sqlhardcoded="true" style="height:100%;" limit="[__limits__]">
	<title>ENTREGAS POR SECCION</title>
	<obs/>
	<form >
		<table id="TURNOSPRODUCCION" label="ENTREGAS POR SECCION"  showCantidad="false" >

			<field id="puestos" local="true" noshow="true">
				<label>puestos</label>
			</field>
			
			<field id="_ORDEN" local="true" noshow="true">
				<tipo>integer</tipo>
			</field>
			
			<field id="numorden" local="true" noshow="true">
			<label>order</label>
			    <if exp="true">
				<true>_ORDEN - 1 + puestos</true>
				<false>0</false>
			    </if>
			</field>			
			<field id="coches" local="true" noshow="true"/>
			
			
			<field id="limits" local="true" noshow="true">
			
				<setvar>limit</setvar>
			</field>
      
            <field id="fechaing2" _PDFanchofijo="true" oculto="true">
          <expression>fechaing</expression>
            </field>
            <field id="linea_id" noshow="true">
            </field>

			<field id="primercoche" noshow="true">
			    <expression having="false">(select  T.fechaing  from TURNOSPRODUCCION as T
				    left join PEDCOTIZ as P on P.nrocha = T.nrofab
				    where (P.terminacion = '0000-00-00' or ( month(P.terminacion) = [__mes__] and year(P.terminacion) = [__year__])) and
				    year(T.fechaing ) = [__year__]
				    order by (T.fechaing ) limit 1)</expression>
				    <condicion operador="&lt;=">fechaing</condicion>
			</field>

			<field id="fechaSalida" esClave="true"	>
				<label modpos="nobr" >Sale</label>
			
		            <expression sql="true">select fechaing  from TURNOSPRODUCCION left join PEDCOTIZ on PEDCOTIZ.nrocha = TURNOSPRODUCCION.nrofab where 
			        fechaing >= '[__year__]-[__mes__]-01' 
			        order by fechaing  limit [__numorden__] , 1</expression>
			        <tipo>date</tipo>
			</field> 
<!--			<field id="sale2" esClave="true">
				<label modpos="nobr" >Sale</label>
				<expression having="false">(case when ingresoLinea != '0000-00-00' then ingresoLinea else fechaing end)</expression>
				<tipo>date</tipo>
			</field>
-->			
			
			<field id="nrofab" linkint="fichaventas.xml" linkdes="Ver Ficha de Ventas">
				<label modpos="nobr" style="color:#444;font-weight:bold;">Nro.</label>
				<help>Numero de Fabricacion</help>
				<ayuda_ex id="CHASIS">
					<field id="nrocha"/>
					<field id="chades"/>
				</ayuda_ex>
				<!--<format><![CDATA[<b>%d</b>]]></format>
-->
				<paring destino="nrocha">nrofab</paring>
			</field>
			<field id="siscli" local="true" oculto="true" >
				<valor>'02'</valor>
			</field>
			<field deshabilitado="true" id="ctaconces" tabla="CHASIS" noshow="true">
				<expression>case when CONCESIONARIO.ctacod >= 0 then CONCESIONARIO.ctacod else 0 end</expression>
				<tipo>integer</tipo>

			</field>

			<field deshabilitado="true" id="ctacod" tabla="PEDCOTIZ" linkint="cctconta_consulta.xml" linkdes="Ver medios de Contacto">
<!--				<expression>PEDCOTIZ.ctacod</expression> -->
				<expression>case when PEDCOTIZ.ctacod != '' then PEDCOTIZ.ctacod else TURNOSPRODUCCION.ctacod end</expression>

				<label >Cliente</label>
				<help>Codigo de Cuenta</help>
				<tabla_ex condes="true" id="CCTCUENT">
					<field id="ctacod"/>
					<field id="ctafan">
						<expression>LEFT(ctafan, 17)</expression>
					</field>
					<field id="siscod" oculto="true">
						<condicion operador="=">'02'</condicion>
					</field>
				</tabla_ex>
				<tipo>varchar</tipo>
				<paring destino="ctacod">ctacod</paring>
				<paring destino="siscod">siscli</paring>
			</field>
			<field esClave="true" id="fechaing" PDFanchofijo="true" noshow="true" tipoOrden="DESC"> 
				<label >Entra</label>
				<help>Fecha de Ingreso a Linea</help>


			</field>
<!--			<field id="offset" noshow="true" deshabilitado="true">
				<expression>
					select count(*) from TURNOSPRODUCCION as TUR where TUR.fechaing &gt;= TURNOSPRODUCCION.fechaing and TUR.fechaing &lt;= now()</expression>
				<tipo>integer</tipo>
			</field>-->

<!--			<field id="fechasal" esclave="true" >
				<label modpos="nobr">Sale</label>
				<help>Fecha de Salida de Linea</help>

			</field> -->
			<field deshabilitado="true" id="moddes" tabla="MODCHASIS">
<!--				<expression>MODCHASIS.moddes</expression> -->
				<expression>case when MODCHASIS.moddes != '' then MODCHASIS.moddes else TURNOSPRODUCCION.modeloChasis end</expression>

				<label >Mod</label>
				<help/>
				<tipo>varchar</tipo>
			</field>
			<field deshabilitado="true" id="chasis" tabla="CHASIS" linkint="chasis_cons.xml" linkdes="Ver Datos del Chasis">
				<expression>RIGHT(CHASIS.chasis, 6)</expression>
				<label>Chasis</label>
				<help>Numero de Serie del chasis</help>
				<paring destino="nrocha">nrofab</paring>
			</field>

			<field deshabilitado="true" id="conces" tabla="CHASIS" linkint="cctconta_consulta.xml" linkdes="Ver medios de Contacto">
<!--				<expression>CHASIS.conces</expression> -->
				<expression>case when CHASIS.conces != '' then CHASIS.conces else TURNOSPRODUCCION.idconces end</expression>
			-	<tabla_ex vacio="true" xml="concesionario.xml"/>
				<label>Conc</label>
				<help>Concesionario</help>
				<tipo>varchar</tipo>
				<paring destino="ctacod">ctaconces</paring>
				<paring destino="siscod">siscli</paring>
			</field>

