					<field id="siscod">
						<condicion operador="=">03</condicion>
					</field>
				</tabla_ex>
				<tipo>integer</tipo>
			</field> -->

<!--			<field id="audio">
				<expression>case when PEDCOTIZ.preair = 1 then 'prep' when PEDCOTIZ. </expression>
			</field> -->
			<field id="aire">
				<expression>PEDCOTIZ.marair</expression>
				<label>A/A</label>
				<tabla_ex id="MARCAAIR" vacio="true" indexvacio="0" valorvacio="NO">
					<field id="marair">

					</field>
					<field id="desair">
					<expression>LEFT(desair, 5)</expression>
					</field>

					<field id="siscod">
						<condicion operador="=">03</condicion>
					</field>
				</tabla_ex>
				<tipo>varchar</tipo>
			</field>

			<field id="marasi" tabla="PEDCOTIZ">
				<expression>PEDCOTIZ.marasi</expression>
				<label >Marca</label>
				<help/>
				<tabla_ex xml="marcaasi.xml">

					<field id="marasi">
					</field>
					<field id="asides">
						<expression>LEFT(asides, 5)</expression>

					</field>
					<field id="siscod">
						<condicion operador="=">03</condicion>
					</field>
				</tabla_ex>
			</field>


			<field id="mes"  local="true" noshow="true">

				<tipo>integer</tipo>
			</field>
			<field id="year" local="true" noshow="true">
				<tipo>integer</tipo>
			</field>
			<field id="fechacal" _noshow="true" tipoOrden="ASC">
				<expression>(case when PEDCOTIZ.ingresoLinea != '0000-00-00' then PEDCOTIZ.ingresoLinea else TURNOSPRODUCCION.fechaing end)</expression>	
				<tipo>date</tipo>
			</field>
