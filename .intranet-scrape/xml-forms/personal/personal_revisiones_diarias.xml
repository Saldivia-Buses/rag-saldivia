    </field>
-->


      <field id="usuario" _noshow="true" autocompletar="true" _oculto="true">
        <label>Usuario </label>
        <help>Busque el Paciente </help>
            <ayuda_ex id="FSMOPERA" xml="HLPpersonal_ope.xml" dir="/help_local">
