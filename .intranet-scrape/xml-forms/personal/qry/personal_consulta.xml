      <field id="fecing">
        <label>Ing</label>
      </field>
      <field id="years">
        <label>Años</label>
        <help></help>
        <expression>[__pervac__] + 1 - year(fecing)</expression>
        <tipo>integer</tipo>
      </field>
      
      <field id="vacs">
        <label>Vacaciones</label>
        <expression>case when [__pervac__] - year(fecing) = 0 and  DATEDIFF(  MAKEDATE( [__pervac__], 365), fecing) &lt; (DATEDIFF(  MAKEDATE( [__pervac__], 365), MAKEDATE( [__pervac__], 365 / 2))) then   CEILING(DATEDIFF(  MAKEDATE( [__pervac__], 365), fecing) * 14 / 365)
                when [__pervac__] - year(fecing) = 0 and  DATEDIFF(  MAKEDATE( [__pervac__], 365), fecing) &gt;= (DATEDIFF(  MAKEDATE( [__pervac__], 365), MAKEDATE( [__pervac__], 365 / 2))) then   14
                when [__pervac__] + 1 - year(fecing)  &lt; 5 and  [__pervac__] + 1 - year(fecing) &gt; 0 then 14
                when [__pervac__] + 1 - year(fecing)  &lt; 10 and [__pervac__] + 1 - year(fecing) &gt;= 5 then 21
                when [__pervac__] + 1 - year(fecing)  &lt; 20 and [__pervac__] + 1 - year(fecing) &gt;= 10 then 28
                when [__pervac__] + 1- year(fecing)  &gt;= 20 then 35 end</expression>
        <tipo>integer</tipo>
        <detalle>vacs</detalle>
      </field>

      <field id="finvac" local="true" noshow="true">
        <label>Fin</label>
        <if exp="true">
          <true>date('Y-m-d', strtotime('+vacs days', strtotime('comvac')))</true>
          <false>vacs + comvac</false>
        </if>
        <tipo>date</tipo>
        <detalle>finvac</detalle>
      </field>
      
