		<table id="PERSONAL" label="ENTREGA DE ROPA DE TRABAJO Y ELEMENTOS DE PROTECCIÓN PERSONAL">

<field id="IdPersona" noshow="true" print="false">
</field>

<field id="titulo" local="true" PDFnolabel="true" PDFsize="11">
  <label posx="20" posy="+11" _PDFbackgroundColor="000000" />
  <valor>ENTREGA DE ROPA DE TRABAJO Y ELEMENTOS DE PROTECCIÓN PERSONAL</valor>
</field>
<field id="razon_social" local="true">
  <label posx="4" posy="+3" size="20">Razón Social:</label>
  <valor>'María Carmen Murabito'</valor>
</field>
<field id="cuit" local="true">
  <label posx="143" posy="0" size="20">C.U.I.T.:</label>
  <valor>27-06508092-9</valor>
</field>
<field id="direccion" local="true">
  <label posx="4" posy="+2.5" size="20">Dirección:</label>
  <valor>Ruta Prov. 21 KM 7 PIA LOTE 00-04</valor>
</field>
<field id="localidad" local="true">
  <label posx="75" posy="0" size="20">Localidad:</label>
  <valor>"Alvear"</valor>
</field>
<field id="cp" local="true">
  <label posx="110" posy="0" size="20">C.P.:</label>
  <valor>2126</valor>
</field>
<field id="provincia" local="true">
  <label posx="143" posy="0" size="20">Provincia:</label>
  <valor>Santa Fe</valor>
</field>
<field id="nomape" _deshabilitado="true">
  <label posx="4" posy="+2" size="55">Nombre y Apellido del Trabajador:</label>
  <expression>CONCAT(PERSONAL.apellido,', ', PERSONAL.Nombre)</expression>
  <tipo>varchar</tipo>
  <size>60</size>
</field>
<field id="DNI">
  <label posx="143" posy="0" size="20">D.N.I.:</label>
</field>
<field id="lblnombre_ciuo" local="true">
  <label posx="4" posy="+2" size="55">Descripción breve del puesto/s de trabajo:</label>
        <expression having="false">
          (select SECCION.nombre from SECCIONHISTORIA
   left join SECCION on SECCION.id_seccion = SECCIONHISTORIA.id_seccion
   where SECCIONHISTORIA.IdPersona = PERSONAL.IdPersona
  and SECCIONHISTORIA.fechaDesde &lt;= date(now())
   order by SECCIONHISTORIA.fechaDesde desc limit 1)
        </expression>

</field>
<!--<field id="nombre_ciuo">
  <label posx="60" posy="0" />
  <expression>CIUO.nombre</expression>
</field>
-->
<field id="lblarticulos_puesto" local="true">
  <label posx="5" posy="+2" size="85">Elementos de protección personal, según el puesto de trabajo:</label>
</field>

<field id="articulos_puesto" _pdfancho="195">
  <label posx="5" posy="+1" />
  <expression>SELECT GROUP_CONCAT( DISTINCT STKINSUM.artdes) FROM PERSONAL_ARTICULOS INNER JOIN STKINSUM ON PERSONAL_ARTICULOS.artcod = STKINSUM.artcod WHERE PERSONAL_ARTICULOS.idPersona = PERSONAL.idPersona</expression>
</field>
<field id="idPuesto" _local="tue" noshow="true" print="false">
  <label>Puesto</label>
  <help>Codigo</help>
  <detalle>idPuesto</detalle>
</field>
<field id="movcod" noshow="true" local="true" print="false">
  <label>concepto</label>
  <helper type="parameter" id="SIS::01:stock_codigo_concepto_utilizacion" >
  <label>Codigo de Concepto Stock para Utilizacion de materiales</label>
  <defaultValue>31</defaultValue>
  </helper>
</field>
			<field id="fecha_desde" local="true" print="false">
				<tipo>date</tipo>
			</field>
			<field id="fecha_hasta" local="true" print="false">
				<tipo>date</tipo>
			</field>

<field id="opecod" noshow="true" print="false">
  <detalle>opecod</detalle> 
</field>

<field id="movimientos" local="true" showObjTabla="true" pdfwidth="195" >
  <label posx="6" posy="78"  PDFrestorePosition="true"/>
  <helper type="object" xml="salida_seguridad_det.xml">
    <parameter source="opecod"  target="opecod"/>
    <parameter source="fecha_desde" target="fecha_desde" />
    <parameter source="fecha_hasta" target="fecha_hasta" />
    <parameter source="movcod" target="movcod" />
  </helper>
</field>
<field id="separator" local="true">
    <label posx="6" posy="+58" />
</field>

