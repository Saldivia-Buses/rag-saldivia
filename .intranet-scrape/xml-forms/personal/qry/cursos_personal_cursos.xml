			<campo id="years">
				<label>Años</label>
				<help></help>
				<expresion>year(now()) - year(fecing)</expresion>
				<tipo>integer</tipo>
			</campo>
			<campo id="vacs">
				<label>Dias Vacaciones</label>
				<expresion>case when year(now()) - year(fecing) = 0 and  DATEDIFF(  MAKEDATE( YEAR( now() ), 365), fecing) &lt; (DATEDIFF(  MAKEDATE( YEAR( now() ), 365), MAKEDATE( YEAR( now() ), 365 / 2))) then   CEILING(DATEDIFF(  MAKEDATE( YEAR( now() ), 365), fecing) / 20)
								when year(now()) - year(fecing) = 0 and  DATEDIFF(  MAKEDATE( YEAR( now() ), 365), fecing) &gt;= (DATEDIFF(  MAKEDATE( YEAR( now() ), 365), MAKEDATE( YEAR( now() ), 365 / 2))) then   14
								when year(now()) - year(fecing)  &lt; 5 and  year(now()) - year(fecing) &gt; 0 then 14
								when year(now()) - year(fecing)  &lt; 10 and year(now()) - year(fecing) &gt;= 5 then 21
								when year(now()) - year(fecing)  &lt; 20 and year(now()) - year(fecing) &gt;= 10 then 28
								when year(now()) - year(fecing)  &gt;= 20 then 21 end</expresion>
				<tipo>integer</tipo>
				<detalle>vacs</detalle>
			</campo>
			<campo id="finvac" local="true" noshow="true">
				<label>Fin</label>
				<if exp="true">
					<verdadero>date('Y-m-d', strtotime('+vacs days', strtotime('comvac')))</verdadero>
					<falso>vacs + comvac</falso>
				</if>
				<tipo>date</tipo>
				<detalle>finvac</detalle>
			</campo>
