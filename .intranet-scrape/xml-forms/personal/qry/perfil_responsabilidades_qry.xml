<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="abm-mini">
    <title>Funciones</title>
    <obs/>
    <form>
        <table id="RH_PERFIL_RESPONSABILIDAD" title="Funciones">

            <field id="id_perfilresponsabilidad" noshow="true" />

            <field id="perfilpuesto_id" valauto="true" noshow="true"/>

            <field id="perfilfuncion_id" PDFcolWidth="5" oculto="true">
                <label>Funciones</label>
                <tabla_ex id="RH_PERFIL_FUNCION">
                    <field id="id_perfilfuncion"></field>
                    <field id="desc_perfilfuncion"></field>
                    <order>
                        <field id="desc_perfilfuncion" />
                    </order>
                </tabla_ex>
            </field>

            <field id="desc_perfilresponsabilidad">
                <expression>CONCAT(desc_perfilfuncion,' - ', desc_perfilresponsabilidad)</expression>
                <label>Funciones y Responsabilidades</label>
                <help>Funciones y Responsabilidades del puesto</help>
                <size>300</size>
            </field>

        </table>
        <join tipo="left">
            <table id="RH_PERFIL_FUNCION">
                <field id="id_perfilfuncion">
                    <condicion operador="=">RH_PERFIL_RESPONSABILIDAD.perfilfuncion_id</condicion>
                </field>
            </table>
        </join>
    </form>
</histrix>
