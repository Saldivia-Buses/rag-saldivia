<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" imprimetanda="true">
	<title>FICHA PERSONAL</title>
	<obs></obs>
	<form  detalle="personal_cons_ficha.xml" inline="true">
		<table id="PERSONAL" label="Ficha Personal">

			<field id="pervac" local="true" oculto="true">
				<label>Periodo</label>
				<parametro id="fsmparam_paralf.xml" retorna="paralf">
					<field id="parcla">
						<condicion operador="=">'pervac'</condicion>
					</field>
				</parametro>
				<tipo>varchar</tipo>
				<detalle>pervac</detalle>
			</field>

			<field id="comvac" local="true" oculto="true">
				<label>Com</label>
				<parametro id="fsmparam_paralf.xml" retorna="paralf">
					<field id="parcla">
						<condicion operador="=">'comvac'</condicion>
					</field>
				</parametro>
				<tipo>date</tipo>
				<detalle>comvac</detalle>
			</field>
			<field id="impvac" local="true" oculto="true">
				<label>Comienza</label>
				<parametro id="fsmparam_paralf.xml" retorna="paralf">
					<field id="parcla">
						<condicion operador="=">'impvac'</condicion>
					</field>
				</parametro>
				<tipo>varchar</tipo>
				<size>50</size>
				<detalle>impvac</detalle>
			</field>
			
<!--
			<field id="impvac" local="true" oculto="true">
				<label>FechaImpresion</label>
				<parametro id="fsmparam_paralf.xml" retorna="paralf">
					<field id="parcla">
						<condicion operador="=">'impvac'</condicion>
					</field>
				</parametro>
				<tipo>varchar</tipo>
				<size>50</size>
			</field>
-->
			<field id="IdPersona" noshow="true">
				<label modpos="nobr">pers</label>
				<detalle>IdPersona</detalle>
			</field>

			<field id="legajo">
				<label modpos="nobr">Legajo</label>
				<detalle>legajo</detalle>
			</field>
			<field id="apellido">
				<label modpos="nobr" colspan="6">Apellido</label>
				<help>Apellido</help>
			</field>
			<field id="Nombre">
				<label modpos="nobr">Nombre</label>
				<help>Nombre</help>
			</field>
          
      <field id="des2" tabla="SECCION">
 <expression>select nombre from SECCIONHISTORIA 
left join SECCION on SECCION.id_seccion = SECCIONHISTORIA.id_seccion 
where SECCIONHISTORIA.IdPersona=PERSONAL.IdPersona and SECCIONHISTORIA.fechaDesde &lt;= PERSONAL.fechaEgreso
order by SECCIONHISTORIA.fechaDesde desc limit 1</expression>
        <label>Sección</label>
        <tipo>varchar</tipo>
      </field>          
          
          
          
			<field id="CUIL">
				<label modpos="nobr" >C.U.I.L.</label>
				<help>Numero de Clave Unica de Identificacion Laboral</help>
			</field>

			<field id="DNI">
				<label modpos="nobr" >D.N.I.</label>
				<help>Numero de Documento Nacional de Identidad</help>
			</field>

			<field id="nacimiento">
				<label >Fecha Nac</label>
				<help>Fecha de Nacimiento</help>
			</field>
			
			<!--<field id="fecha_Egreso" noshow="true">

				<expression having="false">case when fechaEgreso = '0000-00-00' then NOW() else fechaEgreso end</expression>
				<tipo>date</tipo>
			</field>-->
			<field id="fecing">
				<label>Ing</label>
			</field>
			<field id="years">
				<label>Año</label>
				<help></help>
				<expression>FSMPARAM.paralf + 1 - year(fecing)</expression>
				<tipo>integer</tipo>
			</field>
			<field id="vacs">
				<label>Dias Vac.</label>
				<expression>case when FSMPARAM.paralf - year(fecing) = 0 and  DATEDIFF(  MAKEDATE( FSMPARAM.paralf, 365), fecing) &lt; (DATEDIFF(  MAKEDATE( FSMPARAM.paralf, 365), MAKEDATE( FSMPARAM.paralf, 365 / 2))) then   CEILING(DATEDIFF(  MAKEDATE( FSMPARAM.paralf, 365), fecing) / 20)
								when FSMPARAM.paralf - year(fecing) = 0 and  DATEDIFF(  MAKEDATE( FSMPARAM.paralf, 365), fecing) &gt;= (DATEDIFF(  MAKEDATE( FSMPARAM.paralf, 365), MAKEDATE( FSMPARAM.paralf, 365 / 2))) then   14
								when FSMPARAM.paralf + 1 - year(fecing)  &lt; 6 and  FSMPARAM.paralf + 1 - year(fecing) &gt; 0 then 14
								when FSMPARAM.paralf + 1 - year(fecing)  &lt; 11 and FSMPARAM.paralf + 1 - year(fecing) &gt;= 6 then 21
								when FSMPARAM.paralf + 1 - year(fecing)  &lt; 21 and FSMPARAM.paralf + 1 - year(fecing) &gt;= 11 then 28
								when FSMPARAM.paralf + 1- year(fecing)  &gt;= 21 then 35 end</expression>
				<tipo>integer</tipo>
				<detalle>vacs</detalle>
			</field>
			<field id="fechaEgreso" tipoOrden="DESC">
				<label>Egreso</label>
				<condicion operador="!=">"0000-00-00"</condicion>
			</field>

			<field id="finvac" local="true" noshow="true">
				<label>Fin</label>
				<if exp="true">
					<true>date('Y-m-d', strtotime('+vacs days', strtotime('comvac')))</true>
					<false>vacs + comvac</false>
				</if>
				<tipo>date</tipo>
				<detalle>finvac</detalle>
			</field>
			<field id="idMotivo">
                		<label modpos="nobr">Motivo</label>
                		<tabla_ex xml="motivosegreso.xml" vacio="true">
                		</tabla_ex>
            		</field>
         <field id="cta_bancaria">
        <label>Cuenta bancaria</label>
        <size>40</size>
      </field>

      <field id="certificado_trabajo" local="true" noshow="true">
        <valor>'false'</valor>
      </field>

      <field id="certificado_renuncia" local="true" noshow="true">
        <valor>'true'</valor>
      </field>

      <field id="renuncia" local="true" style="width:5em;">
    	<label>Certificado Renuncia</label>
    	<helper type="link" xml="personal_certificado_qry.xml" dir="/personal/qry">
          <parameter source="IdPersona" target="IdPersona" />
          <parameter source="certificado_trabajo" target="certificado_trabajo" />
          <parameter source="certificado_renuncia" target="certificado_renuncia" />
    	</helper>
    	<valor>'&gt;&gt;'</valor>
      </field>

		<order>
			<field id="fechaEgreso"></field>
		</order>
		</table>

        <join tipo="left">
            <table id="FSMPARAM">
                <field id="parcla">
                     <condicion operador="=">'pervac'</condicion>
                 </field>
            </table>
         </join>
	</form>
</histrix>
