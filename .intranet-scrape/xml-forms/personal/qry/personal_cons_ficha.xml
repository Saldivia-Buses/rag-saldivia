<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="ficha" borra="false" cancelar="false" imprime="false">
	<title>FICHA PERSONAL</title>
	<obs/>
	<form >
		<table id="PERSONAL" label="Ficha Personal">
			
			<field deshabilitado="true" id="IdPersona" noshow="true">
				<label>Cuenta</label>
				<help>Codigo de Cuenta</help>
				<valor>0</valor>
				<tipo>varchar</tipo>
	 		</field>
			<field id="legajo" deshabilitado="true">
				<label>Legajo</label>
				<help>Numero de Legajo</help>
				<tipo>varchar</tipo>

			</field>
			<field id="nom" deshabilitado="true">
				<label>Nombre</label>
				<expression>CONCAT(apellido, ', ', PERSONAL.Nombre)</expression>
				<tipo>varchar</tipo>
			</field>			
			<field id="alias" deshabilitado="true">
				<label modpos="nobr">Alias</label>
				<help>Apodo</help>
				<size>20</size>
			</field>
			<field id="nacimiento" deshabilitado="true">
				<label>Fecha Nac</label>
				<help>Fecha de Nacimiento</help>
			</field>
			<field id="nacionalidad" deshabilitado="true">
				<tabla_ex id="NACIONALIDAD" xml="nacionalidad.xml"/>
				<label modpos="nobr">Nacionalidad</label>
				<help>Nacionalidad</help>
			</field>
			
			<field id="doc" deshabilitado="true">
				<expression>DNI</expression>
				<label>D.N.I.</label>
				<help>Numero de Documento Nacional de Identidad</help>
				<tipo>varchar</tipo>
			</field>
			<field id="afip" deshabilitado="true">
				<expression>CUIL</expression>
				
				<label modpos="nobr">C.U.I.L.</label>
				<help>Numero de Clave Unica de Identificacion Laboral</help>
				<tipo>varchar</tipo>
				
			</field>
			<field id="estadocivil" deshabilitado="true">
				<tabla_ex id="ESTADOCIVIL" xml="estadocivil.xml"/>
				<label >Estado Civil</label>
				<help>Estado Civil</help>
			</field>
			<field id="rnos" deshabilitado="true">
				<tabla_ex id="OBRASOCIAL">
					<field id="rnos"></field>
					<field id="siglo">
					<expression>concat(rnos,"-",sigla)</expression>
					</field>
				</tabla_ex>

				<label modpos="nobr">Obra Social</label>
				<help>Obra Social</help>
			</field>
			<field id="direccion" deshabilitado="true">
				<label>Direccion</label>
				<expression>CONCAT(calle,' Nro:',numero, ' Piso:',piso,' Dto.', depto)</expression>
				<tipo>varchar</tipo>
			</field>
			<field id="localidad" deshabilitado="true">
				<expression>CONCAT(LOCALIDADES.nombre, ' - ', prvnom)</expression>
				<label modpos="nobr" colspan="3">Localidad</label>
				<help>Localidad</help>
			</field>
			
<!--			<field id="calle">
				<label>Calle</label>
				<help/>
			</field>
			<field id="numero">
				<label modpos="nobr">Numero</label>
				<help>Numero</help>
			</field>
