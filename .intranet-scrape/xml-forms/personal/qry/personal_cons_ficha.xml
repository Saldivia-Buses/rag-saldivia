				<label modpos="nobr">Piso</label>
				<help>Piso</help>
			</field>
			<field id="depto" >
				<label modpos="nobr">Depto</label>
				<help>Departamento</help>
			</field> -->
			<field id="telefono" deshabilitado="true">
				<label>Telefono Fijo</label>
				<help>Numero de Telefono Fijo</help>
				<tipo>varchar</tipo>
				
			</field>
			<field id="celular" deshabilitado="true">
				<label modpos="nobr">Celular</label>
				<help>Numero de Celular</help>
			</field>

			<field id="fecing" deshabilitado="true">
				<label>Fecha de Ingreso</label>
				<help/>
			</field>
			<field id="idJornada" deshabilitado="true">
				<helper xml="jornadas.xml" dir="/personal/man/" type="combo" />

				<label modpos="nobr">Horario</label>
				<help>Horario</help>
			</field>
			<field id="fechaEgreso" deshabilitado="true">
				<label>Fecha de Egreso</label>
			</field>
			<field id="idMotivo">
				<label modpos="nobr">Motivo</label>
				<tabla_ex xml="motivosegreso.xml" vacio="true">
				</tabla_ex>
			</field>			
<!--			<field id="foto">
				<label>Foto</label>
				<help>Foto</help>
			</field>
			<field id="login">
				<label modpos="nobr">Login</label>
				<help></help>
			</field> -->
			<field id="tarjeta" deshabilitado="true">
				<label >Tarjeta</label>
				<help></help>
			</field>
			<field id="nomsind" deshabilitado="true">
				<expression>SINDICATO.Nombre</expression>
				<label modpos="nobr">Sindicato</label>
				<help>Nombre del Sindicato</help>
				<tipo>varchar</tipo>
				
			</field>	


			<field id="IdCateg2" deshabilitado="true">
				<label  >Categoria.</label>
				<expression>select descripcion from CATEGHISTORIA left join CATPERSONAL on CATPERSONAL.IdSindicato = CATEGHISTORIA.idSindicato and CATPERSONAL.IdCateg = CATEGHISTORIA.IdCateg where CATEGHISTORIA.IdPersona = PERSONAL.IdPersona order by CATEGHISTORIA.fechaDesde desc limit 1</expression>
				<tipo>varchar</tipo>

			</field>

