				<label>Nombre</label>
				<tipo>varchar</tipo>
				<size>60</size>
			</field>

			<field id="IdPersona" noshow="true">
			</field>

			<field id="idPuesto" noshow="true" />

			<field id="opecod" noshow="true" />

			<field id="movfec" local="true" noshow="true">
				<valor>today</valor>
				<tipo>date</tipo>
			</field>

			<field id="movcod" noshow="true" local="true">
				<helper type="parameter" id="SIS::01:stock_codigo_concepto_utilizacion">
					<label>Codigo de Concepto Stock para Utilizacion de materiales</label>
					<defaultValue>31</defaultValue>
