			</field>

			<field id="movref" local="true">
				<label>Observaciones</label>
				<size>70</size>
			</field>

			<field id="articulos" local="true" showObjTabla="true">
				<label colspan="8">Artículos</label>
				<helper type="object" xml="seguridad_articulos.xml" 
				    
				</helper>
			</field>

