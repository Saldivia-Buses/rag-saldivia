<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="grid" _subtipo="vertical" procesa="true" inserta="false" delete="false" deleteRow="false" modifica="false">
    <title>FICHA SECCION</title>
    <obs/>
    <form>
        <table id="HS_SECCION_ARTICULOS" label="Ficha Seccion">

        	<movimientos>
        		<relacion id="personal_art_detalle_insert.xml" />
        	</movimientos>

		    <field id="id_seccionart" noshow="true" esClave="true" />
		    <field id="seccion_id" valauto="true" noshow="true" />
		    <field id="persona_id" valauto="true" _noshow="true" local="true" />
		    
		    <field id="chk_articulo" local="true" deshabilitado="false" >
		    	<tipo>check</tipo>
		    	<valor default="true">1</valor>
		    </field>

		    <field id="stkinsum_id" _autocompletar="true">
				<helper type="external" xml="stkarticulo_autocomplete_qry.xml" dir="/help_local">
				    <field id="artcod" noshow="true">
						<detalle>stkinsum_id</detalle>
				    </field>
				    <field id="artdes">
						<detalle>artdes</detalle>
				    </field>
				</helper>
				<label>Articulo</label>
				<size>30</size>
		    </field>

		    <field id="artdes" tabla="STKINSUM" deshabilitado="true">
				<label modpos="nobr">Descripcion</label>
				<size>70</size>
		    </field>

		    <field id="dias_recambio">
				<label>Recambio</label>
				<size>30</size>
		    </field>

		    <field id="observacion">
				<label colspan="4">Observacion</label>
				<size>200</size>
		    </field>
        </table>
		
		<join tipo="left">
		  <table id="STKINSUM">
		    <field id="artcod">
		    	<condicion operador="=">HS_SECCION_ARTICULOS.stkinsum_id</condicion>
		    </field>
		    <field id="siscod">
		    	<condicion operador="=">'01'</condicion>
		    </field>
		  </table>
		</join>
    </form>
</histrix>
