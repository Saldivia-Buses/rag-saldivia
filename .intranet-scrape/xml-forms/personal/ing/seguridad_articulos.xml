-->

                <field id="dias_recambio">
					<label>Recambio</label>
					<tipo>integer</tipo>
				</field>

				<field id="ultima">
					<label>Última</label>
					<expression>@ultima:=(SELECT fecha_movimiento FROM STK_MOVIMIENTOS WHERE STK_MOVIMIENTOS.stkarticulo_id = STK_ARTICULOS.id_stkarticulo AND STK_MOVIMIENTOS.subsistema_id = '01' AND STK_MOVIMIENTOS.opecod = PERSONAL.opecod ORDER BY fecha_movimiento desc LIMIT 1)</expression>
					<tipo>date</tipo>
				</field>

				<field id="transcurrido" _style="text-align:right;padding-right:5px;" noshow="true">
					<label>Transcurrido</label>
					<expression>@transcurrido:=IFNULL( DATEDIFF(NOW(), @ultima), dias_recambio)</expression>
				</field>
<!-- variante con var 25 seg y sin var repitiendo la consulta 27 seg alla -->				
 				<field id="faltan" local="true">
					<label>Faltan (días)</label>
					<expression>case when (dias_recambio - @transcurrido) &gt; 0 then (dias_recambio - @transcurrido) else '' end</expression>
					<!-- <if exp="dias_recambio &gt;= transcurrido)">
						<true>dias_recambio - transcurrido . ' días'</true>
						<false>''</false>
					</if> -->
				</field>
			
			<!--<fieldGroup>
                <if> return ($_SESSION['mobile'] !== 'true' ? true : false); </if> 
                <field id="observacion">
					<label>Observación</label>
				</field>
			</fieldGroup> -->
<!--            	<field id="stkdeposito_id" noshow="true" tabla="STK_STOCKACTUAL">
			<condicion operador="=">40 or STK_STOCKACTUAL.stkdeposito_id = 33</condicion>
            	</field>
-->
            	<field id="stklocacion_id" noshow="true" >
           			<expression>SELECT stklocacion_fija_id FROM STK_ARTICULOS where id_stkarticulo = artcod</expression>
				</field>
           		
                <field id="movcant" local="true" noshow="true">
					<label>Cant</label>
					<valor>1</valor>
				</field>

				<field id="opecla" local="true" noshow="true">
					<valor eval="true">$_SESSION['usuario']</valor>
				</field>

				<field id="nopermito_grabar" local="true" noshow="true">
				    <if exp=" (dias_recambio &gt; transcurrido) ">
						<true>'true'</true>
						<false>'false'</false>
				    </if>
				</field>

				<field id="graba" local="true">
					<attribute id="deshabilitado">nopermito_grabar</attribute>
					<label>Todos</label>
					<tipo>check</tipo>
				</field>

				<field id="color" clasefila="true" noshow="true" local="true">
					<if exp="'nopermito_grabar' == 'false'">
						<true>'resaltadoVioleta'</true>
						<false>''</false>
					</if>
				</field>
				<field id="opecod" noshow="true" valauto="true" tabla="PERSONAL">
					<label>OpeCod</label>
				</field>

                <field id="IdPersona" noshow="true" _valauto="true">
					<label>Cuenta</label>
				</field>
			
                <field id="artcod" noshow="true">
					<label>Artículo</label>
					<tipo>varchar</tipo>
				</field>
		<field id="dep_id" local="true" noshow="true">
					<label>Dep</label>
					<valor>40</valor>
				</field>	
		<field id="loc_id" local="true" noshow="true">
					<label>Loc</label>
					<valor>1779</valor>
				</field>	
			</fieldGroup>
		
		</table>

		<join>
			<table id="STK_ARTICULOS">
				<field id="id_stkarticulo">
					<condicion operador="=">PERSONAL_ARTICULOS.artcod</condicion>
				</field>
				<field id="subsistema_id">
					<condicion operador="=">'01'</condicion>
				</field>
			</table>
		</join>

		<join>
			<table id="PERSONAL">
				<field id="IdPersona">
					<condicion operador="=">PERSONAL_ARTICULOS.IdPersona</condicion>
				</field>
			</table>
		</join>

