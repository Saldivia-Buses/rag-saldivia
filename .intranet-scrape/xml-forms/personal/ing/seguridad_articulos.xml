<?xml version="1.0" encoding="UTF8"?>
<histrix tipo="grid" subtipo="vertical" deleteRow="false" imprime="false" path="fotos/articulos" _preloadData="false" process="true" inserta="false">
	<title>Puestos de Trabajo</title>
	<customScript>
	    $('select:visible').change();
	</customScript>
	<form>

		<table id="PERSONAL_ARTICULOS" label="Secciones">

			<movimientos cabecera="seguridad_articulos_cab.xml">
				<relacion id="seguridad_articulos_ins.xml" />
			</movimientos>

			<fieldGroup>
				<if> return ($_SESSION['mobile'] !== 'true' ? true : false); </if>
				<field id="id_personalart" noshow="true">
					<label>Cod</label>
					<help>Codigo</help>
				</field>
				<!-- <field id="fotopath" local="true" noshow="true">
					<if exp="true">
						<true>'artcod/'</true>
						<false>''</false>
					</if>
					<tipo>varchar</tipo>
				</field>
			</fieldGroup>

			<fieldGroup>
                <if> return ($_SESSION['mobile'] !== 'true' ? true : false); </if> 
				<field id="foto" path="fotopath" download="true" watermark="artcod">
					<expression><![CDATA[SELECT AF.foto FROM ARTICULO_FOTO AF WHERE AF.idArticulo = PERSONAL_ARTICULOS.artcod AND AF.foto != '' LIMIT 1]]></expression> 
					<label>Imagen</label>
					<tipo>file</tipo>
					<size>40</size> 
				</field> -->
			</fieldGroup> 

			<fieldGroup>
				<field id="id_stkarticulo" tabla="STK_ARTICULOS" deshabilitado="true">
					<label modpos="nobr">Cod.</label>
					<size>8</size>
				</field>

				<field id="nombre_articulo" tabla="STK_ARTICULOS" deshabilitado="true">
					<label modpos="nobr">Descrip.</label>
					<size>40</size>
				</field>

<!--                <field id="stock_actual">
					<label>Stock -fija</label>
				    <expression>select stock_actual from STK_ARTICULO_LOCACION left join STK_LOCACION on stklocacion_id = id_stklocacion where stkarticulo_id = artcod and stklocacion_id = stklocacion_fija_id</expression>
			    </field>
-->

<!--
                <field id="depcod" local="true" _noshow="true" editable="true">
	                <label>Depósito Origen</label>
	                <helper xml="deposito_articulo_qry.xml" dir="/stock_local/qry" type="combo" _empty="true">
	                	<parameter source="artcod" target="stkarticulo_id" />
