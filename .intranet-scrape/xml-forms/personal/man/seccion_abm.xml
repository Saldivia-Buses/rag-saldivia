        	<field id="enviomail" local="true" print="false">
			    <label>Mail</label>
			    
			    <helper type="link" xml="mails_send.xml" dir="/histrix/mensajeria">
			    	<parameter source="mail_msg"  target="mensaje" />
			    	<parameter source="mail_to"   target="para" />
			    	<parameter source="mail_subj" target="subject" />
			    </helper>
			
			    <expression><![CDATA[IFNULL(('<img src="../img/mail_generic.png"/>'), '')]]></expression>
			</field>

        	<field id="detalle" local="true" print="false">
			    <label>Mail</label>
			    
			    <helper type="link" xml="seccion_abm_det.xml" title="editar" >
			    	<parameter source="id_seccion" target="id_seccion" />
			    </helper>
			
			    <expression>'Editar'</expression>
			</field>
		
    
