		    <field id="personal" local="true">
			<label>Personal de la seccion</label>
			<helper type="object" xml="personal_seccion.xml" dir="/personal/qry/" >
			    <parameter source="id_seccion" target="idSeccion" />
			    <parameter source="idSeccionSup" target="idSeccion" />
			</helper>
		    </field>
			
		</table>
		<join tipo="left">
			<table id="CIUO">
				<field id="idPuesto">
					<condicion operador="=">SECCION.idPuesto</condicion>
				</field>
				
		</table>
		</join>

	</form>
	
</histrix>
