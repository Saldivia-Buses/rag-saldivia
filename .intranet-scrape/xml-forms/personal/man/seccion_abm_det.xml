<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="ficha" path="fotos/puestos" preFetch="true">
	<title>Secciones de Trabajo</title>
	<obs/>
	<form>
		<table id="SECCION">
			<title>Secciones de Trabajo</title>
			<field id="id_seccion" noshow="true" esClave="true">
				<label _Formstyle="display:none;">Codigo</label>
				<help>Codigo de Seccion</help>
			</field>

			<field id="idSeccionSup">
			    <helper type="combo" id="SECCION" empty="true">
				<field id="idsec">
				    <expression>id_seccion</expression>
				</field>
				<field id="nombre"></field>
			    </helper>
			    <label colstyle="display:none;">Secc Sup</label>
			</field>

            <field id="activa" sincelda="true" colstyle="display:none;">
                <label modpos="nobr">Activa</label>
                <tipo>check</tipo>
                <valor default="true">1</valor>
				<condicion operador="=">1</condicion><!-- Comentar esta linea para poder editar secciones no activas -->
            </field>

			<field id="nombre" nodeTitle="true" >
				<label>Nombre</label>
				<help>Nombre de Seccion</help>
			</field>

			<field id="descripcion" nodeText="true">
				<label>Mision del puesto</label>
				<help>Mision del puesto</help>
			</field>

			<field id="descripcion_perfil" _nodeText="false" colstyle="display:none;">
				<label>Perfil</label>
				<help>Descripcion del perfil</help>
				<tipo>editor</tipo>
			</field>

			<field id="idSupervisor" _nodeText="true">
				<label>Supervisor</label>

            			<tabla_ex id="PERSONAL" xml="HLPpersonal.xml" vacio="true" dir="/help_local">
                		    <field id="legajo">
                		        <condicion operador="!=">0</condicion>
                		    </field>
				    <field id="fechaEgreso">
					<condicion operador="=">'0000-00-00'</condicion>
				    </field>
            			</tabla_ex>
			</field>

        	<field id="supervisor">
            	<label>desc supervisor</label>
			    <help>Supervisor de Seccion</help>
			</field>

	    <field id="linea_id" colstyle="display:none;">
            	<helper type="combo" xml="lineas.xml" dir="/produccion" _empty="true"/>
            	<label >Linea</label>
            	<valor>1</valor>
		<actualiza>
		    <field id="idMomento" destino="linea_id" />
		</actualiza>
            </field>

	    <field id="idMomento">
		<label>Seccion Calc.Premio</label>
		<helper type="combo" id="MOMENTO" empty="true">
		    <field id="idMomento" />
		    <field id="descripcion" />
		    <field id="linea_id" oculto="true">
				<condicion operador="=">1</condicion>
		    </field>
		    <order>
			<field id="descripcion" />
		    </order>
		</helper>
	    </field>

	    <field id="idMomentoCalidad">
		<label>Seccion Indice Calidad</label>
		<helper type="combo" id="MOMENTO" empty="true">
		    <field id="idMomento" />
		    <field id="descripcion" />
		    <field id="linea_id" oculto="true">
		    	<condicion operador="=">1</condicion>
		    </field>
		    <order>
			<field id="descripcion" />
		    </order>
		</helper>
	    </field>

  		<field id="seccion_productiva">
    		<label>Productiva</label>
    		<help>Productiva</help>
    		<options>
        		<option valor="0">Si</option>
        		<option valor="1">No</option>           
    		</options>
  		</field>
<!--	    <field id="archivo" open="true" path="id_seccion">
		<label>Adjunto</label>
		<tipo>file</tipo>
	    </field>
-->
