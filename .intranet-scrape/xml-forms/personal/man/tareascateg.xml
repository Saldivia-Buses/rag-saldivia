			</field>

			<field id="IdCateg" local="true" oculto="true">
				<label style="font-size:15px;color:green;">Categoría</label>
				<tabla_ex id="CATPERSONAL">
					<field id="IdCateg"/>
					<field id="descripcion"/>
					<field id="IdSindicato">
					</field>
				</tabla_ex>
				<tipo>varchar</tipo>
				<detalle>idCateg</detalle>
								<actualiza>
						<field destino="actual" id="actual"/>
					
					</actualiza>	
			</field>
			<field id="id_seccion">
					<label>Id</label>
				<detalle>id_seccion</detalle>

			</field>
			<field id="descripcion">
					<label>Sección</label>
			</field>

			<field id="actual" local="true" oculto="true">

			</field>

