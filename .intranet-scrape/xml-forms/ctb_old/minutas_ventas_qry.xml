      		  <order>
                  <field id="regmin"></field>
                  <field id="regord"></field>

      		  </order>
			  
      </table>
    <join tipo="left">

      <table id="CCTMOVIM">
        <field id="siscod" oculto="true">
          <condicion operador="=">"02"</condicion>
        </field>        
        <field id="concod" >
          <condicion operador="=">IVAVENTAS.codcom</condicion>
        </field>
        <field id="ctacod" >
          <condicion operador="=">IVAVENTAS.ctacod</condicion>
        </field>
        <field id="movnro" >
          <condicion operador="=">IVAVENTAS.nrocom</condicion>
        </field>
        <field id="movnpv" >
          <condicion operador="=">IVAVENTAS.nronpv</condicion>
        </field>

      </table>
    </join>       
      <join>
        <table id="CTBREGIS">
          <field id="regfec">
            <condicion operador="=">CCTMOVIM.regfec</condicion>
          </field>
          <field id="regnro">
            <condicion operador="=">CCTMOVIM.movnro</condicion>
          </field>
          <field id="regmin">
            <condicion operador="=">CCTMOVIM.regmin</condicion>
          </field>
        </table>
      </join>
		  <join tipo="left">
		    <table id="CTBCUENT">
    			<field id="ctbcod" oculto="true">
    			    <condicion operador="=">CTBREGIS.ctbcod</condicion>
    			</field>

		    </table>
		  </join>



               </form>
        </histrix>
