                				<label>Articulo</label>
                			</field>


                			<field id="ctbcod">
                				<operador>=</operador>
                				<label>Cuenta a Modificar</label>
                			</field>

                      <field id="ctbnew" required="true">
                        <operador>=</operador>
                        <label>Cuenta Nueva</label>
                      </field>              			
              		  </filters>

	    
