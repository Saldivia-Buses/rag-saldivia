		    <field id="movnro" tabla="CCTMOVIM">
			<label>Comp</label>
		    </field>
		    <field id="movimp" tabla="CCTMOVIM">
			<label>$</label>
			<tipo>numeric</tipo>
		    </field>
		    <field id="artcod" tabla="STKINMOV" noshow="true">
			<label>Articulo</label>
		    </field>

            		  <order>
                      <field id="regmin" tabla="CTBREGIS"></field>
                      <field id="regord"></field>

            		  </order>
			  
                  </table>
            		  <join tipo="left">
            		    <table id="CTBCUENT">
            			<field id="ctbcod" oculto="true">
	      			    <condicion operador="=">CTBREGIS.ctbcod</condicion>
            			</field>
            		    </table>
            		  </join>

            		  <join tipo="left">
            		    <table id="CCTMOVIM">
                			<field id="siscod" >
              			    <condicion operador="=">'01'</condicion>
                			</field>
                			<field id="regmin" >
              			    <condicion operador="=">CTBREGIS.regmin</condicion>
                			</field>
                			<field id="regfec" >
              			    <condicion operador="=">CTBREGIS.regfec</condicion>
                			</field>
            		    </table>
            		  </join>
            		  <join tipo="left">
            		    <table id="FACREMIMP">
                		<field id="ctacod" >
                 		    <condicion operador="=">CCTMOVIM.ctacod</condicion>
                		</field>
                		<field id="movnro" >
	          		    <condicion operador="=">CCTMOVIM.movnro</condicion>
                		</field>
                		<field id="movnpv" >
                  		    <condicion operador="=">CCTMOVIM.movnpv</condicion>
                		</field>
            		    </table>
            		  </join>
            		  <join tipo="left">
            		    <table id="FACREMIT">
                		<field id="ctacod" >
                 		    <condicion operador="=">FACREMIMP.ctacod</condicion>
                		</field>
                		<field id="remnro" >
	          		    <condicion operador="=">FACREMIMP.remnro</condicion>
                		</field>
<!--
                		<field id="movnpv" >
                  		    <condicion operador="=">FACREMIMP.remnpv</condicion>
                		</field>
-->
            		    </table>
            		  </join>
            		  <join tipo="left">
            		    <table id="STKINMOV">
                		<field id="ctacod" >
                 		    <condicion operador="=">FACREMIT.ctacod</condicion>
                		</field>
                		<field id="movnro" >
	          		    <condicion operador="=">FACREMIT.remnro</condicion>
                		</field>
                		<field id="movnpv" >
                  		    <condicion operador="=">FACREMIT.remnpv</condicion>
                		</field>
            		    </table>
            		  </join>

               </form>
