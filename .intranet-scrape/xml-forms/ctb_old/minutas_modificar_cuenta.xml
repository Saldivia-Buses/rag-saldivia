		  <field id="grabar" noshow="true">
		    <expression>ifnull((select 1 from CTBCUENT where CTBCUENT.ctbcod = '[__ctbnew__]' limit 1),0)</expression>
		  </field>
		  <field id="nueva">
		    <label>Nueva</label>
		    <expression>ifnull((select ctbnom from CTBCUENT where CTBCUENT.ctbcod = '[__ctbnew__]' limit 1),'DEBE INGRESAR CUENTA')</expression>
		  </field>

                  <field id="minuta" showObjTabla="true" local="true">
                    <label>Detalle</label>
                    <helper xml="detalle_minuta.xml" type="object">
                      <parameter source="regmin" target="regmin" />
                      <parameter source="regfec" target="regfec" />
                      <parameter source="siscod" target="siscod" />
                    </helper>
                  </field>


                  <field id="cuenta" noshow="true">
		      <expression>ctbnom</expression>
                      <label>Cuenta</label>
		      
                      <help>Codigo de Cuenta Contable</help>
		      <tipo>string</tipo>
                  </field>

