			<order>
				<field id="regmin" tabla="CTBREGIS"></field>
				<field id="regdoh"></field>
			</order>
			
		</table>
		<join tipo="left">
			<table id="CTBCUENT">
				<field id="ctbcod" oculto="true">
					<condicion operador="=">CTBREGIS.ctbcod</condicion>
				</field>
				<field id="ctbnom" oculto="true">
				</field>
			</table>
		</join>
