                  <field id="idimpu">
                      <label>? </label>
                      <help> </help>
                  </field>
                  <field id="regcta">
                      <label>? </label>
                      <help> </help>
                  </field>
                  <field id="regfco">
                      <label>Fecha Comprobante </label>
                      <help> </help>
                  </field>
                  <field id="regnro">
                      <label>Nro.</label>
                      <help>Numero de Comprobante Correspondiente. </help>
                  </field>
		  -->
        <field id="regfec">
            <label>Fecha</label>
            <help>Fecha del Asiento (Movimiento Contable) </help>
            <detalle>regfec</detalle>
        </field>
<!--
                  <field id="regnpv">
                      <label>Nro Puesto </label>
                      <help> </help>
                  </field>
                  <field id="regord">
                      <label>Orden en el Asiento  . </label>
                      <help> </help>
                  </field>
                  <field id="regsub">
                      <label>Subdiario </label>
                      <help> </help>
                  </field>
                  <field id="reguni">
                      <label>Unidades Fisicas     . </label>
                      <help>Unidades Fisicas. </help>
                  </field>
		  -->

		  <order>
        <field id="regmin"></field>
        <field id="regord"></field>
		  </order>
			  
          </table>

		  <join tipo="left">
		    <table id="CTBCUENT">
    			<field id="ctbcod" oculto="true">
    			    <condicion operador="=">CTBREGIS.ctbcod</condicion>
    			</field>
		    </table>
		  </join>

      <join tipo="left">
        <table id="CCTMOVIM">
        <field id="regmin" oculto="true">
          <condicion operador="=">CTBREGIS.regmin</condicion>
        </field>        
        <field id="movfec" oculto="true">
          <condicion operador="=">CTBREGIS.regfec</condicion>
        </field>
        </table>
      </join>

      <join tipo="left">
        <table id="CCTCUENT">
        <field id="ctacod" oculto="true">
          <condicion operador="=">CCTMOVIM.ctacod</condicion>
        </field>        
        <field id="siscod" oculto="true">
          <condicion operador="=">'01'</condicion>
        </field>
        </table>
      </join>

