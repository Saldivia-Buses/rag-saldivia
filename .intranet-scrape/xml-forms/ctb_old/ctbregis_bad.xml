<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta">
	<title>Minutas</title>
	<obs></obs>
	<form  detalle="ctbregis2.xml">
		<table id="CTBREGIS" label="Minutas">

			<filters>

				<field id="regfec">
					<operador>&gt;=</operador>
					<label>Desde Fecha</label>
					<valor>today</valor>
				</field>

				<field id="siscod" >
                    <label modpos="nobr">Ejercicio</label>
                    <operador>=</operador>
                </field>

				<field id="regfec">
					<operador>&lt;=</operador>
					<label>Hasta Fecha</label>
					<valor>today</valor>
				</field>

			</filters>
			
			<field id="regmin">
				<label>Minuta </label>
				<help>Numero de Asiento </help>
				<detalle>regmin</detalle>
			</field>
			
			<field id="cuenta">
				<expression>ctbnom</expression>
				<label>Cuenta</label>
				
				<help>Codigo de Cuenta Contable</help>
				<!--		      <tabla_ex id="CTBCUENT">
				<field id="ctbcod"></field>
				<field id="ctbnom"></field>
				
				</tabla_ex>
				-->
				<tipo>string</tipo>
			</field>

			<field id="siscod" noshow="true">
<!--             	<preparam campo="siscod" operador="=">true</preparam>
 -->                <helper type="combo" xml="ctbejercicios_crud.xml" dir="/contabilidad/man/">
                    <field id="activo" tipoOrden="DESC" />
                    <field id="fecha_mov1">
                        <expresion>DATE_FORMAT(comienza, '%d/%m/%Y')</expresion>
                        <tipo>date</tipo>
                    </field>
                    <field id="fecha_mov2">
                        <expresion>DATE_FORMAT(finaliza, '%d/%m/%Y')</expresion>
                        <tipo>date</tipo>
                    </field>
                    <field id="finaliza" />
                </helper>
            </field>
			
			<field id="regdoh" oculto="true">
				<label>Tipo Mov.</label>
				<help>Tipo Movimiento</help>
				<options>
					<option valor="1">Debe </option>
					<option valor="2">Haber</option>
				</options>
				
			</field>
			
			<field id="regref">
				<label>Referencia</label>
				<help>Referencia</help>
			</field>
<!--			<field id="debe" suma="true">
				<expression>select sum(regimp) from CTBREGIS as CTB where CTB.regfec = CTBREGIS.regfec and CTB.regmin = CTBREGIS.regmin and regdoh = 1</expression>
				
				<label>Debe</label>
				<help>Importe del Movimiento en el Debe</help>
			</field>
			<field id="haber" suma="true">
				<expression>select sum(regimp) from CTBREGIS as CTB where CTB.regfec = CTBREGIS.regfec and CTB.regmin = CTBREGIS.regmin and regdoh = 1</expression>
				
				<label>Debe</label>
				<help>Importe del Movimiento en el Debe</help>
			</field>
			-->
			<field id="deber" suma="true">
				<expression>sum(regimp * (case when regdoh = 1 then 1 else 0 end))</expression> 
				<label>Debe</label>
				<help>Importe del Movimiento en el Haber</help>
				<tipo>custom_numeric</tipo>
			</field>

			<field id="haber" suma="true">
				<expression>sum(regimp * (case when regdoh = 2 then 1 else 0 end))</expression> 
				<label>Haber</label>
				<help>Importe del Movimiento en el Haber</help>
				<tipo>custom_numeric</tipo>
			</field>

			<field id="dif" suma="true">
				<expression>sum(regimp * (case when regdoh = 1 then 1 else 0 end)) - sum(regimp * (case when regdoh = 2 then 1 else 0 end))</expression> 
				<label>Dif</label>
				<help>Importe del Movimiento en el Haber</help>
				<condicion operador="!=">0</condicion>
				<tipo>custom_numeric</tipo>
			</field>
			<!--
			<field id="regpoa">
			<label>Estado</label>
			<help>Estado del Movimiento.Aprobado  o  Provisorio </help>
			<options>
			<option valor="A">Aprobado</option>
			<option valor="P">Provisorio</option>
			</options>
			</field>
			<field id="coscod">
			<label>Centro Costo</label>
			<help>Codigo de Centro de Costo </help>
			</field>
			<field id="impcod">
			<label>Cod.Imput.</label>
			<help>Codigo de Centro de Imputacion</help>
			</field>
			<field id="idcos">
			<label>? </label>
			<help> </help>
			</field>
			<field id="idimpu">
			<label>? </label>
			<help> </help>
			</field>
			<field id="regcta">
			<label>? </label>
			<help> </help>
			</field>
			<field id="regfco">
			<label>Fecha Comprobante </label>
			<help> </help>
			</field>
			<field id="regnro">
			<label>Nro.</label>
			<help>Numero de Comprobante Correspondiente. </help>
			</field>
			-->
			<field id="regfec">
				<label>Fecha</label>
				<help>Fecha del Asiento (Movimiento Contable) </help>
				<detalle>regfec</detalle>				
			</field>
			<!--
			<field id="regnpv">
			<label>Nro Puesto </label>
			<help> </help>
			</field>
			<field id="regord">
			<label>Orden en el Asiento  . </label>
			<help> </help>
			</field>
			<field id="regsub">
			<label>Subdiario </label>
			<help> </help>
			</field>
			<field id="reguni">
			<label>Unidades Fisicas     . </label>
			<help>Unidades Fisicas. </help>
			</field>
			-->
			<field id="importe_comp">
			    <label>Imp.Comprobante</label>
				<expression>importe_movimiento</expression>
				<tipo>custom_numeric</tipo>
			</field>
			<order>
				<field id="regmin"></field>
			</order>

			<group>
				<field id="regmin"></field>
				<field id="regfec"></field>
			</group>		
		</table>

		<join tipo="left">
			<table id="CTBCUENT">
<!--				<field id="siscod" oculto="true">
					<condicion operador="=">'10'</condicion>
				</field>
-->				
				<field id="ctbcod" oculto="true">
					<condicion operador="=">CTBREGIS.ctbcod</condicion>
				</field>
				<field id="ctbnom" oculto="true">
				</field>
			</table>
		</join>
		
		<join tipo="left">
			<table id="REG_MOVIMIENTOS">
<!--				<field id="siscod" oculto="true">
					<condicion operador="=">'10'</condicion>
				</field>
-->				
				<field id="regmin" >
					<condicion operador="=">CTBREGIS.regmin</condicion>
				</field>
				<field id="reg_fecha" >
					<condicion operador="=">CTBREGIS.regfec</condicion>
				</field>
				<field id="nro_movimiento" >
					<condicion operador="=">CTBREGIS.regnro</condicion>
				</field>
			</table>
		</join>
		
	</form>
</histrix>