<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" preloadData="false">
	<title>Minutas</title>
	<obs></obs>
	<form >
		<table id="CTBREGIS" label="Minutas">
			<preconsultas>
				<xmlfile id="ctbregismayor_pre.xml"/>
			</preconsultas>         

			<filters>

				<field id="siscod" >
                    <label>Ejercicio</label>
                    <operador>=</operador>
                </field>

                <field id="idcos">
					<label modpos="nobr">Centro de costos</label>
				</field>
				
				<field id="ctbcod_desde">
					<operador>=</operador>
					<label>Desde Cuenta</label>
				</field>

				<field id="regfec_desde">
					<operador>&gt;=</operador>
					<label modpos="nobr">Desde Fecha</label>
					<valor>today</valor>
				</field>

				<field id="ctbcod_hasta">
					<operador>=</operador>
					<label>Hasta Cuenta</label>
				</field>

				<field id="regfec_hasta">
					<operador>&lt;=</operador>
					<label modpos="nobr">Hasta Fecha</label>
					<valor>today</valor>
				</field>
				
			</filters>            
			
			<field id="regmin">
				<label>Minuta </label>
				<help>Número de Asiento </help>
			</field>

			<field id="regfec">
				<label>Fecha </label>
				<help></help>
				<condicion operador="&lt;=">STR_TO_DATE('[__regfec_hasta__]', '%d/%m/%Y') and CTBREGIS.regfec &gt;= STR_TO_DATE('[__regfec_desde__]', '%d/%m/%Y')</condicion>
			</field>

			<field id="regfec_desde" local="true" noshow="true" _required="true">
				<label>desde</label>
				<tipo>date</tipo>
				<preparam campo="regfec" operador="&lt;">true</preparam>
			</field>

			<field id="regfec_hasta" local="true" noshow="true">
				<label>hasta</label>
				<tipo>date</tipo>
			</field>

            <field id="siscod" noshow="true">
            	<preparam campo="siscod" operador="=">true</preparam>
                <helper type="combo" xml="ctbejercicios_crud.xml" dir="/contabilidad/man/">
                    <field id="activo" tipoOrden="DESC" />
                    <field id="fecha_mov1">
                        <expresion>DATE_FORMAT(comienza, '%d/%m/%Y')</expresion>
                        <tipo>date</tipo>
                    </field>
                    <field id="fecha_mov2">
                        <expresion>DATE_FORMAT(finaliza, '%d/%m/%Y')</expresion>
                        <tipo>date</tipo>
                    </field>
                    <field id="finaliza" />
                </helper>
            </field>

            <field id="idcos" modpos="nobr">
				<!-- <expression having="false">CTB_DETALLES.ctbcentro_id</expression> -->
				<label>Centro de costos</label>
				<helper id="CTB_CENTROS"  type="combo" empty="true" >
					<field id="id_ctbcentro" />
					<field id="centro">
						<expression>concat(referencia_centro,' ', nombre_centro)</expression>
					</field> 
				</helper>
			</field>
		
			<field id="ctbcod">
		            <helper type="external" xml="cuentas_habilitadas_qry.xml" dir="/ayudas" empty="true" />

				<label>Cuenta</label>
				<condicion operador="&lt;=">'[__ctbcod_hasta__]' and CTBREGIS.ctbcod &gt;= '[__ctbcod_desde__]'</condicion>	
			</field>
			
			<field id="ctbcod_desde" local="true" noshow="true">
		            <helper type="external" xml="cuentas_habilitadas_qry.xml" dir="/ayudas" empty="true" />
				<label>ctbdesde</label>
				<!-- <ayuda_ex id="CTBCUENT" xml="HLPctbcuent.xml" dir="/help_local">
					<field id="ctbcod">
					</field>
					<field id="ctbnom">
					</field>
				</ayuda_ex>	 -->
				<preparam campo="ctbcod_desde" operador="=">true</preparam>
				<tipo>varchar</tipo>
			</field>

			<field id="ctbcod_hasta" local="true" noshow="true">
		            <helper type="external" xml="cuentas_habilitadas_qry.xml" dir="/ayudas" empty="true" />
				<label>ctbhasta</label>
				<!-- <ayuda_ex id="CTBCUENT" xml="HLPctbcuent.xml" dir="/help_local">
					<field id="ctbcod">
					</field>
					<field id="ctbnom">
					</field>
				</ayuda_ex>	 -->
				<preparam campo="ctbcod_hasta" operador="=">true</preparam>
				<tipo>varchar</tipo>
			</field>

			<field id="ctbnom" tabla="CTBCUENT">
				<label>Nombre</label>
				<help>Codigo de Cuenta Contable</help>
				<tipo>string</tipo>
			</field>
			
			<field id="regref">
				<expression>max(regref)</expression> 
				<label>Referencia</label>
				<help>Referencia</help>
			</field>

			<field id="referencia_movimiento" tabla="REG_MOVIMIENTOS">
                <label>Ref. movimiento</label>
                <help>Referencia del movimiento</help>
            </field>

			<field id="nombre_cuenta" tabla="REG_CUENTA">
			    <label>Nombre</label>
			</field>

			<field id="comprobante" style="white-space:nowrap;">
				<expression>case when isnull(REG_MOVIMIENTOS.nro_movimiento) then concat('Comp: ', regnro) else CONCAT(REG_CONCEPTOS.abreviacion_concepto, LPAD(REG_MOVIMIENTOS.puesto_movimiento, 4, 0), '-', LPAD(REG_MOVIMIENTOS.nro_movimiento, 8, 0)) end</expression>
				<label>Comprobante</label>
			</field>

			<field id="debe" suma="true"  noZero="true">
				<expression>sum(regimp * (case when regdoh = 1 then 1 else 0	end))</expression>
				<label>Debe</label>
				<help>Importe del Movimiento en el Debe</help>
			</field>
			
			<field id="haber" suma="true"  noZero="true">
				<expression>sum(regimp * (case when regdoh = 2 then 1 else 0	end))</expression>
				<label>Haber</label>
				<help>Importe del Movimiento en el Haber</help>
			</field>
	
			<field id="dif" suma="true" local="true" _acumula="true" noZero="true" >
				<expression> sum(regimp * (case when regdoh = 1 then 1 else 0	end)) - sum(regimp * (case when regdoh = 2 then 1 else 0	end))</expression>
				<label>Saldo</label>
				<help>Importe del Movimiento en el Haber</help>
			</field>
			
			<field id="difacum" local="true" acumula="true" suma="true">
			    <if exp="true">
					<true>(dif + 0)</true>
					<false>(dif + 0)</false>
			    </if>
			    <label>Acum</label>
			</field>

			<field id="color" clasefila="true" local="true" noshow="true"/>
	
			<group>
				<field id="CTBREGIS.siscod"></field>
				<field id="CTBREGIS.ctbcod"></field>
				<field id="CTBREGIS.regmin"></field>
				<field id="CTBREGIS.regfec"></field>
				<field id="REG_MOVIMIENTOS.concepto_id"></field>
			</group>

			<order>
				<field id="regfec"></field>
			</order>
			
		</table>
		<join tipo="left">
			<table id="CTBCUENT">
				<field id="ctbcod" oculto="true">
					<condicion operador="=">CTBREGIS.ctbcod</condicion>
				</field>
			</table>
		</join>
		<join tipo="left">
			<table id="REG_MOVIMIENTOS">
				<field id="nro_movimiento" >
					<condicion operador="=">CTBREGIS.regnro</condicion>
				</field>
				<field id="regmin" >
					<condicion operador="=">CTBREGIS.regmin</condicion>
				</field>
				<field id="reg_fecha">
					<condicion operador="=">CTBREGIS.regfec and (CASE WHEN concepto_id = 67 and referencia_movimiento like "%contado%" THEN 1 ELSE 0 END) != 1</condicion>
				</field>
			</table>
		</join>

		<!-- <join>
            <table id="CTB_MOVIMIENTOS">
                <field id="regmovim_id" >
                    <condicion operador="=">REG_MOVIMIENTOS.nro_cuenta</condicion>
                </field>
            </table>
        </join> -->

		<join tipo="left">
			<table id="REG_CUENTA">
				<field id="nro_cuenta" oculto="true">
					<condicion operador="=">REG_MOVIMIENTOS.nro_cuenta</condicion>
				</field>
				<field id="subsistema_id" oculto="true">
					<condicion operador="=">REG_MOVIMIENTOS.subsistema_id</condicion>
				</field>
			</table>
		</join>
		<join tipo="left">
			<table id="REG_CONCEPTOS">
				<field id="id_concepto" oculto="true">
					<condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
				</field>
			</table>
		</join>

		<!-- <join tipo="left">
            <table id="CTB_DETALLES">
                <field id="ctbregis_id">
                    <condicion operador="=">CTBREGIS.id_ctbregis</condicion>
                </field>
            </table>
        </join> -->
	</form>
</histrix>