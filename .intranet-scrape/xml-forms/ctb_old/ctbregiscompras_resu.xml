<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta">
	<title>Asiento Resumen de Compras</title>
	<obs/>
	<form >
		<table id="IVACOMPRAS" label="Asiento Resumen de Compras">

			<filters>
				<field id="fecreg">
					<operador>&gt;=</operador>
					<label>Desde Fecha</label>
					<valor>today</valor>
				</field>
				<field id="fecreg">
					<operador>&lt;=</operador>
					<label>Hasta Fecha</label>
					<valor>today</valor>
				</field>
			</filters>

				<field id="ctbtip" tabla="CTBCUENT" noshow="true"/>

			<field id="codcom" oculto="true">
				<label>cod</label>
				<condicion operador="!=">0</condicion> 
				
			</field> 
		<!--	<field id="regdoh" tabla="CTBREGIS" oculto="true"/> -->
		
			<field id="fecreg" oculto="true">
				<label>Fecha</label>
			</field>
			<field id="ctbcod" tabla="CTBREGIS" >
				<label>Cuenta</label>
				<tipo>varchar</tipo>
			</field>
		<field id="cuenta">
				<expression>ctbnom</expression>
				<label>Cuenta Contable</label>
				<help>Codigo de Cuenta Contable</help>
				<tipo>varchar</tipo>
			</field> 
<!--			<field id="conimp" tabla="CCTCONCE">
				
			</field> -->
			<field id="debe" suma="true" _noshow="true">
				<expression>sum(ABS(regimp) * (case when regdoh &lt; 2  then 1 else 0 end) * (case when CCTCONCE.conimp > 1 then 1 else -1 end) )</expression>

<!--<expression>sum(regimp * (case when regdoh &lt; 2 then 1 else 0 end) ) * (case when CCTCONCE.conimp > 1 then 1 else -1 end)</expression> -->				
				<help>Importe del Movimiento en el Debe</help>
				<tipo>decimal</tipo>
			</field>
			<field id="haber" suma="true" _noshow="true"  >
				<expression>sum(ABS(regimp) * (case when regdoh = 2  then 1 else 0 end) * (case when CCTCONCE.conimp > 1 then 1 else -1 end) )</expression>
<!--	<expression>sum(regimp * (case when regdoh = 2 then 1 else 0 end) ) * (case when CCTCONCE.conimp > 1 then 1 else -1 end)</expression> -->
				<help>Importe del Movimiento en el Haber</help>
				<tipo>decimal</tipo>
			</field>
			<field id="_D_" local="true" suma="true" noZero="true">
				<label>Debe</label>
				<if exp="(debe + 0) &gt; (haber + 0)" operador="=">
					<true>(debe + 0) - ( haber + 0)</true>
					<false>0</false>
				</if>	
				<tipo>decimal</tipo>		
			</field>
			<field id="_H_" local="true" suma="true"  noZero="true">
				<label>Haber</label>			
				<if exp="(haber + 0)  &gt; (debe + 0)" operador="=">
					<true>(haber + 0) - (debe + 0)</true>
					<false>0</false>
				</if>			
				<tipo>decimal</tipo>
			</field>			
			<field id="saldo" local="true" suma="true"  noZero="true">
				<if exp="true" operador="=">
					<true>(debe + 0 ) + ( haber + 0)</true>
					<false>0</false>
				</if>		
				<tipo>decimal</tipo>	
			</field>
			
			<group>

				<field id="CTBREGIS.ctbcod"/> 
			</group>  
			<order>

				<field id="ctbtip" tabla="CTBCUENT"/>

				<field id="CTBREGIS.ctbcod" tabla="CTBREGIS"/>

			</order> 
		</table>
		<join tipo="left">
			<table id="CCTMOVIM">
				<field id="siscod" oculto="true">
					<condicion operador="=">'01'</condicion>
				</field>				
				<field id="concod" >
					<condicion operador="=">IVACOMPRAS.codcom</condicion>
				</field> 
				<field id="ctacod" >
					<condicion operador="=">IVACOMPRAS.ctacod</condicion>
				</field>
				<field id="movnro" >
					<condicion operador="=">IVACOMPRAS.nrocom</condicion>
				</field>
				<field id="movnpv" >
					<condicion operador="=">IVACOMPRAS.nronpv</condicion>
				</field>
				<field id="movfec" >
					<condicion operador="=">IVACOMPRAS.feciva</condicion>
				</field>		 
			</table>
		</join>
		<join tipo="left">
			<table id="CCTCONCE">
				<field id="siscod" oculto="true">
					<condicion operador="=">'01'</condicion>
				</field>
				<field id="concod">
					<condicion operador="=">CCTMOVIM.concod</condicion>
				</field>
			</table>
		</join>		
		<join tipo="left">
			<table id="CTBREGIS">
				<field id="regnro" oculto="true">
					<condicion operador="=">IVACOMPRAS.nrocom </condicion>
				</field>  
                <field id="regfec" oculto="true">
					<condicion operador="=">CCTMOVIM.regfec</condicion>
				</field>				
				<field id="regmin" oculto="true">
					<condicion operador="=">CCTMOVIM.regmin</condicion>
				</field>				
				
			</table>
		</join>
		<join tipo="left">
			<table id="CTBCUENT">
<!--				<field id="siscod" oculto="true">
					<label>cctcuent.siscod</label>
					<condicion operador="=">'10'</condicion>
				</field>
-->
				<field id="ctbcod" oculto="true">
					<condicion operador="=">CTBREGIS.ctbcod</condicion>
				</field>
			</table>
		</join>
	</form>
</histrix>
