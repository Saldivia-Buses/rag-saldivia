                  <field id="siscod" noshow="true">
                    <preparam campo="siscod" operador="=">true</preparam>
                      <helper type="combo" xml="ctbejercicios_crud.xml" dir="/contabilidad/man/">
                          <field id="activo" tipoOrden="DESC" />
                          <field id="fecha_mov1">
                              <expresion>DATE_FORMAT(comienza, '%d/%m/%Y')</expresion>
                              <tipo>date</tipo>
                          </field>
                          <field id="fecha_mov2">
                              <expresion>DATE_FORMAT(finaliza, '%d/%m/%Y')</expresion>
                              <tipo>date</tipo>
                          </field>
                          <field id="finaliza" />
                      </helper>
                  </field>

                  <field id="idcos" modpos="nobr" _tabla="CTB_DETALLES">
                    <!-- <expression having="false">CTB_DETALLES.ctbcentro_id</expression> -->
                    <label>Centro de costos</label>
                    <helper id="CTB_CENTROS"  type="combo" empty="true" _multiple="true">
                      <field id="id_ctbcentro" />
                      <field id="centro">
                        <expression>concat(referencia_centro,' ', nombre_centro)</expression>
                      </field> 
                    </helper>
                  </field>

                  <field id="ctbcod" noshow="true">
              					<helper type="external" id="CTBCUENT">
              						<field id="ctbcod"></field>
              						<field id="ctbnom"></field>
              						<field id="ctbhab">
              						<condicion operador="=">1</condicion>
              						</field> 
              						<order>
              							<field id="ctbnom"></field>
              						</order>
              					</helper>
                      <help> Cuenta</help>
		      
                  </field>

                  <field id="regfec" PDFwidth="4" tdWidth="4" noResize="true">
                      <label>Fecha</label>
                      <help>Fecha del Asiento (Movimiento Contable) </help>
                      <detalle>regfec</detalle>

                  </field>
                  <field id="regmin" noshow="true">
                      
                      <help>Numero de Asiento </help>
		                  <detalle>regmin</detalle>

                  </field>
                  <field id="datos">
                    <label>Minuta </label>
                    <expression>concat(regmin,' - comp: ', regnro, ' ', regref)</expression>
                  </field>
                  <!--
                  <field id="regnro" >
                    <label>Nro</label>
                  </field>

                  <field id="regref">
                      <label>Ref</label>
                      <help>Referencia</help>
                  </field>
-->
                  <field id="minuta" showObjTabla="true" local="true">
                    <label>Detalle</label>
                    <helper xml="detalle_minuta.xml" type="object">
                      <parameter source="regmin" target="regmin" />
                      <parameter source="regfec" target="regfec" />
                      <parameter source="siscod" target="siscod" />
                    </helper>
                  </field>


                  <field id="cuenta" noshow="true">
		                <expression>ctbnom</expression>
                      <label>Cuenta</label>
                      <help>Codigo de Cuenta Contable</help>
		                  <tipo>string</tipo>
                  </field>

		<!--
                  <field id="regtip">
                      <label>Cod.Comp.</label>
                      <help>Codigo de Comprobante </help>
                  </field>
		  -->
