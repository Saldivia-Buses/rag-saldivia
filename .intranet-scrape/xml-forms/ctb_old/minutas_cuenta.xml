<?xml version="1.0" encoding="UTF-8" ?>
   <histrix tipo="consulta">
       <title>Minutas</title>
        <obs></obs>
               <form  >
                  <table id="CTBREGIS" label="Minutas" >
              		  <filters>

                      <field id="siscod" >
                        <label>Ejercicio</label>
                        <operador>=</operador>
                      </field>

                      <field id="idcos">
                        <label>Centro de costos</label>
                      </field>

                			<field id="regfec"  >
                			    <operador>&gt;=</operador>
                			    <label modpos="nobr">Desde Fecha</label>
                			    <valor>today</valor>
                			</field>  

                			<field id="regfec"  >
                			    <operador>&lt;=</operador>
                			    <label modpos="nobr">Hasta Fecha</label>
                			    <valor>today</valor>
                			</field>  

                			<field id="ctbcod">
                				<operador>=</operador>
                				<label modpos="nobr">Cuenta</label>
                			</field>
              			
              		  </filters>
