<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="liveGrid" imprime="false" deleteRow="false">
  <title>Tareas por unidad</title>
  <obs></obs>
<!--
  <eventos>
    <event id="insert">refresh</event>
    <event id="update">refresh</event>
    <event id="delete">refresh</event>
  </eventos>
-->
  <form >
    <table id="SERVICE_TAREA_UNIDAD" label="TAREAS X UNIDAD">
      <field id="idTareaUnidad" autoinc="true" noshow="true">
        <label>id</label>
      </field>
      <field id="idTurno" noshow="true" valauto="true">
        <label>idService</label>
      </field>
      <field id="idTarea" >
        <label>Cod. Tarea</label>
        <ayuda_ex id="SERVICE_TAREAS" _xml="HLPservice_tareas.xml" dir="/help_local">
          <field id="idTarea" >
            <label>id</label>
          </field>
          <field id="nomTarea" >
            <label>Tarea</label>
            <detalle>nomTarea</detalle>
          </field>
          <field id="tiempoEst" noshow="true">
            <detalle>tiempo</detalle>
          </field>
          <field id="cargo" noshow="true">
            <detalle>cargo</detalle>
          </field>
          <field id="activo" noshow="true">
            <condicion operador="=">0</condicion>
          </field>
          </ayuda_ex>
      </field>
      <field id="nomTarea" >
        <expression>SERVICE_TAREAS.nomTarea</expression>
        <label>Descrpción</label>
      </field>
      <field id="observaciones" >
        <label>Observ</label>
        <help>Observaciones</help>
        <size>50</size>
      </field>
      <field id="responsable_id">
	<helper type="combo" xml="HLPpersonal_ope.xml" dir="/help_local" empty="true">
	    <field id="fechaEgreso">
		<condicion operador="=">'0000-00-00'</condicion>
	    </field>
	</helper>
        <label modpos="nobr">Responsable</label>
        <help >Empleado responsable de la Acción</help>
      </field>

      <field id="cargo" >
        <label>Tipo</label>
        <tipo>time</tipo>
        <options>
          <option valor="0">Sin Cargo</option>
          <option valor="1">Con Cargo</option>
          <option valor="2">Con Cargo 3ro</option>
	              <option valor="3">Envio de Repuestos</option>
              <option valor="4">Viaje</option>

        </options>
      </field>
      
      <field id="cumplida" editable="true">
        <label>Cumplida</label>
        <tipo>check</tipo>
        <jseval campodestino="usuario">yo</jseval>
<!--        <jseval campodestino="user">yo</jseval> -->
      </field>
      <field id="tiempo" editable="true">
        <label>Tiempo </label>
        <tipo>time</tipo>
      </field>

      <field id="yo" local="true" _noshow="true" style="display:none;" editable="true">
        <valor eval="true">$_SESSION['idUser']</valor>
      </field>
			<field id="usuario" editable="true" deshabilitado="true" _noshow="true" style="display:none;">
				<label>Usuario </label>
				<help>Usuario que hace el pedido</help>
        <!--
				<helper id="HTXUSERS" type="combo" empty="true">
					<field id="id_usuario"></field>
					<field id="nombre">
            <expression>concat(ifnull(nombre, ''), ' ', ifnull(apellido, ''))</expression>
          </field>
          <field id="baja">
            <condicion operador="=">0</condicion>
          </field>
					<order>
						<field id="nombre"></field>
					</order>
				</helper>
        -->
    <!--    <expression>(case when usuario != 0 then usuario else [__yo__] end)</expression> -->
				
			</field>      
      <field id="user" _editable="true">
        <expression>usuario</expression>

				<helper id="HTXUSERS" type="combo">
					<field id="id_usuario"></field>
					<field id="nombre">
            <expression>concat(ifnull(nombre, ''), ' ', ifnull(apellido, ''))</expression>
          </field>
          <field id="baja">
            <condicion operador="=">0</condicion>
          </field>
					<order>
						<field id="nombre"></field>
					</order>
				</helper>

      </field>
      <field id="aprobacion_final" editable="true">
        <label>aprobacion final</label>
        <tipo>check</tipo>
      </field>      

    </table>
    <join tipo="left">
      <table id="SERVICE_TAREAS">
        <field id="idTarea">
          <condicion operador="=">SERVICE_TAREA_UNIDAD.idTarea</condicion>
        </field>
      </table>
    </join>
  </form>
</histrix>