<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="crud" subtipo="vertical"  path="/fotos/archivo/Services/" paginar="50">
  <title>TURNOS DE SERVICE/REPARACION</title>
  <obs/>
  <form>
    <table id="SERVICE_TURNOS" label="Turnos de Reparaciones">

      <filters>
      	<field id="ctacod">
      	    <label>Cliente</label>
      	    <operador>=</operador>
      	</field>
      	<field id="nrofab">
      	    <label>Nro.</label>
      	    <operador>=</operador>
      	</field>
      </filters>

      <field id="siscli" noshow="true" local="true">
        <valor>'02'</valor>
      </field>
      
      <field autoinc="true" id="idTurno"  esClave="true" _deshabilitado="true" _valauto="true" noshow="true">
        <label modpos="nobr" _Formstyle="display:none;">Turno</label>
        <help>Turno</help>
<!--
	<actualiza>
	    <field id="trabajos" destino="idTurno" />
	</actualiza>
-->
      </field>

      <field id="fecha" tipoOrden="DESC" calendarStartDate="true">
        <label modpos="nobr" >Fecha</label>
        <tipo>date</tipo>
        <valor>today</valor>
      </field>

      <field id="fechaFin">
      	<label modpos="nobr">Fecha Fin</label>
      	<tipo>date</tipo>

      </field>
      
      <field id="numero" _deshabilitado="true">
        <label modpos="nobr" style="font-size:15px; color:red;">Número</label>
        <help>Número de Reparación/Service</help>
        <parametro id="service_numerador.xml" retorna="numero2">
          <field id="numero" noselect="true">
          </field>
        </parametro>
      </field>
      
      <field id="ctacod" calendarSubject="true">
        <label _modpos="nobr" >Cliente:</label>
        <help>Código de Cuenta</help>
      	<helper type="external" id="CCTCUENT">
    			<field id="ctacod"/>
    			<field id="ctafan">
           		<expression>LEFT(ctafan, 22)</expression>
          	</field>
    			<field id="siscod">
    				<condicion operador="=">02</condicion>
  			</field><!--
  			<field id="catcod">
  				<condicion operador="=">1</condicion>
  			</field>-->
  		  </helper>
        <actualiza>
          <field destino="ctacod" id="idconta"/>
        </actualiza>
      </field>

      <field deshabilitado="true" id="ctacodot" local="true" linkint="fichas_x_cliente.xml" linkdes="Total de Coches" print="false">
        <expression>select count(*) from PEDCOTIZ as PED where PED.ctacod = SERVICE_TURNOS.ctacod</expression>
        <label >Ot.</label>
        <help>Código de Cuenta</help>
        <paring destino="ctacod">ctacod</paring>
        <tipo>varchar</tipo>
      </field>

        <field id="ficha_id" noshow="true">
            <expression>PEDCOTIZ.id</expression>
        </field>

        <field id="nrofab"  noZero="true" deshabilitado="false">
            <label _modpos="nobr" style="text-align:center;color:#444;font-size:14px;">Fab</label>
            <help>Número de Fabricación</help>
                <paring destino="nrocha">nrofab</paring>
            <helper type="link" xml="ficha_producto1_qry.xml" dir="/producto" modal="true" title="Ficha Técnica">
                <parameter source="ficha_id" target="producto_id"/>
                <parameter source="nrofab" target="nrofab"/>
            </helper>
        </field>
        
        <field id="idconta" >
          <label modpos="nobr" colspan="4">Contacto</label>
          <help>Código de Cuenta</help>
          <tabla_ex condes="true" id="CCTCONTA" vacio="true">
            <field id="idconta"/>
            <field id="nombre">
              <expression>CONCAT(nombre,'-' , mail, ' - ', Telefono)</expression>
            </field>
            <field id="ctacod" oculto="true" >
            </field>
            <field id="siscod" oculto="true">
              <condicion operador="=">'02'</condicion>
            </field>
          </tabla_ex>
        </field>
        
        <field deshabilitado="true" id="ctacod2" tabla="PEDCOTIZ" linkint="cctconta_consulta.xml" linkdes="Ver medios de Contacto">
          <expression>SERVICE_TURNOS.ctacod</expression>
          <label Formstyle="display:none;" style="width:auto;">Cliente</label>
          <help>Código de Cuenta</help>
          <tabla_ex condes="true" id="CCTCUENT">
            <field id="ctacod"/>
            <field id="ctafan">
              <expression>LEFT(ctafan, 17)</expression>
            </field>
            <field id="siscod" oculto="true">
              <condicion operador="=">'02'</condicion>
            </field>
          </tabla_ex>
          <paring destino="ctacod">ctacod</paring>
          <paring destino="siscod">siscli</paring>
          <tipo>button</tipo>
        </field>

        <field id="trabajos" _obj="service_tarea_unidad.xml" showObjTabla="true"  showValor="true" linkint="service_tarea_unidad.xml" linkdes="Tareas" local="true" >
          <label Formstyle="display:none;" colspan="5" >Tareas a Realizar</label>
          <paring destino="idTurno" operador="=">idTurno</paring>
          <valor>Agregar / Modificar Tareas</valor>
          <tipo>varchar</tipo>
        </field>
        
        <field id="corpath" local="true" noshow="true">
          <if exp="true">
            <true>'nrofab/corte'</true>
            <false>''</false>
          </if>
          <tipo>varchar</tipo>
        </field>
        
        <field id="cortePint" tabla="PEDCOTIZ" path="corpath" download="true" print="false" disabled="true" local="true">
          <label Formstyle="display:none">Corte</label>
          <tipo>file</tipo>
        </field>
        
        <field id="Imprimir" linkint="service_ficha.xml" linkdes="Ver Ficha de service" local="true">
          <label modpos="nobr" style="font-weight:bold; height:3em;width:auto;" Formstyle="display:none;">Ficha</label>
          <paring destino="idTurno">idTurno</paring>
          <valor>Imprimir</valor>
        </field>

        <field id="numpath" noshow="true">
          <expression>numero</expression>
        </field>

      <field id="archivo"  local="true" _browse="true" _deshabilitado="true" path="numpath" colstyle="display:none;" width="25">
        <label Formstyle="width:10px;">Fotos.</label>
        <tipo>file</tipo>
        <size>45</size>
      </field>                 

      <field id="fotos" _imageWidth="165" watermark="chasis" style="white-space:nowrap;" Formstyle="display:none;" deshabilitado="true" _foto="true"  PDFcolWidth="11">
        <expression>CONCAT('/fotos/archivo/Services/', numero,'/')</expression>
        <label>Fotos</label>
        <tipo>dir</tipo>
      </field>

        <order>
          <field id="fecha"/>
        </order>

      </table>

        <join tipo="left">
          <table id="PEDCOTIZ">
            <field id="nrocha">
              <condicion operador="=">SERVICE_TURNOS.nrofab</condicion>
            </field>
          </table>
        </join>
        
      </form>
      </histrix>
