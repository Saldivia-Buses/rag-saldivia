<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="ayuda" >
    <title>Service</title>
    <obs></obs>
    <form >
        <table id="CHASIS">
            <title>CHASIS</title>

            <field id="nrocha">
                <label>Numero</label>
            </field>

            <field id="desC">
                <label>Descripcion</label>
                <expression>concat(MARCHASIS.desabv,' ', MODCHASIS.moddes,' - ', CARROCERIA.desabv, '(', PEDCOTIZ.cantasi,') ')</expression>
                <tipo>varchar</tipo>
                <detalle>chades</detalle>
            </field>
            <field id="ctacod" oculto="true">
                <expression>PEDCOTIZ.ctacod</expression>
                <label modpos="nobr">Cod.</label>
                <detalle>ctacod</detalle>
            </field>
            <field id="ctanom" oculto="true">
                <expression>CCTCUENT.ctanom</expression>
                <label modpos="nobr">Nombre</label>
                <detalle>ctanom</detalle>
            </field>
            <field id="homologacion_id" tabla="PEDCOTIZ">
                <label>Homolog</label>
                <detalle>homologacion_id</detalle>
            </field>
            <order>
                <field id="CHASIS.nrocha"></field>
            </order>
        </table>
        <join tipo="left">
            <table id="MARCHASIS">
                <field id="marcod">
                    <condicion operador="=">CHASIS.marcod</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="MODCHASIS">
                <field id="marcod">
                    <condicion operador="=">CHASIS.marcod</condicion>
                </field>
                <field id="modcha">
                    <condicion operador="=">CHASIS.modcod</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="PEDCOTIZ">
                <field id="nrocha">
                    <condicion operador="=">CHASIS.nrocha</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="CARROCERIA">
                <field id="nrocar">
                    <condicion operador="=">PEDCOTIZ.nrocar</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="CCTCUENT">
                <field id="ctacod">
                    <condicion operador="=">PEDCOTIZ.ctacod</condicion>
                </field>
                <field id="siscod">
                    <label>Codigo</label>
                    <condicion operador="=">'02'</condicion>
            </field>
            </table>
        </join>
    </form>

    <form >
        <table id="SERVICE_TURNOS" >
            <field id="nrocha">
		<expression>numero</expression>
                <label>Numero</label>
            </field>
            <field id="desC">
                <label>Descripcion</label>
                <expression having="false">concat(MARCHASIS.desabv,' ', MODCHASIS.moddes,' - ', CARROCERIA.desabv, '(', PEDCOTIZ.cantasi,') ')</expression>
                <tipo>varchar</tipo>
                <detalle>chades</detalle>
            </field>
            <field id="ctacod" oculto="true">
                <label modpos="nobr">Cod.</label>
                <detalle>ctacod</detalle>
            </field>
            <field id="ctanom" oculto="true">
                <expression>CCTCUENT.ctanom</expression>
                <label modpos="nobr">Nombre</label>
                <detalle>ctanom</detalle>
            </field>
            <field id="homologacion_id" tabla="PEDCOTIZ">
                <label>Homolog</label>
                <detalle>homologacion_id</detalle>
            </field>
        </table>

        <join tipo="left">
            <table id="CHASIS">
                <field id="nrocha2">
                    <expression having="false">CHASIS.nrocha</expression>
                    <condicion operador="=">SERVICE_TURNOS.nrofab</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="MARCHASIS">
                <field id="marcod">
                    <condicion operador="=">CHASIS.marcod</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="MODCHASIS">
                <field id="marcod">
                    <condicion operador="=">CHASIS.marcod</condicion>
                </field>
                <field id="modcha">
                    <condicion operador="=">CHASIS.modcod</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="PEDCOTIZ">
                <field id="nrocha3">
                    <expression having="false">PEDCOTIZ.nrocha</expression>
                    <condicion operador="=">SERVICE_TURNOS.nrofab</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="CARROCERIA">
                <field id="nrocar">
                    <condicion operador="=">PEDCOTIZ.nrocar</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="CCTCUENT">
                <field id="ctacod">
                    <condicion operador="=">PEDCOTIZ.ctacod</condicion>
                </field>
                <field id="siscod">
                    <label>Codigo</label>
                    <condicion operador="=">'02'</condicion>
            </field>
            </table>
        </join>
    </form>

</histrix>
