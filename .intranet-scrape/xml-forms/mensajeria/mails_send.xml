<?xml version="1.0" encoding="UTF-8"?>
<histrix  tipo="fichaing" class="consultaancha" imprime="false" tabindex="1000" borra="false" tooltip="false" inserta="false" modifica="false"
          path="../tmp" btnconfirma="ENVIAR" hasFieldset="false">
    <title>Enviar Correo</title>
    <obs/>
    <eventos>
        <event id="procesar">close</event>
    </eventos>
    <form >
        <table id="HTXMAIL" label="enviar Correo" styleTbody="height:325px;overflow-x:hidden;">
            <movimientos>
                <relacion id="mails_send_ingmov.xml"></relacion>
            </movimientos>
            <field autoinc="true" id="idMail" noshow="true" tipoOrden="DESC">
                <label>id</label>
            </field>

            <field  id="hora" valauto="true" deshabilitado="true" noshow="true">
                <label modpos="nobr">Hora</label>
                <valor eval="true">date('H:i:s')</valor>
                <tipo>varchar</tipo>
            </field>
            <field id="nom" local="true"  noselect="true" noshow="true">
                <valor eval="true">$_SESSION['usuario']</valor>
                <tipo>varchar</tipo>
            </field>

            <field deshabilitado="true" id="de" valoropcion="true">
                <label>de</label>
                <help></help>
                <size>10</size>
                <tabla_ex id="HTXUSERS">
                    <field id="login2" >
                        <expresion>LCASE(login)</expresion>
                    </field>
                    <field id="email" >
                        <expresion>LCASE(email)</expresion>
                    </field>
                </tabla_ex>
                <tipo>varchar</tipo>
                <valor eval="true">strtolower ( $_SESSION['usuario'])</valor>
                <condicion operador="=" valorde="nom" ></condicion>
            </field>
            <field id="fecha" valauto="true" deshabilitado="true">
                <label modpos="nobr">Fecha</label>
                <valor>today</valor>
                <tipo>date</tipo>
            </field>
            <field id="para" autocompletar="true" validar="false">
                <helper xml="htxaddressbook_qry.xml" type="external" >
			<field id="value" >
				<expresion having="false">trim(value)</expresion>
                               <label>email</label>
                                <detalle>para</detalle>
                        </field>
                        <field id="vcard_type" noshow="true">
                            <condicion operador="like">'%EMAIL%'</condicion>
                        </field>

                </helper>
                <label colspan="4">Para</label>
                <size>55</size>
            </field>
            <field id="cc_email" autocompletar="true" validar="false">
                <helper id="HTXADDRESSBOOK" type="external" >
			<field id="name1" >
                                <label>Nombre</label>
                                <expresion>concat(first_name, ' ', last_name,' ',value)</expresion>
                        </field>
			<field id="value" >
				<expresion having="false">trim(value)</expresion>

                               <label>email</label>
                                <detalle>cc_email</detalle>
                        </field>
                        <field id="vcard_type" noshow="true">
                            <condicion operador="like">'%EMAIL%'</condicion>
                        </field>
                </helper>
                <label colspan="4">Copia</label>
                <size>55</size>
            </field>
            <field id="subject">
                <label colspan="4">Asunto</label>
                <tipo>varchar</tipo>
                <size>55</size>
            </field>
            <!--            <field id="checkAdjunto" >
                 <label colspan="4">Adjunto</label>
                <tipo>check</tipo>
            </field> -->
            <field id="adjunto" local="true" deshabilitado="true" noselect="true" imagen="true" hidden="true" _sincelda="true">
                <label colspan="4">Adjuntos</label>
                <tipo>file</tipo>
                <size>50</size>
            </field>
            <field id="filesArray" local="true" deshabilitado="true" noselect="true" imagen="true" hidden="true" sincelda="true" oculto="true">
                <label modpos="nobr"></label>
                <tipo>file</tipo>
                <size>50</size>
            </field>

            <field id="mensaje">
                <label colspan="3">mensaje</label>
                <help>Texto del mensaje</help>
                <tipo>simpleditor</tipo>
                <size>300</size>
            </field>
            <order>
                <field id="idMensaje"/>
            </order>
        </table>
    </form>
</histrix>
