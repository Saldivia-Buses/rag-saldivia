			<field id="idMensaje" noshow="true" tipoOrden="DESC">
				<label>id</label>

			</field>
			<field  id="fec2" deshabilitado="true" local="true" noshow="true">
				<label modpos="nobr" Formstyle="display:none;">Fec2</label>
				<tipo>date</tipo>
					<valor eval="true">date("d/m/Y", mktime(0, 0, 0, date("m") ,
						date("d")-15, date("Y")))</valor>					

<!--				<preparam campo="fecha" operador="&gt;=">true</preparam>
 -->
			</field>
			
			<field  id="fecha">
				<label Formstyle="display:none;" >Fecha</label>
				<valor>today</valor>
<!--				<preparam campo="fecha" operador="&lt;=">true</preparam> -->
			</field>
			<field deshabilitado="true" id="hora" >
				<label Formstyle="display:none;">Hora</label>
			</field>
			<field deshabilitado="true" id="DE" >
				<expresion>de</expresion>
				<label>de</label>
				<tipo>varchar</tipo>
			</field>
			
			<field deshabilitado="true" id="_de" local="true" noshow="true">
				<tipo>varchar</tipo>
			</field>
			<field id="para" deshabilitado="true" noshow="true" >
			</field>
			
			<field id="_para" deshabilitado="true" noshow="true" local="true">
			</field>
			<field id="depara" deshabilitado="true" noshow="true">
			    <expresion having="false">CONCAT(de,para)</expresion>
			    <condicion operador="=">'[___de__][___para__]' or CONCAT(de,para) = '[___para__][___de__]'</condicion>
			    
			</field>
			
			
			<field id="title" deshabilitado="true" >
			<label>asunto</label>
			</field>
			
			<field id="mensaje" deshabilitado="true">
				<expresion>case when isnull((select obs from HTXLOG where HTXLOG.idEvento = HTXMESSAGES.idEvento and HTXMESSAGES.idEvento != '' and (tipo = 'UPDATE' or tipo = 'DELETE') limit 1)) then mensaje else CONCAT(mensaje, ' (',(select obs from HTXLOG where HTXLOG.idEvento = HTXMESSAGES.idEvento and (tipo = 'UPDATE' or tipo = 'DELETE') limit 1),')') end </expresion>
				
				<label Formstyle="display:none;"
					colstyle="color:#444;font-size:15px;">mensaje</label>
				<help>Texto del mensaje</help>
			</field>
			<field id="msg2" deshabilitado="true"  local="true" noshow="true">
				<if exp="true">
					<true>'%0A%0A'.str_replace('%0A', '%0A>>', urlencode('>>mensaje'))</true>
					<false>''</false>
				</if>
				<tipo>varchar</tipo>
			</field>			
		
			<field id="idEvento" noshow="true">
                            <condicion operador="=">'' or isnull(idEvento)</condicion>
                        </field>
			<field id="det" print="false" local="true" linkint="log_msg_cons.xml" linkdes="Detalle">
        		        <label Formstyle="display:none;">Detalles</label>				
				<paring destino="idEvento" operador="=">idEvento</paring>
				<tipo>varchar</tipo>
				<if exp="strlen('idEvento') != 0">
					<true>'Detalle'</true>
					<false>''</false>
				</if>
			</field>				
			

			<field id="responder" local="true" print="false"  linkint="mensajes_reply.xml" linkdes="Responder este Mensaje">
				<label Formstyle="display:none;">Responder</label>
				<tipo>varchar</tipo>
				<valor><![CDATA['<img alt="../img/mail_generic.png" src="../img/mail_generic.png"/>']]></valor>
				<paring destino="para" operador="=">DE</paring>
				<paring destino="idHilo" >idMensaje</paring>
				<paring destino="mensaje" operador="=">msg2</paring>					
			</field>			
								
			<field id="leido" deshabilitado="true">
				<label Formstyle="display:none;">leido</label>
				<options>
					<option valor="0">No</option>
					<option valor="1">Si</option>
				</options>
				<tipo>check</tipo>
				
			</field>

			<field id="hi" deshabilitado="true" clasefila="true" noshow="true" _local="true">
			    <expresion>case when de = '[___de__]' then 'grisado' end</expresion>

				<tipo>varchar</tipo>
			</field>
			
			<order _ordenaTemporal="true">
				<field id="idMensaje"/>
			</order>
		</table>
