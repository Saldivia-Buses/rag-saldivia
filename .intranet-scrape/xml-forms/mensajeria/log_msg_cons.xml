<?xml version="1.0" encoding="ISO-8859-1" ?>
<histrix tipo="consulta">
	<title>HISTORICO</title>
	<obs></obs>
	<consulta>
		<table id="HTXLOG" label="Historico">

			<field id="xmlprog" oculto="true">
			</field>
			<field id="tipo" noshow="true">
				<label>Acción</label>
				<options>
					<option valor="INSERT"> insertó el registro</option>
					<option valor="UPDATE"> Modificó </option>
					<option valor="DELETE"> Borró el registro</option>
				</options>
			</field>
			<field id="idEvento" noshow="true">
				<tipo>varchar</tipo>
				<condicion operador="=">'[__idEvento__]'</condicion>
					
			</field>			
			<field id="obs" noshow="true"></field>
			<field id="acc">
			<!--	<expresion>case when tipo="UPDATE" then CONCAT('el campo "', campo, '" de "', valorViejo, '" a ' , valorNuevo, ' de: ', obs ) else CONCAT('donde ', obs) end</expresion> -->
					<expresion>case when tipo="UPDATE" then CONCAT('el campo "', campo, '" a ' , valorNuevoTxt ) else CONCAT('donde ', obs) end</expresion> 
				<tipo>varchar</tipo>
				<size>200</size>
			</field>			
		</table>
		<join tipo="left">
			<table id="HTXUSERS">
				<field id="login">
					<condicion operador="=">HTXLOG.usuario</condicion>
				</field>
			</table>
			
		</join>
	</consulta>	   
</histrix> 