<?xml version="1.0" encoding="UTF-8"?>
<histrix    tipo="cabecera" barraDrag="false" >
	<title>Contenido</title>
	<obs/>
	<form >
		<table id="HTXUSERS" label="Mensajes" styleTbody="height:150px;overflow-x:hidden;" >
			<field id="de" deshabilitado="true">
				<label>de</label>
				<tipo>varchar</tipo>
				<valor eval="true">$_SESSION['usuario']</valor>
			</field>
			<field id="fecha" deshabilitado="true">
				<label modpos="nobr">Fecha</label>
				<tipo>date</tipo>
				<valor>today</valor>
			</field>
			<field id="hora" deshabilitado="true" noshow="true">
				<label modpos="nobr">Fecha</label>
				<valor>NOW()</valor>
			</field>			
			<field id="contenido" >
				<label>Texto</label>
				<tipo>varchar</tipo>
				
				<size>200</size>
			</field>
		</table>
	</form>
</histrix>
