<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="crud" path="ISO9000">
	<title>LISTADO MAESTRO DE DOCUMENTACION</title>
	<obs></obs>
	<form >
		<table id="CAL_DOCUMENTOS" label="Documentacion">
			<filters>
				<field id="tipodocumento_id">
					<helper xml="cal_tipo_documento.xml" type="combo" />
					<label>Tipo</label>
					<help>Tipoo de Documento</help>
					<operador>=</operador>
				</field>

			</filters>

			<field id="id_documento" noshow="true" autoinc="true" />

			<field id="tipodocumento_id">
				<helper xml="cal_tipo_documento.xml" type="combo" />
				<label>Tipo</label>
				<help>Tipoo de Documento</help>
			</field>

			<field id="codigo_documento">
				<label>código</label>
				<help>código de Documento</help>
			</field>
			<field id="nombre_documento">
				<label>Nombre</label>
				<help>Nombre de Documento</help>
			</field>
			<field id="vigencia_documento">
				<label>vigencia</label>
				<help>vigencia de Documento</help>
			</field>
			<field id="emisor_documento">
				<label>emisor</label>
				<help>emisor de Documento</help>
				<size>60</size>
			</field>
			<field id="distribuidor_documento">
				<label>Distribucion</label>
				<help>Distribuidor del Documento</help>
				<size>60</size>
			</field>
			<field id="aprueba_documento">
				<label>Aprobado por</label>
				<help>Aprobación del Documento</help>
				<size>60</size>
			</field>
			<field id="conservacion_documento">
				<label>conservacion</label>
				<help>conservacion de Documento</help>
				<size>60</size>
			</field>

			<field id="guarda_documento">
				<label>Guarda</label>
				<help>Guarda de Documento</help>
			</field>

			<field id="revision_documento">
				<label>Revisión</label>
				<help>Revisión de Documento</help>
			</field>

			<field id="archivo_documento" _path="codigo_documento" viewer="true" print="false">
				<label>Archivo</label>
				<help>Archivo del Documento</help>
				<tipo>file</tipo>
				<size>50</size>
			</field>

		</table>
	</form>
</histrix>

