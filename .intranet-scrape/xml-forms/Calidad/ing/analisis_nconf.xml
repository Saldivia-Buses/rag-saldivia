						<field id="id_usuario"/>
						<field id="nombre">
							<expression>CONCAT(apellido, ' ', Nombre)</expression>
						</field>
						<field id="baja">
							<condicion operador="=">0</condicion>
						</field>
						<order>
							<field id="nombre"/>
						</order>
		            </helper>
				</field>
				
				<field id="test" noshow="true">
					<expression having="false">'[__filt_resp__]' IN (SELECT HTXUSERS.id_usuario FROM CAL_ACCIONES_NCONF can LEFT JOIN HTXUSERS ON can.resp_rhpersonal_id = HTXUSERS.id_usuario WHERE can.noconformidad_id = CAL_NOCONFORMIDADES.id_noconformidad) or '[__filt_resp__]' = CAL_NOCONFORMIDADES.responsable_nconf</expression>
				</field>

				<field id="test2" local="true" validRow="true" noshow="true">
					<if exp="filt_resp + 0">
						<true>test</true>
						<false>1</false>
					</if>
				</field>
