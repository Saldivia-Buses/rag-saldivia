		<field id="login_id" colstyle="display:none;">
		    <expression>CONCAT(creador.apellido, ' ', creador.Nombre)</expression>
		    <label>Creador</label>
                </field>

				<field id="responsables">
		    <expression><![CDATA[
		    IFNULL((CASE WHEN 
		    (SELECT  
		    REPLACE(GROUP_CONCAT(DISTINCT CONCAT(h.apellido, ' ', LEFT(h.Nombre, 1), '.')), ",", "</br>") 
		    FROM CAL_ACCIONES_NCONF can LEFT JOIN HTXUSERS h ON can.resp_rhpersonal_id = h.id_usuario 
		    WHERE can.noconformidad_id = CAL_NOCONFORMIDADES.id_noconformidad)
		    
		    LIKE   CONCAT('%',responsable.apellido, ' ', LEFT(responsable.Nombre, 1), '.', '%') 
		    
		    THEN
		     
		     ( REPLACE(
		     
		     (SELECT  
		    REPLACE(GROUP_CONCAT(DISTINCT CONCAT(h.apellido, ' ', LEFT(h.Nombre, 1), '.')), ",", "</br>") 
		    FROM CAL_ACCIONES_NCONF can LEFT JOIN HTXUSERS h ON can.resp_rhpersonal_id = h.id_usuario 
		    WHERE can.noconformidad_id = CAL_NOCONFORMIDADES.id_noconformidad), CONCAT(responsable.apellido, ' ', LEFT(responsable.Nombre, 1), '.'),
		    CONCAT('<i><b>', responsable.apellido, ' ', LEFT(responsable.Nombre, 1), '.', '</b></i>')
		    
		    )               )
		    
		    ELSE
		    
		    (SELECT DISTINCT CONCAT('<i><b>', CONCAT(responsable.apellido, ' ', LEFT(responsable.Nombre, 1), '.'), '</b></i>', "</br>", 
		    REPLACE(GROUP_CONCAT(DISTINCT CONCAT(h.apellido, ' ', LEFT(h.Nombre, 1), '.')), ",", "</br>")) 
		    FROM CAL_ACCIONES_NCONF can LEFT JOIN HTXUSERS h ON can.resp_rhpersonal_id = h.id_usuario 
		    WHERE can.noconformidad_id = CAL_NOCONFORMIDADES.id_noconformidad)
		    
		    END), CONCAT('<i><b>', responsable.apellido, ' ', LEFT(responsable.Nombre, 1), '.', '</b></i>'))
		    
		    ]]></expression>
					<label Formstyle="display:none;">Responsables</label>
		    <tipo>editor</tipo>
				</field>
				
				<field id="responsablesnum" noshow="true">
					<expression><![CDATA[(SELECT GROUP_CONCAT(DISTINCT h.id_usuario) FROM CAL_ACCIONES_NCONF can LEFT JOIN HTXUSERS h ON can.resp_rhpersonal_id = h.id_usuario WHERE can.noconformidad_id = CAL_NOCONFORMIDADES.id_noconformidad)]]></expression>
					<label>Ids Resp.</label>
				</field>

				<field id="filt_resp" local="true" noshow="true" sincelda="true">
