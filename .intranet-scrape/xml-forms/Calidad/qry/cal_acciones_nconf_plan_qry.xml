<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="abm-mini" borra="false" path="fotos/personal">
    <title>Plan Accion Total</title>
    <obs></obs>
    <form detalle="cal_plan_accion_acciones_crud.xml" inline="true">
    <table id="CAL_PLAN_ACCION_TOTAL" label="Plan Accion Total">

    <field id="id_plan_accion" esClave="true" Formstyle="display:none;" print="false">
        <label>Nro</label>
        <detalle>plan_accion_id</detalle>
    </field>

    <field id="origen_planaccion" noshow="true" valauto="true" local="true">
        <label>Origen</label>
        <help>Origen del Plan Accion</help>
    </field>

    <field id="descripcion_planaccion">
        <label>Descripción</label>
        <help>Descripcion Plan Accion</help>
        <size>60</size>
        <tipo>varchar</tipo>
        <expression><![CDATA[CONCAT(descripcion_planaccion, '\n',
            (select GROUP_CONCAT(CONCAT(' - ', PA.acciones_planaccion, ' ', DATE_FORMAT(PA.inicio_planaccion, '%d/%m/%Y')) SEPARATOR '\n') from CAL_PLAN_ACCION_ACCION PA where PA.plan_accion_id = id_plan_accion))]]></expression>
    </field>

    <field id="seccion_id" noshow="true" valauto="true" local="true">
        <label>Seccion</label>
        <help>Seccion del Plan de Acción</help>
    </field>

    <field id="inicio_planaccion" required="true" PDFcolWidth="20">
        <label>Fecha</label>
        <help>Inicio</help>
        <tipo>date</tipo>
    </field>

    <field id="objetivo_planaccion" required="true" print="false">
        <label>Fecha Obj.</label>
        <help>Objetivo</help>
        <tipo>date</tipo>
    </field>

    <field id="cierre_planaccion" print="false">
        <label>Fecha Cierre</label>
        <help>Cierre</help>
        <tipo>date</tipo>
    </field>			                                      

    <field id="responsable_planaccion" PDFcolWidth="20">
        <label>Resp.</label>
        <help>Responsable del Plan de Acción</help>
        <helper type="combo" id="HTXUSERS" empty="true">
            <field id="id_usuario"/>
            <field id="nombre">
                <expression>CONCAT(Nombre, LEFT(apellido,1))</expression>
            </field>
            <field id="baja">
                <condicion operador="=">0</condicion>
            </field>
            <field id="Id_perfil">
                <condicion operador="!=">14</condicion>
            </field>
            <order>
                <field id="nombre"/>
            </order>
        </helper>
    </field>

    <field id="noconformidad_planaccion" noshow="true" valauto="true">
        <label>No Confomidad</label>
        <help>Num. No Conformidad</help>
        <size>18</size>
    </field>

    <field id="creador_planaccion" noshow="true" deshabilitado="true">
        <label modpos="nobr">Usuario</label>
        <valor eval="true">$_SESSION['usuario']</valor>
    </field>

    <field id="userid" colstyle="display:none;">
        <label>Creó Plan Accion</label>
        <expression>concat(HTXUSERS.Nombre,' ', LEFT(HTXUSERS.apellido, 1),' ', CAL_PLAN_ACCION_TOTAL.stamp)</expression>
        <label>Creó Plan Accion</label>
        <size>40</size>
    </field>
</table>

    <join tipo="left">
      <table id="HTXUSERS">
        <field id="login">
          <condicion operador="=">creador_planaccion</condicion>
        </field>
      </table>
    </join>

<!--     <join tipo="left">
      <table id="CAL_PLAN_ACCION_ACCION">
        <field id="plan_accion_id">
          <condicion operador="=">id_plan_accion</condicion>
        </field>
      </table>
    </join> -->

</form>
</histrix>	
