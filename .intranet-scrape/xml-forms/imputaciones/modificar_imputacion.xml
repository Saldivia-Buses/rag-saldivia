<?xml version="1.0" encoding="utf-8" ?>
   <histrix tipo="consulta" _ancho="40">
       <title>Cuenta Corriente</title>
        <obs></obs>
				<form  detalle="imputaciones.xml"  _detalle="factura_reimp.xml" _inline="true">
					<table id="CCTMOVIM" label="Movimientos" _styleTbody="height:500px;">
						
						<filters>
							<field id="ctacod">
								<label>Cod.</label>
								<operador>=</operador>															
							</field>	

							<field id="ctanom" tabla="CCTCUENT" local="true" deshabilitado="true">
								<label>Nombre</label>
							</field>

							<field id="movfec">
								<operador>&gt;=</operador>
								<label>Desde Fecha</label>
								<valor>today</valor>
							</field>
							
							<field id="movfec">
								<operador>&lt;=</operador>
								<label>Hasta Fecha</label>
								<valor>today</valor>
							</field>
						</filters>

						<field id="siscod" oculto="true">
							<label>Cod.</label>
							<help>
							</help>
							<detalle>siscod</detalle>
						</field>
<!--						<filters_ex>
							<label>Cuenta</label>
							<ayuda_ex id="CCTCUENT">
								<field id="ctacod"></field>
								<field id="ctanom"></field>
								<field id="siscod" oculto="true"></field>
								<field id="baja">
									<condicion operador="=">0</condicion>
								</field>

								<order>
									<field id="ctanom"></field>
								</order>
								
								<filtra>ctacod</filtra>
							</ayuda_ex>
						</filtro_ex> -->
						<field id="ctacod">
							<label>Cod.</label>
							<help>Código de Cuenta </help>
							<ayuda_ex id="CCTCUENT">
								<field id="ctacod">
									<detalle>ctacod</detalle>
								</field>
								<field id="ctanom">
									<detalle>ctanom</detalle>
								</field>
								<field id="siscod" noshow="true">
								</field>
								<field id="baja">
									<condicion operador="=">0</condicion>
								</field>
								<order>
									<field id="ctanom"></field>
								</order>
								<filtra>ctacod</filtra>
							</ayuda_ex>
							<detalle>ctacod</detalle>	
						</field>

							<field id="ctanom" tabla="CCTCUENT" deshabilitado="true" local="true" >
								<label>Nombre</label>
							</field>								

							<!--		        <condicion operador="=">20</condicion> 
							-->

						<field id="movlet" noshow="true">
							<label>Letra</label>
<!--							<detalle>movlet</detalle> -->
						</field>
			                        
						<field id="movnpv">
							<label>P.V.</label>
							<help> Punto Venta</help>
							<format>%04d</format>
							<detalle>movnpv</detalle>
						</field>
						<field id="movnro" >
							<label>Número</label>
							<help> Número Comprobante</help>
							<format>%12d</format>
							<detalle>movnro</detalle>		
                                                               <tipo>decimal</tipo>
							
						</field>
						<field id="link" local="true" noshow="true">
							<if exp="concod==1">
								<true>'factura_reimp.xml'</true>
								<false>''</false>
								
							</if>
							<tipo>varchar</tipo>
						</field>
						<field id="ELECT" local="true" noshow="true">
							<if exp="concod==1">
								<true>'factura_elec_reimp.xml'</true>
								<false>''</false>
								
							</if>
							<tipo>varchar</tipo>
						</field>
						
						
						<field id="concepto" >
<!--							<attribute id="linkint">link</attribute> -->
							<expression>condes</expression>
							<label>Cod.Concepto</label>
							<help>
							</help>
<!--							
								<paring destino="siscod">siscod</paring>								
								<paring destino="ctacod">ctacod</paring>								
								
								<paring destino="movnro">movnro</paring>
								<paring destino="movnpv">movnpv</paring>								
-->
								<tipo>varchar</tipo>
							
						</field>
						
						<field id="movfec">
							<label>Fecha </label>
							<help>
							</help>
							<detalle>movfec</detalle>
						</field>
						
						<!--          <field id="movvto">
						<label>Venc. </label>
						<help> </help>
						</field>
						-->
						<field id="Debe" suma="true">
							<expression>movimp * (case when conimp = 1 then 1 else 0 end)</expression>
							<label>Debe</label>
							<help>
							</help>
						</field>
						
						<field id="Haber" suma="true" link_int="cctmovim_comp.xml" linkdes="Ver Recibo">
							<expression>movimp * (case when conimp = 2 then 1 else 0 end)</expression>
							<label>Haber</label>
							<help>
							</help>
						<!-- <paring destino="siscod">siscod</paring>							-->
							<paring destino="movnro">movnro</paring>
							<paring destino="carrec">movnro</paring>
							<paring destino="cajnro">movnro</paring>
							<paring destino="movinc">movnro</paring> 
							<paring destino="movnpv">movnpv</paring>
							<paring destino="ctacod">ctacod</paring>
							<paring destino="movfec">movfec</paring>
							<paring destino="cajfec">movfec</paring>							
						</field>
						<field id="resaltado" clasefila="true" local="true" noshow="true">
							<expression>case when movsal != 0 then 'resaltado' end</expression>
							<tipo>varchar</tipo>
						</field>
						<field id="movsal" suma="true">
							<label>Saldo</label>
							<help></help>
							<tipo>numeric</tipo>
						</field>
            <field id="acumulado" suma="true" acumula="true" local="true">
                <if exp="true">
                    <true>Haber - Debe</true>
                    <false>0</false>
                </if>
                <tipo>numeric</tipo>
                <label>Acumulado</label>
            </field>

						<order>
							<field id="movfec"></field>
						</order>
					</table>
					<join tipo="left">
						<table id="CCTCUENT">
							<field id="siscod" >
								<condicion operador="=">CCTMOVIM.siscod</condicion>
							</field>
							<field id="ctacod" >
								<condicion operador="=">CCTMOVIM.ctacod</condicion>
							</field>
						</table>
					</join>					
					<join tipo="left">
						<table id="CCTCONCE">
							<field id="siscod" oculto="true">
								<label>cctcuent.siscod</label>
								<condicion operador="=">CCTMOVIM.siscod</condicion>
							</field>
							
							<field id="concod" oculto="true">
								<condicion operador="=">CCTMOVIM.concod</condicion>
							</field>
							
							<field id="condes" oculto="true">
							</field>
							
						</table>
					</join>
				</form>
        </histrix>
