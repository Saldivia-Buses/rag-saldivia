<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="abm-mini" subtipo="vertical">
  <title>Cuentas Contables</title>
  <obs/>
  <form >
    <table id="REG_CUENTA_IMPUTACION" label="Cuentas Contables">

      <field id="id_regcuentaimputacion" autoinc="true" noshow="true" />

      <field id="regcuenta_id" noshow="true" valauto="true">
        <condicion operador="=">-1</condicion>
      </field>

      <field id="cuenta_id" noshow="true">
        <label modpos="nobr">Cuenta</label>
      </field>
      
      <field id="cuenta_contable" deshabilitado="false" autocompletar="true" colspan="6" style="white-space:nowrap;" local="true">
		<size>50</size>
	    	<label _modpos="nobr">Cuenta</label>
	    	<helper id="CTB_CUENTAS" type="external">
        		<field id="id_cuenta" noshow="true">				
        			<detalle>cuenta_id</detalle>
        		</field>
	        	<field id="nombres">
			    <expression having="false">nombre_cuenta</expression>
			</field>       	
			<field id="habilitada" noshow="true">
				<condicion operador="=">1</condicion>
			</field>
			<field id="ejercicio_id" noshow="true">
				<condicion operador="=">(select id_ejercicio from CTB_EJERCICIOS where activo = 1 limit 1)</condicion>
			</field>
			
			<field id="tipo_id" noshow="true" />
			<order>
				<field id="nombres" />
			</order>
        	</helper>
		<expression>CTB_CUENTAS.nombre_cuenta</expression>
      </field> 

      <field id="porcentaje" noshow="true">
        <label>Porcentaje</label>
        <tipo>numeric</tipo>
        <valor>100</valor>
      </field>

      <field id="doh">
        <label>Imputa</label>
        <helper type="combo">
          <option value="0">Debe</option>
          <option value="1">Haber</option>
        </helper>
      </field>
    </table>

    <join tipo="left">
      <table id="CTB_CUENTAS">
        <field id="id_cuenta">
          <condicion operador="=">REG_CUENTA_IMPUTACION.cuenta_id</condicion>
        </field>
        <field id="ejercicio_id">
          <condicion operador="=">(select id_ejercicio from CTB_EJERCICIOS where activo = 1 ORDER BY id_ejercicio DESC LIMIT 1)</condicion>
        </field>
      </table>
    </join>
  </form>
</histrix>
