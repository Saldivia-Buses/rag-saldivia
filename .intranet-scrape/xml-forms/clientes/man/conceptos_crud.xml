<?xml version="1.0" encoding="UTF-8" ?>
    <histrix tipo="crud">
	<title>Conceptos</title>
	 <obs></obs>
		<form >
		    <table id="REG_CONCEPTOS" label="Conceptos">

				<field id="id_concepto" autoinc="true" noshow="true" />
			   
				<field id="descripcion_concepto" required="true">
					<label>Descripción</label>
				</field>
			 
				<field id="abreviacion_concepto" required="true">
					<label>Abreviación</label>
				</field>
				
				<field id="imputacion_concepto" required="true">
					<label>Imputación</label>
					<help>Imputación del Concepto</help>
					<options>
						  <option valor="0">Debe</option>
						  <option valor="1">Haber</option>
					</options>
				</field>

				<field id="tipo_concepto">
					<label>Libro IVA</label>
					<help>Registración de los comprobantes en Libro de IVA</help>
					<tipo>check</tipo>
				</field>

				<field id="informa_calculo">
					<label>Informa</label>
					<help>Determina si los comprobantes de este tipo impactan en la facturación por lote</help>
					<tipo>check</tipo>
				</field>
				<field id="reintegra_comision">
					<label>Reintegra</label>
					<help>Determina si en la liquidación de comisiones este concepto debe descontar la comisión</help>
					<tipo>check</tipo>
				</field>				

				<field id="subsistema_id" oculto="true" valauto="true">
<!--					<condicion operador="=">'[__subsistema_id__]'</condicion> -->
				</field>

		    </table>
		</form>
    </histrix>	
