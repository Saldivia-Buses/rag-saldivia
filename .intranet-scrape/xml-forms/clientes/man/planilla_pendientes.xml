<?xml version="1.0"?>
<histrix tipo="consulta" paginar="100" preloadData="false">
  <title>Planilla de Pendientes</title>
  <form>
    <table id="REG_MOVIMIENTOS" label="Planilla de Pendientes">
      <filters>
        <field id="nro_cuenta">
          <label>Cliente</label>
          <operador>=</operador>
        </field>

        <field id="regzona_id" deshabilitado="false">
          <label>Ruta</label>
          <operador>=</operador>
        </field>
      
<field id="categoria_ganancia" deshabilitado="false">
          <label>Categoria</label>
          <operador>=</operador>
        </field>
		<field id="localidad_id">
      	  <label>Localidad</label>
      	  <operador>in</operador>
        </field>

        <field id="fecha_movimiento">
          <label>Fecha hasta</label>
          <operador>&lt;=</operador>
          <valor>today</valor>
        </field>
                <field id="regcuentarelacionada_id" noshow="true" _local="true" tabla="REG_CUENTA_RELACIONES">
                    <label>Vendedor</label>
          <operador>=</operador>
                </field>

      </filters>
      
                <field id="subsistemave_id" local="true" noshow="true" >
              	  <valor>22</valor>
                </field>

                <field id="regcuentarelacionada_id" _noshow="true" _local="true" tabla="REG_CUENTA_RELACIONES">
                    <helper type="combo" id="REG_CUENTA" _xml="regcuenta_cmb.xml" dir="/ayudas" empty="true">
                        <field id="id_regcuenta" autoinc="true" _noshow="true" esClave="true">
                            <label>Numero Cuenta</label>
                        </field>
                        <field id="nombre_cuenta">
                            <label>Nombre</label>
                            <detalle>nombre</detalle>
                        </field>
                        <field id="subsistema_id" noshow="true">
                            <condicion operador="=" valorde="subsistemave_id"></condicion>
                        </field>
                        <order>
                            <field id="nombre_cuenta" />
                        </order>
                    </helper>
                    <label>Vendedor</label>
                </field>


      <field id="subsistema_id" noshow="true">
        <valor>'02'</valor>
        <condicion operador="=">'02'</condicion>
      </field>

      <field id="id_regmovim" noshow="true"/>

      <field id="regcuenta_id" break="true" noshow="true" />


	  <field id="regzona_id" colstyle="display: none;"  deshabilitado="false" print="false">
	    <expresion having="false">REG_CUENTA.regzona_id</expresion>
		<helper type="combo" xml="regzonas_qry.xml" dir="/ayudas" empty="true">
<!--			<option value="-1">Seleccione</option>                -->
	    </helper>
	    <actualiza>
           <field id="localidad_id" destino="regzona_id" />
	    </actualiza>
	  </field>

	<field id="categoria_ganancia" tabla="REG_CUENTA"   deshabilitado="false" print="false">
	<label>Categoria</label>
	<helper type="combo" xml="categorias_consultas.xml" dir="/clientes/man" empty="true">
			
	    </helper>
	  </field>
  	  
	  <field id="localidad_id" tabla="REG_CUENTA" colstyle="display: none;">
        <label>Localidad</label>
        <helper type="combo"  xml="localidadesxzona_qry.xml" dir="/ayudas" _empty="true" multiple="true">
         <field id="regzona_id" oculto="true">
            <condicion operador="=">-1</condicion>
         </field>
        </helper>
      </field>                                	    

      <field id="nro_cuenta" tabla="REG_CUENTA" repeat="false" tdWidth="5%">
        <label>Cliente</label>
        <help>Nº/Nombre</help>
        <helper type="external" xml="regcuenta_solamente_nro_qry.xml" dir="/ayudas" empty="true"/>
      </field>

      <field id="nombre_cuenta" tabla="REG_CUENTA" repeat="false" tdWidth="20%">
        <label>Nombre</label>
      </field>

      <field id="nombre_forma" tabla="REG_FORMAS" _repeat="false" >
        <label>Cond.Vta</label>
      </field>
      <field id="limite_ch_dis" _repeat="false">
        <expression>case when (VW_SALDOS.limite_cartera - VW_SALDOS.saldo_valores) &lt; 0 then 'Excedido' else (VW_SALDOS.limite_cartera - VW_SALDOS.saldo_valores) end</expression>
        <label>Lmt.Ch.Dis.</label>
      </field>
      

<!--      <field id="solo" repeat="false" >
        <label>Cond.Pago</label>
        <expression>case when solo_efectivo = 1 then 'Solo Efectivo' end</expression>
      </field>
      -->
      <field id="tel_cuenta" tabla="REG_CUENTA" repeat="false" tdWidth="15%">
        <label>Teléfono</label>
      </field>

      <field id="fecha_movimiento">
        <label>Fecha del movimiento</label>
        <tipo>date</tipo>
        <help> dd/mm/yyyy</help>
      </field>

      <field id="abreviacion_concepto" tabla="REG_CONCEPTOS">
        <label>Concepto</label>
      </field>

      <field id="nro_movimiento" tdWidth="150" linkdes="Detalle del Comprobante" linkmodal="true" style="text-align: center">
        <label>Número</label>
        <expresion>CONCAT(REG_MOVIMIENTOS.letra_movimiento,' ',LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,'0'),'-',LPAD(REG_MOVIMIENTOS.nro_movimiento  ,8,'0'))</expresion>
      </field>

      <field id="vencimiento_movimiento">
        <label>Fecha vencimiento</label>
      </field>

      <field id="importe_movimiento">
        <label>Importe original</label>
      </field>

      <field id="saldo_movimiento" suma="true">
        <label>Saldo</label>
        <condicion operador="!=">0</condicion>
        <tipo>decimal</tipo>
      </field>

      <field id="enviarMail">
        <label>Enviar por Mail</label>
        <tipo>check</tipo>
      </field>

      <field id="imputacion_concepto" oculto="true" tabla="REG_CONCEPTOS" />

	  <group>
	    <field id="id_regmovim" />
	  </group>
      <order>
        <field id="nombre_cuenta" />
        <field id="fecha_movimiento" />
        <field id="nro_movimiento" />
      </order>
    </table>

    <join>
      <table id="REG_CONCEPTOS">
        <field id="id_concepto">
          <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
        </field>

        <field id="informa_calculo">
          <condicion operador="=">0</condicion>
        </field>
      </table>
    </join>

    <join>
      <table id="REG_CUENTA">
        <field id="id_regcuenta">
          <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
        </field>
      </table>
    </join>
          <join tipo="left">
            <table id="REG_CUENTA_RELACIONES">
                <field id="regcuenta_id">
                    <condicion operador="=">REG_CUENTA.id_regcuenta</condicion>
                </field>
                <field id="subsistemarelacionada_id">
                    <condicion operador="=">'[__subsistemave_id__]'</condicion>
                </field>
            </table>
        </join>

    <join>
      <table id="VW_SALDOS">
        <field id="id_regcuenta">
          <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
        </field>
      </table>
    </join>
    <join tipo="left">
      <table id="REG_FORMAS">
        <field id="id_regforma">
          <condicion operador="=">REG_CUENTA.regforma_id</condicion>
        </field>
      </table>
    </join>
    
    
  </form>
</histrix>
