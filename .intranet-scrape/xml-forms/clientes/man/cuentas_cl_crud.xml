<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="crud" imprime="false" preloadData="false" paginar="200" inserta="false">
	<title>Listado de Clientes</title>
	<obs/>
	<form>
		<table id="REG_CUENTA" label="Listado de Clientes">
			<filters>
				<field id="nro_cuenta">
					<label>Numero</label>
					<operador>=</operador>
				</field>
				<field id="nombre_cuenta">
					<label>Nombre</label>
					<operador>LIKE</operador>
				</field>
			</filters>
			<fieldGroup>
				<field id="id_regcuenta" noshow="true" esClave="true" ></field>
				<field id="subsistema_id" noshow="true">
				</field>
				<field id="subsistemarelacionada_id" local="true" noshow="true" />
				<field id="nro_cuenta" esClave="true">
					<label colspan="8">Número</label>
					<help>Numero de la Cuenta</help>
				</field>
				<field id="nombre_cuenta">
					<label colspan="8">Nombre</label>
					<help>Nombre de la cuenta</help>
					<size>80</size>
				</field>
				<field id="provincia_id">
					<label colspan="9">Provincia</label>
					<tabla_ex xml="provincia_qry.xml" dir="/ayudas" vacio="true"/>
					<actualiza>
						<field id="localidad_id" destino="provincia_id"/>
					</actualiza>
				</field>

				<field id="localidad_id" sincelda="true" colstyle="display:none">
					<label modpos="nobr" >Localidad</label>
					<helper type="combo" xml="localidad_qry.xml" dir="/ayudas" empty="true">
						<field id="provincia_id" oculto="true">
							<condicion operador="=">-1</condicion>
						</field>
					</helper>
				</field>
				<field id="nombre_localidad" tabla="GEN_LOCALIDADES" Formstyle="display:none;">
					<label>Localidad </label>
				</field>
				<!-- Dirección -->
				<field id="cod_direccion" colstyle="display:none">
					<label>Calle</label>
					<size>40</size>
				</field>
				<field id="bis_direccion" sincelda="true" colstyle="display:none">
					<label modpos="nobr">Bis</label>
					<tipo>check</tipo>
				</field>
				<field id="nro_direccion" colstyle="display:none">
					<label modpos="nobr">Nº</label>
					<size>10</size>
				</field>
				<field id="abreviacion_direccion" colstyle="display:none">
					<label modpos="nobr">Piso/Dpto</label>
					<size>15</size>
				</field>
				//DOMICIO POSTAL
				<field id="separator_1" local="true" style="background-color: #c9c9c9; height: 5px;" colspan="9" deshabilitado="true" colstyle="display:none">
					<valor></valor>
					<size>60</size>
				</field>
				<field id="entrega_direccion" colstyle="display:none">
					<label colspan="4">Domicilio de Envio</label>
					<size>70</size>
				</field>
				<field id="entrega_provincia_id" colstyle="display:none">
					<label>Provincia de Envio</label>
					<tabla_ex xml="provincia_qry.xml" dir="/ayudas" vacio="true"/>
					<actualiza>
						<field id="entrega_localidad" destino="provincia_id"/>
					</actualiza>
				</field>
				<field id="entrega_localidad" colstyle="display:none">
					<label modpos="nobr" sincelda="true" >Localidad</label>
					<helper type="combo" xml="localidad_qry.xml" dir="/ayudas" empty="true">
						<field id="provincia_id">
							<condicion operador="=">-1</condicion>
						</field>
						<field id="entrega_codigopostal">
							<expression>cp</expression>
						</field>
					</helper>
				</field>
				<field id="entrega_codigopostal" colstyle="display:none">
					<label modpos="nobr">Código Postal de Envio</label>
				</field>
				<field id="entrega_hora" colstyle="display:none">
					<label modpos="nobr">Horario de Entrega</label>
				</field>
				<field id="separator_0" local="true" style="background-color: #c9c9c9; height: 5px;" colspan="9" deshabilitado="true" colstyle="display:none">
					<valor></valor>
					<size>60</size>
				</field>
				<field id="email_cuenta" colstyle="display:none">
					<label colspan="5">email</label>
					<help>email de la cuenta</help>
					<size>60</size>
					<jsfunction event="onblur">
						<![CDATA[ var RE=/^[^\s@]+@[^\s@]+\.[^\s@]+$/; if(this.value != '' &amp;&amp; !RE.test(this.value)) alert('E-mail No Válido');  ]]>
					</jsfunction>
				</field>
				<field id="regzona_id" colstyle="display:none">
					<helper type="combo" id="REG_ZONAS" empty="true">
						<field id="id_regzona"/>
						<field id="nombre_zona"/>
						<field id="subsistema_id"/>
						<order>
							<field id="nombre_zona"/>
						</order>
					</helper>
					<label>Zona</label>
				</field>
				<field id="esadmin" local="true" noshow="true" deshabilitado="true">
					<valor eval="true">$_SESSION['administrator'] == 1 ? 'false' : 'true'</valor>
				</field>
				<field id="limite_credito" deshabilitado="true" colstyle="display:none">
					<attribute id="deshabilitado">esadmin</attribute>
					<label modpos="nobr">Limite de Credito</label>
					<tipo>numeric</tipo>
					<size>12</size>
				</field>
				<field id="regforma_id">
					<label modpos="nobr">Condicion de Venta</label>
					<tabla_ex id="REG_FORMAS" vacio="true">
						<field id="id_regforma"/>
						<field id="nombre_forma"/>
						<field id="subsistema_id"/>
					</tabla_ex>
				</field>
				<!-- Fechas -->
				<field id="alta_cuenta">
					<label>Alta</label>
					<help>Fecha de alta de la cuenta</help>
					<tipo>date</tipo>
					<valor>today</valor>
				</field>
				<field id="baja_cuenta">
					<label modpos="nobr">Baja</label>
					<help>Fecha de Baja de la cuenta</help>
					<tipo>date</tipo>
				</field>
				<!-- Identificacion -->
				<field id="tipo_documento_id">
					<tabla_ex xml="tipos_documento_qry.xml" dir="/ayudas" vacio="true"/>
					<label>Documento</label>
				</field>
				<field id="nro_documento">
					<label modpos="nobr">Nº doc</label>
					<help>Numero de documento</help>
				</field>
				<field id="fecha_nacimiento">
					<label modpos="nobr">Fecha Nacimiento</label>
					<tipo>date</tipo>
				</field>
				<!-- Fiscales -->
				<field id="iva_id" required="true">
					<tabla_ex xml="iva_qry.xml" dir="/ayudas" vacio="true"/>
					<label>Cat. IVA</label>
					<help>Categoria de IVA</help>
				</field>
				<field id="cuit_cuenta">
					<label modpos="nobr">Nº CUIT</label>
					<help>Número de CUIT</help>
					<!-- jsfunction event="onchange">
					<![CDATA[ var RE=/^(20|23|27|30|33)-[0-9]{8}-[0-9]$/; if(this.value != '' && !RE.test(this.value)) alert('CUIT ERRONEO: Formato XX-XXXXXXXX-X'); ]]>
				</jsfunction -->
				<size>15</size>
			</field>
			<field id="solo_efectivo" colstyle="display:none">
				<label>No aceptar cheques</label>
				<help>Habilitado a cancelar con valores</help>
				<tipo>check</tipo>
			</field>
		</fieldGroup>
		<!-- IBR Y GANACIAS -->
		<fieldGroup>
			<if>
				if (strpos($_SESSION['properties']['modulos'],'retenciones') != false) return true;
			</if>
			<field id="nro_ingbrutos">
				<label>Nº IBR</label>
				<help>Numero de ingresos brutos de la cuenta</help>
			</field>
			<field id="iibb_id">
				<label colspan="5" modpos="nobr">Categoria IBR</label>
				<helper type="combo" xml="iibb_qry.xml" dir="/ayudas" empty="true">
					<field id="nombre_iibb">
						<expression>CONCAT(nombre_iibb, ' (', alicuota, '%)')</expression>
					</field>
				</helper>
			</field>
			<field id="iibb_percepcion" local="true" noshow="true">
				<helper type="parameter" id="ID_PERCEPCION">
					<defaultValue>1</defaultValue>
					<label>ID regimen de Percepciones</label>
				</helper>
				<actualiza>
					<field id="iibb_id" destino="iibb_regimen_id" />
				</actualiza>
			</field>
			<field id="percepcion">
				<label _colspan="5">Agente Percepcion</label>
				<tipo>check</tipo>
			</field>
			<field id="categoria_ganancia" colstyle="display:none">
				<helper type="combo" empty="true" id="REG_CATEGORIAS">
					<field id="id_regcategoria" />
					<field id="nombre_categoria" />
					<field id="tipo_categoria" >
						<condicion operador="=">'ganancias'</condicion>
					</field>
					<field id="subsistema_id" />
				</helper>
				<label modpos="nobr" _colspan="6">Categoria</label>
			</field>
			<field id="afipcategoria_id">
				<helper type="external" xml="actividades_afip_qry.xml" dir="/ayudas"/>
				<label modpos="nobr" _colspan="6">Cod. Actividad</label>
				<help>Código de actividad principal según AFIP</help>
			</field>
		</fieldGroup>
	</table>
	<join tipo="left">
		<table id="GEN_LOCALIDADES">
			<field id="id_localidad">
				<condicion operador="=">REG_CUENTA.localidad_id</condicion>
			</field>
		</table>
	</join>
</form>
</histrix>