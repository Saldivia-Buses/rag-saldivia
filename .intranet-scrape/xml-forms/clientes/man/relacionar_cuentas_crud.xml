<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="crud" path="cuentas">
<title>Relacionar Cuentas</title>
<obs></obs>
	<form>
	    <table id="REG_CUENTA_RELACIONES" label="Relacionar Cuentas">

			<field id="id_regcuentarelacion" esClave="true" noshow="true" />

			<field id="regcuenta_id" valauto="true" noshow="true" />

			<field id="subsistemarelacionada_id" valauto="true" noshow="true">
				<actualiza>
					<field id="regcuentarelacionada_id" destino="subsistema_id" />
				</actualiza>
			</field>

			<field id="imagen_cuenta" path="regcuentarelacionada_id" tabla="REG_CUENTA" Formstyle="display:none;" colstyle="text-align:center;">
				<label>Foto</label>
	        	<tipo Type="Image">file</tipo>
	        	<size>60</size>
			</field>

			<field id="nro_documento" tabla="REG_CUENTA" Formstyle="display:none;" colstyle="text-align:center;">
				<label>Documento</label>
			</field>
			
			<field id="regcuentarelacionada_id" required="true" colstyle="text-align:center;">
				<label>Cuenta Relacionada</label>
				<helper type="combo" id="REG_CUENTA" empty="true">
					<field id="id_regcuenta" />
					<field id="nombre_cuenta" />
					<field id="baja_cuenta" oculto="true">
						<condicion operador="=">'0000-00-00'</condicion>
					</field>
					<field id="subsistema_id" oculto="true" />
				</helper>
			</field>

			<field id="fecha_vigencia" noshow="true">
				<valor>today</valor>
				<tipo>date</tipo>
			</field>

	    </table>

	    <join>
	    	<table id="REG_CUENTA">
	    		<field id="id_regcuenta">
	    			<condicion operador="=">REG_CUENTA_RELACIONES.regcuentarelacionada_id</condicion>
	    		</field>
	    	</table>
	    </join>

	</form>
</histrix>	