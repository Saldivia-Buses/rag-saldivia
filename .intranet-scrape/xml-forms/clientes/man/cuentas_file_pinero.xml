<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="ficha" imprime="false" conBusqueda="true">
   <title>Ficha de Contribuyentes</title>
   <obs/>
   <form>
	<table id="REG_CUENTA" label="Ficha de Contribuyentes">

		<fieldGroup>
			<field id="id_regcuenta" noshow="true" esClave="true" autoinc="true">
				<valor>0</valor>
			</field>

			<field id="subsistema_id" oculto="true" valauto="true" />

			<field id="nro_cuenta" esClave="true">
				<label colspan="8">Número</label>
				<help>Numero de la Cuenta</help>
			</field>
            
			<field id="prox_nro" local="true" deshabilitado="true" sincelda="true" valauto="true">
				<label modpos="nobr" style="color:red;">  Proximo Nº</label>
				<helper type="combo" id="REG_CUENTA">
					<field id="nro_cuenta1">
						<expression>max(nro_cuenta * 1) + 1</expression>
					</field>          
					<field id="nro_cuenta2">
						<expression>max(nro_cuenta * 1) + 1</expression>
					</field>        
					<field id="subsistema_id">				
						<condicion operador="=" valorde="subsistema_id" />
					</field>
				</helper>
			</field>

			<field id="nombre_cuenta" preventLoop="true">
				<label colspan="8">Nombre</label>
				<help>Nombre de la cuenta</help>
				<size>80</size>
			</field>

			<field id="provincia_id">
				<label colspan="9">Provincia</label>
				<tabla_ex xml="provincia_qry.xml" dir="/ayudas" vacio="true"/>
				<actualiza>
					<field id="localidad_id" destino="provincia_id"/>
				</actualiza>
			</field>

			<field id="localidad_id" sincelda="true" style="width:300px">
				<label modpos="nobr" >Localidad</label>
				<helper type="combo" xml="localidad_qry.xml" dir="/ayudas" empty="true">
					<field id="provincia_id" oculto="true">
						<condicion operador="=">-1</condicion>
					</field>
				</helper>
			</field>

			<!-- Dirección -->
			<field id="cod_direccion">
				<label>Calle</label>
				<size>40</size>
			</field>

			<field id="bis_direccion" sincelda="true">
				<label modpos="nobr">Bis</label>
				<tipo>check</tipo>
			</field>

			<field id="nro_direccion">
				<label modpos="nobr">Nº</label>
				<size>10</size>
			</field>

			<field id="abreviacion_direccion">
				<label modpos="nobr">Piso/Dpto</label>
				<size>15</size>
			</field>
			
			<field id="separator" local="true" style="background-color:#c9c9c9; height:5px;" colspan="9" deshabilitado="true">
				<valor></valor>
				<size>60</size>
			</field>

			// SUMINISTRO	

			<field id="manzana" _deshabilitado="true">
				<label>Manzana</label>
			</field>

			<field id="lote" _deshabilitado="true">
				<label modpos="nobr">Lote</label>
			</field>

			<field id="baldio">
				<label>Baldio</label>
				<tipo>check</tipo>
			</field>

			<field id="cercado">
				<label modpos="nobr">Cercado</label>
				<tipo>check</tipo>
			</field>

			<field id="cloaca">
				<label modpos="nobr">Cloaca</label>
				<tipo>check</tipo>
			</field>

			<field id="metros">
				<label>Metros</label>
			</field>

			<field id="tipoterreno_id" required="true">
				<label modpos="nobr">Terreno</label>
				<helper type="combo" id="GEN_TIPO_TERRENOS" empty="true">
					<field id="id_tipoterreno" />
					<field id="nombre_tipoterreno" />
				</helper>
			</field>

			//DOMICIO POSTAL
			<field id="separator_1" local="true" style="background-color: #c9c9c9; height: 5px;" colspan="9" deshabilitado="true">
				<valor></valor>
				<size>60</size>
			</field>

			<field id="entrega_direccion">
				<label colspan="4">Domicilio de Envio</label>
				<size>70</size>
			</field>

			<field id="entrega_provincia_id">
				<label>Provincia de Envio</label>
				<tabla_ex xml="provincia_qry.xml" dir="/ayudas" vacio="true"/>
				<actualiza>
					<field id="entrega_localidad" destino="provincia_id"/>
				</actualiza>
			</field>

			<field id="entrega_localidad">
				<label modpos="nobr" sincelda="true" style="width:300px">Localidad </label>
				<helper type="combo" xml="localidad_qry.xml" dir="/ayudas" empty="true">
					<field id="provincia_id">
						<condicion operador="=">-1</condicion>
					</field>
					<field id="entrega_codigopostal">
						<expression>cp</expression>
					</field>
				</helper>
			</field>

			<field id="entrega_codigopostal">
				<label modpos="nobr">Código Postal de Envio</label>
			</field>     

			<field id="entrega_hora">
				<label modpos="nobr">Horario de Entrega</label>     
			</field>

			<field id="separator_0" local="true" style="background-color: #c9c9c9; height: 5px;" colspan="9" deshabilitado="true">
				<valor></valor>
				<size>60</size>
			</field>

			<field id="email_cuenta">
				<label colspan="5">email</label>
				<help>email de la cuenta</help>
				<size>60</size>
				<jsfunction event="onblur"><![CDATA[ var RE=/^[^\s@]+@[^\s@]+\.[^\s@]+$/; if(this.value != '' &amp;&amp; !RE.test(this.value)) alert('E-mail No Válido');  ]]></jsfunction>
			</field>

			<field id="regzona_id">
				<helper type="combo" id="REG_ZONAS" empty="true">
					<field id="id_regzona"/>
					<field id="nombre_zona"/>
					<field id="subsistema_id" />
					<order>
						<field id="nombre_zona"/>
					</order>
				</helper>
				<label>Zona</label>
			</field>

			<field id="esadmin" local="true" noshow="true" deshabilitado="true">
				<valor eval="true">$_SESSION['administrator'] == 1 ? 'false' : 'true'</valor>
			</field>

			<field id="limite_credito" deshabilitado="true">
				<attribute id="deshabilitado">esadmin</attribute>  
				<label modpos="nobr">Limite de Credito</label>
				<tipo>numeric</tipo>
				<size>12</size>
			</field>

			<field id="genactividad_id">
				<label modpos="nobr">Actividad</label>
                                <helper type="combo" xml="genactividades_qry.xml" dir="/ayudas" empty="true" />
			</field>        

			<!-- Fechas -->
			<field id="alta_cuenta">
				<label>Alta</label>
				<help>Fecha de alta de la cuenta</help>
				<tipo>date</tipo>
				<valor>today</valor>
			</field>

			<field id="baja_cuenta">
				<label modpos="nobr">Baja</label>
				<help>Fecha de Baja de la cuenta</help>
				<tipo>date</tipo>
			</field>

			<!-- Identificacion -->
			<field id="tipo_documento_id">
				<tabla_ex xml="tipos_documento_qry.xml" dir="/ayudas" vacio="true"/>
				<label>Documento</label>
			</field>

			<field id="nro_documento">
				<label modpos="nobr">Nº doc</label>
				<help>Numero de documento</help>
			</field>

			<field id="fecha_nacimiento">
				<label modpos="nobr">Fecha Nacimiento</label>
				<tipo>date</tipo>
			</field>

			<!-- Fiscales -->
			<field id="iva_id" required="true">
				<tabla_ex xml="iva_qry.xml" dir="/ayudas" vacio="true"/>
				<label>Cat. IVA</label>
				<help>Categoria de IVA</help>
			</field>

			<field id="cuit_cuenta">
				<label modpos="nobr">Nº CUIT</label>
				<help>Número de CUIT</help>
				<size>15</size>
			</field>

			<field id="solo_efectivo">
				<label>No aceptar cheques</label>
				<help>Habilitado a cancelar con valores</help>
				<tipo>check</tipo>
			</field>

		</fieldGroup>

		<!-- IBR Y GANACIAS -->
		<fieldGroup>
			<if> if (strpos($_SESSION['properties']['modulos'],'retenciones') != false) return true; </if>

			<field id="nro_ingbrutos">
				<label>Nº IBR</label>
				<help>Numero de ingresos brutos de la cuenta</help>
			</field>
		
			<field id="iibb_id">
				<label colspan="5" modpos="nobr">Categoria IBR</label>
				<helper type="combo" xml="iibb_qry.xml" dir="/ayudas" empty="true">
					<field id="nombre_iibb">
						<expression>CONCAT(nombre_iibb, ' (', alicuota, '%)')</expression>
					</field>
				</helper>
			</field>

			<field id="iibb_percepcion" local="true" noshow="true">
				<helper type="parameter" id="ID_PERCEPCION">
					<defaultValue>1</defaultValue>
					<label>ID regimen de Percepciones</label>
				</helper>
				<actualiza>
					<field id="iibb_id" destino="iibb_regimen_id" />
				</actualiza>
			</field>

			<field id="percepcion">
				<label _colspan="5">Agente Percepcion</label>
				<tipo>check</tipo>
			</field>

			<field id="categoria_ganancia">
				<helper type="combo" empty="true" id="REG_CATEGORIAS">
					<field id="id_regcategoria" />
					<field id="nombre_categoria" />
					<field id="tipo_categoria" >
						<condicion operador="=">'ganancias'</condicion>
					</field>
					<field id="subsistema_id" />
				</helper>
				<label modpos="nobr" _colspan="6">Categoria</label>
			</field>

			<field id="afipcategoria_id">
				<helper type="external" xml="actividades_afip_qry.xml" dir="/ayudas"/>
				<label modpos="nobr" _colspan="6">Cod. Actividad</label>
				<help>Código de actividad principal según AFIP</help>
			</field>
		</fieldGroup>

		<!-- FACTURACION DE SERVICIOS **************************************** -->
		<fieldGroup>
			<if> if (strpos($_SESSION['properties']['modulos'],'servicios') != false) return true; </if>
		
			<field id="usuarios" obj="facusuarioser_crud.xml" objdir="/servicios/man" local="true">
				<paring destino="regcuenta_id">id_regcuenta</paring>
			</field>
		</fieldGroup>

		<fieldGroup>
			<field id="contacto" obj="cuenta_contactos_crud.xml" local="true">
				<paring destino="regcuenta_id">id_regcuenta</paring>
			</field>
		</fieldGroup>
	
		// OBSERVACIONES
		<fieldGroup>
			<field id="observaciones" local="true">
				<helper type="object" xml="cuenta_observaciones_crud.xml">
					<parameter source="id_regcuenta" target="regcuenta_id" />
				</helper>
				<label colspan="6">Observaciones</label>
			</field>
		</fieldGroup>

    	</table>
   </form>
</histrix>