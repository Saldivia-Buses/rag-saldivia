<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="abm-mini" subtipo="vertical">
  <title>Garantes</title>
  <obs/>
  <form>
    <table id="REG_CUENTA_RELACIONES" label="Referencias Comerciales ">
      <field id="id_regcuentarelacion" noshow="true"/>
      <field id="regcuenta_id" noshow="true" valauto="true"/>
      <field id="fecha_vigencia">
        <label>Desde Fecha</label>
        <help>Fecha</help>
        <valor>today</valor>
        <tipo>date</tipo>
      </field>
      <field id="subsistemarelacionada_id" noshow="true">
        <label>Subsistem</label>
        <valor>GR</valor>
        <condicion operador="=">'GR'</condicion>
      </field>
      <field id="regcuentarelacionada_id">
        <helper type="combo" xml="regcuenta_cmb.xml" dir="/ayudas" empty="true">
          <field id="id_regcuenta" autoinc="true" noshow="true" esClave="true">
            <label>Numero Cuenta</label>
            <detalle>regcuenta_id</detalle>
          </field>
          <field id="nombre_cuenta">
            <label>Nombre</label>
            <detalle>nombre</detalle>
          </field>
          <field id="subsistema_id" oculto="true">
            <condicion operador="=">'GR'</condicion>
          </field>
        </helper>
        <label>Referente</label>
        <help>Seleccione el Referente</help>
      </field>
      <field id="valor_aplicado">
        <label>Comision</label>
        <help>Ingrese la comision</help>
      </field>
    </table>
  </form>
</histrix>
