<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="crud" inserta="false" preloadData="false">
  <title>Recurrencia Facturas</title>
  <obs/>
  <form >
    <table id="REG_MOVIMIENTO_RRULES" label="Recurrencia Facturas">
	
	<filters>
		<field id="nombre_cuenta" colstyle="width:260px;">
			<label>Cliente</label>
			<operador>like</operador>
			<size>140</size>
		</field>

		<field id="cod_direccion">
			<label>Direccion</label>
			<operador>like</operador>
			<size>80</size>				
		</field>
		
		<field id="nro_cuenta">
                        <label>Nro</label>
                        <operador>=</operador>							
                </field>

		
	</filters>

        <field id="fecha_movimiento" tabla="REG_MOVIMIENTOS" Formstyle="display:none;">
        	<label>Fec.Mov.</label>
		<tipo>date</tipo>
	</field>
	
	<field id="nro_cuenta" tabla="REG_CUENTA" colstyle="text-align:center;">
		<label>Nro Cuenta</label>
	</field>
		
	<field id="nombre_cuenta" tabla="REG_CUENTA" Formstyle="display:none;">
        	<label>Cliente</label>
	</field>
	
	<field id="cod_direccion" tabla="REG_CUENTA">
		<label> Direccion</label>
|		<size> 40</size>				
	</field>
	

	<field id="id_regmovimrrule" noshow="true" Formstyle="display:none;" />
	
	<field id="regmovim_id" noshow="true" Formstyle="display:none;" />

	<field id="regcuenta_id" tabla="REG_MOVIMIENTOS" noshow="true" Formstyle="display:none;">
		<helper type="combo" id="REG_CUENTA" empty="true">
			<field id="id_regcuenta" />
			<field id="nombre_cuenta" />
			<field id="subsistema_id">
				<condicion operador="=">'02'</condicion>
			</field>
		</helper>
	</field>

	<field id="subsistema_id" noshow="true" tabla="REG_MOVIMIENTOS" Formstyle="display:none;" />
        	


      	<field id="descripcion_concepto" tabla="REG_CONCEPTOS" Formstyle="display:none;">
        	<label>Comprobante</label>
        </field>

        <field id="imprime_concepto1" noshow="true" Formstyle="display:none;">
        	<expresion>
          		case when isnull(CAJ_CONCEPTOS.imprime_concepto) then trim(REG_NUMERADORES.ejecuta) else trim(CAJ_CONCEPTOS.imprime_concepto) end
	        </expresion>
        </field>

        <field id="nro_movimiento" Formstyle="display:none;">
        	<label>Nro. Comp.</label>
	        <expresion>CONCAT(REG_MOVIMIENTOS.letra_movimiento,' ',LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,'0'),'-',LPAD(REG_MOVIMIENTOS.nro_movimiento  ,8,'0'))</expresion>
        	<helper type="link" _dir="/caja/qry">
	        	<parameter source="id_regmovim" target="id_regmovim"/>
	        </helper>
        	<attribute id="linkint">imprime_concepto1</attribute>
        </field>

        <field id="importe_movimiento" tabla="REG_MOVIMIENTOS" Formstyle="display:none;">
    	    <label>Importe</label>
    	    <tipo>numeric</tipo>
    	</field>

	<field id="saldo_movimiento" tabla="REG_MOVIMIENTOS" suma="true" Formstyle="display:none;">
        	<label>Saldo</label>
	        <tipo>numeric</tipo>
	</field>

	
	
	<field id="nombre_cuenta" tabla="REG_CUENTA">
	<label> Cliente</label>
	<size>40</size>
	</field>

	<field id="rrule">
                <label>Repetir</label>
		<tipo>rrule</tipo>
	</field>

	<field id="id_regmovim" tabla="REG_MOVIMIENTOS" noshow="true" Formstyle="display:none;" />
	
	<order>
		<field id="nro_cuenta" tabla="REG_CUENTA" />

	</order>

	<group>
		<field id="id_regmovimrrule" />
	</group>
      	
    </table>

    <join>
      <table id="REG_MOVIMIENTOS">
        <field id="id_regmovim">
          <condicion operador="=">REG_MOVIMIENTO_RRULES.regmovim_id</condicion>
        </field>
      </table>
    </join>

    <join>
      <table id="REG_CUENTA">
        <field id="id_regcuenta">
          <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
        </field>
      </table>
    </join>

    <join>
      <table id="REG_CONCEPTOS">
        <field id="id_concepto">
          <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
        </field>
        <field id="informa_calculo">
          <condicion operador="=">0</condicion>
        </field>
      </table>
    </join>

    <join tipo="left">
      <table id="CAJ_CONCEPTOS">
        <field id="regconcepto_id">
          <condicion operador="=">REG_CONCEPTOS.id_concepto</condicion>
        </field>
      </table>
    </join>

    <join tipo="left">
      <table id="REG_NUMERADORES">
        <field id="regconcepto_id">
          <condicion operador="=">REG_CONCEPTOS.id_concepto</condicion>
        </field>
      </table>
    </join>

  </form>
</histrix>
