<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="ficha" imprime="false" conBusqueda="true" log="false" borra="false">
    <title>Cuentas</title>
    <obs></obs>

    <form>

        <table id="REG_CUENTA" label="Cuentas">
            <fieldGroup>            
                <field id="id_regcuenta" noshow="true" esClave="true" autoinc="true">
                  <valor>0</valor> 
                </field>

                <field id="alta_cuenta" _noshow="true" valauto="true" deshabilitado="true">
                  <label>Fecha de Alta</label>
                  <help>Fecha de alta de la cuenta</help>
                  <tipo>date</tipo>
                  <valor>today</valor>
                </field>

                <field id="subsistema_id" oculto="true"   />
                <field id="subsistemarelacionada_id" local="true" oculto="true" valauto="true" />
            
                <field id="nro_cuenta" noshow="true" valauto="true" deshabilitado="true">
                    <parametro id="nro_cuenta.xml" retorna="prox_nro" >
     
                        <field id="subsistema_id" valorde="subsistema_id">
                        </field>

                    </parametro>                    
                </field>
            <field id="nombre_cuenta" required="true">
                <label colspan="5">Nombre o Razón Social</label>
                <help>Nombre de la cuenta</help>
                <size>80</size>
	          </field>
	
            <field id="provincia_id" required="true">
                <label colspan="9">Provincia</label>
                <tabla_ex xml="provincia_qry.xml" dir="/ayudas" vacio="true" />
                <actualiza>
	                <field id="localidad_id" destino="provincia_id" />
                </actualiza>
            </field>

            <field id="localidad_id" required="true">
                <label colspan="9">Localidad</label>
                <helper type="combo" xml="localidad_qry.xml" dir="/ayudas" empty="true" > 
            			<field id="provincia_id">
            			    <condicion operador="=">-1</condicion>
            			</field>
                </helper>
            </field>
		    
	    <!-- Dirección -->	  
		    
            <field id="cod_direccion" required="true">
                <label>Calle</label>
                <size>40</size>
            </field>

            <field id="bis_direccion" sincelda="true">
                <label modpos="nobr">Bis</label>
                <tipo>check</tipo>
            </field>

            <field id="nro_direccion" required="true">
                <label modpos="nobr">Nº</label>
                <size>10</size>
            </field>

            <field id="abreviacion_direccion">
                <label modpos="nobr">Piso/Dpto</label>
                <size>15</size>
            </field>
<!--
            //DOMICIO POSTAL
        <field id="separator_1" local="true" style="background-color: #c9c9c9; height: 5px;" colspan="9" deshabilitado="true">
              <valor></valor>
              <size>60</size>
        </field>

        <field id="entrega_direccion">
          <label colspan="4">Domicilio de Envio</label>
          <size>70</size>
        </field>

        <field id="entrega_provincia_id">
          <label>Provincia de Envio</label>
          <tabla_ex xml="provincia_qry.xml" dir="/ayudas" vacio="true"/>
          <actualiza>
            <field id="entrega_localidad" destino="provincia_id"/>
          </actualiza>
        </field>

        <field id="entrega_localidad">
          <label modpos="nobr" _sincelda="true" _style="width:300px">Localidad de Envio</label>
          <helper type="combo" xml="localidad_qry.xml" dir="/ayudas" empty="true">
            <field id="provincia_id">
              <condicion operador="=">-1</condicion>
            </field>
            <field id="entrega_codigopostal">
                <expression>cp</expression>
            </field>
          </helper>
        </field>

        <field id="entrega_codigopostal" noshow="true">
          <label modpos="nobr">Código Postal de Envio</label>
        </field>     

        <field id="entrega_hora">
          <label modpos="nobr">Horario de Entrega</label>     
        </field>

        <field id="separator_0" local="true" style="background-color: #c9c9c9; height: 5px;" colspan="9" deshabilitado="true">
              <valor></valor>
              <size>60</size>
        </field>
-->
	   <!-- Fiscales -->

            <field id="tipo_documento_id">
                <tabla_ex xml="tipos_documento_qry.xml" dir="/ayudas" vacio="true" />
                <label>Tipo Documento</label>
            </field>

            <field id="nro_documento">
                <label modpos="nobr">Nº documento</label>
                <help>Numero de documento</help>
            </field>
			
			<field id="regforma_id" required="true">
				<label>Condición de Venta</label>
				<helper type="combo" tabla="REG_FORMAS">
					<field id="id_regforma"/>
					<field id="nombre_forma"/>
				</helper>
			</field>

            <field id="cuit_cuenta" required="true">
                <label modpos="nobr">Nº CUIT</label>
                <help>Número de CUIT</help>
            </field>

            <field id="nro_ingbrutos" required="true">
                <label modpos="nobr">Nº IBR</label>
                <help>Numero de ingresos brutos de la cuenta</help>
            </field>

  	    <field id="regforma_id" required="true">
      		<label>Condicion de Venta</label>
      		<tabla_ex id="REG_FORMAS" vacio="true">
      		    <field id="id_regforma" />
      		    <field id="nombre_forma" />
      		</tabla_ex>
	      </field>		
          
		    <field id="afipcategoria_id">
       	   <helper type="external" xml="actividades_afip_qry.xml" dir="/ayudas"/>
           <label>Actividad</label>
		       <help>Código de actividad principal según AFIP</help>
        </field>
		
    		<field id="ref_cuenta">
    			<label>Opinión del Vendedor</label>
    		</field>

        <field id="ref_comercial">
          <label>Referencia comercial</label>
          <size>100</size>
        </field>

        <field id="ref_bancaria">
          <label>Referencia bancaria</label>
          <size>100</size>
        </field>

            </fieldGroup>
           
        <fieldGroup>
          <if> if (strpos($_SESSION['properties']['modulos'],'transportistas') != false) return true; </if>    
  	     <field id="subsistematransporte_id"  valauto="true" local="true" noshow="true" >
  				<detalle>subsistematransporte_id</detalle>
  			 </field>

		     <field id="transportes" obj="cuenta_relaciontr_crud.xml"   local="true" >
			     <paring destino="regcuenta_id">id_regcuenta</paring>
			     <paring destino="subsistematransporte_id">subsistematransporte_id</paring> 
			     <paring destino="subsistemarelacionada_id">subsistematransporte_id</paring> 
		     </field>
	
        </fieldGroup>

        <!-- SISTEMA DE VENDEDORES ******************************************* -->
      <fieldGroup>
        <if> if (strpos($_SESSION['properties']['modulos'],'vendedores') != false) return true; </if>
        <field id="subsistemavendedor_id" valauto="true" noshow="true" local="true">
          <detalle>subsistemavendedor_id</detalle>
        </field>
        <field id="vendedores" obj="cuenta_relaciones_crud.xml" local="true">
          <paring destino="regcuenta_id">id_regcuenta</paring>
          <paring destino="subsistemavendedor_id">subsistemavendedor_id</paring>
          <paring destino="subsistemarelacionada_id">subsistemavendedor_id</paring>
        </field>
      </fieldGroup>

       
          <field id="contacto" obj="cuenta_contactos_crud.xml" local="true" >
            <paring destino="regcuenta_id">id_regcuenta</paring>
          </field>

          <field id="contacto" obj="cuenta_contactos_crud.xml" local="true" >
            <paring destino="regcuenta_id">id_regcuenta</paring>
          </field>

<!--
	<fieldGroup>	
	<if> if (strpos($_SESSION['properties']['modulos'],'garantes') != false) return true; </if>    
		<field id="garantes" obj="cuenta_relaciongr_crud.xml"   local="true" >
			<paring destino="regcuenta_id">id_regcuenta</paring>
		</field>

		<field id="subsistemagarante_id" local="true" noshow="true">
			<valor>GR</valor>
		</field>

		<field id="inggarantes" local="true" display="toolbar">
			<helper type="link" xml="cuenta_garantes.xml">
				<parameter source="subsistemagarante_id" target="subsistema_id" operator="="/>
			</helper>
		<valor>Crear Garante</valor>
		</field>            
    </fieldGroup>
-->
        </table>

<!--
        <join tipo="left">
            <table id="GEN_LOCALIDADES">
                <field id="id_localidad">
                    <condicion operador="=">REG_CUENTA.localidad_id</condicion>
                </field>
            </table>
        </join>
-->
    </form>
</histrix>
