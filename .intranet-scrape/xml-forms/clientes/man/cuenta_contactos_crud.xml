<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="abm-mini" subtipo="vertical">
    <title>Datos de Contacto</title>
    <obs/>
    <form>
        <table id="REG_CUENTAS_CONTACTOS" label="Datos de Contacto">

            <field id="id_regcontacto" autoinc="true" noshow="true" />

            <field id="regcuenta_id" noshow="true" valauto="true" />

            <field id="contacto_id" colspan="8">
                <helper type="combo" xml="contactos_qry.xml" dir="/ayudas" empty="true">
                    <field id="catcontacto_id" noshow="true">
                        <detalle>catcontacto_id</detalle>
                    </field>
                </helper>
                <label>Tipo Contacto</label>
            </field>

            <field id="catcontacto_id" noshow="true" local="true" activa="true" />

            <field id="ddn" activador="catcontacto_id">
                <label>Caracteristica</label>
                <size>5</size>
            </field>

            <field id="valor" sincelda="true">
                <label modpos="nobr">Valor</label>
                <size>30</size>
            </field>

            <field id="interno" activador="catcontacto_id" sincelda="true">
                <label modpos="nobr">Interno</label>
                <size>5</size>
            </field>

            <field id="nota" colspan="8">
                <label>Notas</label>
                <size>53</size>
            </field>

            <field id="cargo" colspan="8">
                <label>Cargo</label>
                <size>30</size>
            </field>

        </table>
    </form>
</histrix>