<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="abm-mini">
    <title>Localidades segun zona</title>
    <obs></obs>
    <form  >
        <table id="REG_ZONA_LOCALIDADES" label="LOCALIDADES POR ZONA">
	  
	     <field id="id_regzonaloc" autoinc="true" noshow="true" esClave="true">
                <label>Id zonalocalidad</label>
	    </field>

         <field id="regzona_id" noshow="true">
                <label>Id zona</label>
        </field>
        
        <field id="provincia_id" local="true" noshow="true">
            <helper type="combo" xml="provincia_qry.xml" dir="/ayudas" />
            <label>Provincia</label>
            <actualiza>
                <field id="localidad_id" destino="provincia_id" />
            </actualiza>
        </field>

        <field id="localidad_id" _noshow="true">
			<helper type="combo" _id="GEN_LOCALIDADES" xml="localidad_qry.xml" dir="/ayudas" empty="true">
				<field id="id_localidad" />
				<field id="nombre_localidad" />
				<order>
					<field id="nombre_localidad" />
				</order>
			</helper>
			<label>Localidad</label>
		</field>
		


	</table>
<!--
	<join tipo="LEFT">
		<table id="REG_ZONAS">
			<field id="id_regzona">
				<condicion operador="=">REG_ZONA_LOCALIDADES.regzona_id</condicion>
			</field>
		</table>
	</join>	
-->
    </form>
</histrix>

