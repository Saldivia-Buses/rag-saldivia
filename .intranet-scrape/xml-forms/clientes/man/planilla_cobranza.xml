<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="ing" subtipo="vertical" inserta="false" modifica="false" deleteRow="false" paginar="100">
  <title>Planilla de Cobranza</title>
  <confirmacion><![CDATA[¿Confirma la operación?]]></confirmacion>
  <form>
    <table id="REG_MOVIMIENTOS" label="Planilla de Cobranza">

      <!-- BEGIN VALIDACIONES -->

      <validation>
        <condition><![CDATA[nro_cuenta == 0]]></condition>
        <message>Debe ingresar un número de cuenta.</message>
      </validation>

      <validation>
        <condition><![CDATA[graba == 0]]></condition>
        <message>Debe seleccionar al menos un comprobante.</message>
      </validation>

      <!-- FIN VALIDACIONES -->

      <movimientos cabecera="planilla_cobranza_cab.xml">
        <relacion id="planilla_cobranza_obs.xml"/>
      </movimientos>

      <filters>
        <field id="nro_cuenta">
          <label>Cliente</label>
          <operador>=</operador>
        </field>
        <field id="regcuenta_nombre" deshabilitado="true">
          <label modpos="nobr"/>
        </field>
      </filters>

      <field id="id_regmovim" noshow="true" />

      <field id="subsistema_id" valauto="true" noshow="true">
        <detalle>subsistema_id</detalle>
      </field>

      <field id="regcuenta_id" noshow="true" />

      <field id="nro_cuenta" tabla="REG_CUENTA" break="true">
        <label>Cliente</label>
        <helper type="external" xml="regcuenta_nro_cmb.xml" dir="/ayudas" empty="true" />
        <size>11</size>
        <help>Nº/Nombre</help>
      </field>

      <field id="regcuenta_nombre" deshabilitado="true" local="true" noshow="true">
        <size>50</size>
      </field>

      <field id="nombre_cuenta">
        <expresion>REG_CUENTA.nombre_cuenta</expresion>
        <label Formstyle="display:none;">Nombre</label>
      </field>

      <field id="fecha_movimiento">
        <label>Fecha del movimiento</label>
        <help>Fecha movimiento</help>
        <tipo>date</tipo>
      </field>

      <field id="descripcion_concepto" tabla="REG_CONCEPTOS">
        <label modpos="nobr">Comprobante</label>
      </field>

      <field id="nro_movimiento">
        <label Formstyle="display:none;">Nro. del comprobante</label>
        <expresion>CONCAT(REG_MOVIMIENTOS.letra_movimiento,' ',LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,'0'),'-',LPAD(REG_MOVIMIENTOS.nro_movimiento  ,8,'0'))</expresion>
      </field>
      <field id="importe_movimiento">
        <label Formstyle="display:none;">Importe del comprobante</label>
      </field>

      <field id="saldo_movimiento" _noshow="true" suma="true">
        <label>Saldo</label>
        <condicion operador="!=">0</condicion>
        <tipo>numeric</tipo>
      </field>
      
      <field id="movimiento" noZero="true">
        <label Formstyle="display:none;">Importe cancelado</label>
        <expresion>SUM(REG_IMPUTACIONES.movimiento_imputacion)</expresion>
        <tipo>numeric</tipo>
      </field>
	  
        <field id="detalles" local="true" obj="seguimiento.xml" objdir="/clientes/qry/" showObjTabla="true">
            <tipo>varchar</tipo>
            <paring destino="regmovim_id">id_regmovim</paring>
            <paring destino="tabla_origen">REG_MOVIMIENTOS</paring>
            <label Formstyle="display:none;">Observaciones</label>
        </field>

        <field id="imputacion_concepto" tabla="REG_CONCEPTOS" noshow="true">
            <condicion operador="=">0</condicion>
        </field>

        <field id="canc_val" deshabilitado="true" >
            <label Formstyle="display:none;">Con valores</label>
            <expresion>IF(REG_CUENTA.solo_efectivo = 1,'NO ACEPTAR VALORES','')</expresion>
        </field>

        <field id="tieneObs" local="true" _refresh="true">
            <tipo>check</tipo>
        </field>

        <field id="graba" local="true" _noshow="true" >
            <if exp="tieneObs == 1">
                <true>1</true>
                <false>0</false>
            </if>
        </field>

        <group>
            <field id="id_regmovim"/>
        </group>
  
        <order>
            <field id="nombre_cuenta" />
            <field id="fecha_movimiento" />
        </order>
      
        </table>

        <join>
            <table id="REG_CUENTA">
                <field id="id_regcuenta">
                    <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
                </field>
            </table>
        </join>

        <join tipo="left">
            <table id="REG_CONCEPTOS">
                <field id="id_concepto">
                    <condicion operador="=">REG_MOVIMIENTOS.concepto_id and informa_calculo = 0</condicion>
                </field>
            </table>
        </join>

        <join tipo="left">
            <table id="REG_IMPUTACIONES">
                <field id="regmovim_id">
                    <condicion operador="=">REG_MOVIMIENTOS.id_regmovim</condicion>
                </field>
            </table>
        </join>

        <join tipo="left">
            <table id="CAJ_VALORES">
                <field id="id_cajvalor">
                    <condicion operador="=">REG_MOVIMIENTOS.cajvalor_id</condicion>
                </field>
            </table>
        </join>

        <join tipo="left">
            <table id="CAJ_FORMAS_PAGO">
                <field id="id_cajformapago">
                    <condicion operador="=">CAJ_VALORES.cajformapago_id</condicion>
                </field>
            </table>
        </join>
    </form>
</histrix>
