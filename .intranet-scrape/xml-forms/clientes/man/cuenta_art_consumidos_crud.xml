<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="abm-mini" subtipo="vertical">
  <title>Articulos Consumidos</title>
  <obs/>
  <form>
    <table id="REG_CUENTA_OBSERVACIONES" label="Articulos Consumidos">

    <fieldGroup Formstyle="padding:2px 2px 2px 2px;vertical-align:middle;">

      <field id="id_regobservacion" autoinc="true" noshow="true"/>

      <field id="regcuenta_id" noshow="true" valauto="true"/>

      <field id="regtipobs_id" noshow="true" valauto="true">
          <valor>2</valor> 
          <condicion operador="=">2</condicion> 
      </field>

      <field id="codigo_articulo" >
        <label>Cod Articulo</label>
        <help>Articulo que consume</help>
        <helper type="external" xml="stkarticulo_qry2.xml" dir="/ayudas">
          <field id="id_stkarticulo" />
          <field id="nombre_articulo">
            <detalle>texto_observacion</detalle>
          </field>
          <order>
            <field id="nombre_articulo" tabla="STK_ARTICULOS" />
          </order>
        </helper>
      </field>

      <field id="texto_observacion" modpos="nobr"> 
        <label>Nombre Articulo</label>
        <help>Nombre articulo que consume</help>
        <size>99</size>
      </field>

      <field id="cantidad">
        <label>Cantidad</label>
        <help>Cantidad que consume</help>
      </field>

      <field id="precio" modpos="nobr">
        <label>Precio</label>
        <help>Precio al que compra</help>
    </field>


    </fieldGroup>

    </table>
  </form>
</histrix>
