		<parameter source="id_regmovim" target="id_regmovim2" operator="!="/>
	    </helper>
	    <label posx="24" posY="220" pdfancho="100">Ultimos Movimientos</label>
	</field>
	
	<field id="referencia_facturacion" local="true" maxsize="160" maxlength="160" PDFnolabel="true">
		<label posx="20" posY="240" pdfancho="100" />
	    <helper type="parameter" id="SIS::02:refrerencia_facturacion" >
  	  	    <label>Referencia Para Facturacion</label>
      		<defaultValue/>
