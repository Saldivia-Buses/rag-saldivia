	</field>



	<field id="importe_movimiento" PDFnoborder="true" PDFbold="true">
		<label modpos="nobr" posx="120" posY="254" PDFsize="8" size="22" pdfancho="55">TOTAL</label>
	</field>
	
	<field id="aviso_saldo" PDFnoborder="true" local="true">
