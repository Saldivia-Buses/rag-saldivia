<?xml version="1.0" encoding="UTF-8" ?>
    <histrix tipo="consulta" exportasuma="true" PDFlineColor="255,255,255">
	<title>Detalles</title>
	 <obs></obs>
		<form >
	    <table id="REG_DETALLES" label="Detalle de Movimientos" styleTbody="height:150px;overflow-x:hidden;" PDFnoborder="true" >
	
			<field id="regmovim_id" noshow="true" PDFlineas="false"/>
	
			<field id="orden" noshow="true" PDFlineas="false"/>
	
			<field id="codigo_detalle" PDFsize="9"  PDFnoborder="true"  >
		            <label size="30"></label>
			</field>
	
			<field id="descripcion_detalle" PDFsize="9" PDFlineas="false">
		            <label  modpos="nobr" size="60"></label>
			</field>
	
	        <!-- BUSCO SI CAMBIARON DESCRIPCION DEL ARTICULO MANUAL EN LA FACTURACION Y LO COLOREO -->
            <field id="resaltado_detalle" noshow="true" clasefila="true">
                <expression>CASE WHEN (SELECT nombre_articulo FROM STK_ARTICULOS WHERE id_stkarticulo = REG_DETALLES.codigo_detalle) != REG_DETALLES.descripcion_detalle THEN 'resaltado' ELSE '' END</expression>
            </field>

			<field id="cantidad_detalle" PDFsize="9" PDFlineas="false">
		            <label modpos="nobr" size="20"></label>
			    <tipo>numeric</tipo>
			</field>
			
			<field id="precio_venta" PDFsize="9" PDFlineas="false">
		            <label modpos="nobr" size="20"></label>
			    <tipo>numeric</tipo>
			</field>
			
			<field id="total_detalle"  total="true" PDFsize="9" PDFlineas="false" PDFnoborder="true">
			    <label size="25"></label>
			    <tipo>numeric</tipo>	
				<detalle>SubTotal</detalle>
			</field>
			
			<order>
			    <field id="orden"/>
			</order>

	    </table>
		</form>
    </histrix>	

