<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="ficha" imprime="false" preFetch="true" _conBusqueda="true" log="false" sololectura="true">
    <title>Cuentas</title>
    <obs></obs>

    <form >

        <table id="REG_CUENTA" label="Cuentas">
            
            <field id="id_regcuenta" noshow="true" esClave="true" />
            
            <field id="subsistema_id" noshow="true"   />
            
            <field id="subsistemarelacionada_id" local="true" noshow="true" valauto="true" />

            <fieldGroup Formstyle="vertical-align:middle; padding: 2px 2px 2px 2px;">

                <field id="nro_cuenta">
                    <label>Cuenta Nro</label>
                </field>

                <field id="nombre_cuenta">
                    <label colspan="5">Nombre</label>
                    <help>Nombre de la cuenta</help>
                    <size>80</size>
                </field>

                <field id="separator_1" local="true" Formstyle="background-color: #c9c9c9; height: 1px;font-size:2px;" colspan="9" deshabilitado="true" />

                <field id="regzona_id">
                    <tabla_ex id="REG_ZONAS">
                        <field id="id_regzona" />
                        <field id="nombre_zona" />
                        <field id="subsistema_id" />
                    </tabla_ex>
                    <label>Zona</label>
                </field>

                <field id="nombre_provincia">
                    <label>Provincia</label>
                    <expresion>nombre_provincia</expresion>
                    <size>20</size>
                </field>

                <field id="nombre_localidad">
                    <label modpos="nobr">Localidad</label>
                    <expresion>nombre_localidad</expresion>
                    <help>Nombre de la localidad</help>
                    <size>20</size>
                </field>
	    <!-- Dirección -->

                <field id="cod_direccion">
                    <label>Calle</label>
                    <size>40</size>
                </field>

                <field id="bis_direccion">
                    <label modpos="nobr">Bis</label>
                    <tipo>check</tipo>
                </field>

                <field id="nro_direccion">
                    <label >Nº</label>
                    <size>10</size>
                </field>

                <field id="abreviacion_direccion" >
                    <label modpos="nobr">Piso/Dpto</label>
                    <size>15</size>
                </field>

                <field id="separator_2" local="true" Formstyle="background-color: #c9c9c9; height: 1px;font-size:2px;" colspan="9" deshabilitado="true" />

                <field id="fecha_nacimiento">
                    <label>Fecha Nac.</label>
                    <tipo>date</tipo>
                </field>

                <field id="tel_cuenta">
                    <label _modpos="nobr">Telefonos</label>
                    <!-- <expression>
                        SELECT group_concat(valor, ' ') 
                                 
                         FROM REG_CUENTAS_CONTACTOS

                         JOIN GEN_TIPO_CONTACTOS on 
                        
                            ( GEN_TIPO_CONTACTOS.id_contacto = REG_CUENTAS_CONTACTOS.contacto_id  )

                            WHERE regcuenta_id = REG_CUENTA.id_regcuenta and vcard_type like 'TEL%' LIMIT 1
                    </expression> -->
                    <size>40</size>
                </field>

                <field id="email_cuenta" _modpos="nobr">
                  <label>email</label>
                   <size>40</size>
                </field>

                <field id="separator_3" local="true" Formstyle="background-color: #c9c9c9; height: 1px;font-size:2px;" colspan="9" deshabilitado="true" />
	    <!-- Fechas -->

                <field id="alta_cuenta">
                    <label >Alta</label>
                    <tipo>date</tipo>
                </field>

                <field id="baja_cuenta">
                    <label modpos="nobr">Baja</label>
                    <tipo>date</tipo>
                </field>

	    <!-- Fiscales -->

                <field id="tipo_documento_id">
                    <tabla_ex xml="tipos_documento_qry.xml" dir="/ayudas"/>
                    <label>Documento</label>
                </field>

                <field id="nro_documento">
                    <label modpos="nobr">Nº DOC</label>
                </field>

                <field id="iva_id">
                    <tabla_ex xml="iva_qry.xml" dir="/ayudas" vacio="true" />
                    <label >Cat. IVA</label>
                    <help>Categoria de IVA</help>
                </field>

                <field id="cuit_cuenta">
                    <label modpos="nobr">Nº CUIT</label>
                    <help>Número de CUIT</help>
                </field>

                <field id="nro_ingbrutos">
                    <label _modpos="nobr">Nº IBR</label>
                    <help>Numero de ingresos brutos de la cuenta</help>
                </field>

                <field id="percepcion" modpos="nobr">
                    <label>Agente Percepcion</label>
                    <options exp="true">
                        <option valor=""></option>
                        <option valor="0">NO</option>
                        <option valor="1">SI</option>
                    </options>
                </field>

            </fieldGroup>
         
        </table>
        <join tipo="left">
            <table id="GEN_PROVINCIAS">
                <field id="id_provincia">
                    <condicion operador="=">REG_CUENTA.provincia_id</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="GEN_LOCALIDADES">
                <field id="id_localidad">
                    <condicion operador="=">REG_CUENTA.localidad_id</condicion>
                </field>
            </table>
        </join>

    </form>
</histrix>
