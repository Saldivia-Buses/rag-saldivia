			<field id="nro_movimiento" noshow="true">
				<label modpos="nobr">Nro.Comp.</label>
			</field>  
			<field id="letra_movimiento" noshow="true">
				<label modpos="nobr">letra</label>
			</field>  

			<field id="id_regmovim" noshow="true">
				<help>Codigo de Movimiento</help>
				<detalle>regmovim_id</detalle>
			</field>

			<field id="concepto_id" noshow="true">
				<label>Concepto</label>
<!--				<condicion operador="=">(select option_value from HTXOPTIONS where option_name ='ID_FACTURAS')</condicion> -->
			</field>
			<field id="nro_cuenta" tabla="REG_CUENTA" repeat="false">
					<helper type="external" xml="regcuenta_solamente_nro_qry.xml" dir="/ayudas" empty="true" />

			    <label>Cod</label>
			</field> 

		<field  id="nombre_cuenta" tabla="REG_CUENTA" linkdes="Cuenta Corriente" repeat="false" >
                <label>Nombre</label>
                <helper type="link" xml="regdetalles_all_qry.xml" dir="/clientes/qry" modal="true">
                    <parameter source="regcuenta_id" target="regcuenta_id" operator="="/>
                    <parameter source="subsistema_id" target="subsistema_id" operator="="/>
                </helper>
            </field>

          	<field id="contactos" linkint="cctconta_consulta.xml" dir="/" linkdes="Ver medios de Contacto">
              	<expression>'Contactos'</expression>
                <label>Contactos</label>
                <help>Contactos Cliente</help>
                <paring destino="ctacod">nro_cuenta</paring>
                <paring destino="siscod">subsistema_id</paring>
<!--                 <attribute id="tooltip">telefono</attribute>
 -->            </field>

