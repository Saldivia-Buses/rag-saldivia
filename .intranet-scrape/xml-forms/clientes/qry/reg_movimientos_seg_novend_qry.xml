				<operador>&gt;=</operador>
			</field>
			<field id="fecha_movimiento" >
				<label modpos="nobr">Hasta Fecha</label>
				<valor>today</valor>
				<operador>&lt;=</operador>
			</field>
			<field id="maxobs" deshabilitado="false">
			    <label>Fecha Observacion</label>
			    <tipo>date</tipo>
			</field>

			<field id="nro_cuenta" tabla="REG_CUENTA">
			    <label>Cliente</label>
			</field> 

			<!--
			<field id="regcuenta_id">
				<label modpos="nobr">Nombre de Cuenta</label>
				<operador>=</operador>
			</field> 
			--> 
			
			<field id="nro_movimiento" >
				<label modpos="nobr">Nro.Comp.</label>
				<operador>=</operador>
			</field>  
