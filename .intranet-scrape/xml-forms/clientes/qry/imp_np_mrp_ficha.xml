<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="ficha" PDFsincabecera="true" sololectura="true" autoprint="true" PDFfontSize="9" PDFpageSize="A4">
  <title>Nota de Pedido</title>
  <obs></obs>
  <form>
    <pdf PDForientacion="P">
        <code><![CDATA[
                $pdf->SetDrawColor(0);
                $pdf->SetXY(10,10);

                $tp = 05;
                $ap = $pdf->anchoPagina - 2;
                $mp = ($ap / 2);
                $lp = $pdf->largoPagina;

                // Frame Principal
                $pdf->Rect(005, 005, $ap, $lp, 0.1);

                // Nombre Empresa
                $pdf->Rect(005, 005, $mp, 045, 0.1);

                $datapath = $_SESSION['datapath'];
                $file = "../database/$datapath/img/logotc_pdf.jpg";

                if (is_file($file))
                {
                    $posx = 10;
                    $posy = 6;
                    $width = 85;
                    $pdf->Image($file, $posx + $this->offsetX, $posy + $this->offsetY, $width);
                }

                // Datos Comprobante
                $pdf->Rect($mp + 5, 005, $mp, 045, 0.1);

                // letra
                $pdf->setFillColor(255,255,255);
                $pdf->Rect($mp - 12, 005, 040, 025, 'F');
                $pdf->Rect($mp - 12, 005, 040, 025, 0.1);

                // Cliente
                $pdf->Rect(005, 053, $ap, 033, 0.1);

                // DATOS EMPRESA
                $pdf->SetFontSize(8);

                $pdf->text(047, 035, iconv('UTF-8', 'windows-1252', html_entity_decode($_SESSION['properties']['nombre'])));
                $pdf->text(027, 041, iconv('UTF-8', 'windows-1252', html_entity_decode($_SESSION['properties']['direccion'])).' - '.$_SESSION['properties']['localidad']);
                $pdf->text(030, 045, $_SESSION['properties']['telefonos'].' - '.$_SESSION['properties']['mail']);
                $pdf->text(040, 051, 'IVA RESPONSABLE INSCRIPTO');

                $pdf->SetFont('Arial', 'B', 8);
                $pdf->text($mp + 010, 045, 'C.U.I.T.: '.$_SESSION['properties']['cuit']);
                $pdf->text($mp + 010, 051, 'Ingresos Brutos: '.$_SESSION['properties']['iibb']);
                $pdf->text($mp + 075, 051, 'Fec. Inicio. Activ.: '.$_SESSION['properties']['fecha']);

            ]]></code>
        </pdf>

        <table id="REG_MOVIMIENTOS"  label="FACTURA">

            <field id="id_regmovim" noshow="false" esClave="true" print="false" />

            <field id="muestra_iva" noshow="true" local="true" print="false">
                <expresion>case when letra_movimiento = 'A' or letra_movimiento = 'a'  then 'true' else 'false' end </expresion>
            </field>

            <field id="nomuestra_iva" noshow="true" local="true" print="false">
                <expresion>case when letra_movimiento = 'A' or letra_movimiento = 'a'  then 'false' else 'true' end </expresion>
            </field>

            <field id="muestra_dto" noshow="true" local="true" print="false">
                <expresion>IF(importe_bon != 0,'true','false')</expresion>
            </field>

            <field id="muestra_vencimiento" noshow="true" local="true" print="false">
                <if exp="'vencimiento_movimiento' != ''">
                    <true>'true'</true>
                    <false>'false'</false>
                </if>
            </field>

            <field id="subsistema_id" noshow="true" print="false" />

            <field id="concepto_id" noshow="true" print="false" />

            <field id="regcuenta_id" noshow="true" print="false" />

            <field id="id_regcuenta" noshow="true" print="false" tabla="REG_CUENTA" deshabilitado="true" />

            <fieldGroup id="letra" deshabilitado="true" PDFnoborder="true">
                <field id="letra_movimiento" PDFbold="true" PDFsize="26">
                    <label posx="98.5" posY="5" />
                    <expresion>UPPER(letra_movimiento)</expresion>
                </field>

                <field id="documento_no_valido" PDFbold="true" PDFsize="7" local="true">
                    <label posx="85" posY="+3" />
                    <valor>DOCUMENTO NO VALIDO
          COMO FACTURA</valor>
                </field>
            </fieldGroup>

            <fieldGroup id="cabecera1" deshabilitado="true" PDFnoborder="true">
                <field id="descripcion_concepto" PDFbold="true" PDFsize="13">
                    <label posx="140" posY="5" />
                    <expresion>UPPER(REG_CONCEPTOS.descripcion_concepto)</expresion>
                </field>

                <field id="nro_Movimiento" PDFsize="10" PDFnoborder="true" PDFbold="true">
                    <label posx="135" posY="+1">Nro: </label>
                    <expresion>CONCAT(LPAD(puesto_movimiento,4,'0'),' - ',LPAD(nro_movimiento,8,'0'))</expresion> 
                </field>

                <field id="fecha_movimiento" PDFsize="10" PDFnoborder="true">
                    <label posx="135" posY="15" size="26">Fecha: </label>
                </field>

                <field id="nombre_cuenta" tabla="REG_CUENTA" PDFbold="true" pdfancho="120">
                    <label posx="3" posY="+13" size="20">Nombre: </label>
                    <expression>LEFT(REG_CUENTA.nombre_cuenta, 120)</expression>
                </field>

                <field id="iva_id" tabla="REG_CUENTA">
                    <label posx="125" posY="0" size="20">I.V.A.: </label>
                    <helper type="combo" xml="iva_qry.xml" dir="/ayudas" empty="true" />
                </field>

                <field id="cod_direccion" tabla="REG_CUENTA" pdfancho="120">
                    <label posx="3" posY="+2" size="20">Direccion: </label>
                    <expression>LEFT(CONCAT(cod_direccion, ' ', (CASE WHEN nro_direccion = 0 OR nro_direccion is null THEN '' ELSE nro_direccion END)), 120)</expression>
                </field>

                <field id="cuit_cuenta" tabla="REG_CUENTA">
                    <label posx="125" posY="0" size="20">C.U.I.T.: </label>
                </field>

                <field id="localidad" pdfancho="120">
                    <expression>LEFT(CONCAT(LOCALIDAD_CUENTA.cp, ' ', LOCALIDAD_CUENTA.nombre_localidad), 110)</expression>
                    <label posx="3" posY="+2" size="20">Localidad: </label>
                </field>

                <field id="provincia" pdfancho="80">
                    <expression>LEFT(PROVINCIA_CUENTA.nombre_provincia, 110)</expression>
                    <label posx="125" posY="0" size="20">Provincia: </label>
                </field>

                <field id="regforma_id" pdfancho="120">
                    <label posx="3" posY="+2" size="20">Forma pago:</label>
                    <helper type="combo" id="REG_FORMAS">
                        <field id="id_regforma"/>
                        <field id="nombre_forma"/>
                    </helper>
                </field>
            </fieldGroup>

            <fieldGroup id="cuerpo1" pdfwidth="200">
                <field id="detalles" local="true">
                    <label posx="5" posy="+3" />
                    <helper xml="imp_np_mrp_detalle.xml" type="object" dir="/clientes/qry">
                        <parameter source="id_regmovim"   target="regmovim_id" />
                    </helper>
                </field>
            </fieldGroup>

            <fieldGroup id="email" print="false" noshow="true">
                <field id="email_cuenta" email="to" tabla="REG_CUENTA" />
                <field id="asunto" email="subject">
                    <expression>concat(REG_CONCEPTOS.descripcion_concepto,' ',letra_movimiento,' ',lpad(puesto_movimiento,4,0),'-',lpad(nro_movimiento,8,0))</expression>
                </field>
            </fieldGroup>

            <group>
                <field id="id_regmovim" />
            </group>

        </table>

        <join tipo="left">
            <table id="REG_CONCEPTOS">
                <field id="id_concepto">
                    <condicion operador="=">concepto_id</condicion>
                </field>
            </table>
        </join>

        <join tipo="left">
            <table id="REG_CUENTA">
                <field id="id_regcuenta">
                    <condicion operador="=">regcuenta_id</condicion>
                </field>
            </table>
        </join>

        <join tipo="left">
            <table id="GEN_LOCALIDADES" as="LOCALIDAD_CUENTA">
                <field id="id_localidad">
                    <condicion operador="=">REG_CUENTA.localidad_id</condicion>
                </field>
            </table>
        </join>

        <join tipo="left">
            <table id="GEN_PROVINCIAS" as="PROVINCIA_CUENTA">
                <field id="id_provincia">
                    <condicion operador="=">REG_CUENTA.provincia_id</condicion>
                </field>
            </table>
        </join>

    </form>
</histrix>
