<?xml version="1.0" encoding="ISO-8859-1" ?>
<histrix tipo="consulta" preloadData="false" paginar="200" PDFfontSize="7" PDFlines="false">
    <title>MOVIMIENTOS</title>
    <obs></obs>
    <form>
        <table id="REG_MOVIMIENTOS" label="MOVIMIENTOS">

            <filters>
                <field id="fecha_movimiento">
                    <label>Desde Fecha</label>
                    <valor eval="true">date('d/m/Y', mktime(0, 0, 0, date("m" ) - 3 , 1, date("Y") ))</valor>
                    <operador>&gt;=</operador>
                </field>
                <field id="fecha_movimiento">
                    <label modpos="nobr">Hasta Fecha</label>
                    <valor>today</valor>
                    <operador>&lt;=</operador>
                </field>
                <field id="maxobs" deshabilitado="false">
                    <label>Fecha Observacion</label>
                    <tipo>date</tipo>
                </field>
                <field id="nro_cuenta" tabla="REG_CUENTA">
                    <label>Cliente</label>
                </field>
                <field id="nro_movimiento">
                    <label modpos="nobr">Nro.Comp.</label>
                    <operador>=</operador>
                </field>
                <field id="regcuenta_idv" deshabilitado="false" modpos="nobr">
                    <label>Vendedor</label>
                    <operador>=</operador>
                </field>
            </filters>

        <fieldGroup colstyle="text-align:center;vertical-align:middle;padding:2px 2px 2px 2px;">

            <field id="subsistema_idv" local="true" oculto="true">
                <label>ss</label>
            </field>

            <field id="regcuenta_idv"  deshabilitado="false" print="false" >
                <expresion having="false">regcuentarelacionada_id</expresion>
                <label>Vendedor</label>
                <helper type="combo" xml="regcuenta_solamente_qry.xml" dir="/ayudas" empty="true" >
                    <field id="subsistema_id">
                        <condicion operador="=" valorde="subsistema_idv">'[__subsistema_idv__]'</condicion>
                    </field>
                </helper>
            </field>

            <field id="nro_movimiento" noshow="true">
                <label modpos="nobr">Nro.Comp.</label>
            </field>

            <field id="letra_movimiento" noshow="true">
                <label modpos="nobr">letra</label>
            </field>

            <field id="id_regmovim" noshow="true">
                <help>Codigo de Movimiento</help>
                <detalle>regmovim_id</detalle>
            </field>

            <field id="concepto_id" noshow="true">
                <label>Concepto</label>
            </field>

            <field id="nro_cuenta" tabla="REG_CUENTA" repeat="false">
                <helper type="external" xml="regcuenta_solamente_nro_qry.xml" dir="/ayudas" empty="true" />
                <label>Cod</label>
            </field>

            <field id="nombre_cuenta" tabla="REG_CUENTA" linkdes="Cuenta Corriente" repeat="false">
                <label>Nombre</label>
                <helper type="link" xml="regdetalles_all_qry.xml" dir="/clientes/qry" modal="true">
                    <parameter source="regcuenta_id" target="regcuenta_id" operator="="/>
                    <parameter source="subsistema_id" target="subsistema_id" operator="="/>
                </helper>
            </field>

            <field id="telefono" print="false" >
                <label >Telefono</label>
                <expresion>SELECT group_concat(REG_CUENTAS_CONTACTOS.valor, '&lt;br>') 
                             FROM REG_CUENTAS_CONTACTOS
                             JOIN GEN_TIPO_CONTACTOS on ( GEN_TIPO_CONTACTOS.id_contacto = REG_CUENTAS_CONTACTOS.contacto_id  )
                            WHERE regcuenta_id = REG_MOVIMIENTOS.regcuenta_id and vcard_type like 'TEL%' LIMIT 1
                </expresion>
                <tipo>editor</tipo>
            </field>

            <field id="regcuenta_id" noshow="true" break="true" />

            <field id="subsistema_id" noshow="true" />

            <field id="fecha_movimiento">
                <label>Fecha</label>
                <help>Fecha del movimiento</help>
            </field>

            <field id="imprime_concepto1" noshow="true">
                <label>imprim_con</label>
                <expresion>REG_NUMERADORES.ejecuta</expresion>
            </field>

            <field id="comprobantes" local="true"  linkdes="Facturas" linkdir="/caja/qry">
                <label>Comprobante</label>
                <expresion>concat(descripcion_concepto,' ',letra_movimiento, ' ' , lpad(puesto_movimiento,4,0),' ', lpad(nro_movimiento,8,'0') )</expresion>
                <paring destino="id_regmovim">id_regmovim</paring>
                <attribute id="linkint">imprime_concepto1</attribute>
                <helper type="link" xml="regmovim_obs_qry.xml" dir="caja/qry">
                    <parameter source="id_regmovim" target="regmovim_id" />
                </helper>
            </field>

            <field id="importe_movimiento" suma="true">
                <label>Importe</label>
            </field>

            <field id="saldo_movimiento" _noshow="true" suma="true">
                <label>Saldo</label>
                <condicion operador="&gt;">0</condicion>
            </field>

            <field id="saldo_movimiento" _noshow="true" suma="true" >
                <label>Saldo</label>
                <condicion operador="&gt;">0</condicion>
            </field>

            <field id="dias_demora" print="false">
                <label style="text-align:center;">demora</label>
                <expresion>datediff(curdate(), vencimiento_movimiento)</expresion>
            </field>

            <field id="dias_demora_grafico" print="false">
                <label></label>
                <expresion>datediff(curdate(), vencimiento_movimiento)</expresion>
                <tipo>grafico</tipo>
            </field>

            <field id="observaciones" local="true"  _linkint="regmovim_obs_qry.xml" linkdes="Observaciones" _linkdir="/clientes/qry" showValor="true" showObjTabla="true" obj="regmovim_obs_qry.xml" print="false" >
                <label>Obser.</label>
                <valor>'Obser'</valor>
                <tipo>varchar</tipo>
                <helper type="link" xml="regmovim_obs_qry.xml">
                    <parameter source="id_regmovim" target="regmovim_id" />
                    <parameter source="REG_MOVIMIENTOS" target="tabla_origen" />
                </helper>
            </field>

            <field id="prox_llamado">
                 <label>Llamar</label>
                <tipo>date</tipo>
            </field>

            <field id="posible_pago">
                <label>PosPago</label>
                <tipo>date</tipo>
            </field>

            <field id="cobranza_llamado" local="true" style="text-align:center;">
                <label>Cobranza</label>
                <helper type="link" xml="gestion_cobranza_ficha.xml" dir="/clientes/ing">
                    <parameter target="id_regmovim" source="id_regmovim" />
                </helper>
                <valor>+</valor>
            </field>

            <field id="obs_txt" colstyle="display:none;" print="false">
                <expresion>SELECT REPLACE(REPLACE(GROUP_CONCAT(CONCAT(rmo.fec_observacion, ' ', rmo.observacion), '*'), '*,', '\n'), '*', '') FROM REG_MOVIMIENTO_OBS rmo WHERE rmo.regmovim_id = REG_MOVIMIENTOS.id_regmovim and rmo.tabla_origen = 'REG_MOVIMIENTOS'</expresion>
                <label>Observaciones</label>
            </field>

            <field id="tablaorigen" noshow="true">
                <label>Tabla Orgien</label>
                <expresion>'REG_MOVIMIENTOS'</expresion>
                <detalle>tabla_origen</detalle>
            </field>

            <field id="maxobs" noshow="true">
                <expresion having="false">fec_observacion</expresion>
                <tipo>date</tipo>
            </field>

        </fieldGroup>

            <group>
                <field id="id_regmovim" /> 
            </group>

            <order>
                <field id="nombre_cuenta"/>
                <field id="fecha_movimiento"/>
                <field id="comprobantes">
                    <label>Comprobante</label>
                    <expresion>concat(descripcion_concepto,' ',letra_movimiento, ' ' , lpad(puesto_movimiento,4,0),' ', lpad(nro_movimiento,8,'0'))</expresion>
                </field>
            </order>

        </table>

        <join>
            <table id="REG_CUENTA">
                <field id="id_regcuenta">
                    <condicion operador="=">regcuenta_id</condicion>
                </field>
            </table>
        </join>

        <join>
            <table id="REG_CONCEPTOS">
                <field id="id_concepto">
                    <condicion operador="=">concepto_id</condicion>
                </field>
                <field id="imputacion_concepto">
                    <condicion operador="=">0</condicion>
                </field>
                <field id="informa_calculo">
                    <condicion operador="=">0</condicion>
                </field>
            </table>
        </join>

        <join tipo="left">
            <table id="REG_NUMERADORES">
                <field id="regconcepto_id">
                    <condicion operador="=">REG_CONCEPTOS.id_concepto</condicion>
                </field>
                <field id="puesto">
                    <condicion operador="=">REG_MOVIMIENTOS.puesto_movimiento</condicion>
                </field>
            </table>
        </join>

        <join tipo="left">
            <table id="REG_MOVIMIENTO_OBS">
                <field id="regmovim_id">
                    <condicion operador="=">id_regmovim</condicion>
                </field>
            </table>
        </join>

        <join tipo="left">
            <table id="REG_CUENTA_RELACIONES">
                <field id="regcuenta_id">
                    <condicion operador="=">id_regcuenta</condicion>
                </field>
                <field id="subsistemarelacionada_id">
                    <condicion operador="=">[__subsistema_idv__]</condicion>
                </field>
            </table>
        </join>

    </form>
</histrix>