<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="ficha" PDFsincabecera="true"  sololectura="true" autoprint="true" PDFfontSize="8" PDFfont="Courier" copies="3">
  <title>FACTURA</title>
  <obs></obs>
  <form >

     <table id="REG_MOVIMIENTOS"  label="FACTURA">
     
      <field id="id_regmovim"  noshow="false" esClave="true" print="false">
        <label>Codigo</label>
        <help>Codigo de movimiento</help>
      </field>


	<field id="muestra_iva" noshow="true" local="true" print="false">
		<expresion>case when letra_movimiento = 'A' or letra_movimiento = 'a'  then 'true' else 'false' end </expresion>
	</field>	
	<field id="muestra_dto" noshow="true" local="true" print="false">
		<expresion>IF(importe_bon != 0,'true','false')</expresion>
	</field>
	
	
        
	<field id="subsistema_id" noshow="true" print="false"></field>
	
    <field id="concepto_id" noshow="true" print="false" />
    
      <field id="regcuenta_id" noshow="true" print="false">
        <label posx="5" posy="+1"></label>
      </field>

      <field id="descripcion_concepto" tabla="REG_CONCEPTOS" PDFbold="true" >
			<label modpos="nobr"  posx="145" posY="5" PDFsize="12"></label>
      </field>

      <field id="nro_movimiento" oculto="true"/>

      <field id="NumeroMov" print="false">
           <label modpos="nobr"  posx="140" posY="15" PDFsize="12"></label>
           <expresion>LPAD(nro_movimiento,8,'0')</expresion>
         </field>
      <field id="fecha_movimiento">
        <label modpos="nobr"  posx="122" posY="22" PDFsize="10"></label>
        <help>Fecha movimiento</help>
      </field>
      <field id="nro_Movimiento" PDFnoborder="true" PDFbold="true">
           <label modpos="nobr"  posx="145" posY="22" PDFsize="9" _size="6" PDFnolabel="true">Nº</label>
           <expresion>CONCAT(letra_movimiento,' ',LPAD(puesto_movimiento,4,'0'),' - ',LPAD(nro_movimiento,8,'0'))</expresion> 
           <expresion>LPAD(nro_movimiento,8,'0')</expresion>
         </field>
      <field id="vencimiento_movimiento">
        <expresion>case when vencimiento_movimiento != '0000-00-00' then vencimiento_movimiento end</expresion>
        <label modpos="nobr"  posx="122" posY="26" PDFsize="8">Entrega</label>
        <help>Entrega</help>
      </field>

           <field id="nombre_cuenta"  tabla="REG_CUENTA" deshabilitado="true" _sincelda="true" PDFbold="true">
                <label colspan="4"  posx="17" posY="+20" size="80"></label>                
            </field>
           <field id="nro_cuenta"  tabla="REG_CUENTA" deshabilitado="true"  PDFnoborder="true" _sincelda="true" style="text-align:right;">
                <label colspan="4"  posx="130" _posY="+0" size="20">Cuenta Nº</label>
            </field>
            <field id="cod_direccion" tabla="REG_CUENTA" deshabilitado="true" _sincelda="true">
                <label colspan="0" posx="17" posY="+0.5" size="50"></label>
            </field>
            <field id="telefono" deshabilitado="true" PDFnoborder="true" _sincelda="true">
                <label colspan="0" posx="130" _posY="+0" size="20">Telefono</label>
		<expresion>SELECT valor FROM REG_CUENTAS_CONTACTOS 
			JOIN GEN_TIPO_CONTACTOS on ( GEN_TIPO_CONTACTOS.id_contacto = REG_CUENTAS_CONTACTOS.contacto_id  ) 
			where regcuenta_id = REG_MOVIMIENTOS.regcuenta_id and vcard_type = 'TEL;WORK' LIMIT 1
		</expresion>
            </field>

	    <field id="localidad_id" tabla="REG_CUENTA" deshabilitado="true" _sincelda="true">
                <label colspan="4" posx="17" posY="+0.5" size="50"></label>
		<expresion>SELECT nombre_localidad FROM GEN_LOCALIDADES where id_localidad = REG_CUENTA.localidad_id</expresion>
            </field>
            <field id="fax" deshabilitado="true" PDFnoborder="true" _sincelda="true">
                <label colspan="0" posx="130" _posY="+0" size="20">Fax</label>
		<expresion>SELECT valor FROM REG_CUENTAS_CONTACTOS 
			JOIN GEN_TIPO_CONTACTOS on ( GEN_TIPO_CONTACTOS.id_contacto = REG_CUENTAS_CONTACTOS.contacto_id  ) 
			where regcuenta_id = REG_MOVIMIENTOS.regcuenta_id and vcard_type = 'TEL;FAX;WORK' LIMIT 1
		</expresion>
            </field>
	 <field id="iva_id" tabla="REG_CUENTA" >
		<tabla_ex xml="iva_qry.xml" dir="/ayudas" vacio="true">
		</tabla_ex>
		<label colspan="3" modpos="nobr" posx="20" posY="+6" ></label>
	</field>
	<field id="cuit_cuenta" tabla="REG_CUENTA" deshabilitado="true" sincelda="true" >
            <label colspan="3" modpos="nobr" posx="126" _posY="101" size="30"></label>
    </field>

	<field id="regforma_id" >
		<helper type="combo" id="REG_FORMAS" >
			<field id="id_regforma"/>
			<field id="nombre_forma"/>
		</helper>
		<label colspan="3" modpos="nobr" posx="45" posY="+0.5" ></label>
	</field>

	<field id="factura" local="true" sincelda="true" PDFnolabel="true" >
		<expresion>SELECT mrem.nro_movimiento FROM REG_DETALLES 
		LEFT JOIN REG_IMPUTACIONESDETALLES rimp ON REG_DETALLES.id_regdetalle = rimp.regdetallefac_id 
		LEFT JOIN REG_DETALLES dfac ON rimp.regdetalleped_id = dfac.id_regdetalle
		LEFT JOIN REG_MOVIMIENTOS mrem ON dfac.regmovim_id = mrem.id_regmovim
		WHERE REG_DETALLES.regmovim_id = REG_MOVIMIENTOS.id_regmovim and mrem.concepto_id = 47
		GROUP BY mrem.nro_movimiento
		/*rm.nro_movimiento = REG_MOVIMIENTOS.nro_movimiento and rm.concepto_id = (SELECT option_value FROM `HTXOPTIONS` where option_name = 'ID_NOITASPEDIDOS')*/
		</expresion>
		<label posx="130" posy="0">Factura</label>
	</field>

	<field id="pedido" local="true" PDFnolabel="true" >
		<expresion>SELECT mnp.nro_movimiento FROM REG_DETALLES 
		LEFT JOIN REG_IMPUTACIONESDETALLES rimp ON REG_DETALLES.id_regdetalle = rimp.regdetallefac_id 
		LEFT JOIN REG_DETALLES dfac ON rimp.regdetalleped_id = dfac.id_regdetalle
		LEFT JOIN REG_MOVIMIENTOS mnp ON dfac.regmovim_id = mnp.id_regmovim
		WHERE REG_DETALLES.regmovim_id = REG_MOVIMIENTOS.id_regmovim and mnp.concepto_id = (SELECT option_value FROM `HTXOPTIONS` where option_name = 'ID_NOTA_PEDIDOS')
		GROUP BY mnp.nro_movimiento
		</expresion>
		<label posx="160" posy="0">Pedido</label>
	</field>
                                                        
			<field id="regcuentatransporte_id" >
				<label posx="17" posy="+2">Transporte</label>
				
				<helper type="combo" xml="regcuenta_simple_qry.xml" dir="/ayudas" empty="true">
					<field id="id_regcuenta" />
					<field id="baja_cuenta">
						<condicion operador="=">'0000-00-00'</condicion> 
					</field>
					<field id="subsistema_id" >
						<condicion operador="=">'TR'</condicion>
					</field>
				</helper>
			</field>      
                                                             
         <field id="detalles" local="true" pdfwidth="185">
              <label  PDFnolabel="true" PDFlineas="false" size="25" posx="15" posy="+10" ></label>
			  <helper xml="imp_factura_detalle_dh_qry.xml" type="object" dir="/clientes/qry">
					<parameter source="id_regmovim" target="regmovim_id"/>
					<parameter source="subsistema_id" target="subsistema_id"/>
					<parameter source="muestra_iva" target="muestra_iva"/>
			  </helper>
        </field>



    == TALON ==
	
	<field id="SubTotal" PDFnoborder="true">
		<label modpos="nobr" posx="120" posY="220"   size="22" PDFsize="9" pdfancho="55">Sub-Total</label>
		<expresion>	SUM(REG_DETALLES.neto_detalle) </expresion>
		<tipo>numeric</tipo>
		<attribute id="print">muestra_iva</attribute>
	</field>

	<field id="SubTotalT" PDFnoborder="true">
		<label modpos="nobr" posx="120" posY="220"   size="22" PDFsize="9" pdfancho="55">Sub Total</label>
		<expresion>	SUM(REG_DETALLES.total_detalle) </expresion>
		<tipo>numeric</tipo>
		<attribute id="print">nomuestra_iva</attribute>
	</field>

	<field id="Saldo" PDFnoborder="true" pdfancho="70">
		<label posx="20" posY="220">Su saldo actual es de $</label>
		<expresion>SELECT saldo_cuenta FROM REG_CUENTA_SALDOS WHERE REG_CUENTA_SALDOS.id_regcuenta = REG_MOVIMIENTOS.regcuenta_id</expresion>
	</field>

    <field id="cantidad_bultos">
  	  <label posx="20" posY="228">Cant.Unidades:</label>
<!--	  <expresion>SELECT sum(cantidad_detalle) FROM REG_DETALLE_VISTA 
	  WHERE REG_DETALLE_VISTA.regmovim_id = REG_MOVIMIENTOS.id_regmovim 
	  AND not (REG_DETALLE_VISTA.codigo_detalle like 'cbo%' or REG_DETALLE_VISTA.codigo_detalle 
	  like 'pro%')</expresion> 
	  -->
	  <expression> ifnull((SELECT sum(cantidad_detallecmb) FROM REG_DETALLE_COMBOS WHERE REG_DETALLE_COMBOS.regmovim_id = REG_MOVIMIENTOS.id_regmovim), 0)
+ ifnull((SELECT sum(cantidad_detalle) FROM REG_DETALLES
	  WHERE REG_DETALLES.regmovim_id = REG_MOVIMIENTOS.id_regmovim
	  AND not (REG_DETALLES.codigo_detalle like 'cbo%' or REG_DETALLES.codigo_detalle 
	  like 'pro%')),0)
	  </expression>
	  
    </field>
  
	<field id="regcuentavendedor_id" _PDFnoborder="true">
		<label posx="20" posY="+2">Vendedor</label>
		<expresion>SELECT nro_cuenta FROM REG_CUENTA WHERE REG_CUENTA.id_regcuenta = REG_MOVIMIENTOS.regcuentavendedor_id</expresion>
	</field>
    

    

	<field id="bonificaciones_movimiento" PDFnoborder="true">
		<label modpos="nobr" posx="120" posY="228" size="25" pdfancho="25" PDFsize="9">Descuento %</label>
		<tipo>numeric</tipo>
		<attribute id="print">muestra_dto</attribute>
	</field>

    	<field id="importe_bon" PDFnoborder="true">
			<label modpos="nobr" posx="177" posY="0" size="2" pdfancho="18" PDFsize="9">$</label>
			<expresion>ROUND(importe_bon * 1.21,2)</expresion>
  	  		<tipo>numeric</tipo>
		    <attribute id="print">muestra_dto</attribute>
	    </field>
	

	<field id="neto_movimiento" PDFnoborder="true">
		<label posx="120" posY="233" size="24" pdfancho="53" PDFsize="8">Neto Gravado</label>
		<tipo>numeric</tipo>
		<attribute id="print">muestra_iva</attribute>
	</field>
		
	<field id="total_iva" PDFnoborder="true">
		<label modpos="nobr" posx="120" posY="238" size="22" pdfancho="55" PDFsize="9">I.V.A.</label>
		<expresion>SUM(REG_DETALLES.iva_detalle)</expresion>
		<tipo>numeric</tipo>
		<attribute id="print">muestra_iva</attribute>
	</field>




	<field id="referencia_movimiento" maxsize="160" maxlength="160">
		<label posx="20" posY="+2" pdfancho="170">Observaciones</label>
		<size>40</size>
	</field>

	<field id="importe_movimiento" PDFnoborder="true" PDFbold="true">
		<label modpos="nobr" posx="120" posY="244" PDFsize="10" size="22" pdfancho="55">TOTAL</label>
	</field>
	
























	<group>
		<field id="id_regmovim"/>
	</group>

	
      
		    </table>
		<join tipo="left">
			<table id="REG_CONCEPTOS">
			    <field id="id_concepto">
				<condicion operador="=">concepto_id</condicion>
			    </field>
			</table>
		</join>
		<join tipo="left">
			<table id="REG_CUENTA">
				<field id="id_regcuenta">
					<condicion operador="=">regcuenta_id</condicion>
				</field>
			</table>
		</join> 
		<join tipo="left">
			<table id="REG_DETALLES">
				<field id="regmovim_id">
					<condicion operador="=">id_regmovim</condicion>
				</field>
			</table>
		</join> 

  </form>
</histrix>  
