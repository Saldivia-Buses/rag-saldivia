            <field id="factura" local="true" sincelda="true" PDFnolabel="true">
                <expresion>SELECT CONCAT(mfac.letra_movimiento, ' ', LPAD(mfac.puesto_movimiento,4,'0'), '-', LPAD(mfac.nro_movimiento, 8, '0')) FROM REG_DETALLES
LEFT JOIN REG_IMPUTACIONESDETALLES rimp ON REG_DETALLES.id_regdetalle = rimp.regdetalleped_id 
LEFT JOIN REG_DETALLES dfac ON rimp.regdetallefac_id = dfac.id_regdetalle
LEFT JOIN REG_MOVIMIENTOS mfac ON dfac.regmovim_id = mfac.id_regmovim
WHERE REG_DETALLES.regmovim_id = REG_MOVIMIENTOS.id_regmovim
GROUP BY mfac.nro_movimiento limit 1
                </expresion>

/*rm.nro_movimiento = REG_MOVIMIENTOS.nro_movimiento and rm.concepto_id = (SELECT option_value FROM `HTXOPTIONS` where option_name = 'ID_NOTASPEDIDOS')*/
