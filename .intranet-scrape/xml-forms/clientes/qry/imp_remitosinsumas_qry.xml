            <field id="pedido" local="true" PDFnolabel="true">
                <expresion>
SELECT np.nro_movimiento FROM REG_DETALLES xrdt
LEFT JOIN REG_IMPUTACIONESDETALLES xrimp ON xrdt.id_regdetalle = xrimp.regdetallefac_id 
LEFT JOIN REG_DETALLES xrdnp  ON xrimp.regdetalleped_id = xrdnp.id_regdetalle
LEFT JOIN REG_MOVIMIENTOS np ON xrdnp.regmovim_id = np.id_regmovim 
WHERE xrdt.regmovim_id = ( SELECT mfac1.id_regmovim FROM REG_DETALLES xrdt1
LEFT JOIN REG_IMPUTACIONESDETALLES rimp1 ON xrdt1.id_regdetalle = rimp1.regdetalleped_id 
LEFT JOIN REG_DETALLES dfac1 ON rimp1.regdetallefac_id = dfac1.id_regdetalle
LEFT JOIN REG_MOVIMIENTOS mfac1 ON dfac1.regmovim_id = mfac1.id_regmovim
WHERE xrdt1.regmovim_id = REG_MOVIMIENTOS.id_regmovim
GROUP BY mfac1.nro_movimiento
limit 1) and  np.concepto_id =  (SELECT option_value FROM `HTXOPTIONS` where option_name = 'ID_NOTA_PEDIDOS' limit 1)
GROUP BY np.nro_movimiento limit 1

                </expresion>
                <label posx="160" posy="0">Pedido</label>
            </field>
