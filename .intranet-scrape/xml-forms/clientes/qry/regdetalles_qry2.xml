<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta">
  <title>Movimientos</title>
  <obs/>
  <form detalle="regimputaciones_qry.xml" inline="true" hasDetail="imputacion_concepto">
  
    <table id="REG_MOVIMIENTOS" label="Resumen de Cuenta">

      <preconsultas>
		<xmlfile id="regdetalles_pre.xml" />
      </preconsultas>
      
      <fieldGroup id="entorno" noshow="true">

      <field id="subsistema_id" valauto="true">
        <preparam operador="=">true</preparam>
	    <tipo>varchar</tipo>
      </field>

      <field id="tipo" valauto="true" local="true" />

      <field id="regcuenta_id" valauto="true">
        <preparam operador="=">true</preparam>
      </field>
      
      <field id="desde" valauto="true" local="true">
        <preparam campo="fecha_movimiento" operador="&lt;">true</preparam>
      </field>
      
      <field id="hasta" valauto="true" local="true" />
      
      </fieldGroup>

      <field id="id_regmovim" noshow="true">
    	<detalle>regmovim_id</detalle>
      </field>

      <field id="nombre_cuenta" noshow="true">
        <expresion>REG_CUENTA.nombre_cuenta</expresion>
        <setvar>nombre_div</setvar>
      </field>

	<field id="cajmovimiento_id" noshow="true" /> 

	<field id="xml_llamar"  local="true" noshow="true">
		<if exp="cajmovimiento_id !=0">
		  <true>'cajmovimiento_ficha.xml'</true>
		  <false>''</false>
		</if>
	</field>
	
    <field id="imprime_concepto1" noshow="true">
	  <expresion>case when isnull(CAJ_CONCEPTOS.imprime_concepto) then REG_NUMERADORES.ejecuta else CAJ_CONCEPTOS.imprime_concepto end</expresion>
	</field>
	
      <field id="fecha_movimiento">
        <label>Fec.Mov.</label>
        <help>Fecha movimiento</help>
        <condicion operador="&gt;=">'[__desde__]' and REG_MOVIMIENTOS.fecha_movimiento &lt;= '[__hasta__]' </condicion>
        <tipo>date</tipo>
      </field>

      <field id="abreviacion_concepto" tabla="REG_CONCEPTOS">
        <label>Comp</label>
      </field>

      <field id="nro_movimiento" tdWidth="150" linkdes="Detalle del Comprobante" linkmodal="true" style="text-align: center">
        <label>Numero</label>
        <expresion>CONCAT(REG_MOVIMIENTOS.letra_movimiento,' ',LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,'0'),'-',LPAD(REG_MOVIMIENTOS.nro_movimiento  ,8,'0'))</expresion>
	  	<helper type="link" dir="/caja/qry" >
			<parameter source="id_cajmovimiento" target="id_cajmovimiento" />
			<parameter source="id_regmovim" target="id_regmovim" />
	  	</helper>
	  	<attribute id="linkint">imprime_concepto1</attribute>
      </field>
            
	  <!-- Cambiar de Acuerdo a como se quiere visualizar las imputaciones de CtaCte -->

      <field id="imputacion_concepto" noshow="true">
    	<expresion>CASE WHEN REG_CONCEPTOS.imputacion_concepto = 0 THEN 0 ELSE 1 END</expresion>  
      </field>
      
      <!-- Importes -->

      <field id="debe" suma="true" noZero="true">
        <label>debe</label>
        <expresion>case when REG_CONCEPTOS.imputacion_concepto = 0 then REG_MOVIMIENTOS.importe_movimiento else 0  end</expresion>
      	<tipo>numeric</tipo>
      </field>

      <field id="haber" suma="true" noZero="true">
        <label>haber</label>
        <expresion>case when REG_CONCEPTOS.imputacion_concepto = 1 then REG_MOVIMIENTOS.importe_movimiento else 0 end</expresion>
        <tipo>numeric</tipo>
      </field>
      
	  <field id="acumulado" suma="true" acumula="true"  local="true">
		<label>Acumulado</label> 
		<if exp="true">
		  <true>debe - haber</true>
		  <false>0</false>
		</if>
		<tipo>numeric</tipo>
	  </field>

      <field id="saldo_movimiento" suma="true" noZero="true">
        <label>Pendiente</label> 
		<tipo>numeric</tipo>
      </field>
      
      <!-- Funciones -->

      <field id="eliminacion" tdWidth="20" linkdir="/caja/proc/del/" local="true" print="false">
		<attribute id="linkint">xml_llamar</attribute>
	    <label>Detalle</label>
	    <if exp="xml_llamar.'' != ''">
  	  	  <true>'>>'</true>
  	  	  <false>''</false>
	    </if>
	    <paring destino="id_regmovimheader">id_regmovim</paring>
	  </field>
  
	  <field id="referencia_movimiento" noshow="true" />
    
      <field id="observaciones" local="true" tdWidth="50" print="false">
        <helper type="link" xml="regmovim_obs_qry.xml" dir="/proveedores/qry" width="600px" height="350px" title="Observaciones">
          <parameter source="id_regmovim" target="regmovim_id" operator="="/>
		  <parameter source="referencia_movimiento" target="obsmov" operator="="/>
        </helper>        
        <label>Obs</label>
		<valor>+</valor>
		<attribute id="style">tieneObs</attribute>
      </field>
    
      <field id="tieneObs" noshow="true">
  	    <expresion>SELECT 'color:red;font-weight:bold;' FROM REG_MOVIMIENTO_OBS WHERE REG_MOVIMIENTO_OBS.regmovim_id = REG_MOVIMIENTOS.id_regmovim</expresion>
  	  </field>
  	  
  	  <!-- Fin -->

	<order>
		<field id="fecha_movimiento" tabla="REG_MOVIMIENTOS" />
		<field id="imputacion_concepto"/>
	</order>

	<group>
		<field id="id_regmovim" tabla="REG_MOVIMIENTOS"/>
	</group>
    </table>
    
    <join tipo="left">
      <table id="REG_CUENTA">
        <field id="id_regcuenta">
          <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
        </field>
      </table>
    </join>
    <join>
      <table id="REG_CONCEPTOS">
        <field id="id_concepto">
          <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
        </field>
      </table>
    </join>
   <join tipo="left">
      <table id="CAJ_CONCEPTOS">
        <field id="regconcepto_id">
          <condicion operador="=">REG_CONCEPTOS.id_concepto</condicion>
        </field>
      </table>
    </join>
   <join tipo="left">
      <table id="REG_NUMERADORES">
        <field id="regconcepto_id">
          <condicion operador="=">REG_CONCEPTOS.id_concepto</condicion>
        </field>
      </table>
    </join>
    <join tipo="left">
      <table id="REG_IMPUTACIONES">
        <field id="regmovim_id">
          <condicion operador="=">REG_MOVIMIENTOS.id_regmovim</condicion> 
        </field>
      </table>
    </join>

  </form>
</histrix>
