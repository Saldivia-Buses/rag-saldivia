     <table id="REG_MOVIMIENTOS"  label="FACTURA">
      <field id="id_regmovim"  noshow="false" esClave="true" print="false">
        <label>Codigo</label>
        <help>Codigo de movimiento</help>
      </field>
<!--       <field id="letra_movimiento">
         <label modpos="nobr" PDFnolabel="true" posx="103" posy="8" PDFsize="20"></label>
      </field> -->
	<field id="muestra_iva" noshow="true" print="false">
		<expresion>case when letra_movimiento = 'A' or letra_movimiento = 'a'  then 'true' else 'false' end </expresion>
	</field>	
	<field id="sin_iva" noshow="true"  print="false">
		<expresion>case when letra_movimiento = 'A' or letra_movimiento = 'a'  then 'false' else 'true' end </expresion>
	</field>	
        
	<field id="subsistema_id" noshow="true" print="false">
					<label>Subsistema</label>
					<help>subsistema al que pertenece</help>
				      </field>
  <!--    <field id="id_regdetalle" tabla="REG_DETALLES" noshow="true">
      </field> -->
    <field id="concepto_id" noshow="true" print="false" />
      <field id="regcuenta_id" noshow="true" print="false">
        <label posx="5" posy="+1">Cuenta</label>
      </field>
      <field id="descripcion_concepto" tabla="REG_CONCEPTOS" PDFbold="true" >
			<label modpos="nobr"  posx="145" posY="5" PDFsize="12"></label>
      </field>

      <field id="nro_movimiento" oculto="true"/>

      <field id="fecha_movimiento">
        <label modpos="nobr"  posx="122" posY="22" PDFsize="10"></label>
        <help>Fecha movimiento</help>
      </field>
      <field id="NumeroMov" _print="false" PDFbold="true">
           <label modpos="nobr"  posx="160" posY="22" PDFsize="10"></label>
           <expresion>LPAD(nro_movimiento,8,'0')</expresion>
      </field>

      <field id="nro_Movimiento" PDFnoborder="true" PDFbold="true" >
           <label modpos="nobr"  posx="145" posY="22" PDFsize="10" _size="6" PDFnolabel="true">Nº</label>
           <expresion>CONCAT('Nº ',LPAD(puesto_movimiento,4,'0'),'-')</expresion> 
         </field>
<!--            <field id="cuit_empresa" local="true" PDFsize="8">
                <label posx="110" posY="40" ></label>
                <valor>C.U.I.T. Nº:EMPRESA</valor>
            </field>
	     <field id="ing_brutos" local="true" PDFsize="8">
                <label posx="110" posY="43" ></label>
                <valor>Ing.Brutos:</valor>
            </field>
            <field id="actividades" local="true" PDFsize="8">
                <label posx="110" posY="46" ></label>
                <valor>Inicio Act.:01/08/05</valor>
            </field> -->
    
           <field id="nombre_cuenta"  tabla="REG_CUENTA" deshabilitado="true" _sincelda="true" PDFbold="true">
        	<expression>(CASE WHEN REG_MOVIMIENTOS.nombre_movimiento != '' THEN REG_MOVIMIENTOS.nombre_movimiento ELSE REG_CUENTA.nombre_cuenta END)</expression>
                <label colspan="4"  posx="17" posY="+21" size="80"></label>                
            </field>
            
           <field id="nro_cuenta"  tabla="REG_CUENTA" deshabilitado="true"  PDFnoborder="true" _sincelda="true" style="text-align:right;">
                <label colspan="4"  posx="130" _posY="+0" size="20">Cuenta Nº</label>
            </field>
           <field id="id_regcuenta" noshow="true" print="false" tabla="REG_CUENTA" deshabilitado="true"  PDFnoborder="true" _sincelda="true" style="text-align:right;">
            </field>

            <field id="direccion" deshabilitado="true" _sincelda="true">
            	<expression>CONCAT(cod_direccion, ' ', IF(nro_direccion = 0, '', nro_direccion))</expression>
                <label colspan="0" posx="17" posY="+0.5" size="50"></label>
            </field>
            <field id="telefono" deshabilitado="true" PDFnoborder="true" _sincelda="true">
                <label colspan="0" posx="130" _posY="+0" size="20">Telefono</label>
		<expresion>SELECT valor FROM REG_CUENTAS_CONTACTOS 
			JOIN GEN_TIPO_CONTACTOS on ( GEN_TIPO_CONTACTOS.id_contacto = REG_CUENTAS_CONTACTOS.contacto_id  ) 
			where regcuenta_id = REG_MOVIMIENTOS.regcuenta_id and vcard_type like 'TEL%' LIMIT 1
		</expresion>
            </field>

	    <field id="localidad_id" tabla="REG_CUENTA" deshabilitado="true" _sincelda="true">
                <label colspan="4" posx="17" posY="+0.5" size="50"></label>
		<expresion>SELECT nombre_localidad FROM GEN_LOCALIDADES where id_localidad = REG_CUENTA.localidad_id limit 1</expresion>
            </field><!--
	    <field id="provincia_id" tabla="REG_CUENTA" deshabilitado="true" PDFsize="9" sincelda="true">
		<label colspan="4" posx="100" _posY="+0" size="50"></label>
		<expresion>concat('(' , (SELECT nombre_provincia FROM GEN_PROVINCIAS where id_provincia = REG_CUENTA.provincia_id),')')</expresion>
	    </field>-->
            <field id="fax" deshabilitado="true" PDFnoborder="true" _sincelda="true">
                <label colspan="0" posx="130" _posY="+0" size="20">Fax</label>
		<expresion>SELECT valor FROM REG_CUENTAS_CONTACTOS 
			JOIN GEN_TIPO_CONTACTOS on ( GEN_TIPO_CONTACTOS.id_contacto = REG_CUENTAS_CONTACTOS.contacto_id  ) 
			where regcuenta_id = REG_MOVIMIENTOS.regcuenta_id and vcard_type like '%FAX%' LIMIT 1
		</expresion>
            </field>
            
	    <field id="Entrega" tabla="REG_CUENTA" deshabilitado="true" PDFnoborder="true" _sincelda="true">
                <label  posx="17" posY="+1" size="20">Entrega:</label>
		<expresion>concat(entrega_direccion,' ',ifnull((SELECT nombre_localidad FROM GEN_LOCALIDADES where id_localidad = REG_CUENTA.entrega_localidad limit 1),''))</expresion>
            </field> 
            
            
	 <field id="iva_id" tabla="REG_CUENTA" >
		<tabla_ex xml="iva_qry.xml" dir="/ayudas" vacio="true">
		</tabla_ex>
		<label colspan="3" modpos="nobr" posx="20" posY="+6" ></label>
	</field>
	<field id="cuit_cuenta" tabla="REG_CUENTA" deshabilitado="true" sincelda="true" >
            <label colspan="3" modpos="nobr" posx="126" _posY="101" size="30"></label>
            <expression>(CASE WHEN REG_MOVIMIENTOS.cuit_movimiento != '' THEN REG_MOVIMIENTOS.cuit_movimiento ELSE REG_CUENTA.cuit_cuenta END)</expression>
        </field>

	<field id="regforma_id" >
		<helper type="combo" id="REG_FORMAS" >
			<field id="id_regforma"/>
			<field id="nombre_forma"/>
		</helper>
		<label colspan="3" modpos="nobr" posx="45" posY="+0.5" ></label>
	</field>

	<field id="factura" local="true" sincelda="true" PDFnolabel="true" >
		<expresion>SELECT mrem.nro_movimiento FROM REG_DETALLES 
		LEFT JOIN REG_IMPUTACIONESDETALLES rimp ON REG_DETALLES.id_regdetalle = rimp.regdetallefac_id 
		LEFT JOIN REG_DETALLES dfac ON rimp.regdetalleped_id = dfac.id_regdetalle
		LEFT JOIN REG_MOVIMIENTOS mrem ON dfac.regmovim_id = mrem.id_regmovim
		WHERE REG_DETALLES.regmovim_id = REG_MOVIMIENTOS.id_regmovim and mrem.concepto_id = 47
		GROUP BY mrem.nro_movimiento limit 1
		/*rm.nro_movimiento = REG_MOVIMIENTOS.nro_movimiento and rm.concepto_id = (SELECT option_value FROM `HTXOPTIONS` where option_name = 'ID_NOITASPEDIDOS')*/
		</expresion>
		<label posx="130" posy="0">Factura</label>
	</field>

	<field id="pedido" local="true" PDFnolabel="true" >
		<expresion>SELECT mnp.nro_movimiento FROM REG_DETALLES 
		LEFT JOIN REG_IMPUTACIONESDETALLES rimp ON REG_DETALLES.id_regdetalle = rimp.regdetallefac_id 
		LEFT JOIN REG_DETALLES dfac ON rimp.regdetalleped_id = dfac.id_regdetalle
		LEFT JOIN REG_MOVIMIENTOS mnp ON dfac.regmovim_id = mnp.id_regmovim
		WHERE REG_DETALLES.regmovim_id = REG_MOVIMIENTOS.id_regmovim and mnp.concepto_id = (SELECT option_value FROM `HTXOPTIONS` where option_name = 'ID_NOTA_PEDIDOS')
		GROUP BY mnp.nro_movimiento limit 1
		</expresion>
		<label posx="160" posy="0">Pedido</label>
	</field>
<!--	<field id="vencimiento_movimiento">
        <label  colspan="3" modpos="nobr" posx="135" posY="101" size="35">Vencimiento</label>
        <help>Fecha vencimiento</help>
      </field> -->
         <field id="detalles" local="true" pdfwidth="185">
              <label  PDFnolabel="true" PDFlineas="false" size="25" posx="15" posy="+10" ></label>
			  <helper xml="imp_factura_detalleinsumas_qry.xml" type="object" dir="/clientes/qry">
					<parameter source="id_regmovim" target="regmovim_id"/>
					<parameter source="subsistema_id" target="subsistema_id"/>
					<parameter source="muestra_iva" target="muestra_iva"/>
			  </helper>
         </field>
            <field id="transporte" PDFnoborder="true" PDFnolabel="true">
                <label  posx="10" posy="+4">Transporte</label>
                <expresion>select concat(nombre_cuenta,' ' , apellido_cuenta)  from REG_CUENTA pp where pp.id_regcuenta = REG_MOVIMIENTOS.regcuentatransporte_id LIMIT 1</expresion>
            </field>
         
	<field id="referencia_movimiento"  pdfwidth="185" PDFnoborder="true">
	    <label posx="10" posy="+4">Obs:</label>
	    
	</field>
	

	<field id="SubTotal0" _local="true" _total="true" PDFnoborder="true">
		<label modpos="nobr"	posx="120" posY="250"   size="22" PDFsize="9" pdfancho="55">Sub Total </label>
		<attribute id="print">sin_iva</attribute>		

		<expresion>importe_movimiento</expresion>
		<tipo>numeric</tipo>
	</field>

        <field id="regcuentavendedor_id" PDFnoborder="true">                                 
    		<expression>CASE WHEN REG_MOVIMIENTOS.regcuentavendedor_id != 0 THEN REG_MOVIMIENTOS.regcuentavendedor_id
    		ELSE
		(SELECT regcuentarelacionada_id FROM REG_CUENTA_RELACIONES 
		WHERE regcuenta_id = REG_MOVIMIENTOS.regcuenta_id and subsistemarelacionada_id = '22' LIMIT 1)
		END
    		</expression>
                <label posx="120" posY="240" >Vendedor</label>
                <helper type="combo" xml="regcuenta_simple2_mos_qry.xml" dir="/ayudas" empty="true">
                    <field id="id_regcuenta" />
                    <field id="baja_cuenta">
                        <condicion operador="=">'0000-00-00'</condicion>
                    </field>
                    <field id="SubSistema_id" >
                        <expresion>subsistema_id</expresion>
                        <condicion operador="=">'22'</condicion>
                    </field>
                </helper>
        </field>

	<field id="SubTotal" _local="true" _total="true" PDFnoborder="true">
		<label modpos="nobr"	posx="120" posY="250"   size="22" PDFsize="9" pdfancho="55">Sub Total</label>
		<attribute id="print">muestra_iva</attribute>		

		<expresion>SUM(REG_DETALLES.neto_detalle)</expresion>
		<tipo>numeric</tipo>
	</field>



	<field id="Saldo" PDFnoborder="true">
		<label size="45" posx="20" posy="250" >Su saldo actual es de $</label>
		<expresion>Select  sum(importe_movimiento * (case when imputacion_concepto = 0 then 1 else -1 end) ) from REG_MOVIMIENTOS  as Pend
				JOIN REG_CONCEPTOS  c1 ON c1.id_concepto = Pend.concepto_id
				where  
				Pend.subsistema_id = REG_CUENTA.subsistema_id and c1.informa_calculo = 0
				and Pend.regcuenta_id = REG_CUENTA.id_regcuenta</expresion>
		  		<!--	<formato>%01.2f</formato>-->

	</field>

      <field id="dolar"  _PDFnolabel="true" PDFnoborder="true">
		<label size="22" posx="20" posy="+1" >Cotizacion</label>
		<expresion>select concat(descripcion_moneda,' ' , cotizacion_genmonedahis) from GEN_MONEDAS left join GEN_MONEDA_HIS on id_moneda = moneda_id  where id_moneda = 2 and REG_MOVIMIENTOS.fecha_movimiento &gt;= fecha_genmonedahis order by fecha_genmonedahis DESC limit 1</expresion>
      </field>
      
      <field id="digo" local="true" _PDFnolabel="true" PDFnoborder="true">
		<label posx="20" posY="+0.5">Son Pesos:  </label>
	<!--	<valor>Digo Importe en Letras:</valor>-->
      </field>
      <field id="prueba" local="true" PDFnolabel="true">
        <label posx="38" posY="0" pdfancho="57"/>
        <tipo aletras="true">char</tipo>
        <expresion>importe_movimiento</expresion>
      </field>


	<field id="Neto_Movimiento" local="true" noshow="true" print="false">
		<expresion>neto_movimiento</expresion>
	</field>

	<field id="Bonificaciones_movimiento" local ="true" PDFnoborder="true">
		<label modpos="nobr"	posx="120" posY="258" size="22" PDFsize="9" >Descuento</label>
		<if exp="true">
			<true>SubTotal + 0 - neto_movimiento + 0 </true>
			<false>0</false>
		</if>
		<tipo>numeric</tipo>
	</field>

	<field id="neto_movimiento" PDFnoborder="true">
		<label posx="120" posY="263" size="22" pdfancho="55" PDFsize="9">Neto Gravado</label>
		<tipo>numeric</tipo>
		<attribute id="print">muestra_iva</attribute>		

	</field>
		
	<field id="total_iva" PDFnoborder="true">
		<label modpos="nobr"	posx="120" posY="268" size="22" pdfancho="55" PDFsize="9">I.V.A.</label>
		<attribute id="print">muestra_iva</attribute>		
		<expresion>SUM(REG_DETALLES.iva_detalle)</expresion>
		<tipo>numeric</tipo>
	</field>
	<field id="importe_movimiento" PDFnoborder="true" PDFbold="true">
		<label modpos="nobr"	posx="120" posY="273,5" PDFsize="10" size="22" pdfancho="55">TOTAL</label>
	</field>
	<field id="cajmovimiento_id" noshow="true" print="false"/> NECESARIO PARA IMPRIMIR DESDE CAJA


	<group>
		<field id="id_regmovim"/>
	</group>

	
      
		    </table>
		<join tipo="left">
			<table id="REG_CONCEPTOS">
			    <field id="id_concepto">
				<condicion operador="=">concepto_id</condicion>
			    </field>
			</table>
		</join>
		<join tipo="left">
			<table id="REG_CUENTA">
				<field id="id_regcuenta">
					<condicion operador="=">regcuenta_id</condicion>
				</field>
			</table>
		</join> 
		<join tipo="left">
			<table id="REG_DETALLES">
				<field id="regmovim_id">
					<condicion operador="=">id_regmovim</condicion>
				</field>
			</table>
		</join> 

  </form>
</histrix>  
