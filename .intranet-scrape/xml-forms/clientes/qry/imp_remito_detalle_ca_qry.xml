<?xml version="1.0" encoding="UTF-8" ?>
    <histrix tipo="consulta" exportasuma="true" PDFlineColor="255,255,255" _PDFfont="Courier">
	<title>Detalles</title>
	 <obs></obs>
		<form >
		    <table id="REG_DETALLES" label="Detalle de Movimientos" styleTbody="height:150px;overflow-x:hidden;" PDFnoborder="true" >

			<field id="regmovim_id" noshow="true" PDFlineas="false"/>

			<field id="orden" noshow="true" PDFlineas="false"/>

			<field id="codigo_detalle" PDFsize="9"  PDFnoborder="true" PDFcolWidth="20">
		        <label size="30">Código</label>
			</field>
			<field id="cantidad_detalle" PDFsize="9" PDFlineas="false" PDFcolWidth="20">
		        <label modpos="nobr" size="20">Cant.</label>
			    <tipo>numeric</tipo>
			</field>			
			<field id="descripcion_detalle" _PDFsize="9" PDFlineas="false">
		        <label modpos="nobr" _size="80">Descripción</label>
		        <expresion><![CDATA[

		        CONCAT( descripcion_detalle, 
		         IFNULL( (SELECT GROUP_CONCAT( CONCAT('<br>*', RPAD(descripcion_detallecmb, 39,' '), ' x ', cantidad_detallecmb) SEPARATOR '' )
		           FROM REG_DETALLE_COMBOS 
		          WHERE REG_DETALLE_COMBOS.regdetalle_id = REG_DETALLES.id_regdetalle
		            AND REG_DETALLE_COMBOS.cantidad_detallecmb != 0), '') 
		          )
		        ]]></expresion>
		  	     <tipo>simpleditor</tipo> 
			</field>

			<order>
			    <field id="orden"/>
			</order>
			<group>
			  <field id="id_regdetalle" />
			</group>
		    </table>
		</form>
    </histrix>	

