			<expresion>1</expresion>
			<condicion operador="=">1 and ((REG_IMPUTACIONESDETALLES.regdetallefac_id = REG_DETALLES.id_regdetalle and REG_MOVIMIENTOS.concepto_id = (select option_value from HTXOPTIONS where option_name = 'ID_FACTURAS')) or (REG_IMPUTACIONESDETALLES.regdetalleped_id = REG_DETALLES.id_regdetalle and REG_MOVIMIENTOS.concepto_id in (select option_value from HTXOPTIONS where option_name in ('ID_NOTA_PEDIDOS', 'ID_REMITOS'))))</condicion>
             </field>
            </table>
