<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta">
  <title>Movimientos</title>
  <obs/>
  <pie>Resumen de cuenta [__nombre_cuenta__] - Desde: [__desde__] / Hasta: [__hasta__]</pie>
        
  <form detalle="regimputaciones_qry.xml" inline="true" hasDetail="imputacion_concepto">
        
    <table id="REG_MOVIMIENTOS" label="Resumen de Cuenta">
        
      <preconsultas>
        <xmlfile id="regdetalles_pre.xml"/>
      </preconsultas>
        
      <fieldGroup id="entorno" noshow="true">
        <field id="subsistema_id" valauto="true">
          <preparam operador="=">true</preparam>
          <tipo>varchar</tipo>
        </field>
        <field id="tipo" valauto="true" local="true"/>
        <field id="regcuenta_id" valauto="true">
          <preparam operador="=">true</preparam>
        </field>
        <field id="desde" _valauto="true" local="true">
          <preparam campo="fecha_movimiento" operador="&lt;=">true</preparam>
          <tipo>date</tipo>
        </field>
        <field id="hasta" valauto="true" local="true">
          <tipo>date</tipo>
        </field>
        <field id="arrastrasaldo" local="true">
          <preparam operador="=">true</preparam>
        </field>
        <field id="omitirpend" local="true" noshow="true">
          <tipo>check</tipo>
          <valor>1</valor>
        </field>
      <field id="filtro" noshow="true">
          <expression>
            (case when [__omitirpend__] = 1 AND (REG_MOVIMIENTOS.saldo_movimiento) = 0 THEN 0 ELSE 1 END)
          </expression>
          <condicion operador="=">1</condicion>
        </field>
      </fieldGroup>
        <fieldGroup>
      <field id="id_regmovim" noshow="true">
        <detalle>regmovim_id</detalle>
      </field>
        
      <field id="nombre_cuenta" noshow="true">
        <label>Cuenta</label>
        <expression>REG_CUENTA.nombre_cuenta</expression>
      </field>
        
      <field id="titulo_impr" noshow="true">
			<expression>CONCAT('Resumen de cuenta: ',REG_CUENTA.nombre_cuenta)</expression>
			<setvar>titulo_div</setvar>
      </field>

      <field id="cajmovimiento_id" noshow="true"/>

      <field id="xml_llamar" local="true" noshow="true">
        <if exp="cajmovimiento_id + 0 != 0">
          <true>'cajmovimiento_ficha.xml'</true>
          <false>'regmovimiento_ficha.xml'</false>
        </if>
      </field>
   <!--<field id="imprime_concepto1" noshow="true">
        <expression>
          CASE WHEN IFNULL(REG_NUMERADORES.ejecuta,'') = '' THEN trim(CAJ_CONCEPTOS.imprime_concepto) ELSE trim(REG_NUMERADORES.ejecuta) END
        </expression>
      </field>-->
      <field id="imprime_concepto1" noshow="true">
        <expression>
          CASE WHEN IFNULL(REG_NUMERADORES.ejecuta,'') = '' THEN trim(CAJ_CONCEPTOS.imprime_concepto) ELSE trim(REG_NUMERADORES.ejecuta) END
        </expression>
      </field>
        
          
        
       <!--<field id="nro_movimiento" tdWidth="150" linkdes="Detalle del Comprobante" linkmodal="true" style="text-align: center">
        <label>Numero</label>
        <expression>
          CONCAT(REG_MOVIMIENTOS.letra_movimiento,' ',LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,'0'),'-',LPAD(REG_MOVIMIENTOS.nro_movimiento ,8,'0'))
        </expression>
        <helper type="link" _dir="/caja/qry">
          <parameter source="id_regmovim" target="id_regmovim"/>
        </helper>
        <attribute id="linkint">imprime_concepto1</attribute>
      </field>-->


      <field id="concepto_id" noshow="true">
        <helper type="combo" xml="regconcepto_qry.xml" dir="/ayudas" empty="true" />
      </field>

      <field id="fecha_movimiento">
        <label>Fec.Mov.</label>
        <help>Fecha movimiento</help>
        <condicion operador="BETWEEN">IF('[__desde__]' = '', '0000-00-00', STR_TO_DATE('[__desde__]','%d/%m/%Y'))
    AND  IF('[__hasta__]' = '', '9999-99-99', STR_TO_DATE('[__hasta__]','%d/%m/%Y'))
        </condicion>
        <tipo>date</tipo>
      </field>

 <field id="abreviacion_concepto" tabla="REG_CONCEPTOS">
        <label>Comp</label>
      </field>


      <field id="nro_movimiento" linkdes="Detalle del Comprobante" linkmodal="true" style="text-align:center;width:12em;">
        <label>Numero</label>
        <expression>
          CONCAT(REG_MOVIMIENTOS.letra_movimiento,' ',LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,'0'),'-',LPAD(REG_MOVIMIENTOS.nro_movimiento ,8,'0'))
        </expression>
        <helper type="link" _dir="/caja/qry">
          <parameter source="id_regmovim" target="id_regmovim"/>
        </helper>
        <attribute id="linkint">imprime_concepto1</attribute>
      </field>

      <!-- Cambiar de Acuerdo a como se quiere visualizar las imputaciones de CtaCte -->
      <field id="imputacion_concepto" noshow="true">
        <expression>
          CASE WHEN REG_CONCEPTOS.imputacion_concepto = 1 THEN 1 ELSE 0 END
        </expression>
      </field>

      <!-- Importes -->

  <field id="oculta_edc" local="true" noshow="true">
          <helper type="parameter" id="SIS::02::oculta_edc">
            <label>Oculta la columna EDC en Consulta de movimientos de clientes</label>
            <defaultValue>true</defaultValue>
          </helper>
      </field>
          
      <field id="saldo_referencia" noshow="true" local="true">
        <attribute id="noshow">oculta_edc</attribute>
        <label>EDC</label>........
        <expression>
          case when REG_MOVIMIENTOS.saldo_movimiento = 0 then 'CAN' else 'PEN' end
        </expression>
      </field>
        
      <field id="debe" suma="true" noZero="true">
        <label>debe</label>
        <expression>
          (case when REG_CONCEPTOS.imputacion_concepto = 0 then REG_MOVIMIENTOS.importe_movimiento else 0  end)
        </expression>
        <tipo>numeric</tipo>
      </field>

      <field id="haber" suma="true" noZero="true">
        <label>haber</label>
        <expression>
          (case when REG_CONCEPTOS.imputacion_concepto = 1 then REG_MOVIMIENTOS.importe_movimiento else 0 end)
        </expression>
        <tipo>numeric</tipo>
      </field>

      <field id="acumulado" suma="true" acumula="true" _local="true" print="false">
        <label>Acumulado</label>
        <expression>(case when REG_CONCEPTOS.imputacion_concepto = 0 then REG_MOVIMIENTOS.importe_movimiento else 0  end) -
 (case when REG_CONCEPTOS.imputacion_concepto = 1 then REG_MOVIMIENTOS.importe_movimiento else 0 end)</expression>
        <tipo>numeric</tipo>
      </field>

  <field id="saldo_movimiento" suma="true" noZero="true" >
        <label>Pendiente</label>
        <tipo>numeric</tipo>
      </field>
<!-- Este campo muestra el saldo que debería tener un comprobante teniendo en cuenta sus imputaciones -->
<!--
      <field id="imputado_t" noZero="true">
        <label>Imputado</label>
        <expression>(REG_MOVIMIENTOS.importe_movimiento - IFNULL((CASE WHEN REG_CONCEPTOS.imputacion_concepto = 0 THEN.
(SELECT SUM(movimiento_imputacion) FROM REG_IMPUTACIONES WHERE regmovim0_id = REG_MOVIMIENTOS.id_regmovim).
ELSE (SELECT SUM(movimiento_imputacion) FROM REG_IMPUTACIONES WHERE regmovim_id = REG_MOVIMIENTOS.id_regmovim) END), 0)) * (case when.
REG_CONCEPTOS.imputacion_concepto = 0 then 1 else -1 end)</expression>
        <tipo>numeric</tipo>
      </field>
-->

      <!-- Funciones -->

      <field id="eliminacion" linkdir="/caja/proc/del/" local="true" print="false" linkdes="Detalle del Comprobante"
style="text-align:center;width:4em;">
        <attribute id="linkint">xml_llamar</attribute>
        <label>Detalle</label>
        <if exp="'xml_llamar' != ''">
          <true>'&gt;&gt;'</true>
          <false>''</false>
        </if>
        <paring destino="id_regmovimheader">id_regmovim</paring>
        <paring destino="id_regmovim">id_regmovim</paring>
        <paring destino="id_cajmovmiento">cajmovimiento_id</paring>
      </field>
        
      <field id="referencia_movimiento" noshow="true"/>
        
   <field id="observaciones" local="true" print="false" style="text-align:center;width:4em;">
        <helper type="link" xml="regmovim_obs_qry.xml" dir="/proveedores/qry" width="600px" height="350px" title="Observaciones">
          <parameter source="id_regmovim" target="regmovim_id" operator="="/>
          <parameter source="referencia_movimiento" target="obsmov" operator="="/>
        </helper>
        <label>Obs</label>
        <valor>+</valor>
        <attribute id="style">tieneObs</attribute>
      </field>


       <field id="tieneObs" noshow="true">
          <expression>
          IFNULL((SELECT 'color:red;font-weight:bold;text-align:center;width:4em;'
FROM REG_MOVIMIENTO_OBS WHERE REG_MOVIMIENTO_OBS.regmovim_id = REG_MOVIMIENTOS.id_regmovim limit 1), 'text-align:center;width:4em;')
          </expression>
   </field>
      </fieldGroup>

      <fieldGroup>
        <if> if ($_SESSION['EDITOR'] == 'editor') return true; </if>
      <field id="modificacion" local="true" print="false" style="text-align:center;width:4em;">
            <helper type="link" xml="regmovimiento_crud2.xml" dir="/clientes/ing" width="600px" height="350px" title="Modificar Comprobante">
    <parameter source="id_regmovim" target="id_regmovim" />
     </helper>
        <label>Mod</label>
			<valor>Mod</valor>
      </field>
      </fieldGroup>

      <field id="color" local="true" clasefila="true" oculto="true"></field>
      <!-- Fin -->

   <order>
        <field id="fecha_movimiento" table="REG_MOVIMIENTOS"/>
        <field id="imputacion_concepto"/>
        <field id="nro_movimiento" table="REG_MOVIMIENTOS"/>
      </order>
        
      <group>
        <field id="id_regmovim" tabla="REG_MOVIMIENTOS"/>
      </group>

      <filters auto="true">
        <field id="concepto_id">
          <label>Concepto</label>
          <operador>=</operador>
        </field>
        <field id="omitirpend" print="false">
          <label>Omitir S/Pendiente</label>
          <operador>=</operador>
          <valor>1</valor>
        </field>
      </filters>
    </table>
      
    <join tipo="left">
      <table id="REG_CUENTA">
        <field id="id_regcuenta">
          <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
        </field>
      </table>
    </join>
    <join>
    <table id="REG_CONCEPTOS">
        <field id="id_concepto">
          <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
        </field>
        <field id="informa_calculo">
          <condicion operador="=">0</condicion>
        </field>
      </table>
    </join>

    <join tipo="left">
      <table id="CAJ_MOVIMIENTOS">
        <field id="id_cajmovimiento">
          <condicion operador="=">REG_MOVIMIENTOS.cajmovimiento_id</condicion>
        </field>
      </table>
    </join>

    <join tipo="left">
      <table id="CAJ_CONCEPTOS">
        <field id="id_cajconcepto">
          <condicion operador="=">CAJ_MOVIMIENTOS.cajconcepto_id</condicion>
        </field>
      </table>
    </join>
<join tipo="left">
      <table id="REG_NUMERADORES">
        <field id="subsistema_id">
          <condicion operador="=">REG_MOVIMIENTOS.subsistema_id</condicion>
        </field>
        <field id="regconcepto_id">
          <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
        </field>
        <field id="puesto">
          <condicion operador="=">REG_MOVIMIENTOS.puesto_movimiento</condicion>
        </field>
        <field id="letra">
          <condicion operador="=">REG_MOVIMIENTOS.letra_movimiento</condicion>
        </field>
      </table>
    </join>
  </form>
</histrix>
