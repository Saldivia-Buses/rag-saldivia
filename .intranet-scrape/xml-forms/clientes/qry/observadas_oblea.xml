<?xml version="1.0"?>
<histrix tipo="grid" borra="false" inserta="false" deleteRow="false" _log="true" editable="true" process="true">

  <title>Planilla de Pendientes</title>
  <obs/>

   <form>
    <table id="REG_MOVIMIENTOS" label="Planilla de Pendientes">

      <filters>       
        <field id="fecha_movimiento">
          <label>Hasta Fecha</label>
          <operador>&lt;=</operador>
          <valor>today</valor>
        </field>

        <field id="tabla_detalle"  _tdWidth="5%">
          <label>Dominio</label>
          <operador>like</operador>
        </field>
      </filters>    
     
      <movimientos>          
            <relacion id="pos_regdetalles_oblea_upd.xml"/>   actualizo los datos del regdetalle (oblea, patente, fecha)
            <relacion id="regmovimientos_rec_upd.xml"/>      actualizo en recibo c en la cuenta corriente del cliente
            <relacion id="regmovimientos_rec_upd_prov.xml"/> actualizo el recibo en la cuenta de proveedores  
      </movimientos>       

    <field id="id_regmovim"   esClave="truye"               noshow="true" desabilitado="true"/>
    <field id="subsistema_id" local="true"                  noshow="true"/> 
    <field id="regcuenta_id"                                noshow="true" desabilitado="true"/>
    <field id="id_regdetalle" tabla="REG_DETALLES"          noshow="true" desabilitado="true"/> 

    <field id="concepto_id" noshow="true" desabilitado="true"> 
      <condicion operador="=">(SELECT HTXOPTIONS.option_value FROM HTXOPTIONS WHERE HTXOPTIONS.option_name = "SIS::02::concepto_recibo_vend")</condicion>
    </field>

    <field id="letra_movimiento" noshow="true" desabilitado="true"> 
      <condicion operador="=">'X'</condicion>
    </field>  

    <field id="nro_movimiento" _tdWidth="150" linkdes="Detalle del Comprobante" linkmodal="true" 
      style="text-align: center" deshabilitado="true" Formstyle="display:none;">
        <label>Comprobante</label>
        <expression>CONCAT(RM1.letra_movimiento,' ',LPAD(RM1.puesto_movimiento,4,'0'),'-',LPAD(RM1.nro_movimiento  ,8,'0'))
        </expression>
      <size>13</size> 
    </field>      
    
    <field id="descripcion_detalle" tabla="REG_DETALLES" deshabilitado="true" Formstyle="display:none;">
        <label>Detalle</label>
        <tipo>varchar</tipo>
        <size>15</size> 
    </field>

    <field id="tabla_detalle" tabla="REG_DETALLES" deshabilitado="true" >
        <label>Dominio</label>
        <tipo>varchar</tipo>
        <size>7</size>         
    </field>

    <field id="codigo_serie" tabla="REG_DETALLES" editable="true" >
         <label>Oblea</label>
         <tipo>varchar</tipo>         
         <size>15</size> 
    </field>
    
    <field id="fecha_movimiento" tabla="RM1" deshabilitado="true">      
      <label>Fec.Emision</label>  
      <tipo>date</tipo>
      <size>10</size>       
    </field>
    
    <field id="fecha_vencimiento" tabla="REG_DETALLES" _noshow="true" deshabilitado="false" editable="true">   
      <label>Fec.Vto.</label>    
      <!-- <tipo>date</tipo> -->
      <size>10</size>             
    </field>  

     <field id="nro_recibo" _tdWidth="150" linkdes="Detalle del Comprobante" linkmodal="true" 
      style="text-align: center" deshabilitado="true" Formstyle="display:none;">
        <label>Rec. Cond.</label>
        <expression>CONCAT(REG_MOVIMIENTOS.letra_movimiento,' ',LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,'0'),'-',LPAD(REG_MOVIMIENTOS.nro_movimiento  ,8,'0'))</expression>
      <size>13</size> 
    </field>  
    
    <field id="letra_mov" local="true" _editable="true">
        <label>Rec. Final</label>
        <valor>'C'</valor>
        <size>2</size>                       
    </field>     
         
    <field id="puesto_mov" local="true" editable="true">
        <label>Puesto</label>
        <size>2</size>   
        <jseval campodestino="graba_recibo">(numero_movimiento + 0 != 0 &amp;&amp; puesto_mov + 0 != 0 ) ? 1 : 0</jseval>
    </field> 

    <field id="numero_movimiento"          local="true" editable="true">
      <label>Numero</label>
      <size>8</size>             
      <jseval campodestino="graba_recibo">(numero_movimiento + 0 != 0 &amp;&amp; puesto_mov + 0 != 0 ) ? 1 : 0</jseval>
    </field> 
<!--
    <field id="id_regmovim_prov"  local="true" noshow="true">
      <expression>(SELECT RM2.id_regmovim FROM REG_MOVIMIENTOS RM2 
                  WHERE RM2.subsistema_id = '01' 
                        AND RM2.letra_movimiento = REG_MOVIMIENTOS.letra_movimiento
                        AND RM2.puesto_movimiento = REG_MOVIMIENTOS.puesto_movimiento 
                        AND RM2.nro_movimiento = REG_MOVIMIENTOS.nro_movimiento )
      </expression>
    </field>
 -->
    <field id="validacion"    local="true"  noshow="true" colstyle="display:none;">
      <valor>1</valor>
    </field>

    <field id="graba_recibo"  local="true" noshow="true" editable="true" colstyle="display:none;">
      <label>graba</label>
      <size>1</size>
    </field>

    <order>
        <field id="fecha_movimiento" tipoOrden="DESC"/>
        <field id="nro_movimiento"   tipoOrden="DESC"/>
    </order>
  </table>
  <join>
      <table id="REG_IMPUTACIONES" as="RI">
	<field id="regmovim0_id">
	    <condicion operador="=">REG_MOVIMIENTOS.id_regmovim</condicion>
	</field>
      </table>
  </join>

  <join>
      <table id="REG_IMPUTACIONES" as="RI2">
	<field id="regmovim_id">
	    <condicion operador="=">RI.regmovim_id</condicion>
	</field>
        <field id="regmovim0_id">
          <condicion operador="!=">REG_MOVIMIENTOS.id_regmovim</condicion>
        </field>
      </table>
  </join>


  <join>
      <table id="REG_MOVIMIENTOS" as="RM1">
        <field id="id_regmovim">
          <condicion operador="=">RI2.regmovim0_id</condicion>
	</field>
        <field id="subsistema_id">
          <condicion operador="=">'02'</condicion>
        </field>      
      </table>
  </join><!--
  <join>
      <table id="REG_MOVIMIENTOS" as="RM1">
        <field id="id_regmovim">
          <condicion operador="=">(SELECT RI2.regmovim0_id FROM REG_IMPUTACIONES RI2 WHERE 
                          RI2.regmovim_id = (SELECT RI.regmovim_id FROM REG_IMPUTACIONES RI 
                          WHERE RI.regmovim0_id = REG_MOVIMIENTOS.id_regmovim LIMIT 1 ) AND RI2.regmovim0_id != REG_MOVIMIENTOS.id_regmovim LIMIT 1 )</condicion>
        </field>
        <field id="subsistema_id">
          <condicion operador="=">'02'</condicion>
        </field>      
      </table>
  </join>-->

  <join tipo="left">
      <table id="REG_DETALLES">
        <field id="regmovim_id">
          <condicion operador="=">RM1.id_regmovim</condicion>
        </field>              
      </table>
  </join>

  <join>
    <table id="CAJ_CTBCUENTA_AUX" >
        <field id="codigo">
          <condicion operador="=">REG_DETALLES.codigo_detalle</condicion>
        </field>
        <field id="con_dominio">
          <condicion operador="=">'01'</condicion>
        </field>      
      </table>
    </join>    

    <join>
      <table id="REG_CUENTA">
        <field id="id_regcuenta">
          <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
        </field>
      </table>
    </join>
  </form>
</histrix>
