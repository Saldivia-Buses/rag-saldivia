<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="consulta" limit="5">
  <title>Movimientos</title>
  <obs/>

  <form>

    <table id="REG_MOVIMIENTOS" label="Resumen de Cuenta">

      <field id="id_regmovim2" noshow="true" tipoOrden="DESC">
	<expression>id_regmovim</expression>
      </field>

      <field id="regcuenta_id" valauto="true" print="false"/>

      <field id="fecha_movimiento">
        <label>Fec.Mov.</label>
        <help>Fecha movimiento</help>
        <tipo>date</tipo>
      </field>

      <field id="nro_movimiento">
        <label>Numero</label>
        <expression>
          CONCAT(REG_CONCEPTOS.abreviacion_concepto, ' ', REG_MOVIMIENTOS.letra_movimiento,' ',LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,'0'),'-',LPAD(REG_MOVIMIENTOS.nro_movimiento  ,8,'0'))
        </expression>
      </field>

      <field id="importe_movimiento" noZero="true">
        <label>Importe</label>
        <tipo>numeric</tipo>
      </field>

      <field id="saldo_movimiento" noZero="true" >
        <label>Saldo</label>
        <tipo>numeric</tipo>
      </field>


      <order>
        <field id="id_regmovim2"/>
      </order>

    </table>

    <join>
      <table id="REG_CONCEPTOS">
        <field id="id_concepto">
          <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
        </field>
        <field id="informa_calculo">
          <condicion operador="=">0</condicion>
        </field>
      </table>
    </join>
  </form>
</histrix>