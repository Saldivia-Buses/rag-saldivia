        <label posx="5" posy="+2">Direccion</label>
        <expression>concat('......................................................................................................................................') </expression>
    </field>
    <field id="banc_cta" local="true">
        <label posx="5" posy="+2">Nº de Cuenta</label>
        <expression>concat('..................................................................................................................................') </expression>
    </field>

    <field id="firma" local="true">
        <label posx="5" posy="+20">Firma</label>
        <expression>concat('........................................................................................') </expression>
    </field>
    <field id="fir_cli" local="true">
        <label posx="50" posy="0">Firma y sello del Cliente</label>
        <expression>concat('..........................................................') </expression>
    </field>
    <field id="Aclaracion" local="true">
        <label posx="130" posy="0">Aclaracion de Firma</label>
        <expression>concat('.................................................................') </expression>
    </field>
-->
    <field id="uso_vendedor" local="true">
        <label posx="5" posy="+10" size="190" pdffill="192" PDFsize="12">Para uso exclusivo del vendedor</label>
    </field>
    <field id="ref_cuenta">
        <label posx="5" posy="+5" pdfancho="190">Opinión</label>
        <!--
        <label>Ventas mensuales Promedio del cliente:....................................................................................................
        Proyeccion de ventas mensuales promedio del cliente:................................................................................
        Credito Solicitado......................................................................................................................................
        </label>
        -->
        
   </field>
   <field id="fir_vendedor" local="true">
        <label posx="5" posy="+20">Fecha y Lugar:.........................................................                   Firma del Vendedor:........................
        </label>      
    </field>
     <field id="uso_credito" local="true">
        <label posx="5" posy="+5" size="190" pdffill="192" PDFsize="12">Para uso exclusivo de Creditos y Cobranzas</label>
    </field>
    <!--
    <field id="texto2" local="true">
        <label posx="5" posy="+5">Opinión u Observaciones: ........................................................................................................................
        ...............................................................................................................................................................
        ...............................................................................................................................................................
        ...............................................................................................................................................................
        ...............................................................................................................................................................
        ...............................................................................................................................................................
        ...............................................................................................................................................................
        ...............................................................................................................................................................
        Fecha de recepción ...................................................           Credito otorgado...................................................
        </label>
   </field >
   -->
   <field id="fir_Credito" local="true">
        <label posx="5" posy="+20">Fecha.........................Firma del Responsable.......................... Pasado a Sistema:......................................
        </label>      
    </field>
    
    
      </table>
    
    <join tipo="left">
        <table id="GEN_LOCALIDADES">
        <field id="id_localidad">
        <condicion operador="=">REG_CUENTA.localidad_id</condicion>
        </field>
        </table>
    </join>
     <join tipo="left">
        <table id="GEN_PROVINCIAS">
        <field id="id_provincia">
        <condicion operador="=">GEN_LOCALIDADES.provincia_id</condicion>
        </field>
        </table>
    </join>    
     <join tipo="left">
        <table id="GEN_AFIP_ACTIVIDADES">
        <field id="id_afipactividad">
        <condicion operador="=">REG_CUENTA.afipcategoria_id</condicion>
        </field>
        </table>
    </join>    
  </form>
</histrix>  
