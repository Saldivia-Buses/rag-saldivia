<?xml version="1.0"?>
<histrix tipo="consulta">
  <title>Planilla de Pendientes</title>
  <obs/>
  <form>
    <table id="REG_MOVIMIENTOS" label="Planilla de Pendientes">


      <filters>
          
          <field id="fecha_movimiento">
            <label>Desde Fecha</label>
            <operador>&gt;=</operador>
          </field>
          
      	<field id="separador" deshabilitado="true" editable="false" modpos="nobr"/>

          <field id="fecha_movimiento" modpos="nobr">
            <label >Hasta Fecha</label>
            <operador>&lt;=</operador>
            <valor>today</valor>
          </field>

        <field id="separador" deshabilitado="true" editable="false" modpos="nobr"/>

          <field id="nro_cuenta" modpos="nobr">
            <label>Cuenta</label>
            <operador>=</operador>
          </field>
        
        <field id="separador" deshabilitado="true" editable="false" modpos="nobr"/>          
          
          <field id="regzona_id" modpos="nobr">
            <label>Ruta</label>
            <operador>=</operador>
          </field>

      </filters>

		    <field id="separador" deshabilitado="true" noshow="true"  local="true">
            <size>1</size>
        </field>

        <field id="id_regmovim" noshow="true"/>
        <field id="subsistema_id" noshow="true" valauto="true" />
        <field id="regcuenta_id" break="true" noshow="true" />
        <field id="subsistema_idv" noshow="true" local="true" valauto="true" />

        <field id="regcuentavendedor_id" noshow="true" />

      <fieldGroup>
          <field id="regzona_id" tabla="REG_CUENTA" noshow="true">
              <helper type="combo" xml="regzonas_qry.xml" dir="/ayudas" empty="true"/>
          </field>

          <field id="nro_cuenta" tabla="REG_CUENTA" repeat="false">
              <label>Codigo</label>
              <helper type="external" xml="regcuenta_solamente_nro_qry.xml" dir="/ayudas" empty="true"/>
        <attribute id="style">color_noautorizada</attribute>    
          </field>

          <field id="nombre_cuenta" tabla="REG_CUENTA" repeat="false">
              <label>Nombre</label>
        <attribute id="style">color_noautorizada</attribute>    
          </field>

          <field id="datos_contacto" repeat="false">
          <label>Datos Contacto</label>
            <expression><![CDATA[
CONCAT(
        (select informe_contacto from VISTA_CONTACTOS where VISTA_CONTACTOS.regcuenta_id = REG_MOVIMIENTOS.regcuenta_id),
        IF(REG_CUENTA.email_cuenta != '', concat('<br>','<b>','Email: ','</b>', REG_CUENTA.email_cuenta),''),
        IF(REG_CUENTA.tel_cuenta != '', concat('<br>','<b>','Telefono: ','</b>', REG_CUENTA.tel_cuenta),''))

             ]]></expression>
            <attribute id="style">color_noautorizada</attribute>
          </field>
      </fieldGroup>


      <fieldGroup>
        <if> if (($_SESSION['administrator'] != 1) &amp;&amp; (strpos($_SESSION['properties']['modulos'],'vendedores') != false)) return true; </if>

          <field id="regcuenta_idv"  deshabilitado="true">
             <label>Vendedor</label>
             <helper type="combo" xml="regcuenta_solamente_qry.xml" dir="/ayudas" _empty="true" >
                <field id="subsistema_id">
                    <condicion operador="=">'[__subsistema_idv__]'</condicion>
                </field>
                <field id="login" local="true" noshow="true">
                    <label>login</label>
                    <valor eval="true">$_SESSION['idUser']</valor>
                </field>
          // FILTRO LOS CLIENTES DEL VENDEDOR QUE USA EL PROGRAMA

                <field id="usuario_vendedor" noshow="true">
                    <eval> if ($_SESSION['administrator'] != 1) return true; </eval>
                    <expresion having="false"> ifnull((select usuario_id from REG_CUENTA_USERS RCU where RCU.regcuenta_id = REG_CUENTA.id_regcuenta limit 1),0) </expresion>
                    <condicion operador="=">[__login__]</condicion>
                </field>
              </helper>
              <expresion having="false">
              ( select REG_CUENTA.nombre_cuenta 
              from REG_CUENTA_RELACIONES 
              join REG_CUENTA on REG_CUENTA.id_regcuenta = REG_CUENTA_RELACIONES.regcuentarelacionada_id
              where REG_CUENTA_RELACIONES.subsistemarelacionada_id = '[__subsistema_idv__]' 
              and REG_CUENTA_RELACIONES.regcuenta_id = REG_MOVIMIENTOS.regcuenta_id order by fecha_vigencia desc limit 1)
              </expresion>
          </field>
      </fieldGroup>

      <fieldGroup>
          <if> if (($_SESSION['administrator'] == 1) &amp;&amp; (strpos($_SESSION['properties']['modulos'],'vendedores') != false)) return true; </if>

          <field id="regcuenta_idv"  deshabilitado="false">
              <label>Vendedor</label>
              <helper type="combo" xml="regcuenta_solamente_qry.xml" dir="/ayudas" empty="true">
              <field id="subsistema_id">
                <condicion operador="=">'[__subsistema_idv__]'</condicion>
                    </field>
                    <field id="login" local="true" noshow="true">
                        <label>login</label>
                        <valor eval="true">$_SESSION['idUser']</valor>
                    </field>
                    // FILTRO LOS CLIENTES DEL VENDEDOR QUE USA EL PROGRAMA
                    <field id="usuario_vendedor" noshow="true">
                        <eval> if ($_SESSION['administrator'] != 1) return true; </eval>
                        <expresion having="false">ifnull((select usuario_id from  REG_CUENTA_USERS RCU where RCU.regcuenta_id =  REG_CUENTA.id_regcuenta  limit 1), 0 )</expresion>
                        <condicion operador="=">[__login__]</condicion>
                    </field>
                </helper>

              <expresion having="false">
              ( select REG_CUENTA.nombre_cuenta 
              from REG_CUENTA_RELACIONES 
              join REG_CUENTA on REG_CUENTA.id_regcuenta = REG_CUENTA_RELACIONES.regcuentarelacionada_id
              where REG_CUENTA_RELACIONES.subsistemarelacionada_id = '[__subsistema_idv__]' 
              and REG_CUENTA_RELACIONES.regcuenta_id = REG_MOVIMIENTOS.regcuenta_id order by fecha_vigencia desc limit 1)
              </expresion>
            </field>
        </fieldGroup>
      <field id="fecha_movimiento">
        <label>Fecha Emision</label>
        <tipo>date</tipo>
        <attribute id="style">color_noautorizada</attribute>    
      </field>

      <field id="dias_vencimiento" local="true" noshow="true">
        <helper type="parameter" id="SIS::02::vencimiento_factura">
            <label>Dias para el vencimiento de facturas</label>
            <defaultValue></defaultValue>
        </helper>
      </field>

      <field id="vencimiento_movimiento">
        <label>Vencimiento</label>
        <expression>case when '[__dias_vencimiento__]' = '' then vencimiento_movimiento else DATE_ADD(fecha_movimiento, INTERVAL '[__dias_vencimiento__]' DAY) end</expression>
        <attribute id="style">color_noautorizada</attribute>    
      </field>

      <field id="nro_movimiento" tdWidth="150" linkdes="Detalle del Comprobante" linkmodal="true" style="text-align: center; white-space: nowrap;">
        <label>Numero</label>
        <expresion>CONCAT((IF(REG_NUMERADORES.fiscal = 1 AND REG_NUMERADORES.printer = 'WSAFIP' AND IFNULL(REG_MOVIMIENTOS.numero_cae + 0, 0) = 0, ' NO AUTORIZADA: ', '')), REG_CONCEPTOS.abreviacion_concepto, ' ', REG_MOVIMIENTOS.letra_movimiento, ' ', LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,'0'), '-', LPAD(REG_MOVIMIENTOS.nro_movimiento  ,8,'0'))</expresion>
        <helper type="link" _dir="/caja/qry">
          <parameter source="id_regmovim" target="id_regmovim"/>
        </helper>
        <attribute id="linkint">imprime_concepto1</attribute>       
      </field>

      <field id="imprime_concepto1" noshow="true">
        <expresion>IFNULL(REG_NUMERADORES.ejecuta,'')</expresion>
      </field>

      <field id="importe_movimiento">
        <label>Imp. Original</label>
        <tipo>custom_numeric</tipo>
        <attribute id="style">color_noautorizada</attribute>    
      </field>

      <field id="saldo_movimiento" suma="true">
        <label>Saldo</label>
        <condicion operador="!=">0</condicion>
        <tipo>custom_numeric</tipo>
        <attribute id="style">color_noautorizada</attribute>    
      </field>

      <!-- Se muestran el detalle de las facturas -->
      <field id="forma_envio" local="true" style="text-align:center;">
          <label>Envíos</label>
          <helper type="link" xml="regmovim_obs_qry.xml" dir="/proveedores/qry">
             <parameter target="regmovim_id" source="id_regmovim" operator="="/>
          </helper>
          <expression sql="true">select concat((select count(*) from REG_MOVIMIENTO_OBS where REG_MOVIMIENTO_OBS.regmovim_id = '[__id_regmovim__]'), ' Enviados')</expression>
      </field>

        <field id="prox_llamado">
            <label>Llamar</label>
            <tipo>date</tipo>
            <attribute id="style">color_noautorizada</attribute>
        </field>

        <field id="posible_pago">
            <label>PosPago</label>
            <tipo>date</tipo>
            <attribute id="style">color_noautorizada</attribute>
        </field>

        <field id="cobranza_llamado" local="true" style="text-align:center;">
            <label>Cobranza</label>
            <helper type="link" xml="gestion_cobranza_ficha.xml" dir="/clientes/ing" width="435px" height="110px">
                <parameter target="id_regmovim" source="id_regmovim" />
            </helper>
            <valor>+</valor>
        </field>

      <field id="color_fondo" noshow="true" clasefila="true">
          <expression>case when CURDATE() &lt;= (case when '[__dias_vencimiento__]' = '' then vencimiento_movimiento else DATE_ADD(fecha_movimiento, INTERVAL '[__dias_vencimiento__]' DAY) end) then '' else 'resaltadoRojo' end</expression>
      </field>

      <field id="color_noautorizada" noshow="true">
          <expression>IF(REG_NUMERADORES.fiscal = 1 AND REG_NUMERADORES.printer = 'WSAFIP' AND IFNULL(REG_MOVIMIENTOS.numero_cae + 0, 0) = 0, 'color: #fff; background-color:#AE0909;', '')</expression>
      </field>

      <field id="imputacion_concepto" oculto="true" tabla="REG_CONCEPTOS"/>

      <order>
        <field id="dias_restantes" tipoOrden="DESC" />
        <field id="nombre_cuenta"/>
        <field id="fecha_movimiento"/>
        <field id="nro_movimiento"/>
      </order>

    </table>

    <join>
      <table id="REG_CONCEPTOS">
        <field id="id_concepto">
          <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
        </field>
        <field id="tipo_concepto">
          <condicion operador="=">1</condicion>
        </field>
        <field id="informa_calculo">
          <condicion operador="=">0</condicion>
        </field>
      </table>
    </join>

    <join>
      <table id="REG_CUENTA">
        <field id="id_regcuenta">
          <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
        </field>
      </table>
    </join>

    <join tipo="left">
      <table id="REG_NUMERADORES">
        <field id="subsistema_id">
          <condicion operador="=">REG_MOVIMIENTOS.subsistema_id</condicion>
        </field>
        <field id="regconcepto_id">
          <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
        </field>
        <field id="puesto">
          <condicion operador="=">REG_MOVIMIENTOS.puesto_movimiento</condicion>
        </field>
        <field id="letra">
          <condicion operador="=">REG_MOVIMIENTOS.letra_movimiento</condicion>
        </field>
      </table>
    </join>

  </form>
</histrix>