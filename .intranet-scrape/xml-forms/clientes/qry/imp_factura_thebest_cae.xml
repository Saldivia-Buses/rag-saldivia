<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="ficha" PDFsincabecera="true" _PDFconpie="true" sololectura="true" autoprint="true" PDFfontSize="8" PDFpageSize="A4">
  <title>FACTURA</title>
  <obs></obs>
  <form>
            <pdf PDForientacion="P">
            <header><![CDATA[

				$pdf->SetDrawColor(0);
				$pdf->SetXY(10,10);

				$tp = 05;
				$ap = $pdf->anchoPagina - 2;
				$mp = ($ap / 2);
				$lp = $pdf->largoPagina;

				// Frame Principal
				$pdf->Rect(005, 005, $ap, $lp, 0.1);

				// Nombre Empresa
				$pdf->Rect(005, 005, $mp, 045, 0.1);

				$datapath = $_SESSION['datapath'];
				//$file = "../database/$datapath/img/logo_factura.png"; 

				if (is_file($file))
				{
					$posx = 26;
					$posy = 6;
					$width = 50;
					$pdf->Image($file, $posx + $this->offsetX, $posy + $this->offsetY, $width);
				}
				
				// Datos Comprobante
				$pdf->Rect($mp + 5, 005, $mp, 045, 0.1);
				
				/// letra
				$pdf->setFillColor(255,255,255);
				$pdf->Rect($mp - 2 , 005, 015, 015, 'F');
				$pdf->Rect($mp - 2 , 005, 015, 015, 0.1);

				
				// Cliente
				$pdf->Rect(005, 053, $ap, 031, 0.1);
				
				// DATOS EMPRESA
				$pdf->SetFont('Arial','B',20);
				$pdf->text(027, 022,$_SESSION['properties']['nombre']);
				
				$pdf->SetFontSize(8);
				$pdf->text(012, 037, $_SESSION['properties']['direccion'].' - '.$_SESSION['properties']['localidad'] );
				$pdf->text(027, 044, $_SESSION['properties']['telefonos'].' - '.$_SESSION['properties']['mail']);
				$pdf->text(040, 051,'IVA RESPONSABLE INSCRIPTO');
				
				$pdf->text($mp + 077, 051, 'C.U.I.T.: ' .            $_SESSION['properties']['cuit']);
				$pdf->text($mp + 012, 045, 'Ingresos Brutos: ' .     $_SESSION['properties']['iibb']);
				$pdf->text($mp + 012, 051, 'Fec. Inicio. Activ.: ' . $_SESSION['properties']['fecha']);
				
				$pdf->SetFontSize(10);
				/*
				// Totales
				$pdf->Rect(005, 240, $ap, 040, 0.1);			
				*/
				
				$pdf->text(185, 8, 'Hoja: ' .($pdf->PageNo() + 1).'/{nb}');

				 $pdf->setY(25);
				$pdf->bottomMargin = 15;

            ]]></header>
		<footer>
				$pdf->bottomMargin = 25;

				// Logo Factura Electronica
				$datapath = $_SESSION['datapath'];
				$file = "../database/$datapath/img/logo_afip.png";
				$pdf->Image($file,10, 275, 40);

		</footer>
        </pdf>

	<table id="REG_MOVIMIENTOS"  label="FACTURA">
		
		<field id="id_regmovim" noshow="false" esClave="true" print="false" />
		
		<field id="muestra_iva" noshow="true" local="true" print="false">
			<expresion>case when letra_movimiento = 'A' or letra_movimiento = 'a'  then 'true' else 'false' end </expresion>
		</field>
		
		<field id="nomuestra_iva" noshow="true" local="true" print="false">
			<expresion>case when letra_movimiento = 'A' or letra_movimiento = 'a'  then 'false' else 'true' end </expresion>
		</field>
		
		<field id="muestra_dto" noshow="true" local="true" print="false">
			<expresion>IF(importe_bon != 0,'true','false')</expresion>
		</field>
		
		<field id="muestra_vencimiento" noshow="true" local="true" print="false">
			<if exp="'vencimiento_movimiento' != ''">
				<true>'true'</true>
				<false>'false'</false>
			</if>
		</field>
		
		<field id="subsistema_id" noshow="true" print="false" />
		
		<field id="concepto_id"   noshow="true" print="false" />
		
		<field id="regcuenta_id"  noshow="true" print="false" />
		
		<field id="id_regcuenta"  noshow="true" print="false" tabla="REG_CUENTA" deshabilitado="true" />
		
		== LETRA Y CODIGO
		<fieldGroup id="letra" deshabilitado="true" PDFnoborder="true">	
		
			<field id="letra_movimiento" PDFbold="true" PDFsize="24" PDFheader="true">
				<label posx="97" posY="3" />
				<expresion>UPPER(letra_movimiento)</expresion>
			</field>
			
			<field id="regconcepto_afip" PDFbold="true" PDFsize="8" pdfancho="120" PDFheader="true">
				<label posx="94" posY="8"/>
				<expresion>CONCAT('COD. ', LPAD(regconcepto_afip,2,'0'))</expresion>
				<tipo>varchar</tipo>
			</field>
		
		</fieldGroup>
		
		== CABECERA ==
		
		<fieldGroup id="cabecera1" deshabilitado="true" PDFnoborder="true">
		
			<field id="descripcion_concepto" PDFbold="true" PDFsize="13" PDFheader="true">
				<label posx="140" posY="3" />
				<expresion>UPPER(REG_CONCEPTOS.descripcion_concepto)</expresion>
			</field>
			
			<field id="nro_Movimiento" _PDFnolabel="true" PDFnoborder="true" PDFbold="true" PDFsize="11" PDFheader="true">
				<label posx="135" posY="12">Nº: </label>
				<expresion>CONCAT(LPAD(puesto_movimiento,4,'0'),' - ',LPAD(nro_movimiento,8,'0'))</expresion> 
			</field>
			  
			<field id="fecha_movimiento" PDFsize="11" PDFheader="true">
				<label posx="135" posY="18" size="26">Fecha: </label>
			</field>

			<field id="nombre_cuenta" tabla="REG_CUENTA" PDFbold="true" pdfancho="120" PDFheader="true">
				<label posx="5" posY="+17" size="17">Nombre: </label>
				<expression>LEFT(REG_CUENTA.nombre_cuenta, 120)</expression>
			</field>

			<field id="iva_id" tabla="REG_CUENTA" PDFheader="true">
				<label posx="125" posY="0" size="20">I.V.A.: </label>
				<helper type="combo" xml="iva_qry.xml" dir="/ayudas" empty="true" />
			</field>

			<field id="cod_direccion" tabla="REG_CUENTA" pdfancho="120" _PDFnolabel="true" PDFheader="true">
				<label posx="5" posY="+1" size="17">Direccion: </label>
				<expression>CONCAT(cod_direccion, ' ', (CASE WHEN nro_direccion = 0 OR nro_direccion is null THEN '' ELSE nro_direccion END), ' ',(CASE WHEN abreviacion_direccion != 0 OR abreviacion_direccion is not null THEN abreviacion_direccion else '' END))</expression>		
			</field>

				<field id="cuit_cuenta" tabla="REG_CUENTA" pdfancho="80" PDFheader="true">
					<label posx="125" posY="0" size="20">C.U.I.T.: </label>
				</field>

			<field id="localidad" pdfancho="120" _PDFnolabel="true" PDFheader="true">
				<expression>LEFT(CONCAT(LOCALIDAD_CUENTA.cp, ' ', LOCALIDAD_CUENTA.nombre_localidad), 110)</expression>
				<label posx="5" posY="+1" size="17">Localidad: </label>
			</field>

				<field id="regforma_id" PDFheader="true">
					<label posx="125" posY="0" size="20">Forma pago:</label>
					<helper type="combo" id="REG_FORMAS" >
						<field id="id_regforma"/>
						<field id="nombre_forma"/>
					</helper>
				</field>

			<field id="provincia" pdfancho="120" _PDFnolabel="true" PDFheader="true">
				<expression>LEFT(PROVINCIA_CUENTA.nombre_provincia, 110)</expression>
				<label posx="5" posY="+1" size="17">Provincia: </label>
			</field>

			<field id="reg_periodo" pdfancho="120" PDFheader="true">
				<label posx="125" posY="0" size="20">Periodo</label>
				<attribute id="print">imprime_vto</attribute>
			</field>

			<field id="imprime_vto" print="false" noshow="true">
				<expression>case when tiposervicio_afip != 1 then 'true' else 'false' end</expression>
			</field>
			
			<field id="vencimiento_movimiento" PDFheader="true">
				<label posx="125" posY="+1" size="20">Fecha Vto.: </label>
				<attribute id="print">imprime_vto</attribute>
			</field>			
			
			
			<field id="marca_agua" local="true" PDFbold="true" PDFitalic="true" PDFrotate="-30">
				<label posx="10" posY="+10" PDFcolor="#E3E3E3" PDFrestorePosition="true" PDFsize="73" size="300" />
				<expression>case when numero_cae != 0 then '' else 'NO AUTORIZADA' end</expression>
			</field>
			
		</fieldGroup>

		== ETIQUETAS ==

		<fieldGroup id="cuerpo1" pdfwidth="200">
			<field id="detalles" local="true">
				<label posx="5" posy="65" />
				<helper xml="imp_factura_detalle_thebest_cae.xml" type="object" dir="/clientes/qry">
					<parameter source="id_regmovim"   target="regmovim_id"/>
					<parameter source="subsistema_id" target="subsistema_id"/>
					<parameter source="muestra_iva"   target="muestra_iva"/>
				</helper>
			</field>
		</fieldGroup>

		== TALON ==

		<fieldGroup id="talon1" deshabilitado="true" PDFnoborder="true" PDFsize="12">
			
			<field id="observacion_facturacion" local="true" maxsize="250" maxlength="250" PDFnolabel="true" PDFsize="7" pdfancho="130">
				<label posx="5" posY="210" />
				<helper type="parameter" id="SIS::02:observacion_facturacion" >
					<label>Observacion Para Facturacion</label>
					<defaultValue></defaultValue>
				</helper>
				<size>250</size>
			</field>

			<field id="referencia_facturacion" local="true" maxsize="250" maxlength="250" PDFnolabel="true" PDFsize="8" pdfancho="120" PDFbold="true">
				<label posx="5" posY="240" />
				<helper type="parameter" id="SIS::02:refrerencia_facturacion" >
					<label>Referencia Para Facturacion</label>
					<defaultValue></defaultValue>
				</helper>
				<size>250</size>
			</field>

			<field id="bonificaciones_movimiento" PDFnolabel="true" pdfancho="25" noZero="true" >
				<label posx="120" posY="0" size="24">Descuento %</label>
				<tipo>numeric</tipo>
				<attribute id="print">muestra_dto</attribute>
			</field>
			<field id="importe_bon" PDFnolabel="true" pdfancho="25">
				<label posx="165" posY="0" />
				<tipo>numeric</tipo>
				<expresion>case when letra_movimiento = 'A' or letra_movimiento = 'a' then importe_bon else importe_bon * 1.21 end </expresion>
				<attribute id="print">muestra_dto</attribute>
			</field>
			<field id="neto_movimiento" pdfancho="30">
				<label posx="130" posY="240" size="35">Subtotal $</label>
				<tipo>numeric</tipo>
				<attribute id="print">muestra_iva</attribute>
			</field>
			<field id="total_iva" pdfancho="30">
				<label posx="130" posY="250" size="35">Importe I.V.A. $</label>
				<expression>importe_iva</expression>
				<tipo>numeric</tipo>
				<attribute id="print">muestra_iva</attribute>
			</field>
			<field id="importe_movimiento" pdfancho="30" PDFbold="true">
				<label posx="130" posY="260" size="35">Importe Total $</label>
			</field>
			
			<!-- ELECTRONICA! -->
			
			<field id="codigo" PDFnolabel="true" pdfancho="40" PDFbold="true" grafico="barcode" imageHeight="40" imageWidth="100" imageScale="2" PDFfooter="true">
				<label posx="050" posY="270" /> 
				<expression>CONCAT( '30709128651', LPAD(regconcepto_afip,2,'0'), LPAD(puesto_movimiento,4,'0'), numero_cae, DATE_FORMAT(fecha_cae,'%Y%m%d') )</expression>
				<tipo>grafico</tipo>
				<size>60</size>
			</field>
			
			<field id="numero_cae" pdfancho="40" PDFsize="6" PDFbold="true" PDFfooter="true">
				<label posx="155" posY="268" size="20">CAE Nº:</label>
			</field>
			
			<field id="fecha_cae" pdfancho="40" PDFsize="6" PDFbold="true" PDFfooter="true">
				<label posx="155" posY="272" size="20">Fec. Vto. CAE:</label>
				<tipo>date</tipo>
			</field>
			
		</fieldGroup>
		
		<group>
			<field id="id_regmovim"/>
		</group>
	
	</table>
	
	<join tipo="left">
	    <table id="REG_CONCEPTOS">
	        <field id="id_concepto">
		    <condicion operador="=">concepto_id</condicion>
		</field>
	    </table>
	</join>
	<join tipo="left">
	    <table id="REG_CUENTA">
		<field id="id_regcuenta">
		    <condicion operador="=">regcuenta_id</condicion>
		</field>
	    </table>
	</join>
	<join tipo="left">
	    <table id="REG_DETALLES">
		<field id="regmovim_id">
		    <condicion operador="=">id_regmovim</condicion>
		</field>
	    </table>
	</join>
	<join tipo="left">
		<table id="GEN_LOCALIDADES" as="LOCALIDAD_CUENTA">
			<field id="id_localidad">
				<condicion operador="=">REG_CUENTA.localidad_id</condicion>
			</field>
		</table>
	</join>
	<join tipo="left">
		<table id="GEN_PROVINCIAS" as="PROVINCIA_CUENTA">
			<field id="id_provincia">
				<condicion operador="=">REG_CUENTA.provincia_id</condicion>
			</field>
		</table>
	</join>
  </form>
</histrix>
