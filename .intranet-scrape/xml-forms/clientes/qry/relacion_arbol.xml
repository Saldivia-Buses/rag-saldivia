<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="consulta" >
    <title>Consulta de Cuentas</title>
    <obs></obs>
    <form>

    <table id="REG_CUENTA_RELACIONES" label="Cuentas Relacionadas">

  <fieldGroup colstyle="text-align:center;vertical-align:middle; padding: 2px 2px 2px 2px;">

            <field id="nro_cuenta" tabla="REG_CUENTA">
                <label>Nº</label>
                <helper type="external" xml="regcuenta_relacionescmb_nro.xml" dir="/ayudas" />
                <size>6</size> 
            </field>

            <field id="subsistema_id" local="true" noshow="true">
                <label>subsistema_id</label>
            </field>

            <field id="nombre_cuenta" linkdes="Datos del Cliente" tabla="REG_CUENTA">
                <label>Nombre</label> 
                <helper type="link" xml="det_cliente.xml" modal="true">
                    <parameter source="id_regcuenta" target="id_regcuenta" operator="="/>
                </helper>               
                <size>25</size>
            </field>

            <field id="deuda" linkdes="Cuenta Corriente" local="true" tabla="REG_CUENTA">
                <label>Cuenta</label>
                <helper type="link" xml="cc_notas_venta.xml" dir="/clientes/qry" modal="true">
                    <parameter source="regcuenta_id" target="regcuenta_id" operator="="/>
                    <parameter source="subsistema_id" target="subsistema_id" operator="="/>
                </helper>
                <valor>'Cuenta'</valor>
            </field>

            <field id="regzona_id" tabla="REG_CUENTA">
                <helper type="combo" id="REG_ZONAS" empty="true" >
                    <field id="id_regzona" />
                    <field id="nombre_zona" />
                    <field id="subsistema_id" />
                </helper>
                <label>Zona</label>
            </field>

            <field id="cod_direccion" tabla="REG_CUENTA">
                <label>Direccion</label>
                <size>25</size>
            </field>

            <field id="provincia_id" tabla="REG_CUENTA">
                <label>Provincia</label>
                <helper type="combo" xml="provincia_qry.xml" dir="/ayudas" empty="true" />
                <actualiza>
                    <field id="localidad_id" destino="provincia_id" />
                </actualiza>
            </field>

            <field id="localidad_id" tabla="REG_CUENTA">
                <label>Localidad</label>
                <helper type="combo" xml="localidad_qry.xml" dir="/ayudas" empty="true" > 
                    <field id="provincia_id" oculto="true" />
                </helper>
            </field>

        </fieldGroup>

    <fieldGroup colstyle="text-align:center;" noshow="true">

            <field id="id_regcuentarelacion">
                <label>id_regcuentarelacion</label>
            </field>

            <field id="regcuenta_id">
                <label>regcuenta_id</label>
            </field>

            <field id="regcuentarelacionada_id">
                <label>regcuentarelacionada_id</label>
            </field>

            <field id="subsistemarelacionada_id">
                <label>subsistemarelacionada_id</label>
            </field>

            <field id="fecha_vigencia">
                <label>fecha_vigencia</label>
            </field>

            <field id="valor_aplicado">
                <label>valor_aplicado</label>
            </field>

        </fieldGroup>

        </table>

        <join tipo="left">
            <table id="REG_CUENTA">
                <field id="id_regcuenta">
                    <condicion operador="=">regcuenta_id</condicion>
                </field>
            </table>
        </join>

    
    </form>
</histrix>  
