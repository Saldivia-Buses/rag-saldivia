<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="consulta" preloadData="false" paginar="200">
    <title>Consulta de Cuentas</title>
    <obs></obs>
    <form detalle="detalle_cliente.xml" inline="true">

        <table id="REG_CUENTA" label="Cuentas">

            <filters>
    	        <field id="nro_cuenta"  noshow="true">
        		    <label>Cod</label>
    	            <operador>=</operador>
                </field>

                <field id="separador" deshabilitado="true" editable="false" modpos="nobr"/>

                <field id="nombre_cuenta" deshabilitado="false" modpos="nobr">
                    <operador>like</operador>
                    <label>Nombre</label>
                </field>

                <field id="separador" deshabilitado="true" editable="false" modpos="nobr"/>
                
                <field id="cod_direccion">
                    <label modpos="nobr">Direccion</label>
                    <operador>like</operador>
                </field>

                <field id="separador" deshabilitado="true" editable="false" modpos="nobr"/>

                <field id="nombre_localidad" deshabilitado="false">
                    <operador>like</operador>
                    <label modpos="nobr">Ciudad</label>
                </field>

                <!--    <field id="tel_cuenta" deshabilitado="false">
                    <operador>=</operador>
                    <label modpos="nobr">Telefono</label>
                </field>	 -->
                
                <!--  <field id="regzona_id" _noshow="true" >
                    <label modpos="nobr">Zona</label>
                </field>                    -->
                
                <field id="regcuentarelacionada_id">
                    <label>Vendedor</label>
                </field>

                <field id="separador" deshabilitado="true" editable="false" modpos="nobr"/>

                <field id="categoria_ganancia">
                  <label modpos="nobr">Categoria</label>
                </field>
                
            </filters>

            <field id="separador" deshabilitado="true" noshow="true"  local="true">
                <size>1</size>
            </field>

    <fieldGroup style="text-align:center;">

            <field id="categoria_ganancia" noshow="true">
              <helper type="combo" empty="true" id="REG_CATEGORIAS">
                <field id="id_regcategoria" />
                <field id="nombre_categoria" />
                <field id="subsistema_id" />
              </helper>
              <label colspan="6">Categoria</label>
            </field>
            
            <field id="nro_cuenta"  _noshow="true" >
                <label>Cod</label>
                <helper type="external" xml="regcuenta_relacionescmb_nro.xml" dir="/ayudas"  >
                </helper> 
                <size>6</size> 
            </field>

            <field id="id_regcuenta" noshow="true">
                <label>Número</label>
                <detalle>regcuenta_id</detalle>
            </field>
				
            <field id="nombre_cuenta" linkdes="Datos del Cliente">
                <label>Nombre</label>                
                <helper type="link" xml="det_cliente.xml" modal="true">
                    <parameter source="id_regcuenta" target="id_regcuenta" operator="="/>
                </helper>               
                <size>25</size>
            </field>

            <field id="deuda" linkdes="Cuenta Corriente" local="true">
                <label>Deuda</label>                
                <helper type="link" xml="regdetalles_all_qry.xml" dir="/clientes/qry" modal="true">
                    <parameter source="id_regcuenta" target="regcuenta_id" operator="="/>
                    <parameter source="subsistema_id" target="subsistema_id" operator="="/>
                </helper>
                
                <valor>'Cta. Cte.'</valor>
            </field>

            <field id="cod_direccion">
                <label>Direccion</label>
                <size>25</size>
            </field>
	    
            <field id="telefono" >
                <label _modpos="nobr">Telefonos</label>
                <expression>SELECT group_concat(valor, ' ') 
                             FROM REG_CUENTAS_CONTACTOS
                             JOIN GEN_TIPO_CONTACTOS on 
                            ( GEN_TIPO_CONTACTOS.id_contacto = REG_CUENTAS_CONTACTOS.contacto_id  )
                            WHERE regcuenta_id = REG_CUENTA.id_regcuenta and vcard_type like 'TEL%' LIMIT 1
                </expression>
                <size>30</size>
	        </field>
	       
            <field id="transporte" >
                <label _modpos="nobr">Transporte</label>
                <expression>SELECT group_concat(rc.nombre_cuenta, ' ') 
                             FROM REG_CUENTA_RELACIONES
                             LEFT JOIN REG_CUENTA rc on 
                             rc.id_regcuenta = REG_CUENTA_RELACIONES.regcuentarelacionada_id
                             and REG_CUENTA_RELACIONES.subsistemarelacionada_id = 'tr'
                            WHERE REG_CUENTA_RELACIONES.regcuenta_id = rc.id_regcuenta 
                </expression>
                <size>30</size>
	        </field>
	    
            <field id="cp" tabla="GEN_LOCALIDADES">
                <label>cp</label>
            </field>	

            <field id="nombre_localidad" tabla="GEN_LOCALIDADES">
                <label>Localidad</label>
            </field>

            <field id="nombre_provincia" tabla="GEN_PROVINCIAS">
                <label>Provincia</label>
            </field>

            <field id="regzona_id">
                <helper type="combo" id="REG_ZONAS" empty="true">
                    <field id="id_regzona" />
                    <field id="nombre_zona" />
                    <field id="subsistema_id" />
                </helper>
                <label  modpos="nobr">Zona</label>
            </field>
                       <!--
            <field id="alta_cuenta">
                <label>Fecha Alta</label>
                <tipo>date</tipo>
            </field>       -->

            <field id="nombre_iva" tabla="GEN_IVA">
                <label>IVA</label>
            </field>

            <field id="cuit_cuenta">
                <label>CUIT/CUIL</label>
            </field>
                      <!--
            <field id="solo_efectivo" deshabilitado="true">
                <label>Valores</label>
                <expression>IF(solo_efectivo = 1,'NO ACEPTAR VALORES','')</expression>
            </field>      -->
            <field id="limite_credito">
        	<label>Limite Cr.</label>
    	    </field>

            <field id="impsobre" local="true" tdWidth="50">
              <helper type="link" xml="imp_sobreclientes_qry.xml" dir="/clientes/qry" modal="true">
                <parameter source="id_regcuenta" target="id_regcuenta" operator="=" />
                <!--
                <parameter source="nro_cuenta" target="nro_regcuenta" operator="=" />
                <parameter source="subsistema_id" target="subsistema_id" operator="=" />
            -->
              </helper>
              <label>Imprime</label>
              <valor>sobre</valor>
            </field>

			<!-- Filtros -->

            <field id="subsistema_id" oculto="true" valauto="true" >
                <detalle>subsistema_id</detalle>
            </field>


            <field id="subsistemave_id" local="true" oculto="true" />

            <field id="regcuentarelacionada_id2" noshow="true">
                    <expression>regcuentarelacionada_id</expression>
            </field>

        </fieldGroup>
            <!--
            <field id="regcuentarelacionada_id" _noshow="true" _local="true" tabla="REG_CUENTA_RELACIONES">
                <helper type="combo" id="REG_CUENTA" _xml="regcuenta_cmb.xml" dir="/ayudas" empty="true">
                    <field id="id_regcuenta" autoinc="true" _noshow="true" esClave="true">
                        <label>Numero Cuenta</label>
          
                    </field>
                    <field id="nombre_cuenta">
                        <label>Nombre</label>
                        <detalle>nombre</detalle>
                    </field>
                    <field id="subsistema_id" noshow="true">
                        <condicion operador="=" valorde="subsistemave_id"></condicion>
                    </field>
                </helper>
                <label>Vendedor</label>
                <help>Seleccione el Vendedor</help>
            </field>
-->

            <!-- si es vendedor-->
        <fieldGroup style="text-align:center;"> 

            <field id="regcuentarelacionada_id" tabla="REG_CUENTA_RELACIONES" Formstyle="display:none;" noshow="true">
              <label>Vendedor</label>
              <helper type="combo" xml="regcuenta_vendedor_qry.xml" dir="/ayudas" _empty="true">
                <field id="subsistemave_id" local="true" />
                <field id="subsistema_id">
                  <condicion operador="=">'[__subsistemave_id__]'</condicion>
                </field>
   
                <field id="login" local="true" noshow="true">
                    <label>login</label>
                    <valor eval="true">$_SESSION['idUser']</valor>
                </field>
                          // FILTRO LOS CLIENTES DEL VENDEDOR QUE USA EL PROGRAMA
                <field id="usuario_vendedor" noshow="true">
                    <eval> if ($_SESSION['administrator'] != 1) return true; </eval>

                    <expression having="false">ifnull((select usuario_id from  REG_CUENTA_USERS RCU where RCU.regcuenta_id =  REG_CUENTA.id_regcuenta  limit 1), 0 )</expression>
                    <condicion operador="=">[__login__]</condicion>
                </field>   
              </helper>

            </field>

        </fieldGroup>

        
         
            <!-- si es administrador -->
        <fieldGroup>    
            <if> if ($_SESSION['administrator'] == 1) return true; </if>

            <field id="regcuentarelacionada_id" tabla="REG_CUENTA_RELACIONES" Formstyle="display:none;">
              <label>Vendedor</label>
              <helper type="combo" xml="regcuenta_vendedor_qry.xml" dir="/ayudas" empty="true">
                <field id="subsistemave_id" local="true" />
                <field id="subsistema_id">
                  <condicion operador="=">'[__subsistemave_id__]'</condicion>
                </field>
              </helper>
            </field>

        </fieldGroup>    

           
            <group>
                <field id="nro_cuenta"/>
            </group>
            <order>
                <field id="nombre_cuenta" />
            </order>

        </table>
        <join tipo="left">
            <table id="REG_CUENTA_RELACIONES">
                <field id="regcuenta_id">
                    <condicion operador="=">id_regcuenta</condicion>
                </field>
                <field id="subsistemarelacionada_id">
                    <condicion operador="=">'[__subsistemave_id__]'</condicion>
                </field>
            </table>
        </join>
        <join tipo="left">
            <table id="REG_CUENTA_USERS">
                <field id="regcuenta_id">
                    <condicion operador="=">REG_CUENTA_RELACIONES.regcuentarelacionada_id</condicion>
                </field>
            </table>
        </join>        
        <join tipo="left">
            <table id="GEN_PROVINCIAS">
                <field id="id_provincia">
                    <condicion operador="=">REG_CUENTA.provincia_id</condicion>
                </field>
            </table>
        </join>


        <join tipo="left">
            <table id="GEN_LOCALIDADES">
                <field id="id_localidad">
                    <condicion operador="=">REG_CUENTA.localidad_id</condicion>
                </field>
            </table>
        </join>

        <join tipo="left">
            <table id="GEN_IVA">
                <field id="id_iva">
                    <condicion operador="=">REG_CUENTA.iva_id</condicion>
                </field>
            </table>
        </join>

    </form>
</histrix>	
