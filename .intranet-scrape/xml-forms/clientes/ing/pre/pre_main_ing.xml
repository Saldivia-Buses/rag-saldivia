<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="fichaing" inserta="false" borra="false" modifica="false" imprime="false" 
	tooltip="false" confirma="CONFIRMAR" transaccional="true" processFirst="true" log="false">
	<title />
	<obs></obs>
	<confirmacion><![CDATA[¿Confirma el Ingreso?]]></confirmacion>
	<form>
		<table id="REG_MOVIMIENTOS" label="Presupuesto">

			<validation>
				<condition><![CDATA[nro_cuenta + 0 == 0]]></condition>
				<message>Debe Ingresar una Cuenta</message>
			</validation>

			<validation>
				<condition><![CDATA[regcuentavendedor_id + 0 == 0 && modulo_vendedores + 0 == 1 ]]></condition>
				<message>Debe ingresar un vendedor</message>
			</validation>
			
			<validation>
				<condition><![CDATA['regcuenta_ivaletra' == '']]></condition>
				<message>La cuenta ingresada tiene datos incompletos</message>
			</validation>

			<validation>
				<condition><![CDATA[regconcepto_id + 0 == 0]]></condition>
				<message>Tipo de Comprobante no válido</message>
			</validation>

			<validation>
				<condition><![CDATA[puesto_movimiento + 0 == 0]]></condition>
				<message>Punto de Venta no válido</message>
			</validation>

			<validation>
				<condition><![CDATA[nro_movimiento + 0 == 0]]></condition>
				<message>Numero de Movimiento no válido</message>
			</validation>

			<validation>
				<condition><![CDATA[micanpro + 0 == 0]]></condition>
				<message>Debe ingresar un articulo</message>
			</validation>

		<!-- GRABACION DE CUENTA CORRIENTE -->

			<movimientos>
					
					<relacion id="pre_regmovimientos_ins.xml" />
					<relacion id="pre_main_numerador_upd.xml" />
					<relacion id="pre_regmovimientos_print.xml" />

			</movimientos>

			<fieldGroup noshow="true">

				<field id="id_regmovim" oculto="true">
					<condicion operador="=">0</condicion>
				</field>

			</fieldGroup>


			<fieldGroup local="true" noshow="true">

					<field id="regcuenta_id" />

				    <field id="subsistemavendedor_id"   /> <!-- PARA LA BUSQUEDA DEL VENDEDOR -->
		    		<field id="subsistematransporte_id" /> <!-- SUBSISTEMA DE TRANSPORTE -->
					<field id="subsistema_id" 			/> <!-- GRABA COMPROBANTE 22 XQ NO VA EN CCORRIENTE -->
					<field id="subsistema" valauto="true"> <!-- PARA LA BUSQUEDA DEL CLIENTE Y FORMA DE PAGO -->
						<actualiza>
							<field id="nro_cuenta" destino="subsistema_id" />
							<field id="regforma_id" destino="subsistema_id" />					
						</actualiza>
					</field>

		            <field id="stkconcepto_id">
		                <helper type="parameter" id="SIS::02:stock_codigo_concepto_venta" >
		                    <label>Codigo de Concepto Stock para salida por venta</label>
		                    <defaultValue>2</defaultValue>
		                </helper>
		                <detalle>stkconcepto_id</detalle>
		            </field>

					<field id="noshow_field" >
		                <helper type="parameter" id="SIS::02::noshow_field">
		                    <label>Oculta fields dentro del programa</label>
		                    <defaultValue>false</defaultValue>
		                </helper>
		            </field>

		            <field id="deshabilita_field">
		                <helper type="parameter" id="SIS::02::deshabilita_field">
		                    <label>Deshabilita fields dentro del programa</label>
		                    <defaultValue>false</defaultValue>
		                </helper>
		            </field>

		            <field id="noshow_field_tsafip" local="true" noshow="true">
		                <helper type="parameter" id="SIS::02::noshow_tsafip_field">
		                    <label>Oculta fields dentro del programa</label>
		                    <defaultValue>false</defaultValue>
		                </helper>
		            </field>

			        <field id="regcuenta_ivaid" />
					<field id="mi_dto_global" />
					<field id="genlocalidad_id" />
					<field id="max_desc1" />
					<field id="max_desc2" />		
		            <field id="login" >
					   <valor eval="true">$_SESSION['idUser']</valor>
			        </field>

			</fieldGroup>


			<fieldGroup Formstyle="vertical-align:middle;text-align:center;font-size: large;background-color: #333; color: #fff;" >

				<field id="concepto_id" deshabilitado="true" local="true" >
					<label> </label>
					<helper type="combo" id="REG_CONCEPTOS">
						<field id="id_concepto" />
						<field id="descripcion_concepto"/>
						<field id="subsistema" local="true" oculto="true"/>
					</helper>
					<detalle>concepto_id</detalle>
				</field>

				<field id="regcuenta_ivaletra" local="true" deshabilitado="true" modpos="nobr">
					<actualiza>
						<field id="puesto_movimiento" 	destino="letra" />
						<field id="nro_movimiento"	 	destino="letra" />
						<field id="impresion" 			destino="letra" />
						<field id="impresora" 			destino="letra" />
					</actualiza>
					<size>1</size>
					<detalle>letra_movimimento</detalle>
					<valor>X</valor>
				</field>



				<field id="puesto_movimiento"  modpos="nobr" >
					<helper type="combo" id="REG_NUMERADORES" >
						<field id="puesto" />
						<field id="nombre_puesto" >
							<expression>LPAD(puesto,4,'0')</expression>
						</field>
						<field id="letra" oculto="true">
							<condicion operador="=">'X'</condicion>
						</field>
						<field id="regconcepto_id" oculto="true" />
					</helper>
					<actualiza>
						<field id="nro_movimiento" destino="puesto" />
						<field id="impresion"      destino="puesto" />
						<field id="impresora"      destino="puesto" />
						<field id="stkdeposito_id" destino="puesto" />
					</actualiza>
					<size>4</size>
					<detalle>puesto_movimiento</detalle>
				</field>

				<field id="nro_movimiento"  deshabilitado="true"  modpos="nobr">
					<label>Nº</label>
					<parametro id="numerador_param.xml" retorna="numero" />
				    <format>%08d</format>
				    <size>8</size>
				    <tipo>numeric</tipo>
				    <detalle>nro_movimiento</detalle>
			    </field>

		</fieldGroup>

		<fieldGroup style="padding:2px 2px 2px 2px;vertical-align:middle;">
				
				<field id="nro_cuenta" local="true">
					<label>Cliente</label>
					<helper type="external" xml="regcuenta_relacionescmb_nro.xml" dir="/ayudas" >
						<field id="login" local="true" noshow="true">
							<label>login</label>
							<valor eval="true">$_SESSION['idUser']</valor>
						</field>
						<field id="subsistema_id" oculto="true" />
						<field id="letra" oculto="true">
							<expression>'X'</expression>
							<detalle>regcuenta_ivaletra</detalle>
						</field>
					</helper>
					<size>6</size>
				</field>

				<field id="regcuenta_nombre" local="true" modpos="nobr" sincelda="true">
					<size>40</size>
					<attribute id="deshabilitado">deshabilita_field</attribute>
				</field>

				<field id="regcuenta_iva" local="true" deshabilitado="true" _modpos="nobr">
					<label>Categoria IVA</label>
				</field>

				<field id="fecha_movimiento" deshabilitado="false" modpos="nobr">
					<label modpos="nobr">Fecha</label>
					<if exp="'fecha' != ''">
						<true>'fecha'</true>
						<false>date('Y-m-d')</false>
					</if>
					<tipo>date</tipo>
					<actualiza>
						<field id="fecha_vigencia" destino="regcuentarelacionada_id" />
						<field id="regcuenta_id"   destino="fecha_movimiento" />
					</actualiza>
					<attribute id="deshabilitado">deshabilita_field</attribute>
				</field>

				<field id="regcuenta_direccion" local="true" modpos="nobr">
					<label>Direccion</label>
					<size>40</size>
					<attribute id="deshabilitado">deshabilita_field</attribute>
				</field>

				<field id="regcuenta_cuit" local="true" deshabilitado="true"  _modpos="nobr">
					<label>CUIT</label>
				</field>

				<field id="regcuenta_doc" local="true" deshabilitado="true" sincelda="true" modpos="nobr">
					<label>DNI</label>
				</field>

				<field id="regforma_id" local="true" modpos="nobr">
					<label>Condicion</label>
					<helper type="combo" xml="regforma_qry.xml" dir="/ayudas" >
						<field id="subsistema_id" oculto="true" />
					</helper>
				</field>

				<field id="regcuenta_localidad" local="true" deshabilitado="true" modpos="nobr">
					<label>Localidad</label>
					<size>15</size>
				</field>

				<field id="fecha" deshabilitado="true" local="true" noshow="true" />
			
			<!-- 3 -->

				<field id="limite_credito" deshabilitado="true" modpos="nobr" >
					<label>limite credito</label>
				</field>


				<field id="wstklista_id" local="true" required="true" modpos="nobr">
					<label>Precios </label>
					<help>Lista de Precios</help>
					<helper type="combo"  xml="stklista_qry.xml" dir="/ayudas" >
						<field id="max_desc1" >
								<expression>porcentaje_desc</expression>
						</field>					
						<field id="max_desc2" >
								<expression>porcentaje_desc1</expression>
						</field>
					</helper>
					<actualiza>
					    <field id="control_dtogral" destino="stklista_id" />
						<field id="codigo_detalle" destino="wstklista_id" xml="pre_main_grid.xml" />
					</actualiza>
				</field>      

				<field id="regcuenta_provincia" local="true" deshabilitado="true">
					<label modpos="nobr">Provincia</label>
				</field>


				<field id="regcuentavendedor_id" >
					<label>Vendedor</label>
					<helper type="external" xml="regcuenta_simple_qry.xml" dir="/ayudas" empty="true">
						<field id="id_regcuenta" />
						<field id="subsistema_id" oculto="true">
							<!-- SE COMENTO PORQUE NO ANDA Y SE DEJO FIJO <condicion operador="=" valorde="subsistemavendedor_id"/> -->
							<condicion operador="=">22</condicion>
						</field>
					</helper>
					<attribute id="noshow">noshow_field</attribute>
				</field>

				<field id="regcuentavendedor_nombre" deshabilitado="true" sincelda="true" >
					<attribute id="noshow">noshow_field</attribute>
				</field>

			<!-- 4 -->
				<field id="tiposervicio_afip"  modpos="nobr">
		          	<label>Tipo</label>
		          	<helper type="combo" id="GEN_TIPO_SERVICIO_AFIP">
		            	<field id="id_tiposervicio" />
		            	<field id="nombre_tiposervicio" />
	    	        </helper>
					<attribute id="noshow">noshow_field_tsafip</attribute>
	        	</field> 
	        	

				<field id="contacto_movimiento" local="true" modpos="nobr">
					<label>Contacto</label>
					<size>40</size>
					<attribute id="deshabilitado">deshabilita_field</attribute>
				</field>

		</fieldGroup>

		<!-- DETALLE DEL COMPROBANTE  -->
		<fieldGroup>
				
				<field id="detalle" local="true" colspan="6">
					<label modpos="force" />
					<helper type="object" xml="pre_main_grid.xml" />
				</field>

		</fieldGroup>
		<!-- FIN -->

        <!-- Si en el detalle de artículos interviene un articulo que no acepta descuento global se cambian estos flags para que utilice una u otra grabacion (idCampoCond) en los movimientos -->	

		<fieldGroup Formstyle="vertical-align:middle;padding:2px 2px 2px 2px;">             

				<field id="sin_dto_global" local="true" noshow="true">
				    <if exp="mi_dto_global + 0 != 0 &amp;&amp; importe_bon + 0 != 0 ">
				        <true>1</true>
				        <false>0</false>
				    </if>
				</field>

				<field id="con_dto_global" local="true" noshow="true">
				    <if exp="mi_dto_global + 0 != 0">
				        <true>'false'</true>
				        <false>'true'</false>
				    </if>
				</field>
				<!-- fin -->
			
				<field id="separator1" local="true" deshabilitado="true" colspan="4" />
					
				<field id="subtotal_movimiento" local="true" deshabilitado="true" modpos="nobr" >
					<label>Sub Total</label>
					<tipo>decimal</tipo>		
					<valor default="true">0.00</valor>
	                <jseval campodestino="neto_movimiento">subtotal_movimiento + 0 - ((subtotal_movimiento + 0) * (bonificaciones_movimiento + 0) / 100)</jseval>
	                <jseval campodestino="importe_bon">((subtotal_movimiento + 0) * (bonificaciones_movimiento + 0) / 100)</jseval>
	                <jseval campodestino="importe_IVA">mi_importe_iva + 0 - ((mi_importe_iva + 0) * (bonificaciones_movimiento + 0) / 100)</jseval>
	                <jseval campodestino="importe_movimiento">neto_movimiento  + (importe_IVA + 0 ) + (importe_exento + 0) </jseval>
					<size>20</size>
				</field>

				<field id="Descu" local="true" colspan="2">
	                <label></label>
					<helper xml="stk_descuentosvolumen_qry.xml" dir="/stock/listas/" type="link" width="400px" height="300px">
					  <parameter source="wstklista_id" target="stklista_id" />                                          
					</helper>
					<valor>Desc.Grales</valor>
					<tipo>varchar</tipo>
				</field>		

				<field id="bonificaciones_movimiento" modpos="nobr" >
					<label>Descuento Gral %</label>
	                <jseval campodestino="neto_movimiento">subtotal_movimiento + 0 - ((subtotal_movimiento + 0) * (bonificaciones_movimiento + 0) / 100)</jseval>
	                <jseval campodestino="importe_bon">((subtotal_movimiento + 0) * (bonificaciones_movimiento + 0) / 100)</jseval>
	                <jseval campodestino="importe_IVA">mi_importe_iva + 0 - ((mi_importe_iva + 0) * (bonificaciones_movimiento + 0) / 100)</jseval>
	                <jseval campodestino="importe_movimiento">neto_movimiento  + (importe_IVA + 0 ) + (importe_exento + 0) </jseval>
					<tipo>decimal</tipo>		
				</field>
				
				<field id="importe_bon"  deshabilitado="true" modpos="nobr" >
			        <label>Descuento $</label>
			        <tipo>decimal</tipo>
			        <valor>0.00</valor>
	                <jseval campodestino="neto_movimiento">subtotal_movimiento + 0 - ((subtotal_movimiento + 0) * (bonificaciones_movimiento + 0) / 100)</jseval>
	                <jseval campodestino="importe_IVA">mi_importe_iva + 0 - ((mi_importe_iva + 0) * (bonificaciones_movimiento + 0) / 100)</jseval>
	                <jseval campodestino="importe_movimiento">neto_movimiento  + (importe_IVA + 0 ) + (importe_exento + 0) </jseval>		         
					<size>20</size>
				</field>
				
				<field id="separator3" local="true" deshabilitado="true"  colspan="4" />

				<field id="neto_movimiento" deshabilitado="true" modpos="nobr" >
					<label>Neto</label>
					<tipo>decimal</tipo>
					<size>20</size>				
				</field>

				<field id="referencia_movimiento" maxsize="160" maxlength="160" colspan="3">
					<label>Observaciones</label>
					<size>40</size>
				</field>      

				<field id="importe_IVA" deshabilitado="true" modpos="nobr">
					<label>IVA</label>
					<tipo>decimal</tipo>
					<size>20</size>				
				</field>

				<field id="micanpro" local="true" deshabilitado="true" colspan="3">
				  <label>Cant. de Productos</label>
				  <actualiza>
						<field id="control_dtogral" destino="cantidad" />
				  </actualiza>
				</field>

				<field id="importe_exento" deshabilitado="true" modpos="nobr">
					<label>Exento</label>
					<valor default="true">0</valor>
					<tipo>decimal</tipo>
					<size>20</size>
				</field>

				<field id="control_dtogral" local="true" deshabilitado="true" noshow="true"  colspan="3">
				  <label>Ctrl</label>
				  <helper type="combo" id="STK_DESCUENTOSVOLUMEN">
					<field id="limite">
					  <expression>round(porcentaje_descuento0)</expression>
					</field>
					<field id="porcentaje_descuento0">
					  <expression>round(porcentaje_descuento0)</expression>
					</field>
					<field id="desde_cantidad">
					  <condicion operador="&lt;=">'[__cantidad__]' AND hasta_cantidad &gt;= '[__cantidad__]'</condicion>
					</field>
					<field id="stklista_id" />
					<field id="cantidad" local="true" />
					<parameter source="wstklista_id" target="stklista_id" />
					<parameter source="micanpro"    target="cantidad" />
				  </helper>
				  <tipo>int</tipo>
				</field>

				<field id="separator4" local="true" deshabilitado="true" colspan="4" />
				
				<field id="importe_movimiento" deshabilitado="true">
					<label modpos="nobr">Total</label>
					<tipo>decimal</tipo>		
					<valor>0</valor>
					<size>20</size>
				    <if exp="true">
					    <true>(neto_movimiento + 0) + (importe_IVA + 0) + (importe_exento + 0) </true>
					    <false>0</false>
					</if>
				</field>			
				
				<!-- Se almacena el importe original por si tiene descuentos globales para poder recalcularlos y tomar este como base de calculo -->
	            <field id="mi_importe_iva" local="true" deshabilitado="true" noshow="true" />

		</fieldGroup> 

		<field id="modulo_vendedores" local="true" noshow="true">
			<label>UNOOCERO</label>
			<valor eval="true"><![CDATA[ strpos($_SESSION['properties']['modulos'],'vendedores') != false ? '1' : '0' ]]></valor>
		</field>

		<fieldGroup local="true" deshabilitado="true" noshow="true">

				<field id="mi_bonificaciones_movimiento">
				    <if exp="mi_dto_global + 0 != 0">
					    <true>0</true>
					    <false>bonificaciones_movimiento</false>
					</if>
				</field>

				<field id="mi_importe_bon">
				    <if exp="mi_dto_global + 0 != 0">
					    <true>0</true>
					    <false>importe_bon</false>
					</if>
				</field>

				<field id="mi_detalle_bon">
				    <if exp="mi_dto_global + 0 != 0">
				        <true>(importe_bon * -1)</true>
				        <false>0</false>
				    </if>
				</field>

				<field id="impresion">
					<parametro id="numerador_param.xml" retorna="impresion" />
				</field>

				<field id="impresora">
					<parametro id="numerador_param.xml" retorna="impresora" />
				</field>

		</fieldGroup> 
        
	</table>
</form>
</histrix>
