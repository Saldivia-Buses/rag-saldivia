<?xml version="1.0" encoding="UTF-8" ?>
    <histrix tipo="crud">
	<title>Tickets Anulados</title>
	 <obs></obs>
		<form>
		    <table id="REG_MOVIMIENTOS">
			
			<field id="id_regmovim" autoinc="true" noshow="true" />

			<field id="subsistema_id" noshow="true" valauto="true" />
			
			<field id="regcuenta_id" noshow="true" />

			<field id="fecha_movimiento">
				<label>Fecha</label>
				<tipo>date</tipo>
				<valor>today</valor>
			</field>           

            <field id="vencimiento_movimiento">
				<label modpos="nobr">Fecha Vto</label>
				<tipo>date</tipo>
				<valor>today</valor>
			</field>
			
			<field id="reg_fecha">
				<label>Fecha Registracion</label>
				<tipo>date</tipo>
				<valor>today</valor>
			</field>

			<field id="referencia_movimiento" valauto="true" deshabilitado="true">
            	<label modpos="nobr">Referencia</label>
            	<valor>ANULADA</valor>
            	<condicion operador="=">'ANULADA'</condicion>
            	<size>25</size>
            </field>

			<field id="nro_cuenta" local="true" required="true" min="1" colstyle="display:none;" deshabilitado="false">
				<label>Cliente</label>
				<helper type="external" xml="regcuenta_nro_movimientos.xml" empty="true" dir="/ayudas/" />
				<size>6</size>
				<expression>REG_CUENTA.nro_cuenta</expression>
			</field>

			<field id="nombre_movimiento" deshabilitado="true">
				<label modpos="nobr">Nombre</label>
				<size>25</size>
			</field>

			<field id="letra_movimiento" deshabilitado="true" colstyle="display:none;">
				<label>Letra</label>
				<actualiza>
					<field id="puesto_movimiento" 	destino="letra" />
				</actualiza>
				<size>1</size>
				<detalle>letra_movimimento</detalle>
			</field>

			<field id="concepto_id">
				<label modpos="nobr">Concepto</label>
				<helper type="combo" id="REG_CONCEPTOS">
					<field id="id_concepto" />
					<field id="descripcion_concepto"/>
					<field id="subsistema_id" />
					<field id="imputacion_concepto" />
				</helper>
				<actualiza>
					<field id="puesto_movimiento" destino="regconcepto_id" />
				</actualiza>
				<detalle>concepto_id</detalle>
			</field>

			<field id="puesto_movimiento" colstyle="display:none;">
				<label>Puesto</label>
				<helper type="combo" id="REG_NUMERADORES" empty="true">
					<field id="puesto" />
					<field id="nombre_puesto">
						<expression>LPAD(puesto,4,'0')</expression>
					</field>
					<field id="letra">
						<condicion operador="=">''</condicion>
					</field>
					<field id="regconcepto_id" oculto="true" />
				</helper>
				<size>4</size>
				<detalle>puesto_movimiento</detalle>
			</field>

			<field id="nro_movimiento" colstyle="display:none;">
				<label modpos="nobr">Nro</label>
			    <format>%08d</format>
			    <size>8</size>
			    <detalle>nro_movimiento</detalle>
		    </field>

		    <field id="numero_movim" Formstyle="display:none;">
		    	<label>Nro Movimiento</label>
		    	<expression>
          			CONCAT(REG_MOVIMIENTOS.letra_movimiento,' ',LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,'0'),'-',LPAD(REG_MOVIMIENTOS.nro_movimiento  ,8,'0'))
        		</expression>
        	</field>

			<field id="domicilio_movimiento" deshabilitado="true" noshow="true">
				<label>Direccion</label>
				<size>25</size>
			</field>
			
			<field id="cuit_movimiento" deshabilitado="true" noshow="true">
				<label modpos="nobr">CUIT</label>
			</field>
			
            <field id="dni_movimiento" deshabilitado="true" noshow="true">
                <label>DNI</label>
            </field>

			<field id="genlocalidad_id" deshabilitado="true" noshow="true">
				<label>Localidad</label>
				<size>15</size>
			</field>

			<field id="iva_id" deshabilitado="true" noshow="true">
				<label modpos="nobr">Cat.Iva</label>
			</field>

			<field id="esadmin" local="true" noshow="true" deshabilitado="true" bloqueafila="true">
		      	<valor eval="true">$_SESSION['administrator'] == 1 ? '0' : '1'</valor>
		    </field>

	    </table>

	    <join>
	    	<tabla id="REG_CUENTA">
	    		<field id="id_regcuenta">
	    			<condicion operador="=">regcuenta_id</condicion>
	    		</field>
	    	</tabla>
	    </join>

	</form>
</histrix>	