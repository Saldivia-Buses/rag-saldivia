<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="ing">
  <title>Modificacion de Movimientos</title>
  <obs></obs>
  <eventos>
	<event id="procesar">close</event>
	<event id="procesar">reload</event>
  </eventos>
  <form>
	<table id="REG_DETALLES">

		<movimientos>
			<relacion id="regdetalles_drop.xml" />
			<relacion id="regdetalles_ins.xml" />
			<relacion id="regmovimientos_recalc.xml" />
		</movimientos>

		<field id="id_regdetalle" noshow="true" esClave="true" deshabilitado="true" />

		<field id="regmovim_id" noshow="true" deshabilitado="true" />

		<field id="_ORDEN" local="true" noshow="true" />

		<field id="borra" noshow="true" local="true">
			<if exp="_ORDEN + 1 == 1">
				<true>'1'</true>
				<false>'0'</false>
			</if>
		</field>

		<field id="codigo_detalle" required="true">
			<label>Cod.</label>
			<helper type="external" xml="stkarticulo_mos.xml" dir="/ayudas" />
			<size>15</size>
		</field>

		<field id="descripcion_detalle">
			<label modpos="nobr" colspan="4">Descripción</label>
			<size>30</size>
		</field>

		<field id="cantidad_detalle" suma="true" forceCellValue="true" validRow="true" validar="true" errorMessage="Debe ingresar una cantidad" style="width:5em;">
			<label modpos="nobr">Unidades</label>
			<tipo>integer</tipo>
			<valor default="true">1</valor>
			<size>5</size>
			<jseval fielddestino="neto_detalle"     actxml="false" suma="true">(precio_venta * cantidad_detalle).toFixed(2)</jseval>
			<jseval fielddestino="micanpro"         actxml="false" total="true">cantidad_detalle</jseval>
		</field>

		<field id="precio_venta">
			<label modpos="nobr">P.Unitario</label>
			<valor default="true">0</valor>
			<jseval fielddestino="neto_detalle"     actxml="false" suma="true">(precio_venta * cantidad_detalle).toFixed(2)</jseval>
		</field>

		<field id="neto_detalle" suma="true">
			<label modpos="nobr">Subtotal</label>
			<tipo>decimal</tipo>
			<if exp="true">
				<true>round((precio_venta + 0 ) * (cantidad_detalle + 0),2)</true>
				<false>0</false>
			</if>					
			<jseval fielddestino="iva_detalle"         actxml="false">(neto_detalle *      (alicuota_iva / 100)).toFixed(2)</jseval>
			<jseval fielddestino="total_detalle"       actxml="false">(neto_detalle * (1 + (alicuota_iva / 100))).toFixed(2)</jseval>
			<jseval fielddestino="subtotal_movimiento" actxml="false" total="true">neto_detalle</jseval>
			<jseval fielddestino="precio_unit_final"   actxml="false">(total_detalle / cantidad_detalle).toFixed(2)</jseval>
			<jseval campodestino="neto_debe">(imputacion_concepto == \'0\' ?  0 : neto_detalle).toFixed(2)</jseval>
			<jseval campodestino="neto_haber">(imputacion_concepto == \'0\' ?  neto_detalle : 0).toFixed(2)</jseval>
		</field>
				
		<field id="alicuota_iva">
			<label modpos="nobr">Alic.</label>
			<tipo>decimal</tipo>
			<helper type="combo" xml="genalicuotas_qry.xml" dir="/ayudas" _empty="true" />				
			<valor>21.00</valor>
			<jseval fielddestino="iva_detalle"   actxml="false">neto_detalle *      (alicuota_iva / 100)</jseval>
			<jseval fielddestino="total_detalle" actxml="false">neto_detalle * (1 + (alicuota_iva / 100))</jseval>
		</field>
				
		<field id="iva_detalle" suma="true">
			<label modpos="nobr">IVA</label>
			<valor default="true">0.00</valor>
			<tipo>decimal</tipo>
			<if exp="true">
				<true>round((neto_detalle + 0 ) * (alicuota_iva + 0) / 100,2)</true>
				<false>0</false>
			</if>
			<jseval fielddestino="total_detalle"  actxml="false">neto_detalle * (1 + (alicuota_iva / 100))</jseval>
			<jseval fielddestino="mi_importe_iva" actxml="false" total="true">iva_detalle</jseval>
			<jseval campodestino="iva_debe">(imputacion_concepto == \'0\' ?  0 : iva_detalle).toFixed(2)</jseval>
			<jseval campodestino="iva_haber">(imputacion_concepto == \'0\' ?  iva_detalle : 0).toFixed(2)</jseval>
		</field>			

		<field id="total_detalle" suma="true" deshabilitado="true">
			<label modpos="nobr">Total</label>
			<tipo>decimal</tipo>
			<detalle>importe_movimiento</detalle>
			<if exp="true">
				<true>neto_detalle + iva_detalle</true>
				<false>0</false>
			</if>
		</field>

	</table>
  </form>
</histrix>	



