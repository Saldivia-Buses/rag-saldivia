<?xml version="1.0" encoding="UTF-8"?>
<histrix tipo="ing" inserta="false" modifica="false" deleteRow="false" imprime="false" log="false" procesa="true" confirma="FACTURAR" preloadData="false" transaccional="true">
	<title>Facturación de Presupuestos</title>
	
	<confirmacion><![CDATA[¿Confirma la operación?]]></confirmacion>
	
	<form>
	<table id="REG_MOVIMIENTOS">

		<!-- INICIO VALIDACIONES -->
		<validation>
			<condition>	<![CDATA[fecha_movimiento == 0]]> </condition>
			<message>Debe especificar un valor para el campo Fecha de Emision.</message>
		</validation>

		<validation>
			<condition>	<![CDATA[vencimiento_movimiento == 0]]>	</condition>
			<message>Debe especificar un valor para el campo Fecha de vencimiento.</message>
		</validation>

		<validation>
			<condition>	<![CDATA[regconcepto_id == 0]]>	</condition>
			<message>Debe especificar un valor para el campo Concepto.</message>
		</validation>

		<validation>
			<condition>	<![CDATA[puesto_movimiento == 0]]> </condition>
			<message>Debe especificar un valor para el campo Punto de venta.</message>
		</validation>

		<validation>
			<condition>	<![CDATA[stkdeposito_id == 0]]>	</condition>
			<message>Debe especificar un valor para el campo Depósito.</message>
		</validation>

		<validation>
			<condition>	<![CDATA[facturar == 0]]>	</condition>
			<message>Debe seleccionar un comprobante</message>
		</validation>

		
		<!-- FIN VALIDACIONES -->

		<movimientos cabecera="facturar_presup_cab.xml" >
			<relacion id="mos_rrule_movimientos_ins.xml" /> CREO REG_MOVIMIENTO
			<relacion id="mos_rrule_detalle_dup.xml" />     DUPLICO DETALLE E IMPUTO
			<relacion id="mos_rrule_minuta_dup.xml" />		DUPLICO MINUTA
			<relacion id="mos_rrule_marcamovimiento.xml" />	MARCA PRESUPUESTO FACTURADO
			<relacion id="mos_rrule_numerador_upd.xml" />   ACTUALIZO NUMERADOR
			<relacion id="mos_rrule_fiscal.xml" />          EMITE FISCAL / WEBSERVICE
			<relacion id="mos_rrule_print.xml" />           IMPRIMO
		</movimientos>

		<filters>		
			
			<field id="puesto_movimiento" required="true"  >
				<label>Puesto P/ Facturar</label>
				<operador>=</operador>
			</field>

			<field id="separador_filtro" local="true" modpos="nobr" deshabilitado="true" noshow="true" />

			<field id="fecha_movimiento" required="true" modpos="nobr">
			    <label>Desde</label>
			    <operador>&gt;=</operador>
			    <valor eval="true">date("d/m/Y", mktime(0, 0, 0, date("m")  , 1, date("Y")))</valor>
			</field>

			<field id="separador_filtro" local="true" modpos="nobr" deshabilitado="true" noshow="true" />

            <field id="fecha_movimiento" required="true"  modpos="nobr">
			    <label>Hasta</label>
			    <operador>&lt;=</operador>
			    <valor>today</valor>
			</field>	

			<field id="separador_filtro" local="true" modpos="nobr" deshabilitado="true" noshow="true"/>

			<field id="nro_cuenta"  modpos="nobr">
				<label>Cuenta</label>
				<operador>=</operador>
			</field>

			<field id="separador_filtro" local="true" modpos="nobr" deshabilitado="true" noshow="true"/>

			<field id="nombre" local="true"  deshabilitado="true" sincelda="true" modpos="nobr"/>

		</filters>

		<fieldGroup id="DatosFactura" noshow="true">
			<field id="_ORDEN" local="true" />
			<field id="subsistemavendedor_id" local="true" valauto="true" />
			<field id="subsistematransporte_id" local="true" valauto="true" />					
			<field id="stklista_id" />
			<field id="alicuota_iva" />
			<field id="bonificaciones_movimiento" />
			<field id="importe_exento" />
			<field id="importe_periodo" />
			<field id="importe_percepcion" />
			<field id="importe_ibr" />
			<field id="importe_nogravado" />
			<field id="alicuota_percepcion" />
			<field id="regcuentatransporte_id" />
			<field id="regforma_id" />
			<field id="cantidad_bultos" />
			<field id="domicilio_movimiento" />
			<field id="iva_id" />
			<field id="cuit_movimiento" />
			<field id="referencia_movimiento" />
			<field id="contacto_movimiento" />
			<field id="tiposervicio_afip" />
		</fieldGroup>

		<fieldGroup id="DatosPresupuesto" noshow="true">

    		<field id="genlocalidad_id"  />

      		<field id="dni_movimiento"   />

			<field id="separador_filtro" local="true" modpos="nobr" deshabilitado="true" noshow="true" Formstyle="width:30px;" />

			<field id="id_regmovim" />	

			<field id="regcuenta_id" />

			<field id="subsistema_id" local="true"><!-- SUBSISTEMA FACTURA -->
				<actualiza>
					<field id="puesto_movimiento" destino="subsistema_id" />
				</actualiza>
			</field>

			<field id="concepto_id" />	

			<field id="subsistema_presup" local="true">	
				<!-- <condicion operador="=">REG_MOVIMIENTOS.subsistema_id</condicion> no deberia ir esto, por parametro-->
			</field>

    		<field id="nombre" local="true" noshow="true">
    			<size>40</size>
    		</field>

			<field id="vencimiento_movimiento" noshow="true">
				<label>Vto</label>
				<expression>date_add(now(), INTERVAL ifnull(REG_FORMAS.plazo, 0 ) DAY)</expression>
				<tipo>date</tipo>
			</field>

			<field id="descripcion_concepto" tabla="REG_CONCEPTOS" noshow="true">
				<label>Concepto</label>				
			</field>

			<field id="letra_movimiento" noshow="true">
				<expression>GEN_IVA.letra</expression>
				<actualiza>
					<field id="puesto_movimiento" destino="letra" />
				</actualiza>
			</field>
			
			<field id="puesto_origen" noshow="true" local="true"  modpos="nobr">
				<label>Punto de venta</label>
				<helper type="combo" id="REG_NUMERADORES" empty="true">
					<field id="puesto" />
					<field id="nombre_puesto">
						<expression>LPAD(puesto,4,'0')</expression>
					</field>
				</helper>
				<condicion operador="=">REG_MOVIMIENTOS.puesto_movimiento</condicion>
			</field>	

			<field id="puesto_movimiento" local="true" noshow="true">
				<label />
				<helper type="combo" id="REG_NUMERADORES" empty="true">
					<field id="puesto" />
					<field id="nombre_puesto">
						<expression>LPAD(puesto,4,'0')</expression>
					</field>
					<field id="letra" oculto="true" />
					<field id="regconcepto_id" oculto="true" />
					<field id="subsistema_id" oculto="true" />
				</helper>
				<size>4</size>
			</field>

			<field id="mar_movimiento" noshow="true">
				<condicion operador="=">0 or mar_movimiento IS NULL</condicion>
			</field>

			<field id="tiene_ctb" local="true" noshow="true">
			    <label>Contabilidad</label>
			    <valor eval="true"><![CDATA[ strpos($_SESSION['properties']['modulos'],'contabilidad') != false ? '1' : '0' ]]></valor>
			</field>

			<field id="graba_minuta" local="true" refresh="true" noshow="true">
				<if exp="facturar + 0 == 1 &amp;&amp; tiene_ctb + 0 == 1">
				    <true>'1'</true>
				    <false>'0'</false>
				</if>
			</field>

		</fieldGroup>


		<fieldGroup colstyle="vertical-align:middle; text-align:center; padding:2px 2px 2px 2px;">

			<field id="fecha_movimiento">
				<label>Fecha</label>
				<tipo>date</tipo>
			</field>

		    <field id="nro_cuenta" tabla="REG_CUENTA" >
				<label>Cliente</label>
				<helper type="external" xml="regcuenta_solamente_nro_qry.xml" dir="/ayudas">
	    		    <field id="subsistema_id">
	    		    	<condicion operador="=" valorde="subsistema_id" />
	    		    </field>
	    		    <order>
	        			<field id="nombre_cuenta" />
	    		    </order>
				</helper>				
    		</field>




			<field id="nombre_movimiento">
				<expression>REG_CUENTA.nombre_cuenta</expression>
				<label>Nombre</label>				
			</field>

			<field id="regcuentavendedor_id" _noshow="true">
				<label>Vendedor</label>
				<helper type="combo" xml="regcuenta_solamente_qry.xml" dir="/ayudas" empty="true">
					<field id="subsistema_id">
						<condicion operador="=" valorde="subsistemavendedor_id">'[__subsistemavendedor_id__]'</condicion>
					</field>
				</helper>
			</field>

			<field id="nro_movimiento">
				<expression>CONCAT(REG_CONCEPTOS.abreviacion_concepto,' ',REG_MOVIMIENTOS.letra_movimiento,' ',LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,'0'),'-',LPAD(REG_MOVIMIENTOS.nro_movimiento,8,'0'))</expression>
				<label>Comprobante</label>
				<helper type="link" title="Comprobante">
					<parameter source="id_regmovim" target="id_regmovim" />
				</helper>
				<attribute id="linkint">imprime_concepto</attribute>				
			</field>		

			<field id="neto_movimiento" suma="true">
				<label>Neto</label>
				<tipo>numeric</tipo>
			</field>

			<field id="importe_iva" suma="true">
				<label>IVA</label>
				<tipo>numeric</tipo>
			</field>			

			<field id="importe_movimiento" suma="true">
				<label>Importe</label>				
				<tipo>numeric</tipo>
			</field>		

			<field id="estado_cuenta" noshow="true" style="text-align: right;">
				<label>Estado Cuenta</label>
				<expression having="false">
					IF( (VW_SALDOS.limite_credito > 0) and (VW_SALDOS.saldo_valores + VW_SALDOS.saldo_cuenta + importe_movimiento > VW_SALDOS.limite_credito ), 'CREDITO EXCEDIDO', (VW_SALDOS.saldo_valores + VW_SALDOS.saldo_cuenta) )
				</expression>
			</field>
		
			<field id="tilde_fact" local="true" editable="true" refresh="true" deshabilitado="false">
				<valor>0</valor>
				<tipo>check</tipo>
			</field>

			<field id="facturar" local="true" noshow="true">
				<if exp="tilde_fact + 0 == 1">
					<true>'1'</true>
					<false>'0'</false>
				</if>
			</field>

		</fieldGroup>
		
		<fieldGroup id="DatosImpresion" noshow="true">
		
			<field id="imprime_concepto">
				<expression>REG_NUMERADORES.ejecuta</expression>
			</field>

			<field id="xmlImpresion" local="true">
				<expression sql="true">select ejecuta from REG_NUMERADORES where puesto = '[__puesto_movimiento__]' and REG_NUMERADORES.letra = '[__letra_movimiento__]' and REG_NUMERADORES.regconcepto_id = '[__codigo_concepto_factura__]' limit 1</expression>
			</field>

			<field id="printer" local="true">
				<expression sql="true">select IF(fiscal = 1 AND printer = 'WSAFIP', '', printer) from REG_NUMERADORES where puesto = '[__puesto_movimiento__]' and REG_NUMERADORES.letra = '[__letra_movimiento__]' and REG_NUMERADORES.regconcepto_id = '[__codigo_concepto_factura__]' limit 1</expression>
				
			</field>
			
			<field id="fiscal" local="true">
				<expression sql="true">select fiscal from REG_NUMERADORES where puesto = '[__puesto_movimiento__]' and REG_NUMERADORES.letra = '[__letra_movimiento__]' and REG_NUMERADORES.regconcepto_id = '[__codigo_concepto_factura__]' limit 1</expression>
			</field>
			
		</fieldGroup>



		<group>
			<field id="id_regmovim" />
		</group>

		<order>
    		<field id="nro_cuenta"/>
    	</order>
	
	</table>
	
	<join>
		<table id="REG_CUENTA">
			<field id="id_regcuenta">
				<condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
			</field>
		</table>
	</join>

	<join tipo="left">
		<table id="REG_FORMAS">
			<field id="id_regforma">
				<condicion operador="=">REG_CUENTA.regforma_id</condicion>
			</field>
		</table>
	</join>

	<join tipo="left">
		<table id="GEN_SUBSISTEMAS">
			<field id="id_subsistema">
				<condicion operador="=">REG_CUENTA.subsistema_id</condicion>
			</field>
		</table>
	</join>

	<join tipo="left">
		<table id="REG_CONCEPTOS">
			<field id="id_concepto">
				<condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
			</field>
		</table>
	</join>
	
	<join tipo="left">
		<table id="REG_NUMERADORES">
			<field id="subsistema_id">
				<condicion operador="=">REG_MOVIMIENTOS.subsistema_id</condicion>
			</field>
			<field id="regconcepto_id">
				<condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
			</field>
			<field id="puesto">
				<condicion operador="=">REG_MOVIMIENTOS.puesto_movimiento</condicion>
			</field>
			<field id="letra">
				<condicion operador="=">REG_MOVIMIENTOS.letra_movimiento</condicion>
			</field>
		</table>
	</join>

	<join tipo="left">
		<table id="VW_SALDOS">
			<field id="id_regcuenta">
				<condicion operador="=">REG_CUENTA.id_regcuenta</condicion>
			</field>
		</table>
	</join>

	<join tipo="left">
		<table id="GEN_IVA">
			<field id="id_iva">
				<condicion operador="=">REG_CUENTA.iva_id</condicion>
			</field>
		</table>
	</join>

	</form>
</histrix>