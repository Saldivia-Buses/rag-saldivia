<?xml version="1.0" encoding="UTF-8" ?>
<histrix tipo="fichaing" 
class="consultaancha" 
inserta="false" 
modifica="false">
    <title>Ingreso de factura anulada</title>
    <obs></obs>
    <form>
      <table id="REG_MOVIMIENTOS" label="MOVIMIENTOS">
        <movimientos>
                <relacion id="regmovimiento_ins.xml" />
        </movimientos>

	<field id="id_regmovim" esClave="true" autoInc="true" noshow="true" />

      	<field id="regcuenta_id" noshow="true">
		<helper type="external" xml="regcuenta_solamente_qry.xml" dir="/ayudas" empty="true" />
		<label>Cuenta</label>
		<help>Código de Cuenta</help>
      	</field>
      
	<field id="nombre" local="true" noshow="true">
          <label modpos="nobr"> </label>
          <size>40</size>
        </field>

        <field id="concepto_id" >
		<helper type="combo" xml="regconcepto_qry.xml" dir="/ayudas" />
		<label modpos="nobr">Concepto</label>
	</field>

        <field id="letra_movimiento" _noshow="true">
          <label modpos="nobr">Letra</label>
              <helper type="combo">
            	  <option value=""></option>
                  <option value="A">A</option>
		  <option value="B">B</option>
                  <option value="C">C</option>
              </helper>
        </field>
        
        <field id="puesto_movimiento">
          <label modpos="nobr">Nro Factura</label>
          <size>4</size>
        </field>
                            
        <field id="nro_movimiento" sincelda="true">
          <label modpos="nobr">-</label>
          <size>8</size>
        </field>
        
		<field id="fecha_movimiento" copia="vencimiento_movimiento">
			<label>Fecha</label>
			<help>Fecha movimiento</help>
			<tipo>date</tipo>
		</field>
        
		<field id="vencimiento_movimiento" >
			<label>Vencimiento</label>
			<help>Fecha de Vencimiento</help>
			<valor eval="true">today</valor>
			<tipo>date</tipo>
		</field>
        
		<field id="reg_fecha">
			<label modpos="nobr">Registracion</label>
			<help>Corresponde a la Fecha de Registracion Contable</help>
			<tipo>date</tipo>
		</field>
        
        <field id="referencia_movimiento">
    	    <label colspan="5">Referencia</label>
	    <valor>ANULADO</valor>
	    <size>90</size>
	</field>

        <field id="nombre_movimiento" noshow="true">
	    <valor>ANULADO</valor>
	    <size>90</size>
	</field>





        <field id="importe_movimiento" deshabilitado="true" >
          <label >Total</label>
           <valor>0</valor>
        </field>        
		

      </table>
  </form>
</histrix>
