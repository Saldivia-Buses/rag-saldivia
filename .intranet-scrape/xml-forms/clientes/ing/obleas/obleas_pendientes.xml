<?xml version="1.0"?>
<histrix tipo="consulta">
  <title>Planilla de Pendientes</title>
  <obs/>
  <form>
    <table id="REG_MOVIMIENTOS" label="Planilla de Pendientes">

    <filters>  
      <field id="fecha_movimiento">
        <label>Desde Fecha</label>
        <operador>&gt;=</operador>
        <valor>today</valor>
      </field>     
      <field id="fecha_movimiento">
        <label>Hasta Fecha</label>
        <operador>&lt;=</operador>
        <valor>today</valor>
      </field>
      <field id="tabla_detalle">
        <label>Dominio</label>
        <operador>like</operador>
      </field>
    </filters>    

    <field id="id_regmovim" noshow="true" />
    <field id="subsistema_id" noshow="true"/> 
    <field id="regcuenta_id" noshow="true" />
    <field id="id_regdetalle" tabla="REG_DETALLES" noshow="true" /> 
    <field id="id_factura" noshow="true">
      <expression>RM1.id_regmovim</expression>
    </field>

    <field id="concepto_id" noshow="true"> 
      <condicion operador="=">(SELECT HTXOPTIONS.option_value FROM HTXOPTIONS WHERE HTXOPTIONS.option_name = "SIS::02::concepto_recibo_vend")</condicion>
    </field>

    <field id="letra_movimiento" noshow="true"> 
      <condicion operador="=">'X'</condicion>
    </field>  

    <field id="nro_movimiento">
      <label>Comprobante</label>
      <expression>CONCAT(RM1.letra_movimiento,' ',LPAD(RM1.puesto_movimiento,4,'0'),'-',LPAD(RM1.nro_movimiento  ,8,'0'))</expression>
    </field>      
    
    <field id="descripcion_detalle" tabla="REG_DETALLES">
      <label>Detalle</label>
      <tipo>varchar</tipo>
    </field>

    <field id="tabla_detalle" tabla="REG_DETALLES">
      <label>Dominio</label>
      <tipo>varchar</tipo>   
    </field>

    <field id="codigo_serie" tabla="REG_DETALLES">
      <label>Oblea</label>
      <tipo>varchar</tipo>         
    </field>
    
    <field id="fecha_movimiento" tabla="RM1">      
      <label>Fec.Emision</label>  
      <tipo>date</tipo>
    </field>
    
    <field id="fecha_vencimiento" tabla="REG_DETALLES">   
      <label>Fec.Vto.</label>    
      <tipo>date</tipo>           
    </field>  

    <field id="nro_recibo">
      <label>Rec. Cond.</label>
      <expression>CONCAT(REG_MOVIMIENTOS.letra_movimiento,' ',LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,'0'),'-',LPAD(REG_MOVIMIENTOS.nro_movimiento  ,8,'0'))</expression>
    </field>  

    <field id="id_regmovim_acredor"  local="true">
      <expression>(SELECT RM2.id_regmovim FROM REG_MOVIMIENTOS RM2 
                  WHERE RM2.subsistema_id = '05' 
                        AND RM2.letra_movimiento = REG_MOVIMIENTOS.letra_movimiento
                        AND RM2.puesto_movimiento = REG_MOVIMIENTOS.puesto_movimiento 
                        AND RM2.nro_movimiento = REG_MOVIMIENTOS.nro_movimiento)
      </expression>
    </field>
 
    <field id="genera_movs" local="true">
      <label>Generar</label>
      <valor>Actualizar</valor>
      <helper type="link" xml="actualizar_obleas.xml">
        <parameter source="id_regmovim" target="regoblea_id" />
        <parameter source="id_factura" target="regmovim_id" />
        <parameter source="id_regmovim_acredor" target="id_regmovim_acredor" />
      </helper>
    </field>

    <order>
      <field id="fecha_movimiento" tipoOrden="DESC" />
      <field id="nro_movimiento"   tipoOrden="DESC" />
    </order>

  </table>
  
  <join>
    <table id="REG_IMPUTACIONES" as="RI">
      <field id="regmovim0_id">
        <condicion operador="=">REG_MOVIMIENTOS.id_regmovim</condicion>
      </field>
    </table>
  </join>

  <join>
    <table id="REG_IMPUTACIONES" as="RI2">
      <field id="regmovim_id">
        <condicion operador="=">RI.regmovim_id</condicion>
      </field>
      <field id="regmovim0_id">
        <condicion operador="!=">REG_MOVIMIENTOS.id_regmovim</condicion>
      </field>
    </table>
  </join>

  <join>
    <table id="REG_MOVIMIENTOS" as="RM1">
      <field id="id_regmovim">
        <condicion operador="=">RI2.regmovim0_id</condicion>
      </field>
      <field id="subsistema_id">
        <condicion operador="=">'02'</condicion>
      </field>      
    </table>
  </join>

  <join tipo="left">
    <table id="REG_DETALLES">
      <field id="regmovim_id">
        <condicion operador="=">RM1.id_regmovim</condicion>
      </field>              
    </table>
  </join>

  <join>
    <table id="CAJ_CTBCUENTA_AUX">
      <field id="codigo">
        <condicion operador="=">REG_DETALLES.codigo_detalle</condicion>
      </field>
      <field id="con_dominio">
        <condicion operador="=">'01'</condicion>
      </field>      
    </table>
  </join>    

  <join>
    <table id="REG_CUENTA">
      <field id="id_regcuenta">
        <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
      </field>
    </table>
  </join>

  </form>
</histrix>