<?xml version="1.0"?>
<histrix tipo="consulta">
  <title>Planilla de Pendientes</title>
  <obs/>
  <form detalle="detalle_pend_obleas.xml" inline="true">
  <table id="REG_MOVIMIENTOS" label="Planilla de Pendientes">

    <filters>    
      <field id="fecha_movimiento">
        <label>Desde Fecha</label>
        <operador>&gt;=</operador>
        <valor>today</valor>
      </field>   
      <field id="fecha_movimiento">
        <label modpos="nobr">Hasta Fecha</label>
        <operador>&lt;=</operador>
        <valor>today</valor>
      </field>
    </filters>    

  <fieldGroup id="DEBUG" noshow="true">

    <field id="id_regmovim">
      <detalle>regmovim_id</detalle>
    </field>
    
    <field id="subsistema_id" />
    
    <field id="tipo_concepto" tabla="REG_CONCEPTOS" />

    <field id="regcuenta_id" />

    <field id="fecha_movimiento">
      <tipo>date</tipo>
    </field>  

    <field id="rubro_id" tabla="CAJ_CTBCUENTA_AUX" />
    
    <field id="codigo_serie" tabla="REG_DETALLES">
      <condicion operador="=">''</condicion>
    </field>
  
  </fieldGroup>
  
  <field id="nro_cuenta" tabla="REG_CUENTA">
    <label>Nro. Cliente</label>
  </field>

  <field id="nombre_cuenta" tabla="REG_CUENTA">
    <label>Cliente</label>
  </field>

  <field id="abreviacion_concepto" tabla="REG_CONCEPTOS">
    <label>Tipo</label>
  </field>

  <field id="nro_movimiento">
    <label>Nro. Comp.</label>
    <expression>CONCAT(REG_MOVIMIENTOS.letra_movimiento,' ',LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,'0'),'-',LPAD(REG_MOVIMIENTOS.nro_movimiento  ,8,'0'))</expression>
  </field>      

  <field id="descripcion_detalle" tabla="REG_DETALLES">
    <label>Detalle</label>
    <tipo>varchar</tipo>
  </field>

  <field id="genera_movs" local="true">
    <label>Generar</label>
    <valor>Actualizar</valor>
    <helper type="link" xml="genera_recibo_obleas.xml">
      <parameter source="id_regmovim" target="regmovim_id" />
    </helper>
  </field>

  </table>

  <join tipo="left">
    <table id="REG_DETALLES">
      <field id="regmovim_id">
        <condicion operador="=">REG_MOVIMIENTOS.id_regmovim</condicion>
      </field>
    </table>
  </join>

  <join>
    <table id="CAJ_CTBCUENTA_AUX">
      <field id="codigo">
        <condicion operador="=">REG_DETALLES.codigo_detalle</condicion>
      </field>
      <field id="con_dominio">
        <condicion operador="=">'01'</condicion>
      </field>        
    </table>
  </join>

  <join>
    <table id="REG_CONCEPTOS">
      <field id="id_concepto">
        <condicion operador="=">REG_MOVIMIENTOS.concepto_id</condicion>
      </field>
    </table>
  </join>

  <join>
    <table id="REG_CUENTA">
      <field id="id_regcuenta">
        <condicion operador="=">REG_MOVIMIENTOS.regcuenta_id</condicion>
      </field>
    </table>
  </join>

</form>
</histrix>  