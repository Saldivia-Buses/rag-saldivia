<?xml version="1.0"?>
<histrix tipo="fichaing" preFetch="true" inserta="false" imprime="false" modifica="false" borra="false" procesa="true">
  <title>Generador de Obleas</title>
  <obs/>
  <form>
  <table id="REG_DETALLES" label="Generador de Obleas">

  <movimientos>          
    <relacion id="pos_regdetalles_oblea_upd.xml" /> <!-- ACTUALIZA REG_DETALLES (OBLEA, DOMINIO, VENCIMIENTO) -->
    <relacion id="regmovimientos_rec_upd.xml" /> <!-- ACTUALIZA COMPROBANTE DE OBLEA -->
    <relacion id="regmovimientos_rec_upd_prov.xml" /> <!-- ACTUALIZA FACTURA EN ACREDOR -->
  </movimientos>

  <field id="id_regdetalle" noshow="true" />

  <field id="regmovim_id" noshow="true" />

  <field id="subsistema_id" tabla="REG_MOVIMIENTOS" noshow="true" />

  <field id="regcuenta_id" tabla="REG_MOVIMIENTOS" noshow="true" />

  <field id="fecha_movimiento" tabla="REG_MOVIMIENTOS" noshow="true" />

  <field id="separator_1" local="true" style="background-color:#000;color:#fff;text-align:center;" deshabilitado="true" colspan="9">
    <valor>Datos Factura</valor>
  </field>

  <field id="separator_2" local="true" style="height:5px;" deshabilitado="true" colspan="9" />

  <field id="nro_movimiento" deshabilitado="true">
    <label colspan="9">Nro. Movimiento</label>
    <expression>CONCAT(REG_MOVIMIENTOS.letra_movimiento,' ',LPAD(REG_MOVIMIENTOS.puesto_movimiento,4,'0'),'-',LPAD(REG_MOVIMIENTOS.nro_movimiento  ,8,'0'))</expression>
    <size>50</size>
  </field>
  
  <field id="detalle" deshabilitado="true">
    <label colspan="9">Detalle</label>
    <expression>concat(codigo_detalle,' (',descripcion_detalle,')')</expression>
    <size>50</size>
  </field>

  <field id="neto_detalle" deshabilitado="true">
    <label>Imp. Neto</label>
  </field>

  <field id="iva_detalle" deshabilitado="true">
    <label modpos="nobr">Imp. Iva</label>
  </field>

  <field id="total_detalle" deshabilitado="true">
    <label modpos="nobr">Imp. Total</label>
  </field>

  <field id="tabla_detalle">
    <label>Dominio</label>
  </field>

  <field id="codigo_serie">
    <label modpos="nobr">Nro. Oblea</label>
    <jseval campodestino="referencia_recibo">\'Oblea_\'+ \'codigo_serie\'</jseval>  
  </field>

  <field id="fecha_vencimiento">
    <label modpos="nobr">Vencimiento</label>
  </field>

  <field id="separador_1" local="true" style="height:5px;" deshabilitado="true" colspan="9" />

  <field id="separador_2" local="true" style="background-color:#000;color:#fff;text-align:center;" deshabilitado="true" colspan="9" >
    <valor>Datos Oblea</valor>
  </field>

  <field id="separador_3" local="true" style="height:5px;" deshabilitado="true" colspan="9" />

  <field id="letra_recibo" local="true">
    <label>Letra</label>
    <helper type="combo" empty="false" >
      <option value="C">C</option>
      <option value="X">X</option>
    </helper>
    <size>1</size> 
  </field>

  <field id="puesto_recibo" local="true" maxlength="2">
    <label modpos="nobr">Puesto</label>
    <size>2</size>           
  </field>

  <field id="numero_recibo" local="true" maxlength="8">
    <label modpos="nobr">Numero</label>
    <size>8</size>       
  </field>   

  <field id="referencia_recibo" local="true" deshabilitado="true">
    <label>Referencia</label>
    <size>50</size>
  </field> 

  <field id="importe_recibo" local="true">
    <label modpos="nobr">Importe</label>
    <expression>ABS(RECIBO_GENERAL.saldo_movimiento)</expression>       
  </field> 

  <field id="fpv_movimiento" local="true">
    <label modpos="nobr">Aprobado</label>
    <valor>today</valor>
    <tipo>date</tipo>
  </field> 

  <field id="separador_4" local="true" style="height:5px;" deshabilitado="true" colspan="9" />

  <field id="separador_5" local="true" style="background-color:#000;color:#fff;text-align:center;" deshabilitado="true" colspan="9" >
    <valor>Datos Acredor</valor>
  </field>

  <field id="separador_6" local="true" style="height:5px;" deshabilitado="true" colspan="9" />

  <field id="nombre_acredor" local="true">
    <label>Acredor</label>
    <expression>(SELECT nombre_cuenta FROM REG_CUENTA WHERE REG_CUENTA.id_regcuenta = '[__cuenta_proveedor__]' LIMIT 1)</expression>
  </field> 

  <field id="cuit_acredor" local="true">
    <label modpos="nobr">CUIT</label>
    <expression>(SELECT cuit_cuenta FROM REG_CUENTA WHERE REG_CUENTA.id_regcuenta = '[__cuenta_proveedor__]' LIMIT 1)</expression>
  </field> 

  <field id="separador_7" local="true" style="height:5px;" deshabilitado="true" colspan="9" />
    
  <fieldGroup id="DEBUG" noshow="true">
    <field id="id_recibo_general">
      <expression>RECIBO_GENERAL.id_regmovim</expression>
    </field>

    <field id="concepto_recibo" local="true" valauto="true">
      <helper type="parameter" id="SIS::02::concepto_recibo_vend">
        <label>Valor del REG_CONCEPTOS.id_regconceptos para comprobantes de obleas</label>
        <defaultValue>1</defaultValue>
      </helper>            
    </field>

    <field id="concepto_proveedor" local="true" valauto="true">
        <helper type="parameter" id="SIS::01::concepto_recibo_prov">
            <label>Valor del REG_CONCEPTOS.id_regconceptos para comprobante ACREDOR</label>
            <defaultValue>1</defaultValue>
        </helper>            
    </field>  

    <field id="cuenta_proveedor" local="true" valauto="true">
        <helper type="parameter" id="SIS::02::oblea_proveedor">
            <label>Id Acredor</label>
            <defaultValue>1</defaultValue>
        </helper>            
    </field>   

    <field id="id_regmovim_acredor" local="true" />
    <field id="regoblea_id" local="true" />
    
    <field id="subsistema_acredor" local="true">
      <expression>(SELECT subsistema_id FROM REG_CUENTA WHERE REG_CUENTA.id_regcuenta = '[__cuenta_proveedor__]' LIMIT 1)</expression>
    </field> 

    <field id="iva_acredor" local="true">
      <expression>(SELECT iva_id FROM REG_CUENTA WHERE REG_CUENTA.id_regcuenta = '[__cuenta_proveedor__]' LIMIT 1)</expression>
    </field> 

  </fieldGroup>

  </table>

  <join>
    <table id="CAJ_CTBCUENTA_AUX">
      <field id="codigo">
        <condicion operador="=">REG_DETALLES.codigo_detalle</condicion>
      </field>
    </table>
  </join>

  <join>
    <table id="REG_MOVIMIENTOS">
      <field id="id_regmovim">
        <condicion operador="=">REG_DETALLES.regmovim_id</condicion>
      </field>
    </table>
  </join>

  <join>
    <table id="REG_IMPUTACIONES">
      <field id="regmovim0_id">
        <condicion operador="=">REG_MOVIMIENTOS.id_regmovim</condicion>
      </field>
    </table>
  </join>

  <join>
    <table id="REG_MOVIMIENTOS" as="RECIBO_GENERAL">
      <field id="id_regmovim">
        <condicion operador="=">REG_IMPUTACIONES.regmovim_id</condicion>
      </field>
    </table>
  </join>

</form>
</histrix>   