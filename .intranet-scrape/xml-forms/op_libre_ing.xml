<?xml version="1.0" encoding="UTF-8"?>
<histrix graboasiento="true" transaccional="true" tipo="ing"  llenoTemporal="false"   imprime="false"  impresion="cctmovim_OP.xml">
	<title>Orden de pago LIBRE</title>
	<obs/>
	<form >
		<table id="CCTMOVIM" label="ORDEN DE PAGO LIBRE" idCampoCond="imputar" >
<!--			<importar xml="op_libre_cctmovim_select.xml"  label="Seleccionar Facturas" titulo="Seleccione Facturas">
				<field id="ctacod"></field>
			</importar>
			-->
			<movimientos cabecera="op_libre_cab.xml"> 
<!--				<relacion id="op_libre_cajcompr_ingmov.xml">	</relacion> -->
<!--				<relacion id="op_libre_cajmovim_ins.xml">	</relacion> --> 
				<relacion id="op_libre_cajmovimiento_ins.xml">	</relacion>
			</movimientos> 
			
			<field id="siscod" oculto="true">
				<label>Cod.</label>
				<help></help>
					<valor>'01'</valor>
				<condicion operador="=">'01'</condicion>
			</field>
			<field id="_ORDEN" oculto="true">
				<label>Orden</label>
			</field>
			
			<field id="cuenta" local="true" ctbcuenta="1">
				<label>Cuenta Ctb</label>
				<ayuda_ex id="CTBCUENT">
					<field id="ctbcod">
						
					</field>
					<field id="ctbnom">
						<detalle>ctanom</detalle>
					
					</field>					
					<field id="ctbhab">
						<condicion operador="=">1</condicion>
					</field>					

					<field id="cajconce">
						<expression>select cajcod from CAJCONCE where ctbcod__1 = ctbcod and cajtip = 1 limit 1</expression>
						
						<detalle>cajconce</detalle>
					</field>

				</ayuda_ex>

			</field>
			<field id="cajconce" local="true" deshabilitado="true">
				<label>conce</label>
			</field>
			<field id="ctanom" local="true" deshabilitado="true">
				<label>Nombre Cuenta</label>

			</field>
			
			
			
			
			
			<!--
			<field id="concod"  deshabilitado="true" tabla="CCTCONCE" noshow="true">
				<label>conc</label>
				<help>Tipo de Comprobante</help>
			</field>
			<field id="condes" oculto="true" tabla="CCTCONCE">
				<label>Tipo</label>
				<help>Tipo de Comprobante</help>
			</field>
			<field id="movfec" deshabilitado="true">
				<label modpos="nobr">Fecha</label>
				<help></help>

			</field>

			<field id="movnpv" deshabilitado="true">
				<label modpos="nobr">npv</label>
				<help>Comprobante</help>
				<format>%04d</format>

				
			</field>
			<field id="movnro" deshabilitado="true">
				<label modpos="nobr"/>
				<help>Numero</help>
				<format>%012d</format>
-
				
			</field>
-->			
<!--			<field id="neto" suma="true">
				<label >Neto Gravado</label>
				<help></help>
				
			</field> -->
			<field id="movimp" deshabilitado="true">
				<label PDFsize="12" posx="130" posy="+1">Total Pago</label>
				<help></help>
				<format>%01.2f</format>
				
			</field>

			<field id="movsal" suma="true"  ctbimporte="1" calcsuma="true">
				<label>Imputado</label>
				<help></help>
				<condicion operador="!=">0</condicion>

				
			</field>
			<field id="salant" local="true" noshow="true">
				<label>salant</label>
				<help></help>
			</field>
			
			<field id="newsaldo" local="true" deshabilitado="true">
				<label>Saldo</label>
				<if exp="true" operador="=">
					<true>salant - movsal</true>
					<false>0</false>
				</if>
				<tipo>numeric</tipo>
			</field>			
			<field id="acum" local="true" noshow="true" suma="true" retroalimenta="true">
				<label>acum</label>
				<if exp="true" operador="=">
					<true>movsal</true>
					<false>0</false>
				</if>
				<tipo>numeric</tipo>
			</field>	
			<field id="apagar" local="true" deshabilitado="true"  >
				<label>apagar</label>
				<if exp="true" operador="=">
					<true>acum - (cajimp + 0)</true>
					<false>0</false>
				</if>
				<tipo>numeric</tipo>
			</field>			
			<field id="imputar" local="true"  noshow="true">
				<valor>1</valor>
			</field>				
			<field id="movcta"  noshow="true">
				<valor>0</valor>
			</field>			
			<field id="movlet"  noshow="true">
			</field>			

			<field id="movipv"  noshow="true">
			</field>			
			<field id="movinc"  noshow="true">
			</field>			
			<field id="zoncod"  noshow="true">
			</field>			
		
		</table>
		<join tipo="left">
			<table id="CCTCONCE">
				<field id="siscod" oculto="true">
					<label>cctcuent.siscod</label>
					<condicion operador="=">CCTMOVIM.siscod</condicion>
				</field>
				<field id="concod" oculto="true">
					<condicion operador="=">CCTMOVIM.concod</condicion>
				</field>
				<field id="condes" oculto="true"></field>
			</table>
		</join>
		<join tipo="left">
			<table id="CCTCUENT">
				<field id="siscod" oculto="true">
					<label>cctcuent.siscod</label>
					<condicion operador="=">CCTMOVIM.siscod</condicion>
				</field>
				<field id="ctacod" oculto="true">
					<condicion operador="=">CCTMOVIM.ctacod</condicion>
				</field>
			</table>
		</join>
	</form>
</histrix>
