# RAG Saldivia — Environment Template
# Copy to .env.local and fill in secrets

# === Auth (required) ===
NGC_API_KEY=nvapi-YOUR_KEY_HERE
NVIDIA_API_KEY=nvapi-YOUR_KEY_HERE

# === Workstation profile only ===
# APP_LLM_SERVERURL=https://openrouter.ai/api/v1
# APP_LLM_MODELNAME=your-model-here
# APP_LLM_APIKEY=your-api-key-here

# === Collection name ===
COLLECTION_NAME=tecpia

# === Gateway ===
CORS_ORIGINS=http://localhost:3000
