# RAG Saldivia — Environment Variables
# ──────────────────────────────────────────────────────────────────────────
# Copiá este archivo a .env.local y completá los valores marcados con REQUIRED.
# .env.local está en .gitignore y nunca se commitea.
#
# Formato de anotaciones:
#   [REQUIRED-PROD]  → obligatorio en producción, sin valor por defecto seguro
#   [REQUIRED-DEV]   → obligatorio incluso en desarrollo
#   [OPTIONAL]       → tiene valor por defecto, cambiar según necesidad
#   [DEV-ONLY]       → solo relevante en desarrollo local
# ──────────────────────────────────────────────────────────────────────────


# ── Autenticación JWT ──────────────────────────────────────────────────────
# Clave secreta para firmar tokens JWT. Usá un string aleatorio largo.
# Generar: openssl rand -base64 32
# [REQUIRED-PROD]
JWT_SECRET=CHANGE_ME_use_openssl_rand_base64_32

# Tiempo de vida de los tokens JWT (formato: Nh=horas, Nm=minutos, Nd=días)
# [OPTIONAL] default: 24h
JWT_EXPIRY=24h

# Clave interna para autenticación service-to-service (CLI → servidor, etc.)
# Generar: openssl rand -hex 32
# [REQUIRED-PROD]
SYSTEM_API_KEY=CHANGE_ME_use_openssl_rand_hex_32


# ── Base de datos ──────────────────────────────────────────────────────────
# Ruta al archivo SQLite de la aplicación.
# En Docker: usar una ruta dentro del volumen montado.
# [OPTIONAL] default: ./data/app.db
DATABASE_PATH=./data/app.db


# ── Servidor Next.js ───────────────────────────────────────────────────────
# Puerto donde escucha el servidor web.
# [OPTIONAL] default: 3000
PORT=3000

# Entorno de ejecución (development | production | test)
# [OPTIONAL] default: development
NODE_ENV=development

# Nivel de log: TRACE | DEBUG | INFO | WARN | ERROR | FATAL
# En producción usar INFO o WARN para no saturar los logs.
# [OPTIONAL] default: INFO
LOG_LEVEL=INFO

# Días de retención de eventos en la tabla events.
# Eventos más viejos que este valor se eliminan diariamente en el worker de ingesta.
# [OPTIONAL] default: 90
LOG_RETENTION_DAYS=90


# ── RAG Server (NVIDIA Blueprint) ─────────────────────────────────────────
# URL del servidor RAG de NVIDIA (puerto 8081 en deploy estándar).
# [OPTIONAL] default: http://localhost:8081
RAG_SERVER_URL=http://localhost:8081

# Timeout para requests al RAG Server, en milisegundos.
# [OPTIONAL] default: 120000 (2 minutos)
RAG_TIMEOUT_MS=120000

# Modo mock: si es "true", el servidor simula respuestas del RAG sin Docker.
# Útil para desarrollo de UI sin el stack de NVIDIA levantado.
# [DEV-ONLY] default: false
MOCK_RAG=false


# ── CORS ───────────────────────────────────────────────────────────────────
# Orígenes permitidos para CORS. En producción, limitá a tu dominio exacto.
# Separar múltiples orígenes con coma: https://app.tudominio.com,https://admin.tudominio.com
# [OPTIONAL] default: http://localhost:3000
CORS_ORIGINS=http://localhost:3000


# ── NVIDIA API Keys ────────────────────────────────────────────────────────
# API key de NVIDIA NGC. Requerida para descargar imágenes Docker del blueprint
# y para usar modelos vía NVIDIA API (llama, embeddings, etc.)
# Obtener en: https://org.ngc.nvidia.com/setup/api-keys
# [REQUIRED-PROD]
NGC_API_KEY=nvapi-YOUR_KEY_HERE

# Alias de NGC_API_KEY, usado por algunos servicios del blueprint.
# Debe tener el mismo valor que NGC_API_KEY.
# [REQUIRED-PROD]
NVIDIA_API_KEY=nvapi-YOUR_KEY_HERE


# ── Colección por defecto ──────────────────────────────────────────────────
# Nombre de la colección de documentos usada por defecto en el RAG.
# [OPTIONAL] default: tecpia
COLLECTION_NAME=tecpia


# ── OpenRouter (opcional, perfil workstation) ──────────────────────────────
# Solo necesario si usás el perfil workstation-1gpu con crossdoc via OpenRouter.
# [OPTIONAL]
# APP_LLM_SERVERURL=https://openrouter.ai/api/v1
# APP_LLM_MODELNAME=anthropic/claude-sonnet-4
# APP_LLM_APIKEY=sk-or-YOUR_KEY_HERE

# SSO — Google (F3.47)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=same-as-google-client-id

# SSO — Azure AD / Microsoft Entra ID (F3.47)
# AZURE_AD_CLIENT_ID=your-azure-client-id
# AZURE_AD_CLIENT_SECRET=your-azure-client-secret
# AZURE_AD_TENANT_ID=common
# NEXT_PUBLIC_AZURE_AD_CLIENT_ID=same-as-azure-client-id

# NextAuth (F3.47)
# NEXTAUTH_SECRET=$(openssl rand -base64 32)
# NEXTAUTH_URL=http://localhost:3000
