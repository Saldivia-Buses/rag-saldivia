# SDA Framework — Environment Variables
# ──────────────────────────────────────────────────────────────────────────
# Copy to .env.local and fill in values marked REQUIRED.
# .env.local is gitignored and never committed.
#
# Annotations:
#   [REQUIRED]  → must be set before running
#   [OPTIONAL]  → has sensible default
#   [DEV-ONLY]  → only relevant in local development
# ──────────────────────────────────────────────────────────────────────────


# ── JWT (Ed25519 asymmetric) ─────────────────────────────────────────────
# Generate: bash deploy/scripts/gen-jwt-keys.sh
# [REQUIRED] Auth service needs both. All other services need only PUBLIC.
JWT_PRIVATE_KEY=<base64-encoded-ed25519-private-key-pem>
JWT_PUBLIC_KEY=<base64-encoded-ed25519-public-key-pem>

# [OPTIONAL] Token expiry (default: 15m access, 7d refresh)
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# [REQUIRED] Internal key for service-to-service auth. Generate: openssl rand -hex 32
SYSTEM_API_KEY=CHANGE_ME_use_openssl_rand_hex_32


# ── PostgreSQL ───────────────────────────────────────────────────────────
# [REQUIRED] Platform database connection
POSTGRES_PLATFORM_URL=postgres://sda:sda_dev@localhost:5432/sda_platform

# [REQUIRED] Dev tenant database connection
POSTGRES_TENANT_URL=postgres://sda:sda_dev@localhost:5432/sda_tenant_dev

# [OPTIONAL] PostgreSQL credentials (used by docker-compose)
POSTGRES_USER=sda
POSTGRES_PASSWORD=sda_dev


# ── Redis ────────────────────────────────────────────────────────────────
# [REQUIRED] Platform Redis
REDIS_PLATFORM_URL=redis://localhost:6379/0

# [REQUIRED] Dev tenant Redis (DB 1 on same instance in dev)
REDIS_TENANT_URL=redis://localhost:6379/1


# ── NATS ─────────────────────────────────────────────────────────────────
# [REQUIRED] NATS server with JetStream
NATS_URL=nats://localhost:4222


# ── NVIDIA RAG Blueprint ─────────────────────────────────────────────────
# [OPTIONAL] RAG server endpoint (NVIDIA Blueprint)
RAG_SERVER_URL=http://localhost:8081

# [OPTIONAL] Timeout for RAG requests in milliseconds
RAG_TIMEOUT_MS=120000

# [DEV-ONLY] Simulate RAG without Docker/GPU
MOCK_RAG=true

# [OPTIONAL] NGC API key for pulling NVIDIA images
NGC_API_KEY=nvapi-YOUR_KEY_HERE

# [OPTIONAL] NVIDIA API key for hosted inference
NVIDIA_API_KEY=nvapi-YOUR_KEY_HERE


# ── Services (ports) ─────────────────────────────────────────────────────
# [OPTIONAL] Ports for Go services running on host
AUTH_PORT=8001
WS_PORT=8002
CHAT_PORT=8003
RAG_PORT=8004
NOTIFICATION_PORT=8005
PLATFORM_PORT=8006
INGEST_PORT=8007


# ── Email (dev) ──────────────────────────────────────────────────────────
# [DEV-ONLY] Mailpit SMTP for dev (catches all emails)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@sda.local


# ── Observability ────────────────────────────────────────────────────────
# [OPTIONAL] Log level for all services
LOG_LEVEL=INFO

# [OPTIONAL] OpenTelemetry collector endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317


# ── External APIs (optional) ─────────────────────────────────────────────
# [OPTIONAL] OpenRouter for mock mode with real LLM
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-haiku-4-5
