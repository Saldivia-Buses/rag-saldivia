{
  "workspaces": {
    "apps/web": {
      "entry": [
        "src/app/**/{page,layout,route}.ts{x,}",
        "src/workers/*.ts"
      ]
    },
    "apps/cli": {
      "entry": ["src/commands/*.ts"]
    }
  },
  "ignore": [
    "**/__tests__/**",
    "**/*.test.*",
    "apps/web/src/lib/test-setup.ts",
    "apps/web/src/lib/component-test-setup.ts",
    "apps/web/stories/**",
    "apps/web/.storybook/**",
    "apps/web/tests/**",
    "apps/web/src/components/ui/data-table.tsx",
    "apps/web/src/components/error-boundary.tsx"
  ],
  "ignoreDependencies": [
    "@radix-ui/react-checkbox",
    "@radix-ui/react-label",
    "@radix-ui/react-scroll-area",
    "@radix-ui/react-select",
    "@radix-ui/react-switch",
    "@happy-dom/global-registrator",
    "@testing-library/react",
    "@testing-library/user-event",
    "happy-dom",
    "@vitejs/plugin-react",
    "@tanstack/react-table"
  ],
  "ignoreIssues": {
    "apps/web/src/components/ui/**": ["exports", "types"],
    "apps/web/src/lib/auth/rbac.ts": ["exports", "types"],
    "apps/web/src/lib/queue.ts": ["exports", "types"],
    "apps/web/src/lib/changelog.ts": ["exports", "types"],
    "apps/web/src/lib/rag/client.ts": ["exports", "types"],
    "apps/web/src/app/actions/chat.ts": ["exports"],
    "apps/web/src/app/actions/users.ts": ["exports"],
    "packages/logger/src/levels.ts": ["exports", "types"],
    "apps/cli/src/output.ts": ["exports", "types"]
  }
}
